<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="KOAFiloServis.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:KOAFiloServis.Maui.Pages"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#1e3c72"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White">

    <TabBar>
        <ShellContent Title="Ana Sayfa"
                      ContentTemplate="{DataTemplate pages:DashboardPage}" />
        <ShellContent Title="Güzergah"
                      ContentTemplate="{DataTemplate pages:GuzergahPage}" />
    </TabBar>
</Shell>
