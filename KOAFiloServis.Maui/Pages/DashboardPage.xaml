<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KOAFiloServis.Maui.Pages.DashboardPage"
             Title="Ana Sayfa"
             BackgroundColor="#f0f4f8">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <!-- Hoşgeldin -->
            <Frame BackgroundColor="#1e3c72" CornerRadius="12" Padding="20"
                   BorderColor="Transparent" HasShadow="True">
                <VerticalStackLayout Spacing="5">
                    <Label x:Name="HosgeldinLabel"
                           Text="Hoşgeldiniz"
                           FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label x:Name="TarihLabel"
                           Text=""
                           FontSize="14" TextColor="#a8c8ff" />
                </VerticalStackLayout>
            </Frame>

            <!-- Hızlı Erişim Kartları -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12">

                <!-- Puantaj Girişi -->
                <Frame Grid.Row="0" Grid.Column="0"
                       BackgroundColor="#4CAF50" CornerRadius="12"
                       Padding="15" BorderColor="Transparent" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPuantajTapped" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="📋" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Puantaj" FontSize="14" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label Text="Günlük Giriş" FontSize="11"
                               TextColor="#c8e6c9" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Güzergahlarım -->
                <Frame Grid.Row="0" Grid.Column="1"
                       BackgroundColor="#2196F3" CornerRadius="12"
                       Padding="15" BorderColor="Transparent" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGuzergahTapped" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="🛣️" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Güzergah" FontSize="14" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label Text="Rotalarım" FontSize="11"
                               TextColor="#bbdefb" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Araç Bilgisi -->
                <Frame Grid.Row="1" Grid.Column="0"
                       BackgroundColor="#FF9800" CornerRadius="12"
                       Padding="15" BorderColor="Transparent" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAracTapped" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="🚐" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Aracım" FontSize="14" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label Text="Araç Bilgisi" FontSize="11"
                               TextColor="#ffe0b2" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Bildirimler -->
                <Frame Grid.Row="1" Grid.Column="1"
                       BackgroundColor="#9C27B0" CornerRadius="12"
                       Padding="15" BorderColor="Transparent" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBildirimTapped" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="🔔" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Uyarılar" FontSize="14" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label x:Name="UyariSayisiLabel" Text="0 yeni"
                               FontSize="11" TextColor="#e1bee7"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Bugünün Puantaj Özeti -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="15"
                   BorderColor="#e0e0e0" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📊 Bugünün Özeti" FontSize="16"
                           FontAttributes="Bold" TextColor="#333" />
                    <BoxView HeightRequest="1" Color="#eee" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="8" ColumnSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Sefer Sayısı:"
                               FontSize="13" TextColor="#666" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="SeferSayisiLabel"
                               Text="—" FontSize="13" FontAttributes="Bold"
                               TextColor="#333" HorizontalTextAlignment="End" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Rota:"
                               FontSize="13" TextColor="#666" />
                        <Label Grid.Row="1" Grid.Column="1" x:Name="RotaLabel"
                               Text="—" FontSize="13" TextColor="#333"
                               HorizontalTextAlignment="End" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Plaka:"
                               FontSize="13" TextColor="#666" />
                        <Label Grid.Row="2" Grid.Column="1" x:Name="PlakaLabel"
                               Text="—" FontSize="13" FontAttributes="Bold"
                               TextColor="#1e3c72" HorizontalTextAlignment="End" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
