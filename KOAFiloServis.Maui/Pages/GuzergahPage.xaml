<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KOAFiloServis.Maui.Pages.GuzergahPage"
             Title="Güzergahlarım"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="Auto,*" Padding="15" RowSpacing="15">

        <!-- Başlık ve Ay Seçici -->
        <HorizontalStackLayout Grid.Row="0" Spacing="10"
                                HorizontalOptions="Center">
            <Button Text="◀" BackgroundColor="Transparent" TextColor="#1e3c72"
                    FontSize="18" Clicked="OnOncekiAy" />
            <Label x:Name="AyLabel" Text="Haziran 2026"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="#1e3c72" VerticalOptions="Center" />
            <Button Text="▶" BackgroundColor="Transparent" TextColor="#1e3c72"
                    FontSize="18" Clicked="OnSonrakiAy" />
        </HorizontalStackLayout>

        <!-- Güzergah Listesi -->
        <CollectionView Grid.Row="1" x:Name="GuzergahListesi"
                         SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center" Spacing="10">
                    <Label Text="📭" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Bu ay için güzergah ataması bulunamadı."
                           FontSize="14" TextColor="#999"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" CornerRadius="10"
                           BackgroundColor="White" BorderColor="#e0e0e0"
                           HasShadow="False">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="5">
                            <!-- Güzergah Adı -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding GuzergahAdi}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#333" />
                            <!-- Durum Badge -->
                            <Frame Grid.Row="0" Grid.Column="1"
                                   BackgroundColor="#4CAF50" CornerRadius="10"
                                   Padding="8,2" HasShadow="False"
                                   BorderColor="Transparent">
                                <Label Text="{Binding Durum}"
                                       FontSize="11" TextColor="White" />
                            </Frame>

                            <!-- Detaylar -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0"
                                                    Grid.ColumnSpan="2" Spacing="15">
                                <Label FontSize="13" TextColor="#666">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🚐 " />
                                            <Span Text="{Binding Plaka}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label FontSize="13" TextColor="#666">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🕐 " />
                                            <Span Text="{Binding Slot}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label FontSize="13" TextColor="#666">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🔁 " />
                                            <Span Text="{Binding SeferSayisi, StringFormat='{0} sefer'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <!-- Tarih -->
                            <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding Tarih, StringFormat='{0:dd MMMM yyyy}'}"
                                   FontSize="11" TextColor="#999" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
