<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KOAFiloServis.Maui.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1e3c72">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30"
                             VerticalOptions="Center"
                             MaximumWidthRequest="400">

            <!-- Logo / Başlık -->
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="KOA"
                       FontSize="48" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center" />
                <Label Text="Filo Servis"
                       FontSize="24"
                       TextColor="#a8c8ff" HorizontalOptions="Center" />
                <Label Text="Şoför Uygulaması"
                       FontSize="14"
                       TextColor="#7fa3d9" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="#3a5a8c" Margin="0,10" />

            <!-- Kullanıcı Adı -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Kullanıcı Adı" TextColor="White" FontSize="14" />
                <Entry x:Name="KullaniciAdiEntry"
                       Placeholder="kullanici adiniz"
                       PlaceholderColor="#8899bb"
                       TextColor="White"
                       BackgroundColor="#2a4a7a"
                       FontSize="16" />
            </VerticalStackLayout>

            <!-- Şifre -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Şifre" TextColor="White" FontSize="14" />
                <Entry x:Name="SifreEntry"
                       Placeholder="••••••••"
                       PlaceholderColor="#8899bb"
                       IsPassword="True"
                       TextColor="White"
                       BackgroundColor="#2a4a7a"
                       FontSize="16" />
            </VerticalStackLayout>

            <!-- Giriş Butonu -->
            <Button x:Name="GirisBtn"
                    Text="GİRİŞ YAP"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="50"
                    CornerRadius="8"
                    Clicked="OnGirisClicked" />

            <!-- Hata Mesajı -->
            <Label x:Name="HataLabel"
                   TextColor="#ff6b6b"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False" />

            <!-- Loading -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="White"
                               HorizontalOptions="Center" />

            <!-- Alt Bilgi -->
            <Label Text="Karamur Yazılım © 2026"
                   TextColor="#667799"
                   FontSize="11"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
