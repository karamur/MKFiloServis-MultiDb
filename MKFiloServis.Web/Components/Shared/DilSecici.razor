@inject MKFiloServis.Web.Services.Interfaces.ILokalizasyonService Lokalizasyon
@inject IJSRuntime JS

<div class="dropdown d-inline-block">
    <button class="btn btn-sm btn-outline-secondary border dropdown-toggle"
            type="button" data-bs-toggle="dropdown" title="Dil / Language">
        <i class="bi bi-translate me-1"></i>
        <span class="d-none d-md-inline">@AktifDilAdi</span>
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
        @foreach (var dil in Lokalizasyon.DesteklenenDiller)
        {
            <li>
                <button class="dropdown-item @(dil.Kod == Lokalizasyon.AktifDil ? "active" : "")"
                        @onclick="() => DilSec(dil.Kod)">
                    @DilBayrak(dil.Kod) @dil.Ad
                </button>
            </li>
        }
    </ul>
</div>

@code {
    private string AktifDilAdi => Lokalizasyon.DesteklenenDiller
        .FirstOrDefault(d => d.Kod == Lokalizasyon.AktifDil).Ad ?? Lokalizasyon.AktifDil.ToUpper();

    private static string DilBayrak(string kod) => kod switch
    {
        "tr" => "🇹🇷",
        "en" => "🇬🇧",
        _ => "🌐"
    };

    private async Task DilSec(string kod)
    {
        await Lokalizasyon.DilDegistirAsync(kod);
        await JS.InvokeVoidAsync("localStorage.setItem", "crm-lang", kod);
        StateHasChanged();
    }
}

