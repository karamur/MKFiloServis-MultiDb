@using MKFiloServis.Web.Services
@using MKFiloServis.Shared.Entities
@using Microsoft.Extensions.Logging
@inject IKullaniciService KullaniciService
@inject AppAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<YetkiKontrol> Logger

@* 
    Sayfa seviyesinde yetki kontrolü bileşeni.
    Kullanım:
    <YetkiKontrol Yetki="kullaniciyonetim.oku">
        <Yetkili>
            ... sayfa içeriği ...
        </Yetkili>
        <Yetkisiz>
            ... yetkisiz mesajı (opsiyonel, varsayılan mesaj gösterilir) ...
        </Yetkisiz>
    </YetkiKontrol>
    
    veya sadece yetki kontrolü:
    <YetkiKontrol Yetki="kullaniciyonetim.oku">
        <Yetkili>
            ... sayfa içeriği ...
        </Yetkili>
    </YetkiKontrol>
    
    Birden fazla yetki kontrolü (OR mantığı):
    <YetkiKontrol Yetkiler="new[] { "kullaniciyonetim.oku", "rolyonetim.oku" }">
*@

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yetki kontrol ediliyor...</span>
        </div>
    </div>
}
else if (yetkiVar)
{
    @Yetkili
}
else
{
    @if (Yetkisiz != null)
    {
        @Yetkisiz
    }
    else
    {
        <!-- Varsayilan yetkisiz mesaji -->
        <div class="container-fluid">
            <div class="row justify-content-center mt-5">
                <div class="col-md-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-body text-center p-5">
                            <i class="bi bi-shield-lock text-warning" style="font-size: 4rem;"></i>
                            <h3 class="mt-3 mb-2">Erişim Reddedildi</h3>
                            <p class="text-muted mb-4">
                                Bu sayfayı görüntülemek için gerekli yetkiniz bulunmuyor.
                                @if (!string.IsNullOrEmpty(GerekliYetkiAdi))
                                {
                                    <br /><small class="text-secondary">Gerekli yetki: @GerekliYetkiAdi</small>
                                }
                            </p>
                            <div class="d-flex justify-content-center gap-2 flex-wrap">
                                <button class="btn btn-outline-secondary" @onclick="GeriDon">
                                    <i class="bi bi-arrow-left me-1"></i>Geri Dön
                                </button>
                                <a href="/dashboard" class="btn btn-primary">
                                    <i class="bi bi-house-door me-1"></i>Dashboard
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    /// <summary>
    /// Tek bir yetki kodu kontrolü için
    /// </summary>
    [Parameter]
    public string? Yetki { get; set; }

    /// <summary>
    /// Birden fazla yetki kontrolü için (OR mantığı - herhangi biri varsa yetkili)
    /// </summary>
    [Parameter]
    public string[]? Yetkiler { get; set; }

    /// <summary>
    /// Rol kontrolü için (Admin, Muhasebeci, Operasyon vs.)
    /// </summary>
    [Parameter]
    public string? Rol { get; set; }

    /// <summary>
    /// Birden fazla rol kontrolü (OR mantığı)
    /// </summary>
    [Parameter]
    public string[]? Roller { get; set; }

    /// <summary>
    /// Yetkisi varsa gösterilecek içerik
    /// </summary>
    [Parameter]
    public RenderFragment? Yetkili { get; set; }

    /// <summary>
    /// Yetkisi yoksa gösterilecek içerik (opsiyonel)
    /// </summary>
    [Parameter]
    public RenderFragment? Yetkisiz { get; set; }

    /// <summary>
    /// Yetkisiz kullanıcıyı Dashboard'a yönlendir (varsayılan: false)
    /// </summary>
    [Parameter]
    public bool YetkisizYonlendir { get; set; } = false;

    /// <summary>
    /// Yetkisiz durumunda mesaj olarak gösterilecek yetki adı
    /// </summary>
    [Parameter]
    public string? GerekliYetkiAdi { get; set; }

    private bool isLoading = true;
    private bool yetkiVar = false;

    protected override async Task OnInitializedAsync()
    {
        await YetkiKontrolEt();
    }

    private async Task YetkiKontrolEt()
    {
        try
        {
            var aktifKullanici = AuthProvider.GetAktifKullanici();
            
            if (aktifKullanici == null)
            {
                yetkiVar = false;
                isLoading = false;
                
                if (YetkisizYonlendir)
                {
                    Navigation.NavigateTo("/login");
                }
                return;
            }

            // Admin her şeye yetkili
            if (aktifKullanici.Rol?.RolAdi == SistemRolleri.Admin)
            {
                yetkiVar = true;
                isLoading = false;
                return;
            }

            // Rol kontrolü
            if (!string.IsNullOrEmpty(Rol))
            {
                yetkiVar = aktifKullanici.Rol?.RolAdi == Rol;
                isLoading = false;
                
                if (!yetkiVar && YetkisizYonlendir)
                {
                    Navigation.NavigateTo("/dashboard");
                }
                return;
            }

            if (Roller != null && Roller.Length > 0)
            {
                yetkiVar = Roller.Any(r => aktifKullanici.Rol?.RolAdi == r);
                isLoading = false;
                
                if (!yetkiVar && YetkisizYonlendir)
                {
                    Navigation.NavigateTo("/dashboard");
                }
                return;
            }

            // Yetki kodu kontrolü
            var kullaniciYetkileri = await KullaniciService.GetKullaniciYetkileriAsync(aktifKullanici.Id);
            var yetkiSet = kullaniciYetkileri.ToHashSet();

            if (!string.IsNullOrEmpty(Yetki))
            {
                yetkiVar = yetkiSet.Contains(Yetki);
            }
            else if (Yetkiler != null && Yetkiler.Length > 0)
            {
                yetkiVar = Yetkiler.Any(y => yetkiSet.Contains(y));
            }
            else
            {
                // Yetki belirtilmediyse varsayılan olarak yetkili kabul et
                yetkiVar = true;
            }

            if (!yetkiVar && YetkisizYonlendir)
            {
                Navigation.NavigateTo("/dashboard");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "YetkiKontrol yetki kontrolu sirasinda hata olustu (Yetki={Yetki}, Rol={Rol})", Yetki, Rol);
            yetkiVar = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GeriDon()
    {
        try
        {
            await JS.InvokeVoidAsync("history.back");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "YetkiKontrol GeriDon sirasinda hata olustu, dashboard'a yonlendiriliyor");
            Navigation.NavigateTo("/dashboard");
        }
    }
}

