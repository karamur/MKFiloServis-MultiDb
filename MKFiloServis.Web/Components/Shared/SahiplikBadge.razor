@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Helpers

@if (Tip.HasValue)
{
    <span class="badge @SahiplikHelper.GetBadgeClass(Tip.Value) @CssClass" title="@SahiplikHelper.GetAciklama(Tip.Value)">
        @if (ShowIcon)
        {
            <i class="bi @SahiplikHelper.GetIcon(Tip.Value) me-1"></i>
        }
        @SahiplikHelper.GetMetin(Tip.Value)
    </span>
}
else if (Kalem.HasValue)
{
    <span class="badge @SahiplikHelper.GetBadgeClass(Kalem.Value) @CssClass">
        @if (ShowIcon)
        {
            <i class="bi @SahiplikHelper.GetIcon(Kalem.Value) me-1"></i>
        }
        @SahiplikHelper.GetMetin(Kalem.Value)
    </span>
}

@code {
    /// <summary>
    /// Araç sahiplik tipi (5 değerli enum: Özmal, Kiralık, Komisyon, Diğer, Tedarikçi)
    /// </summary>
    [Parameter] public AracSahiplikTipi? Tip { get; set; }

    /// <summary>
    /// İhale sahiplik kalemi (3 değerli enum: Özmal, Kiralık, Komisyon)
    /// </summary>
    [Parameter] public AracSahiplikKalem? Kalem { get; set; }

    /// <summary>
    /// Rozet üzerinde ikon göster
    /// </summary>
    [Parameter] public bool ShowIcon { get; set; } = false;

    /// <summary>
    /// Ek CSS sınıfları
    /// </summary>
    [Parameter] public string CssClass { get; set; } = string.Empty;
}

