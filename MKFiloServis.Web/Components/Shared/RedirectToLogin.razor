@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var hedefUrl = string.IsNullOrWhiteSpace(relativePath)
            ? "/login"
            : $"/login?returnUrl={Uri.EscapeDataString('/' + relativePath)}";

        // forceLoad: false - circuit koruyarak yonlendir (auth state korunur)
        Navigation.NavigateTo(hedefUrl, forceLoad: false);
    }
}
