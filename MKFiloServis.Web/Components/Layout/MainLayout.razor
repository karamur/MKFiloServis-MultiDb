@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Logging
@using MKFiloServis.Shared
@using MKFiloServis.Web.Services.Interfaces
@inject MKFiloServis.Web.Services.Interfaces.IKullaniciService KullaniciService
@inject MKFiloServis.Web.Services.LicenseService LicenseSvc
@inject MKFiloServis.Web.Services.Interfaces.IFirmaService FirmaService
@inject MKFiloServis.Web.Services.IAktifFirmaProvider AktifFirmaProvider
@inject MKFiloServis.Web.Services.AppAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger

<AuthorizeView>
    <Authorized>
        @if (!isInitialized)
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Yukleniyor...</span>
                </div>
            </div>
        }
        else
        {
            @* 🔶 DEMO MODE BANNER — Satış odaklı, korkutmaz *@
            @if (AppMode.IsDemoMode && !LicenseSvc.HasValidLicense())
            {
                <div style="background: linear-gradient(90deg, #fef3c7, #fde68a); color: #92400e; padding: 10px 16px; text-align: center; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; gap: 12px; border-bottom: 2px solid #f59e0b;">
                    <i class="bi bi-info-circle"></i>
                    <span>
                        <strong>Demo Mod</strong> — @(string.IsNullOrEmpty(lisansHataMesaji) ? "Deneme süreniz sona erdi." : lisansHataMesaji)
                        Sistemi kullanmaya devam etmek için lisans yükleyebilirsiniz.
                    </span>
                    <a href="/admin/license" class="btn btn-warning btn-sm" style="white-space: nowrap;">
                        <i class="bi bi-key me-1"></i>Lisans Yükle
                    </a>
                </div>
            }

            <div class="page">
                <div class="sidebar">
                    <NavMenu />
                </div>

                <main>
                    <div class="top-row px-4 d-flex justify-content-between align-items-center bg-white border-bottom">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center text-muted">
                                <i class="bi bi-person-circle me-2 fs-5"></i>
                                <div>
                                    <div class="fw-bold">@aktifKullanici?.AdSoyad</div>
                                    <small class="text-muted">@aktifKullanici?.Rol?.RolAdi</small>
                                </div>
                            </div>
                            @if (!tumFirmalarMod && !string.IsNullOrEmpty(aktifFirmaKodu))
                            {
                                <div class="vr d-none d-md-block"></div>
                                <div class="d-none d-md-block">
                                    <div class="fw-bold small">@aktifFirmaAdi</div>
                                    <small class="text-muted">@aktifFirmaKodu</small>
                                </div>
                                <div class="vr d-none d-md-block"></div>
                                <div class="d-none d-md-block text-muted small">
                                    <i class="bi bi-calendar-month me-1"></i>Dönem: @aktifDonemAy.ToString("D2")/@aktifDonemYil
                                </div>
                            }
                            <div class="vr d-none d-md-block"></div>
                            <div class="text-muted d-none d-md-block">
                                <i class="bi bi-calendar3 me-2"></i>
                                @DateTime.Now.ToString("dd MMMM yyyy, dddd", TrCulture)
                            </div>
                            @if (kalanLisansGunu <= 30)
                            {
                                <div class="vr d-none d-md-block"></div>
                                <div class="badge bg-warning text-dark">
                                    <i class="bi bi-clock-history me-1"></i>
                                    Lisans: @kalanLisansGunu gun kaldi
                                </div>
                            }
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-outline-info border" title="Puantaj ve Fatura Kılavuzu"
                                    data-bs-toggle="modal" data-bs-target="#yardimKilavuzModal">
                                <i class="bi bi-question-circle"></i>
                            </button>
                            <button class="btn btn-sm @(isDarkMode ? "btn-warning" : "btn-outline-secondary") border"
                                    title="@(isDarkMode ? "Açık Tema" : "Koyu Tema")"
                                    @onclick="ToggleDarkMode">
                                <i class="bi @(isDarkMode ? "bi-sun-fill" : "bi-moon-stars-fill")"></i>
                            </button>
                            <MKFiloServis.Web.Components.Shared.DilSecici />
                            <MKFiloServis.Web.Components.Shared.FavorilerDropdown />
                            <MKFiloServis.Web.Components.Shared.OpenInNewTab />
                            <MKFiloServis.Web.Components.Shared.OperasyonAlarmDropdown />
                            <MKFiloServis.Web.Components.Shared.BildirimDropdown />

                            <div class="dropdown">
                                <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-building me-1"></i><span class="d-none d-md-inline">@aktifFirmaAdi</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" style="min-width: 250px;">
                                    @foreach (var firma in firmalar)
                                    {
                                        <li>
                                            <button class="dropdown-item @(firma.Id == aktifFirmaId ? "active" : "")" 
                                                    @onclick="() => FirmaSecildi(firma)">
                                                <i class="bi bi-building me-2"></i>@firma.FirmaAdi
                                                @if (firma.VarsayilanFirma)
                                                {
                                                    <i class="bi bi-star-fill text-warning ms-2"></i>
                                                }
                                            </button>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" href="/firma-sec?returnUrl=%2Fdashboard">
                                            <i class="bi bi-building-check me-2"></i>Firma Değiştir (Tam Ekran)
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-primary" href="/ayarlar/firmalar">
                                            <i class="bi bi-gear me-2"></i>Firma Ayarlari
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <div class="dropdown">
                                <button id="settings-dropdown-button" class="btn btn-light btn-sm dropdown-toggle border" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i><span class="d-none d-md-inline">Ayarlar</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="/ayarlar/profil">
                                            <i class="bi bi-person me-2"></i>Profil Ayarlari
                                        </a>
                                    </li>
                                    <li>
                                        <a id="settings-license-link" class="dropdown-item" href="/ayarlar/lisans">
                                            <i class="bi bi-key me-2"></i>Lisans Bilgileri
                                        </a>
                                    </li>
                                    <li>
                                        <a id="settings-database-link" class="dropdown-item" href="/ayarlar/veritabani">
                                            <i class="bi bi-database me-2"></i>Veritabani Ayarlari
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" href="/ayarlar/firma-kopyalama">
                                            <i class="bi bi-arrow-left-right me-2"></i>Şirketler Arası Kopyalama
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <button id="logout-button" type="button" class="btn btn-danger btn-sm" @onclick="CikisYapAsync" title="Cikis Yap">
                                <i class="bi bi-box-arrow-right me-1"></i><span class="d-none d-md-inline">Cikis</span>
                            </button>
                        </div>
                    </div>

                    <article class="content px-4">
                        @Body
                    </article>
                </main>
            </div>

            <!-- Yardım Kılavuzu Modal -->
            <div class="modal fade" id="yardimKilavuzModal" tabindex="-1" aria-labelledby="yardimKilavuzModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header bg-info bg-opacity-25">
                            <h5 class="modal-title" id="yardimKilavuzModalLabel"><i class="bi bi-journal-text me-2"></i>Puantaj ve Faturalama Kılavuzu</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <iframe src="/docs/puantaj-ve-fatura-kilavuzu.md" style="width: 100%; height: 60vh; border: none;"></iframe>
                            <div class="alert alert-light mt-3">
                                <strong>1.</strong> Önce `Puantaj Kalıcı Eşleştirme` menüsünden şablonlarınızı oluşturun.<br />
                                <strong>2.</strong> Günlük olarak `Filo Puantaj` sayfasından seferleri işleyin.<br />
                                <strong>3.</strong> Dönem sonunda `Puantaj-Fatura Mutabakat` sayfasında sağlama yapın.<br />
                                <strong>4.</strong> Mutabakatlara dayanarak Faturalarınızı (Gelir/Gider) oluşturun.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <MKFiloServis.Web.Components.Shared.ToastContainer />
            
            <MKFiloServis.Web.Components.Shared.KlavyeKisayollari />
        }
    </Authorized>
    <NotAuthorized>
        @if (!_authChecked)
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh; background:#f8f9fa;">
                <div class="card shadow-sm border-0" style="max-width: 520px; width: 100%;">
                    <div class="card-body text-center p-5">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <h5 class="mb-2">Giriş ekranına yönlendiriliyorsunuz...</h5>
                        <p class="text-muted small mb-3">Otomatik yönlendirme gerçekleşmezse aşağıdaki bağlantıyı kullanın.</p>
                        <a href="/login" class="btn btn-primary btn-sm">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Giriş Ekranı
                        </a>
                    </div>
                </div>
            </div>
        }
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private static readonly System.Globalization.CultureInfo TrCulture = new("tr-TR");

    private MKFiloServis.Shared.Entities.Kullanici? aktifKullanici;
    private bool isInitialized = false;
    private string lisansHataMesaji = "";
    private string makineKodu = "";
    private int kalanLisansGunu = 0;
    private bool _authChecked = false;

    private List<MKFiloServis.Shared.Entities.Firma> firmalar = new();
    private int aktifFirmaId;
    private string aktifFirmaAdi = "Firma";
    private string aktifFirmaKodu = "";
    private int aktifDonemYil = DateTime.Today.Year;
    private int aktifDonemAy = DateTime.Today.Month;
    private bool tumFirmalarMod = false;
    private bool isDarkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var theme = await JS.InvokeAsync<string>("darkMode.init");
                isDarkMode = theme == "dark";
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "MainLayout dark mode baslatilirken hata olustu");
            }

            // Aktif firmayı ProtectedLocalStorage'dan geri yükle (circuit reset / refresh sonrası).
            // Bu çağrı interaktif circuit'te yapılmalı; OnInitializedAsync prerender olabileceği için
            // burada yapıyoruz.
            var firmaRestored = false;
            try
            {
                firmaRestored = await AktifFirmaProvider.TryRestoreAsync();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "MainLayout aktif firma restore sirasinda hata olustu");
            }

            // Circuit yeniden bağlandığında storage'dan kullanıcıyı geri yükle
            if (!AuthProvider.IsAuthenticated)
            {
                var restored = await AuthProvider.TryRestoreFromStorageAsync();
                if (restored)
                {
                    aktifKullanici = AuthProvider.GetAktifKullanici();
                    try { await LisansKontrol(); }
                    catch (Exception ex) { Logger.LogWarning(ex, "MainLayout lisans kontrolu sirasinda hata olustu (restore)"); }
                    try { await FirmalariYukle(); }
                    catch (Exception ex) { Logger.LogWarning(ex, "MainLayout firmalar yuklenirken hata olustu (restore)"); }
                }
                else
                {
                    // Restore başarısız: kullanıcıyı doğrudan login'e yönlendir
                    var currentUri = Navigation.Uri;
                    if (!currentUri.Contains("/login", StringComparison.OrdinalIgnoreCase))
                    {
                        var relativePath = Navigation.ToBaseRelativePath(currentUri);
                        var hedef = string.IsNullOrWhiteSpace(relativePath)
                            ? "/login"
                            : $"/login?returnUrl={Uri.EscapeDataString('/' + relativePath)}";
                        Navigation.NavigateTo(hedef, forceLoad: false);
                        return;
                    }
                }
            }
            else if (firmaRestored)
            {
                // Auth zaten vardı ama firma yeni restore edildi → üst bardaki firma adını tazele.
                try { await FirmalariYukle(); }
                catch (Exception ex) { Logger.LogWarning(ex, "MainLayout firmalar yuklenirken hata olustu (firma restore)"); }
            }

            // Kural 11: Aktif firma zorunludur. Firma seçilmemişse /firma-sec'e yönlendir.
            if (!AktifFirmaProvider.HasAktifFirma)
            {
                var currentRelative = Navigation.ToBaseRelativePath(Navigation.Uri);
                if (!currentRelative.StartsWith("firma-sec", StringComparison.OrdinalIgnoreCase) &&
                    !currentRelative.StartsWith("login", StringComparison.OrdinalIgnoreCase) &&
                    !currentRelative.StartsWith("ayarlar/lisans", StringComparison.OrdinalIgnoreCase))
                {
                    var returnUrl = string.IsNullOrWhiteSpace(currentRelative)
                        ? "/dashboard"
                        : "/" + currentRelative;
                    Navigation.NavigateTo($"/firma-sec?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: false);
                    return;
                }
            }

            _authChecked = true;
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        var theme = isDarkMode ? "dark" : "light";
        await JS.InvokeVoidAsync("darkMode.set", theme);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var currentUri = Navigation.Uri;
            if (currentUri.Contains("/login") || currentUri.Contains("/ayarlar/lisans") || currentUri.Contains("/firma-sec"))
            {
                isInitialized = true;
                return;
            }

            aktifKullanici = AuthProvider.GetAktifKullanici();
            isInitialized = true;

            if (aktifKullanici == null)
            {
                return;
            }

            await LisansKontrol();

            // Demo modda da firmaları yükle — uygulama her zaman açılır
            await FirmalariYukle();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "MainLayout OnInitializedAsync sirasinda hata olustu");
            isInitialized = true;
            aktifKullanici = null;
        }
    }

    private async Task LisansKontrol()
    {
        try
        {
            makineKodu = LicenseService.GetMachineId();
            var lisans = await LicenseSvc.GetCurrentLicenseAsync();

            if (lisans == null)
            {
                // Startup'ta ValidateAsync zaten çalıştı ve cache set edildi (Singleton).
                // Cache boşsa gerçekten lisans yok demektir.
                lisansHataMesaji = "Lisans bulunamadi. Lutfen lisans anahtarinizi girin.";
                return;
            }

            // Negative time kontrolu
            if (lisans != null && DateTime.UtcNow < lisans.CreatedAt)
            {
                lisansHataMesaji = "Sistem saati hatali. Lutfen saat ayarlarinizi kontrol edin.";
                return;
            }

            // Demo suresi kontrolu (CreatedAt + ExpireDate cift validasyon)
            if (lisans != null && LicenseService.IsDemoExpired(lisans))
            {
                var elapsed = (DateTime.UtcNow - lisans.CreatedAt).TotalDays;
                lisansHataMesaji = $"Demo suresi {lisans.ExpireDate:dd.MM.yyyy} tarihinde doldu. ({elapsed:F0} gun)";
                return;
            }

            // Machine lock
            if (lisans != null &&
                !string.IsNullOrEmpty(lisans.MachineId) &&
                !string.Equals(lisans.MachineId, makineKodu, StringComparison.Ordinal))
            {
                lisansHataMesaji = "Bu lisans baska bir bilgisayar icin gecerlidir.";
                return;
            }

            kalanLisansGunu = lisans != null ? LicenseService.GetRemainingDays(lisans) : 0;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "MainLayout lisans kontrolu sirasinda hata olustu");
            lisansHataMesaji = $"Lisans kontrolu sirasinda hata: {ex.Message}";
        }
    }

    private async Task FirmalariYukle()
    {
        try
        {
            firmalar = await FirmaService.GetAktifFirmalarAsync();
            var aktifFirma = FirmaService.GetAktifFirma();
            aktifFirmaId = aktifFirma.FirmaId;
            tumFirmalarMod = aktifFirma.TumFirmalar;
            aktifFirmaAdi = tumFirmalarMod ? "Tüm Firmalar" : aktifFirma.FirmaAdi;
            aktifFirmaKodu = tumFirmalarMod ? "" : aktifFirma.FirmaKodu;
            aktifDonemYil = aktifFirma.AktifDonemYil;
            aktifDonemAy = aktifFirma.AktifDonemAy;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "MainLayout firmalar yuklenirken hata olustu");
        }
    }

    private void FirmaSecildi(MKFiloServis.Shared.Entities.Firma firma)
    {
        FirmaService.SetAktifFirma(firma.Id);
        aktifFirmaId = firma.Id;
        aktifFirmaAdi = firma.FirmaAdi;
        tumFirmalarMod = false;
        Navigation.NavigateTo(Navigation.Uri, true);
    }

    private void TumFirmalarSecildi()
    {
        FirmaService.SetTumFirmalar(true);
        tumFirmalarMod = true;
        aktifFirmaAdi = "Tüm Firmalar";
        Navigation.NavigateTo(Navigation.Uri, true);
    }

    private async Task CikisYapAsync()
    {
        try
        {
            await KullaniciService.CikisYapAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "MainLayout cikis yapilirken hata olustu");
        }
        finally
        {
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    }
}




