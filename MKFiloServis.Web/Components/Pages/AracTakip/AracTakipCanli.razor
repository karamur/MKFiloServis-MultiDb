@page "/arac-takip"
@page "/arac-takip/{AracId:int}"
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Hubs
@using MKFiloServis.Shared.Entities
@inject IAracTakipService AracTakipService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Araç Takip - Canlı Harita</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="bi bi-geo-alt-fill text-primary me-2"></i>Canlı Araç Takip
                </h3>
                <div class="d-flex gap-2 align-items-center">
                    <!-- SignalR Bağlantı Durumu -->
                    <span class="badge @GetBaglantiDurumuBadge() me-2">
                        <i class="bi @GetBaglantiDurumuIcon()"></i> @baglantiDurumu
                    </span>
                    <button class="btn btn-outline-primary" @onclick="YenidenYukle" disabled="@yukleniyor">
                        <i class="bi bi-arrow-clockwise @(yukleniyor ? "spin" : "")"></i> Yenile
                    </button>
                    <div class="form-check form-switch d-flex align-items-center ms-3">
                        <input class="form-check-input" type="checkbox" id="canliTakip" @bind="canliTakipAktif" @bind:after="CanliTakipToggle">
                        <label class="form-check-label ms-2" for="canliTakip">Canlı Takip</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor && !aracKonumlar.Any())
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Araç konumları yükleniyor...</p>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Sol Panel - Araç Listesi -->
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-truck me-2"></i>Araçlar (@aracKonumlar.Count)</span>
                            <span class="badge bg-light text-dark">@aracKonumlar.Count(a => a.Durum == AracTakipDurum.Hareket) hareket</span>
                        </div>
                    </div>
                    <div class="card-body p-0" style="max-height: 70vh; overflow-y: auto;">
                        @if (!aracKonumlar.Any())
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-info-circle fs-1"></i>
                                <p class="mt-2">Takip cihazı tanımlı araç bulunamadı.</p>
                                <a href="/ayarlar/arac-takip-cihaz" class="btn btn-sm btn-primary">
                                    <i class="bi bi-plus-lg"></i> Cihaz Ekle
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var arac in aracKonumlar.OrderByDescending(a => a.Durum == AracTakipDurum.Hareket))
                                {
                                    <button type="button" 
                                            class="list-group-item list-group-item-action @(seciliAracId == arac.AracId ? "active" : "")"
                                            @onclick="() => AracSec(arac)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong class="@(seciliAracId == arac.AracId ? "" : "text-primary")">
                                                    @arac.Plaka
                                                </strong>
                                                <br />
                                                <small class="@(seciliAracId == arac.AracId ? "" : "text-muted")">
                                                    @arac.AracMarka @arac.AracModel
                                                </small>
                                            </div>
                                            <span class="badge @GetDurumBadgeClass(arac.Durum)">
                                                @arac.DurumAciklama
                                            </span>
                                        </div>
                                        @if (arac.Durum != AracTakipDurum.Cevrimdisi)
                                        {
                                            <div class="mt-2 small @(seciliAracId == arac.AracId ? "" : "text-muted")">
                                                <div class="d-flex justify-content-between">
                                                    <span><i class="bi bi-speedometer2"></i> @(arac.Hiz?.ToString("F0") ?? "-") km/s</span>
                                                    @if (arac.YakitSeviyesi.HasValue)
                                                    {
                                                        <span><i class="bi bi-fuel-pump"></i> @arac.YakitSeviyesi%</span>
                                                    }
                                                </div>
                                                <div class="mt-1">
                                                    <i class="bi bi-clock"></i> @arac.KayitZamani.ToString("HH:mm:ss")
                                                </div>
                                            </div>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Özet Kartları -->
                <div class="row g-2 mt-2">
                    <div class="col-6">
                        <div class="card bg-success text-white text-center py-2">
                            <div class="fs-4 fw-bold">@aracKonumlar.Count(a => a.Durum == AracTakipDurum.Hareket)</div>
                            <small>Hareket</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-warning text-dark text-center py-2">
                            <div class="fs-4 fw-bold">@aracKonumlar.Count(a => a.Durum == AracTakipDurum.Bekliyor)</div>
                            <small>Bekliyor</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-secondary text-white text-center py-2">
                            <div class="fs-4 fw-bold">@aracKonumlar.Count(a => a.Durum == AracTakipDurum.Park)</div>
                            <small>Park</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-danger text-white text-center py-2">
                            <div class="fs-4 fw-bold">@aracKonumlar.Count(a => a.Durum == AracTakipDurum.Cevrimdisi)</div>
                            <small>Çevrimdışı</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sağ Panel - Harita -->
            <div class="col-md-9">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <div id="arac-takip-harita" style="height: 75vh; border-radius: 0.375rem;"></div>
                    </div>
                </div>

                <!-- Seçili Araç Detayı -->
                @if (seciliArac != null)
                {
                    <div class="card mt-2 shadow-sm">
                        <div class="card-body py-2">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <strong class="text-primary fs-5">@seciliArac.Plaka</strong>
                                    <span class="badge @GetDurumBadgeClass(seciliArac.Durum) ms-2">@seciliArac.DurumAciklama</span>
                                </div>
                                <div class="col-md-6">
                                    @if (!string.IsNullOrEmpty(seciliArac.Adres))
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-geo-alt"></i> @seciliArac.Adres
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-geo-alt"></i> @seciliArac.Latitude.ToString("F5"), @seciliArac.Longitude.ToString("F5")
                                        </small>
                                    }
                                </div>
                                <div class="col-md-3 text-end">
                                    <a href="/arac-takip/gecmis/@seciliArac.AracId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-clock-history"></i> Geçmiş
                                    </a>
                                    <a href="/araclar/@seciliArac.AracId" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Düzenle
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Alarm Bildirimi Toast -->
@if (okunmamisAlarmSayisi > 0)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show bg-danger text-white" role="alert">
            <div class="toast-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong class="me-auto">Aktif Alarm</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => okunmamisAlarmSayisi = 0"></button>
            </div>
            <div class="toast-body">
                @okunmamisAlarmSayisi adet okunmamış alarm var.
                <a href="/ayarlar/arac-takip-cihaz" class="text-white fw-bold ms-2">Görüntüle</a>
            </div>
        </div>
    </div>
}

<style>
    .spin {
        animation: spin 1s linear infinite;
    }
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>

@code {
    [Parameter]
    public int? AracId { get; set; }

    private List<AracKonumDto> aracKonumlar = new();
    private bool yukleniyor = false;
    private bool canliTakipAktif = true;
    private int? seciliAracId;
    private AracKonumDto? seciliArac;
    private int okunmamisAlarmSayisi = 0;
    private bool haritaHazir = false;
    private DotNetObjectReference<AracTakipCanli>? dotNetRef;
    private string baglantiDurumu = "Bağlanıyor...";
    private bool signalRBagli = false;

    protected override async Task OnInitializedAsync()
    {
        await YenidenYukle();

        if (AracId.HasValue)
        {
            seciliAracId = AracId.Value;
            seciliArac = aracKonumlar.FirstOrDefault(a => a.AracId == AracId.Value);
        }

        okunmamisAlarmSayisi = await AracTakipService.GetOkunmamisAlarmSayisiAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HaritayiBaslat();
            haritaHazir = true;

            // SignalR bağlantısını başlat
            if (canliTakipAktif)
            {
                await SignalRBaglantiBaslat();
            }
        }
    }

    private async Task SignalRBaglantiBaslat()
    {
        try
        {
            baglantiDurumu = "Bağlanıyor...";
            StateHasChanged();

            dotNetRef = DotNetObjectReference.Create(this);
            var basarili = await JSRuntime.InvokeAsync<bool>("signalRHelper.startConnection", dotNetRef);

            if (basarili)
            {
                baglantiDurumu = "Bağlı";
                signalRBagli = true;
            }
            else
            {
                baglantiDurumu = "Bağlantı Hatası";
                signalRBagli = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR bağlantı hatası: {ex.Message}");
            baglantiDurumu = "Hata";
            signalRBagli = false;
        }
        StateHasChanged();
    }

    private async Task SignalRBaglantiyiKapat()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("signalRHelper.stopConnection");
            baglantiDurumu = "Bağlı Değil";
            signalRBagli = false;
        }
        catch { }
        StateHasChanged();
    }

    // SignalR Event Callbacks
    [JSInvokable]
    public void OnSignalRConnected()
    {
        baglantiDurumu = "Bağlı";
        signalRBagli = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnSignalRDisconnected(string? error)
    {
        baglantiDurumu = "Bağlantı Kesildi";
        signalRBagli = false;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnSignalRReconnecting(string? error)
    {
        baglantiDurumu = "Yeniden Bağlanıyor...";
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnSignalRReconnected()
    {
        baglantiDurumu = "Bağlı";
        signalRBagli = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnKonumGuncellendi(AracKonumGuncelleme guncelleme)
    {
        await InvokeAsync(async () =>
        {
            // Mevcut araç listesinde güncelle
            var mevcutArac = aracKonumlar.FirstOrDefault(a => a.AracId == guncelleme.AracId);
            if (mevcutArac != null)
            {
                mevcutArac.Latitude = guncelleme.Enlem;
                mevcutArac.Longitude = guncelleme.Boylam;
                mevcutArac.Hiz = guncelleme.Hiz;
                mevcutArac.Yon = guncelleme.Yon;
                mevcutArac.KontakDurumu = guncelleme.KontakDurumu;
                mevcutArac.MotorDurumu = guncelleme.MotorDurumu;
                mevcutArac.YakitSeviyesi = guncelleme.YakitSeviyesi;
                mevcutArac.KayitZamani = guncelleme.ZamanDamgasi;
                mevcutArac.Adres = guncelleme.Adres;
                mevcutArac.Durum = ParseDurum(guncelleme.Durum);
                mevcutArac.DurumAciklama = guncelleme.Durum;

                // Seçili araçsa güncelle
                if (seciliAracId == guncelleme.AracId)
                {
                    seciliArac = mevcutArac;
                }

                // Haritada güncelle
                if (haritaHazir)
                {
                    await AraclariHaritayaEkle();
                }
            }

            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task OnAracKonumGuncellendi(AracKonumGuncelleme guncelleme)
    {
        await OnKonumGuncellendi(guncelleme);
    }

    [JSInvokable]
    public async Task OnTopluKonumGuncellendi(List<AracKonumGuncelleme> guncellemeler)
    {
        await InvokeAsync(async () =>
        {
            foreach (var guncelleme in guncellemeler)
            {
                var mevcutArac = aracKonumlar.FirstOrDefault(a => a.AracId == guncelleme.AracId);
                if (mevcutArac != null)
                {
                    mevcutArac.Latitude = guncelleme.Enlem;
                    mevcutArac.Longitude = guncelleme.Boylam;
                    mevcutArac.Hiz = guncelleme.Hiz;
                    mevcutArac.Yon = guncelleme.Yon;
                    mevcutArac.KontakDurumu = guncelleme.KontakDurumu;
                    mevcutArac.MotorDurumu = guncelleme.MotorDurumu;
                    mevcutArac.YakitSeviyesi = guncelleme.YakitSeviyesi;
                    mevcutArac.KayitZamani = guncelleme.ZamanDamgasi;
                    mevcutArac.Adres = guncelleme.Adres;
                    mevcutArac.Durum = ParseDurum(guncelleme.Durum);
                    mevcutArac.DurumAciklama = guncelleme.Durum;
                }
            }

            // Seçili aracı güncelle
            if (seciliAracId.HasValue)
            {
                seciliArac = aracKonumlar.FirstOrDefault(a => a.AracId == seciliAracId.Value);
            }

            if (haritaHazir)
            {
                await AraclariHaritayaEkle();
            }

            StateHasChanged();
        });
    }

    [JSInvokable]
    public void OnAlarmOlustu(AlarmBildirimi alarm)
    {
        okunmamisAlarmSayisi++;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnAracAlarmOlustu(AlarmBildirimi alarm)
    {
        OnAlarmOlustu(alarm);
    }

    [JSInvokable]
    public void OnBolgeOlayiOlustu(BolgeOlayi olay)
    {
        // Bölge olayı bildirimi
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnSistemMesaji(object mesaj)
    {
        // Sistem mesajı bildirimi
        InvokeAsync(StateHasChanged);
    }

    private AracTakipDurum ParseDurum(string durum)
    {
        return durum switch
        {
            "Hareket" => AracTakipDurum.Hareket,
            "Bekliyor" => AracTakipDurum.Bekliyor,
            "Park" => AracTakipDurum.Park,
            _ => AracTakipDurum.Cevrimdisi
        };
    }

    private string GetBaglantiDurumuBadge()
    {
        return baglantiDurumu switch
        {
            "Bağlı" => "bg-success",
            "Bağlanıyor..." or "Yeniden Bağlanıyor..." => "bg-warning text-dark",
            _ => "bg-danger"
        };
    }

    private string GetBaglantiDurumuIcon()
    {
        return baglantiDurumu switch
        {
            "Bağlı" => "bi-wifi",
            "Bağlanıyor..." or "Yeniden Bağlanıyor..." => "bi-wifi-1",
            _ => "bi-wifi-off"
        };
    }

    private async Task CanliTakipToggle()
    {
        if (canliTakipAktif)
        {
            await SignalRBaglantiBaslat();
        }
        else
        {
            await SignalRBaglantiyiKapat();
        }
    }

    private async Task HaritayiBaslat()
    {
        try
        {
            // Türkiye merkezli başlat
            await JSRuntime.InvokeVoidAsync("leafletInterop.initMap", "arac-takip-harita", 39.0, 35.0, 6);

            // Mevcut araçları haritaya ekle
            await AraclariHaritayaEkle();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Harita başlatma hatası: {ex.Message}");
        }
    }

    private async Task AraclariHaritayaEkle()
    {
        if (!haritaHazir) return;

        try
        {
            // Mevcut marker'ları temizle
            await JSRuntime.InvokeVoidAsync("leafletInterop.clearMarkers", "arac-takip-harita");

            foreach (var arac in aracKonumlar.Where(a => a.Durum != AracTakipDurum.Cevrimdisi))
            {
                var markerRenk = GetMarkerRenk(arac.Durum);
                var popup = $@"
                    <div style='min-width: 180px;'>
                        <strong style='font-size: 14px;'>{arac.Plaka}</strong><br/>
                        <span style='color: {markerRenk}; font-weight: bold;'>{arac.DurumAciklama}</span><br/>
                        <hr style='margin: 5px 0;'/>
                        <small>
                            <i class='bi bi-speedometer2'></i> Hız: {arac.Hiz?.ToString("F0") ?? "-"} km/s<br/>
                            <i class='bi bi-clock'></i> {arac.KayitZamani:HH:mm:ss}
                        </small>
                    </div>";

                await JSRuntime.InvokeVoidAsync("leafletInterop.addMarker", 
                    "arac-takip-harita", 
                    arac.Latitude, 
                    arac.Longitude, 
                    markerRenk,
                    popup);
            }

            // Seçili araç varsa ona yakınlaş
            if (seciliArac != null && seciliArac.Durum != AracTakipDurum.Cevrimdisi)
            {
                await JSRuntime.InvokeVoidAsync("leafletInterop.setView", 
                    "arac-takip-harita", 
                    seciliArac.Latitude, 
                    seciliArac.Longitude, 
                    15);
            }
            else if (aracKonumlar.Any(a => a.Durum != AracTakipDurum.Cevrimdisi))
            {
                // Tüm araçları göster
                await JSRuntime.InvokeVoidAsync("leafletInterop.fitBounds", "arac-takip-harita");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Marker ekleme hatası: {ex.Message}");
        }
    }

    private async Task YenidenYukle()
    {
        yukleniyor = true;
        try
        {
            aracKonumlar = await AracTakipService.GetTumAraclarinSonKonumlariAsync();

            if (seciliAracId.HasValue)
            {
                seciliArac = aracKonumlar.FirstOrDefault(a => a.AracId == seciliAracId.Value);
            }

            if (haritaHazir)
            {
                await AraclariHaritayaEkle();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Veri yükleme hatası: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private async Task AracSec(AracKonumDto arac)
    {
        seciliAracId = arac.AracId;
        seciliArac = arac;

        // SignalR ile bu aracı özellikle takip et
        if (signalRBagli)
        {
            await JSRuntime.InvokeVoidAsync("signalRHelper.takipBaslat", arac.AracId);
        }

        if (haritaHazir && arac.Durum != AracTakipDurum.Cevrimdisi)
        {
            await JSRuntime.InvokeVoidAsync("leafletInterop.setView", 
                "arac-takip-harita", 
                arac.Latitude, 
                arac.Longitude, 
                15);
        }
    }

    private string GetDurumBadgeClass(AracTakipDurum durum)
    {
        return durum switch
        {
            AracTakipDurum.Hareket => "bg-success",
            AracTakipDurum.Bekliyor => "bg-warning text-dark",
            AracTakipDurum.Park => "bg-secondary",
            AracTakipDurum.Cevrimdisi => "bg-danger",
            _ => "bg-light text-dark"
        };
    }

    private string GetMarkerRenk(AracTakipDurum durum)
    {
        return durum switch
        {
            AracTakipDurum.Hareket => "#28a745",    // Yeşil
            AracTakipDurum.Bekliyor => "#ffc107",   // Sarı
            AracTakipDurum.Park => "#6c757d",       // Gri
            _ => "#dc3545"                          // Kırmızı
        };
    }

    public async ValueTask DisposeAsync()
    {
        // SignalR bağlantısını kapat
        await SignalRBaglantiyiKapat();
        dotNetRef?.Dispose();

        if (haritaHazir)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("leafletInterop.destroyMap", "arac-takip-harita");
            }
            catch { }
        }
    }
}

