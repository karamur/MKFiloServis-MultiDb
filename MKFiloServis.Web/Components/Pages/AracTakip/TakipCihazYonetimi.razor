@page "/ayarlar/arac-takip-cihaz"
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Services
@using MKFiloServis.Shared.Entities
@inject IAracTakipService AracTakipService
@inject IAracService AracService
@inject IJSRuntime JSRuntime

<PageTitle>Araç Takip Cihazları</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="bi bi-broadcast-pin text-primary me-2"></i>Araç Takip Cihazları
                </h3>
                <button class="btn btn-primary" @onclick="YeniCihazAc">
                    <i class="bi bi-plus-lg"></i> Yeni Cihaz Ekle
                </button>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Yükleniyor...</p>
        </div>
    }
    else if (!cihazlar.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-broadcast text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">Henüz Cihaz Tanımlanmamış</h4>
                <p class="text-muted">GPS takip cihazlarınızı tanımlayarak araçlarınızı canlı olarak takip edebilirsiniz.</p>
                <button class="btn btn-primary" @onclick="YeniCihazAc">
                    <i class="bi bi-plus-lg"></i> İlk Cihazı Ekle
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Araç</th>
                                <th>Cihaz ID / IMEI</th>
                                <th>Marka / Model</th>
                                <th>SIM Kart</th>
                                <th>Kurulum Tarihi</th>
                                <th>Son İletişim</th>
                                <th>Durum</th>
                                <th class="text-end">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cihaz in cihazlar)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary">@(cihaz.Arac?.AktifPlaka ?? "Araç Yok")</strong>
                                        <br />
                                        <small class="text-muted">@cihaz.Arac?.Marka @cihaz.Arac?.Model</small>
                                    </td>
                                    <td>
                                        <code>@cihaz.CihazId</code>
                                    </td>
                                    <td>
                                        @(cihaz.CihazMarka ?? "-") @(cihaz.CihazModel ?? "")
                                    </td>
                                    <td>@(cihaz.SimKartNo ?? "-")</td>
                                    <td>@(cihaz.KurulumTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td>
                                        @if (cihaz.SonIletisimZamani.HasValue)
                                        {
                                            var sure = DateTime.Now - cihaz.SonIletisimZamani.Value;
                                            <span class="@(sure.TotalMinutes < 10 ? "text-success" : sure.TotalMinutes < 60 ? "text-warning" : "text-danger")">
                                                @cihaz.SonIletisimZamani.Value.ToString("dd.MM HH:mm")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (cihaz.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pasif</span>
                                        }
                                        @if (cihaz.BataryaSeviyesi.HasValue)
                                        {
                                            <br />
                                            <small class="@(cihaz.BataryaSeviyesi < 20 ? "text-danger" : "text-muted")">
                                                <i class="bi bi-battery-half"></i> @cihaz.BataryaSeviyesi%
                                            </small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => DuzenleAc(cihaz)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => SilOnay(cihaz)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Cihaz Modal -->
@if (modalGoster)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-broadcast-pin me-2"></i>
                        @(duzenlenenCihaz.Id == 0 ? "Yeni Cihaz Ekle" : "Cihaz Düzenle")
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="duzenlenenCihaz" OnValidSubmit="Kaydet">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label">Araç <span class="text-danger">*</span></label>
                            <div class="position-relative">
                                <input type="text" class="form-control" placeholder="Plaka veya marka ara..."
                                       value="@tcPlakaArama"
                                       @oninput="TcPlakaFiltrele"
                                       @onfocus="() => tcPlakaDropAcik = true"
                                       @onblur="TcPlakaDropKapat" />
                                @if (tcPlakaDropAcik && tcFiltreliAraclar.Any())
                                {
                                    <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1060;">
                                        @foreach (var a in tcFiltreliAraclar)
                                        {
                                            <button type="button" class="dropdown-item" @onmousedown="() => TcAracSec(a)">
                                                <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                            @if (duzenlenenCihaz.AracId > 0)
                            {
                                <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @tcPlakaArama</small>
                            }
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Cihaz ID / IMEI <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="duzenlenenCihaz.CihazId" placeholder="Cihaz seri numarası veya IMEI" required />
                            <small class="text-muted">Cihaz üzerindeki benzersiz tanımlayıcı</small>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cihaz Markası</label>
                                <select class="form-select" @bind="duzenlenenCihaz.CihazMarka">
                                    <option value="">-- Seçin --</option>
                                    <option value="Teltonika">Teltonika</option>
                                    <option value="Queclink">Queclink</option>
                                    <option value="Concox">Concox</option>
                                    <option value="Meitrack">Meitrack</option>
                                    <option value="Coban">Coban</option>
                                    <option value="Diger">Diğer</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cihaz Modeli</label>
                                <input type="text" class="form-control" @bind="duzenlenenCihaz.CihazModel" placeholder="Örn: FMB920" />
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">SIM Kart Numarası</label>
                            <input type="text" class="form-control" @bind="duzenlenenCihaz.SimKartNo" placeholder="05XX XXX XXXX" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Kurulum Tarihi</label>
                            <input type="date" class="form-control" @bind="duzenlenenCihaz.KurulumTarihi" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <textarea class="form-control" rows="2" @bind="duzenlenenCihaz.Notlar" placeholder="Ek bilgiler..."></textarea>
                        </div>
                        
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="aktif" @bind="duzenlenenCihaz.Aktif" />
                            <label class="form-check-label" for="aktif">Aktif</label>
                        </div>
                    </EditForm>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="Kaydet" disabled="@kaydediliyor">
                        @if (kaydediliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (silinecekCihaz != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Silme Onayı</h5>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekCihaz.CihazId</strong> cihazını silmek istediğinize emin misiniz?</p>
                    <p class="text-muted small mb-0">Bu işlem geri alınamaz.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="() => silinecekCihaz = null">İptal</button>
                    <button type="button" class="btn btn-danger btn-sm" @onclick="Sil">
                        <i class="bi bi-trash"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AracTakipCihaz> cihazlar = new();
    private List<Arac> araclar = new();
    private List<Arac> tcFiltreliAraclar = new();
    private bool yukleniyor = true;
    private bool modalGoster = false;
    private bool kaydediliyor = false;
    private AracTakipCihaz duzenlenenCihaz = new();
    private AracTakipCihaz? silinecekCihaz = null;
    private string tcPlakaArama = string.Empty;
    private bool tcPlakaDropAcik = false;

    protected override async Task OnInitializedAsync()
    {
        await Yukle();
    }

    private async Task Yukle()
    {
        yukleniyor = true;
        try
        {
            cihazlar = await AracTakipService.GetAllCihazlarAsync();
            araclar = await AracService.GetAllAsync();
            tcFiltreliAraclar = araclar;
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void YeniCihazAc()
    {
        duzenlenenCihaz = new AracTakipCihaz
        {
            Aktif = true,
            KurulumTarihi = DateTime.Today
        };
        tcPlakaArama = string.Empty;
        tcFiltreliAraclar = araclar;
        modalGoster = true;
    }

    private void DuzenleAc(AracTakipCihaz cihaz)
    {
        duzenlenenCihaz = new AracTakipCihaz
        {
            Id = cihaz.Id,
            AracId = cihaz.AracId,
            CihazId = cihaz.CihazId,
            CihazMarka = cihaz.CihazMarka,
            CihazModel = cihaz.CihazModel,
            SimKartNo = cihaz.SimKartNo,
            KurulumTarihi = cihaz.KurulumTarihi,
            Aktif = cihaz.Aktif,
            Notlar = cihaz.Notlar
        };
        var a = araclar.FirstOrDefault(x => x.Id == cihaz.AracId);
        tcPlakaArama = a != null ? $"{a.AktifPlaka} - {a.Marka} {a.Model}" : string.Empty;
        tcFiltreliAraclar = araclar;
        modalGoster = true;
    }

    private void ModalKapat()
    {
        modalGoster = false;
        duzenlenenCihaz = new();
        tcPlakaArama = string.Empty;
        tcPlakaDropAcik = false;
    }

    private void TcPlakaFiltrele(ChangeEventArgs e)
    {
        tcPlakaArama = e.Value?.ToString() ?? string.Empty;
        duzenlenenCihaz.AracId = 0;
        tcPlakaDropAcik = true;
        var ara = tcPlakaArama.Trim().ToLowerInvariant();
        tcFiltreliAraclar = string.IsNullOrEmpty(ara)
            ? araclar
            : araclar.Where(a =>
                (a.AktifPlaka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Marka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Model ?? string.Empty).ToLowerInvariant().Contains(ara)).ToList();
    }

    private void TcAracSec(Arac arac)
    {
        duzenlenenCihaz.AracId = arac.Id;
        tcPlakaArama = $"{arac.AktifPlaka} - {arac.Marka} {arac.Model}";
        tcPlakaDropAcik = false;
        tcFiltreliAraclar = araclar;
    }

    private async Task TcPlakaDropKapat()
    {
        await Task.Delay(150);
        tcPlakaDropAcik = false;
    }

    private async Task Kaydet()
    {
        if (duzenlenenCihaz.AracId == 0 || string.IsNullOrWhiteSpace(duzenlenenCihaz.CihazId))
        {
            return;
        }

        kaydediliyor = true;
        try
        {
            if (duzenlenenCihaz.Id == 0)
            {
                await AracTakipService.CreateCihazAsync(duzenlenenCihaz);
            }
            else
            {
                await AracTakipService.UpdateCihazAsync(duzenlenenCihaz);
            }

            ModalKapat();
            await Yukle();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Hata: {ex.Message}");
        }
        finally
        {
            kaydediliyor = false;
        }
    }

    private void SilOnay(AracTakipCihaz cihaz)
    {
        silinecekCihaz = cihaz;
    }

    private async Task Sil()
    {
        if (silinecekCihaz == null) return;

        try
        {
            await AracTakipService.DeleteCihazAsync(silinecekCihaz.Id);
            silinecekCihaz = null;
            await Yukle();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Silme hatası: {ex.Message}");
        }
    }
}

