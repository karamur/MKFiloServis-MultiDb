@page "/personel/bordro/icmal"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Components
@inject IBordroService BordroService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Bordro İcmali</PageTitle>

<div class="container-fluid no-print">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-table me-2"></i>Bordro İcmali</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Bordro İcmali</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            @if (detaylar.Count > 0)
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick="TumunuSec">
                    <i class="bi bi-check-all me-1"></i>Tümünü Seç
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="SecimTemizle">
                    <i class="bi bi-x-lg me-1"></i>Temizle
                </button>
                <button class="btn btn-primary btn-sm" @onclick="YazdirSecilenler">
                    <i class="bi bi-printer me-1"></i>Yazdır
                </button>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Yıl</label>
                    <select class="form-select form-select-sm" @bind="secilenYil" @bind:after="YilDegisti">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="secilenFirmaId" @bind:after="FirmaDegisti">
                        <option value="0">Tüm Firmalar</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bordro Tipi</label>
                    <select class="form-select form-select-sm" @bind="secilenTip" @bind:after="TipDegisti">
                        <option value="@BordroTipi.Normal">Normal</option>
                        <option value="@BordroTipi.Arge">AR-GE</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1">Dönem</label>
                    <select class="form-select form-select-sm" @bind="secilenBordroId" @bind:after="BordroDegisti">
                        <option value="0">-- Dönem Seçiniz --</option>
                        @foreach (var bordro in bordrolar)
                        {
                            <option value="@bordro.Id">@bordro.DonemeAdi @(bordro.Firma != null ? $"- {bordro.Firma.FirmaAdi}" : string.Empty)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    @if (secilenBordro != null)
                    {
                        <span class="badge @(secilenBordro.Onaylandi ? "bg-success" : "bg-warning text-dark")">
                            @(secilenBordro.Onaylandi ? "Onaylı" : "Bekliyor")
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (secilenBordroId == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Bordro icmali için dönem seçiniz.
        </div>
    }
    else if (!detaylar.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>Seçilen döneme ait bordro detayı bulunamadı.
        </div>
    }
    else
    {
        <div class="row g-2 mb-3">
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2 text-center">
                        <small>Personel</small>
                        <div class="fs-4 fw-bold">@detaylar.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success text-white">
                    <div class="card-body py-2 text-center">
                        <small>Bankaya Yatan</small>
                        <div class="fw-bold">@FormatPara(detaylar.Sum(x => x.NetMaas))</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2 text-center">
                        <small>Elden / Fark</small>
                        <div class="fw-bold">@FormatPara(detaylar.Sum(x => x.EkOdeme))</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger text-white">
                    <div class="card-body py-2 text-center">
                        <small>Kesinti</small>
                        <div class="fw-bold">@FormatPara(detaylar.Sum(x => x.ToplamKesinti))</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body py-2 text-center">
                        <small>Personel Harcaması</small>
                        <div class="fw-bold">@FormatPara(kalanOdemeRaporu.Sum(x => x.PersonelHarcamalari))</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body py-2 text-center">
                        <small>İşveren Maliyeti</small>
                        <div class="fw-bold">@FormatPara(detaylar.Sum(x => x.ToplamIsverenMaliyet))</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-dark text-white">
                    <div class="card-body py-2 text-center">
                        <small>Nihai Ödeme</small>
                        <div class="fw-bold">@FormatPara(kalanOdemeRaporu.Sum(x => x.KalanOdeme))</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-files me-1"></i>İcmal Satırları</strong>
                <small class="text-muted">Seçili: @SeciliSayisi kişi</small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:40px;"><input type="checkbox" class="form-check-input" @bind="tumSecili" @bind:after="TumSeciliDegisti" /></th>
                                <th>Sıra</th>
                                <th>Personel</th>
                                <th>Görev</th>
                                <th class="text-end">Brüt</th>
                                <th class="text-end">SGK İşçi</th>
                                <th class="text-end">G.Vergisi</th>
                                <th class="text-end">D.Vergisi</th>
                                <th class="text-end">Özel Kes.</th>
                                <th class="text-end">Bankaya Yatan</th>
                                <th class="text-end">Yan Haklar</th>
                                <th class="text-end">Elden / Fark</th>
                                <th class="text-end">Kesinti</th>
                                <th class="text-end">İşveren Mlyt</th>
                                <th class="text-end">Personel Harcaması</th>
                                <th class="text-end">Avans / Alacak</th>
                                <th class="text-end">Nihai Ödeme</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var sira = 0; }
                            @foreach (var detay in detaylar)
                            {
                                var kalanSatir = GetKalanOdemeSatiri(detay.Id);
                                sira++;
                                <tr>
                                    <td><input type="checkbox" class="form-check-input" @bind="detay.Secili" /></td>
                                    <td class="text-center">@(detay.Personel.SiralamaNo > 0 ? detay.Personel.SiralamaNo : sira)</td>
                                    <td>
                                        <strong>@detay.Personel.TamAd</strong><br />
                                        <small class="text-muted">@detay.Personel.SoforKodu</small>
                                    </td>
                                    <td>@GorevAdi(detay.Personel.Gorev)</td>
                                    <td class="text-end">@FormatPara(detay.BrutMaas)</td>
                                    <td class="text-end"><small>@FormatPara(detay.SgkIssizlikKesinti)</small></td>
                                    <td class="text-end"><small>@FormatPara(detay.GelirVergisi)</small></td>
                                    <td class="text-end"><small>@FormatPara(detay.DamgaVergisi)</small></td>
                                    <td class="text-end"><small class="text-danger">@(detay.OzelKesintilerToplam > 0 ? FormatPara(detay.OzelKesintilerToplam) : "-")</small></td>
                                    <td class="text-end">@FormatPara(detay.NetMaas)</td>
                                    <td class="text-end">@FormatPara(detay.ToplamEkOdeme)</td>
                                    <td class="text-end">@FormatPara(detay.EkOdeme)</td>
                                    <td class="text-end text-danger">@FormatPara(detay.ToplamKesinti)</td>
                                    <td class="text-end"><small class="text-info" title="SGK İşv:@FormatPara(detay.SgkIsverenPrim) İşsiz İşv:@FormatPara(detay.IssizlikIsverenPrim)">@FormatPara(detay.ToplamIsverenMaliyet)</small></td>
                                    <td class="text-end text-info">@FormatPara(kalanSatir.PersonelHarcamalari)</td>
                                    <td class="text-end text-warning">@FormatPara(kalanSatir.PersonelAvansAlacaklari)</td>
                                    <td class="text-end fw-bold">@FormatPara(kalanSatir.KalanOdeme)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<div class="print-only" id="printArea">
    @if (yazdirmaListesi.Any() && secilenBordro != null)
    {
        var firma = secilenBordro.Firma;
        <div class="icmal-sayfa">
            <div class="icmal-header">
                <div>
                    <h4 class="mb-0">@(firma?.UnvanTam ?? firma?.FirmaAdi ?? "Firma")</h4>
                    <small>@AyAdi(secilenBordro.Ay) @secilenBordro.Yil - @(secilenBordro.BordroTipi == BordroTipi.Arge ? "AR-GE Bordro İcmali" : "Bordro İcmali")</small>
                </div>
                <div class="text-end">
                    <strong>Yazdırma Tarihi</strong><br />
                    <small>@DateTime.Now.ToString("dd.MM.yyyy")</small>
                </div>
            </div>

            <table class="icmal-tablo">
                <thead>
                    <tr>
                        <th>Sıra</th>
                        <th>Personel</th>
                        <th>Görev</th>
                        <th>Brüt</th>
                        <th>SGK İşçi</th>
                        <th>G.Vergisi</th>
                        <th>D.Vergisi</th>
                        <th>Özel Kes.</th>
                        <th>Bankaya Yatan</th>
                        <th>Yan Haklar</th>
                        <th>Elden / Fark</th>
                        <th>Kesinti</th>
                        <th>İşveren Mlyt</th>
                        <th>Personel Harcaması</th>
                        <th>Avans / Alacak</th>
                        <th>Nihai Ödeme</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var sira = 0; }
                    @foreach (var detay in yazdirmaListesi)
                    {
                        var kalanSatir = GetKalanOdemeSatiri(detay.Id);
                        sira++;
                        <tr>
                            <td>@(detay.Personel.SiralamaNo > 0 ? detay.Personel.SiralamaNo : sira)</td>
                            <td>@detay.Personel.TamAd</td>
                            <td>@GorevAdi(detay.Personel.Gorev)</td>
                            <td>@detay.BrutMaas.ToString("N2")</td>
                            <td>@detay.SgkIssizlikKesinti.ToString("N2")</td>
                            <td>@detay.GelirVergisi.ToString("N2")</td>
                            <td>@detay.DamgaVergisi.ToString("N2")</td>
                            <td>@detay.OzelKesintilerToplam.ToString("N2")</td>
                            <td>@detay.NetMaas.ToString("N2")</td>
                            <td>@detay.ToplamEkOdeme.ToString("N2")</td>
                            <td>@detay.EkOdeme.ToString("N2")</td>
                            <td>@detay.ToplamKesinti.ToString("N2")</td>
                            <td>@detay.ToplamIsverenMaliyet.ToString("N2")</td>
                            <td>@kalanSatir.PersonelHarcamalari.ToString("N2")</td>
                            <td>@kalanSatir.PersonelAvansAlacaklari.ToString("N2")</td>
                            <td><strong>@kalanSatir.KalanOdeme.ToString("N2")</strong></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3"><strong>TOPLAM</strong></td>
                        <td>@yazdirmaListesi.Sum(x => x.BrutMaas).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.SgkIssizlikKesinti).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.GelirVergisi).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.DamgaVergisi).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.OzelKesintilerToplam).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.NetMaas).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.ToplamEkOdeme).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.EkOdeme).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.ToplamKesinti).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => x.ToplamIsverenMaliyet).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => GetKalanOdemeSatiri(x.Id).PersonelHarcamalari).ToString("N2")</td>
                        <td>@yazdirmaListesi.Sum(x => GetKalanOdemeSatiri(x.Id).PersonelAvansAlacaklari).ToString("N2")</td>
                        <td><strong>@yazdirmaListesi.Sum(x => GetKalanOdemeSatiri(x.Id).KalanOdeme).ToString("N2")</strong></td>
                    </tr>
                </tfoot>
            </table>

            <div class="imza-row">
                <div class="imza-box">
                    <div class="imza-line"></div>
                    <small>Hazırlayan</small>
                </div>
                <div class="imza-box">
                    <div class="imza-line"></div>
                    <small>Kontrol Eden</small>
                </div>
                <div class="imza-box">
                    <div class="imza-line"></div>
                    <small>Onaylayan</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "bordroId")]
    public int? BordroIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "detayIds")]
    public string? DetayIdsQuery { get; set; }

    private List<Firma> firmalar = new();
    private List<Bordro> bordrolar = new();
    private List<BordroDetay> detaylar = new();
    private List<BordroDetay> yazdirmaListesi = new();
    private List<BordroKalanOdemeSatir> kalanOdemeRaporu = new();
    private Bordro? secilenBordro;
    private int secilenYil = DateTime.Now.Year;
    private int secilenFirmaId = 0;
    private BordroTipi secilenTip = BordroTipi.Normal;
    private int secilenBordroId = 0;
    private bool yukleniyor;
    private bool tumSecili;

    private int SeciliSayisi => detaylar.Count(d => d.Secili);

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        await BordrolariYukle();
        await QuerySecimiUygula();
    }

    private async Task QuerySecimiUygula()
    {
        if (!BordroIdQuery.HasValue)
            return;

        secilenBordroId = BordroIdQuery.Value;
        await DetaylariYukle();

        if (!detaylar.Any())
            return;

        var seciliDetayIdleri = (DetayIdsQuery ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(x => int.TryParse(x, out var id) ? id : 0)
            .Where(id => id > 0)
            .ToHashSet();

        if (seciliDetayIdleri.Any())
        {
            foreach (var detay in detaylar)
            {
                detay.Secili = seciliDetayIdleri.Contains(detay.Id);
            }

            yazdirmaListesi = detaylar.Where(d => d.Secili).ToList();
            tumSecili = detaylar.All(d => d.Secili);
        }
        else
        {
            foreach (var detay in detaylar)
            {
                detay.Secili = true;
            }

            yazdirmaListesi = detaylar.ToList();
            tumSecili = true;
        }
    }

    private async Task YilDegisti()
    {
        secilenBordroId = 0;
        detaylar.Clear();
        await BordrolariYukle();
    }

    private async Task FirmaDegisti()
    {
        secilenBordroId = 0;
        detaylar.Clear();
        await BordrolariYukle();
    }

    private async Task TipDegisti()
    {
        secilenBordroId = 0;
        detaylar.Clear();
        await BordrolariYukle();
    }

    private async Task BordroDegisti()
    {
        if (secilenBordroId > 0)
            await DetaylariYukle();
        else
        {
            detaylar.Clear();
            secilenBordro = null;
        }
    }

    private async Task BordrolariYukle()
    {
        int? firmaId = secilenFirmaId > 0 ? secilenFirmaId : null;
        bordrolar = await BordroService.GetBordrolarAsync(firmaId, secilenYil, secilenTip);
    }

    private async Task DetaylariYukle()
    {
        yukleniyor = true;
        try
        {
            detaylar = await BordroService.GetBordroDetaylarAsync(secilenBordroId);
            kalanOdemeRaporu = await BordroService.GetKalanOdemeRaporuAsync(secilenBordroId);
            secilenBordro = bordrolar.FirstOrDefault(b => b.Id == secilenBordroId) ?? await BordroService.GetBordroByIdAsync(secilenBordroId);
            tumSecili = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Bordro icmali yüklenirken hata: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void TumunuSec()
    {
        foreach (var d in detaylar) d.Secili = true;
        tumSecili = true;
    }

    private void SecimTemizle()
    {
        foreach (var d in detaylar) d.Secili = false;
        tumSecili = false;
    }

    private void TumSeciliDegisti()
    {
        foreach (var d in detaylar) d.Secili = tumSecili;
    }

    private async Task YazdirSecilenler()
    {
        var seciliDetaylar = detaylar.Where(d => d.Secili).ToList();
        if (!seciliDetaylar.Any())
        {
            ToastService.ShowWarning("Lütfen en az bir personel seçiniz.");
            return;
        }

        yazdirmaListesi = seciliDetaylar;
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("window.print");
    }

    private static string FormatPara(decimal tutar) => tutar.ToString("N2") + " ₺";

    private BordroKalanOdemeSatir GetKalanOdemeSatiri(int bordroDetayId)
        => kalanOdemeRaporu.FirstOrDefault(x => x.BordroDetayId == bordroDetayId) ?? new BordroKalanOdemeSatir();

    private string GorevAdi(PersonelGorev gorev) => gorev switch
    {
        PersonelGorev.Sofor => "Şoför",
        PersonelGorev.OfisCalisani => "Ofis Çalışanı",
        PersonelGorev.Muhasebe => "Muhasebe",
        PersonelGorev.Yonetici => "Yönetici",
        PersonelGorev.Teknik => "Teknik",
        PersonelGorev.Diger => "Diğer",
        _ => gorev.ToString()
    };

    private string AyAdi(int ay) => ay switch
    {
        1 => "Ocak",
        2 => "Şubat",
        3 => "Mart",
        4 => "Nisan",
        5 => "Mayıs",
        6 => "Haziran",
        7 => "Temmuz",
        8 => "Ağustos",
        9 => "Eylül",
        10 => "Ekim",
        11 => "Kasım",
        12 => "Aralık",
        _ => string.Empty
    };
}

<style>
    .print-only {
        display: none;
    }

    @@media print {
        .no-print {
            display: none !important;
        }

        .print-only {
            display: block !important;
        }

        .icmal-sayfa {
            padding: 10mm;
            font-family: 'Segoe UI', Arial, sans-serif;
            color: #000;
        }

        .icmal-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
            border-bottom: 1px solid #000;
            padding-bottom: 8px;
        }

        .icmal-tablo {
            width: 100%;
            border-collapse: collapse;
            font-size: 10pt;
        }

        .icmal-tablo th,
        .icmal-tablo td {
            border: 1px solid #000;
            padding: 6px;
        }

        .icmal-tablo th {
            background: #f0f0f0 !important;
        }

        .imza-row {
            display: flex;
            justify-content: space-between;
            margin-top: 32px;
            gap: 20px;
        }

        .imza-box {
            flex: 1;
            text-align: center;
        }

        .imza-line {
            border-top: 1px solid #000;
            margin-bottom: 6px;
            margin-top: 32px;
        }
    }
</style>

