    #region Toplu Tahakkuk ve Ödeme İşlemleri

    private void TopluTahakkukModalAc()
    {
        tahakkukTarihi = new DateTime(secilenYil, secilenAy, DateTime.DaysInMonth(secilenYil, secilenAy)); // Ayın son günü
        tahakkukAciklama = $"{new DateTime(secilenYil, secilenAy, 1):MMMM yyyy} maaş tahakkuku";
        // Tüm personeli seçili yap
        foreach (var item in personelListesi!)
        {
            item.Secili = true;
        }
        showTahakkukModal = true;
    }

    private async Task TopluOdemeModalAc()
    {
        odemeTarihi = DateTime.Today;
        odemeAciklama = $"{new DateTime(secilenYil, secilenAy, 1):MMMM yyyy} maaş ödemesi";
        odemeBelgeNo = $"MAAS-{secilenYil}{secilenAy:00}";
        // IBAN'ı olan personelleri otomatik seç (BankayaYatan=0 olsa da SGK'lılar listede)
        foreach (var item in personelListesi!)
        {
            item.Secili = !string.IsNullOrWhiteSpace(item.Personel.IBAN);
        }
        showOdemeModal = true;
        await Task.CompletedTask;
    }

    private bool TumunuSecildiMi()
    {
        if (personelListesi == null || !personelListesi.Any()) return false;
        return personelListesi.All(p => p.Secili);
    }

    private void TumunuSecToggle(ChangeEventArgs e)
    {
        var secili = (bool)(e.Value ?? false);
        foreach (var item in personelListesi!)
        {
            // Ödeme modalında IBAN'sız olanları seçme
            if (showOdemeModal && string.IsNullOrWhiteSpace(item.Personel.IBAN))
                continue;
            item.Secili = secili;
        }
    }

    private async Task TopluTahakkukKaydet()
    {
        if (personelListesi == null || !personelListesi.Any(p => p.Secili))
        {
            ToastService.ShowWarning("Lütfen en az bir personel seçin.");
            return;
        }

        isProcessing = true;
        try
        {
            var seciliPersoneller = personelListesi.Where(p => p.Secili).ToList();
            var donemBaslangic = new DateTime(secilenYil, secilenAy, 1);
            var donemBitis = donemBaslangic.AddMonths(1).AddDays(-1);

            int basarili = 0;
            int atlanan = 0;

            await using var db = await DbContextFactory.CreateDbContextAsync();

            foreach (var item in seciliPersoneller)
            {
                var personelId = item.Personel.Id;
                var yil = secilenYil;
                var ay = secilenAy;

                // Bu dönem için tahakkuk var mı kontrol et
                var mevcutTahakkuk = await db.PersonelMaaslari
                    .AsQueryable()
                    .Where(m => m.SoforId == personelId && m.Yil == yil && m.Ay == ay)
                    .AnyAsync();

                if (mevcutTahakkuk)
                {
                    atlanan++;
                    continue;
                }

                // Yeni tahakkuk kaydı oluştur
                var gercekMaas = item.Personel.ResmiNetMaas + item.Personel.DigerMaas;
                var bankayaYatan = item.Personel.ResmiNetMaas;
                var sonuc = MaasHesaplamaEngine.Hesapla(new MaasInput
                {
                    GercekMaas = gercekMaas,
                    BankayaYatan = bankayaYatan,
                    Avans = 0,
                    Kesinti = 0,
                    Harcama = 0
                });
                var eldenOdenecek = sonuc.Odenecek;

                var maasKaydi = new PersonelMaas
                {
                    SoforId = item.Personel.Id,
                    Yil = secilenYil,
                    Ay = secilenAy,
                    BrutMaas = gercekMaas,
                    NetMaas = gercekMaas,
                    SGKIsciPayi = 0,
                    SGKIsverenPayi = 0,
                    GelirVergisi = 0,
                    DamgaVergisi = 0,
                    DigerEklemeler = 0,
                    Avans = 0,
                    DigerKesintiler = 0,
                    OdemeTarihi = null,
                    OdemeDurum = MaasOdemeDurum.Bekliyor,
                    OdemeAciklama = tahakkukAciklama,
                    CreatedAt = DateTime.UtcNow
                };

                db.PersonelMaaslari.Add(maasKaydi);
                basarili++;
            }

            await db.SaveChangesAsync();

            showTahakkukModal = false;
            ToastService.ShowSuccess($"Tahakkuk tamamlandı: {basarili} kayıt oluşturuldu" + (atlanan > 0 ? $", {atlanan} kayıt atlandı (mevcut)" : ""));
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Tahakkuk oluşturulurken hata: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task TopluOdemeKaydet()
    {
        if (secilenBankaHesapId == 0)
        {
            ToastService.ShowWarning("Lütfen bir banka hesabı seçin.");
            return;
        }

        if (personelListesi == null || !personelListesi.Any(p => p.Secili && p.BankayaYatan > 0))
        {
            ToastService.ShowWarning("Lütfen en az bir personel seçin.");
            return;
        }

        isProcessing = true;
        try
        {
            var seciliPersoneller = personelListesi.Where(p => p.Secili && p.BankayaYatan > 0).ToList();
            var toplamTutar = seciliPersoneller.Sum(p => p.BankayaYatan);
            var secilenHesap = bankaHesaplari.First(h => h.Id == secilenBankaHesapId);

            // Toplu ödeme için grup ID oluştur
            var odemeGrupId = Guid.NewGuid();
            var islemNoBase = $"MAAS-{secilenYil}{secilenAy:00}-{DateTime.Now:HHmm}";

            await using var db = await DbContextFactory.CreateDbContextAsync();

            // Ana banka hareketi oluştur (çıkış)
            var bankaHareket = new BankaKasaHareket
            {
                BankaHesapId = secilenBankaHesapId,
                IslemNo = islemNoBase,
                IslemTarihi = odemeTarihi,
                HareketTipi = HareketTipi.Cikis,
                Tutar = toplamTutar,
                Aciklama = $"{odemeAciklama} - {seciliPersoneller.Count} personel toplu ödeme",
                BelgeNo = odemeBelgeNo,
                IslemKaynak = IslemKaynak.Eft,
                MahsupGrupId = odemeGrupId,
                MuhasebeHesapKodu = secilenHesap.VarsayilanMuhasebeKodu ?? "102", // Banka hesabı
                MuhasebeAciklama = $"Toplu maaş ödemesi - {new DateTime(secilenYil, secilenAy, 1):MMMM yyyy}",
                CreatedAt = DateTime.UtcNow
            };

            db.BankaKasaHareketleri.Add(bankaHareket);

            // Her personel için maaş kaydını güncelle (ödendi olarak işaretle)
            foreach (var item in seciliPersoneller)
            {
                // Lambda capture için local variable'lar
                var personelId = item.Personel.Id;
                var yil = secilenYil;
                var ay = secilenAy;

                // Bu dönem için maaş kaydı var mı?
                var maasKaydi = await db.PersonelMaaslari
                    .AsQueryable()
                    .Where(m => m.SoforId == personelId && m.Yil == yil && m.Ay == ay)
                    .FirstOrDefaultAsync();

                if (maasKaydi != null)
                {
                    maasKaydi.OdemeTarihi = odemeTarihi;
                    maasKaydi.OdemeDurum = MaasOdemeDurum.Odendi;
                    maasKaydi.UpdatedAt = DateTime.UtcNow;
                }
                else
                {
                    // Maaş kaydı yoksa oluştur ve ödendi olarak işaretle
                    maasKaydi = new PersonelMaas
                    {
                        SoforId = item.Personel.Id,
                        Yil = secilenYil,
                        Ay = secilenAy,
                        BrutMaas = item.GercekMaas,
                        NetMaas = item.GercekMaas,
                        DigerEklemeler = item.PersonelHarcamasi,
                        Avans = item.Avans,
                        DigerKesintiler = item.Kesinti,
                        OdemeTarihi = odemeTarihi,
                        OdemeDurum = MaasOdemeDurum.Odendi,
                        OdemeAciklama = odemeAciklama,
                        CreatedAt = DateTime.UtcNow
                    };
                    db.PersonelMaaslari.Add(maasKaydi);
                }
            }

            await db.SaveChangesAsync();

            showOdemeModal = false;
            ToastService.ShowSuccess($"Toplu ödeme kaydedildi: {seciliPersoneller.Count} personel, Toplam: {FormatPara(toplamTutar)}");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Ödeme kaydedilirken hata: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    #endregion

    private async Task BankayaYatanDegisti(PersonelOdemeKalemi item, ChangeEventArgs e)
    {
        if (!decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var val))
            decimal.TryParse(e.Value?.ToString(), out val);

        if (!item.Personel.Aktif)
        {
            ToastService.ShowWarning("Pasif personel için Bankaya Yatan değiştirilemez.");
            return;
        }

        item.BankayaYatan = val;
        var sonuc = MaasHesaplamaEngine.Hesapla(new MaasInput
        {
            GercekMaas = item.GercekMaas,
            BankayaYatan = item.BankayaYatan,
            Avans = item.Avans,
            Kesinti = item.Kesinti,
            Harcama = item.PersonelHarcamasi
        });
        item.EldenOdenecek = sonuc.Odenecek;
        GorevOzetleriniGuncelle();

        // Personel kartına anında kaydet
        try
        {
            item.Personel.ResmiNetMaas = item.BankayaYatan;
            item.Personel.NetMaas = item.BankayaYatan + item.Personel.DigerMaas;
            await SoforService.UpdateAsync(item.Personel);
            ToastService.ShowSuccess($"{item.Personel.TamAd} – Bankaya Yatan güncellendi: {FormatPara(item.BankayaYatan)}");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kaydetme hatası: {ex.Message}");
        }
    }

    private void GorevOzetleriniGuncelle()
    {
        if (personelListesi == null) return;
        gorevOzetleri = personelListesi
            .GroupBy(p => p.Personel.Gorev)
            .Select(g => new GorevOzet
            {
                Gorev = g.Key,
                GorevAdi = GetGorevAdi(g.Key),
                BadgeClass = GetGorevBadgeClass(g.Key),
                KisiSayisi = g.Count(),
                ToplamGercekMaas = g.Sum(x => x.GercekMaas),
                ToplamBankayaYatan = g.Sum(x => x.BankayaYatan),
                ToplamAvans = g.Sum(x => x.Avans),
                ToplamKesinti = g.Sum(x => x.Kesinti),
                ToplamPersonelHarcamasi = g.Sum(x => x.PersonelHarcamasi),
                ToplamEldenOdenecek = g.Sum(x => x.EldenOdenecek)
            })
            .OrderBy(g => g.Gorev)
            .ToList();
    }

    private async Task BankayaYatanKaydet()
    {
        if (personelListesi == null || !personelListesi.Any()) return;
        isKaydediliyor = true;
        try
        {
            int guncellenen = 0;
            foreach (var item in personelListesi)
            {
                if (item.Personel.ResmiNetMaas != item.BankayaYatan)
                {
                    item.Personel.ResmiNetMaas = item.BankayaYatan;
                    item.Personel.NetMaas = item.BankayaYatan + item.Personel.DigerMaas;
                    await SoforService.UpdateAsync(item.Personel);
                    guncellenen++;
                }
            }

            // Personel dosyasındaki güncel değerlerle listeyi yeniden yükle
            await YenileData();
            ToastService.ShowSuccess($"{guncellenen} personelin bankaya yatan tutarı güncellendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kaydetme sırasında hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
        }
    }

    private async Task PdfAktar()
    {
        try
        {
            // Tarayıcı print dialog ile PDF
            await JS.InvokeVoidAsync("window.print");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF hatası: {ex.Message}");
        }
