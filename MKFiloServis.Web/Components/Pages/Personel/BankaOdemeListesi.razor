@page "/personel/banka-odeme-listesi"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Services.Calculation
@using MKFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ISoforService SoforService
@inject IPersonelFinansService FinansService
@inject IPersonelMaasIzinService PersonelMaasService
@inject IMaasSnapshotService SnapshotService
@inject IBankaHesapService BankaHesapService
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Personel Banka Ödeme Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-bank me-2"></i>Personel Banka Ödeme Listesi</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Banka Ödeme Listesi</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 120px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenAy" @bind:after="YenileData">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 160px;" @bind="sgkBordroFiltre" @bind:after="YenileData">
                <option value="">Tüm Bordro</option>
                <option value="true">SGK Bordrolu</option>
                <option value="false">SGK Bordrosuz</option>
            </select>
            <div class="form-check form-switch d-flex align-items-center px-2" title="Aktifken SGK'lı ve SGK'sız personeller raporda ayrı başlıklarla listelenir">
                <input class="form-check-input" type="checkbox" id="sgkAyriListe" @bind="sgkAyriListedeGoster" />
                <label class="form-check-label small ms-2" for="sgkAyriListe">SGK ayrı liste</label>
            </div>
            <select class="form-select form-select-sm" style="width: 180px;" @bind="secilenGorev" @bind:after="YenileData">
                <option value="">Tüm Görevler</option>
                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                {
                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                }
            </select>
            <div class="btn-group" role="group">
                <button class="btn btn-outline-success btn-sm" @onclick="ExcelAktar" disabled="@(personelListesi == null || !personelListesi.Any())">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="PdfAktar" disabled="@(personelListesi == null || !personelListesi.Any())" title="PDF olarak aktar">
                    <i class="bi bi-file-earmark-pdf me-1"></i>PDF
                </button>
            </div>
            <div class="btn-group" role="group">
                <button class="btn btn-warning btn-sm" @onclick="TopluTahakkukModalAc" disabled="@(personelListesi == null || !personelListesi.Any())" title="Seçili dönem için toplu maaş tahakkuku oluştur">
                    <i class="bi bi-receipt me-1"></i>Toplu Tahakkuk
                </button>
                <button class="btn btn-primary btn-sm" @onclick="TopluOdemeModalAc" disabled="@(personelListesi == null || !personelListesi.Any())" title="Banka hesabından toplu maaş ödemesi yap">
                    <i class="bi bi-cash-stack me-1"></i>Bankadan Öde
                </button>
                <button class="btn btn-success btn-sm" @onclick="BankayaYatanKaydet" disabled="@(personelListesi == null || !personelListesi.Any() || isKaydediliyor)" title="Bankaya Yatan tutarlarını personel kartlarına kaydet">
                    @if (isKaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-floppy me-1"></i>Kaydet
                </button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (personelListesi != null && personelListesi.Any())
    {
        <!-- Ana Tablo -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        @(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy")) Banka Ödeme Listesi
                    </h5>
                    <span class="badge bg-light text-primary">@personelListesi.Count personel</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0" id="bankaOdemeTablosu">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width: 40px;" class="text-center">S.NO</th>
                                <th>PLAKA</th>
                                <th>AD SOYAD</th>
                                <th>TELEFON</th>
                                <th>ADRES</th>
                                <th class="text-end">GERÇEK MAAŞ</th>
                                <th class="text-end bg-info bg-opacity-10" style="width: 150px;" title="Banka hesabına yatırılacak resmi net maaş">BANKAYA YATAN</th>
                                <th class="text-end">AVANS (-)</th>
                                <th class="text-end">KESİNTİ (-)</th>
                                <th class="text-end">HARCAMASI (+)</th>
                                <th class="text-end">FARK / ÖDENECEK</th>
                                <th>FİRMA</th>
                                <th>SGK</th>
                                <th>İŞE GİRİŞ</th>
                                <th>İŞTEN ÇIKIŞ</th>
                            </tr>
                        </thead>
                        @if (sgkAyriListedeGoster)
                        {
                            <tbody>
                                <tr class="table-secondary fw-bold">
                                    <td colspan="15">SGK'lı Personeller (@sgkliPersonelListesi.Count kişi)</td>
                                </tr>
                                @foreach (var item in sgkliPersonelListesi)
                                {
                                    <tr>
                                        <td class="text-center">@(item.SiralamaNo > 0 ? item.SiralamaNo : (sgkliPersonelListesi.IndexOf(item) + 1))</td>
                                        <td><span class="badge bg-secondary font-monospace">@(string.IsNullOrWhiteSpace(item.AracPlakasi) ? "-" : item.AracPlakasi)</span></td>
                                        <td><strong>@item.Personel.TamAd</strong></td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Personel.Telefon) ? "-" : item.Personel.Telefon)</td>
                                        <td><small>@(string.IsNullOrWhiteSpace(item.Personel.Adres) ? "-" : item.Personel.Adres)</small></td>
                                        <td class="text-end">@FormatPara(item.GercekMaas)</td>
                                        <td class="text-end bg-info bg-opacity-10"><strong>@FormatPara(item.BankayaYatan)</strong></td>
                                        <td class="text-end">@FormatPara(item.Avans)</td>
                                        <td class="text-end">@FormatPara(item.Kesinti)</td>
                                        <td class="text-end">@FormatPara(item.PersonelHarcamasi)</td>
                                        <td class="text-end fw-bold">@FormatPara(item.EldenOdenecek)</td>
                                        <td>@(item.Personel.Firma?.FirmaAdi ?? "-")</td>
                                        <td>SGK'lı</td>
                                        <td>@(item.Personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>@(item.Personel.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    </tr>
                                }

                                <tr class="table-secondary fw-bold">
                                    <td colspan="15">SGK'sız Personeller (@sgksizPersonelListesi.Count kişi)</td>
                                </tr>
                                @foreach (var item in sgksizPersonelListesi)
                                {
                                    <tr>
                                        <td class="text-center">@(item.SiralamaNo > 0 ? item.SiralamaNo : (sgksizPersonelListesi.IndexOf(item) + 1))</td>
                                        <td><span class="badge bg-secondary font-monospace">@(string.IsNullOrWhiteSpace(item.AracPlakasi) ? "-" : item.AracPlakasi)</span></td>
                                        <td><strong>@item.Personel.TamAd</strong></td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Personel.Telefon) ? "-" : item.Personel.Telefon)</td>
                                        <td><small>@(string.IsNullOrWhiteSpace(item.Personel.Adres) ? "-" : item.Personel.Adres)</small></td>
                                        <td class="text-end">@FormatPara(item.GercekMaas)</td>
                                        <td class="text-end bg-info bg-opacity-10"><strong>@FormatPara(item.BankayaYatan)</strong></td>
                                        <td class="text-end">@FormatPara(item.Avans)</td>
                                        <td class="text-end">@FormatPara(item.Kesinti)</td>
                                        <td class="text-end">@FormatPara(item.PersonelHarcamasi)</td>
                                        <td class="text-end fw-bold">@FormatPara(item.EldenOdenecek)</td>
                                        <td>@(item.Personel.Firma?.FirmaAdi ?? "-")</td>
                                        <td>SGK'sız</td>
                                        <td>@(item.Personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>@(item.Personel.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        }
                        else
                        {
                            <tbody>
                                @foreach (var item in personelListesi)
                                {
                                    <tr>
                                        <td class="text-center">@(item.SiralamaNo > 0 ? item.SiralamaNo : (personelListesi.IndexOf(item) + 1))</td>
                                        <td><span class="badge bg-secondary font-monospace">@(string.IsNullOrWhiteSpace(item.AracPlakasi) ? "-" : item.AracPlakasi)</span></td>
                                        <td><strong>@item.Personel.TamAd</strong></td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Personel.Telefon) ? "-" : item.Personel.Telefon)</td>
                                        <td><small>@(string.IsNullOrWhiteSpace(item.Personel.Adres) ? "-" : item.Personel.Adres)</small></td>
                                        <td class="text-end">@FormatPara(item.GercekMaas)</td>
                                        <td class="text-end bg-info bg-opacity-10"><strong>@FormatPara(item.BankayaYatan)</strong></td>
                                        <td class="text-end">@FormatPara(item.Avans)</td>
                                        <td class="text-end">@FormatPara(item.Kesinti)</td>
                                        <td class="text-end">@FormatPara(item.PersonelHarcamasi)</td>
                                        <td class="text-end fw-bold">@FormatPara(item.EldenOdenecek)</td>
                                        <td>@(item.Personel.Firma?.FirmaAdi ?? "-")</td>
                                        <td>@(item.Personel.SGKBordroDahilMi ? "SGK'lı" : "SGK'sız")</td>
                                        <td>@(item.Personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>@(item.Personel.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        }
                        <tfoot class="table-dark">
                            <tr>
                                <td colspan="5" class="text-end"><strong>GENEL TOPLAM</strong></td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.GercekMaas))</strong></td>
                                <td class="text-end bg-info"><strong>@FormatPara(personelListesi.Sum(p => p.BankayaYatan))</strong></td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.Avans))</strong></td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.Kesinti))</strong></td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.PersonelHarcamasi))</strong></td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.EldenOdenecek))</strong></td>
                                <td colspan="4"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Görev Dağılımı Özet Tablosu -->
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white py-2">
                        <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Görev Dağılımına Göre Ödemeler</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Görev</th>
                                    <th class="text-center">Kişi</th>
                                    <th class="text-end">Bankaya Yatan</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ozet in gorevOzetleri)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @ozet.BadgeClass">@ozet.GorevAdi</span>
                                        </td>
                                        <td class="text-center">@ozet.KisiSayisi</td>
                                        <td class="text-end">@FormatPara(ozet.ToplamBankayaYatan)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-dark">
                                <tr>
                                    <td><strong>TOPLAM</strong></td>
                                    <td class="text-center"><strong>@gorevOzetleri.Sum(g => g.KisiSayisi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamBankayaYatan))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-secondary text-white py-2">
                        <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>Ödeme Özeti</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tr class="table-info">
                                <td><i class="bi bi-bank text-info me-2"></i>Toplam Bankaya Yatan</td>
                                <td class="text-end"><strong class="fs-5">@FormatPara(personelListesi.Sum(p => p.BankayaYatan))</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Seçilen dönem için aktif personel bulunamadı.
        </div>
    }
</div>

@* Toplu Tahakkuk Modal *@
@if (showTahakkukModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Toplu Maaş Tahakkuku</h5>
                    <button type="button" class="btn-close" @onclick="() => showTahakkukModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>@(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy"))</strong> dönemi için <strong>@personelListesi!.Count</strong> personele toplam <strong>@FormatPara(personelListesi.Sum(p => p.GercekMaas))</strong> gerçek maaş tahakkuku oluşturulacaktır.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tahakkuk Tarihi</label>
                            <input type="date" class="form-control" @bind="tahakkukTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tahakkuk Açıklaması</label>
                            <input type="text" class="form-control" @bind="tahakkukAciklama" placeholder="Opsiyonel açıklama" />
                        </div>
                    </div>

                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>
                                        <input type="checkbox" class="form-check-input" checked="@TumunuSecildiMi()" @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th class="text-end">Gerçek Maaş</th>
                                    <th class="text-end">Bankaya Yatan</th>
                                    <th class="text-end">Elden Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in personelListesi!)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="item.Secili" />
                                        </td>
                                        <td>@item.Personel.TamAd</td>
                                        <td class="text-end">@FormatPara(item.GercekMaas)</td>
                                        <td class="text-end">@FormatPara(item.BankayaYatan)</td>
                                        <td class="text-end"><strong>@FormatPara(item.EldenOdenecek)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-warning">
                                <tr>
                                    <td colspan="2"><strong>Seçili Toplam (@personelListesi.Count(p => p.Secili) kişi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.GercekMaas))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.BankayaYatan))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.EldenOdenecek))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showTahakkukModal = false">İptal</button>
                    <button type="button" class="btn btn-warning" @onclick="TopluTahakkukKaydet" disabled="@(!personelListesi.Any(p => p.Secili) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Tahakkuk Oluştur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Toplu Ödeme Modal *@
@if (showOdemeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-stack me-2"></i>Toplu Banka Ödemesi</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOdemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-primary mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>@(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy"))</strong> dönemi için <strong>@personelListesi!.Count</strong> personele toplam <strong>@FormatPara(personelListesi.Sum(p => p.BankayaYatan))</strong> banka ödemesi yapılacaktır.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Yapılacak Hesap <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="secilenBankaHesapId">
                                <option value="0">-- Hesap Seçin --</option>
                                @foreach (var hesap in bankaHesaplari)
                                {
                                    <option value="@hesap.Id">@hesap.HesapAdi (@hesap.BankaAdi)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Tarihi</label>
                            <input type="date" class="form-control" @bind="odemeTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Belge No</label>
                            <input type="text" class="form-control" @bind="odemeBelgeNo" placeholder="Dekont no vb." />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <input type="text" class="form-control" @bind="odemeAciklama" placeholder="Ödeme açıklaması" />
                        </div>
                    </div>

                    @if (secilenBankaHesapId > 0)
                    {
                        var secilenHesap = bankaHesaplari.FirstOrDefault(h => h.Id == secilenBankaHesapId);
                        if (secilenHesap != null)
                        {
                            <div class="alert alert-secondary mb-3">
                                <div class="d-flex justify-content-between">
                                    <span><i class="bi bi-bank me-2"></i><strong>@secilenHesap.HesapAdi</strong></span>
                                    <span>IBAN: <code>@secilenHesap.Iban</code></span>
                                </div>
                            </div>
                        }
                    }

                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>
                                        <input type="checkbox" class="form-check-input" checked="@TumunuSecildiMi()" @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th>IBAN</th>
                                    <th class="text-end">Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in personelListesi!)
                                {
                                    <tr class="@(string.IsNullOrWhiteSpace(item.Personel.IBAN) ? "table-danger" : "")">
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="item.Secili" disabled="@(string.IsNullOrWhiteSpace(item.Personel.IBAN))" />
                                        </td>
                                        <td>@item.Personel.TamAd</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.Personel.IBAN))
                                            {
                                                <small class="font-monospace">@FormatIBAN(item.Personel.IBAN)</small>
                                            }
                                            else
                                            {
                                                <span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>IBAN Eksik</span>
                                            }
                                        </td>
                                        <td class="text-end"><strong>@FormatPara(item.BankayaYatan)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-primary">
                                <tr>
                                    <td colspan="3"><strong>Seçili Toplam (@personelListesi.Count(p => p.Secili && p.BankayaYatan > 0) kişi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili && p.BankayaYatan > 0).Sum(p => p.BankayaYatan))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @if (personelListesi.Any(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.BankayaYatan > 0))
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>@personelListesi.Count(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.BankayaYatan > 0)</strong> personelin IBAN bilgisi eksik olduğu için ödeme listesine dahil edilemedi.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showOdemeModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TopluOdemeKaydet" disabled="@(secilenBankaHesapId == 0 || !personelListesi.Any(p => p.Secili && p.BankayaYatan > 0) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Ödeme Yap
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil = DateTime.Now.Year;
    private int secilenAy = DateTime.Now.Month;
    private string secilenGorev = "";
    private string sgkBordroFiltre = "";
    private bool sgkAyriListedeGoster = false;
    private bool isLoading = false;
    private bool isProcessing = false;

    private List<PersonelOdemeKalemi>? personelListesi;
    private List<GorevOzet> gorevOzetleri = new();
    private List<PersonelOdemeKalemi> sgkliPersonelListesi => personelListesi?.Where(p => p.Personel.SGKBordroDahilMi).ToList() ?? new();
    private List<PersonelOdemeKalemi> sgksizPersonelListesi => personelListesi?.Where(p => !p.Personel.SGKBordroDahilMi).ToList() ?? new();

    // Toplu Tahakkuk Modal
    private bool showTahakkukModal = false;
    private DateTime tahakkukTarihi = DateTime.Today;
    private string tahakkukAciklama = "";

    // Toplu Ödeme Modal
    private bool showOdemeModal = false;
    private List<BankaHesap> bankaHesaplari = new();
    private int secilenBankaHesapId = 0;
    private DateTime odemeTarihi = DateTime.Today;
    private string odemeBelgeNo = "";
    private string odemeAciklama = "";

    // Kaydet
    private bool isKaydediliyor = false;

    protected override async Task OnInitializedAsync()
    {
        await YenileData();
        bankaHesaplari = await BankaHesapService.GetActiveAsync();
    }

    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            // Aktif personelleri doğrudan DB'den al (cache bypass + AracAtamalari dahil)
            await using var db = await DbContextFactory.CreateDbContextAsync();
            var donemBaslangic = new DateTime(secilenYil, secilenAy, 1);
            var aktifPersoneller = await db.Soforler
                .AsNoTracking()
                .Include(s => s.Firma)
                .Include(s => s.AracAtamalari.Where(a => a.Aktif))
                    .ThenInclude(a => a.Arac)
                .Where(s => !s.IsDeleted && s.Aktif)
                .Where(s => s.IstenAyrilmaTarihi == null || s.IstenAyrilmaTarihi >= donemBaslangic)
                .OrderBy(s => s.SiralamaNo == 0 ? int.MaxValue : s.SiralamaNo)
                .ThenBy(s => s.Ad)
                .ToListAsync();

            // Görev filtresi
            if (!string.IsNullOrEmpty(secilenGorev) && Enum.TryParse<PersonelGorev>(secilenGorev, out var gorev))
            {
                aktifPersoneller = aktifPersoneller.Where(p => p.Gorev == gorev).ToList();
            }

            // SGK bordro filtresi
            if (!string.IsNullOrEmpty(sgkBordroFiltre) && bool.TryParse(sgkBordroFiltre, out var sgkDurum))
            {
                aktifPersoneller = aktifPersoneller.Where(p => p.SGKBordroDahilMi == sgkDurum).ToList();
            }

            // Her personel için avans ve borç bilgilerini al
            personelListesi = new List<PersonelOdemeKalemi>();
            var donemMaasKayitlari = await PersonelMaasService.GetMaaslarAsync(secilenYil, secilenAy);
            var donemMaasMap = donemMaasKayitlari
                .GroupBy(m => m.SoforId)
                .ToDictionary(g => g.Key, g => g.First());

            foreach (var personel in aktifPersoneller)
            {
                // Bankaya yatan: personel dosyasından okunur.
                // Eski kayıtlarda ResmiNetMaas ve NetMaas 0, sadece BrutMaas varsa fallback uygula.
                // Kullanıcı kasıtlı 0 girmişse ResmiNetMaas=0 ve NetMaas=DigerMaas olacağından 0 gösterilir.
                var finansOzet = await FinansService.GetPersonelFinansOzetAsync(personel.Id);
                donemMaasMap.TryGetValue(personel.Id, out var donemMaas);
                var bankayaYatan = (personel.ResmiNetMaas == 0 && personel.NetMaas == 0 && personel.BrutMaas > 0)
                    ? personel.BrutMaas
                    : personel.ResmiNetMaas;
                var gercekMaas = donemMaas != null
                    ? donemMaas.NetMaas + donemMaas.ToplamEklemeler
                    : personel.ResmiNetMaas + personel.DigerMaas;

                // Aktif araç plakası
                var aracPlaka = personel.AracAtamalari?.FirstOrDefault(a => a.Aktif)?.Arac?.Plaka;

                var item = new PersonelOdemeKalemi
                {
                    Personel = personel,
                    SiralamaNo = personel.SiralamaNo,
                    GercekMaas = gercekMaas,
                    BankayaYatan = bankayaYatan,
                    Avans = finansOzet?.KalanAvans ?? 0,
                    Kesinti = 0,
                    PersonelHarcamasi = (finansOzet?.ToplamHarcama ?? 0) + (finansOzet?.KalanBorc > 0 ? finansOzet!.KalanBorc : 0),
                    AracPlakasi = aracPlaka
                };

                var sonuc = MaasHesaplamaEngine.Hesapla(new MaasInput
                {
                    GercekMaas = item.GercekMaas,
                    BankayaYatan = item.BankayaYatan,
                    Avans = item.Avans,
                    Kesinti = item.Kesinti,
                    Harcama = item.PersonelHarcamasi
                });
                item.EldenOdenecek = sonuc.Odenecek;

                personelListesi.Add(item);
            }

            // Görev özetlerini hesapla
            gorevOzetleri = personelListesi
                .GroupBy(p => p.Personel.Gorev)
                .Select(g => new GorevOzet
                {
                    Gorev = g.Key,
                    GorevAdi = GetGorevAdi(g.Key),
                    BadgeClass = GetGorevBadgeClass(g.Key),
                    KisiSayisi = g.Count(),
                    ToplamGercekMaas = g.Sum(x => x.GercekMaas),
                    ToplamBankayaYatan = g.Sum(x => x.BankayaYatan),
                    ToplamAvans = g.Sum(x => x.Avans),
                    ToplamKesinti = g.Sum(x => x.Kesinti),
                    ToplamPersonelHarcamasi = g.Sum(x => x.PersonelHarcamasi),
                    ToplamEldenOdenecek = g.Sum(x => x.EldenOdenecek)
                })
                .OrderBy(g => g.Gorev)
                .ToList();

            // ── Snapshot kaydet (arka planda, sessiz) ──
            _ = Task.Run(async () =>
            {
                try
                {
                    var firmaId = aktifPersoneller.FirstOrDefault()?.FirmaId ?? 0;
                    if (firmaId > 0 && personelListesi.Any())
                    {
                        var varMi = await SnapshotService.VarMiAsync(secilenYil, secilenAy, firmaId);
                        if (!varMi)
                        {
                            var snapshotData = personelListesi.Select(p => (
                                PersonelId: p.Personel.Id,
                                AdSoyad: p.Personel.TamAd,
                                PersonelKodu: (string?)p.Personel.SoforKodu,
                                GorevAdi: (string?)GetGorevAdi(p.Personel.Gorev),
                                AracPlakasi: (string?)p.AracPlakasi,
                                GercekMaas: p.GercekMaas,
                                BankayaYatan: p.BankayaYatan,
                                Avans: p.Avans,
                                Kesinti: p.Kesinti,
                                Harcama: p.PersonelHarcamasi,
                                Odenecek: p.EldenOdenecek,
                                HakedisGelir: 0m,
                                HakedisGider: 0m
                            )).ToList();
                            await SnapshotService.OlusturAsync(secilenYil, secilenAy, firmaId, snapshotData);
                        }
                    }
                }
                catch (Exception ex) { Console.WriteLine($"[Snapshot] Banka liste kayıt hatası: {ex.Message}"); }
            });
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExcelAktar()
    {
        try
        {
            using var workbook = new ClosedXML.Excel.XLWorkbook();

            if (sgkAyriListedeGoster)
            {
                ExcelSayfaDoldur(workbook.Worksheets.Add("SGK'lı"), sgkliPersonelListesi, "SGK'lı Personel Ödeme Listesi");
                ExcelSayfaDoldur(workbook.Worksheets.Add("SGK'sız"), sgksizPersonelListesi, "SGK'sız Personel Ödeme Listesi");
            }
            else
            {
                ExcelSayfaDoldur(workbook.Worksheets.Add("Banka Ödeme Listesi"), personelListesi ?? new List<PersonelOdemeKalemi>(), "Personel Ödeme Listesi");
            }

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var bytes = stream.ToArray();

            var dosyaAdi = $"maas_odeme_raporu_{secilenYil}_{secilenAy:00}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Excel dosyası indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel oluşturulurken hata: {ex.Message}");
        }
    }

    private void ExcelSayfaDoldur(ClosedXML.Excel.IXLWorksheet worksheet, List<PersonelOdemeKalemi> liste, string raporBaslik)
    {
        worksheet.Cell("A1").Value = $"{raporBaslik} - {new DateTime(secilenYil, secilenAy, 1):MMMM yyyy}";
        worksheet.Range("A1:O1").Merge().Style.Font.Bold = true;
        worksheet.Range("A1:O1").Style.Font.FontSize = 14;

        var header = worksheet.Row(3);
        header.Cell(1).Value = "S.NO";
        header.Cell(2).Value = "PLAKA";
        header.Cell(3).Value = "AD SOYAD";
        header.Cell(4).Value = "TELEFON";
        header.Cell(5).Value = "ADRES";
        header.Cell(6).Value = "GERÇEK MAAŞ";
        header.Cell(7).Value = "BANKAYA YATAN";
        header.Cell(8).Value = "AVANS (-)";
        header.Cell(9).Value = "KESİNTİ (-)";
        header.Cell(10).Value = "HARCAMASI (+)";
        header.Cell(11).Value = "FARK / ÖDENECEK";
        header.Cell(12).Value = "FİRMA";
        header.Cell(13).Value = "SGK";
        header.Cell(14).Value = "İŞE GİRİŞ";
        header.Cell(15).Value = "İŞTEN ÇIKIŞ";
        header.Style.Font.Bold = true;
        header.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightGray;
        header.Cell(7).Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightGreen;

        int row = 4;
        int sira = 0;
        foreach (var item in liste)
        {
            sira++;
            worksheet.Cell(row, 1).Value = item.SiralamaNo > 0 ? item.SiralamaNo : sira;
            worksheet.Cell(row, 2).Value = item.AracPlakasi ?? "-";
            worksheet.Cell(row, 3).Value = item.Personel.TamAd;
            worksheet.Cell(row, 4).Value = item.Personel.Telefon ?? "-";
            worksheet.Cell(row, 5).Value = item.Personel.Adres ?? "-";
            worksheet.Cell(row, 6).Value = item.GercekMaas;
            worksheet.Cell(row, 7).Value = item.BankayaYatan;
            worksheet.Cell(row, 8).Value = item.Avans;
            worksheet.Cell(row, 9).Value = item.Kesinti;
            worksheet.Cell(row, 10).Value = item.PersonelHarcamasi;
            worksheet.Cell(row, 11).Value = item.EldenOdenecek;
            worksheet.Cell(row, 12).Value = item.Personel.Firma?.FirmaAdi ?? "-";
            worksheet.Cell(row, 13).Value = item.Personel.SGKBordroDahilMi ? "SGK'lı" : "SGK'sız";
            worksheet.Cell(row, 14).Value = item.Personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy") ?? "-";
            worksheet.Cell(row, 15).Value = item.Personel.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy") ?? "-";
            row++;
        }

        worksheet.Cell(row, 5).Value = "TOPLAM:";
        worksheet.Cell(row, 6).Value = liste.Sum(p => p.GercekMaas);
        worksheet.Cell(row, 7).Value = liste.Sum(p => p.BankayaYatan);
        worksheet.Cell(row, 8).Value = liste.Sum(p => p.Avans);
        worksheet.Cell(row, 9).Value = liste.Sum(p => p.Kesinti);
        worksheet.Cell(row, 10).Value = liste.Sum(p => p.PersonelHarcamasi);
        worksheet.Cell(row, 11).Value = liste.Sum(p => p.EldenOdenecek);
        worksheet.Range(row, 5, row, 11).Style.Font.Bold = true;
        worksheet.Range(row, 5, row, 11).Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightYellow;

        worksheet.Range(4, 6, row, 11).Style.NumberFormat.Format = "#,##0.00 ₺";
        worksheet.Columns().AdjustToContents();
    }

