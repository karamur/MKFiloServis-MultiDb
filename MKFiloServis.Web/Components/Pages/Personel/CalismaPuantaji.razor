                <div class="modal-header bg-warning py-2">
                    <h6 class="modal-title"><i class="bi bi-lightning-charge me-2"></i>Hızlı Doldur — @topluSatirPersonelAdi</h6>
                    <button type="button" class="btn-close" @onclick="() => showTopluSatirModal = false"></button>
                </div>
                <div class="modal-body">
