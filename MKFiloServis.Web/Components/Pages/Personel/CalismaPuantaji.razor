                        </button>
                        <button class="btn btn-outline-warning" @onclick='() => TopluSatirUygula("tum_izin")'>
                            <i class="bi bi-calendar-x me-2"></i>Tüm ay → İzin
                        </button>
                        <button class="btn btn-outline-danger" @onclick='() => TopluSatirUygula("tum_mazeret")'>
