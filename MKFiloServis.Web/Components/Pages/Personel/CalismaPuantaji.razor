<!-- AI Puantaj Analiz Modalı -->
@if (aiModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #6f42c1, #4a1f9e); color: white;">
                    <h5 class="modal-title">
                        <i class="bi bi-robot me-2"></i>AI Puantaj Analizi - @GetAyAdi(filtreAy) @filtreYil
                        <small class="ms-2 opacity-75">(@OllamaService.ModelAdi)</small>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => aiModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (aiAnalizing)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border" style="color: #6f42c1;" role="status"></div>
                            <p class="mt-3 text-muted">AI puantaj analizi yapılıyor, lütfen bekleyin...</p>
                            <small class="text-muted">Devamsızlık, fazla mesai, anomali tespiti çalışıyor...</small>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(aiSonuc))
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge px-3 py-2" style="background-color: #6f42c1;">
                                <i class="bi bi-clock me-1"></i>Analiz süresi: @aiSure
                            </span>
                            <div>
                                <span class="badge bg-info me-1">@puantajListesi.Count personel</span>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="AISonucTemizle">
                                    <i class="bi bi-trash me-1"></i>Temizle
                                </button>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                                <div style="white-space: pre-wrap; line-height: 1.6;">@aiSonuc</div>
                            </div>
                        </div>

                        @if (aiAksiyonlar.Count > 0)
                        {
                            <div class="card mt-3 border-warning">
                                <div class="card-header bg-warning bg-opacity-10 py-2">
                                    <strong><i class="bi bi-lightning-charge me-1"></i>Önerilen Aksiyonlar</strong>
                                </div>
                                <div class="card-body py-2">
                                    @foreach (var aksiyon in aiAksiyonlar)
                                    {
                                        <div class="form-check mb-1">
                                            <input type="checkbox" class="form-check-input" id="@($"paksiyon_{aiAksiyonlar.IndexOf(aksiyon)}")"
                                                   checked="@aksiyon.Secildi" @onchange="() => aksiyon.Secildi = !aksiyon.Secildi" />
                                            <label class="form-check-label small" for="@($"paksiyon_{aiAksiyonlar.IndexOf(aksiyon)}")">
                                                <span class="badge @GetAksiyonBadge(aksiyon.Oncelik) me-1">@aksiyon.Oncelik</span>
                                                @aksiyon.Aciklama
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => aiModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Satır Doldurma Modalı -->
@if (showTopluSatirModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
