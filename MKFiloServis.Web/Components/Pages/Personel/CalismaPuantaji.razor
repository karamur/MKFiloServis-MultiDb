    private void TopluSatirModalAc(int puantajId, bool isSaatlik)
    {
        topluSatirPuantajId = puantajId;
        var puantaj = puantajListesi.FirstOrDefault(p => p.Id == puantajId);
        topluSatirPersonelAdi = puantaj?.Personel?.TamAd ?? "";
