    private async Task TopluSatirUygula(string mod)
    {
        showTopluSatirModal = false;
        isLoading = true;
        StateHasChanged();

        try
        {
            if (!gunlukPuantajMap.ContainsKey(topluSatirPuantajId)) return;
            var gunlukler = gunlukPuantajMap[topluSatirPuantajId];

            foreach (var g in gunlukler)
            {
                var haftaIci = g.Tarih.DayOfWeek != DayOfWeek.Saturday && g.Tarih.DayOfWeek != DayOfWeek.Sunday;

                switch (mod)
                {
                    case "haftaici_calisir":
                        g.Calisti = haftaIci;
                        g.Izinli = false;
                        g.Mazeret = false;
                        break;
                    case "tum_calisir":
                        g.Calisti = true;
                        g.Izinli = false;
                        g.Mazeret = false;
                        break;
                    case "haftaici_izin":
                        if (haftaIci) { g.Calisti = false; g.Izinli = true; g.Mazeret = false; }
                        break;
                    case "tum_izin":
                        g.Calisti = false;
                        g.Izinli = true;
                        g.Mazeret = false;
                        break;
                    case "tum_mazeret":
                        g.Calisti = false;
                        g.Izinli = false;
                        g.Mazeret = true;
                        break;
                    case "temizle":
                        g.Calisti = false;
                        g.Izinli = false;
                        g.Mazeret = false;
                        g.FazlaMesaiSaat = 0;
                        g.CalismaSaati = 0;
                        break;
                }
                await PuantajService.SaveGunlukPuantajAsync(g);
            }

            await GunluktenPuantajOzetGuncelle(topluSatirPuantajId);
            degisiklikVar = true;
            ShowBildirim("Başarılı", $"{topluSatirPersonelAdi} için toplu atama tamamlandı.", "success");
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Toplu atama hatası: {ex.Message}", "danger");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void TopluSaatModalAc(int puantajId)
    {
        topluSaatPuantajId = puantajId;
        var puantaj = puantajListesi.FirstOrDefault(p => p.Id == puantajId);
        topluSaatPersonelAdi = puantaj?.Personel?.TamAd ?? "";
        topluSaatGunlukSaat = puantaj?.Personel?.CalismaMiktari > 0 ? puantaj!.Personel.CalismaMiktari : 8;
        topluSaatHaftaiciSadece = true;

        // Mevcut verileri gün haritasına yükle
        topluSaatGunMap = new Dictionary<int, decimal>();
        if (gunlukPuantajMap.ContainsKey(puantajId))
        {
            foreach (var g in gunlukPuantajMap[puantajId])
                topluSaatGunMap[g.Tarih.Day] = g.CalismaSaati;
        }
        showTopluSaatModal = true;
    }

    private async Task TopluSaatUygula()
    {
        showTopluSaatModal = false;
        isLoading = true;
        StateHasChanged();

        try
        {
            if (!gunlukPuantajMap.ContainsKey(topluSaatPuantajId)) return;
            var gunlukler = gunlukPuantajMap[topluSaatPuantajId];

            foreach (var g in gunlukler)
            {
                var saat = topluSaatGunMap.TryGetValue(g.Tarih.Day, out var sv) ? sv : 0;
                g.CalismaSaati = saat;
                g.Calisti = saat > 0;
                if (saat > 0) { g.Izinli = false; g.Mazeret = false; }
                await PuantajService.SaveGunlukPuantajAsync(g);
            }

            await GunluktenPuantajOzetGuncelle(topluSaatPuantajId);
            degisiklikVar = true;
            ShowBildirim("Başarılı", $"{topluSaatPersonelAdi} saatleri güncellendi.", "success");
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Toplu saat hatası: {ex.Message}", "danger");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void TopluSaatHizliDoldur()
    {
        for (int g = 1; g <= AyGunSayisi; g++)
        {
            var td = new DateTime(filtreYil, filtreAy, g);
            var isHaftaIci = td.DayOfWeek != DayOfWeek.Saturday && td.DayOfWeek != DayOfWeek.Sunday;
            if (topluSaatHaftaiciSadece && !isHaftaIci) continue;
            topluSaatGunMap[g] = topluSaatGunlukSaat;
        }
        StateHasChanged();
    }

    private void TopluSaatHepsiniTemizle()
    {
        topluSaatGunMap = new Dictionary<int, decimal>();
        StateHasChanged();
    }

    private void TopluSaatGunGuncelle(int gun, string? value)
    {
        if (decimal.TryParse(value?.Replace(",", "."), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var saat))
            topluSaatGunMap[gun] = saat < 0 ? 0 : saat;
        else
            topluSaatGunMap[gun] = 0;
    }

