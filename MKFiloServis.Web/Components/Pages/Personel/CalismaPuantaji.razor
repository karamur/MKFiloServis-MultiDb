@page "/personel/puantaj"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IPuantajService PuantajService
@inject IKullaniciService KullaniciService
@inject ISoforService SoforService
@inject IFirmaService FirmaService
@inject IOllamaService OllamaService
@inject IToastService ToastService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS
@inject NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Personel Puantaj</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-calendar-check me-2 text-primary"></i>Personel Servis Çalışma Puantajı</h3>
            <small class="text-muted">Personel bazlı günlük çalışma takibi, izin ve mazeret yönetimi</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm" @onclick="PuantajAIAnaliz" disabled="@(isLoading || !puantajListesi.Any() || aiAnalizing)"
                    style="border-color: #6f42c1; color: #6f42c1; background: white;">
                @if (aiAnalizing)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-robot me-1"></i>AI Analiz
            </button>
            <button class="btn btn-success btn-sm" @onclick="TopluPuantajOlustur" disabled="@isLoading">
                <i class="bi bi-calendar-plus me-1"></i>Ay Puantajı Oluştur
            </button>
            <button class="btn btn-outline-warning btn-sm" @onclick="TopluBirimUcretModalAc"
                    disabled="@(isLoading || !puantajListesi.Any(p => p.Personel?.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik))"
                    title="Saatlik personellerin birim ücretini toplu güncelle">
                <i class="bi bi-currency-exchange me-1"></i>Toplu Birim Ücret
            </button>
            <button class="btn btn-outline-dark btn-sm" @onclick="ResmiHesapPusulasiAc" disabled="@(isLoading || !filtrelenmisListe.Any())">
                <i class="bi bi-file-earmark-text me-1"></i>Resmi Hesap Pusulası
            </button>
            <button class="btn btn-outline-primary btn-sm" @onclick="ExcelExport" disabled="@(isLoading || !puantajListesi.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-success btn-sm" @onclick="VakifbankExport" disabled="@(isLoading || !puantajListesi.Any(p => p.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi))"
                    title="Onaylı personeller için Vakıfbank ödeme listesi">
                <i class="bi bi-bank me-1"></i>Vakıfbank
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="YenileAsync" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2 bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1 fw-bold">Firma</label>
                    <select class="form-select form-select-sm" @bind="filtreFirmaId" @bind:after="YenileAsync">
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Yıl</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="YenileAsync">
                        @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 2; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAy" @bind:after="YenileAsync">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@GetAyAdi(a)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1 fw-bold">Personel Ara</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Ad soyad..."
                           @bind="aramaMetni" @bind:event="oninput" @bind:after="FiltreleListeyi" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="YenileAsync" disabled="@isLoading">
                        <i class="bi bi-search me-1"></i>Göster
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (OlusturulabilirPersoneller.Any())
    {
        <div class="card shadow-sm mb-3 border-success">
            <div class="card-header bg-success bg-opacity-10 py-2 d-flex justify-content-between align-items-center">
                <div>
                    <strong><i class="bi bi-people me-1"></i>Puantaj Oluşturulabilir Personeller</strong>
                    <small class="text-muted ms-2">@OlusturulabilirPersoneller.Count kişi</small>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="TumOlusturulabilirleriSec" disabled="@(isLoading || !OlusturulabilirPersoneller.Any())">
                        <i class="bi bi-check-all me-1"></i>Tümünü Seç
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="OlusturulabilirSecimiTemizle" disabled="@(isLoading || !seciliPersonelIds.Any())">
                        <i class="bi bi-x-lg me-1"></i>Temizle
                    </button>
                    <button class="btn btn-success btn-sm" @onclick="SeciliPuantajOlustur" disabled="@(isLoading || !seciliPersonelIds.Any())">
                        <i class="bi bi-calendar-plus me-1"></i>Seçilileri Oluştur (@seciliPersonelIds.Count)
                    </button>
                </div>
            </div>
            <div class="card-body py-2">
                <div class="row g-2">
                    @foreach (var personel in OlusturulabilirPersoneller)
                    {
                        <div class="col-md-4 col-lg-3">
                            <label class="border rounded p-2 w-100 d-flex align-items-start gap-2" style="cursor: pointer;">
                                <input type="checkbox" class="form-check-input mt-1"
                                       checked="@seciliPersonelIds.Contains(personel.Id)"
                                       @onchange="(e) => PersonelSecimDegisti(personel.Id, e)" />
                                <span>
                                    <strong>@personel.TamAd</strong><br />
                                    <small class="text-muted">@personel.SoforKodu</small>
                                </span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Özet Kartlar -->
    @if (puantajListesi.Any())
    {
        <div class="row g-3 mb-3">
            <div class="col-md-2">
                <div class="card border-primary h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Personel</div>
                        <div class="fs-4 fw-bold text-primary">@puantajListesi.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-success h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Ort. Çalışılan Gün</div>
                        <div class="fs-4 fw-bold text-success">@(puantajListesi.Any() ? puantajListesi.Average(p => p.CalisilanGun).ToString("0.#") : "0")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-warning h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Toplam İzin</div>
                        <div class="fs-4 fw-bold text-warning">@puantajListesi.Sum(p => p.IzinGunu)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-danger h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Toplam Mazeret</div>
                        <div class="fs-4 fw-bold text-danger">@puantajListesi.Sum(p => p.MazeretGunu)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-info h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Toplam F. Mesai</div>
                        <div class="fs-4 fw-bold text-info">@puantajListesi.Sum(p => p.FazlaMesaiSaat).ToString("0.#") s</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-dark h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Net Ödeme</div>
                        <div class="fs-5 fw-bold text-dark">@FormatPara(puantajListesi.Sum(p => p.NetOdeme))</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-secondary h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Onay Bekleyen</div>
                        <div class="fs-4 fw-bold text-secondary">@puantajListesi.Count(p => p.OnayDurumu == PersonelPuantajOnayDurumu.OnayBekliyor)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-success h-100">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Onaylanan</div>
                        <div class="fs-4 fw-bold text-success">@puantajListesi.Count(p => p.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi)</div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Yükleniyor...</p>
        </div>
    }
    else if (!puantajListesi.Any() && !tumSoforler.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-4 text-muted"></i>
            <p class="text-muted mt-2">Personel bulunamadı. Önce şoför/personel kaydı oluşturun.</p>
        </div>
    }
    else
    {
        <!-- Puantaj Takvim Tablosu -->
        <div class="card shadow-sm">
            <div class="card-header bg-light py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span>
                        <strong>@GetAyAdi(filtreAy) @filtreYil</strong> - Çalışma Puantajı
                        <span class="badge bg-secondary ms-2">@AyGunSayisi gün</span>
                    </span>
                    <div class="d-flex gap-2">
                        @if (degisiklikVar)
                        {
                            <button class="btn btn-success btn-sm" @onclick="TumDegisiklikleriKaydet">
                                <i class="bi bi-save me-1"></i>Değişiklikleri Kaydet
                            </button>
                        }
                        <button class="btn btn-outline-warning btn-sm" @onclick="TopluOnayaGonder" disabled="@(!filtrelenmisListe.Any(p => p.OnayDurumu == PersonelPuantajOnayDurumu.Taslak || p.OnayDurumu == PersonelPuantajOnayDurumu.Reddedildi))">
                            <i class="bi bi-send-check me-1"></i>Tümünü Onaya Gönder
                        </button>
                        <button class="btn btn-outline-success btn-sm" @onclick="TopluOnayla" disabled="@(!filtrelenmisListe.Any(p => p.OnayDurumu == PersonelPuantajOnayDurumu.OnayBekliyor))">
                            <i class="bi bi-check-all me-1"></i>Tümünü Onayla (@filtrelenmisListe.Count(p => p.OnayDurumu == PersonelPuantajOnayDurumu.OnayBekliyor))
                        </button>
                        <button class="btn btn-outline-info btn-sm" @onclick="HesaplaVeGuncelle" disabled="@(!puantajListesi.Any() || isLoading)">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-calculator me-1"></i>
                            }
                            Hesapla
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 65vh;">
                    <table class="table table-sm table-bordered mb-0" style="font-size: 0.75rem;">
                        <thead class="table-light sticky-top" style="z-index: 5;">
                            <tr>
                                <th class="sticky-start" style="min-width: 180px; position: sticky; left: 0; background: #f8f9fa; z-index: 10;">
                                    Personel
                                </th>
                                @for (int gun = 1; gun <= AyGunSayisi; gun++)
                                {
                                    var tarih = new DateTime(filtreYil, filtreAy, gun);
                                    var haftaSonu = tarih.DayOfWeek == DayOfWeek.Saturday || tarih.DayOfWeek == DayOfWeek.Sunday;
                                    var pazar = tarih.DayOfWeek == DayOfWeek.Sunday;
                                    <th class="text-center @(pazar ? "table-danger" : haftaSonu ? "table-warning" : "")"
                                        style="min-width: 32px; font-size: 0.65rem; cursor: pointer;"
                                        title="Tüm personele toplu uygula" @onclick="() => SutunTikla(gun)">
                                        @gun
                                        <br /><span class="fw-normal">@GetGunKisa(tarih)</span>
                                    </th>
                                }
                                <th class="text-center bg-light" style="min-width: 40px;" title="Çalışılan Gün">Ç</th>
                                <th class="text-center bg-light" style="min-width: 40px;" title="İzin">İ</th>
                                <th class="text-center bg-light" style="min-width: 40px;" title="Mazeret">M</th>
                                <th class="text-center bg-light" style="min-width: 50px;" title="Fazla Mesai">FM</th>
                                <th class="text-center bg-light" style="min-width: 110px;" title="Onay Durumu">Onay</th>
                                <th class="text-center bg-light" style="min-width: 105px;" title="Net Ödeme">Net ₺</th>
                                <th class="text-center bg-light" style="min-width: 120px;" title="İşlem">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filtrelenmisListe.Any())
                            {
                                <tr>
                                    <td colspan="@(AyGunSayisi + 5)" class="text-center text-muted py-4">
                                        @if (puantajListesi.Any())
                                        {
                                            <span>Arama sonucuna uygun personel bulunamadı.</span>
                                        }
                                        else
                                        {
                                            <span>Bu dönem için puantaj kaydı yok. <strong>"Ay Puantajı Oluştur"</strong> butonuna tıklayın.</span>
                                        }
                                    </td>
                                </tr>
                            }
                            @foreach (var puantaj in filtrelenmisListe)
                            {
                                var gunlukler = gunlukPuantajMap.ContainsKey(puantaj.Id) ? gunlukPuantajMap[puantaj.Id] : new List<GunlukPuantaj>();

                                <tr>
                                    <td class="sticky-start" style="position: sticky; left: 0; background: white; z-index: 3;">
                                        @{
                                            var capturedPersonel = puantaj.Personel;
                                            var capturedPuantajIdQuick = puantaj.Id;
                                            var isSaatlikQuick = puantaj.Personel?.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik;
                                        }
                                        <div class="d-flex align-items-start gap-1">
                                            <div class="flex-grow-1">
                                                <a href="javascript:void(0)" class="text-decoration-none text-dark"
                                                   @onclick="() => PersonelKartAc(capturedPersonel)" title="Personel kartını düzenle">
                                                    <strong>@puantaj.Personel?.Ad @puantaj.Personel?.Soyad</strong>
                                                </a>
                                                @if (puantaj.Personel?.SoforKodu != null)
                                                {
                                                    <br /><small class="text-muted">@puantaj.Personel.SoforKodu</small>
                                                }
                                                @if (isSaatlikQuick)
                                                {
                                                    <br /><span class="badge bg-info" style="font-size: 0.6rem;">⏱ Saatlik @puantaj.Personel!.BirimUcret.ToString("N2")₺</span>
                                                }
                                            </div>
                                            @if (puantaj.OnayDurumu != PersonelPuantajOnayDurumu.Onaylandi)
                                            {
                                                <button class="btn btn-link btn-sm p-0 ms-1" title="Hızlı Toplu Doldur"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => TopluSatirModalAc(capturedPuantajIdQuick, isSaatlikQuick)">
                                                    <i class="bi bi-lightning-charge-fill text-warning" style="font-size:0.85rem;"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    @for (int gun = 1; gun <= AyGunSayisi; gun++)
                                    {
                                        var tarih = new DateTime(filtreYil, filtreAy, gun);
                                        var gunluk = gunlukler.FirstOrDefault(g => g.Tarih.Date == tarih.Date);
                                        var haftaSonu = tarih.DayOfWeek == DayOfWeek.Saturday || tarih.DayOfWeek == DayOfWeek.Sunday;
                                        var pazar = tarih.DayOfWeek == DayOfWeek.Sunday;

                                        var durum = GetGunlukDurum(gunluk);
                                        var badgeClass = GetDurumBadgeClass(durum);
                                        var durumKisa = GetDurumKisaltma(durum);

                                        var capturedPuantajId = puantaj.Id;
                                        var capturedTarih = tarih;
                                        var capturedGunluk = gunluk;
                                        var isSaatlik = puantaj.Personel?.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik;

                                        <td class="text-center p-0 @(pazar ? "table-danger" : haftaSonu ? "table-warning" : "")"
                                            style="cursor: pointer; vertical-align: middle;"
                                            @onclick="() => HucreTikla(capturedPuantajId, capturedTarih, capturedGunluk)">
                                            @if (isSaatlik && gunluk != null && gunluk.Calisti && gunluk.CalismaSaati > 0)
                                            {
                                                <span class="badge bg-info" style="font-size: 0.6rem; padding: 2px 4px;"
                                                      title="@gunluk.CalismaSaati.ToString("0.#") saat">@gunluk.CalismaSaati.ToString("0.#")</span>
                                            }
                                            else if (durumKisa != "-")
                                            {
                                                <span class="badge @badgeClass" style="font-size: 0.6rem; padding: 2px 4px;">@durumKisa</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted" style="font-size: 0.6rem;">-</span>
                                            }
                                        </td>
                                    }
                                    <td class="text-center fw-bold text-success">
                                        @puantaj.CalisilanGun
                                        @if (puantaj.Personel?.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik)
                                        {
                                            var pSaat = gunlukler.Sum(g => g.CalismaSaati);
                                            if (pSaat > 0)
                                            {
                                                <br /><span class="badge bg-info" style="font-size: 0.55rem;">@pSaat.ToString("0.#")s</span>
                                            }
                                        }
                                    </td>
                                    <td class="text-center fw-bold text-warning">@puantaj.IzinGunu</td>
                                    <td class="text-center fw-bold text-danger">@puantaj.MazeretGunu</td>
                                    <td class="text-center fw-bold text-info">@puantaj.FazlaMesaiSaat.ToString("0.#")</td>
                                    <td class="text-center">
                                        <span class="badge @GetOnayBadgeClass(puantaj.OnayDurumu)">@GetOnayText(puantaj.OnayDurumu)</span>
                                        @if (!string.IsNullOrWhiteSpace(puantaj.OnaylayanKullanici))
                                        {
                                            <br /><small class="text-muted">@puantaj.OnaylayanKullanici</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div>
                                            <span class="fw-bold text-dark" style="font-size:0.75rem;">@puantaj.NetOdeme.ToString("N0") ₺</span>
                                            @if (puantaj.BrutMaas > 0 && puantaj.BrutMaas != puantaj.NetOdeme)
                                            {
                                                <br /><small class="text-muted" style="font-size:0.6rem;">Brüt: @puantaj.BrutMaas.ToString("N0") ₺</small>
                                            }
                                            @if (puantaj.Odendi)
                                            {
                                                <br /><span class="badge bg-success" style="font-size:0.55rem;">Ödendi</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            @if (puantaj.OnayDurumu == PersonelPuantajOnayDurumu.Taslak || puantaj.OnayDurumu == PersonelPuantajOnayDurumu.Reddedildi)
                                            {
                                                <button class="btn btn-outline-warning btn-sm" @onclick="() => OnayaGonder(puantaj.Id)" title="Onaya Gönder">
                                                    <i class="bi bi-send"></i>
                                                </button>
                                            }
                                            @if (puantaj.OnayDurumu == PersonelPuantajOnayDurumu.OnayBekliyor)
                                            {
                                                <button class="btn btn-outline-success btn-sm" @onclick="() => Onayla(puantaj.Id)" title="Onayla">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Reddet(puantaj.Id)" title="Reddet">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                            @if (puantaj.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi)
                                            {
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => OnayGeriAl(puantaj.Id)" title="Onay Geri Al">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => PuantajSil(puantaj.Id)"
                                                    disabled="@(puantaj.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi)"
                                                    title="@(puantaj.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi ? "Önce onayı geri alın" : "Puantajı kalıcı sil")">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (filtrelenmisListe.Any())
                        {
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td class="sticky-start" style="position: sticky; left: 0; background: #f8f9fa; z-index: 3;">
                                        TOPLAM
                                    </td>
                                    @for (int gun = 1; gun <= AyGunSayisi; gun++)
                                    {
                                        var tarih = new DateTime(filtreYil, filtreAy, gun);
                                        var calisan = 0;
                                        foreach (var p in filtrelenmisListe)
                                        {
                                            if (gunlukPuantajMap.ContainsKey(p.Id))
                                            {
                                                var g = gunlukPuantajMap[p.Id].FirstOrDefault(x => x.Tarih.Date == tarih.Date);
                                                if (g != null && g.Calisti) calisan++;
                                            }
                                        }
                                        <td class="text-center" style="font-size: 0.65rem;">@(calisan > 0 ? calisan.ToString() : "")</td>
                                    }
                                    <td class="text-center text-success">@filtrelenmisListe.Sum(p => p.CalisilanGun)</td>
                                    <td class="text-center text-warning">@filtrelenmisListe.Sum(p => p.IzinGunu)</td>
                                    <td class="text-center text-danger">@filtrelenmisListe.Sum(p => p.MazeretGunu)</td>
                                    <td class="text-center text-info">@filtrelenmisListe.Sum(p => p.FazlaMesaiSaat).ToString("0.#")</td>
                                    <td class="text-center">@filtrelenmisListe.Count(p => p.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi)</td>
                                    <td class="text-center fw-bold text-dark" style="font-size:0.75rem;">@filtrelenmisListe.Sum(p => p.NetOdeme).ToString("N0") ₺</td>
                                    <td class="text-center">
                                        @{
                                            var toplamSaat = filtrelenmisListe
                                                .Where(p => p.Personel?.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik)
                                                .Sum(p => gunlukPuantajMap.ContainsKey(p.Id) ? gunlukPuantajMap[p.Id].Sum(g => g.CalismaSaati) : 0);
                                        }
                                        @if (toplamSaat > 0)
                                        {
                                            <span class="badge bg-info" style="font-size: 0.6rem;">⏱ @toplamSaat.ToString("0.#")s</span>
                                        }
                                    </td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
            <div class="card-footer bg-light py-2">
                <div class="row text-center small">
                    <div class="col">
                        <span class="badge bg-success">Ç</span> Çalıştı
                    </div>
                    <div class="col">
                        <span class="badge bg-warning text-dark">İ</span> İzinli
                    </div>
                    <div class="col">
                        <span class="badge bg-danger">M</span> Mazeret/Rapor
                    </div>
                    <div class="col">
                        <span class="badge bg-info">FM</span> Fazla Mesai
                    </div>
                    <div class="col">
                        <span class="text-muted">-</span> Boş
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<!-- Günlük Puantaj Düzenleme Modal -->
@if (showModal && editGunluk != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-calendar-day me-2"></i>
                        @editPersonelAdi - @editGunluk.Tarih.ToString("dd.MM.yyyy dddd", turkce)
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        @if (editPersonelSaatlik)
                        {
                            <div class="col-12">
                                <div class="alert alert-info py-2 mb-0">
                                    <i class="bi bi-clock me-1"></i>
                                    <strong>Saatlik personel</strong> - Birim ücret: <strong>@editPersonelBirimUcret.ToString("N2") ₺/saat</strong>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small mb-1 fw-bold">Çalışma Saati</label>
                                <input type="number" class="form-control form-control-sm" @bind="editCalismaSaati"
                                       step="0.5" min="0" max="24" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small mb-1">Günlük Tutar</label>
                                <input type="text" class="form-control form-control-sm" readonly
                                       value="@((editCalismaSaati * editPersonelBirimUcret).ToString("N2")) ₺" />
                            </div>
                        }
                        <div class="col-md-6">
                            <div class="form-check form-switch mb-2">
                                <input type="checkbox" class="form-check-input" id="calisti" @bind="editGunluk.Calisti"
                                       @bind:after="CalistiDegisti" />
                                <label class="form-check-label fw-bold" for="calisti">
                                    <i class="bi bi-check-circle text-success me-1"></i>Çalıştı
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mb-2">
                                <input type="checkbox" class="form-check-input" id="izinli" @bind="editGunluk.Izinli"
                                       @bind:after="IzinliDegisti" />
                                <label class="form-check-label fw-bold" for="izinli">
                                    <i class="bi bi-calendar-x text-warning me-1"></i>İzinli
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mb-2">
                                <input type="checkbox" class="form-check-input" id="mazeret" @bind="editGunluk.Mazeret"
                                       @bind:after="MazeretDegisti" />
                                <label class="form-check-label fw-bold" for="mazeret">
                                    <i class="bi bi-exclamation-triangle text-danger me-1"></i>Mazeret/Rapor
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Fazla Mesai (Saat)</label>
                            <input type="number" class="form-control form-control-sm" @bind="editGunluk.FazlaMesaiSaat"
                                   step="0.5" min="0" max="24" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small mb-1">Not</label>
                            <input type="text" class="form-control form-control-sm" @bind="editGunluk.Notlar"
                                   placeholder="Açıklama..." />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="GunlukKaydet">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Personel Kart Düzenleme Modalı -->
@if (showPersonelKartModal && editKartPersonel != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-info text-white py-2">
                    <h6 class="modal-title"><i class="bi bi-person-gear me-2"></i>@editKartPersonel.TamAd</h6>
                    <button type="button" class="btn-close btn-close-white btn-sm" @onclick="() => showPersonelKartModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Hesaplama Tipi</label>
                            <input type="text" class="form-control form-control-sm" readonly
                                   value="@editKartPersonel.BrutMaasHesaplamaTipi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1 fw-bold">Birim Ücret (₺/saat)</label>
                            <input type="number" class="form-control form-control-sm" @bind="editKartBirimUcret"
                                   step="0.01" min="0" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Brüt Maaş</label>
                            <input type="text" class="form-control form-control-sm" readonly
                                   value="@editKartPersonel.BrutMaas.ToString("N2") ₺" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Net Maaş</label>
                            <input type="text" class="form-control form-control-sm" readonly
                                   value="@editKartPersonel.NetMaas.ToString("N2") ₺" />
                        </div>
                        @if (editKartPersonel.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik)
                        {
                            var toplamSaatPersonel = gunlukPuantajMap
                                .Where(kv => puantajListesi.Any(p => p.Id == kv.Key && p.PersonelId == editKartPersonel.Id))
                                .SelectMany(kv => kv.Value)
                                .Sum(g => g.CalismaSaati);
                            <div class="col-12">
                                <div class="alert alert-info py-2 mb-0">
                                    <i class="bi bi-calculator me-1"></i>
                                    Bu ay toplam: <strong>@toplamSaatPersonel.ToString("0.#") saat</strong> ×
                                    <strong>@editKartBirimUcret.ToString("N2") ₺</strong> =
                                    <strong>@((toplamSaatPersonel * editKartBirimUcret).ToString("N2")) ₺</strong>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="() => showPersonelKartModal = false">İptal</button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="PersonelKartKaydet">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Hafta Sonu / Bayram Seçenekleri Modalı -->
