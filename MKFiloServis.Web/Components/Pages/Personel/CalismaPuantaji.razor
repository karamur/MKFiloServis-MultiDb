    private async Task TopluBirimUcretKaydet()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            foreach (var satir in topluBirimUcretListesi.Where(s => s.Yeni != s.Mevcut))
            {
                var sofor = await context.Soforler.FindAsync(satir.SoforId);
                if (sofor != null)
                {
                    sofor.BirimUcret = satir.Yeni;
                    sofor.UpdatedAt = DateTime.UtcNow;
                }
            }
            await context.SaveChangesAsync();

            // Bellekteki listeyi güncelle
            foreach (var satir in topluBirimUcretListesi)
            {
                var personel = puantajListesi.FirstOrDefault(p => p.PersonelId == satir.SoforId)?.Personel;
                if (personel != null) personel.BirimUcret = satir.Yeni;
            }

            showTopluBirimUcretModal = false;
            ShowBildirim("Kaydedildi", "Birim ücretler güncellendi.", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Kaydetme hatası: {ex.Message}", "danger");
