<!-- Toplu Saat Girişi Modalı (Saatlik Personel) -->
@if (showTopluSaatModal)
{
    var puantajForSaat2 = puantajListesi.FirstOrDefault(p => p.Id == topluSaatPuantajId);
    var birimUcretSaat2 = puantajForSaat2?.Personel?.BirimUcret ?? 0;
    var toplamSaatHesap2 = topluSaatGunMap.Values.Sum();

    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-info text-white py-2">
                    <h6 class="modal-title"><i class="bi bi-clock me-2"></i>Saat Girişi — @topluSaatPersonelAdi</h6>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showTopluSaatModal = false"></button>
                </div>
                <div class="modal-body">
                    <!-- Hızlı Doldur -->
                    <div class="card border-info mb-3">
                        <div class="card-body py-2">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <span class="small fw-bold text-info">Hızlı Doldur:</span>
                                </div>
                                <div class="col-auto">
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control" style="width:80px" @bind="topluSaatGunlukSaat" step="0.5" min="0" max="24" />
                                        <span class="input-group-text">saat</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <div class="form-check form-switch mb-0">
                                        <input type="checkbox" class="form-check-input" id="haftaiciSadece" @bind="topluSaatHaftaiciSadece" />
                                        <label class="form-check-label small" for="haftaiciSadece">Hafta içi</label>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-outline-info btn-sm" @onclick="TopluSaatHizliDoldur">
                                        <i class="bi bi-arrow-down me-1"></i>Tümüne Uygula
                                    </button>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-outline-danger btn-sm" @onclick="TopluSaatHepsiniTemizle">
                                        <i class="bi bi-eraser me-1"></i>Temizle
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Gün Bazlı Liste -->
                    <div style="max-height: 380px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light" style="position:sticky;top:0;z-index:1">
                                <tr>
                                    <th class="small">Tarih</th>
                                    <th class="small">Gün</th>
                                    <th class="small" style="width:110px">Çalışma Saati</th>
                                    <th style="width:40px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int gd = 1; gd <= AyGunSayisi; gd++)
                                {
                                    var gn = gd;
                                    var td2 = new DateTime(filtreYil, filtreAy, gn);
                                    var isHaftaSonu2 = td2.DayOfWeek == DayOfWeek.Saturday || td2.DayOfWeek == DayOfWeek.Sunday;
                                    var saatVal = topluSaatGunMap.TryGetValue(gn, out var sv) ? sv : 0;
                                    <tr class="@(isHaftaSonu2 ? "table-secondary" : "")">
                                        <td class="small @(isHaftaSonu2 ? "text-muted" : "")">@td2.ToString("dd MMMM", turkce)</td>
                                        <td class="small @(isHaftaSonu2 ? "text-muted" : "")">@td2.ToString("dddd", turkce)</td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm"
                                                   style="width:95px"
                                                   value="@(saatVal > 0 ? saatVal.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                                   step="0.5" min="0" max="24"
                                                   placeholder="—"
                                                   @oninput="e => TopluSaatGunGuncelle(gn, e.Value?.ToString())" />
                                        </td>
                                        <td class="text-center">
                                            @if (saatVal > 0)
                                            {
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1"
                                                        @onclick="() => { topluSaatGunMap[gn] = 0; StateHasChanged(); }"
                                                        title="Sil">✕</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Özet -->
                    <div class="alert alert-info py-2 mb-0 mt-2">
                        <i class="bi bi-calculator me-1"></i>
                        Toplam: <strong>@toplamSaatHesap2.ToString("0.#") saat</strong>
                        @if (birimUcretSaat2 > 0)
                        {
                            <span class="ms-3">× @birimUcretSaat2.ToString("N2") ₺ = <strong>@((toplamSaatHesap2 * birimUcretSaat2).ToString("N2")) ₺</strong></span>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => showTopluSaatModal = false">İptal</button>
                    <button class="btn btn-info btn-sm text-white" @onclick="TopluSaatUygula">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Birim Ücret Değiştirme Modalı -->
@if (showTopluBirimUcretModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning py-2">
                    <h6 class="modal-title"><i class="bi bi-currency-exchange me-2"></i>Toplu Birim Ücret Güncelleme</h6>
                    <button type="button" class="btn-close" @onclick="() => showTopluBirimUcretModal = false"></button>
                </div>
                <div class="modal-body">
                    <!-- Hepsine Uygula -->
                    <div class="card border-warning mb-3">
                        <div class="card-body py-2">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <span class="small fw-bold">Hepsine Aynı Ücret:</span>
                                </div>
                                <div class="col-auto">
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control" style="width:110px" @bind="topluBirimUcretHepsine" step="0.01" min="0" />
                                        <span class="input-group-text">₺/saat</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-warning btn-sm" @onclick="TopluBirimUcretHepsineUygula"
                                            disabled="@(topluBirimUcretHepsine <= 0)">
                                        <i class="bi bi-arrow-down me-1"></i>Tümüne Uygula
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Personel Listesi -->
                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light" style="position:sticky;top:0;z-index:1">
                                <tr>
                                    <th class="small">Personel</th>
                                    <th class="small text-end" style="width:130px">Mevcut Ücret</th>
                                    <th class="small" style="width:150px">Yeni Ücret (₺/saat)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var satir in topluBirimUcretListesi)
                                {
                                    var degisti = satir.Yeni != satir.Mevcut;
                                    <tr class="@(degisti ? "table-warning" : "")">
                                        <td class="small fw-bold">@satir.Ad</td>
                                        <td class="small text-end text-muted">@satir.Mevcut.ToString("N2") ₺</td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm @(degisti ? "border-warning" : "")"
                                                   @bind="satir.Yeni" step="0.01" min="0" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (topluBirimUcretListesi.Any(s => s.Yeni != s.Mevcut))
                    {
                        <div class="alert alert-warning py-2 mb-0 mt-2 small">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>@topluBirimUcretListesi.Count(s => s.Yeni != s.Mevcut) personelin</strong> birim ücreti değişecek.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => showTopluBirimUcretModal = false">İptal</button>
                    <button class="btn btn-warning btn-sm" @onclick="TopluBirimUcretKaydet"
                            disabled="@(!topluBirimUcretListesi.Any(s => s.Yeni != s.Mevcut))">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Sütun (Gün) Doldurma Modalı -->
@if (showTopluSutunModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white py-2">
                    <h6 class="modal-title"><i class="bi bi-calendar-day me-2"></i>@topluSutunTarih.ToString("dd MMMM dddd", turkce)</h6>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showTopluSutunModal = false"></button>
