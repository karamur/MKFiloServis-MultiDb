        }
    }

    private async Task GunlukKaydet()
    {
        if (editGunluk == null) return;

        try
        {
            // Saatlik personel için saat bilgisini kaydet
            if (editPersonelSaatlik)
            {
                editGunluk.CalismaSaati = editCalismaSaati;
                if (editCalismaSaati > 0)
                    editGunluk.Calisti = true;
            }

            await PuantajService.SaveGunlukPuantajAsync(editGunluk);

            // Günlük map güncelle
            if (gunlukPuantajMap.ContainsKey(editPuantajId))
            {
                var mevcutIndex = gunlukPuantajMap[editPuantajId].FindIndex(g => g.Tarih.Date == editGunluk.Tarih.Date);
                if (mevcutIndex >= 0)
                    gunlukPuantajMap[editPuantajId][mevcutIndex] = editGunluk;
                else
                    gunlukPuantajMap[editPuantajId].Add(editGunluk);
            }
            else
            {
                gunlukPuantajMap[editPuantajId] = new List<GunlukPuantaj> { editGunluk };
            }

            // Aylık puantaj özetini güncelle
            await GunluktenPuantajOzetGuncelle(editPuantajId);

            degisiklikVar = true;
            showModal = false;
            ShowBildirim("Kaydedildi", $"{editGunluk.Tarih:dd.MM.yyyy} günü güncellendi.", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Kaydetme hatası: {ex.Message}", "danger");
        }
    }

    private async Task GunluktenPuantajOzetGuncelle(int puantajId)
    {
        if (!gunlukPuantajMap.ContainsKey(puantajId)) return;

        var gunlukler = gunlukPuantajMap[puantajId];
        var puantaj = puantajListesi.FirstOrDefault(p => p.Id == puantajId);
        if (puantaj == null) return;

        puantaj.CalisilanGun = gunlukler.Count(g => g.Calisti);
        puantaj.IzinGunu = gunlukler.Count(g => g.Izinli);
        puantaj.MazeretGunu = gunlukler.Count(g => g.Mazeret);
        puantaj.FazlaMesaiSaat = gunlukler.Sum(g => g.FazlaMesaiSaat);

        await PuantajService.CreateOrUpdatePuantajAsync(puantaj);
    }

