@code {
    private List<Firma> firmalar = new();
    private List<Sofor> tumSoforler = new();
    private List<PersonelPuantaj> puantajListesi = new();
    private List<PersonelPuantaj> filtrelenmisListe = new();
    private Dictionary<int, List<GunlukPuantaj>> gunlukPuantajMap = new();
    private HashSet<int> seciliPersonelIds = new();

    private bool isLoading = true;
    private bool yenilemeCalisiyor = false;
    private bool disposed = false;
    private bool degisiklikVar = false;
    private int filtreFirmaId = 1;
    private int filtreYil = DateTime.Today.Year;
    private int filtreAy = DateTime.Today.Month;
    private string aramaMetni = "";

    // Modal
    private bool showModal = false;
    private GunlukPuantaj? editGunluk;
    private string editPersonelAdi = "";
    private int editPuantajId = 0;
    private bool editPersonelSaatlik = false;
    private decimal editPersonelBirimUcret = 0;
    private decimal editCalismaSaati = 0;

    // Toast
    private bool showToast = false;
    private string toastMesaj = "";
    private string toastBaslik = "";
    private string toastClass = "";
    private string toastIcon = "";
    private System.Timers.Timer? toastTimer;

    // AI Analiz
    private bool aiModal = false;
    private bool aiAnalizing = false;
    private string? aiSonuc;
    private string aiSure = "";
    private List<PuantajAIAksiyon> aiAksiyonlar = new();

    // Hafta Sonu / Bayram Seçenekleri
    private bool showHaftaSonuModal = false;
    private bool cumartesiCalisir = true;
    private bool pazarCalisir = false;
    private bool bayramlarCalisir = false;
    private bool haftaSonuSeciliMod = false; // true: seçili, false: toplu

    // Personel Kart Düzenleme
    private bool showPersonelKartModal = false;
    private Sofor? editKartPersonel;
    private decimal editKartBirimUcret = 0;

    // Toplu Satır Doldurma
    private bool showTopluSatirModal = false;
    private int topluSatirPuantajId = 0;
    private string topluSatirPersonelAdi = "";
    private bool topluSatirIsSaatlik = false;

    // Toplu Sütun (Gün) Doldurma
    private bool showTopluSutunModal = false;
    private int topluSutunGun = 0;
    private DateTime topluSutunTarih = DateTime.MinValue;

    // Saatlik Toplu Saat Girişi
    private bool showTopluSaatModal = false;
    private int topluSaatPuantajId = 0;
    private string topluSaatPersonelAdi = "";
    private decimal topluSaatGunlukSaat = 8;
    private bool topluSaatHaftaiciSadece = true;
    private Dictionary<int, decimal> topluSaatGunMap = new(); // gun(1-31) -> saat

    // Toplu Birim Ücret Değiştirme
    private bool showTopluBirimUcretModal = false;
    private List<BirimUcretSatir> topluBirimUcretListesi = new();
    private decimal topluBirimUcretHepsine = 0;
    private class BirimUcretSatir { public int SoforId { get; set; } public string Ad { get; set; } = ""; public decimal Mevcut { get; set; } public decimal Yeni { get; set; } }

    private System.Globalization.CultureInfo turkce = new("tr-TR");

    private int AyGunSayisi => DateTime.DaysInMonth(filtreYil, filtreAy);
    private List<Sofor> OlusturulabilirPersoneller => tumSoforler
        .Where(s => s.Aktif && !s.IsDeleted)
        .Where(s => puantajListesi.All(p => p.PersonelId != s.Id))
        .Where(s => string.IsNullOrWhiteSpace(aramaMetni)
            || s.TamAd.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
            || (s.SoforKodu != null && s.SoforKodu.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)))
        .OrderBy(s => s.SiralamaNo == 0 ? int.MaxValue : s.SiralamaNo)
        .ThenBy(s => s.Ad)
        .ThenBy(s => s.Soyad)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        if (firmalar.Any())
            filtreFirmaId = firmalar.First().Id;

        await LoadPersonellerAsync();
        await YenileAsync();
    }

    private async Task LoadPersonellerAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        tumSoforler = await context.Soforler
            .AsNoTracking()
            .Where(s => !s.IsDeleted && s.Aktif)
            .OrderBy(s => s.Ad).ThenBy(s => s.Soyad)
            .ToListAsync();
    }

    private async Task YenileAsync()
    {
        if (yenilemeCalisiyor)
        {
            return;
        }

        yenilemeCalisiyor = true;
        isLoading = true;
        StateHasChanged();

        try
        {
            puantajListesi = await PuantajService.GetAylikPuantajAsync(filtreFirmaId, filtreYil, filtreAy);

            // Günlük puantajları yükle
            gunlukPuantajMap.Clear();
            foreach (var p in puantajListesi)
            {
                var gunlukler = await PuantajService.GetGunlukPuantajlarAsync(p.Id);
                gunlukPuantajMap[p.Id] = gunlukler;
            }

            FiltreleListeyi();
            seciliPersonelIds.RemoveWhere(id => OlusturulabilirPersoneller.All(p => p.Id != id));
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Veri yükleme hatası: {ex.Message}", "danger");
        }
        finally
        {
            isLoading = false;
            yenilemeCalisiyor = false;
            if (!disposed)
            {
                StateHasChanged();
            }
        }
    }

    private void FiltreleListeyi()
    {
        if (string.IsNullOrWhiteSpace(aramaMetni))
        {
            filtrelenmisListe = puantajListesi;
        }
        else
        {
            var aranan = aramaMetni.ToLowerInvariant();
            filtrelenmisListe = puantajListesi.Where(p =>
                (p.Personel != null && ($"{p.Personel.Ad} {p.Personel.Soyad}").ToLowerInvariant().Contains(aranan)) ||
                (p.Personel != null && p.Personel.SoforKodu != null && p.Personel.SoforKodu.ToLowerInvariant().Contains(aranan))
            ).ToList();
        }
        StateHasChanged();
    }

    private void ResmiHesapPusulasiAc()
    {
        if (filtreFirmaId <= 0)
        {
            ShowBildirim("Uyarı", "Lütfen önce bir firma seçin.", "warning");
            return;
        }

        var hedefListe = filtrelenmisListe.Any() ? filtrelenmisListe : puantajListesi;
        if (!hedefListe.Any())
        {
            ShowBildirim("Uyarı", "Hesap pusulası için personel bulunamadı.", "warning");
            return;
        }

        var tip = hedefListe.All(p => p.Personel?.ArgePersoneli == true)
            ? BordroTipi.Arge
            : BordroTipi.Normal;

        var personelIdQuery = Uri.EscapeDataString(string.Join(",", hedefListe.Select(p => p.PersonelId).Distinct()));
        Nav.NavigateTo($"/personel/bordro/hesap-pusulasi?yil={filtreYil}&ay={filtreAy}&firmaId={filtreFirmaId}&tip={(int)tip}&personelIds={personelIdQuery}");
    }

    private async Task TopluPuantajOlustur()
    {
        var olusturulacakPersoneller = OlusturulabilirPersoneller;
        if (!olusturulacakPersoneller.Any())
        {
            ShowBildirim("Uyarı", "Aktif personel bulunamadı.", "warning");
            return;
        }

        haftaSonuSeciliMod = false;
        showHaftaSonuModal = true;
    }

    private async Task SeciliPuantajOlustur()
    {
        var seciliPersoneller = OlusturulabilirPersoneller
            .Where(p => seciliPersonelIds.Contains(p.Id))
            .ToList();

        if (!seciliPersoneller.Any())
        {
            ShowBildirim("Uyarı", "Lütfen en az bir personel seçin.", "warning");
            return;
        }

        haftaSonuSeciliMod = true;
        showHaftaSonuModal = true;
    }

    private async Task HaftaSonuSecimOnay()
    {
        showHaftaSonuModal = false;
        StateHasChanged();

        List<Sofor> hedefPersoneller;
        if (haftaSonuSeciliMod)
        {
            hedefPersoneller = tumSoforler
                .Where(s => s.Aktif && !s.IsDeleted && seciliPersonelIds.Contains(s.Id))
                .Where(s => puantajListesi.All(p => p.PersonelId != s.Id))
                .ToList();
        }
        else
        {
            hedefPersoneller = tumSoforler
                .Where(s => s.Aktif && !s.IsDeleted)
                .Where(s => puantajListesi.All(p => p.PersonelId != s.Id))
                .ToList();
        }

        if (!hedefPersoneller.Any()) return;

        isLoading = true;
        StateHasChanged();

        try
        {
            var olusturulan = await PuantajlariOlusturAsync(hedefPersoneller);
            await YenileAsync();
            await GunluklerdenOzetGuncelle();
            ShowBildirim("Başarılı", $"{olusturulan} personel için puantaj oluşturuldu.", "success");
        }
        catch (Exception ex)
        {
            var innerMsg = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
            ShowBildirim("Hata", $"Puantaj oluşturma hatası: {innerMsg}", "danger");
        }
        finally
        {
            isLoading = false;
            yenilemeCalisiyor = false;
            if (!disposed)
            {
                StateHasChanged();
            }
        }
    }

    private List<DateTime> GetResmiTatiller(int yil, int ay)
    {
        var tatiller = new List<DateTime>
        {
            new(yil, 1, 1),   // Yılbaşı
            new(yil, 4, 23),  // Ulusal Egemenlik ve Çocuk Bayramı
            new(yil, 5, 1),   // Emek ve Dayanışma Günü
            new(yil, 5, 19),  // Atatürk'ü Anma, Gençlik ve Spor Bayramı
            new(yil, 7, 15),  // Demokrasi ve Milli Birlik Günü
            new(yil, 8, 30),  // Zafer Bayramı
            new(yil, 10, 29), // Cumhuriyet Bayramı
        };

        // Dini bayramlar (yaklaşık tarihler - her yıl güncellenmeli)
        var diniBayramlar = yil switch
        {
            2024 => new List<DateTime>
            {
                new(2024, 4, 10), new(2024, 4, 11), new(2024, 4, 12), // Ramazan Bayramı
                new(2024, 6, 17), new(2024, 6, 18), new(2024, 6, 19), new(2024, 6, 20), // Kurban Bayramı
            },
            2025 => new List<DateTime>
            {
                new(2025, 3, 30), new(2025, 3, 31), new(2025, 4, 1), // Ramazan Bayramı
                new(2025, 6, 6), new(2025, 6, 7), new(2025, 6, 8), new(2025, 6, 9), // Kurban Bayramı
            },
            2026 => new List<DateTime>
            {
                new(2026, 3, 20), new(2026, 3, 21), new(2026, 3, 22), // Ramazan Bayramı
                new(2026, 5, 27), new(2026, 5, 28), new(2026, 5, 29), new(2026, 5, 30), // Kurban Bayramı
            },
            _ => new List<DateTime>()
        };

        tatiller.AddRange(diniBayramlar);
        return tatiller.Where(t => t.Month == ay).OrderBy(t => t.Day).ToList();
    }

    private async Task<int> PuantajlariOlusturAsync(List<Sofor> personeller)
    {
        int olusturulan = 0;

        if (filtreFirmaId <= 0)
        {
            throw new InvalidOperationException("Lütfen önce bir firma seçin.");
        }

        foreach (var personel in personeller)
        {
            var mevcut = puantajListesi.FirstOrDefault(p => p.PersonelId == personel.Id);
            if (mevcut == null)
            {
                try
                {
                    var yeniPuantaj = new PersonelPuantaj
                    {
                        FirmaId = filtreFirmaId,
                        PersonelId = personel.Id,
                        Yil = filtreYil,
                        Ay = filtreAy,
                        CalisilanGun = 0,
                        BrutMaas = personel.BrutMaas,
                        NetOdeme = personel.NetMaas,
                        BankaHesapNo = personel.IBAN
                    };

                    var kaydedilen = await PuantajService.CreateOrUpdatePuantajAsync(yeniPuantaj);
                    var tatiller = bayramlarCalisir ? null : GetResmiTatiller(filtreYil, filtreAy);
                    await PuantajService.OtomatikGunlukPuantajOlusturAsync(kaydedilen.Id, filtreYil, filtreAy, cumartesiCalisir, pazarCalisir, tatiller);
                    olusturulan++;
                }
                catch (Exception ex)
                {
                    var innerMsg = ex.InnerException?.Message ?? ex.Message;
                    throw new InvalidOperationException($"{personel.TamAd} için puantaj oluşturulamadı: {innerMsg}", ex);
                }
            }
            else if (!gunlukPuantajMap.ContainsKey(mevcut.Id) || !gunlukPuantajMap[mevcut.Id].Any())
            {
                var tatiller = bayramlarCalisir ? null : GetResmiTatiller(filtreYil, filtreAy);
                await PuantajService.OtomatikGunlukPuantajOlusturAsync(mevcut.Id, filtreYil, filtreAy, cumartesiCalisir, pazarCalisir, tatiller);
                olusturulan++;
            }
        }

        seciliPersonelIds.Clear();
        return olusturulan;
    }

    private void TumOlusturulabilirleriSec()
    {
        seciliPersonelIds = OlusturulabilirPersoneller.Select(p => p.Id).ToHashSet();
    }

    private void OlusturulabilirSecimiTemizle()
    {
        seciliPersonelIds.Clear();
    }

    private void PersonelSecimDegisti(int personelId, ChangeEventArgs e)
    {
        var secili = e.Value is bool b && b;
        if (secili)
            seciliPersonelIds.Add(personelId);
        else
            seciliPersonelIds.Remove(personelId);
    }

    private void HucreTikla(int puantajId, DateTime tarih, GunlukPuantaj? gunluk)
    {
        editPuantajId = puantajId;
        var puantaj = puantajListesi.FirstOrDefault(p => p.Id == puantajId);
        if (puantaj?.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi)
        {
            ShowBildirim("Uyarı", "Onaylanmış puantaj düzenlenemez.", "warning");
            return;
        }

        editPersonelAdi = puantaj?.Personel != null ? $"{puantaj.Personel.Ad} {puantaj.Personel.Soyad}" : "Personel";
        editPersonelSaatlik = puantaj?.Personel?.BrutMaasHesaplamaTipi == BrutMaasHesaplamaTipi.Saatlik;
        editPersonelBirimUcret = puantaj?.Personel?.BirimUcret ?? 0;

        if (gunluk != null)
        {
            editGunluk = new GunlukPuantaj
            {
                Id = gunluk.Id,
                PersonelPuantajId = gunluk.PersonelPuantajId,
                Gun = gunluk.Gun,
                Tarih = gunluk.Tarih,
                Durum = gunluk.Durum,
                Calisti = gunluk.Calisti,
                FazlaMesaiSaat = gunluk.FazlaMesaiSaat,
                Izinli = gunluk.Izinli,
                Mazeret = gunluk.Mazeret,
                ServisCalismaId = gunluk.ServisCalismaId,
                Notlar = gunluk.Notlar,
                CalismaSaati = gunluk.CalismaSaati
            };
            editCalismaSaati = gunluk.CalismaSaati > 0 ? gunluk.CalismaSaati : (editPersonelSaatlik && gunluk.Calisti ? (puantaj?.Personel?.CalismaMiktari ?? 8) : 0);
        }
        else
        {
            var gunNo = tarih.Day;
            editGunluk = new GunlukPuantaj
            {
                PersonelPuantajId = puantajId,
                Gun = gunNo,
                Tarih = tarih,
                Calisti = tarih.DayOfWeek != DayOfWeek.Sunday,
                Izinli = false,
                Mazeret = false
            };
            editCalismaSaati = editPersonelSaatlik && tarih.DayOfWeek != DayOfWeek.Sunday ? (puantaj?.Personel?.CalismaMiktari ?? 8) : 0;
        }

        showModal = true;
    }

    private void PersonelKartAc(Sofor? personel)
    {
        if (personel == null) return;
        editKartPersonel = personel;
        editKartBirimUcret = personel.BirimUcret;
        showPersonelKartModal = true;
    }

    private async Task PersonelKartKaydet()
    {
        if (editKartPersonel == null) return;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var personel = await context.Soforler.FindAsync(editKartPersonel.Id);
            if (personel != null)
            {
                personel.BirimUcret = editKartBirimUcret;
                personel.UpdatedAt = DateTime.UtcNow;
                await context.SaveChangesAsync();
                editKartPersonel.BirimUcret = editKartBirimUcret;
            }
            showPersonelKartModal = false;
            ShowBildirim("Kaydedildi", $"{editKartPersonel.TamAd} birim ücret güncellendi.", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Kaydetme hatası: {ex.Message}", "danger");
        }
    }

    private void CalistiDegisti()
    {
        if (editGunluk == null) return;
        if (editGunluk.Calisti)
        {
            editGunluk.Izinli = false;
            editGunluk.Mazeret = false;
        }
    }

    private void IzinliDegisti()
    {
        if (editGunluk == null) return;
        if (editGunluk.Izinli)
        {
            editGunluk.Calisti = false;
            editGunluk.Mazeret = false;
        }
