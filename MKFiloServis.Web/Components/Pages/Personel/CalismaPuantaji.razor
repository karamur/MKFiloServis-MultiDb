    private async Task TopluSutunUygula(string mod)
    {
        showTopluSutunModal = false;
        isLoading = true;
        StateHasChanged();

        try
        {
            foreach (var puantaj in filtrelenmisListe)
            {
                if (puantaj.OnayDurumu == PersonelPuantajOnayDurumu.Onaylandi) continue;
                if (!gunlukPuantajMap.ContainsKey(puantaj.Id)) continue;

                var g = gunlukPuantajMap[puantaj.Id].FirstOrDefault(x => x.Tarih.Date == topluSutunTarih.Date);
                if (g == null) continue;

                switch (mod)
                {
                    case "calisir":
                        g.Calisti = true; g.Izinli = false; g.Mazeret = false;
                        break;
                    case "izin":
                        g.Calisti = false; g.Izinli = true; g.Mazeret = false;
                        break;
                    case "mazeret":
                        g.Calisti = false; g.Izinli = false; g.Mazeret = true;
                        break;
                    case "temizle":
                        g.Calisti = false; g.Izinli = false; g.Mazeret = false;
                        g.FazlaMesaiSaat = 0; g.CalismaSaati = 0;
                        break;
                }
                await PuantajService.SaveGunlukPuantajAsync(g);
                await GunluktenPuantajOzetGuncelle(puantaj.Id);
            }

            degisiklikVar = true;
            ShowBildirim("Başarılı", $"{topluSutunTarih:dd.MM.yyyy} için toplu atama tamamlandı.", "success");
        }
        catch (Exception ex)
        {
            ShowBildirim("Hata", $"Toplu sütun hatası: {ex.Message}", "danger");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // Durum Helper Metodları
    private string GetGunlukDurum(GunlukPuantaj? gunluk)    {
        if (gunluk == null) return "bos";
        if (gunluk.Izinli) return "izinli";
        if (gunluk.Mazeret) return "mazeret";
        if (gunluk.Calisti)
        {
            if (gunluk.FazlaMesaiSaat > 0)
                return "mesai";
            return "calisti";
        }
        return "bos";
    }

