@page "/personel/izin"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IPersonelMaasIzinService PersonelService
@inject ISoforService SoforService
@rendermode InteractiveServer

<PageTitle>Personel İzin Yönetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-calendar-check me-2"></i>Personel İzin Yönetimi</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 120px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <button class="btn btn-info" @onclick="IzinHaklariOlustur">
                <i class="bi bi-arrow-repeat me-1"></i>İzin Hakları oluştur
            </button>
            <button class="btn btn-success" @onclick="YeniIzinAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni İzin Talebi
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (izinRapor != null)
    {
        <!-- Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Toplam Personel</h6>
                        <h3 class="mb-0">@izinRapor.ToplamPersonel</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Kullanılan İzin</h6>
                        <h3 class="mb-0">@izinRapor.ToplamKullanilanIzin Gün</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Kalan İzin</h6>
                        <h3 class="mb-0">@izinRapor.ToplamKalanIzin Gün</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Bekleyen Talep</h6>
                        <h3 class="mb-0">@bekleyenIzinler.Count</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- İzin Tipi Özeti -->
        @if (izinRapor.TipBazliOzet.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>İzin Türü Dağılımı</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var tip in izinRapor.TipBazliOzet)
                        {
                            <div class="col-md-3 mb-2">
                                <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                    <span>@tip.IzinTipiAdi</span>
                                    <span class="badge bg-primary">@tip.ToplamGun Gün (@tip.Adet talep)</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Bekleyen İzin Talepleri -->
        @if (bekleyenIzinler.Any())
        {
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Bekleyen İzin Talepleri</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Personel</th>
                                    <th>İzin Türü</th>
                                    <th>Başlangıç</th>
                                    <th>Bitiş</th>
                                    <th class="text-center">Gün</th>
                                    <th>Açıklama</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var izin in bekleyenIzinler)
                                {
                                    <tr>
                                        <td><strong>@izin.Sofor.TamAd</strong></td>
                                        <td>@GetIzinTipiAdi(izin.IzinTipi)</td>
                                        <td>@izin.BaslangicTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>@izin.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                        <td class="text-center"><span class="badge bg-primary">@izin.ToplamGun</span></td>
                                        <td>@izin.Aciklama</td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-success" @onclick="() => IzinOnayla(izin.Id)" title="Onayla">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button class="btn btn-danger" @onclick="() => IzinReddet(izin.Id)" title="Reddet">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Personel İzin Hakları -->
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-people me-2"></i>Personel İzin Hakları - @secilenYil</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Personel</th>
                                <th class="text-center">Yıllık Hak</th>
                                <th class="text-center">Devreden</th>
                                <th class="text-center">Toplam Hak</th>
                                <th class="text-center">Kullanılan</th>
                                <th class="text-center">Kalan</th>
                                <th>İzin Geçmişi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detay in izinRapor.Detaylar)
                            {
                                <tr>
                                    <td><strong>@detay.SoforAdSoyad</strong></td>
                                    <td class="text-center">@detay.YillikHak</td>
                                    <td class="text-center">@detay.DevirenIzin</td>
                                    <td class="text-center"><span class="badge bg-primary">@(detay.YillikHak + detay.DevirenIzin)</span></td>
                                    <td class="text-center"><span class="badge bg-warning text-dark">@detay.KullanilanIzin</span></td>
                                    <td class="text-center">
                                        <span class="badge @(detay.KalanIzin > 5 ? "bg-success" : detay.KalanIzin > 0 ? "bg-warning text-dark" : "bg-danger")">
                                            @detay.KalanIzin
                                        </span>
                                    </td>
                                    <td>
                                        @if (detay.IzinKayitlari.Any())
                                        {
                                            <button class="btn btn-sm btn-outline-info" @onclick="() => IzinGecmisiGoster(detay.SoforId)">
                                                <i class="bi bi-eye me-1"></i>@detay.IzinKayitlari.Count kayıt
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Yeni İzin Modal -->
@if (showYeniIzinModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni İzin Talebi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Personel</label>
                        <select class="form-select" @bind="yeniIzin.SoforId">
                            <option value="0">-- seçiniz --</option>
                            @foreach (var sofor in soforler)
                            {
                                <option value="@sofor.Id">@sofor.TamAd</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">İzin Türü</label>
                        <select class="form-select" @bind="yeniIzin.IzinTipi">
                            @foreach (IzinTipi tip in Enum.GetValues(typeof(IzinTipi)))
                            {
                                <option value="@tip">@GetIzinTipiAdi(tip)</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Başlangıç</label>
                            <input type="date" class="form-control" @bind="yeniIzin.BaslangicTarihi" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Bitiş</label>
                            <input type="date" class="form-control" @bind="yeniIzin.BitisTarihi" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" rows="2" @bind="yeniIzin.Aciklama"></textarea>
                    </div>
                    @if (yeniIzin.BaslangicTarihi <= yeniIzin.BitisTarihi)
                    {
                        <div class="alert alert-info py-2 mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Toplam <strong>@((yeniIzin.BitisTarihi - yeniIzin.BaslangicTarihi).Days + 1)</strong> gün izin talep edilecek.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button class="btn btn-primary" @onclick="IzinKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- İzin Geçmişi Modal -->
@if (showGecmisModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>@secilenSoforAdi - İzin Geçmişi</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showGecmisModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    @if (secilenSoforIzinleri.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>İzin Türü</th>
                                        <th>Başlangıç</th>
                                        <th>Bitiş</th>
                                        <th class="text-center">Gün</th>
                                        <th>Durum</th>
                                        <th>Açıklama</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var izin in secilenSoforIzinleri)
                                    {
                                        <tr>
                                            <td>@GetIzinTipiAdi(izin.IzinTipi)</td>
                                            <td>@izin.BaslangicTarihi.ToString("dd.MM.yyyy")</td>
                                            <td>@izin.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                            <td class="text-center"><span class="badge bg-primary">@izin.ToplamGun</span></td>
                                            <td><span class="badge @GetIzinDurumBadge(izin.Durum)">@GetIzinDurumAdi(izin.Durum)</span></td>
                                            <td><small>@(izin.Aciklama ?? "-")</small></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="3" class="text-end"><strong>Toplam Kullanılan</strong></td>
                                        <td class="text-center"><strong><span class="badge bg-warning text-dark">@secilenSoforIzinleri.Where(i => i.Durum == IzinDurum.Onaylandi).Sum(i => i.ToplamGun) gün</span></strong></td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-calendar-x fs-1"></i>
                            <p class="mt-2">Henüz izin kaydı bulunmuyor.</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showGecmisModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil = DateTime.Today.Year;
    private IzinRaporOzet? izinRapor;
    private List<PersonelIzin> bekleyenIzinler = new();
    private List<Sofor> soforler = new();
    private PersonelIzin yeniIzin = new();
    private bool isLoading = false;
    private bool showYeniIzinModal = false;

    protected override async Task OnInitializedAsync()
    {
        soforler = await SoforService.GetAllAsync();
        await YenileData();
    }

    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            izinRapor = await PersonelService.GetIzinRaporuAsync(secilenYil);
            bekleyenIzinler = await PersonelService.GetIzinlerAsync();
            bekleyenIzinler = bekleyenIzinler.Where(i => i.Durum == IzinDurum.Beklemede).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task IzinHaklariOlustur()
    {
        await PersonelService.YillikIzinHaklariOlusturAsync(secilenYil);
        await YenileData();
    }

    private void YeniIzinAc()
    {
        yeniIzin = new PersonelIzin
        {
            BaslangicTarihi = DateTime.Today,
            BitisTarihi = DateTime.Today,
            IzinTipi = IzinTipi.YillikIzin,
            Durum = IzinDurum.Beklemede
        };
        showYeniIzinModal = true;
    }

    private void ModalKapat()
    {
        showYeniIzinModal = false;
    }

    private async Task IzinKaydet()
    {
        if (yeniIzin.SoforId > 0)
        {
            await PersonelService.CreateIzinAsync(yeniIzin);
            ModalKapat();
            await YenileData();
        }
    }

    private async Task IzinOnayla(int izinId)
    {
        await PersonelService.IzinOnaylaAsync(izinId, "Admin");
        await YenileData();
    }

    private async Task IzinReddet(int izinId)
    {
        await PersonelService.IzinReddetAsync(izinId, "Talep reddedildi");
        await YenileData();
    }

    private int secilenSoforId;
    private string secilenSoforAdi = "";
    private bool showGecmisModal = false;
    private List<PersonelIzin> secilenSoforIzinleri = new();

    private async Task IzinGecmisiGoster(int soforId)
    {
        secilenSoforId = soforId;
        var sofor = soforler.FirstOrDefault(s => s.Id == soforId);
        secilenSoforAdi = sofor?.TamAd ?? "";
        var tumIzinler = await PersonelService.GetIzinlerAsync();
        secilenSoforIzinleri = tumIzinler.Where(i => i.SoforId == soforId).OrderByDescending(i => i.BaslangicTarihi).ToList();
        showGecmisModal = true;
    }

    private string GetIzinTipiAdi(IzinTipi tip)
    {
        return tip switch
        {
            IzinTipi.YillikIzin => "Yıllık İzin",
            IzinTipi.UcretsizIzin => "Ücretsiz İzin",
            IzinTipi.RaporluIzin => "Raporlu İzin",
            IzinTipi.MazeretIzni => "Mazeret İzni",
            IzinTipi.EvlilikIzni => "Evlilik İzni",
            IzinTipi.DogumIzni => "Doğum İzni",
            IzinTipi.OlumIzni => "Ölüm İzni",
            IzinTipi.IdariIzin => "İdari İzin",
            _ => tip.ToString()
        };
    }

    private string GetIzinDurumBadge(IzinDurum durum)
    {
        return durum switch
        {
            IzinDurum.Beklemede => "bg-warning text-dark",
            IzinDurum.Onaylandi => "bg-success",
            IzinDurum.Reddedildi => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetIzinDurumAdi(IzinDurum durum)
    {
        return durum switch
        {
            IzinDurum.Beklemede => "Beklemede",
            IzinDurum.Onaylandi => "Onaylandı",
            IzinDurum.Reddedildi => "Reddedildi",
            _ => durum.ToString()
        };
    }
}












