@page "/personel/{PersonelId:int}/bordrolar"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IBordroService BordroService
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(personel?.TamAd ?? "Personel") - Bordrolar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-file-earmark-text me-2"></i>Ücret Bordroları</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel Listesi</a></li>
                    @if (personel != null)
                    {
                        <li class="breadcrumb-item"><a href="/soforler/@PersonelId">@personel.TamAd</a></li>
                    }
                    <li class="breadcrumb-item active">Bordrolar</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width:120px;" @bind="secilenYil" @bind:after="YukleAsync">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation.NavigateTo("/personel")'>
                <i class="bi bi-arrow-left me-1"></i>Geri
            </button>
        </div>
    </div>

    @if (personel != null)
    {
        <!-- Personel Bilgi Kartı -->
        <div class="card mb-3 border-primary">
            <div class="card-body py-2">
                <div class="row align-items-center g-3">
                    <div class="col-auto">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                             style="width:48px;height:48px;font-size:18px;">
                            @personel.Ad[0]@personel.Soyad[0]
                        </div>
                    </div>
                    <div class="col">
                        <h5 class="mb-0">@personel.TamAd</h5>
                        <small class="text-muted">
                            @GetGorevAdi(personel.Gorev) &nbsp;|&nbsp;
                            Kod: <strong>@personel.SoforKodu</strong> &nbsp;|&nbsp;
                            TC: <strong>@(personel.TcKimlikNo ?? "-")</strong>
                        </small>
                    </div>
                    <div class="col-auto">
                        <span class="badge @(personel.Aktif ? "bg-success" : "bg-danger")">@(personel.Aktif ? "Aktif" : "Pasif")</span>
                        @if (personel.SGKBordroDahilMi)
                        {
                            <span class="badge bg-primary ms-1">SGK Bordro</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (!detaylar.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            <strong>@secilenYil</strong> yılı için kayıtlı bordro bulunamadı.
            <a href="/personel/bordro/normal" class="alert-link ms-2">Bordro oluşturmak için tıklayın →</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header bg-primary text-white py-2 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>@secilenYil Yılı Bordroları — @detaylar.Count dönem</h6>
                <button class="btn btn-light btn-sm" @onclick="TumunuIndir" disabled="@isIndiriliyor">
                    @if (isIndiriliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-download me-1"></i>Tümünü İndir (Excel)
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:100px;">Dönem</th>
                                <th>Bordro Tipi</th>
                                <th class="text-end">Brüt Maaş</th>
                                <th class="text-end">SGK İşçi</th>
                                <th class="text-end">İşsizlik</th>
                                <th class="text-end">Gelir Vergisi</th>
                                <th class="text-end">Damga Vergisi</th>
                                <th class="text-end">Özel Kesinti</th>
                                <th class="text-end bg-info bg-opacity-10">Net Ödeme</th>
                                <th class="text-end">Ek Ödemeler</th>
                                <th class="text-center" style="width:80px;">Ödeme</th>
                                <th class="text-center" style="width:110px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in detaylar.OrderByDescending(x => x.Bordro.Yil).ThenByDescending(x => x.Bordro.Ay))
                            {
                                <tr class="@(d.BankaOdemesiYapildi ? "" : "table-warning bg-opacity-25")">
                                    <td>
                                        <strong>@GetAyAdi(d.Bordro.Ay) @d.Bordro.Yil</strong>
                                        <br /><small class="text-muted">@d.Bordro.BordroTipi</small>
                                    </td>
                                    <td>
                                        <span class="badge @(d.Bordro.BordroTipi == BordroTipi.Arge ? "bg-warning text-dark" : "bg-primary")">
                                            @(d.Bordro.BordroTipi == BordroTipi.Arge ? "AR-GE" : "Normal")
                                        </span>
                                        @if (d.Bordro.Onaylandi)
                                        {
                                            <span class="badge bg-success ms-1"><i class="bi bi-check2"></i> Onaylı</span>
                                        }
                                    </td>
                                    <td class="text-end">@FormatPara(d.BrutMaas)</td>
                                    <td class="text-end text-danger">@FormatPara(d.SgkIsciPrim)</td>
                                    <td class="text-end text-danger">@FormatPara(d.IssizlikIsciPrim)</td>
                                    <td class="text-end text-danger">@FormatPara(d.GelirVergisi)</td>
                                    <td class="text-end text-danger">@FormatPara(d.DamgaVergisi)</td>
                                    <td class="text-end text-danger">@FormatPara(d.OzelKesintilerToplam)</td>
                                    <td class="text-end bg-info bg-opacity-10">
                                        <strong>@FormatPara(d.NetMaas)</strong>
                                    </td>
                                    <td class="text-end text-success">
                                        @if (d.ToplamEkOdeme > 0)
                                        {
                                            <span title="Yemek:@FormatPara(d.YemekYardimi) / Yol:@FormatPara(d.YolYardimi) / Prim:@FormatPara(d.PrimTutar)">
                                                +@FormatPara(d.ToplamEkOdeme)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (d.BankaOdemesiYapildi)
                                        {
                                            <span class="badge bg-success" title="@d.BankaOdemeTarihi?.ToString("dd.MM.yyyy")">
                                                <i class="bi bi-check-circle me-1"></i>Ödendi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Bekliyor</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => ExcelIndir(d.Id)" title="Excel Bordro İndir">
                                                <i class="bi bi-file-earmark-excel"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => BordroDetayGoster(d)" title="Detay Görüntüle">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-dark">
                            <tr>
                                <td colspan="2"><strong>TOPLAM (@detaylar.Count dönem)</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.BrutMaas))</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.SgkIsciPrim))</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.IssizlikIsciPrim))</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.GelirVergisi))</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.DamgaVergisi))</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.OzelKesintilerToplam))</strong></td>
                                <td class="text-end bg-info"><strong>@FormatPara(detaylar.Sum(d => d.NetMaas))</strong></td>
                                <td class="text-end"><strong>@FormatPara(detaylar.Sum(d => d.ToplamEkOdeme))</strong></td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Yıllık Özet -->
        <div class="row mt-3">
            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Yıllık Brüt</small>
                        <h5 class="mb-0 text-primary">@FormatPara(detaylar.Sum(d => d.BrutMaas))</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Yıllık Toplam Kesinti</small>
                        <h5 class="mb-0 text-danger">@FormatPara(detaylar.Sum(d => d.ToplamKesinti))</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-info text-white">
                    <div class="card-body py-2 text-center">
                        <small>Yıllık Net Ödeme</small>
                        <h5 class="mb-0">@FormatPara(detaylar.Sum(d => d.NetMaas))</h5>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* Bordro Detay Modal *@
@if (showDetayModal && secilenDetay != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-text me-2"></i>
                        @GetAyAdi(secilenDetay.Bordro.Ay) @secilenDetay.Bordro.Yil — Ücret Bordrosu
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDetayModal = false"></button>
                </div>
                <div class="modal-body">
                    <!-- Üst Bilgiler -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-light">
                                    <th colspan="2" class="text-center">İŞVEREN BİLGİLERİ</th>
                                </tr>
                                <tr><td>Firma</td><td><strong>@(secilenDetay.Firma?.FirmaAdi ?? secilenDetay.Bordro.Firma?.FirmaAdi ?? "-")</strong></td></tr>
                                <tr><td>Vergi No</td><td>@(secilenDetay.Firma?.VergiNo ?? "-")</td></tr>
                                <tr><td>Vergi Dairesi</td><td>@(secilenDetay.Firma?.VergiDairesi ?? "-")</td></tr>
                                <tr><td>SGK İşyeri No</td><td>-</td></tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-light">
                                    <th colspan="2" class="text-center">PERSONEL BİLGİLERİ</th>
                                </tr>
                                <tr><td>Ad Soyad</td><td><strong>@secilenDetay.Personel.TamAd</strong></td></tr>
                                <tr><td>T.C. Kimlik No</td><td><strong>@(secilenDetay.Personel.TcKimlikNo ?? "-")</strong></td></tr>
                                <tr><td>Sicil No / Kod</td><td>@secilenDetay.Personel.SoforKodu</td></tr>
                                <tr><td>İşe Giriş</td><td>@secilenDetay.Personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy")</td></tr>
                            </table>
                        </div>
                    </div>

                    <!-- Çalışma Bilgileri -->
                    <div class="row mb-3">
                        <div class="col-12">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-light">
                                    <th colspan="6" class="text-center">ÇALIŞMA BİLGİLERİ</th>
                                </tr>
                                <tr>
                                    <th class="text-center">Çalışma Günü</th>
                                    <th class="text-center">İzinli Gün</th>
                                    <th class="text-center">Raporlu Gün</th>
                                    <th class="text-center">Devamsızlık</th>
                                    <th class="text-center">SGK Çalışma Türü</th>
                                    <th class="text-center">Bordro Tipi</th>
                                </tr>
                                <tr>
                                    <td class="text-center">@(secilenDetay.Bordro.BordroDetaylar.FirstOrDefault(x=>x.Id==secilenDetay.Id)?.Id > 0 ? "-" : "-")</td>
                                    <td class="text-center">-</td>
                                    <td class="text-center">-</td>
                                    <td class="text-center">-</td>
                                    <td class="text-center">@(secilenDetay.Personel.SgkCalismaTuru?.ToString() ?? "Tam Zamanlı")</td>
                                    <td class="text-center">
                                        <span class="badge @(secilenDetay.Bordro.BordroTipi == BordroTipi.Arge ? "bg-warning text-dark" : "bg-primary")">
                                            @(secilenDetay.Bordro.BordroTipi == BordroTipi.Arge ? "AR-GE" : "Normal")
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Maaş Hesaplama Tablosu -->
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-success">
                                    <th colspan="2">KAZANÇLAR (+)</th>
                                </tr>
                                <tr><td>Brüt Maaş</td><td class="text-end"><strong>@FormatPara(secilenDetay.BrutMaas)</strong></td></tr>
                                @if (secilenDetay.SgkMaasi > 0 && secilenDetay.SgkMaasi != secilenDetay.BrutMaas)
                                {
                                    <tr><td>SGK Matrahı (Bildirilen)</td><td class="text-end">@FormatPara(secilenDetay.SgkMaasi)</td></tr>
                                }
                                @if (secilenDetay.YemekYardimi > 0)
                                {
                                    <tr><td>Yemek Yardımı</td><td class="text-end text-success">+@FormatPara(secilenDetay.YemekYardimi)</td></tr>
                                }
                                @if (secilenDetay.YolYardimi > 0)
                                {
                                    <tr><td>Yol Yardımı</td><td class="text-end text-success">+@FormatPara(secilenDetay.YolYardimi)</td></tr>
                                }
                                @if (secilenDetay.AileYardimi > 0)
                                {
                                    <tr><td>Aile Yardımı</td><td class="text-end text-success">+@FormatPara(secilenDetay.AileYardimi)</td></tr>
                                }
                                @if (secilenDetay.PrimTutar > 0)
                                {
                                    <tr><td>Prim</td><td class="text-end text-success">+@FormatPara(secilenDetay.PrimTutar)</td></tr>
                                }
                                @if (secilenDetay.Ikramiye > 0)
                                {
                                    <tr><td>İkramiye</td><td class="text-end text-success">+@FormatPara(secilenDetay.Ikramiye)</td></tr>
                                }
                                @if (secilenDetay.DigerEkOdeme > 0)
                                {
                                    <tr><td>Diğer Ek Ödeme</td><td class="text-end text-success">+@FormatPara(secilenDetay.DigerEkOdeme)</td></tr>
                                }
                                <tr class="table-light">
                                    <td><strong>Toplam Kazanç</strong></td>
                                    <td class="text-end"><strong>@FormatPara(secilenDetay.BrutMaas + secilenDetay.ToplamEkOdeme)</strong></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-danger">
                                    <th colspan="3">KESİNTİLER (-)</th>
                                </tr>
                                <tr>
                                    <td>SGK İşçi Payı (%14)</td>
                                    <td class="text-end text-danger">-@FormatPara(secilenDetay.SgkIsciPrim)</td>
                                    <td class="text-end text-muted"><small>Matrah: @FormatPara(secilenDetay.SgkMaasi > 0 ? secilenDetay.SgkMaasi : secilenDetay.BrutMaas)</small></td>
                                </tr>
                                <tr>
                                    <td>İşsizlik İşçi Payı (%1)</td>
                                    <td class="text-end text-danger">-@FormatPara(secilenDetay.IssizlikIsciPrim)</td>
                                    <td></td>
                                </tr>
                                <tr class="table-warning">
                                    <td>Gelir Vergisi Matrahı</td>
                                    <td class="text-end"><strong>@FormatPara(secilenDetay.KumulatifVergiMatrahi)</strong></td>
                                    <td class="text-end text-muted"><small>@secilenDetay.UygulananVergiDilimi. dilim</small></td>
                                </tr>
                                <tr>
                                    <td>Gelir Vergisi</td>
                                    <td class="text-end text-danger">-@FormatPara(secilenDetay.GelirVergisi)</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td>Damga Vergisi</td>
                                    <td class="text-end text-danger">-@FormatPara(secilenDetay.DamgaVergisi)</td>
                                    <td></td>
                                </tr>
                                @if (secilenDetay.IcraKesintisi > 0)
                                {
                                    <tr><td>İcra Kesintisi</td><td class="text-end text-danger">-@FormatPara(secilenDetay.IcraKesintisi)</td><td></td></tr>
                                }
                                @if (secilenDetay.BESKesintisi > 0)
                                {
                                    <tr><td>BES Kesintisi</td><td class="text-end text-danger">-@FormatPara(secilenDetay.BESKesintisi)</td><td></td></tr>
                                }
                                @if (secilenDetay.SendikaKesintisi > 0)
                                {
                                    <tr><td>Sendika Kesintisi</td><td class="text-end text-danger">-@FormatPara(secilenDetay.SendikaKesintisi)</td><td></td></tr>
                                }
                                @if (secilenDetay.HayatSigortasi > 0)
                                {
                                    <tr><td>Hayat Sigortası</td><td class="text-end text-danger">-@FormatPara(secilenDetay.HayatSigortasi)</td><td></td></tr>
                                }
                                @if (secilenDetay.DigerOzelKesinti > 0)
                                {
                                    <tr><td>Diğer Kesinti</td><td class="text-end text-danger">-@FormatPara(secilenDetay.DigerOzelKesinti)</td><td></td></tr>
                                }
                                <tr class="table-light">
                                    <td><strong>Toplam Kesinti</strong></td>
                                    <td class="text-end text-danger"><strong>-@FormatPara(secilenDetay.ToplamKesinti)</strong></td>
                                    <td></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Net Ödeme -->
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-info">
                                    <td><strong>NET ÖDEME (Bankaya Yatan)</strong></td>
                                    <td class="text-end"><strong class="fs-5 text-primary">@FormatPara(secilenDetay.NetMaas)</strong></td>
                                </tr>
                                @if (secilenDetay.EkOdeme > 0)
                                {
                                    <tr>
                                        <td>Ek Ödeme (SGK Dışı)</td>
                                        <td class="text-end text-success">+@FormatPara(secilenDetay.EkOdeme)</td>
                                    </tr>
                                }
                                <tr class="table-success">
                                    <td><strong>TOPLAM ÖDENECEk</strong></td>
                                    <td class="text-end"><strong class="fs-5">@FormatPara(secilenDetay.ToplamOdenecek)</strong></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm table-bordered mb-0">
                                <tr class="table-light">
                                    <th colspan="2" class="text-center">İŞVEREN MALİYETİ</th>
                                </tr>
                                <tr><td>SGK İşveren Payı (%15.5)</td><td class="text-end">@FormatPara(secilenDetay.SgkIsverenPrim)</td></tr>
                                <tr><td>İşsizlik İşveren Payı (%2)</td><td class="text-end">@FormatPara(secilenDetay.IssizlikIsverenPrim)</td></tr>
                                <tr class="table-warning">
                                    <td><strong>Toplam İşveren Maliyeti</strong></td>
                                    <td class="text-end"><strong>@FormatPara(secilenDetay.ToplamIsverenMaliyetDahilMaas)</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-success" @onclick="() => ExcelIndir(secilenDetay.Id)">
                        <i class="bi bi-file-earmark-excel me-1"></i>Excel İndir
                    </button>
                    <button class="btn btn-outline-danger" @onclick="() => BordroYazdir(secilenDetay.Id)">
                        <i class="bi bi-printer me-1"></i>Yazdır / PDF
                    </button>
                    <button class="btn btn-secondary" @onclick="() => showDetayModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int PersonelId { get; set; }

    private Sofor? personel;
    private List<BordroDetay> detaylar = new();
    private int secilenYil = DateTime.Now.Year;
    private bool isLoading = true;
    private bool isIndiriliyor = false;

    private bool showDetayModal = false;
    private BordroDetay? secilenDetay;

    protected override async Task OnInitializedAsync()
    {
        await YukleAsync();
    }

    private async Task YukleAsync()
    {
        isLoading = true;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();

            personel = await ctx.Soforler
                .AsNoTracking()
                .FirstOrDefaultAsync(s => s.Id == PersonelId && !s.IsDeleted);

            if (personel == null) return;

            detaylar = await ctx.BordroDetaylar
                .Include(d => d.Bordro).ThenInclude(b => b.Firma)
                .Include(d => d.Personel)
                .Include(d => d.Firma)
                .Where(d => d.PersonelId == PersonelId && d.Bordro.Yil == secilenYil)
                .OrderByDescending(d => d.Bordro.Ay)
                .AsNoTracking()
                .ToListAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Yükleme hatası: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BordroDetayGoster(BordroDetay detay)
    {
        secilenDetay = detay;
        showDetayModal = true;
    }

    private async Task ExcelIndir(int detayId)
    {
        try
        {
            var bytes = await BordroService.ExportUcretBordrosuAsync(detayId);
            var detay = detaylar.FirstOrDefault(d => d.Id == detayId);
            var dosyaAdi = $"bordro_{personel?.TamAd.Replace(" ", "_")}_{detay?.Bordro.Yil}_{detay?.Bordro.Ay:00}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Bordro Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task BordroYazdir(int detayId)
    {
        try
        {
            var bytes = await BordroService.ExportUcretBordrosuAsync(detayId);
            var dosyaAdi = $"bordro_{personel?.TamAd.Replace(" ","_")}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task TumunuIndir()
    {
        if (!detaylar.Any()) return;
        isIndiriliyor = true;
        try
        {
            var ids = detaylar.Select(d => d.Id).ToList();
            var bytes = await BordroService.ExportTopluUcretBordrosuAsync(ids);
            var dosyaAdi = $"bordrolar_{personel?.TamAd.Replace(" ", "_")}_{secilenYil}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess($"{detaylar.Count} bordro Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isIndiriliyor = false;
        }
    }

    private static string FormatPara(decimal t) => t.ToString("N2") + " ₺";

    private static string GetAyAdi(int ay) => new DateTime(2024, ay, 1).ToString("MMMM");

