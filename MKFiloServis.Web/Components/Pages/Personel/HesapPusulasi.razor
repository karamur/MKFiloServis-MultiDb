@page "/personel/bordro/hesap-pusulasi"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Components
@inject IBordroService BordroService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Bordro Hesap Pusulası</PageTitle>

<div class="container-fluid no-print">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-file-earmark-text me-2"></i>Bordro Hesap Pusulası</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Hesap Pusulası</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Filtre Bölümü -->
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Yıl</label>
                    <select class="form-select form-select-sm" @bind="secilenYil" @bind:after="YilDegisti">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="secilenFirmaId" @bind:after="FirmaDegisti">
                        <option value="0">Tüm Firmalar</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bordro Tipi</label>
                    <select class="form-select form-select-sm" @bind="secilenTip" @bind:after="TipDegisti">
                        <option value="@BordroTipi.Normal">Normal</option>
                        <option value="@BordroTipi.Arge">AR-GE</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Dönem</label>
                    <select class="form-select form-select-sm" @bind="secilenBordroId" @bind:after="BordroDegisti">
                        <option value="0">-- Dönem Seçiniz --</option>
                        @foreach (var bordro in bordrolar)
                        {
                            <option value="@bordro.Id">
                                @bordro.DonemeAdi
                                @(bordro.Firma != null ? $" - {bordro.Firma.FirmaAdi}" : "")
                                @(bordro.Onaylandi ? " ✓" : "")
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3 text-end">
                    @if (detaylar.Count > 0)
                    {
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="TopluYazdir">
                            <i class="bi bi-printer me-1"></i>Tümünü Yazdır (@detaylar.Count kişi)
                        </button>
                        <button class="btn btn-outline-success btn-sm" @onclick="RaptinCsvAktar">
                            <i class="bi bi-filetype-csv me-1"></i>Raptin CSV Aktar
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-2 text-muted">Bordro detayları yükleniyor...</p>
        </div>
    }
    else if (secilenBordroId == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Hesap pusulası oluşturmak için yukarıdan bir dönem seçiniz.
        </div>
    }
    else if (detaylar.Count == 0)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Seçilen dönemde bordro detayı bulunamadı.
        </div>
    }
    else
    {
        <!-- Personel Listesi -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">
                        <i class="bi bi-people me-1"></i>Personel Listesi (@detaylar.Count kişi)
                    </span>
                    <div>
                        <button class="btn btn-outline-secondary btn-sm me-1" @onclick="TumunuSec">
                            <i class="bi bi-check-all me-1"></i>Tümünü Seç
                        </button>
                        <button class="btn btn-outline-secondary btn-sm me-1" @onclick="SecimTemizle">
                            <i class="bi bi-x-lg me-1"></i>Temizle
                        </button>
                        @if (SeciliSayisi > 0)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="SecilenleriYazdir">
                                <i class="bi bi-printer me-1"></i>Seçilenleri Yazdır (@SeciliSayisi kişi)
                            </button>
                        }
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px;">
                                    <input type="checkbox" class="form-check-input" @bind="tumSecili" @bind:after="TumSeciliDegisti" />
                                </th>
                                <th>Personel</th>
                                <th>Görev</th>
                                <th class="text-end">Brüt Maaş</th>
                                <th class="text-end">SGK İşçi</th>
                                <th class="text-end">Net Maaş</th>
                                <th class="text-end">Kesintiler</th>
                                <th class="text-end">İşveren Mlyt</th>
                                <th class="text-end">Ek Ödemeler</th>
                                <th class="text-end">Toplam Ödenecek</th>
                                <th style="width:80px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detay in detaylar)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" class="form-check-input" @bind="detay.Secili" />
                                    </td>
                                    <td>
                                        <strong>@(detay.Personel?.TamAd ?? "-")</strong>
                                        <br /><small class="text-muted">@(detay.Personel?.SoforKodu ?? "")</small>
                                    </td>
                                    <td><small>@GorevAdi(detay.Personel?.Gorev)</small></td>
                                    <td class="text-end">@detay.BrutMaas.ToString("N2")</td>
                                    <td class="text-end"><small>@detay.SgkIssizlikKesinti.ToString("N2")</small></td>
                                    <td class="text-end">@detay.NetMaas.ToString("N2")</td>
                                    <td class="text-end text-danger">@detay.ToplamKesinti.ToString("N2")</td>
                                    <td class="text-end"><small class="text-info">@detay.ToplamIsverenMaliyet.ToString("N2")</small></td>
                                    <td class="text-end text-success">@detay.ToplamEkOdeme.ToString("N2")</td>
                                    <td class="text-end fw-bold">@detay.ToplamOdenecek.ToString("N2")</td>
                                    <td class="text-center">
                                        <button class="btn btn-outline-primary btn-sm" title="Yazdır" @onclick="() => TekYazdir(detay)">
                                            <i class="bi bi-printer"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="3">TOPLAM</td>
                                <td class="text-end">@detaylar.Sum(d => d.BrutMaas).ToString("N2")</td>
                                <td class="text-end">@detaylar.Sum(d => d.SgkIssizlikKesinti).ToString("N2")</td>
                                <td class="text-end">@detaylar.Sum(d => d.NetMaas).ToString("N2")</td>
                                <td class="text-end text-danger">@detaylar.Sum(d => d.ToplamKesinti).ToString("N2")</td>
                                <td class="text-end text-info">@detaylar.Sum(d => d.ToplamIsverenMaliyet).ToString("N2")</td>
                                <td class="text-end text-success">@detaylar.Sum(d => d.ToplamEkOdeme).ToString("N2")</td>
                                <td class="text-end">@detaylar.Sum(d => d.ToplamOdenecek).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Yazdırılabilir Hesap Pusulaları -->
<div class="print-only" id="printArea">
    @if (yazdirmaListesi.Count > 0 && secilenBordro != null)
    {
        @for (int i = 0; i < yazdirmaListesi.Count; i++)
        {
            var detay = yazdirmaListesi[i];
            var firma = detay.Firma ?? secilenBordro.Firma;
            var personel = detay.Personel;

            <div class="pusula-sayfa @(i < yazdirmaListesi.Count - 1 ? "sayfa-sonu" : "")">
                <!-- Firma Başlık -->
                <div class="pusula-header">
                    <div class="firma-bilgi">
                        <h4 class="mb-0">@(firma?.UnvanTam ?? firma?.FirmaAdi ?? "Firma")</h4>
                        @if (!string.IsNullOrEmpty(firma?.Adres))
                        {
                            <small>@firma.Adres @(!string.IsNullOrEmpty(firma.Il) ? $"- {firma.Il}" : "") @(!string.IsNullOrEmpty(firma.Ilce) ? $"/ {firma.Ilce}" : "")</small>
                        }
                        @if (!string.IsNullOrEmpty(firma?.VergiDairesi) || !string.IsNullOrEmpty(firma?.VergiNo))
                        {
                            <br /><small>V.D.: @firma?.VergiDairesi - @firma?.VergiNo</small>
                        }
                    </div>
                    <div class="pusula-baslik">
                        <h5>BORDRO HESAP PUSULASI</h5>
                        <span class="donem-bilgi">@AyAdi(secilenBordro.Ay) @secilenBordro.Yil</span>
                        @if (secilenBordro.BordroTipi == BordroTipi.Arge)
                        {
                            <br /><span class="badge-arge">AR-GE</span>
                        }
                    </div>
                </div>

                <!-- Personel Bilgileri -->
                <div class="personel-bilgi">
                    <table class="bilgi-tablo">
                        <tr>
                            <td class="etiket">Sicil No:</td>
                            <td class="deger">@(personel?.SoforKodu ?? "-")</td>
                            <td class="etiket">Adı Soyadı:</td>
                            <td class="deger fw-bold">@(personel?.TamAd ?? "-")</td>
                        </tr>
                        <tr>
                            <td class="etiket">TC Kimlik No:</td>
                            <td class="deger">@(personel?.TcKimlikNo ?? "-")</td>
                            <td class="etiket">Görevi:</td>
                            <td class="deger">@GorevAdi(personel?.Gorev) @(!string.IsNullOrEmpty(personel?.Departman) ? $"/ {personel.Departman}" : "")</td>
                        </tr>
                        <tr>
                            <td class="etiket">İşe Başlama:</td>
                            <td class="deger">@(personel?.IseBaslamaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td class="etiket">Banka / IBAN:</td>
                            <td class="deger">@(personel?.BankaAdi ?? "-") @(!string.IsNullOrEmpty(personel?.IBAN) ? $"/ {personel.IBAN}" : "")</td>
                        </tr>
                    </table>
                </div>

                <!-- Maaş Detayları -->
                <div class="maas-detay">
                    <div class="detay-kolon">
                        <h6 class="kolon-baslik">KAZANÇLAR</h6>
                        <table class="detay-tablo">
                            <tr>
                                <td>Brüt Maaş</td>
                                <td class="tutar">@detay.BrutMaas.ToString("N2") ₺</td>
                            </tr>
                            <tr>
                                <td>SGK Matrah (Bildirilen)</td>
                                <td class="tutar">@detay.SgkMaasi.ToString("N2") ₺</td>
                            </tr>
                            <tr>
                                <td>Net Maaş</td>
                                <td class="tutar fw-bold">@detay.NetMaas.ToString("N2") ₺</td>
                            </tr>
                            <tr>
                                <td>Resmi / Banka Ödemesi</td>
                                <td class="tutar">@detay.NetMaas.ToString("N2") ₺</td>
                            </tr>
                            @if (detay.TopluMaas > 0 && detay.TopluMaas != detay.SgkMaasi)
                            {
                                <tr>
                                    <td>Toplu Maaş</td>
                                    <td class="tutar">@detay.TopluMaas.ToString("N2") ₺</td>
                                </tr>
                            }
                            @if (detay.EkOdeme > 0)
                            {
                                <tr>
                                    <td>Ek Ödeme (Fark)</td>
                                    <td class="tutar">@detay.EkOdeme.ToString("N2") ₺</td>
                                </tr>
                            }
                        </table>

                        @if (detay.ToplamEkOdeme > 0)
                        {
                            <h6 class="kolon-baslik mt-2">EK ÖDEMELER</h6>
                            <table class="detay-tablo">
                                @if (detay.YemekYardimi > 0)
                                {
                                    <tr>
                                        <td>Yemek Yardımı</td>
                                        <td class="tutar">@detay.YemekYardimi.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.YolYardimi > 0)
                                {
                                    <tr>
                                        <td>Yol Yardımı</td>
                                        <td class="tutar">@detay.YolYardimi.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.PrimTutar > 0)
                                {
                                    <tr>
                                        <td>Prim</td>
                                        <td class="tutar">@detay.PrimTutar.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.DigerEkOdeme > 0)
                                {
                                    <tr>
                                        <td>Diğer Ek Ödeme</td>
                                        <td class="tutar">@detay.DigerEkOdeme.ToString("N2") ₺</td>
                                    </tr>
                                }
                                <tr class="toplam-satir">
                                    <td>Toplam Ek Ödeme</td>
                                    <td class="tutar fw-bold">@detay.ToplamEkOdeme.ToString("N2") ₺</td>
                                </tr>
                            </table>
                        }

                        @if (detay.EkOdeme > 0)
                        {
                            <h6 class="kolon-baslik mt-2">ELDEN / FARK ÖDEMESİ</h6>
                            <table class="detay-tablo">
                                <tr>
                                    <td>Toplu Maaş Farkı</td>
                                    <td class="tutar">@detay.EkOdeme.ToString("N2") ₺</td>
                                </tr>
                                <tr class="toplam-satir">
                                    <td>Elden / 2. Taksit</td>
                                    <td class="tutar fw-bold">@detay.EkOdeme.ToString("N2") ₺</td>
                                </tr>
                            </table>
                        }
                    </div>

                    <div class="detay-kolon">
                        <h6 class="kolon-baslik">KESİNTİLER</h6>
                        <table class="detay-tablo">
                            @if (detay.SgkIsciPrim > 0)
                            {
                                <tr>
                                    <td>SGK İşçi Primi (%14)</td>
                                    <td class="tutar text-danger">@detay.SgkIsciPrim.ToString("N2") ₺</td>
                                </tr>
                            }
                            @if (detay.IssizlikIsciPrim > 0)
                            {
                                <tr>
                                    <td>İşsizlik İşçi Primi (%1)</td>
                                    <td class="tutar text-danger">@detay.IssizlikIsciPrim.ToString("N2") ₺</td>
                                </tr>
                            }
                            @if (detay.GelirVergisi > 0)
                            {
                                <tr>
                                    <td>Gelir Vergisi (Dilim @detay.UygulananVergiDilimi)</td>
                                    <td class="tutar text-danger">@detay.GelirVergisi.ToString("N2") ₺</td>
                                </tr>
                            }
                            @if (detay.DamgaVergisi > 0)
                            {
                                <tr>
                                    <td>Damga Vergisi</td>
                                    <td class="tutar text-danger">@detay.DamgaVergisi.ToString("N2") ₺</td>
                                </tr>
                            }
                            @if (detay.OzelKesintilerToplam > 0)
                            {
                                @if (detay.IcraKesintisi > 0)
                                {
                                    <tr>
                                        <td>İcra Kesintisi</td>
                                        <td class="tutar text-danger">@detay.IcraKesintisi.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.BESKesintisi > 0)
                                {
                                    <tr>
                                        <td>BES Kesintisi</td>
                                        <td class="tutar text-danger">@detay.BESKesintisi.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.SendikaKesintisi > 0)
                                {
                                    <tr>
                                        <td>Sendika Kesintisi</td>
                                        <td class="tutar text-danger">@detay.SendikaKesintisi.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.HayatSigortasi > 0)
                                {
                                    <tr>
                                        <td>Hayat Sigortası</td>
                                        <td class="tutar text-danger">@detay.HayatSigortasi.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.BireyselEmeklilik > 0)
                                {
                                    <tr>
                                        <td>Bireysel Emeklilik</td>
                                        <td class="tutar text-danger">@detay.BireyselEmeklilik.ToString("N2") ₺</td>
                                    </tr>
                                }
                                @if (detay.DigerOzelKesinti > 0)
                                {
                                    <tr>
                                        <td>Diğer Özel Kesinti</td>
                                        <td class="tutar text-danger">@detay.DigerOzelKesinti.ToString("N2") ₺</td>
                                    </tr>
                                }
                            }
                            <tr class="toplam-satir">
                                <td>Toplam Kesinti</td>
                                <td class="tutar fw-bold text-danger">@detay.ToplamKesinti.ToString("N2") ₺</td>
                            </tr>
                        </table>

                        @if (detay.ToplamIsverenMaliyet > 0)
                        {
                            <h6 class="kolon-baslik mt-2">İŞVEREN MALİYETİ</h6>
                            <table class="detay-tablo">
                                <tr>
                                    <td>SGK İşveren Primi</td>
                                    <td class="tutar">@detay.SgkIsverenPrim.ToString("N2") ₺</td>
                                </tr>
                                <tr>
                                    <td>İşsizlik İşveren Primi</td>
                                    <td class="tutar">@detay.IssizlikIsverenPrim.ToString("N2") ₺</td>
                                </tr>
                                <tr class="toplam-satir">
                                    <td>Toplam İşveren Maliyeti</td>
                                    <td class="tutar fw-bold text-info">@detay.ToplamIsverenMaliyet.ToString("N2") ₺</td>
                                </tr>
                                <tr>
                                    <td>İşveren Dahil Toplam Maliyet</td>
                                    <td class="tutar fw-bold">@detay.ToplamIsverenMaliyetDahilMaas.ToString("N2") ₺</td>
                                </tr>
                            </table>
                        }

                        <h6 class="kolon-baslik mt-2">ÖDEME BİLGİSİ</h6>
                        <table class="detay-tablo">
                            <tr>
                                <td>Planlanan Banka Ödemesi</td>
                                <td class="tutar">@detay.NetMaas.ToString("N2") ₺</td>
                            </tr>
                            <tr>
                                <td>Banka Ödeme Durumu</td>
                                <td class="tutar">
                                    @if (detay.BankaOdemesiYapildi)
                                    {
                                        <span class="text-success">✓ Ödendi @(detay.BankaOdemeTarihi?.ToString("dd.MM.yyyy") ?? "")</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning">Bekliyor</span>
                                    }
                                </td>
                            </tr>
                            @if (detay.EkOdeme > 0)
                            {
                                <tr>
                                    <td>Planlanan Elden / Fark Ödemesi</td>
                                    <td class="tutar">@detay.EkOdeme.ToString("N2") ₺</td>
                                </tr>
                                <tr>
                                    <td>Elden / Fark Ödeme Durumu</td>
                                    <td class="tutar">
                                        @if (detay.EkOdemeYapildi)
                                        {
                                            <span class="text-success">✓ Ödendi @(detay.EkOdemeTarihi?.ToString("dd.MM.yyyy") ?? "")</span>
                                        }
                                        else
                                        {
                                            <span class="text-warning">Bekliyor</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>

                <!-- Toplam -->
                <div class="pusula-toplam">
                    <table class="toplam-tablo">
                        <tr>
                            <td>Gerçek Maaş Toplamı</td>
                            <td class="tutar">@((detay.NetMaas + detay.ToplamEkOdeme + detay.EkOdeme).ToString("N2")) ₺</td>
                        </tr>
                        <tr>
                            <td>Bankaya Yatan / Resmi Net</td>
                            <td class="tutar">@detay.NetMaas.ToString("N2") ₺</td>
                        </tr>
                        @if (detay.ToplamEkOdeme > 0)
                        {
                            <tr>
                                <td>Yan Haklar / Toplam Ek Ödemeler</td>
                                <td class="tutar">@detay.ToplamEkOdeme.ToString("N2") ₺</td>
                            </tr>
                        }
                        @if (detay.EkOdeme > 0)
                        {
                            <tr>
                                <td>Elden / Toplu Maaş Farkı</td>
                                <td class="tutar">@detay.EkOdeme.ToString("N2") ₺</td>
                            </tr>
                        }
                        <tr>
                            <td>Toplam Kesinti</td>
                            <td class="tutar text-danger">@detay.ToplamKesinti.ToString("N2") ₺</td>
                        </tr>
                        @if (detay.ToplamIsverenMaliyet > 0)
                        {
                            <tr>
                                <td>İşveren Maliyeti (SGK + İşsizlik)</td>
                                <td class="tutar text-info">@detay.ToplamIsverenMaliyet.ToString("N2") ₺</td>
                            </tr>
                        }
                        <tr class="genel-toplam">
                            <td>TOPLAM ÖDENECEK / PERSONEL ALACAĞI</td>
                            <td class="tutar">@detay.ToplamOdenecek.ToString("N2") ₺</td>
                        </tr>
                    </table>
                </div>

                <!-- İmza Alanı -->
                <div class="imza-alani">
                    <div class="imza-kutu">
                        <div class="imza-cizgi"></div>
                        <small>İşveren / Yetkili</small>
                    </div>
                    <div class="imza-kutu">
                        <div class="imza-cizgi"></div>
                        <small>Personel</small>
                        <br /><small class="text-muted">@(personel?.TamAd ?? "")</small>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(detay.Notlar))
                {
                    <div class="pusula-not">
                        <small><strong>Not:</strong> @detay.Notlar</small>
                    </div>
                }

                <div class="pusula-footer">
                    <small>Düzenlenme Tarihi: @DateTime.Now.ToString("dd.MM.yyyy") | @(secilenBordro.Onaylandi ? $"Onay: {secilenBordro.OnayTarihi?.ToString("dd.MM.yyyy")} - {secilenBordro.OnaylayanKullanici}" : "Onay Bekliyor")</small>
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "bordroId")]
    public int? BordroIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "detayIds")]
    public string? DetayIdsQuery { get; set; }

    [SupplyParameterFromQuery(Name = "personelIds")]
    public string? PersonelIdsQuery { get; set; }

    [SupplyParameterFromQuery(Name = "yil")]
    public int? YilQuery { get; set; }

    [SupplyParameterFromQuery(Name = "ay")]
    public int? AyQuery { get; set; }

    [SupplyParameterFromQuery(Name = "firmaId")]
    public int? FirmaIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "tip")]
    public int? TipQuery { get; set; }

    private List<Firma> firmalar = new();
    private List<Bordro> bordrolar = new();
    private List<BordroDetay> detaylar = new();
    private List<BordroDetay> yazdirmaListesi = new();
    private Bordro? secilenBordro;

    private int secilenYil = DateTime.Now.Year;
    private int secilenFirmaId = 0;
    private BordroTipi secilenTip = BordroTipi.Normal;
    private int secilenBordroId = 0;
    private bool yukleniyor = false;
    private bool tumSecili = false;

    private int SeciliSayisi => detaylar.Count(d => d.Secili);

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        await BordrolariYukle();
        await QuerySecimiUygula();
    }

    private async Task QuerySecimiUygula()
    {
        if (YilQuery.HasValue) secilenYil = YilQuery.Value;
        if (FirmaIdQuery.HasValue) secilenFirmaId = FirmaIdQuery.Value;
        if (TipQuery.HasValue && Enum.IsDefined(typeof(BordroTipi), TipQuery.Value)) secilenTip = (BordroTipi)TipQuery.Value;

        await BordrolariYukle();

        if (!BordroIdQuery.HasValue && !AyQuery.HasValue)
            return;

        secilenBordroId = BordroIdQuery ?? bordrolar.Where(b => AyQuery.HasValue && b.Ay == AyQuery.Value).OrderByDescending(b => b.Onaylandi).ThenByDescending(b => b.CreatedAt).Select(b => b.Id).FirstOrDefault();
        if (secilenBordroId == 0)
        {
            ToastService.ShowWarning($"{AyQuery} / {secilenYil} dönemi için bordro bulunamadı.");
            return;
        }
        await DetaylariYukle();

        if (!detaylar.Any())
            return;

        var seciliDetayIdleri = (DetayIdsQuery ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(x => int.TryParse(x, out var id) ? id : 0)
            .Where(id => id > 0)
            .ToHashSet();
        var seciliPersonelIdleri = (PersonelIdsQuery ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(x => int.TryParse(x, out var id) ? id : 0)
            .Where(id => id > 0)
            .ToHashSet();

        if (seciliDetayIdleri.Any())
        {
            foreach (var detay in detaylar)
            {
                detay.Secili = seciliDetayIdleri.Contains(detay.Id);
            }

            yazdirmaListesi = detaylar.Where(d => d.Secili).ToList();
            tumSecili = detaylar.All(d => d.Secili);
        }
        else if (seciliPersonelIdleri.Any())
        {
            foreach (var detay in detaylar)
            {
                detay.Secili = seciliPersonelIdleri.Contains(detay.PersonelId);
            }

            yazdirmaListesi = detaylar.Where(d => d.Secili).ToList();
            tumSecili = detaylar.All(d => d.Secili);
        }
        else
        {
            foreach (var detay in detaylar)
            {
                detay.Secili = true;
            }

            yazdirmaListesi = detaylar.ToList();
            tumSecili = true;
        }
    }

    private async Task YilDegisti()
    {
        secilenBordroId = 0;
        detaylar.Clear();
        await BordrolariYukle();
    }

    private async Task FirmaDegisti()
    {
        secilenBordroId = 0;
        detaylar.Clear();
        await BordrolariYukle();
    }

    private async Task TipDegisti()
    {
        secilenBordroId = 0;
        detaylar.Clear();
        await BordrolariYukle();
    }

    private async Task BordroDegisti()
    {
        if (secilenBordroId > 0)
            await DetaylariYukle();
        else
        {
            detaylar.Clear();
            secilenBordro = null;
        }
    }

    private async Task BordrolariYukle()
    {
        int? firmaId = secilenFirmaId > 0 ? secilenFirmaId : null;
        bordrolar = await BordroService.GetBordrolarAsync(firmaId, secilenYil, secilenTip);
    }

    private async Task DetaylariYukle()
    {
        yukleniyor = true;
        try
        {
            detaylar = await BordroService.GetBordroDetaylarAsync(secilenBordroId);
            secilenBordro = bordrolar.FirstOrDefault(b => b.Id == secilenBordroId);

            if (secilenBordro == null)
                secilenBordro = await BordroService.GetBordroByIdAsync(secilenBordroId);

            tumSecili = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Bordro detayları yüklenirken hata: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void TumunuSec()
    {
        foreach (var d in detaylar) d.Secili = true;
        tumSecili = true;
    }

    private void SecimTemizle()
    {
        foreach (var d in detaylar) d.Secili = false;
        tumSecili = false;
    }

    private void TumSeciliDegisti()
    {
        foreach (var d in detaylar) d.Secili = tumSecili;
    }

    private async Task TekYazdir(BordroDetay detay)
    {
        yazdirmaListesi = new List<BordroDetay> { detay };
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task SecilenleriYazdir()
    {
        var seciliDetaylar = detaylar.Where(d => d.Secili).ToList();
        if (seciliDetaylar.Count == 0)
        {
            ToastService.ShowWarning("Lütfen en az bir personel seçiniz.");
            return;
        }

        yazdirmaListesi = seciliDetaylar;
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task TopluYazdir()
    {
        yazdirmaListesi = detaylar.ToList();
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task RaptinCsvAktar()
    {
        var hedefDetaylar = detaylar.Where(d => d.Secili).ToList();
        if (!hedefDetaylar.Any())
        {
            hedefDetaylar = detaylar.ToList();
        }

        if (!hedefDetaylar.Any())
        {
            ToastService.ShowWarning("Aktarılacak bordro detayı bulunamadı.");
            return;
        }

        var tr = new System.Globalization.CultureInfo("tr-TR");
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Firma;Yıl;Ay;BordroTipi;SicilNo;AdSoyad;TcKimlikNo;Görev;BrütMaaş;SGKMatrah;NetMaaş;EkÖdeme;ToplamEkÖdeme;ToplamKesinti;İşverenMaliyeti;İşverenDahilToplam;ÖdenecekToplam;IBAN;BankaAdı;ÇalışılanGün;FazlaMesaiSaat;İzinGünü;MazeretGünü");

        foreach (var d in hedefDetaylar.OrderBy(x => x.Personel?.Ad).ThenBy(x => x.Personel?.Soyad))
        {
            var p = d.Personel;
            var firmaAdi = d.Firma?.FirmaAdi ?? secilenBordro?.Firma?.FirmaAdi ?? string.Empty;
            var bordroTip = secilenBordro?.BordroTipi.ToString() ?? secilenTip.ToString();

            sb.Append(CsvEscape(firmaAdi)).Append(';')
              .Append(CsvEscape(secilenBordro?.Yil.ToString() ?? secilenYil.ToString())).Append(';')
              .Append(CsvEscape(secilenBordro?.Ay.ToString() ?? AyQuery?.ToString() ?? string.Empty)).Append(';')
              .Append(CsvEscape(bordroTip)).Append(';')
              .Append(CsvEscape(p?.SoforKodu ?? string.Empty)).Append(';')
              .Append(CsvEscape(p?.TamAd ?? string.Empty)).Append(';')
              .Append(CsvEscape(p?.TcKimlikNo ?? string.Empty)).Append(';')
              .Append(CsvEscape(GorevAdi(p?.Gorev))).Append(';')
              .Append(CsvEscape(d.BrutMaas.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.SgkMaasi.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.NetMaas.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.EkOdeme.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.ToplamEkOdeme.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.ToplamKesinti.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.ToplamIsverenMaliyet.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.ToplamIsverenMaliyetDahilMaas.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(d.ToplamOdenecek.ToString("N2", tr))).Append(';')
              .Append(CsvEscape(p?.IBAN ?? string.Empty)).Append(';')
              .Append(CsvEscape(p?.BankaAdi ?? string.Empty)).Append(';')
               .Append(CsvEscape(string.Empty)).Append(';')
               .Append(CsvEscape(string.Empty)).Append(';')
               .Append(CsvEscape(string.Empty)).Append(';')
               .Append(CsvEscape(string.Empty))
              .AppendLine();
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"Raptin_Bordro_{(secilenBordro?.Yil ?? secilenYil)}_{(secilenBordro?.Ay ?? AyQuery ?? 0):00}.csv";

        await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
        ToastService.ShowSuccess($"Raptin aktarım dosyası indirildi. Dosyayı C:\\Raptin\\RaptinBordro altından içe aktarabilirsiniz. ({hedefDetaylar.Count} kayıt)");
    }

    private static string CsvEscape(string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return string.Empty;
        }

        var escaped = value.Replace("\"", "\"\"");
        return $"\"{escaped}\"";
    }
    private string GorevAdi(PersonelGorev? gorev) => gorev switch
    {
        PersonelGorev.Sofor => "Şoför",
        PersonelGorev.OfisCalisani => "Ofis Çalışanı",
        PersonelGorev.Muhasebe => "Muhasebe",
        PersonelGorev.Yonetici => "Yönetici",
        PersonelGorev.Teknik => "Teknik",
        PersonelGorev.Diger => "Diğer",
        _ => "-"
    };

    private string AyAdi(int ay) => ay switch
    {
        1 => "Ocak",
        2 => "Şubat",
        3 => "Mart",
        4 => "Nisan",
        5 => "Mayıs",
        6 => "Haziran",
        7 => "Temmuz",
        8 => "Ağustos",
        9 => "Eylül",
        10 => "Ekim",
        11 => "Kasım",
        12 => "Aralık",
        _ => ""
    };
}

