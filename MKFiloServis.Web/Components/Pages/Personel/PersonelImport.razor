    private void ShowBildirim(string mesaj, bool basarili)
    {
        bildirimMesaj = mesaj;
        bildirimBasarili = basarili;
        _ = Task.Run(async () =>
        {
            await Task.Delay(4000);
            bildirimMesaj = null;
            await InvokeAsync(StateHasChanged);
        });
    }

