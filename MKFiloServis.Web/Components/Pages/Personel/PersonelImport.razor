    // Yardımcı Metotlar
    private List<ImportSatir> FiltrelenmisListe()
    {
        if (string.IsNullOrEmpty(filtreDurum))
            return importSatirlari;

        return filtreDurum switch
        {
            "Yeni" => importSatirlari.Where(s => s.Durum == ImportDurum.Yeni).ToList(),
            "Guncelleme" => importSatirlari.Where(s => s.Durum == ImportDurum.Guncelleme).ToList(),
            "Atlandi" => importSatirlari.Where(s => s.Durum == ImportDurum.Atlandi).ToList(),
            "Hata" => importSatirlari.Where(s => s.Durum == ImportDurum.Hata).ToList(),
            _ => importSatirlari
        };
    }

    private static PersonelGorev ParseGorev(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return PersonelGorev.Sofor;
        return text.Trim().ToLowerInvariant() switch
        {
            "şoför" or "sofor" or "şöför" or "driver" => PersonelGorev.Sofor,
            "ofis" or "ofis çalışanı" or "office" => PersonelGorev.OfisCalisani,
            "muhasebe" or "accounting" => PersonelGorev.Muhasebe,
            "yönetici" or "yonetici" or "manager" => PersonelGorev.Yonetici,
            "teknik" or "technical" => PersonelGorev.Teknik,
            "diğer" or "diger" or "other" => PersonelGorev.Diger,
            _ => PersonelGorev.Sofor
        };
    }

    private static PersonelBordroTipi ParseBordroTipi(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return PersonelBordroTipi.Yok;
        return text.Trim().ToLowerInvariant() switch
        {
            "normal" => PersonelBordroTipi.Normal,
            "arge" or "ar-ge" or "argé" => PersonelBordroTipi.Arge,
            _ => PersonelBordroTipi.Yok
        };
    }

    private static DateTime? ParseTarih(IXLCell cell)
    {
        try
        {
            if (cell.DataType == XLDataType.DateTime)
                return cell.GetDateTime();

            var text = cell.GetString().Trim();
            if (string.IsNullOrWhiteSpace(text)) return null;

            if (DateTime.TryParseExact(text,
                new[] { "dd.MM.yyyy", "dd/MM/yyyy", "yyyy-MM-dd", "d.M.yyyy", "d/M/yyyy" },
                System.Globalization.CultureInfo.GetCultureInfo("tr-TR"),
                System.Globalization.DateTimeStyles.None, out var dt))
                return dt;

            if (DateTime.TryParse(text, out var dt2))
                return dt2;

            return null;
        }
        catch { return null; }
    }

    private static decimal ParseDecimal(IXLCell cell)
    {
        try
        {
            if (cell.DataType == XLDataType.Number)
                return (decimal)cell.GetDouble();

            var text = cell.GetString().Trim().Replace("₺", "").Replace("TL", "").Trim();
            if (string.IsNullOrWhiteSpace(text)) return 0;

            text = text.Replace(".", "").Replace(",", ".");
            return decimal.TryParse(text, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var val) ? val : 0;
        }
        catch { return 0; }
    }

