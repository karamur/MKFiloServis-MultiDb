@page "/personel/bordro/normal"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject IBordroService BordroService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Normal Bordro</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-cash-stack me-2"></i>Normal Bordro Yönetimi</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Normal Bordro</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenFirmaId" @bind:after="YenileData">
                <option value="0">Tüm Firmalar</option>
                @if (firmalar != null)
                {
                    @foreach (var firma in firmalar)
                    {
                        <option value="@firma.Id">@firma.FirmaAdi</option>
                    }
                }
            </select>
            <button class="btn btn-success btn-sm" @onclick="YeniBordroAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Bordro Oluştur
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Özet Kartlar -->
        <div class="row mb-3 g-2">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2">
                        <small>Toplam Personel</small>
                        <h4 class="mb-0">@ozet.NormalPersonel</h4>
                        <small>Normal personel</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body py-2">
                        <small>Toplam Brüt Maaş</small>
                        <h4 class="mb-0">@FormatPara(ozet.ToplamBrutMaas)</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body py-2">
                        <small>Toplam Net Maaş</small>
                        <h4 class="mb-0">@FormatPara(ozet.ToplamNetMaas)</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2">
                        <small>Toplam Ek Ödeme</small>
                        <h4 class="mb-0">@FormatPara(ozet.ToplamEkOdeme)</h4>
                        <small>Toplu maaş farkı</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bordro Listesi -->
        <div class="card">
            <div class="card-header py-2">
                <h5 class="mb-0">Bordro Dönemleri</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Dönem</th>
                                <th>Firma</th>
                                <th class="text-center">Personel</th>
                                <th class="text-end">Brüt Maaş</th>
                                <th class="text-end">Net Maaş</th>
                                <th class="text-end">SGK Matrahı</th>
                                <th class="text-end">Ek Ödeme</th>
                                <th class="text-end">Genel Toplam</th>
                                <th>Durum</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (bordrolar != null && bordrolar.Any())
                            {
                                @foreach (var bordro in bordrolar)
                                {
                                    <tr>
                                        <td><strong>@bordro.DonemeAdi</strong></td>
                                        <td>@(bordro.Firma?.FirmaAdi ?? "Tüm Firmalar")</td>
                                        <td class="text-center">@bordro.ToplamPersonelSayisi</td>
                                        <td class="text-end">@FormatPara(bordro.ToplamBrutMaas)</td>
                                        <td class="text-end">@FormatPara(bordro.ToplamNetMaas)</td>
                                        <td class="text-end">@FormatPara(bordro.ToplamSgkMatrahi)</td>
                                        <td class="text-end">@FormatPara(bordro.ToplamEkOdeme)</td>
                                        <td class="text-end"><strong>@FormatPara(bordro.GenelToplam)</strong></td>
                                        <td>
                                            <span class="badge @(bordro.Onaylandi ? "bg-success" : "bg-warning")">
                                                @(bordro.Onaylandi ? "Onaylı" : "Bekliyor")
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" @onclick="() => DetayGor(bordro)" title="Detay">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                @if (!bordro.Onaylandi)
                                                {
                                                    <button class="btn btn-outline-success" @onclick="() => OnaySayfasıAc(bordro)" title="Hesapla/Onayla">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => BordroSil(bordro)" title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-outline-info" @onclick="() => OdemeSayfasiAc(bordro)" title="Ödemeler">
                                                        <i class="bi bi-credit-card"></i>
                                                    </button>
                                                }
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" title="Raporlar">
                                                        <i class="bi bi-file-earmark-excel"></i>
                                                    </button>
                                                    <ul class="dropdown-menu">
                                                        <li><a class="dropdown-item" @onclick="() => ExportBanka(bordro.Id)">Banka Ödeme Listesi</a></li>
                                                        <li><a class="dropdown-item" @onclick="() => ExportEkOdeme(bordro.Id)">Ek Ödeme Listesi</a></li>
                                                        <li><a class="dropdown-item" @onclick="() => ExportTumBordro(bordro.Id)">Tam Bordro</a></li>
                                                        <li><hr class="dropdown-divider" /></li>
                                                        <li><a class="dropdown-item" @onclick="() => ExportTumUcretBordrolari(bordro.Id)"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i>Tüm Ücret Bordroları</a></li>
                                                        <li><a class="dropdown-item" @onclick="() => HesapPusulasinaGit(bordro)">Hesap Pusulası</a></li>
                                                        <li><a class="dropdown-item" @onclick="() => BordroIcmalineGit(bordro)">Bordro İcmali</a></li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                        <p class="mt-2 mb-0">Bordro kaydı bulunamadı</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Bordro Detay Modal -->
        @if (showDetayModal && secilenBordro != null)
        {
            <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-list-ul me-2"></i>
                                @secilenBordro.DonemeAdi Normal Bordro Detayı
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                        </div>
                        <div class="modal-body">
                            @if (bordroDetaylar == null)
                            {
                                <div class="text-center py-3">
                                    <div class="spinner-border text-primary" role="status"></div>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 35px;">
                                                    <input type="checkbox" class="form-check-input" @onchange="TumunuSecDetay" />
                                                </th>
                                                <th style="width: 40px;">Sıra</th>
                                                <th>Personel</th>
                                                <th class="text-end">Brüt</th>
                                                <th class="text-end">SGK Maaşı</th>
                                                <th class="text-end">SGK İşçi</th>
                                                <th class="text-end">G.Vergisi</th>
                                                <th class="text-end">D.Vergisi</th>
                                                <th class="text-end">Özel Kes.</th>
                                                <th class="text-end">Kesintiler</th>
                                                <th class="text-end">Net</th>
                                                <th class="text-end">Ek Ödemeler</th>
                                                <th class="text-end">İşveren Mlyt</th>
                                                <th class="text-end">Toplam</th>
                                                <th>Durum</th>
                                                <th class="text-center" style="width:80px;">İşlem</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var detay in bordroDetaylar)
                                            {
                                                <tr class="@(detay.Secili ? "table-info" : "")">
                                                    <td class="text-center">
                                                        <input type="checkbox" class="form-check-input" @bind="detay.Secili" />
                                                    </td>
                                                    <td class="text-center text-muted">@(detay.Personel.SiralamaNo > 0 ? detay.Personel.SiralamaNo.ToString() : "-")</td>
                                                    <td>
                                                        <strong>@detay.Personel.TamAd</strong><br />
                                                        <small class="text-muted">@detay.Personel.SoforKodu</small>
                                                    </td>
                                                    <td class="text-end">@FormatPara(detay.BrutMaas)</td>
                                                    <td class="text-end">@FormatPara(detay.SgkMaasi)</td>
                                                    <td class="text-end"><small>@FormatPara(detay.SgkIssizlikKesinti)</small></td>
                                                    <td class="text-end"><small>@FormatPara(detay.GelirVergisi)</small></td>
                                                    <td class="text-end"><small>@FormatPara(detay.DamgaVergisi)</small></td>
                                                    <td class="text-end">
                                                        @if (detay.OzelKesintilerToplam > 0)
                                                        {
                                                            <small class="text-danger" title="İcra:@FormatPara(detay.IcraKesintisi) BES:@FormatPara(detay.BESKesintisi) Sendika:@FormatPara(detay.SendikaKesintisi)">@FormatPara(detay.OzelKesintilerToplam)</small>
                                                        }
                                                        else
                                                        {
                                                            <small class="text-muted">-</small>
                                                        }
                                                    </td>
                                                    <td class="text-end">@FormatPara(detay.ToplamKesinti)</td>
                                                    <td class="text-end"><strong>@FormatPara(detay.NetMaas)</strong></td>
                                                    <td class="text-end">@FormatPara(detay.ToplamEkOdeme)</td>
                                                    <td class="text-end"><small class="text-info" title="SGK İşv:@FormatPara(detay.SgkIsverenPrim) İşsiz İşv:@FormatPara(detay.IssizlikIsverenPrim)">@FormatPara(detay.ToplamIsverenMaliyet)</small></td>
                                                    <td class="text-end"><strong>@FormatPara(detay.ToplamOdenecek)</strong></td>
                                                    <td>
                                                        @if (detay.BankaOdemesiYapildi && detay.EkOdemeYapildi)
                                                        {
                                                            <span class="badge bg-success">Tamamlandı</span>
                                                        }
                                                        else if (detay.BankaOdemesiYapildi)
                                                        {
                                                            <span class="badge bg-info">Banka Ödendi</span>
                                                        }
                                                        else if (detay.EkOdemeYapildi)
                                                        {
                                                            <span class="badge bg-warning">Ek Ödendi</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">Bekliyor</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="btn-group btn-group-sm">
                                                            <button class="btn btn-outline-danger" @onclick="() => ExportTekUcretBordrosu(detay.Id)" title="Ücret Bordrosu">
                                                                <i class="bi bi-file-earmark-text"></i>
                                                            </button>
                                                            @if (secilenBordro != null && !secilenBordro.Onaylandi)
                                                            {
                                                                <button class="btn btn-outline-dark" @onclick="() => DetayDuzenleAc(detay)" title="Düzenle">
                                                                    <i class="bi bi-pencil"></i>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <td></td>
                                                <td></td>
                                                <td><strong>TOPLAM</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.BrutMaas))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.SgkMaasi))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.SgkIssizlikKesinti))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.GelirVergisi))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.DamgaVergisi))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.OzelKesintilerToplam))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.ToplamKesinti))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.NetMaas))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.ToplamEkOdeme))</strong></td>
                                                <td class="text-end"><strong class="text-info">@FormatPara(bordroDetaylar.Sum(d => d.ToplamIsverenMaliyet))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Sum(d => d.ToplamOdenecek))</strong></td>
                                                <td></td>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <div class="d-flex justify-content-between w-100">
                                <div class="btn-group">
                                    <button type="button" class="btn btn-danger" @onclick="ExportSeciliUcretBordrolari" title="Seçili personellerin ücret bordrolarını indir">
                                        <i class="bi bi-file-earmark-text me-1"></i>Seçili Ücret Bordroları
                                    </button>
                                    @if (secilenBordro != null)
                                    {
                                        <button type="button" class="btn btn-outline-danger" @onclick="() => ExportTumUcretBordrolari(secilenBordro.Id)" title="Tüm personellerin ücret bordrolarını indir">
                                            <i class="bi bi-files me-1"></i>Tümü
                                        </button>
                                    }
                                </div>
                                <div>
                                    <button type="button" class="btn btn-outline-primary" @onclick="SecilenBordrolariAc">
                                        <i class="bi bi-file-earmark-text me-1"></i>Hesap Pusulası
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" @onclick="SecilenIcmalAc">
                                        <i class="bi bi-table me-1"></i>İcmal
                                    </button>
                                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Ödeme Modal -->
        @if (showOdemeModal && secilenBordro != null && bordroDetaylar != null)
        {
            <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-success text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-credit-card me-2"></i>
                                Bordro Ödemeleri - @secilenBordro.DonemeAdi
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                        </div>
                        <div class="modal-body">
                            <ul class="nav nav-tabs mb-3">
                                <li class="nav-item">
                                    <button class="nav-link @(odemeTab == 1 ? "active" : "")" @onclick="() => odemeTab = 1">
                                        <i class="bi bi-bank me-1"></i>Banka Ödemeleri (1. Taksit)
                                    </button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link @(odemeTab == 2 ? "active" : "")" @onclick="() => odemeTab = 2">
                                        <i class="bi bi-cash me-1"></i>Ek Ödemeler (2. Taksit)
                                    </button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link @(odemeTab == 3 ? "active" : "")" @onclick="() => odemeTab = 3">
                                        <i class="bi bi-table me-1"></i>Kalan Ödeme
                                    </button>
                                </li>
                            </ul>

                            @if (odemeTab == 1)
                            {
                                <!-- Banka Ödemeleri -->
                                <div class="alert alert-info py-2 mb-3">
                                    <strong>Banka Ödeme Listesi:</strong> SGK maaşları + ek ödemeler için banka transferi
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Ödeme Tarihi *</label>
                                    <input type="date" class="form-control" @bind="bankaOdemeTarihi" />
                                </div>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th><input type="checkbox" @onchange="TumunuSecBanka" /></th>
                                                <th>Personel</th>
                                                <th>IBAN</th>
                                                <th class="text-end">Net Maaş</th>
                                                <th class="text-end">Ek Ödemeler</th>
                                                <th class="text-end">Toplam</th>
                                                <th>Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var detay in bordroDetaylar)
                                            {
                                                <tr>
                                                    <td>
                                                        @if (!detay.BankaOdemesiYapildi)
                                                        {
                                                            <input type="checkbox" @bind="detay.Secili" />
                                                        }
                                                    </td>
                                                    <td>@detay.Personel.TamAd</td>
                                                    <td><small>@(detay.Personel.IBAN ?? "IBAN yok")</small></td>
                                                    <td class="text-end">@FormatPara(detay.NetMaas)</td>
                                                    <td class="text-end">@FormatPara(detay.ToplamEkOdeme)</td>
                                                    <td class="text-end"><strong>@FormatPara(detay.NetMaas + detay.ToplamEkOdeme)</strong></td>
                                                    <td>
                                                        @if (detay.BankaOdemesiYapildi)
                                                        {
                                                            <span class="badge bg-success">Ödendi</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning">Bekliyor</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <td colspan="3"><strong>Seçili Toplam:</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Where(d => d.Secili).Sum(d => d.NetMaas))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Where(d => d.Secili).Sum(d => d.ToplamEkOdeme))</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Where(d => d.Secili).Sum(d => d.NetMaas + d.ToplamEkOdeme))</strong></td>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                <button class="btn btn-success w-100" @onclick="BankaOdemesiYap" disabled="@(!bordroDetaylar.Any(d => d.Secili))">
                                    <i class="bi bi-check-circle me-1"></i>Banka Ödemesini Tamamla
                                </button>
                            }
                            else if (odemeTab == 2)
                            {
                                <!-- Ek Ödemeler -->
                                <div class="alert alert-warning py-2 mb-3">
                                    <strong>Ek Ödeme Listesi:</strong> Toplu maaş ile SGK maaşı arasındaki fark ödemeleri
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Ödeme Tarihi *</label>
                                        <input type="date" class="form-control" @bind="ekOdemeTarihi" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Ödeme Şekli *</label>
                                        <select class="form-select" @bind="ekOdemeSekli">
                                            <option value="@OdemeSekli.Nakit">Nakit</option>
                                            <option value="@OdemeSekli.BankaTransfer">Banka Transfer</option>
                                            <option value="@OdemeSekli.Cek">Çek</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th><input type="checkbox" @onchange="TumunuSecEk" /></th>
                                                <th>Personel</th>
                                                <th class="text-end">Toplu Maaş</th>
                                                <th class="text-end">SGK Maaşı</th>
                                                <th class="text-end">Ek Ödeme</th>
                                                <th>Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var detay in bordroDetaylar.Where(d => d.EkOdeme > 0))
                                            {
                                                <tr>
                                                    <td>
                                                        @if (!detay.EkOdemeYapildi)
                                                        {
                                                            <input type="checkbox" @bind="detay.Secili" />
                                                        }
                                                    </td>
                                                    <td>@detay.Personel.TamAd</td>
                                                    <td class="text-end">@FormatPara(detay.TopluMaas)</td>
                                                    <td class="text-end">@FormatPara(detay.SgkMaasi)</td>
                                                    <td class="text-end"><strong>@FormatPara(detay.EkOdeme)</strong></td>
                                                    <td>
                                                        @if (detay.EkOdemeYapildi)
                                                        {
                                                            <span class="badge bg-success">Ödendi</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning">Bekliyor</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <td colspan="4"><strong>Seçili Toplam:</strong></td>
                                                <td class="text-end"><strong>@FormatPara(bordroDetaylar.Where(d => d.Secili).Sum(d => d.EkOdeme))</strong></td>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                <button class="btn btn-success w-100" @onclick="EkOdemeYap" disabled="@(!bordroDetaylar.Any(d => d.Secili))">
                                    <i class="bi bi-check-circle me-1"></i>Ek Ödemeyi Tamamla
                                </button>
                            }
                            else
                            {
                                <div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
                                    <div class="alert alert-primary py-2 mb-0 flex-grow-1 me-2">
                                        <strong>Kalan Maaş Listesi:</strong> Net maaş, bordroda ele geçen, avans + ödemeler ve ödenecek miktar
                                    </div>
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-outline-secondary" @onclick="YazdirKalanOdeme">
                                            <i class="bi bi-printer me-1"></i>Yazdır
                                        </button>
                                        <button type="button" class="btn btn-outline-success" @onclick="() => ExportKalanOdeme(secilenBordro.Id)">
                                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                                        </button>
                                    </div>
                                </div>

                                @if (kalanOdemeRaporu == null)
                                {
                                    <div class="text-center py-3">
                                        <div class="spinner-border text-primary" role="status"></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Personel</th>
                                                    <th>IBAN</th>
                                                    <th class="text-end">Net Maaş</th>
                                                    <th class="text-end">Bordroda Ele Geçen</th>
                                                    <th class="text-end">Kalan Maaş</th>
                                                    <th class="text-end">Avans + Ödemeler</th>
                                                    <th class="text-end">Ödenecek Miktar</th>
                                                    <th class="text-center">İşlemler</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var satir in kalanOdemeRaporu)
                                                {
                                                    var odenecekCss = satir.OdenecekMiktar >= 0 ? "text-success" : "text-danger";
                                                    <tr>
                                                        <td>
                                                            <strong>@satir.PersonelAdSoyad</strong><br />
                                                            <small class="text-muted">@satir.PersonelKodu</small>
                                                        </td>
                                                        <td><small>@(satir.Iban ?? "IBAN yok")</small></td>
                                                        <td class="text-end">@FormatPara(satir.NetMaas)</td>
                                                        <td class="text-end">@FormatPara(satir.BordrodaEleGecen)</td>
                                                        <td class="text-end">@FormatPara(satir.KalanMaas)</td>
                                                        <td class="text-end">@FormatPara(satir.AvansVeOdemeler)</td>
                                                        <td class="text-end"><strong class="@odenecekCss">@FormatPara(satir.OdenecekMiktar)</strong></td>
                                                        <td class="text-center">
                                                            <div class="btn-group btn-group-sm">
                                                                <button type="button" class="btn btn-outline-success" @onclick="() => KalanMaasOde(satir)" title="Ödeme">
                                                                    <i class="bi bi-cash-coin"></i>
                                                                </button>
                                                                <button type="button" class="btn btn-outline-warning" @onclick="() => TahsilSayfasinaGit(satir.PersonelId)" title="Tahsil">
                                                                    <i class="bi bi-wallet"></i>
                                                                </button>
                                                                <button type="button" class="btn btn-outline-primary" @onclick="() => CariSayfasinaGit(satir.PersonelId)" title="Cari">
                                                                    <i class="bi bi-person-vcard"></i>
                                                                </button>
                                                                <button type="button" class="btn btn-outline-secondary" @onclick="() => MahsupSayfasinaGit(satir.PersonelId)" title="Mahsup">
                                                                    <i class="bi bi-arrow-left-right"></i>
                                                                </button>
                                                                <button type="button" class="btn btn-outline-dark" @onclick="() => BordroDetayDuzenleAc(satir)" title="Düzenle">
                                                                    <i class="bi bi-pencil"></i>
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot class="table-light">
                                                <tr>
                                                    <td colspan="2"><strong>TOPLAM</strong></td>
                                                    <td class="text-end"><strong>@FormatPara(kalanOdemeRaporu.Sum(x => x.NetMaas))</strong></td>
                                                    <td class="text-end"><strong>@FormatPara(kalanOdemeRaporu.Sum(x => x.BordrodaEleGecen))</strong></td>
                                                    <td class="text-end"><strong>@FormatPara(kalanOdemeRaporu.Sum(x => x.KalanMaas))</strong></td>
                                                    <td class="text-end"><strong>@FormatPara(kalanOdemeRaporu.Sum(x => x.AvansVeOdemeler))</strong></td>
                                                    <td class="text-end"><strong>@FormatPara(kalanOdemeRaporu.Sum(x => x.OdenecekMiktar))</strong></td>
                                                    <td></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                }
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

