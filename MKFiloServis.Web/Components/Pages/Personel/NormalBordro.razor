<!-- Yeni Bordro Modal -->
@if (showYeniBordroModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Yeni Normal Bordro Oluştur</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Yıl *</label>
                                <select class="form-select" @bind="yeniYil">
                                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                                    {
                                        <option value="@y">@y</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Ay *</label>
                                <select class="form-select" @bind="yeniAy">
                                    @for (int a = 1; a <= 12; a++)
                                    {
                                        <option value="@a">@GetAyAdi(a)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Firma</label>
                        <select class="form-select" @bind="yeniFirmaId">
                            <option value="0">Tüm Firmalar</option>
                            @if (firmalar != null)
                            {
                                @foreach (var f in firmalar)
                                {
                                    <option value="@f.Id">@f.FirmaAdi</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="alert alert-info py-2">
                        <small><i class="bi bi-info-circle me-1"></i>Normal bordro sadece ARGE dışı personeller için oluşturulur.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-success" @onclick="YeniBordroOlustur" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Oluştur ve Hesapla
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Firma>? firmalar;
    private List<Bordro>? bordrolar;
    private List<BordroDetay>? bordroDetaylar;
    private List<BordroKalanOdemeSatir>? kalanOdemeRaporu;
    private BordroOzet ozet = new();

    private int secilenYil = DateTime.Now.Year;
    private int secilenFirmaId = 0;
    private bool isLoading = true;
    private bool isSaving = false;

    // Modaller
    private bool showYeniBordroModal = false;
    private bool showDetayModal = false;
    private bool showOdemeModal = false;
    private bool showDuzenleModal = false;
    private Bordro? secilenBordro;
    private BordroDetay? duzenleDetay;
    private int odemeTab = 1;

    // Yeni bordro
    private int yeniYil = DateTime.Now.Year;
    private int yeniAy = DateTime.Now.Month;
    private int yeniFirmaId = 0;

    // Ödeme
    private DateTime bankaOdemeTarihi = DateTime.Today;
    private DateTime ekOdemeTarihi = DateTime.Today;
    private OdemeSekli ekOdemeSekli = OdemeSekli.Nakit;

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        
        var aktifFirma = FirmaService.GetAktifFirma();
        if (!aktifFirma.TumFirmalar && aktifFirma.FirmaId > 0)
            secilenFirmaId = aktifFirma.FirmaId;

        await YenileData();
    }

    private async Task YenileData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            bordrolar = await BordroService.GetBordrolarAsync(
                secilenFirmaId > 0 ? secilenFirmaId : null,
                secilenYil,
                BordroTipi.Normal
            );

            ozet = await BordroService.GetBordroOzetAsync(
                secilenFirmaId > 0 ? secilenFirmaId : null,
                secilenYil,
                null
            );
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void YeniBordroAc()
    {
        yeniYil = DateTime.Now.Year;
        yeniAy = DateTime.Now.Month;
        yeniFirmaId = secilenFirmaId;
        showYeniBordroModal = true;
    }

    private async Task YeniBordroOlustur()
    {
        isSaving = true;
        try
        {
            var bordro = await BordroService.CreateBordroAsync(
                yeniYil,
                yeniAy,
                yeniFirmaId > 0 ? yeniFirmaId : null,
                BordroTipi.Normal
            );

            ToastService.ShowSuccess($"{yeniAy}/{yeniYil} Normal bordro oluşturuldu ve hesaplandı!");
            ModalKapat();
            await YenileData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DetayGor(Bordro bordro)
    {
        secilenBordro = bordro;
        showDetayModal = true;
        bordroDetaylar = null;
        StateHasChanged();

        bordroDetaylar = await BordroService.GetBordroDetaylarAsync(bordro.Id);
        StateHasChanged();
    }

    private void HesapPusulasinaGit(Bordro bordro)
    {
        Navigation.NavigateTo($"/personel/bordro/hesap-pusulasi?bordroId={bordro.Id}");
    }

    private void BordroIcmalineGit(Bordro bordro)
    {
        Navigation.NavigateTo($"/personel/bordro/icmal?bordroId={bordro.Id}");
    }

    private void TekilBordroAc(BordroDetay detay)
    {
        if (secilenBordro == null)
            return;

        Navigation.NavigateTo($"/personel/bordro/hesap-pusulasi?bordroId={secilenBordro.Id}&detayIds={detay.Id}");
    }

    private void TekilIcmalAc(BordroDetay detay)
    {
        if (secilenBordro == null)
            return;

        Navigation.NavigateTo($"/personel/bordro/icmal?bordroId={secilenBordro.Id}&detayIds={detay.Id}");
    }

    private void SecilenBordrolariAc()
    {
        if (secilenBordro == null || bordroDetaylar == null)
            return;

        var seciliIds = bordroDetaylar.Where(d => d.Secili).Select(d => d.Id).ToList();
        if (!seciliIds.Any())
        {
            ToastService.ShowWarning("Lütfen en az bir personel seçiniz.");
            return;
        }

        var detayIdListesi = string.Join(",", seciliIds);
        Navigation.NavigateTo($"/personel/bordro/hesap-pusulasi?bordroId={secilenBordro.Id}&detayIds={detayIdListesi}");
    }

    private void SecilenIcmalAc()
    {
        if (secilenBordro == null || bordroDetaylar == null)
            return;

        var seciliIds = bordroDetaylar.Where(d => d.Secili).Select(d => d.Id).ToList();
        if (!seciliIds.Any())
        {
            ToastService.ShowWarning("Lütfen en az bir personel seçiniz.");
            return;
        }

        var detayIdListesi = string.Join(",", seciliIds);
        Navigation.NavigateTo($"/personel/bordro/icmal?bordroId={secilenBordro.Id}&detayIds={detayIdListesi}");
    }

    private async Task OnaySayfasıAc(Bordro bordro)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"{bordro.DonemeAdi} dönemini onaylamak istediğinize emin misiniz? Onaylanan bordro düzenlenemez!");

        if (confirmed)
        {
            try
            {
                var kullanici = "Admin"; // TODO: Kullanıcı bilgisi alınacak
                await BordroService.OnaylaBordroAsync(bordro.Id, kullanici);
                ToastService.ShowSuccess("Bordro onaylandı!");
                await YenileData();
            }
            catch (Exception ex)
            {
                ToastService.ShowError($"Hata: {ex.Message}");
            }
        }
    }

    private async Task BordroSil(Bordro bordro)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"{bordro.DonemeAdi} bordrosunu silmek istediğinize emin misiniz?");

        if (confirmed)
        {
            try
            {
                await BordroService.DeleteBordroAsync(bordro.Id);
                ToastService.ShowSuccess("Bordro silindi!");
                await YenileData();
            }
            catch (Exception ex)
            {
                ToastService.ShowError($"Hata: {ex.Message}");
            }
        }
    }

    private async Task OdemeSayfasiAc(Bordro bordro)
    {
        secilenBordro = bordro;
        showOdemeModal = true;
        bordroDetaylar = null;
        kalanOdemeRaporu = null;
        odemeTab = 1;
        StateHasChanged();

        bordroDetaylar = await BordroService.GetBordroDetaylarAsync(bordro.Id);
        kalanOdemeRaporu = await BordroService.GetKalanOdemeRaporuAsync(bordro.Id);
        StateHasChanged();
    }

    private void TumunuSecBanka(ChangeEventArgs e)
    {
        var secili = (bool)(e.Value ?? false);
        if (bordroDetaylar != null)
        {
            foreach (var detay in bordroDetaylar.Where(d => !d.BankaOdemesiYapildi))
                detay.Secili = secili;
        }
    }

    private void TumunuSecEk(ChangeEventArgs e)
    {
        var secili = (bool)(e.Value ?? false);
        if (bordroDetaylar != null)
        {
            foreach (var detay in bordroDetaylar.Where(d => !d.EkOdemeYapildi && d.EkOdeme > 0))
                detay.Secili = secili;
        }
    }

    private void TumunuSecDetay(ChangeEventArgs e)
    {
        var secili = (bool)(e.Value ?? false);
        if (bordroDetaylar != null)
        {
            foreach (var detay in bordroDetaylar)
                detay.Secili = secili;
        }
    }

    private async Task BankaOdemesiYap()
    {
        if (bordroDetaylar == null || secilenBordro == null)
            return;

        var seciliIds = bordroDetaylar.Where(d => d.Secili && !d.BankaOdemesiYapildi).Select(d => d.Id).ToList();
        if (!seciliIds.Any())
        {
            ToastService.ShowWarning("Ödeme yapılacak kayıt seçin!");
            return;
        }

        try
        {
            await BordroService.BankaOdemesiYapAsync(seciliIds, bankaOdemeTarihi, null, "Bordro banka ödemesi");
            ToastService.ShowSuccess($"{seciliIds.Count} personele banka ödemesi yapıldı!");

            // Listeyi yenile
            bordroDetaylar = await BordroService.GetBordroDetaylarAsync(secilenBordro.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task EkOdemeYap()
    {
        if (bordroDetaylar == null || secilenBordro == null)
            return;

        var seciliIds = bordroDetaylar.Where(d => d.Secili && !d.EkOdemeYapildi).Select(d => d.Id).ToList();
        if (!seciliIds.Any())
        {
            ToastService.ShowWarning("Ödeme yapılacak kayıt seçin!");
            return;
        }

        try
        {
            await BordroService.EkOdemeYapAsync(seciliIds, ekOdemeTarihi, ekOdemeSekli, null, "Toplu maaş ek ödemesi");
            ToastService.ShowSuccess($"{seciliIds.Count} personele ek ödeme yapıldı!");
            
            // Listeyi yenile
            bordroDetaylar = await BordroService.GetBordroDetaylarAsync(secilenBordro.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

