    private async Task KalanMaasOde(BordroKalanOdemeSatir satir)
    {
        if (secilenBordro == null)
            return;

        var detay = bordroDetaylar?.FirstOrDefault(d => d.Id == satir.BordroDetayId);
        if (detay == null)
        {
            ToastService.ShowWarning("Bordro detayı bulunamadı!");
            return;
        }

        try
        {
            if (!detay.BankaOdemesiYapildi)
            {
                await BordroService.BankaOdemesiYapAsync(new List<int> { detay.Id }, DateTime.Today, null, "Kalan maaş ödeme");
            }

            if (!detay.EkOdemeYapildi && detay.EkOdeme > 0)
            {
                await BordroService.EkOdemeYapAsync(new List<int> { detay.Id }, DateTime.Today, OdemeSekli.BankaTransfer, null, "Kalan maaş ödeme");
            }

            bordroDetaylar = await BordroService.GetBordroDetaylarAsync(secilenBordro.Id);
            kalanOdemeRaporu = await BordroService.GetKalanOdemeRaporuAsync(secilenBordro.Id);
            ToastService.ShowSuccess("Kalan maaş ödemesi tamamlandı!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

