    private void DetayDuzenleAc(BordroDetay detay)
    {
        duzenleDetay = detay;
        showDuzenleModal = true;
    }

    private async Task BordroDetayDuzenleAc(BordroKalanOdemeSatir satir)
    {
        var detay = bordroDetaylar?.FirstOrDefault(d => d.Id == satir.BordroDetayId);
        if (detay == null)
        {
            ToastService.ShowWarning("Bordro detayı bulunamadı!");
            return;
        }

        DetayDuzenleAc(detay);
    }

    private async Task DetayKaydet()
    {
        if (duzenleDetay == null || secilenBordro == null) return;

        isSaving = true;
        try
        {
            await BordroService.UpdateBordroDetayAsync(duzenleDetay);
            bordroDetaylar = await BordroService.GetBordroDetaylarAsync(secilenBordro.Id);
            if (kalanOdemeRaporu != null)
                kalanOdemeRaporu = await BordroService.GetKalanOdemeRaporuAsync(secilenBordro.Id);
            DuzenleKapat();
            ToastService.ShowSuccess("Bordro detayı güncellendi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void DuzenleKapat()
    {
        showDuzenleModal = false;
        duzenleDetay = null;
    }

    private void ModalKapat()
    {
        showYeniBordroModal = false;
        showDetayModal = false;
        showOdemeModal = false;
        showDuzenleModal = false;
        secilenBordro = null;
        bordroDetaylar = null;
        kalanOdemeRaporu = null;
        duzenleDetay = null;
    }

