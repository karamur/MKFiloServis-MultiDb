@page "/satis/personel"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject ISatisService SatisService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Satis Personeli</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-2">
            <a href="/satis" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h3 class="mb-0"><i class="bi bi-people me-2"></i>Satis Personeli</h3>
        </div>
        <button class="btn btn-primary" @onclick="YeniPersonelAc">
            <i class="bi bi-plus-lg me-1"></i>Yeni Personel
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var personel in personeller)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">@personel.AdSoyad</h5>
                                    <span class="badge bg-secondary">@personel.PersonelKodu</span>
                                </div>
                                <span class="badge @(personel.Aktif ? "bg-success" : "bg-danger")">
                                    @(personel.Aktif ? "Aktif" : "Pasif")
                                </span>
                            </div>

                            <div class="mb-3">
                                @if (!string.IsNullOrEmpty(personel.Telefon))
                                {
                                    <p class="mb-1"><i class="bi bi-telephone me-2 text-muted"></i>@personel.Telefon</p>
                                }
                                @if (!string.IsNullOrEmpty(personel.Email))
                                {
                                    <p class="mb-1"><i class="bi bi-envelope me-2 text-muted"></i>@personel.Email</p>
                                }
                            </div>

                            <div class="row g-2 text-center mb-3">
                                <div class="col-4">
                                    <div class="bg-light rounded p-2">
                                        <small class="text-muted d-block">Komisyon</small>
                                        <strong class="text-primary">%@personel.KomisyonOrani</strong>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="bg-light rounded p-2">
                                        <small class="text-muted d-block">Aktif Ilan</small>
                                        <strong>@(personel.Ilanlar?.Count ?? 0)</strong>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="bg-light rounded p-2">
                                        <small class="text-muted d-block">Hedef</small>
                                        <strong>@personel.AylikAracHedefi</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-primary btn-sm flex-fill" @onclick="() => PerformansGoster(personel)">
                                    <i class="bi bi-graph-up me-1"></i>Performans
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => DuzenleAc(personel)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!personeller.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle me-2"></i>Henuz satis personeli eklenmemis.
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Personel Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-badge me-2"></i>
                        @(editPersonel.Id > 0 ? "Personel Duzenle" : "Yeni Personel")
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Personel Kodu *</label>
                            <input type="text" class="form-control" @bind="editPersonel.PersonelKodu" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ad Soyad *</label>
                            <input type="text" class="form-control" @bind="editPersonel.AdSoyad" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" @bind="editPersonel.Telefon" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="editPersonel.Email" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Komisyon Orani (%)</label>
                            <input type="number" class="form-control" step="0.1" @bind="editPersonel.KomisyonOrani" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sabit Komisyon</label>
                            <input type="number" class="form-control" @bind="editPersonel.SabitKomisyon" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Aylik Hedef (Adet)</label>
                            <input type="number" class="form-control" @bind="editPersonel.AylikAracHedefi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Aylik Satis Hedefi (TL)</label>
                            <input type="number" class="form-control" @bind="editPersonel.AylikSatisHedefi" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="aktif" @bind="editPersonel.Aktif" />
                                <label class="form-check-label" for="aktif">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="KaydetAsync">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool showModal = false;
    private List<SatisPersoneli> personeller = new();
    private SatisPersoneli editPersonel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            personeller = await SatisService.GetSatisPersonelListesiAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void YeniPersonelAc()
    {
        editPersonel = new SatisPersoneli
        {
            Aktif = true,
            KomisyonOrani = 2,
            PersonelKodu = $"SP{DateTime.Now:yyMMdd}{new Random().Next(100, 999)}"
        };
        showModal = true;
    }

    private void DuzenleAc(SatisPersoneli personel)
    {
        editPersonel = new SatisPersoneli
        {
            Id = personel.Id,
            PersonelKodu = personel.PersonelKodu,
            AdSoyad = personel.AdSoyad,
            Telefon = personel.Telefon,
            Email = personel.Email,
            KomisyonOrani = personel.KomisyonOrani,
            SabitKomisyon = personel.SabitKomisyon,
            AylikAracHedefi = personel.AylikAracHedefi,
            AylikSatisHedefi = personel.AylikSatisHedefi,
            Aktif = personel.Aktif
        };
        showModal = true;
    }

    private void ModalKapat()
    {
        showModal = false;
    }

    private async Task KaydetAsync()
    {
        if (string.IsNullOrWhiteSpace(editPersonel.PersonelKodu) || string.IsNullOrWhiteSpace(editPersonel.AdSoyad))
        {
            ToastService.ShowWarning("Personel kodu ve ad soyad zorunlu!");
            return;
        }

        try
        {
            if (editPersonel.Id > 0)
            {
                await SatisService.UpdateSatisPersonelAsync(editPersonel);
                ToastService.ShowSuccess("Personel guncellendi!");
            }
            else
            {
                await SatisService.CreateSatisPersonelAsync(editPersonel);
                ToastService.ShowSuccess("Personel eklendi!");
            }

            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void PerformansGoster(SatisPersoneli personel)
    {
        Navigation.NavigateTo($"/satis/personel/{personel.Id}/performans");
    }
}

