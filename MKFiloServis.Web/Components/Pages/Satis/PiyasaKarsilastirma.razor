@page "/satis/ilan/{IlanId:int}/piyasa"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject ISatisService SatisService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Piyasa Karsilastirma</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <a href="/satis/ilan/@IlanId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h4 class="mb-0">
                <i class="bi bi-graph-up me-2"></i>Piyasa Karsilastirma
                @if (ilan != null)
                {
                    <small class="text-muted ms-2">@ilan.Marka @ilan.Model @ilan.ModelYili</small>
                }
            </h4>
        </div>
        <button class="btn btn-primary" @onclick="YeniPiyasaIlanAc">
            <i class="bi bi-plus-lg me-1"></i>Manuel Ilan Ekle
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="row g-3">
            <!-- Sol Panel - Piyasa Degerlendirme -->
            <div class="col-lg-4">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0">Bizim Arac</h6>
                    </div>
                    <div class="card-body">
                        <div class="text-center">
                            <h2 class="text-success mb-0">@FormatPara(ilan?.SatisFiyati ?? 0)</h2>
                            <small class="text-muted">Satis Fiyati</small>
                        </div>
                        <hr />
                        <div class="row text-center small">
                            <div class="col-4">
                                <strong>@ilan?.Kilometre.ToString("N0")</strong><br />
                                <span class="text-muted">KM</span>
                            </div>
                            <div class="col-4">
                                <strong>@ilan?.ModelYili</strong><br />
                                <span class="text-muted">Yil</span>
                            </div>
                            <div class="col-4">
                                <strong>@(ilan?.BoyaliParcaSayisi ?? 0)</strong><br />
                                <span class="text-muted">Boyali</span>
                            </div>
                        </div>
                    </div>
                </div>

                @if (degerlendirme != null && degerlendirme.KarsilastirmaAdet > 0)
                {
                    <div class="card mb-3">
                        <div class="card-header">
                            <h6 class="mb-0">Piyasa Analizi</h6>
                        </div>
                        <div class="card-body">
                            <div class="text-center mb-3">
                                <span class="badge fs-5 @(degerlendirme.Degerlendirme.Contains("Uygun") ? "bg-success" : 
                                    degerlendirme.Degerlendirme.Contains("Piyasa") ? "bg-warning text-dark" : "bg-danger")">
                                    @degerlendirme.Degerlendirme
                                </span>
                            </div>

                            <table class="table table-sm mb-0">
                                <tr>
                                    <td>Minimum:</td>
                                    <td class="text-end"><strong>@FormatPara(degerlendirme.MinFiyat)</strong></td>
                                </tr>
                                <tr>
                                    <td>Ortalama:</td>
                                    <td class="text-end"><strong class="text-primary">@FormatPara(degerlendirme.OrtalamaFiyat)</strong></td>
                                </tr>
                                <tr>
                                    <td>Medyan:</td>
                                    <td class="text-end"><strong>@FormatPara(degerlendirme.MedianFiyat)</strong></td>
                                </tr>
                                <tr>
                                    <td>Maksimum:</td>
                                    <td class="text-end"><strong>@FormatPara(degerlendirme.MaxFiyat)</strong></td>
                                </tr>
                                <tr class="table-active">
                                    <td>Fark:</td>
                                    <td class="text-end">
                                        <strong class="@(degerlendirme.FiyatFarki < 0 ? "text-success" : "text-danger")">
                                            @(degerlendirme.FiyatFarki >= 0 ? "+" : "")@FormatPara(degerlendirme.FiyatFarki)
                                        </strong>
                                        <small>(@degerlendirme.FiyatFarkiYuzde%)</small>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    @if (degerlendirme.SehirDagilimi.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h6 class="mb-0">Sehir Dagilimi</h6>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Sehir</th>
                                            <th class="text-center">Ilan</th>
                                            <th class="text-end">Ort. Fiyat</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sehir in degerlendirme.SehirDagilimi.Take(10))
                                        {
                                            <tr>
                                                <td>@sehir.Sehir</td>
                                                <td class="text-center"><span class="badge bg-primary">@sehir.IlanSayisi</span></td>
                                                <td class="text-end">@FormatPara(sehir.OrtalamaFiyat)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Sag Panel - Piyasa Ilanlari -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-list me-2"></i>Piyasa Ilanlari (@piyasaIlanlari.Count)</h6>
                        <div class="d-flex gap-2">
                            <select class="form-select form-select-sm" style="width: 130px;" @bind="filtreKaynak" @bind:after="FiltreUygula">
                                <option value="">Tum Kaynaklar</option>
                                @foreach (var kaynak in Enum.GetValues<PiyasaKaynagi>())
                                {
                                    <option value="@((int)kaynak)">@GetKaynakAdi(kaynak)</option>
                                }
                            </select>
                            <select class="form-select form-select-sm" style="width: 100px;" @bind="siralama" @bind:after="FiltreUygula">
                                <option value="fiyat_asc">Fiyat ?</option>
                                <option value="fiyat_desc">Fiyat ?</option>
                                <option value="km_asc">KM ?</option>
                                <option value="tarih_desc">En Yeni</option>
                            </select>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Kaynak</th>
                                        <th>Sehir</th>
                                        <th class="text-end">Fiyat</th>
                                        <th class="text-end">KM</th>
                                        <th class="text-center">Yil</th>
                                        <th class="text-center">Boya</th>
                                        <th class="text-center">Degisen</th>
                                        <th class="text-center">Tramer</th>
                                        <th class="text-center">Islem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!filtrelenmisIlanlar.Any())
                                    {
                                        <tr>
                                            <td colspan="9" class="text-center text-muted py-3">
                                                Piyasa ilani bulunamadi. Manuel ilan ekleyebilirsiniz.
                                            </td>
                                        </tr>
                                    }
                                    @foreach (var pilan in filtrelenmisIlanlar)
                                    {
                                        var fark = pilan.Fiyat - (ilan?.SatisFiyati ?? 0);
                                        <tr>
                                            <td>
                                                <span class="badge @GetKaynakBadgeClass(pilan.Kaynak)">@GetKaynakAdi(pilan.Kaynak)</span>
                                            </td>
                                            <td>@(pilan.Sehir ?? "-")</td>
                                            <td class="text-end">
                                                <strong>@FormatPara(pilan.Fiyat)</strong>
                                                <br />
                                                <small class="@(fark < 0 ? "text-success" : fark > 0 ? "text-danger" : "")">
                                                    @(fark >= 0 ? "+" : "")@FormatPara(fark)
                                                </small>
                                            </td>
                                            <td class="text-end">@pilan.Kilometre.ToString("N0")</td>
                                            <td class="text-center">@pilan.Yil</td>
                                            <td class="text-center">
                                                @if (pilan.BoyaliParca > 0)
                                                {
                                                    <span class="badge bg-warning text-dark">@pilan.BoyaliParca</span>
                                                }
                                                else
                                                {
                                                    <span class="text-success">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (pilan.DegisenParca > 0)
                                                {
                                                    <span class="badge bg-danger">@pilan.DegisenParca</span>
                                                }
                                                else
                                                {
                                                    <span class="text-success">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (pilan.TramerVar)
                                                {
                                                    <span class="badge bg-info" title="@FormatPara(pilan.TramerTutari ?? 0)">
                                                        @FormatPara(pilan.TramerTutari ?? 0)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-success">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (!string.IsNullOrEmpty(pilan.IlanUrl))
                                                {
                                                    <a href="@pilan.IlanUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-box-arrow-up-right"></i>
                                                    </a>
                                                }
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => IlanSilAsync(pilan.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Yeni Piyasa Ilan Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Piyasa Ilani Ekle</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kaynak *</label>
                            <select class="form-select" @bind="yeniPiyasaIlan.Kaynak">
                                @foreach (var kaynak in Enum.GetValues<PiyasaKaynagi>())
                                {
                                    <option value="@kaynak">@GetKaynakAdi(kaynak)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fiyat *</label>
                            <input type="number" class="form-control" @bind="yeniPiyasaIlan.Fiyat" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sehir</label>
                            <input type="text" class="form-control" @bind="yeniPiyasaIlan.Sehir" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kilometre</label>
                            <input type="number" class="form-control" @bind="yeniPiyasaIlan.Kilometre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Yil</label>
                            <input type="number" class="form-control" @bind="yeniPiyasaIlan.Yil" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ilan URL</label>
                            <input type="text" class="form-control" @bind="yeniPiyasaIlan.IlanUrl" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Boyali Parca</label>
                            <input type="number" class="form-control" @bind="yeniPiyasaIlan.BoyaliParca" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Degisen Parca</label>
                            <input type="number" class="form-control" @bind="yeniPiyasaIlan.DegisenParca" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tramer</label>
                            <div class="input-group">
                                <div class="input-group-text">
                                    <input type="checkbox" class="form-check-input mt-0" @bind="yeniPiyasaIlan.TramerVar" />
                                </div>
                                <input type="number" class="form-control" @bind="yeniPiyasaIlan.TramerTutari" disabled="@(!yeniPiyasaIlan.TramerVar)" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="PiyasaIlanKaydetAsync">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int IlanId { get; set; }

    private bool isLoading = true;
    private bool showModal = false;
    private string filtreKaynak = "";
    private string siralama = "fiyat_asc";

    private AracIlan? ilan;
    private PiyasaDegerlendirme? degerlendirme;
    private List<PiyasaIlan> piyasaIlanlari = new();
    private List<PiyasaIlan> filtrelenmisIlanlar = new();
    private PiyasaIlan yeniPiyasaIlan = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            ilan = await SatisService.GetAracIlanByIdAsync(IlanId);
            if (ilan == null)
            {
                ToastService.ShowError("Ilan bulunamadi!");
                Navigation.NavigateTo("/satis");
                return;
            }

            piyasaIlanlari = await SatisService.GetPiyasaIlanlariAsync(IlanId);
            degerlendirme = await SatisService.GetPiyasaDegerlendirmeAsync(IlanId);
            FiltreUygula();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FiltreUygula()
    {
        var query = piyasaIlanlari.AsEnumerable();

        if (!string.IsNullOrEmpty(filtreKaynak) && int.TryParse(filtreKaynak, out var kaynak))
        {
            query = query.Where(p => (int)p.Kaynak == kaynak);
        }

        query = siralama switch
        {
            "fiyat_asc" => query.OrderBy(p => p.Fiyat),
            "fiyat_desc" => query.OrderByDescending(p => p.Fiyat),
            "km_asc" => query.OrderBy(p => p.Kilometre),
            "tarih_desc" => query.OrderByDescending(p => p.TaramaTarihi),
            _ => query
        };

        filtrelenmisIlanlar = query.ToList();
        StateHasChanged();
    }

    private void YeniPiyasaIlanAc()
    {
        yeniPiyasaIlan = new PiyasaIlan
        {
            AracIlanId = IlanId,
            Yil = ilan?.ModelYili ?? DateTime.Today.Year,
            Kilometre = ilan?.Kilometre ?? 0,
            Kaynak = PiyasaKaynagi.Sahibinden
        };
        showModal = true;
    }

    private void ModalKapat()
    {
        showModal = false;
    }

    private async Task PiyasaIlanKaydetAsync()
    {
        if (yeniPiyasaIlan.Fiyat <= 0)
        {
            ToastService.ShowWarning("Fiyat girmelisiniz!");
            return;
        }

        try
        {
            await SatisService.AddPiyasaIlanAsync(yeniPiyasaIlan);
            ToastService.ShowSuccess("Piyasa ilani eklendi!");
            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task IlanSilAsync(int id)
    {
        try
        {
            await SatisService.DeletePiyasaIlanAsync(id);
            ToastService.ShowInfo("Ilan silindi");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private string GetKaynakAdi(PiyasaKaynagi k) => k switch
    {
        PiyasaKaynagi.Sahibinden => "Sahibinden",
        PiyasaKaynagi.Arabam => "Arabam",
        PiyasaKaynagi.Araba => "Araba.com",
        PiyasaKaynagi.LetGo => "LetGo",
        PiyasaKaynagi.Facebook => "Facebook",
        PiyasaKaynagi.Instagram => "Instagram",
        PiyasaKaynagi.Diger => "Diger",
        _ => k.ToString()
    };

    private string GetKaynakBadgeClass(PiyasaKaynagi k) => k switch
    {
        PiyasaKaynagi.Sahibinden => "bg-warning text-dark",
        PiyasaKaynagi.Arabam => "bg-info",
        _ => "bg-secondary"
    };

    private string FormatPara(decimal t) => t.ToString("N0") + " TL";
}

