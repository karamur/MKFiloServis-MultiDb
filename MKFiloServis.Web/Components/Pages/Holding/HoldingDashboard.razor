@page "/holding"
@attribute [Authorize(Roles = "Admin,HoldingYoneticisi")]
@rendermode InteractiveServer
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IHoldingService HoldingService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject ILogger<HoldingDashboard> Logger

<PageTitle>Holding Dashboard</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-1"><i class="bi bi-buildings me-2"></i>Holding Dashboard</h4>
                <p class="text-muted small mb-0">Tum firmalarin konsolide finansal ozeti</p>
            </div>
            <div>
                <div class="d-flex gap-2 align-items-center">
                    <select class="form-select form-select-sm" style="width:80px" @bind="seciliYil">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                    <select class="form-select form-select-sm" style="width:100px" @bind="seciliAy">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@(new DateTime(2024, a, 1).ToString("MMMM"))</option>
                        }
                    </select>
                    <button class="btn btn-warning btn-sm" @onclick="VeriTopla" disabled="@toplaniyor">
                        <i class="bi @(toplaniyor ? "bi-hourglass-split" : "bi-database-down") me-1"></i>
                        @(toplaniyor ? "Toplaniyor..." : "Veri Topla")
                    </button>
                </div>
            </div>
        </div>

        @if (veriler.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Henuz holding verisi toplanmamis. Veri toplama islemi her ay otomatik calisir.
            </div>
        }
        else
        {
            var toplamGelir = veriler.Sum(v => v.ToplamGelir);
            var toplamGider = veriler.Sum(v => v.ToplamGider);
            var toplamKar = veriler.Sum(v => v.Kar);
            var toplamAracMaliyet = veriler.Sum(v => v.AraclarMaliyet ?? 0);
            var toplamPersonelMaliyet = veriler.Sum(v => v.PersonelMaliyet ?? 0);

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card border-success">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Toplam Gelir</h6>
                            <h3 class="text-success">@toplamGelir.ToString("N2") TL</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-danger">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Toplam Gider</h6>
                            <h3 class="text-danger">@toplamGider.ToString("N2") TL</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-primary">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Net Kar</h6>
                            <h3 class="text-primary">@toplamKar.ToString("N2") TL</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Arac Maliyet</h6>
                            <h5>@toplamAracMaliyet.ToString("N2") TL</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Personel Maliyet</h6>
                            <h5>@toplamPersonelMaliyet.ToString("N2") TL</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Aktif Arac</h6>
                            <h5>@veriler.Sum(v => v.AktifAracSayisi ?? 0)</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Toplam Personel</h6>
                            <h5>@veriler.Sum(v => v.PersonelSayisi ?? 0)</h5>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="mb-3">Firma Bazli Ozet</h5>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Firma</th>
                            <th class="text-end">Gelir</th>
                            <th class="text-end">Gider</th>
                            <th class="text-end">Kar</th>
                            <th class="text-end">Arac Maliyet</th>
                            <th class="text-end">Personel</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in veriler.OrderByDescending(v => v.Kar))
                        {
                            <tr>
                                <td>@v.FirmaAdi</td>
                                <td class="text-end">@v.ToplamGelir.ToString("N2")</td>
                                <td class="text-end">@v.ToplamGider.ToString("N2")</td>
                                <td class="text-end @(v.Kar >= 0 ? "text-success" : "text-danger")">@v.Kar.ToString("N2")</td>
                                <td class="text-end">@(v.AraclarMaliyet?.ToString("N2") ?? "-")</td>
                                <td class="text-end">@(v.PersonelMaliyet?.ToString("N2") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool isLoading = true;
    private bool toplaniyor;
    private List<HoldingVeri> veriler = new();
    private int seciliYil = DateTime.Now.Year;
    private int seciliAy = DateTime.Now.Month;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            veriler = await HoldingService.GetFirmaKarsilastirmaAsync(seciliYil, seciliAy);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Holding verisi yuklenemedi");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VeriTopla()
    {
        toplaniyor = true;
        try
        {
            await HoldingService.ToplaVeKaydetAsync(seciliYil, seciliAy);
            veriler = await HoldingService.GetFirmaKarsilastirmaAsync(seciliYil, seciliAy);
            ToastService.ShowSuccess($"{seciliYil}-{seciliAy:D2} donemi holding verisi toplandi.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Holding veri toplama hatasi");
            ToastService.ShowError($"Veri toplama hatasi: {ex.Message}");
        }
        finally
        {
            toplaniyor = false;
        }
    }
}

