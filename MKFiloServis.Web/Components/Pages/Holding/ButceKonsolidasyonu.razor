@page "/holding/butce"
@attribute [Authorize(Roles = "Admin,HoldingYoneticisi")]
@rendermode InteractiveServer
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IHoldingService HoldingService
@inject ILogger<ButceKonsolidasyonu> Logger

<PageTitle>Butce Konsolidasyonu</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <h4 class="mb-3"><i class="bi bi-calculator me-2"></i>Butce Konsolidasyonu</h4>

        <div class="row mb-3">
            <div class="col-auto">
                <select class="form-select" @bind="seciliYil" @bind:after="YenidenYukle">
                    @for (int y = DateTime.UtcNow.Year; y >= DateTime.UtcNow.Year - 3; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>
        </div>

        @if (veriler.Count == 0)
        {
            <div class="alert alert-info">Secilen donemde veri bulunamadi.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Firma</th>
                            <th class="text-end">Butce Hedef</th>
                            <th class="text-end">Gerceklesen</th>
                            <th class="text-end">Fark</th>
                            <th class="text-end">Basari %</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in veriler.OrderBy(v => v.FirmaAdi))
                        {
                            var fark = (v.ToplamGelir) - (v.ButceHedef ?? 0);
                            var basari = v.ButceHedef > 0 ? (v.ToplamGelir / v.ButceHedef.Value * 100) : 0m;
                            <tr>
                                <td>@v.FirmaAdi</td>
                                <td class="text-end">@(v.ButceHedef?.ToString("N2") ?? "-")</td>
                                <td class="text-end">@v.ToplamGelir.ToString("N2")</td>
                                <td class="text-end @(fark >= 0 ? "text-success" : "text-danger")">@fark.ToString("N2")</td>
                                <td class="text-end">@(v.ButceHedef > 0 ? basari.ToString("F1") + "%" : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool isLoading = true;
    private List<HoldingVeri> veriler = new();
    private int seciliYil = DateTime.UtcNow.Year;

    protected override async Task OnInitializedAsync() => await Yukle();

    private async Task Yukle()
    {
        isLoading = true;
        try { veriler = await HoldingService.GetButceKonsolidasyonAsync(seciliYil); }
        finally { isLoading = false; }
    }

    private async Task YenidenYukle() => await Yukle();
}

