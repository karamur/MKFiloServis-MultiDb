@page "/holding/hakedis"
@attribute [Authorize(Roles = "Admin,HoldingYoneticisi")]
@rendermode InteractiveServer
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IHoldingService HoldingService
@inject ILogger<HakedisOzeti> Logger

<PageTitle>Hakedis Ozeti</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <h4 class="mb-3"><i class="bi bi-clipboard-check me-2"></i>Hakedis Ozeti</h4>

        <div class="row mb-3">
            <div class="col-auto">
                <select class="form-select" @bind="seciliYil">
                    @for (int y = DateTime.UtcNow.Year; y >= DateTime.UtcNow.Year - 3; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <select class="form-select" @bind="seciliAy">
                    <option value="">Tum Aylar</option>
                    @for (int a = 1; a <= 12; a++)
                    {
                        <option value="@a">@(new DateTime(2024, a, 1).ToString("MMMM"))</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary" @onclick="YenidenYukle">
                    <i class="bi bi-arrow-repeat me-1"></i> Yenile
                </button>
            </div>
        </div>

        @if (veriler.Count == 0)
        {
            <div class="alert alert-info">Secilen donemde veri bulunamadi.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Firma</th>
                            <th class="text-end">Hakedis Toplam</th>
                            <th class="text-end">Toplam Gelir</th>
                            <th class="text-end">Hakedis/Gelir %</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in veriler.OrderByDescending(v => v.HakedisToplam ?? 0))
                        {
                            var oran = v.ToplamGelir > 0 ? (v.HakedisToplam ?? 0) / v.ToplamGelir * 100 : 0;
                            <tr>
                                <td>@v.FirmaAdi</td>
                                <td class="text-end">@(v.HakedisToplam?.ToString("N2") ?? "-")</td>
                                <td class="text-end">@v.ToplamGelir.ToString("N2")</td>
                                <td class="text-end">@(v.ToplamGelir > 0 ? oran.ToString("F1") + "%" : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool isLoading = true;
    private List<HoldingVeri> veriler = new();
    private int seciliYil = DateTime.UtcNow.Year;
    private string seciliAy = "";

    protected override async Task OnInitializedAsync() => await Yukle();

    private async Task Yukle()
    {
        isLoading = true;
        try
        {
            int? ay = string.IsNullOrEmpty(seciliAy) ? null : int.Parse(seciliAy);
            veriler = await HoldingService.GetHakedisOzetiAsync(seciliYil, ay);
        }
        finally { isLoading = false; }
    }

    private async Task YenidenYukle() => await Yukle();
}

