@page "/arac-maliyet-snapshot"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IAracMaliyetService MaliyetService
@inject IAracService AracService
@inject IToastService ToastService
@attribute [Authorize]

<PageTitle>Araç Maliyet Snapshot</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-fuel-pump me-2"></i>Araç Maliyet Snapshot</h2>
            <p class="text-muted mb-0">Özmal / Kiralık araçların aylık maliyet ve karlılık özeti (Tedarikçi araçları hariç)</p>
        </div>
        <div class="d-flex gap-2 flex-wrap justify-content-end">
            <button class="btn btn-outline-warning" @onclick="FullpetModalAc">
                <i class="bi bi-fuel-pump-fill me-1"></i> Fullpet Fatura Dağıt
            </button>
            <button class="btn btn-outline-primary" @onclick="TekAracModalAc">
                <i class="bi bi-plus-lg me-1"></i> Tek Araç Üret
            </button>
            <button class="btn btn-primary" @onclick="TumAraclarUretOnay" disabled="@isleniyor">
                @if (isleniyor)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-arrow-repeat me-1"></i> Tüm Araçlar İçin Üret
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Yıl</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="LoadAsync">
                        @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAy" @bind:after="LoadAsync">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@AyAdi(a)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Araç</label>
                    <select class="form-select form-select-sm" @bind="filtreAracId" @bind:after="LoadAsync">
                        <option value="0">Tümü</option>
                        @foreach (var a in araclar)
                        {
                            <option value="@a.Id">@a.Plaka (@a.SahiplikTipi)</option>
                        }
                    </select>
                </div>
                <div class="col-md-5 text-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreyiTemizle">
                        <i class="bi bi-x-lg me-1"></i>Filtreyi Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Özet kartları -->
    @if (snapshotlar.Any())
    {
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body py-2">
                        <div class="text-muted small">Toplam Maliyet</div>
                        <div class="fs-5 fw-bold text-info">@snapshotlar.Sum(s => s.ToplamMaliyet).ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body py-2">
                        <div class="text-muted small">Toplam Gelir</div>
                        <div class="fs-5 fw-bold text-success">@snapshotlar.Sum(s => s.ToplamGelir).ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(ToplamKarZarar >= 0 ? "border-success" : "border-danger")">
                    <div class="card-body py-2">
                        <div class="text-muted small">Kar / Zarar</div>
                        <div class="fs-5 fw-bold @(ToplamKarZarar >= 0 ? "text-success" : "text-danger")">@ToplamKarZarar.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-secondary">
                    <div class="card-body py-2">
                        <div class="text-muted small">Toplam Sefer</div>
                        <div class="fs-5 fw-bold">@snapshotlar.Sum(s => s.ToplamSefer).ToString("N2")</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Liste -->
    <div class="card">
        <div class="card-body p-0">
            @if (yukleniyor)
            {
                <div class="p-4 text-center text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
                </div>
            }
            else if (!snapshotlar.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Bu kriterlere uygun snapshot bulunamadı. Üstteki butonlardan üretebilirsiniz.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Dönem</th>
                                <th>Plaka</th>
                                <th>Sahiplik</th>
                                <th class="text-end">KM</th>
                                <th class="text-end">Sefer</th>
                                <th class="text-end">Yakıt</th>
                                <th class="text-end">Bakım</th>
                                <th class="text-end">Lastik</th>
                                <th class="text-end">Sigorta</th>
                                <th class="text-end">Kira</th>
                                <th class="text-end">Şoför</th>
                                <th class="text-end">Diğer</th>
                                <th class="text-end fw-bold">Toplam</th>
                                <th class="text-end">Sefer/₺</th>
                                <th class="text-end">Gelir</th>
                                <th class="text-end">Kar/Zarar</th>
                                <th class="text-center" style="width:100px;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in snapshotlar)
                            {
                                <tr>
                                    <td>@s.Yil/@s.Ay.ToString("D2")</td>
                                    <td><strong>@s.Arac?.Plaka</strong></td>
                                    <td><span class="badge @SahiplikBadge(s.SahiplikTipi)">@s.SahiplikTipi</span></td>
                                    <td class="text-end">@s.ToplamKm.ToString("N0")</td>
                                    <td class="text-end">@s.ToplamSefer.ToString("N2")</td>
                                    <td class="text-end">@s.YakitMasraf.ToString("N2")</td>
                                    <td class="text-end">@s.BakimMasraf.ToString("N2")</td>
                                    <td class="text-end">@s.LastikMasraf.ToString("N2")</td>
                                    <td class="text-end">@((s.SigortaMasraf + s.KaskoMasraf).ToString("N2"))</td>
                                    <td class="text-end">@s.PlakaKirasi.ToString("N2")</td>
                                    <td class="text-end">@s.SoforMaasPayi.ToString("N2")</td>
                                    <td class="text-end">@((s.AmortismanPayi + s.DigerMasraf).ToString("N2"))</td>
                                    <td class="text-end fw-bold text-info">@s.ToplamMaliyet.ToString("N2")</td>
                                    <td class="text-end">@s.SeferBasiMaliyet.ToString("N2")</td>
                                    <td class="text-end text-success">@s.ToplamGelir.ToString("N2")</td>
                                    <td class="text-end fw-semibold @(s.KarZarar >= 0 ? "text-success" : "text-danger")">@s.KarZarar.ToString("N2")</td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" title="Yeniden Üret" @onclick="() => YenidenUretOnay(s)">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" title="Sil" @onclick="() => SilOnay(s)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- ========== ONAY MODAL ========== -->
@if (onayModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-question-circle me-2 text-warning"></i>Onay</h5>
                    <button type="button" class="btn-close" @onclick="OnayIptal"></button>
                </div>
                <div class="modal-body">@onayMesaji</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="OnayIptal">İptal</button>
                    <button class="btn btn-primary btn-sm" @onclick="OnayOnayla" disabled="@isleniyor">
                        @if (isleniyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Evet, Devam Et
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ========== TEK ARAÇ MODAL ========== -->
@if (tekAracModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-lg me-2"></i>Tek Araç Snapshot Üret</h5>
                    <button type="button" class="btn-close" @onclick="() => tekAracModalAcik = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small">Yıl</label>
                            <select class="form-select form-select-sm" @bind="uretYil">
                                @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Ay</label>
                            <select class="form-select form-select-sm" @bind="uretAy">
                                @for (int a = 1; a <= 12; a++)
                                {
                                    <option value="@a">@AyAdi(a)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small">Araç</label>
                            <select class="form-select form-select-sm" @bind="uretAracId">
                                <option value="0">-- Seçiniz --</option>
                                @foreach (var a in araclar.Where(x => x.SahiplikTipi != AracSahiplikTipi.Tedarikci))
                                {
                                    <option value="@a.Id">@a.Plaka (@a.SahiplikTipi)</option>
                                }
                            </select>
                            <div class="form-text">Tedarikçi araçları için snapshot üretilmez.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => tekAracModalAcik = false">İptal</button>
                    <button class="btn btn-primary btn-sm" @onclick="TekAracUret" disabled="@(uretAracId <= 0 || isleniyor)">
                        @if (isleniyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Üret
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ========== FULLPET FATURA DAĞIT MODAL ========== -->
@if (fullpetModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning bg-opacity-10">
                    <h5 class="modal-title"><i class="bi bi-fuel-pump-fill me-2 text-warning"></i>Fullpet Fatura Dağılımı</h5>
                    <button type="button" class="btn-close" @onclick="() => fullpetModalAcik = false"></button>
                </div>
                <div class="modal-body">
                    <!-- Fatura bilgileri -->
                    <div class="row g-2 mb-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Fatura Tarihi <span class="text-danger">*</span></label>
                            <input type="date" class="form-control form-control-sm"
                                   value="@fp_tarih.ToString("yyyy-MM-dd")"
                                   @onchange="e => fp_tarih = DateTime.Parse(e.Value!.ToString()!)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Fatura No</label>
                            <input type="text" class="form-control form-control-sm" placeholder="FT-2026-001"
                                   @bind="fp_faturaNo" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Toplam Tutar (₺) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control form-control-sm" step="0.01" min="0"
                                   @bind="fp_toplamTutar" @bind:after="FpTutarDegisti" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Açıklama</label>
                            <input type="text" class="form-control form-control-sm" placeholder="Fullpet Mart 2026..."
                                   @bind="fp_aciklama" />
                        </div>
                    </div>

                    <!-- Dağılım yöntemi -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Dağılım Yöntemi</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="dagYon" id="dagEsit"
                                       checked="@(fp_dagitimYontemi == "esit")"
                                       @onchange="FpYontemEsitSec" />
                                <label class="form-check-label" for="dagEsit">Eşit Dağıt</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="dagYon" id="dagManuel"
                                       checked="@(fp_dagitimYontemi == "manuel")"
                                       @onchange="FpYontemManuelSec" />
                                <label class="form-check-label" for="dagManuel">Manuel Giriş</label>
                            </div>
                        </div>
                    </div>

                    <!-- Araç listesi -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold small">Araçlar</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="FpTumunuSec">Tümünü Seç</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="FpTumunuKaldir">Tümünü Kaldır</button>
                        </div>
                    </div>
                    <div class="table-responsive" style="max-height:320px;overflow-y:auto;">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width:40px;" class="text-center">#</th>
                                    <th>Plaka</th>
                                    <th>Sahiplik</th>
                                    <th class="text-end" style="width:160px;">Tutar (₺)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var satir in fp_satirlar)
                                {
                                    <tr class="@(satir.Secili ? "" : "table-secondary text-muted")">
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@satir.Secili"
                                                   @onchange="e => FpSecimDegisti(satir, (bool)e.Value!)" />
                                        </td>
                                        <td><strong>@satir.Plaka</strong></td>
                                        <td><span class="badge @SahiplikBadge(satir.SahiplikTipi)">@satir.SahiplikTipi</span></td>
                                        <td class="text-end">
                                            @if (fp_dagitimYontemi == "manuel" && satir.Secili)
                                            {
                                                <input type="number" class="form-control form-control-sm text-end"
                                                       step="0.01" min="0"
                                                       value="@satir.Tutar"
                                                       @onchange="e => FpSatirTutarDegisti(satir, e.Value!.ToString()!)" />
                                            }
                                            else
                                            {
                                                <span class="@(satir.Secili ? "text-dark" : "")">@satir.Tutar.ToString("N2")</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="3" class="text-end">Seçili Araç Tutarı:</td>
                                    <td class="text-end @(Math.Abs(fp_satirlar.Where(s => s.Secili).Sum(s => s.Tutar) - fp_toplamTutar) > 0.05m ? "text-danger" : "text-success")">
                                        @fp_satirlar.Where(s => s.Secili).Sum(s => s.Tutar).ToString("N2") ₺
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    @{
                        var fark = fp_satirlar.Where(s => s.Secili).Sum(s => s.Tutar) - fp_toplamTutar;
                    }
                    @if (fp_dagitimYontemi == "manuel" && Math.Abs(fark) > 0.05m)
                    {
                        <div class="alert alert-warning mt-2 py-1 small mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Araç tutarları toplamı ile fatura tutarı arasında <strong>@Math.Abs(fark).ToString("N2") ₺</strong> fark var.
                            @(fark > 0 ? "Araç tutarları fazla." : "Araç tutarları eksik.")
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <div class="text-muted small me-auto">
                        @fp_satirlar.Count(s => s.Secili) araç seçili
                    </div>
                    <button class="btn btn-secondary btn-sm" @onclick="() => fullpetModalAcik = false">İptal</button>
                    <button class="btn btn-warning btn-sm" @onclick="FullpetKaydet"
                            disabled="@(fp_toplamTutar <= 0 || !fp_satirlar.Any(s => s.Secili) || isleniyor)">
                        @if (isleniyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Dağılımı Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool yukleniyor = true;
    private bool isleniyor = false;
    private bool tekAracModalAcik = false;
    private bool fullpetModalAcik = false;

    // --- Onay modal ---
    private bool onayModalAcik = false;
    private string onayMesaji = "";
    private Func<Task>? onayEylemi;

    // --- Filtre ---
    private int filtreYil = DateTime.Now.Year;
    private int filtreAy = DateTime.Now.Month;
    private int filtreAracId = 0;

    // --- Tek araç üretim ---
    private int uretYil = DateTime.Now.Year;
    private int uretAy = DateTime.Now.Month;
    private int uretAracId = 0;

    // --- Fullpet modal alanları ---
    private DateTime fp_tarih = DateTime.Today;
    private string? fp_faturaNo;
    private string? fp_aciklama;
    private decimal fp_toplamTutar = 0m;
    private string fp_dagitimYontemi = "esit";  // "esit" | "manuel"
    private List<FullpetSatir> fp_satirlar = new();

    private List<AracMaliyetSnapshot> snapshotlar = new();
    private List<Arac> araclar = new();

    private decimal ToplamKarZarar => snapshotlar.Sum(s => s.KarZarar);

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetActiveAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            int? aracId = filtreAracId > 0 ? filtreAracId : null;
            snapshotlar = await MaliyetService.GetSnapshotlarAsync(aracId, filtreYil, filtreAy);
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private async Task FiltreyiTemizle()
    {
        filtreYil = DateTime.Now.Year;
        filtreAy = DateTime.Now.Month;
        filtreAracId = 0;
        await LoadAsync();
    }

    // ===== Onay Modal =====
    private void OnayGoster(string mesaj, Func<Task> eylem)
    {
        onayMesaji = mesaj;
        onayEylemi = eylem;
        onayModalAcik = true;
    }

    private void OnayIptal()
    {
        onayModalAcik = false;
        onayEylemi = null;
    }

    private async Task OnayOnayla()
    {
        onayModalAcik = false;
        if (onayEylemi != null)
            await onayEylemi();
        onayEylemi = null;
    }

    // ===== Tek Araç =====
    private void TekAracModalAc()
    {
        uretYil = filtreYil;
        uretAy = filtreAy;
        uretAracId = 0;
        tekAracModalAcik = true;
    }

    private async Task TekAracUret()
    {
        if (uretAracId <= 0) return;
        isleniyor = true;
        try
        {
            var s = await MaliyetService.SnapshotUretAsync(uretAracId, uretYil, uretAy);
            ToastService.ShowSuccess($"Snapshot üretildi: {s.Arac?.Plaka} – {s.ToplamMaliyet:N2} ₺");
            tekAracModalAcik = false;
            filtreYil = uretYil; filtreAy = uretAy;
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
        finally { isleniyor = false; }
    }

    // ===== Tüm Araçlar =====
    private void TumAraclarUretOnay()
    {
        OnayGoster(
            $"{filtreYil}/{filtreAy:D2} dönemi için tüm özmal+kiralık araçlar üretilsin mi?",
            TumAraclarUret);
    }

    private async Task TumAraclarUret()
    {
        isleniyor = true;
        try
        {
            var liste = await MaliyetService.TumAraclarIcinUretAsync(filtreYil, filtreAy);
            ToastService.ShowSuccess($"{liste.Count} araç için snapshot üretildi.");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
        finally { isleniyor = false; }
    }

    // ===== Yeniden Üret / Sil =====
    private void YenidenUretOnay(AracMaliyetSnapshot s)
    {
        OnayGoster(
            $"{s.Arac?.Plaka} {s.Yil}/{s.Ay:D2} snapshot'u yeniden hesaplansın mı?",
            async () =>
            {
                isleniyor = true;
                try
                {
                    await MaliyetService.SnapshotUretAsync(s.AracId, s.Yil, s.Ay);
                    ToastService.ShowSuccess("Snapshot güncellendi.");
                    await LoadAsync();
                }
                catch (Exception ex) { ToastService.ShowError(ex.Message); }
                finally { isleniyor = false; }
            });
    }

    private void SilOnay(AracMaliyetSnapshot s)
    {
        OnayGoster(
            $"{s.Arac?.Plaka} {s.Yil}/{s.Ay:D2} snapshot'u silinsin mi?",
            async () =>
            {
                try
                {
                    await MaliyetService.SilAsync(s.Id);
                    ToastService.ShowSuccess("Snapshot silindi.");
                    await LoadAsync();
                }
                catch (Exception ex) { ToastService.ShowError(ex.Message); }
            });
    }

    // ===== FULLPET =====
    private void FullpetModalAc()
    {
        fp_tarih = new DateTime(filtreYil, filtreAy, 1);
        fp_faturaNo = null;
        fp_aciklama = null;
        fp_toplamTutar = 0m;
        fp_dagitimYontemi = "esit";

        // Sadece özmal + kiralık araçlar
        var hedefAraclar = araclar
            .Where(a => a.SahiplikTipi != AracSahiplikTipi.Tedarikci)
            .ToList();

        fp_satirlar = hedefAraclar.Select(a => new FullpetSatir
        {
            AracId = a.Id,
            Plaka = a.Plaka,
            SahiplikTipi = a.SahiplikTipi,
            Secili = true,
            Tutar = 0m
        }).ToList();

        fullpetModalAcik = true;
    }

    private void FpYontemDegisti(string yontem)
    {
        fp_dagitimYontemi = yontem;
        FpTutarDagit();
    }

    private void FpYontemEsitSec(ChangeEventArgs _) => FpYontemDegisti("esit");
    private void FpYontemManuelSec(ChangeEventArgs _) => FpYontemDegisti("manuel");

    private void FpTutarDegisti()
    {
        FpTutarDagit();
    }

    private void FpTutarDagit()
    {
        if (fp_dagitimYontemi == "esit")
        {
            var seciliSatirlar = fp_satirlar.Where(s => s.Secili).ToList();
            if (!seciliSatirlar.Any() || fp_toplamTutar <= 0) return;
            decimal birim = Math.Round(fp_toplamTutar / seciliSatirlar.Count, 2);
            for (int i = 0; i < seciliSatirlar.Count; i++)
            {
                seciliSatirlar[i].Tutar = (i < seciliSatirlar.Count - 1)
                    ? birim
                    : fp_toplamTutar - birim * (seciliSatirlar.Count - 1);
            }
            // seçili olmayan sıfırla
            foreach (var s in fp_satirlar.Where(s => !s.Secili))
                s.Tutar = 0m;
        }
    }

    private void FpSecimDegisti(FullpetSatir satir, bool secili)
    {
        satir.Secili = secili;
        if (!secili) satir.Tutar = 0m;
        FpTutarDagit();
    }

    private void FpSatirTutarDegisti(FullpetSatir satir, string deger)
    {
        if (decimal.TryParse(deger.Replace(',', '.'),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out decimal tutar))
            satir.Tutar = tutar;
    }

    private void FpTumunuSec()
    {
        foreach (var s in fp_satirlar) s.Secili = true;
        FpTutarDagit();
    }

    private void FpTumunuKaldir()
    {
        foreach (var s in fp_satirlar) { s.Secili = false; s.Tutar = 0m; }
    }

    private async Task FullpetKaydet()
    {
        var seciliSatirlar = fp_satirlar.Where(s => s.Secili && s.Tutar > 0).ToList();
        if (!seciliSatirlar.Any())
        {
            ToastService.ShowWarning("En az bir araç için tutar girilmeli.");
            return;
        }

        isleniyor = true;
        try
        {
            var aracIdler = seciliSatirlar.Select(s => s.AracId).ToList();
            var esit = fp_dagitimYontemi == "esit";
            Dictionary<int, decimal>? aracTutarlari = esit
                ? null
                : seciliSatirlar.ToDictionary(s => s.AracId, s => s.Tutar);

            int kayit = await MaliyetService.FullpetFaturaDagitAsync(
                fp_tarih, fp_faturaNo, fp_aciklama,
                aracIdler, fp_toplamTutar, esit, aracTutarlari);

            ToastService.ShowSuccess($"Fullpet dağılımı kaydedildi: {kayit} araç, {fp_toplamTutar:N2} ₺");
            fullpetModalAcik = false;
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
        finally { isleniyor = false; }
    }

    // ===== Yardımcılar =====
    private string AyAdi(int a) => a switch
    {
        1 => "Ocak", 2 => "Şubat", 3 => "Mart", 4 => "Nisan",
        5 => "Mayıs", 6 => "Haziran", 7 => "Temmuz", 8 => "Ağustos",
        9 => "Eylül", 10 => "Ekim", 11 => "Kasım", 12 => "Aralık",
        _ => a.ToString()
    };

    private string SahiplikBadge(AracSahiplikTipi t) => SahiplikHelper.GetBadgeClass(t);

    private class FullpetSatir
    {
        public int AracId { get; set; }
        public string Plaka { get; set; } = "";
        public AracSahiplikTipi SahiplikTipi { get; set; }
        public bool Secili { get; set; } = true;
        public decimal Tutar { get; set; }
    }
}

