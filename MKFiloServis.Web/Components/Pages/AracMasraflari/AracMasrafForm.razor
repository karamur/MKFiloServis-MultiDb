@page "/arac-masraflari/yeni"
@page "/arac-masraflari/{Id:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IAracMasrafService AracMasrafService
@inject IBankaKasaHareketService HareketService
@inject IBankaHesapService BankaHesapService
@inject IAracService AracService
@inject IMasrafKalemiService MasrafKalemiService
@inject IGuzergahService GuzergahService
@inject IServisCalismaService ServisCalismaService
@inject ISoforService SoforService
@inject ICariService CariService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@PageTitleText</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-cash-stack me-2"></i>@PageTitleText</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="masraf" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Masraf Tarihi *</label>
                            <InputDate @bind-Value="masraf.MasrafTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Araç (Plaka) *</label>
                            <div class="position-relative">
                                <input type="text" class="form-control" placeholder="Plaka veya marka ara..."
                                       value="@plakaArama"
                                       @oninput="PlakaFiltrele"
                                       @onfocus="() => plakaDropAcik = true"
                                       @onblur="PlakaDropKapat" />
                                @if (plakaDropAcik && filtreliAraclar.Any())
                                {
                                    <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1050;">
                                        @foreach (var a in filtreliAraclar)
                                        {
                                            <button type="button" class="dropdown-item" @onmousedown="() => AracSec(a)">
                                                <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                            @if (masraf.AracId > 0)
                            {
                                <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @plakaArama</small>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Masraf Kalemi *</label>
                            <InputSelect @bind-Value="masraf.MasrafKalemiId" class="form-select">
                                <option value="0">-- Masraf Kalemi Seçiniz --</option>
                                @foreach (var kalem in masrafKalemleri)
                                {
                                    <option value="@kalem.Id">@kalem.MasrafAdi (@GetKategoriText(kalem.Kategori))</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Tutar (₺) *</label>
                            <InputNumber @bind-Value="masraf.Tutar" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Belge No</label>
                            <InputText @bind-Value="masraf.BelgeNo" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="card bg-light border-primary mb-3">
                    <div class="card-body">
                        <h6 class="card-title text-primary"><i class="bi bi-person-vcard me-2"></i>Fiş / Muhatap Bilgisi</h6>
                        <p class="small text-muted mb-3">Ödemenin kasa, personel veya cari tarafından yapıldığını seçin. İsterseniz muhasebe fişini de birlikte oluşturabilirsiniz.</p>
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label class="form-label d-block">Ödemeyi Yapan</label>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="odemeTipi" value="Kasa" checked="@(odemeTipi == "Kasa")" @onchange="OdemeTipiDegisti" />
                                    <label class="form-check-label">Kasa</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="odemeTipi" value="Personel" checked="@(odemeTipi == "Personel")" @onchange="OdemeTipiDegisti" />
                                    <label class="form-check-label">Personel cebinden</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="odemeTipi" value="Cari" checked="@(odemeTipi == "Cari")" @onchange="OdemeTipiDegisti" />
                                    <label class="form-check-label">Cari cebinden</label>
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-1">
                                    <InputCheckbox @bind-Value="muhasebeFisiOlustur" class="form-check-input" id="muhasebeFisiOlustur" />
                                    <label class="form-check-label" for="muhasebeFisiOlustur">Muhasebe fişi oluştur/güncelle</label>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6" style="display:@(odemeTipi == "Personel" ? "block" : "none")">
                                <div class="mb-3">
                                    <label class="form-label">Personel</label>
                                    <InputSelect TValue="int?" @bind-Value="masraf.SoforId" class="form-select">
                                        <option value="">-- Personel Seçiniz --</option>
                                        @foreach (var sofor in soforler)
                                        {
                                            <option value="@sofor.Id">@sofor.TamAd (@sofor.SoforKodu)</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-6" style="display:@(odemeTipi == "Personel" ? "block" : "none")">
                                <div class="mb-3">
                                    <label class="form-label">Geri Ödeme Hesabı</label>
                                    <InputSelect TValue="int?" @bind-Value="masraf.BankaHesapId" class="form-select">
                                        <option value="">-- Hesap Seçiniz (opsiyonel) --</option>
                                        @foreach (var h in hesaplar)
                                        {
                                            <option value="@h.Id">@h.HesapAdi (@GetHesapTipText(h.HesapTipi))</option>
                                        }
                                    </InputSelect>
                                    <small class="text-muted">Personele geri ödeme yapılacak banka/kasa hesabı. Seçilirse Banka/Kasa hareketine otomatik aktarılır.</small>
                                </div>
                            </div>
                            <div class="col-md-6" style="display:@(odemeTipi == "Cari" ? "block" : "none")">
                                <div class="mb-3">
                                    <label class="form-label">Cari</label>
                                    <InputSelect TValue="int?" @bind-Value="masraf.CariId" class="form-select">
                                        <option value="">-- Cari Seçiniz --</option>
                                        @foreach (var cari in cariler)
                                        {
                                            <option value="@cari.Id">@cari.Unvan (@cari.CariKodu)</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <h6 class="card-title text-warning"><i class="bi bi-exclamation-triangle me-2"></i>Arıza Kaynaklı Masraf</h6>
                        <p class="small text-muted">Araç arızası nedeniyle personel ulaşımı (taksi, toplu taşıma vb.) masrafları için bu bölümü kullanın.</p>

                        <div class="form-check mb-3">
                            <InputCheckbox @bind-Value="masraf.ArizaKaynaklimi" class="form-check-input" id="arizaKaynakli" />
                            <label class="form-check-label" for="arizaKaynakli">Bu masraf arıza nedeniyle oluştu</label>
                        </div>

                        @if (masraf.ArizaKaynaklimi)
                        {
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Güzergah</label>
                                        <InputSelect @bind-Value="masraf.GuzergahId" class="form-select">
                                            <option value="">-- Güzergah Seçiniz --</option>
                                            @foreach (var guzergah in guzergahlar)
                                            {
                                                <option value="@guzergah.Id">@guzergah.GuzergahAdi (@guzergah.Cari?.Unvan)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">İlgili Servis Çalışması</label>
                                        <InputSelect @bind-Value="masraf.ServisCalismaId" class="form-select">
                                            <option value="">-- Servis Çalışması Seçiniz --</option>
                                            @foreach (var calisma in servisCalismalar)
                                            {
                                                <option value="@calisma.Id">@calisma.CalismaTarihi.ToString("dd.MM.yyyy") - @calisma.Arac?.AktifPlaka - @calisma.Guzergah?.GuzergahAdi</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Açıklama</label>
                    <InputTextArea @bind-Value="masraf.Aciklama" class="form-control" rows="3" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    [SupplyParameterFromQuery]
    public string? odemeTipiQuery { get; set; }

    [SupplyParameterFromQuery]
    public int? soforId { get; set; }

    [SupplyParameterFromQuery]
    public int? aracId { get; set; }

    private AracMasraf masraf = new();
    private List<Arac> araclar = new();
    private List<Arac> filtreliAraclar = new();
    private List<MasrafKalemi> masrafKalemleri = new();
    private List<Guzergah> guzergahlar = new();
    private List<ServisCalisma> servisCalismalar = new();
    private List<Sofor> soforler = new();
    private List<Cari> cariler = new();
    private List<BankaHesap> hesaplar = new();
    private string odemeTipi = "Kasa";
    private bool muhasebeFisiOlustur = true;
    private bool IsEdit => Id.HasValue;
    private string plakaArama = string.Empty;
    private bool plakaDropAcik = false;

    private string PageTitleText => IsEdit 
        ? (odemeTipi == "Personel" ? "Personel Cebinden Masrafı Düzenle" : "Masraf Düzenle")
        : (odemeTipi == "Personel" ? "Yeni Personel Cebinden Masrafı" : "Yeni Araç Masrafı");

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetActiveAsync();
        filtreliAraclar = araclar;
        masrafKalemleri = await MasrafKalemiService.GetActiveAsync();
        guzergahlar = await GuzergahService.GetActiveAsync();
        soforler = await SoforService.GetActiveAsync();
        cariler = await CariService.GetAllAsync();
        hesaplar = await BankaHesapService.GetActiveAsync();

        var endDate = DateTime.Today;
        var startDate = endDate.AddDays(-30);
        servisCalismalar = await ServisCalismaService.GetByDateRangeAsync(startDate, endDate);

        // Apply query parameters if present (yeni giriş ise ön-doldur)
        if (!IsEdit)
        {
            if (!string.IsNullOrEmpty(odemeTipiQuery))
                odemeTipi = odemeTipiQuery;

            if (soforId.HasValue && odemeTipi == "Personel")
                masraf.SoforId = soforId.Value;

            if (aracId.HasValue)
                masraf.AracId = aracId.Value;

            masraf.MasrafTarihi = DateTime.Today;
        }
        else
        {
            var existing = await AracMasrafService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                masraf = existing;
                muhasebeFisiOlustur = masraf.MuhasebeFisId.HasValue;
                odemeTipi = masraf.SoforId.HasValue ? "Personel" : masraf.CariId.HasValue ? "Cari" : "Kasa";
                var seciliArac = araclar.FirstOrDefault(a => a.Id == masraf.AracId);
                if (seciliArac != null) plakaArama = $"{seciliArac.AktifPlaka} - {seciliArac.Marka} {seciliArac.Model}";
            }
            else
            {
                Navigation.NavigateTo("/bakim-onarim");
            }
        }

        // Update plaka display if aracId is set
        if (masraf.AracId > 0)
        {
            var seciliArac = araclar.FirstOrDefault(a => a.Id == masraf.AracId);
            if (seciliArac != null)
                plakaArama = $"{seciliArac.AktifPlaka} - {seciliArac.Marka} {seciliArac.Model}";
        }
    }

    private void PlakaFiltrele(ChangeEventArgs e)
    {
        plakaArama = e.Value?.ToString() ?? string.Empty;
        masraf.AracId = 0;
        plakaDropAcik = true;
        var ara = plakaArama.Trim().ToLowerInvariant();
        filtreliAraclar = string.IsNullOrEmpty(ara)
            ? araclar
            : araclar.Where(a =>
                (a.AktifPlaka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Marka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Model ?? string.Empty).ToLowerInvariant().Contains(ara)).ToList();
    }

    private void AracSec(Arac arac)
    {
        masraf.AracId = arac.Id;
        plakaArama = $"{arac.AktifPlaka} - {arac.Marka} {arac.Model}";
        plakaDropAcik = false;
        filtreliAraclar = araclar;
    }

    private async Task PlakaDropKapat()
    {
        await Task.Delay(150);
        plakaDropAcik = false;
    }

    private void OdemeTipiDegisti(ChangeEventArgs e)
    {
        odemeTipi = e.Value?.ToString() ?? "Kasa";

        if (odemeTipi != "Personel")
            masraf.SoforId = null;

        if (odemeTipi != "Cari")
            masraf.CariId = null;
    }

    private async Task Kaydet()
    {
        if (masraf.AracId == 0 || masraf.MasrafKalemiId == 0 || masraf.Tutar <= 0)
        {
            ToastService.ShowWarning("Araç, masraf kalemi ve tutar bilgisi zorunludur.");
            return;
        }

        masraf.SoforId = odemeTipi == "Personel" ? masraf.SoforId : null;
        masraf.CariId = odemeTipi == "Cari" ? masraf.CariId : null;

        masraf.OdemeKaynak = odemeTipi switch
        {
            "Personel" => MasrafOdemeKaynak.PersonelCebinden,
            _ => MasrafOdemeKaynak.Kasa
        };

        if (odemeTipi == "Personel" && !masraf.SoforId.HasValue)
        {
            ToastService.ShowWarning("Personel cebinden ödeme için personel seçiniz.");
            return;
        }

        if (odemeTipi == "Cari" && !masraf.CariId.HasValue)
        {
            ToastService.ShowWarning("Cari cebinden ödeme için cari seçiniz.");
            return;
        }

        if (masraf.SoforId.HasValue && masraf.CariId.HasValue)
        {
            ToastService.ShowWarning("Aynı masraf için hem personel hem cari seçilemez.");
            return;
        }

        try
        {
            if (IsEdit)
            {
                await AracMasrafService.UpdateAsync(masraf, muhasebeFisiOlustur);
                ToastService.ShowSuccess(muhasebeFisiOlustur
                    ? "Masraf kaydı ve muhasebe fişi güncellendi."
                    : "Masraf kaydı güncellendi.");
            }
            else
            {
                await AracMasrafService.CreateAsync(masraf, muhasebeFisiOlustur);
                ToastService.ShowSuccess(muhasebeFisiOlustur
                    ? "Masraf kaydı ve muhasebe fişi oluşturuldu."
                    : "Masraf kaydı oluşturuldu.");
            }

            Navigation.NavigateTo("/bakim-onarim");
        }
        catch (Exception ex)
        {
            var detay = ex.InnerException?.Message;
            ToastService.ShowError($"Hata: {ex.Message}{(string.IsNullOrWhiteSpace(detay) ? string.Empty : $" - {detay}")}");
        }
    }

    private void Geri()
    {
        Navigation.NavigateTo("/bakim-onarim");
    }

    private string GetKategoriText(MasrafKategori kategori) => kategori switch
    {
        MasrafKategori.Yakit => "Yakıt",
        MasrafKategori.Bakim => "Bakım",
        MasrafKategori.Tamir => "Tamir",
        MasrafKategori.Sigorta => "Sigorta",
        MasrafKategori.Vergi => "Vergi",
        MasrafKategori.Personel => "Personel Ulaşım",
        MasrafKategori.Lastik => "Lastik",
        MasrafKategori.YedekParca => "Yedek Parça",
        MasrafKategori.Diger => "Diğer",
        _ => kategori.ToString()
    };

    private string GetHesapTipText(HesapTipi tip) => tip switch
    {
        HesapTipi.Kasa => "Kasa",
        HesapTipi.VadesizHesap => "Vadesiz",
        HesapTipi.VadeliHesap => "Vadeli",
        HesapTipi.KrediHesabi => "Kredi",
        HesapTipi.KrediKarti => "Kredi Kartı",
        _ => tip.ToString()
    };
}

