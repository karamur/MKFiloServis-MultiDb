@page "/"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IPortalProjectCatalogService PortalProjectCatalogService
@inject NavigationManager Navigation

<PageTitle>@catalog.Content.BrowserTitle</PageTitle>

<div class="portal-page">
    <section class="topbar-section">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-3 py-2">
            <div class="topbar-items">
                <span><i class="bi bi-envelope me-2"></i>@catalog.SupportEmail</span>
                <span><i class="bi bi-telephone me-2"></i>@catalog.SupportPhone</span>
            </div>
            <div class="topbar-items text-lg-end">
                <span><i class="bi bi-clock-history me-2"></i>@catalog.TopbarMessage</span>
            </div>
        </div>
    </section>

    <section class="hero-section">
        <div class="hero-overlay"></div>
        <div class="container position-relative">
            <div class="hero-nav d-flex flex-wrap justify-content-between align-items-center gap-3 mb-5">
                <div class="d-flex align-items-center gap-3 text-white">
                    <div class="brand-mark"><i class="bi bi-buildings"></i></div>
                    <div>
                        <div class="fw-bold fs-5">@catalog.CompanyName</div>
                        <small class="text-white-50">@catalog.Content.BrandTagline</small>
                    </div>
                </div>
                <div class="hero-nav-links">
                    <a href="#about">@catalog.Content.Navigation.AboutText</a>
                    <a href="#services">@catalog.Content.Navigation.ServicesText</a>
                    <a href="#projects">@catalog.Content.Navigation.ProjectsText</a>
                    <a href="#contact">@catalog.Content.Navigation.ContactText</a>
                </div>
            </div>
            <div class="row align-items-center g-5">
                <div class="col-lg-6 text-white">
                    <span class="hero-badge">@catalog.Content.Hero.BadgeText</span>
                    <h1>@catalog.Content.Hero.Title</h1>
                    <p class="hero-subtitle">@catalog.Content.Hero.Subtitle</p>
                    <div class="hero-actions">
                        <button class="btn btn-light btn-lg" @onclick="OpenDefaultProject">
                            <i class="bi bi-box-arrow-in-right me-2"></i>@catalog.Content.Hero.PrimaryButtonText
                        </button>
                        <a class="btn btn-outline-light btn-lg" href="#contact">
                            <i class="bi bi-chat-dots me-2"></i>@catalog.Content.Hero.SecondaryButtonText
                        </a>
                    </div>
                    <div class="hero-list">
                        @foreach (var item in catalog.Content.Hero.Highlights)
                        {
                            <div class="hero-list-item">
                                <i class="bi bi-check2-circle"></i>
                                <span>@item</span>
                            </div>
                        }
                    </div>
                    <div class="hero-stats">
                        @foreach (var stat in catalog.Content.Hero.Stats)
                        {
                            <div class="hero-stat">
                                <strong>@stat.Value</strong>
                                <span>@stat.Label</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="hero-panel card border-0 shadow-lg">
                        <div class="card-body p-4 p-xl-5">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div>
                                    <div class="small text-uppercase text-muted fw-semibold">@catalog.Content.Hero.FlowEyebrow</div>
                                    <h3 class="mb-0">@catalog.Content.Hero.FlowTitle</h3>
                                </div>
                                <i class="bi bi-diagram-3-fill fs-1 text-primary"></i>
                            </div>
                            @for (var i = 0; i < catalog.Content.Hero.FlowSteps.Count; i++)
                            {
                                var step = catalog.Content.Hero.FlowSteps[i];
                                <div class="flow-step @(i == catalog.Content.Hero.FlowSteps.Count - 1 ? "mb-0" : string.Empty)">
                                    <span>@step.Number</span>
                                    <div>
                                        <h5>@step.Title</h5>
                                        <p>@step.Description</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="about-section section-shell">
        <div class="container">
            <div class="row align-items-center g-4 g-xl-5">
                <div class="col-lg-6">
                    <span class="section-tag">@catalog.Content.About.Tag</span>
                    <h2 class="section-title">@catalog.Content.About.Title</h2>
                    <p class="section-text">@catalog.Content.About.Description</p>
                    <div class="about-grid">
                        @foreach (var item in catalog.Content.About.Cards)
                        {
                            <div class="about-card">
                                <div class="about-icon"><i class="@item.Icon"></i></div>
                                <div>
                                    <h5>@item.Title</h5>
                                    <p>@item.Description</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="about-panel card border-0 shadow-sm">
                        <div class="card-body p-4 p-xl-5">
                            <div class="mini-caption">@catalog.Content.About.PanelTitle</div>
                            <div class="feature-stack">
                                @foreach (var feature in catalog.Content.About.Features)
                                {
                                    <div class="feature-item">
                                        <div class="feature-badge"><i class="bi bi-check-lg"></i></div>
                                        <div>
                                            <h5>@feature.Title</h5>
                                            <p>@feature.Description</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="services-section section-shell">
        <div class="container">
            <div class="section-header text-center">
                <span class="section-tag">@catalog.Content.Services.Tag</span>
                <h2>@catalog.Content.Services.Title</h2>
                <p>@catalog.Content.Services.Description</p>
            </div>

            <div class="row g-4">
                @foreach (var service in catalog.Content.Services.Cards)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="service-card card h-100 border-0 shadow-sm">
                            <div class="card-body p-4">
                                <div class="service-icon"><i class="@service.Icon"></i></div>
                                <h4>@service.Title</h4>
                                <p>@service.Description</p>
                                <ul>
                                    @foreach (var bullet in service.Bullets)
                                    {
                                        <li>@bullet</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="projects" class="projects-section">
        <div class="container">
            <div class="section-header text-center">
                <span class="section-tag">@catalog.Content.Projects.Tag</span>
                <h2>@catalog.Content.Projects.Title</h2>
                <p>@catalog.Content.Projects.Description</p>
            </div>

            <div class="row g-4">
                @foreach (var project in projects)
                {
                    <div class="col-lg-6">
                        <div class="project-card card h-100 border-0 shadow-sm">
                            <div class="card-body p-4 p-xl-5">
                                <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
                                    <div class="project-icon" style="background:@project.ThemeColor;">
                                        <i class="@project.Icon"></i>
                                    </div>
                                    <span class="project-status @(project.LoginEnabled ? "active" : "passive")">
                                        @(project.LoginEnabled ? catalog.Content.Projects.ReadyBadgeText : catalog.Content.Projects.SoonBadgeText)
                                    </span>
                                </div>

                                <div class="mb-3">
                                    <div class="text-uppercase small fw-semibold text-muted mb-2">@project.Category</div>
                                    <h3 class="mb-2">@project.Name</h3>
                                    <p class="text-muted mb-0">@project.Subtitle</p>
                                </div>

                                <p class="project-description">@project.Description</p>

                                <ul class="project-highlights">
                                    @foreach (var highlight in project.Highlights)
                                    {
                                        <li><i class="bi bi-check2-circle"></i>@highlight</li>
                                    }
                                </ul>

                                <div class="mt-4">
                                    @if (project.LoginEnabled)
                                    {
                                        <button class="btn btn-primary w-100" @onclick="() => OpenProject(project)">
                                            <i class="bi bi-arrow-right-circle me-2"></i>@catalog.Content.Projects.OpenButtonText
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary w-100" disabled>
                                            <i class="bi bi-hourglass-split me-2"></i>@catalog.Content.Projects.SoonButtonText
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="team-section section-shell">
        <div class="container">
            <div class="section-header text-center">
                <span class="section-tag">@catalog.Content.Team.Tag</span>
                <h2>@catalog.Content.Team.Title</h2>
                <p>@catalog.Content.Team.Description</p>
            </div>

            <div class="row g-4">
                @foreach (var member in catalog.Content.Team.Members)
                {
                    <div class="col-md-6 col-xl-3">
                        <div class="team-card card border-0 shadow-sm h-100">
                            <div class="card-body p-4 text-center">
                                <div class="team-avatar">@member.Initials</div>
                                <h5 class="mb-1">@member.Name</h5>
                                <div class="text-primary fw-semibold mb-3">@member.Role</div>
                                <p class="text-muted mb-0">@member.Description</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="contact" class="contact-section section-shell">
        <div class="container">
            <div class="contact-panel card border-0 shadow-lg overflow-hidden">
                <div class="row g-0">
                    <div class="col-lg-5 contact-side text-white p-4 p-xl-5">
                        <span class="section-tag section-tag-light">@catalog.Content.Contact.Tag</span>
                        <h2>@catalog.Content.Contact.Title</h2>
                        <p>@catalog.Content.Contact.Description</p>
                        <div class="contact-items">
                            <div><i class="bi bi-telephone"></i><span>@catalog.SupportPhone</span></div>
                            <div><i class="bi bi-envelope"></i><span>@catalog.SupportEmail</span></div>
                            <div><i class="bi bi-geo-alt"></i><span>@catalog.SupportLocation</span></div>
                        </div>
                    </div>
                    <div class="col-lg-7 p-4 p-xl-5 bg-white">
                        <div class="row g-3">
                            @foreach (var cta in catalog.Content.Contact.Cards)
                            {
                                <div class="col-md-6">
                                    <div class="contact-card h-100">
                                        <div class="contact-card-icon"><i class="@cta.Icon"></i></div>
                                        <h5>@cta.Title</h5>
                                        <p>@cta.Description</p>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-4 d-flex flex-wrap gap-3">
                            <button class="btn btn-primary btn-lg" @onclick="OpenDefaultProject">
                                <i class="bi bi-box-arrow-in-right me-2"></i>@catalog.Content.Contact.PrimaryButtonText
                            </button>
                            <a class="btn btn-outline-primary btn-lg" href="@catalog.Content.Contact.SecondaryButtonUrl">
                                <i class="bi bi-send me-2"></i>@catalog.Content.Contact.SecondaryButtonText
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private PortalProjectCatalogOptions catalog = new();
    private IReadOnlyList<PortalProjectDefinition> projects = Array.Empty<PortalProjectDefinition>();

    protected override void OnInitialized()
    {
        catalog = PortalProjectCatalogService.GetCatalog();

        if (!catalog.LandingPageEnabled)
        {
            OpenDefaultProject();
            return;
        }

        projects = PortalProjectCatalogService.GetProjects();
    }

    private void OpenDefaultProject()
    {
        OpenProject(PortalProjectCatalogService.GetDefaultProject());
    }

    private void OpenProject(PortalProjectDefinition project)
    {
        Navigation.NavigateTo($"/login?project={Uri.EscapeDataString(project.Slug)}");
    }
}

<style>
    .portal-page {
        min-height: 100vh;
        background: #f5f8fc;
        color: #11213b;
    }

    .topbar-section {
        background: #07162d;
        color: rgba(255,255,255,.86);
        font-size: .92rem;
    }

    .topbar-items {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
    }

    .topbar-items span {
        display: inline-flex;
        align-items: center;
    }

    .hero-section {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #091a35 0%, #173564 45%, #2a5298 100%);
        padding: 5rem 0 4rem;
    }

    .hero-nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
    }

    .hero-nav-links a {
        color: rgba(255,255,255,.82);
        text-decoration: none;
        font-weight: 600;
    }

    .hero-nav-links a:hover {
        color: #fff;
    }

    .brand-mark {
        width: 3.1rem;
        height: 3.1rem;
        border-radius: 1rem;
        background: rgba(255,255,255,.16);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.12);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(255,255,255,.18), transparent 30%), radial-gradient(circle at bottom left, rgba(255,255,255,.12), transparent 25%);
    }

    .hero-badge, .section-tag {
        display: inline-flex;
        padding: .45rem .9rem;
        border-radius: 999px;
        font-size: .8rem;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .hero-badge {
        margin-bottom: 1rem;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
    }

    .hero-section h1 {
        font-size: clamp(2.4rem, 4vw, 4.5rem);
        font-weight: 800;
        line-height: 1.05;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        max-width: 40rem;
        color: rgba(255,255,255,.85);
        margin-bottom: 2rem;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .hero-list {
        display: grid;
        gap: .85rem;
        margin-bottom: 2rem;
    }

    .hero-list-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        color: rgba(255,255,255,.9);
    }

    .hero-list-item i {
        color: #8ad3b0;
    }

    .hero-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .hero-stat {
        min-width: 130px;
        padding: 1rem 1.2rem;
        border-radius: 1rem;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.14);
        backdrop-filter: blur(12px);
    }

    .hero-stat strong {
        display: block;
        font-size: 1.4rem;
    }

    .hero-stat span {
        color: rgba(255,255,255,.75);
        font-size: .95rem;
    }

    .hero-panel {
        border-radius: 1.5rem;
    }

    .flow-step {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid rgba(17,33,59,.08);
    }

    .flow-step span {
        width: 3rem;
        height: 3rem;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: rgba(42,82,152,.12);
        color: #2a5298;
        font-weight: 800;
    }

    .flow-step h5 {
        margin-bottom: .35rem;
        font-weight: 700;
    }

    .flow-step p {
        margin-bottom: 0;
        color: #5f6f86;
    }

    .projects-section {
        padding: 4.5rem 0 5rem;
    }

    .section-shell {
        padding: 5rem 0;
    }

    .section-title {
        font-size: clamp(2rem, 3vw, 3rem);
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .section-text {
        color: #52657e;
        font-size: 1.05rem;
        margin-bottom: 1.75rem;
    }

    .mini-caption {
        text-transform: uppercase;
        letter-spacing: .08em;
        font-size: .8rem;
        font-weight: 700;
        color: #2a5298;
        margin-bottom: 1rem;
    }

    .about-grid,
    .feature-stack,
    .contact-items {
        display: grid;
        gap: 1rem;
    }

    .about-card,
    .feature-item,
    .contact-card {
        background: #fff;
        border-radius: 1.25rem;
        padding: 1.15rem 1.2rem;
        box-shadow: 0 18px 45px rgba(17,33,59,.08);
    }

    .about-card,
    .feature-item {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .about-card h5,
    .feature-item h5,
    .service-card h4,
    .contact-card h5 {
        font-weight: 700;
        margin-bottom: .45rem;
    }

    .about-card p,
    .feature-item p,
    .service-card p,
    .contact-card p {
        color: #566982;
        margin-bottom: 0;
    }

    .about-icon,
    .feature-badge,
    .service-icon,
    .contact-card-icon,
    .team-avatar {
        width: 3rem;
        height: 3rem;
        border-radius: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .about-icon,
    .service-icon,
    .contact-card-icon {
        background: rgba(42,82,152,.12);
        color: #2a5298;
        font-size: 1.2rem;
    }

    .feature-badge {
        background: rgba(25,135,84,.12);
        color: #198754;
    }

    .about-panel,
    .contact-panel,
    .team-card,
    .service-card {
        border-radius: 1.5rem;
    }

    .service-card ul {
        margin: 1rem 0 0;
        padding-left: 1rem;
        color: #11213b;
    }

    .service-card li + li {
        margin-top: .45rem;
    }

    .team-avatar {
        margin: 0 auto 1rem;
        width: 4.25rem;
        height: 4.25rem;
        border-radius: 50%;
        background: linear-gradient(135deg, #173564, #2a5298);
        color: #fff;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .contact-side {
        background: linear-gradient(160deg, #11213b 0%, #21457d 100%);
    }

    .section-tag-light {
        background: rgba(255,255,255,.14);
        color: #fff;
        margin-bottom: 1rem;
    }

    .contact-items div {
        display: flex;
        gap: .8rem;
        align-items: center;
    }

    .contact-items i {
        font-size: 1.1rem;
    }

    .section-header {
        max-width: 52rem;
        margin: 0 auto 2.5rem;
    }

    .section-tag {
        margin-bottom: 1rem;
        background: rgba(42,82,152,.1);
        color: #2a5298;
    }

    .section-header h2 {
        font-size: clamp(2rem, 3vw, 3rem);
        font-weight: 800;
        margin-bottom: .75rem;
    }

    .section-header p {
        color: #5f6f86;
        font-size: 1.05rem;
    }

    .project-card {
        border-radius: 1.5rem;
    }

    .project-icon {
        width: 4rem;
        height: 4rem;
        border-radius: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.5rem;
        box-shadow: 0 18px 36px rgba(17,33,59,.14);
    }

    .project-status {
        padding: .4rem .8rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .project-status.active {
        background: rgba(25,135,84,.12);
        color: #198754;
    }

    .project-status.passive {
        background: rgba(108,117,125,.14);
        color: #5c636a;
    }

    .project-description {
        color: #4f617a;
        margin-bottom: 1.2rem;
    }

    .project-highlights {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: .75rem;
    }

    .project-highlights li {
        display: flex;
        align-items: center;
        gap: .6rem;
        color: #11213b;
        font-weight: 500;
    }

    .project-highlights i {
        color: #198754;
    }

    @@media (max-width: 991.98px) {
        .hero-section {
            padding-top: 4rem;
        }

        .hero-nav-links {
            width: 100%;
            justify-content: flex-start;
        }
    }
</style>

