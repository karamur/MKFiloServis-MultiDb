@page "/ebys/giden"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IEbysEvrakService EvrakService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Giden Evraklar - EBYS</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-send me-2 text-success"></i>Giden Evraklar</h3>
            <small class="text-muted">Dışarıya gönderilen yazışmalar ve evraklar</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="YeniEvrakAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Giden Evrak
            </button>
            <a href="/ebys/gelen" class="btn btn-outline-secondary">
                <i class="bi bi-inbox me-1"></i>Gelen Evraklar
            </a>
        </div>
    </div>

    @* Filtre Kartı *@
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtre.AramaMetni" @bind:event="oninput" placeholder="Evrak no, konu, kurum..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filtre.KategoriId">
                        <option value="">Tümü</option>
                        @foreach (var kat in kategoriler)
                        {
                            <option value="@kat.Id">@kat.KategoriAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tümü</option>
                        <option value="Taslak">Taslak</option>
                        <option value="Beklemede">Beklemede</option>
                        <option value="Isleniyor">Gönderim Bekliyor</option>
                        <option value="Tamamlandi">Gönderildi</option>
                        <option value="Arsivlendi">Arşivlendi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtre.BaslangicTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtre.BitisTarihi" />
                </div>
                <div class="col-md-1">
                    <button class="btn btn-sm btn-success w-100" @onclick="FiltreleAsync">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* İstatistik Kartları *@
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card border-0 bg-success bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-success">Toplam Giden</h6>
                            <h3 class="mb-0">@istatistik.ToplamGiden</h3>
                        </div>
                        <i class="bi bi-send fs-1 text-success opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-warning">Gönderim Bekleyen</h6>
                            <h3 class="mb-0">@istatistik.BekleyenGiden</h3>
                        </div>
                        <i class="bi bi-hourglass-split fs-1 text-warning opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-info bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-info">Bugün Gönderilen</h6>
                            <h3 class="mb-0">@istatistik.BugunGidenSayisi</h3>
                        </div>
                        <i class="bi bi-calendar-check fs-1 text-info opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-secondary bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-secondary">Bu Ay</h6>
                            <h3 class="mb-0">@evraklar.Count(e => e.EvrakTarihi.Month == DateTime.Now.Month)</h3>
                        </div>
                        <i class="bi bi-calendar-month fs-1 text-secondary opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Evrak Listesi *@
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:120px">Evrak No</th>
                        <th style="width:100px">Tarih</th>
                        <th>Konu</th>
                        <th style="width:150px">Alıcı Kurum</th>
                        <th style="width:100px">Gönderim</th>
                        <th style="width:100px">Öncelik</th>
                        <th style="width:110px">Durum</th>
                        <th style="width:80px">Dosya</th>
                        <th style="width:100px">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (evraklar.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-send fs-1 d-block mb-2"></i>
                                Giden evrak bulunamadı
                            </td>
                        </tr>
                    }
                    @foreach (var evrak in evraklar)
                    {
                        <tr>
                            <td>
                                <a href="/ebys/evrak/@evrak.Id" class="text-decoration-none fw-medium">
                                    @evrak.EvrakNo
                                </a>
                            </td>
                            <td>@evrak.EvrakTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width:250px" title="@evrak.Konu">
                                    @evrak.Konu
                                </span>
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width:140px" title="@evrak.AliciKurum">
                                    @evrak.AliciKurum
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">
                                    <i class="bi @GonderimIkon(evrak.GonderimYontemi) me-1"></i>
                                    @GonderimAdi(evrak.GonderimYontemi)
                                </span>
                            </td>
                            <td>
                                <span class="badge @OncelikRenk(evrak.Oncelik)">
                                    @OncelikAdi(evrak.Oncelik)
                                </span>
                            </td>
                            <td>
                                <span class="badge @DurumRenk(evrak.Durum)">
                                    @DurumAdi(evrak.Durum)
                                </span>
                            </td>
                            <td class="text-center">
                                @if (evrak.Dosyalar?.Count > 0)
                                {
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-paperclip"></i> @evrak.Dosyalar.Count
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/ebys/evrak/@evrak.Id" class="btn btn-outline-success" title="Detay">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-outline-primary" @onclick="() => GonderAsync(evrak)" title="Gönder" disabled="@(evrak.Durum == EbysEvrakDurum.Tamamlandi)">
                                        <i class="bi bi-send"></i>
                                    </button>
                                    <button class="btn btn-outline-danger" @onclick="() => SilAsync(evrak.Id)" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Yeni Evrak Modal *@
@if (showYeniEvrakModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Yeni Giden Evrak</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Evrak Tarihi <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" @bind="yeniEvrak.EvrakTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Gönderim Tarihi</label>
                            <input type="date" class="form-control" @bind="yeniEvrak.GonderimTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Alıcı Kurum <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="yeniEvrak.AliciKurum" placeholder="Örn: Ankara Büyükşehir Belediyesi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Gönderim Yöntemi</label>
                            <select class="form-select" @bind="yeniEvrak.GonderimYontemi">
                                <option value="@GonderimYontemi.Elden">Elden</option>
                                <option value="@GonderimYontemi.Posta">Posta</option>
                                <option value="@GonderimYontemi.Kargo">Kargo</option>
                                <option value="@GonderimYontemi.Email">E-Posta</option>
                                <option value="@GonderimYontemi.Faks">Faks</option>
                                <option value="@GonderimYontemi.KEP">KEP</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Konu <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="yeniEvrak.Konu" placeholder="Evrak konusu" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Özet</label>
                            <textarea class="form-control" rows="2" @bind="yeniEvrak.Ozet" placeholder="Evrak özeti (isteğe bağlı)"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Kategori</label>
                            <select class="form-select" @bind="yeniEvrak.KategoriId">
                                <option value="">Seçiniz</option>
                                @foreach (var kat in kategoriler)
                                {
                                    <option value="@kat.Id">@kat.KategoriAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Öncelik</label>
                            <select class="form-select" @bind="yeniEvrak.Oncelik">
                                <option value="@EvrakOncelik.Dusuk">Düşük</option>
                                <option value="@EvrakOncelik.Normal">Normal</option>
                                <option value="@EvrakOncelik.Yuksek">Yüksek</option>
                                <option value="@EvrakOncelik.Acil">Acil</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Gizlilik</label>
                            <select class="form-select" @bind="yeniEvrak.Gizlilik">
                                <option value="@EvrakGizlilik.Normal">Normal</option>
                                <option value="@EvrakGizlilik.Gizli">Gizli</option>
                                <option value="@EvrakGizlilik.CokGizli">Çok Gizli</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama/Notlar</label>
                            <textarea class="form-control" rows="2" @bind="yeniEvrak.Aciklama"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-outline-success" @onclick="() => EvrakKaydetAsync(true)" disabled="@isLoading">
                        <i class="bi bi-file-earmark me-1"></i>Taslak Kaydet
                    </button>
                    <button type="button" class="btn btn-success" @onclick="() => EvrakKaydetAsync(false)" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-circle me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<EbysEvrak> evraklar = new();
    private List<EbysEvrakKategori> kategoriler = new();
    private EbysEvrakFiltre filtre = new() { Yon = EvrakYonu.Giden };
    private EbysEvrakIstatistik istatistik = new();
    private EbysEvrakOlusturModel yeniEvrak = new() { Yon = EvrakYonu.Giden };
    private string? filtreDurum;
    private bool showYeniEvrakModal;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        kategoriler = await EvrakService.GetKategorilerAsync();
        istatistik = await EvrakService.GetIstatistiklerAsync();
        await FiltreleAsync();
    }

    private async Task FiltreleAsync()
    {
        if (!string.IsNullOrEmpty(filtreDurum) && Enum.TryParse<EbysEvrakDurum>(filtreDurum, out var durum))
            filtre.Durum = durum;
        else
            filtre.Durum = null;

        evraklar = await EvrakService.GetEvraklarAsync(filtre);
    }

    private void YeniEvrakAc()
    {
        yeniEvrak = new EbysEvrakOlusturModel
        {
            Yon = EvrakYonu.Giden,
            EvrakTarihi = DateTime.Today,
            GonderimYontemi = GonderimYontemi.Elden,
            Oncelik = EvrakOncelik.Normal,
            Gizlilik = EvrakGizlilik.Normal
        };
        showYeniEvrakModal = true;
    }

    private void ModalKapat()
    {
        showYeniEvrakModal = false;
    }

    private async Task EvrakKaydetAsync(bool taslak = false)
    {
        if (string.IsNullOrWhiteSpace(yeniEvrak.Konu))
        {
            ToastService.ShowWarning("Konu alanı zorunludur");
            return;
        }

        isLoading = true;
        try
        {
            var evrak = await EvrakService.CreateEvrakAsync(yeniEvrak);
            if (taslak)
            {
                await EvrakService.DurumDegistirAsync(evrak.Id, EbysEvrakDurum.Taslak, "Taslak olarak kaydedildi");
            }
            ToastService.ShowSuccess(taslak ? "Evrak taslak olarak kaydedildi" : "Giden evrak başarıyla kaydedildi");
            showYeniEvrakModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GonderAsync(EbysEvrak evrak)
    {
        try
        {
            await EvrakService.DurumDegistirAsync(evrak.Id, EbysEvrakDurum.Tamamlandi, "Evrak gönderildi");
            ToastService.ShowSuccess("Evrak gönderildi olarak işaretlendi");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task SilAsync(int id)
    {
        try
        {
            await EvrakService.DeleteEvrakAsync(id);
            ToastService.ShowSuccess("Evrak silindi");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private static string GonderimIkon(GonderimYontemi yontem) => yontem switch
    {
        GonderimYontemi.Elden => "bi-hand-index",
        GonderimYontemi.Posta => "bi-envelope",
        GonderimYontemi.Kargo => "bi-truck",
        GonderimYontemi.Email => "bi-at",
        GonderimYontemi.Faks => "bi-printer",
        GonderimYontemi.KEP => "bi-shield-check",
        _ => "bi-send"
    };

    private static string GonderimAdi(GonderimYontemi yontem) => yontem switch
    {
        GonderimYontemi.Elden => "Elden",
        GonderimYontemi.Posta => "Posta",
        GonderimYontemi.Kargo => "Kargo",
        GonderimYontemi.Email => "E-Posta",
        GonderimYontemi.Faks => "Faks",
        GonderimYontemi.KEP => "KEP",
        _ => "Bilinmiyor"
    };

    private static string OncelikRenk(EvrakOncelik oncelik) => oncelik switch
    {
        EvrakOncelik.Dusuk => "bg-secondary",
        EvrakOncelik.Normal => "bg-info",
        EvrakOncelik.Yuksek => "bg-warning",
        EvrakOncelik.Acil => "bg-danger",
        _ => "bg-secondary"
    };

    private static string OncelikAdi(EvrakOncelik oncelik) => oncelik switch
    {
        EvrakOncelik.Dusuk => "Düşük",
        EvrakOncelik.Normal => "Normal",
        EvrakOncelik.Yuksek => "Yüksek",
        EvrakOncelik.Acil => "Acil",
        _ => "Bilinmiyor"
    };

    private static string DurumRenk(EbysEvrakDurum durum) => durum switch
    {
        EbysEvrakDurum.Taslak => "bg-secondary",
        EbysEvrakDurum.Beklemede => "bg-warning",
        EbysEvrakDurum.Isleniyor => "bg-info",
        EbysEvrakDurum.Tamamlandi => "bg-success",
        EbysEvrakDurum.Arsivlendi => "bg-dark",
        EbysEvrakDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string DurumAdi(EbysEvrakDurum durum) => durum switch
    {
        EbysEvrakDurum.Taslak => "Taslak",
        EbysEvrakDurum.Beklemede => "Hazırlanıyor",
        EbysEvrakDurum.Isleniyor => "Gön. Bekliyor",
        EbysEvrakDurum.Tamamlandi => "Gönderildi",
        EbysEvrakDurum.Arsivlendi => "Arşivlendi",
        EbysEvrakDurum.IptalEdildi => "İptal",
        _ => "Bilinmiyor"
    };
}

