@page "/ebys/gelen"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IEbysEvrakService EvrakService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Gelen Evraklar - EBYS</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-inbox me-2 text-primary"></i>Gelen Evraklar</h3>
            <small class="text-muted">Dışarıdan gelen yazışmalar ve evraklar</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniEvrakAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Gelen Evrak
            </button>
            <a href="/ebys/giden" class="btn btn-outline-secondary">
                <i class="bi bi-send me-1"></i>Giden Evraklar
            </a>
        </div>
    </div>

    @* Filtre Kartı *@
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtre.AramaMetni" @bind:event="oninput" placeholder="Evrak no, konu, kurum..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filtre.KategoriId">
                        <option value="">Tümü</option>
                        @foreach (var kat in kategoriler)
                        {
                            <option value="@kat.Id">@kat.KategoriAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tümü</option>
                        <option value="Beklemede">Beklemede</option>
                        <option value="Isleniyor">İşleniyor</option>
                        <option value="AtamaBekliyor">Atama Bekliyor</option>
                        <option value="CevapBekliyor">Cevap Bekliyor</option>
                        <option value="Tamamlandi">Tamamlandı</option>
                        <option value="Arsivlendi">Arşivlendi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtre.BaslangicTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtre.BitisTarihi" />
                </div>
                <div class="col-md-1">
                    <button class="btn btn-sm btn-primary w-100" @onclick="FiltreleAsync">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* İstatistik Kartları *@
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card border-0 bg-primary bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-primary">Toplam Gelen</h6>
                            <h3 class="mb-0">@istatistik.ToplamGelen</h3>
                        </div>
                        <i class="bi bi-inbox fs-1 text-primary opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-warning">Bekleyen</h6>
                            <h3 class="mb-0">@istatistik.BekleyenGelen</h3>
                        </div>
                        <i class="bi bi-hourglass-split fs-1 text-warning opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-danger bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-danger">Cevap Bekleyen</h6>
                            <h3 class="mb-0">@istatistik.CevapBekleyen</h3>
                        </div>
                        <i class="bi bi-reply fs-1 text-danger opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-success bg-opacity-10">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-success">Bugün Gelen</h6>
                            <h3 class="mb-0">@istatistik.BugunGelenSayisi</h3>
                        </div>
                        <i class="bi bi-calendar-check fs-1 text-success opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Evrak Listesi *@
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:120px">Evrak No</th>
                        <th style="width:100px">Tarih</th>
                        <th>Konu</th>
                        <th style="width:150px">Gönderen</th>
                        <th style="width:100px">Kategori</th>
                        <th style="width:100px">Öncelik</th>
                        <th style="width:110px">Durum</th>
                        <th style="width:80px">Dosya</th>
                        <th style="width:100px">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (evraklar.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                Gelen evrak bulunamadı
                            </td>
                        </tr>
                    }
                    @foreach (var evrak in evraklar)
                    {
                        <tr class="@(evrak.CevapGerekli && evrak.CevapSuresi < DateTime.Now && evrak.Durum != EbysEvrakDurum.Cevaplandi ? "table-danger" : "")">
                            <td>
                                <a href="/ebys/evrak/@evrak.Id" class="text-decoration-none fw-medium">
                                    @evrak.EvrakNo
                                </a>
                            </td>
                            <td>@evrak.EvrakTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width:250px" title="@evrak.Konu">
                                    @evrak.Konu
                                </span>
                                @if (evrak.CevapGerekli)
                                {
                                    <i class="bi bi-reply-fill text-warning ms-1" title="Cevap gerekli"></i>
                                }
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width:140px" title="@evrak.GonderenKurum">
                                    @evrak.GonderenKurum
                                </span>
                            </td>
                            <td>
                                @if (evrak.Kategori != null)
                                {
                                    <span class="badge" style="background-color:@evrak.Kategori.Renk">
                                        @evrak.Kategori.KategoriAdi
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="badge @OncelikRenk(evrak.Oncelik)">
                                    @OncelikAdi(evrak.Oncelik)
                                </span>
                            </td>
                            <td>
                                <span class="badge @DurumRenk(evrak.Durum)">
                                    @DurumAdi(evrak.Durum)
                                </span>
                            </td>
                            <td class="text-center">
                                @if (evrak.Dosyalar?.Count > 0)
                                {
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-paperclip"></i> @evrak.Dosyalar.Count
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/ebys/evrak/@evrak.Id" class="btn btn-outline-primary" title="Detay">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-outline-warning" @onclick="() => AtamaAcAsync(evrak)" title="Ata">
                                        <i class="bi bi-person-plus"></i>
                                    </button>
                                    <button class="btn btn-outline-danger" @onclick="() => SilAsync(evrak.Id)" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Yeni Evrak Modal *@
@if (showYeniEvrakModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Yeni Gelen Evrak</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Evrak Tarihi <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" @bind="yeniEvrak.EvrakTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Geliş Tarihi</label>
                            <input type="date" class="form-control" @bind="yeniEvrak.GelisTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Gönderen Kurum <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="yeniEvrak.GonderenKurum" placeholder="Örn: Türkiye İş Bankası A.Ş." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Geliş Numarası</label>
                            <input type="text" class="form-control" @bind="yeniEvrak.GelisNo" placeholder="Gönderen kurumun evrak no" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Konu <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="yeniEvrak.Konu" placeholder="Evrak konusu" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Özet</label>
                            <textarea class="form-control" rows="2" @bind="yeniEvrak.Ozet" placeholder="Evrak özeti (isteğe bağlı)"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Kategori</label>
                            <select class="form-select" @bind="yeniEvrak.KategoriId">
                                <option value="">Seçiniz</option>
                                @foreach (var kat in kategoriler)
                                {
                                    <option value="@kat.Id">@kat.KategoriAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Öncelik</label>
                            <select class="form-select" @bind="yeniEvrak.Oncelik">
                                <option value="@EvrakOncelik.Dusuk">Düşük</option>
                                <option value="@EvrakOncelik.Normal">Normal</option>
                                <option value="@EvrakOncelik.Yuksek">Yüksek</option>
                                <option value="@EvrakOncelik.Acil">Acil</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Gizlilik</label>
                            <select class="form-select" @bind="yeniEvrak.Gizlilik">
                                <option value="@EvrakGizlilik.Normal">Normal</option>
                                <option value="@EvrakGizlilik.Gizli">Gizli</option>
                                <option value="@EvrakGizlilik.CokGizli">Çok Gizli</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="cevapGerekli" @bind="yeniEvrak.CevapGerekli" />
                                <label class="form-check-label" for="cevapGerekli">Cevap Gerekli</label>
                            </div>
                        </div>
                        @if (yeniEvrak.CevapGerekli)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Cevap Son Tarihi</label>
                                <input type="date" class="form-control" @bind="yeniEvrak.CevapSuresi" />
                            </div>
                        }
                        <div class="col-12">
                            <label class="form-label">Açıklama/Notlar</label>
                            <textarea class="form-control" rows="2" @bind="yeniEvrak.Aciklama"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="EvrakKaydetAsync" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-circle me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<EbysEvrak> evraklar = new();
    private List<EbysEvrakKategori> kategoriler = new();
    private EbysEvrakFiltre filtre = new() { Yon = EvrakYonu.Gelen };
    private EbysEvrakIstatistik istatistik = new();
    private EbysEvrakOlusturModel yeniEvrak = new() { Yon = EvrakYonu.Gelen };
    private string? filtreDurum;
    private bool showYeniEvrakModal;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        kategoriler = await EvrakService.GetKategorilerAsync();
        istatistik = await EvrakService.GetIstatistiklerAsync();
        await FiltreleAsync();
    }

    private async Task FiltreleAsync()
    {
        if (!string.IsNullOrEmpty(filtreDurum) && Enum.TryParse<EbysEvrakDurum>(filtreDurum, out var durum))
            filtre.Durum = durum;
        else
            filtre.Durum = null;

        evraklar = await EvrakService.GetEvraklarAsync(filtre);
    }

    private void YeniEvrakAc()
    {
        yeniEvrak = new EbysEvrakOlusturModel
        {
            Yon = EvrakYonu.Gelen,
            EvrakTarihi = DateTime.Today,
            GelisTarihi = DateTime.Today,
            Oncelik = EvrakOncelik.Normal,
            Gizlilik = EvrakGizlilik.Normal
        };
        showYeniEvrakModal = true;
    }

    private void ModalKapat()
    {
        showYeniEvrakModal = false;
    }

    private async Task EvrakKaydetAsync()
    {
        if (string.IsNullOrWhiteSpace(yeniEvrak.Konu))
        {
            ToastService.ShowWarning("Konu alanı zorunludur");
            return;
        }

        isLoading = true;
        try
        {
            await EvrakService.CreateEvrakAsync(yeniEvrak);
            ToastService.ShowSuccess("Gelen evrak başarıyla kaydedildi");
            showYeniEvrakModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AtamaAcAsync(EbysEvrak evrak)
    {
        Navigation.NavigateTo($"/ebys/evrak/{evrak.Id}?tab=atama");
    }

    private async Task SilAsync(int id)
    {
        try
        {
            await EvrakService.DeleteEvrakAsync(id);
            ToastService.ShowSuccess("Evrak silindi");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private static string OncelikRenk(EvrakOncelik oncelik) => oncelik switch
    {
        EvrakOncelik.Dusuk => "bg-secondary",
        EvrakOncelik.Normal => "bg-info",
        EvrakOncelik.Yuksek => "bg-warning",
        EvrakOncelik.Acil => "bg-danger",
        _ => "bg-secondary"
    };

    private static string OncelikAdi(EvrakOncelik oncelik) => oncelik switch
    {
        EvrakOncelik.Dusuk => "Düşük",
        EvrakOncelik.Normal => "Normal",
        EvrakOncelik.Yuksek => "Yüksek",
        EvrakOncelik.Acil => "Acil",
        _ => "Bilinmiyor"
    };

    private static string DurumRenk(EbysEvrakDurum durum) => durum switch
    {
        EbysEvrakDurum.Taslak => "bg-secondary",
        EbysEvrakDurum.Beklemede => "bg-warning",
        EbysEvrakDurum.Isleniyor => "bg-info",
        EbysEvrakDurum.AtamaBekliyor => "bg-primary",
        EbysEvrakDurum.CevapBekliyor => "bg-danger",
        EbysEvrakDurum.Cevaplandi => "bg-success",
        EbysEvrakDurum.Tamamlandi => "bg-success",
        EbysEvrakDurum.Arsivlendi => "bg-dark",
        EbysEvrakDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string DurumAdi(EbysEvrakDurum durum) => durum switch
    {
        EbysEvrakDurum.Taslak => "Taslak",
        EbysEvrakDurum.Beklemede => "Beklemede",
        EbysEvrakDurum.Isleniyor => "İşleniyor",
        EbysEvrakDurum.AtamaBekliyor => "Atama Bek.",
        EbysEvrakDurum.CevapBekliyor => "Cevap Bek.",
        EbysEvrakDurum.Cevaplandi => "Cevaplandı",
        EbysEvrakDurum.Tamamlandi => "Tamamlandı",
        EbysEvrakDurum.Arsivlendi => "Arşivlendi",
        EbysEvrakDurum.IptalEdildi => "İptal",
        _ => "Bilinmiyor"
    };
}

