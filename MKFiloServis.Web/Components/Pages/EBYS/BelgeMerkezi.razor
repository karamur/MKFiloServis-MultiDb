@page "/ebys"
@using MKFiloServis.Web.Services
@inject IEbysService EbysService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>EBYS Belge Merkezi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-folder2-open me-2"></i>EBYS Belge Merkezi</h3>
            <small class="text-muted">Personel özlük ve araç evrak kayıtlarını tek ekranda izleyin</small>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-primary" @onclick="YeniBelgeAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Belge
            </button>
            <a href="/belge-uyarilari" class="btn btn-outline-warning">
                <i class="bi bi-exclamation-triangle me-1"></i>Belge Uyarıları
            </a>
            <a href="/personel/ozluk-evrak" class="btn btn-outline-primary">
                <i class="bi bi-clipboard-check me-1"></i>Özlük Evrak
            </a>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small mb-1">Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtre.AramaMetni" @bind:event="oninput" placeholder="Belge, kategori, personel, araç ara..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Kaynak</label>
                    <select class="form-select form-select-sm" @bind="filtre.Kaynak">
                        <option value="@EbysBelgeKaynakFiltre.Tumu">Tümü</option>
                        <option value="@EbysBelgeKaynakFiltre.Personel">Personel</option>
                        <option value="@EbysBelgeKaynakFiltre.Arac">Araç</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filtre.Kategori">
                        <option value="">Tüm Kategoriler</option>
                        @foreach (var kategori in kategoriler)
                        {
                            <option value="@kategori">@kategori</option>
                        }

@if (showYeniBelgeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Yeni Belge Kaydı</h5>
                    <button type="button" class="btn-close" @onclick="YeniBelgeKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Kaynak</label>
                            <select class="form-select" @bind="yeniBelge.Kaynak">
                                <option value="@EbysBelgeKaynak.Personel">Personel</option>
                                <option value="@EbysBelgeKaynak.Arac">Araç</option>
                            </select>
                        </div>

                        @if (yeniBelge.Kaynak == EbysBelgeKaynak.Personel)
                        {
                            <div class="col-md-4">
                                <label class="form-label">Personel</label>
                                <select class="form-select" @bind="yeniBelge.IlgiliKayitId">
                                    <option value="">Seçiniz</option>
                                    @foreach (var personel in olusturmaSecenekleri.Personeller)
                                    {
                                        <option value="@personel.Id">@personel.Ad (@personel.Kod)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Evrak Tanımı</label>
                                <select class="form-select" @bind="yeniBelge.EvrakTanimId">
                                    <option value="">Seçiniz</option>
                                    @foreach (var tanim in olusturmaSecenekleri.PersonelEvrakTanimlari)
                                    {
                                        <option value="@tanim.Id">@tanim.Ad (@tanim.Kod)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch mt-4">
                                    <input class="form-check-input" type="checkbox" id="yeniTamamlandi" @bind="yeniBelge.Tamamlandi" />
                                    <label class="form-check-label" for="yeniTamamlandi">Tamamlandı</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Tamamlanma Tarihi</label>
                                <input type="date" class="form-control" @bind="yeniBelge.BelgeTarihi" disabled="@(!yeniBelge.Tamamlandi)" />
                            </div>
                        }
                        else
                        {
                            <div class="col-md-4">
                                <label class="form-label">Araç</label>
                                <select class="form-select" @bind="yeniBelge.IlgiliKayitId">
                                    <option value="">Seçiniz</option>
                                    @foreach (var arac in olusturmaSecenekleri.Araclar)
                                    {
                                        <option value="@arac.Id">@arac.Ad</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Kategori</label>
                                <select class="form-select" @bind="yeniBelge.Kategori">
                                    <option value="">Seçiniz</option>
                                    @foreach (var kategori in olusturmaSecenekleri.AracKategorileri)
                                    {
                                        <option value="@kategori">@kategori</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Belge Adı</label>
                                <input class="form-control" @bind="yeniBelge.BelgeAdi" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Durum</label>
                                <select class="form-select" @bind="yeniBelge.Durum">
                                    <option value="Aktif">Aktif</option>
                                    <option value="Pasif">Pasif</option>
                                    <option value="Süresi Dolmuş">Süresi Dolmuş</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Başlangıç Tarihi</label>
                                <input type="date" class="form-control" @bind="yeniBelge.BelgeTarihi" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Bitiş Tarihi</label>
                                <input type="date" class="form-control" @bind="yeniBelge.BitisTarihi" />
                            </div>
                        }

                        <div class="col-md-12">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" rows="3" @bind="yeniBelge.Aciklama"></textarea>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">İlk Dosya (opsiyonel)</label>
                            <InputFile class="form-control" OnChange="YeniBelgeDosyaSecildi" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                            @if (secilenYeniBelgeDosyasi != null)
                            {
                                <small class="text-muted d-block mt-1">@secilenYeniBelgeDosyasi.Name - @FormatDosyaBoyutu(secilenYeniBelgeDosyasi.Size)</small>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="YeniBelgeKapat">Vazgeç</button>
                    <button type="button" class="btn btn-primary" @onclick="YeniBelgeKaydet" disabled="@isCreating">
                        <i class="bi bi-save me-1"></i>@(isCreating ? "Kaydediliyor..." : "Kaydet")
                    </button>
                </div>
            </div>
        </div>
    </div>
}
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check form-switch mt-4">
                        <input class="form-check-input" type="checkbox" id="sadeceDosyali" @bind="filtre.SadeceDosyasiOlanlar" />
                        <label class="form-check-label small" for="sadeceDosyali">Sadece dosyalı</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Risk</label>
                    <select class="form-select form-select-sm" @bind="filtre.Risk">
                        <option value="@EbysBelgeRiskFiltre.Tumu">Tümü</option>
                        <option value="@EbysBelgeRiskFiltre.Risksiz">Risksiz</option>
                        <option value="@EbysBelgeRiskFiltre.Yaklasan">Yaklaşan</option>
                        <option value="@EbysBelgeRiskFiltre.SuresiDolmus">Süresi Dolmuş</option>
                        <option value="@EbysBelgeRiskFiltre.DosyaEksik">Dosya Eksik</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="d-grid gap-1">
                        <button class="btn btn-primary btn-sm" @onclick="LoadData">
                            <i class="bi bi-search me-1"></i>Filtrele
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreleriTemizle" disabled="@(!FiltreVarMi)">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Temizle
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-light border small py-2 mb-3">
        <i class="bi bi-info-circle me-1 text-primary"></i>
        Aramada örnekler: <span class="fw-semibold">saglik</span>, <span class="fw-semibold">sozlesme</span>, <span class="fw-semibold">dosya eksik</span>, <span class="fw-semibold">personel</span>, <span class="fw-semibold">2025</span>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0">@kayitlar.Count</h3>
                    <small>Toplam Kayıt</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0">@kayitlar.Count(x => x.Kaynak == EbysBelgeKaynak.Personel)</h3>
                    <small>Personel Belgesi</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0">@kayitlar.Count(x => x.Kaynak == EbysBelgeKaynak.Arac)</h3>
                    <small>Araç Evrakı</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0">@kayitlar.Count(x => !x.DosyaVar)</h3>
                    <small>Dosyasız Kayıt</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0">@kayitlar.Count(x => x.SuresiDolmusMu || x.YaklasanMi)</h3>
                    <small>Riskli Belge</small>
                </div>
            </div>
        </div>
    </div>

    @if (kategoriOzetleri.Any())
    {
        <div class="card mb-3">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-tags me-2"></i>Kategori Özeti</strong>
                @if (!string.IsNullOrWhiteSpace(filtre.Kategori))
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="KategoriFiltresiniTemizle">
                        <i class="bi bi-x-circle me-1"></i>Kategori Filtresini Temizle
                    </button>
                }
            </div>
            <div class="card-body">
                <div class="row g-2">
                    @foreach (var kategoriOzet in kategoriOzetleri)
                    {
                        <div class="col-md-4 col-xl-3">
                            <button type="button"
                                    class="btn w-100 text-start border @(filtre.Kategori == kategoriOzet.Kategori ? "btn-primary" : "btn-outline-light text-dark")"
                                    @onclick="() => KategoriFiltrele(kategoriOzet.Kategori)">
                                <div class="fw-semibold">@kategoriOzet.Kategori</div>
                                <div class="small @(filtre.Kategori == kategoriOzet.Kategori ? "text-white-50" : "text-muted")">
                                    Toplam: @kategoriOzet.ToplamKayit | Personel: @kategoriOzet.PersonelSayisi | Araç: @kategoriOzet.AracSayisi
                                </div>
                                <div class="mt-1 d-flex gap-1 flex-wrap">
                                    <span class="badge bg-success">Dosyalı @kategoriOzet.DosyaliKayit</span>
                                    @if (kategoriOzet.RiskliKayit > 0)
                                    {
                                        <span class="badge bg-danger">Riskli @kategoriOzet.RiskliKayit</span>
                                    }
                                </div>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Belgeler yükleniyor...</p>
        </div>
    }
    else if (!kayitlar.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Filtreye uygun belge kaydı bulunamadı.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Kaynak</th>
                                <th>Belge</th>
                                <th>Kategori</th>
                                <th>İlgili Kayıt</th>
                                <th>Durum</th>
                                <th>Risk</th>
                                <th>Dosya</th>
                                <th>Tarih</th>
                                <th style="width: 150px;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kayit in kayitlar)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @(kayit.Kaynak == EbysBelgeKaynak.Personel ? "bg-success" : "bg-info")">
                                            @(kayit.Kaynak == EbysBelgeKaynak.Personel ? "Personel" : "Araç")
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@kayit.BelgeAdi</strong>
                                        @if (!string.IsNullOrWhiteSpace(kayit.Aciklama))
                                        {
                                            <br /><small class="text-muted">@kayit.Aciklama</small>
                                        }
                                    </td>
                                    <td>@kayit.Kategori</td>
                                    <td>
                                        <strong>@kayit.IlgiliKayitAdi</strong>
                                        @if (!string.IsNullOrWhiteSpace(kayit.IlgiliKayitKodu))
                                        {
                                            <br /><small class="text-muted">@kayit.IlgiliKayitKodu</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetDurumBadge(kayit)">@kayit.Durum</span>
                                    </td>
                                    <td>
                                        <span class="badge @GetRiskBadge(kayit)">@kayit.RiskDurumu</span>
                                    </td>
                                    <td>
                                        @if (kayit.DosyaVar)
                                        {
                                            <span class="text-success"><i class="bi bi-check-circle me-1"></i>@(kayit.DosyaAdi ?? "Dosya mevcut")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted"><i class="bi bi-x-circle me-1"></i>Dosya yok</span>
                                        }
                                    </td>
                                    <td>
                                        @(kayit.BelgeTarihi?.ToString("dd.MM.yyyy") ?? "-")
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-secondary" @onclick="() => DetayAc(kayit)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-warning" @onclick="() => DuzenleAc(kayit)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-info" @onclick="() => YukleAc(kayit)">
                                                <i class="bi bi-upload"></i>
                                            </button>
                                            <button class="btn btn-outline-primary" @onclick="() => KaynagaGit(kayit.KaynakDetayUrl)">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </button>
                                            <button class="btn btn-outline-success" disabled="@(!kayit.DosyaVar)" @onclick="() => DosyaIndir(kayit)">
                                                <i class="bi bi-download"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showDetayModal && seciliKayit != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">
                        <i class="bi bi-folder2-open me-2"></i>Belge Detayı
                    </h5>
                    <button type="button" class="btn-close" @onclick="DetayKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <div class="card border-primary h-100">
                                <div class="card-body py-2">
                                    <small class="text-muted d-block">Kaynak</small>
                                    <strong>@(seciliKayit.Kaynak == EbysBelgeKaynak.Personel ? "Personel" : "Araç")</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-info h-100">
                                <div class="card-body py-2">
                                    <small class="text-muted d-block">Durum</small>
                                    <span class="badge @GetDurumBadge(seciliKayit)">@seciliKayit.Durum</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-warning h-100">
                                <div class="card-body py-2">
                                    <small class="text-muted d-block">Risk</small>
                                    <span class="badge @GetRiskBadge(seciliKayit)">@seciliKayit.RiskDurumu</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header bg-white"><strong>Belge Bilgileri</strong></div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <small class="text-muted d-block">Belge Adı</small>
                                    <strong>@seciliKayit.BelgeAdi</strong>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted d-block">Kategori</small>
                                    <strong>@seciliKayit.Kategori</strong>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted d-block">İlgili Kayıt</small>
                                    <strong>@seciliKayit.IlgiliKayitAdi</strong>
                                    @if (!string.IsNullOrWhiteSpace(seciliKayit.IlgiliKayitKodu))
                                    {
                                        <div><small class="text-muted">@seciliKayit.IlgiliKayitKodu</small></div>
                                    }
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted d-block">Belge Tarihi</small>
                                    <strong>@(seciliKayit.BelgeTarihi?.ToString("dd.MM.yyyy") ?? "-")</strong>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted d-block">Bitiş Tarihi</small>
                                    <strong>@(seciliKayit.BitisTarihi?.ToString("dd.MM.yyyy") ?? "-")</strong>
                                </div>
                                <div class="col-12">
                                    <small class="text-muted d-block">Açıklama</small>
                                    <div>@(string.IsNullOrWhiteSpace(seciliKayit.Aciklama) ? "-" : seciliKayit.Aciklama)</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header bg-white"><strong>Dosya Bilgileri</strong></div>
                        <div class="card-body">
                            <div class="row g-3 align-items-center">
                                <div class="col-md-8">
                                    <small class="text-muted d-block">Dosya</small>
                                    @if (seciliKayit.DosyaVar)
                                    {
                                        <strong>@(seciliKayit.DosyaAdi ?? "Dosya mevcut")</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Dosya bulunmuyor</span>
                                    }
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <button class="btn btn-outline-success" disabled="@(!seciliKayit.DosyaVar)" @onclick="() => DosyaIndir(seciliKayit)">
                                        <i class="bi bi-download me-1"></i>İndir
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-primary" @onclick="() => KaynagaGit(seciliKayit.KaynakDetayUrl)">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Kaynağa Git
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="DetayKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDuzenleModal && duzenlemeModeli != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Belge Düzenle</h5>
                    <button type="button" class="btn-close" @onclick="DuzenleKapat"></button>
                </div>
                <div class="modal-body">
                    @if (duzenlemeModeli.Kaynak == EbysBelgeKaynak.Personel)
                    {
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Belge</label>
                                <input class="form-control" value="@duzenlemeModeli.BelgeAdi" disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kategori</label>
                                <input class="form-control" value="@duzenlemeModeli.Kategori" disabled />
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch mt-4">
                                    <input class="form-check-input" type="checkbox" id="tamamlandi" @bind="duzenlemeModeli.Tamamlandi" />
                                    <label class="form-check-label" for="tamamlandi">Tamamlandı</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Tamamlanma Tarihi</label>
                                <input type="date" class="form-control" @bind="duzenlemeModeli.BelgeTarihi" disabled="@(!duzenlemeModeli.Tamamlandi)" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Açıklama</label>
                                <textarea class="form-control" rows="3" @bind="duzenlemeModeli.Aciklama"></textarea>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Belge Adı</label>
                                <input class="form-control" @bind="duzenlemeModeli.BelgeAdi" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kategori</label>
                                <input class="form-control" @bind="duzenlemeModeli.Kategori" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Durum</label>
                                <select class="form-select" @bind="duzenlemeModeli.Durum">
                                    <option value="Aktif">Aktif</option>
                                    <option value="Pasif">Pasif</option>
                                    <option value="Süresi Dolmuş">Süresi Dolmuş</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Başlangıç Tarihi</label>
                                <input type="date" class="form-control" @bind="duzenlemeModeli.BelgeTarihi" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Bitiş Tarihi</label>
                                <input type="date" class="form-control" @bind="duzenlemeModeli.BitisTarihi" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Açıklama</label>
                                <textarea class="form-control" rows="3" @bind="duzenlemeModeli.Aciklama"></textarea>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="DuzenleKapat">Vazgeç</button>
                    <button type="button" class="btn btn-warning" @onclick="KaydetDuzenleme" disabled="@isSaving">
                        <i class="bi bi-save me-1"></i>@(isSaving ? "Kaydediliyor..." : "Kaydet")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showYukleModal && yuklemeKaydi != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Belge Dosyası Yükle</h5>
                    <button type="button" class="btn-close" @onclick="YukleKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <div><small class="text-muted">Belge</small></div>
                        <strong>@yuklemeKaydi.BelgeAdi</strong>
                    </div>
                    <div class="mb-3">
                        <div><small class="text-muted">İlgili Kayıt</small></div>
                        <strong>@yuklemeKaydi.IlgiliKayitAdi</strong>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dosya Seç</label>
                        <InputFile class="form-control" OnChange="DosyaSecildi" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                        <small class="text-muted">Tek dosya yüklenir. Maksimum 10 MB.</small>
                    </div>
                    @if (secilenYuklemeDosyasi != null)
                    {
                        <div class="alert alert-info py-2 mb-0">
                            <strong>@secilenYuklemeDosyasi.Name</strong>
                            <div><small>@FormatDosyaBoyutu(secilenYuklemeDosyasi.Size)</small></div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="YukleKapat">Vazgeç</button>
                    <button type="button" class="btn btn-info" @onclick="DosyaYukle" disabled="@(secilenYuklemeDosyasi == null || isUploading)">
                        <i class="bi bi-upload me-1"></i>@(isUploading ? "Yükleniyor..." : "Yükle")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly EbysBelgeListeFiltre filtre = new();
    private List<EbysBelgeKaydi> kayitlar = new();
    private List<string> kategoriler = new();
    private List<EbysKategoriOzet> kategoriOzetleri = new();
    private EbysBelgeOlusturmaSecenekleri olusturmaSecenekleri = new();
    private EbysBelgeOlusturmaModeli yeniBelge = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool isUploading;
    private bool isCreating;
    private bool showDetayModal;
    private bool showDuzenleModal;
    private bool showYukleModal;
    private bool showYeniBelgeModal;
    private EbysBelgeKaydi? seciliKayit;
    private EbysBelgeDuzenlemeModeli? duzenlemeModeli;
    private EbysBelgeKaydi? yuklemeKaydi;
    private IBrowserFile? secilenYuklemeDosyasi;
    private IBrowserFile? secilenYeniBelgeDosyasi;

    private bool FiltreVarMi => !string.IsNullOrWhiteSpace(filtre.AramaMetni)
        || filtre.Kaynak != EbysBelgeKaynakFiltre.Tumu
        || !string.IsNullOrWhiteSpace(filtre.Kategori)
        || filtre.Risk != EbysBelgeRiskFiltre.Tumu
        || filtre.SadeceDosyasiOlanlar;

    protected override async Task OnInitializedAsync()
    {
        kategoriler = await EbysService.GetKategorilerAsync();
        kategoriOzetleri = await EbysService.GetKategoriOzetleriAsync();
        olusturmaSecenekleri = await EbysService.GetBelgeOlusturmaSecenekleriAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            kayitlar = await EbysService.GetBelgeKayitlariAsync(filtre);
            kategoriler = await EbysService.GetKategorilerAsync();
            kategoriOzetleri = await EbysService.GetKategoriOzetleriAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"EBYS belgeleri yüklenemedi: {ex.GetBaseException().Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void YukleAc(EbysBelgeKaydi kayit)
    {
        yuklemeKaydi = kayit;
        secilenYuklemeDosyasi = null;
        showYukleModal = true;
    }

    private void YeniBelgeAc()
    {
        yeniBelge = new EbysBelgeOlusturmaModeli
        {
            Kaynak = EbysBelgeKaynak.Personel,
            Tamamlandi = true,
            BelgeTarihi = DateTime.Today,
            Durum = "Aktif"
        };
        secilenYeniBelgeDosyasi = null;
        showYeniBelgeModal = true;
    }

    private async Task DosyaIndir(EbysBelgeKaydi kayit)
    {
        try
        {
            var dosya = await EbysService.GetBelgeDosyasiAsync(kayit.Kaynak, kayit.BelgeId, kayit.DosyaId);
            if (dosya == null)
            {
                ToastService.ShowWarning("İndirilecek dosya bulunamadı.");
                return;
            }

            await JS.InvokeVoidAsync("downloadFile", dosya.DosyaAdi, Convert.ToBase64String(dosya.Icerik), dosya.MimeTipi);
            ToastService.ShowSuccess("Dosya indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Dosya indirilemedi: {ex.GetBaseException().Message}");
        }
    }

    private void KaynagaGit(string url)
    {
        Navigation.NavigateTo(url);
    }

    private void DetayAc(EbysBelgeKaydi kayit)
    {
        seciliKayit = kayit;
        showDetayModal = true;
    }

    private async Task DuzenleAc(EbysBelgeKaydi kayit)
    {
        try
        {
            duzenlemeModeli = await EbysService.GetBelgeDuzenlemeModeliAsync(kayit.Kaynak, kayit.BelgeId);
            if (duzenlemeModeli == null)
            {
                ToastService.ShowWarning("Düzenlenecek belge bulunamadı.");
                return;
            }

            showDuzenleModal = true;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Belge düzenleme ekranı açılamadı: {ex.GetBaseException().Message}");
        }
    }

    private void DetayKapat()
    {
        showDetayModal = false;
        seciliKayit = null;
    }

    private void DuzenleKapat()
    {
        showDuzenleModal = false;
        duzenlemeModeli = null;
    }

    private void YukleKapat()
    {
        showYukleModal = false;
        yuklemeKaydi = null;
        secilenYuklemeDosyasi = null;
    }

    private void YeniBelgeKapat()
    {
        showYeniBelgeModal = false;
        secilenYeniBelgeDosyasi = null;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        secilenYuklemeDosyasi = e.File;
    }

    private void YeniBelgeDosyaSecildi(InputFileChangeEventArgs e)
    {
        secilenYeniBelgeDosyasi = e.File;
    }

    private async Task KaydetDuzenleme()
    {
        if (duzenlemeModeli == null)
            return;

        isSaving = true;
        try
        {
            await EbysService.BelgeGuncelleAsync(duzenlemeModeli);
            kategoriler = await EbysService.GetKategorilerAsync();
            await LoadData();
            DuzenleKapat();
            ToastService.ShowSuccess("Belge bilgileri güncellendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Belge güncellenemedi: {ex.GetBaseException().Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task YeniBelgeKaydet()
    {
        isCreating = true;
        try
        {
            var olusturulanKayit = await EbysService.BelgeOlusturAsync(yeniBelge);

            if (secilenYeniBelgeDosyasi != null)
            {
                await EbysService.BelgeDosyasiYukleAsync(olusturulanKayit.Kaynak, olusturulanKayit.BelgeId, secilenYeniBelgeDosyasi);
            }

            kategoriler = await EbysService.GetKategorilerAsync();
            olusturmaSecenekleri = await EbysService.GetBelgeOlusturmaSecenekleriAsync();
            await LoadData();
            YeniBelgeKapat();
            ToastService.ShowSuccess("Yeni belge kaydı oluşturuldu.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Belge oluşturulamadı: {ex.GetBaseException().Message}");
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task DosyaYukle()
    {
        if (yuklemeKaydi == null || secilenYuklemeDosyasi == null)
            return;

        isUploading = true;
        try
        {
            await EbysService.BelgeDosyasiYukleAsync(yuklemeKaydi.Kaynak, yuklemeKaydi.BelgeId, secilenYuklemeDosyasi);
            kategoriler = await EbysService.GetKategorilerAsync();
            await LoadData();
            YukleKapat();
            ToastService.ShowSuccess("Belge dosyası yüklendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Dosya yüklenemedi: {ex.GetBaseException().Message}");
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task KategoriFiltrele(string kategori)
    {
        filtre.Kategori = kategori;
        await LoadData();
    }

    private async Task KategoriFiltresiniTemizle()
    {
        filtre.Kategori = null;
        await LoadData();
    }

    private async Task FiltreleriTemizle()
    {
        filtre.AramaMetni = null;
        filtre.Kaynak = EbysBelgeKaynakFiltre.Tumu;
        filtre.Kategori = null;
        filtre.Risk = EbysBelgeRiskFiltre.Tumu;
        filtre.SadeceDosyasiOlanlar = false;
        await LoadData();
    }

    private static string GetDurumBadge(EbysBelgeKaydi kayit)
    {
        if (!kayit.DosyaVar)
        {
            return "bg-secondary";
        }

        return kayit.Kaynak switch
        {
            EbysBelgeKaynak.Personel when kayit.Durum == "Tamamlandı" => "bg-success",
            EbysBelgeKaynak.Arac when kayit.Durum == "Aktif" => "bg-success",
            EbysBelgeKaynak.Arac when kayit.Durum == "Süresi Dolmuş" => "bg-danger",
            EbysBelgeKaynak.Arac when kayit.Durum == "Pasif" => "bg-warning text-dark",
            _ => "bg-info"
        };
    }

    private static string GetRiskBadge(EbysBelgeKaydi kayit)
    {
        return kayit.RiskDurumu switch
        {
            "Normal" => "bg-success",
            "Yaklaşan" => "bg-warning text-dark",
            "Süresi Dolmuş" => "bg-danger",
            "Dosya Eksik" => "bg-secondary",
            _ => "bg-info"
        };
    }

    private static string FormatDosyaBoyutu(long boyut)
    {
        if (boyut >= 1024 * 1024)
            return $"{boyut / 1024d / 1024d:F2} MB";
        if (boyut >= 1024)
            return $"{boyut / 1024d:F1} KB";

        return $"{boyut} B";
    }
}

