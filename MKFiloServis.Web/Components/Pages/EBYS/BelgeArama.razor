    private async Task IndekslemeleriYenile()
    {
        if (indekslemeSuruyor) return;

        indekslemeSuruyor = true;
        indekslemeMesaj = "İndeksleme başlıyor...";
        StateHasChanged();

        try
        {
            var progress = new Progress<EmbeddingIndekslemeProgress>(p =>
            {
                indekslemeMesaj = $"{p.AktifKaynak}: {p.Tamamlanan}/{p.Toplam}";
                InvokeAsync(StateHasChanged);
            });

            var rapor = await SemanticSearchService.TumBelgeleriIndeksleAsync(progress);
            indekslemeMesaj = $"Tamamlandı: {rapor.BasariliIndekslenen} belge ({rapor.Sure.TotalSeconds:N0} sn)";

            // İstatistikleri güncelle
            embeddingIstatistik = await SemanticSearchService.IstatistikleriGetirAsync();
        }
        catch (Exception ex)
        {
            indekslemeMesaj = $"Hata: {ex.Message}";
        }
        finally
        {
            indekslemeSuruyor = false;
        }
    }
}

