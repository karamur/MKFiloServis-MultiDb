        _ => "bi-file-earmark"
    };

    private static string FormatDosyaBoyutu(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        int order = 0;
        double len = bytes;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private async Task DosyaIndir(int dosyaId)
    {
        try
        {
            var dosya = await EvrakService.GetDosyaAsync(dosyaId);
            if (dosya == null) { ToastService.ShowError("Dosya bulunamadı."); return; }
            var icerik = await EvrakService.GetDosyaIcerikAsync(dosyaId);
            if (icerik == null) { ToastService.ShowError("Dosya içeriği okunamadı."); return; }
            var base64 = Convert.ToBase64String(icerik);
            var mime = dosya.DosyaTipi?.ToLowerInvariant() switch
            {
                "pdf"  => "application/pdf",
                "png"  => "image/png",
                "jpg" or "jpeg" => "image/jpeg",
                "docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                "xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                _      => "application/octet-stream"
            };
            await AktiviteLog.LogGoruntulemeAsync("EBYS", "EbysEvrakDosya", dosya.Id, dosya.DosyaAdi, $"Dosya indirildi: {dosya.DosyaAdi} (Evrak #{dosya.EvrakId})");
            await JS.InvokeVoidAsync("downloadFile", dosya.DosyaAdi, base64, mime);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"İndirme hatası: {ex.Message}");
        }
    }
