    // Versiyon Yönetimi Metodları
    private void DosyaGuncelleAc(int dosyaId)
    {
        seciliDosyaId = dosyaId;
        guncellemeDosyasi = null;
        degisiklikNotu = null;
        showGuncellemeModal = true;
    }

    private void OnGuncellemeDosyaSecildi(InputFileChangeEventArgs e)
    {
        guncellemeDosyasi = e.File;
    }

    private async Task DosyaGuncelleAsync()
    {
        if (guncellemeDosyasi == null || seciliDosyaId == null) return;

        isUploading = true;
        try
        {
            // Önce mevcut versiyonu arşivle
            await VersiyonService.ArsivleEbysEvrakDosyaAsync(seciliDosyaId.Value, degisiklikNotu);

            // Yeni dosyayı yükle (mevcut dosyanın üzerine)
            await EvrakService.DosyaGuncelleAsync(seciliDosyaId.Value, guncellemeDosyasi, degisiklikNotu);

            ToastService.ShowSuccess("Dosya güncellendi ve önceki versiyon arşivlendi");
            showGuncellemeModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isUploading = false;
        }
    }

