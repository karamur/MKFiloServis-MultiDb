@page "/ebys/evrak/{Id:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IEbysEvrakService EvrakService
@inject ApplicationDbContext DbContext
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IAktiviteLogService AktiviteLog
@rendermode InteractiveServer

<PageTitle>Evrak Detay - EBYS</PageTitle>

@if (evrak == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        @* Başlık *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/ebys">EBYS</a></li>
                        <li class="breadcrumb-item">
                            <a href="@(evrak.Yon == EvrakYonu.Gelen ? "/ebys/gelen" : "/ebys/giden")">
                                @(evrak.Yon == EvrakYonu.Gelen ? "Gelen" : "Giden") Evraklar
                            </a>
                        </li>
                        <li class="breadcrumb-item active">@evrak.EvrakNo</li>
                    </ol>
                </nav>
                <h3 class="mb-0">
                    <i class="bi @(evrak.Yon == EvrakYonu.Gelen ? "bi-inbox text-primary" : "bi-send text-success") me-2"></i>
                    @evrak.EvrakNo
                    <span class="badge @DurumRenk(evrak.Durum) ms-2">@DurumAdi(evrak.Durum)</span>
                </h3>
            </div>
            <div class="d-flex gap-2">
                @if (evrak.Durum != EbysEvrakDurum.Tamamlandi && evrak.Durum != EbysEvrakDurum.Arsivlendi)
                {
                    <button class="btn btn-success" @onclick="TamamlaAsync">
                        <i class="bi bi-check-circle me-1"></i>Tamamla
                    </button>
                }
                @if (evrak.Durum == EbysEvrakDurum.Tamamlandi)
                {
                    <button class="btn btn-secondary" @onclick="ArsivleAsync">
                        <i class="bi bi-archive me-1"></i>Arşivle
                    </button>
                }
                <button class="btn btn-outline-primary" @onclick="DuzenleAc">
                    <i class="bi bi-pencil me-1"></i>Düzenle
                </button>
            </div>
        </div>

        <div class="row g-3">
            @* Sol Kolon - Evrak Bilgileri *@
            <div class="col-lg-8">
                @* Evrak Bilgileri Kartı *@
                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-file-text me-2"></i>Evrak Bilgileri</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="text-muted small">Konu</label>
                                <p class="mb-2 fw-medium">@evrak.Konu</p>
                            </div>
                            <div class="col-md-3">
                                <label class="text-muted small">Evrak Tarihi</label>
                                <p class="mb-2">@evrak.EvrakTarihi.ToString("dd.MM.yyyy")</p>
                            </div>
                            <div class="col-md-3">
                                <label class="text-muted small">Kayıt Tarihi</label>
                                <p class="mb-2">@evrak.KayitTarihi?.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>

                            @if (evrak.Yon == EvrakYonu.Gelen)
                            {
                                <div class="col-md-6">
                                    <label class="text-muted small">Gönderen Kurum</label>
                                    <p class="mb-2">@(evrak.GonderenKurum ?? "-")</p>
                                </div>
                                <div class="col-md-3">
                                    <label class="text-muted small">Geliş No</label>
                                    <p class="mb-2">@(evrak.GelisNo ?? "-")</p>
                                </div>
                                <div class="col-md-3">
                                    <label class="text-muted small">Geliş Tarihi</label>
                                    <p class="mb-2">@(evrak.GelisTarihi?.ToString("dd.MM.yyyy") ?? "-")</p>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6">
                                    <label class="text-muted small">Alıcı Kurum</label>
                                    <p class="mb-2">@(evrak.AliciKurum ?? "-")</p>
                                </div>
                                <div class="col-md-3">
                                    <label class="text-muted small">Gönderim Yöntemi</label>
                                    <p class="mb-2">@GonderimAdi(evrak.GonderimYontemi)</p>
                                </div>
                                <div class="col-md-3">
                                    <label class="text-muted small">Gönderim Tarihi</label>
                                    <p class="mb-2">@(evrak.GonderimTarihi?.ToString("dd.MM.yyyy") ?? "-")</p>
                                </div>
                            }

                            <div class="col-md-4">
                                <label class="text-muted small">Kategori</label>
                                <p class="mb-2">
                                    @if (evrak.Kategori != null)
                                    {
                                        <span class="badge" style="background-color:@evrak.Kategori.Renk">@evrak.Kategori.KategoriAdi</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </p>
                            </div>
                            <div class="col-md-4">
                                <label class="text-muted small">Öncelik</label>
                                <p class="mb-2"><span class="badge @OncelikRenk(evrak.Oncelik)">@OncelikAdi(evrak.Oncelik)</span></p>
                            </div>
                            <div class="col-md-4">
                                <label class="text-muted small">Gizlilik</label>
                                <p class="mb-2"><span class="badge @GizlilikRenk(evrak.Gizlilik)">@GizlilikAdi(evrak.Gizlilik)</span></p>
                            </div>

                            @if (!string.IsNullOrEmpty(evrak.Ozet))
                            {
                                <div class="col-12">
                                    <label class="text-muted small">Özet</label>
                                    <p class="mb-2">@evrak.Ozet</p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(evrak.Aciklama))
                            {
                                <div class="col-12">
                                    <label class="text-muted small">Açıklama</label>
                                    <p class="mb-2">@evrak.Aciklama</p>
                                </div>
                            }

                            @if (evrak.CevapGerekli)
                            {
                                <div class="col-12">
                                    <div class="alert @(evrak.CevapSuresi < DateTime.Now && evrak.Durum != EbysEvrakDurum.Cevaplandi ? "alert-danger" : "alert-warning") mb-0 py-2">
                                        <i class="bi bi-reply-fill me-2"></i>
                                        <strong>Cevap Gerekli</strong>
                                        @if (evrak.CevapSuresi.HasValue)
                                        {
                                            <span class="ms-2">Son tarih: @evrak.CevapSuresi.Value.ToString("dd.MM.yyyy")</span>
                                            @if (evrak.CevapSuresi.Value < DateTime.Now && evrak.Durum != EbysEvrakDurum.Cevaplandi)
                                            {
                                                <span class="badge bg-danger ms-2">GECİKMİŞ</span>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* Dosyalar Kartı *@
                <div class="card mb-3">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-paperclip me-2"></i>Ekli Dosyalar (@(evrak.Dosyalar?.Count ?? 0))</h6>
                        <button class="btn btn-sm btn-primary" @onclick="DosyaYukleAc">
                            <i class="bi bi-cloud-upload me-1"></i>Dosya Yükle
                        </button>
                    </div>
                    <div class="card-body">
                        @if (evrak.Dosyalar?.Any() == true)
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var dosya in evrak.Dosyalar.Where(d => !d.IsDeleted))
                                {
                                    <div class="list-group-item d-flex align-items-center px-0">
                                        <i class="bi @DosyaIkon(dosya.DosyaTipi) fs-4 text-primary me-3"></i>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">@dosya.DosyaAdi</h6>
                                            <small class="text-muted">
                                                @FormatDosyaBoyutu(dosya.DosyaBoyutu)
                                                @if (dosya.AsilNusha)
                                                {
                                                    <span class="badge bg-success ms-2">Asıl Nüsha</span>
                                                }
                                                @if (dosya.VersiyonNo > 1)
                                                {
                                                    <span class="badge bg-info ms-2">v@dosya.VersiyonNo</span>
                                                }
                                            </small>
                                        </div>
                                        <div class="btn-group btn-group-sm">
                                            @if (dosya.VersiyonNo > 1)
                                            {
                                                <button class="btn btn-outline-secondary" @onclick="() => VersiyonGecmisiAc(dosya.Id)" title="Versiyon Geçmişi">
                                                    <i class="bi bi-clock-history"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-primary" title="İndir" @onclick="() => DosyaIndir(dosya.Id)">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <button class="btn btn-outline-warning" @onclick="() => DosyaGuncelleAc(dosya.Id)" title="Güncelle">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => DosyaSilAsync(dosya.Id)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center mb-0">Ekli dosya bulunmuyor</p>
                        }
                    </div>
                </div>

                @* Hareket Geçmişi *@
                <div class="card">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>İşlem Geçmişi</h6>
                    </div>
                    <div class="card-body p-0">
                        @if (evrak.Hareketler?.Any() == true)
                        {
                            <div class="list-group list-group-flush" style="max-height:300px; overflow-y:auto;">
                                @foreach (var hareket in evrak.Hareketler.OrderByDescending(h => h.IslemTarihi))
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex align-items-start">
                                            <span class="badge @HareketRenk(hareket.HareketTipi) me-3 mt-1">
                                                <i class="bi @HareketIkon(hareket.HareketTipi)"></i>
                                            </span>
                                            <div class="flex-grow-1">
                                                <p class="mb-1">@hareket.Aciklama</p>
                                                <small class="text-muted">
                                                    @hareket.IslemTarihi.ToString("dd.MM.yyyy HH:mm")
                                                    @if (hareket.Kullanici != null)
                                                    {
                                                        <span>- @hareket.Kullanici.AdSoyad</span>
                                                    }
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center py-3 mb-0">İşlem geçmişi bulunmuyor</p>
                        }
                    </div>
                </div>
            </div>

            @* Sağ Kolon - Atamalar ve Hızlı İşlemler *@
            <div class="col-lg-4">
                @* Durum Değiştir *@
                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Durum Değiştir</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            @foreach (var durum in GetUygunDurumlar())
                            {
                                <button class="btn btn-sm @(evrak.Durum == durum ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => DurumDegistirAsync(durum)"
                                        disabled="@(evrak.Durum == durum)">
                                    @DurumAdi(durum)
                                </button>
                            }
                        </div>
                    </div>
                </div>

                @* Atama Yap *@
                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-person-plus me-2"></i>Atama Yap</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small">Kullanıcı</label>
                            <select class="form-select form-select-sm" @bind="yeniAtama.AtananKullaniciId">
                                <option value="">Seçiniz</option>
                                @foreach (var k in kullanicilar)
                                {
                                    <option value="@k.Id">@k.AdSoyad</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Talimat</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="yeniAtama.Talimat" placeholder="Yapılması gereken işlem..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Teslim Tarihi</label>
                            <input type="date" class="form-control form-control-sm" @bind="yeniAtama.TeslimTarihi" />
                        </div>
                        <button class="btn btn-primary btn-sm w-100" @onclick="AtamaYapAsync">
                            <i class="bi bi-send me-1"></i>Ata
                        </button>
                    </div>
                </div>

                @* Mevcut Atamalar *@
                @if (evrak.Atamalar?.Any() == true)
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-people me-2"></i>Atamalar (@evrak.Atamalar.Count)</h6>
                        </div>
                        <div class="list-group list-group-flush" style="max-height:250px; overflow-y:auto;">
                            @foreach (var atama in evrak.Atamalar.OrderByDescending(a => a.AtamaTarihi))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@(atama.AtananKullanici?.AdSoyad ?? "Kullanıcı #" + atama.AtananKullaniciId)</h6>
                                            <small class="text-muted d-block">@atama.AtamaTarihi.ToString("dd.MM.yyyy HH:mm")</small>
                                            @if (!string.IsNullOrEmpty(atama.Talimat))
                                            {
                                                <small class="text-muted">@atama.Talimat</small>
                                            }
                                        </div>
                                        <span class="badge @AtamaDurumRenk(atama.Durum)">@AtamaDurumAdi(atama.Durum)</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
}

@* Dosya Yükleme Modal *@
@if (showDosyaModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-cloud-upload me-2"></i>Dosya Yükle</h5>
                    <button type="button" class="btn-close" @onclick="() => showDosyaModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Dosya Seçin</label>
                        <InputFile OnChange="OnDosyaSecildi" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" />
                        <small class="text-muted">Maksimum 50MB</small>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="asilNusha" @bind="asilNusha" />
                        <label class="form-check-label" for="asilNusha">Asıl nüsha</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDosyaModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="DosyaYukleAsync" disabled="@(secilenDosya == null || isUploading)">
                        @if (isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Yükle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Dosya Güncelleme Modal *@
@if (showGuncellemeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Dosya Güncelle</h5>
                    <button type="button" class="btn-close" @onclick="() => showGuncellemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Mevcut dosya versiyon geçmişine arşivlenecek ve yeni dosya ile değiştirilecektir.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Yeni Dosya Seçin</label>
                        <InputFile OnChange="OnGuncellemeDosyaSecildi" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" />
                        <small class="text-muted">Maksimum 50MB</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Değişiklik Notu</label>
                        <textarea class="form-control" rows="2" @bind="degisiklikNotu" placeholder="Bu güncelleme için not ekleyin..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showGuncellemeModal = false">İptal</button>
                    <button type="button" class="btn btn-warning" @onclick="DosyaGuncelleAsync" disabled="@(guncellemeDosyasi == null || isUploading)">
                        @if (isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Güncelle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Versiyon Geçmişi Modal *@
@if (showVersiyonModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Versiyon Geçmişi</h5>
                    <button type="button" class="btn-close" @onclick="() => showVersiyonModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (versiyonListesi.Any())
                    {
                        @* Mevcut Versiyon *@
                        @if (mevcutDosya != null)
                        {
                            <div class="card border-primary mb-3">
                                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-star-fill me-2"></i>Mevcut Versiyon (v@mevcutDosya.VersiyonNo)</span>
                                    <span class="badge bg-light text-primary">Aktif</span>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <strong>@mevcutDosya.DosyaAdi</strong>
                                            <p class="text-muted small mb-0">@FormatDosyaBoyutu(mevcutDosya.DosyaBoyutu)</p>
                                        </div>
                                        <div class="col-md-6 text-end">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => DosyaIndir(mevcutDosya.Id)">
                                                <i class="bi bi-download me-1"></i>İndir
                                            </button>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(mevcutDosya.SonDegisiklikNotu))
                                    {
                                        <hr class="my-2"/>
                                        <small class="text-muted"><i class="bi bi-chat-left-text me-1"></i>@mevcutDosya.SonDegisiklikNotu</small>
                                    }
                                </div>
                            </div>
                        }

                        @* Önceki Versiyonlar *@
                        <h6 class="text-muted mb-3"><i class="bi bi-archive me-2"></i>Önceki Versiyonlar</h6>
                        <div class="list-group">
                            @foreach (var v in versiyonListesi.OrderByDescending(x => x.VersiyonNo))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">
                                                <span class="badge bg-secondary me-2">v@v.VersiyonNo</span>
                                                @v.DosyaAdi
                                            </h6>
                                            <small class="text-muted d-block">
                                                @FormatDosyaBoyutu(v.DosyaBoyutu) • @v.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")
                                                @if (v.OlusturanKullanici != null)
                                                {
                                                    <span>• @v.OlusturanKullanici.AdSoyad</span>
                                                }
                                            </small>
                                            @if (!string.IsNullOrEmpty(v.DegisiklikNotu))
                                            {
                                                <small class="text-muted"><i class="bi bi-chat-left-text me-1"></i>@v.DegisiklikNotu</small>
                                            }
                                        </div>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" title="İndir" @onclick="() => DosyaIndir(v.Id)">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <button class="btn btn-outline-warning" @onclick="() => VersiyonGeriYukleAsync(v.Id)" title="Geri Yükle">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">Versiyon geçmişi bulunmuyor</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showVersiyonModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    [Inject] private IBelgeVersiyonService VersiyonService { get; set; } = default!;

    private EbysEvrak? evrak;
    private List<Kullanici> kullanicilar = new();
    private EbysEvrakAtamaModel yeniAtama = new();
    private bool showDosyaModal;
    private IBrowserFile? secilenDosya;
    private bool asilNusha;
    private bool isUploading;

    // Versiyon Modal değişkenleri
    private bool showVersiyonModal;
    private bool showGuncellemeModal;
    private int? seciliDosyaId;
    private EbysEvrakDosya? mevcutDosya;
    private List<EbysEvrakDosyaVersiyon> versiyonListesi = new();
    private IBrowserFile? guncellemeDosyasi;
    private string? degisiklikNotu;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        evrak = await EvrakService.GetEvrakByIdAsync(Id);
