@page "/ihale-hazirlik"
@page "/ihale-hazirlik/{ProjeId:int}"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net
@using System.Text.RegularExpressions
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@inject IIhaleHazirlikService IhaleService
@inject IIhaleTeklifVersiyonService TeklifVersiyonService
@inject IIhaleTeklifKarsilastirmaService TeklifKarsilastirmaService
@inject IIhaleTeklifExportService TeklifExportService
@inject IOllamaService OllamaService
@inject ICariService CariService
@inject IGuzergahService GuzergahService
@inject IAracService AracService
@inject IKullaniciService KullaniciService
@inject IExcelService ExcelService
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IToastService ToastService

<PageTitle>İhale Hazırlık</PageTitle>

@if (secilenProje == null)
{
    <!-- PROJE LİSTESİ -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-briefcase me-2"></i>İhale Hazırlık Projeleri</h4>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-success" @onclick="OrnekVeriOlusturAsync" disabled="@yukleniyor">
                <i class="bi bi-magic me-1"></i> Örnek Veri Oluştur
            </button>
            <button class="btn btn-primary" @onclick="YeniProjeModal">
                <i class="bi bi-plus-circle me-1"></i> Yeni Proje
            </button>
        </div>
    </div>

    @if (operasyonDashboard != null && operasyonDashboard.KazanilanProjeSayisi > 0)
    {
        <div class="card shadow-sm mb-3 border-warning-subtle">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>İhale Sonrası Operasyon Özeti</h6>
                <div class="d-flex gap-2 align-items-center">
                    <small class="text-muted">Kazanılan projeler baz alınır</small>
                    <button class="btn btn-sm btn-outline-success" @onclick="OperasyonDashboardExcelExportAsync">
                        <i class="bi bi-file-earmark-excel me-1"></i>Excel
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-2">
                        <div class="card bg-light h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Kazanılan / Analiz Edilen</small><br/>
                                <strong>@operasyonDashboard.KazanilanProjeSayisi / @operasyonDashboard.AnalizEdilenProjeSayisi</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-primary h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Ort. Teklif Doğruluk</small><br/>
                                <strong class="text-primary">%@operasyonDashboard.OrtalamaTeklifDogrulukSkoru.ToString("N1")</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-danger h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Riskli Proje Sayısı</small><br/>
                                <strong class="text-danger">@operasyonDashboard.RiskliProjeSayisi</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-info h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Revizyonlu Proje</small><br/>
                                <strong class="text-info">@operasyonDashboard.RevizyonluProjeSayisi</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-secondary h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Süre Uzatımı</small><br/>
                                <strong>@operasyonDashboard.SureUzatimliProjeSayisi</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-warning h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">En Kötü Kâr Sapması</small><br/>
                                <strong class="@GetKarSapmaClass(operasyonDashboard.EnKotusuKarSapmasi)">@FormatSigned(operasyonDashboard.EnKotusuKarSapmasi) ₺</strong>
                            </div>
                        </div>
                    </div>
                </div>

                @if (operasyonDashboard.ToplamRevizyonBedelFarki != 0)
                {
                    <div class="alert alert-info py-2 mb-3">
                        <strong>Toplam revizyon bedel farkı:</strong>
                        <span class="ms-1 @(operasyonDashboard.ToplamRevizyonBedelFarki >= 0 ? "text-success" : "text-danger")">@FormatSigned(operasyonDashboard.ToplamRevizyonBedelFarki) ₺</span>
                    </div>
                }

                @if (operasyonDashboard.RiskliProjeler.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Proje</th>
                                    <th class="text-center">Risk</th>
                                    <th class="text-center">Revizyon</th>
                                    <th class="text-end">Doğruluk</th>
                                    <th class="text-end">Maliyet Sapma %</th>
                                    <th class="text-end">Bedel Farkı</th>
                                    <th class="text-end">Kâr Sapması</th>
                                    <th class="text-end">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var riskli in operasyonDashboard.RiskliProjeler)
                                {
                                    <tr>
                                        <td>
                                            <strong>@riskli.ProjeAdi</strong>
                                            <div class="small text-muted">@riskli.ProjeKodu</div>
                                        </td>
                                        <td class="text-center"><span class="badge @GetRiskBadge(riskli.RiskSeviyesi)">@GetRiskMetni(riskli.RiskSeviyesi)</span></td>
                                        <td class="text-center">@riskli.AktifRevizyonSayisi</td>
                                        <td class="text-end">%@riskli.TeklifDogrulukSkoru.ToString("N1")</td>
                                        <td class="text-end @GetFarkTextClass(riskli.MaliyetSapmaOrani)">@FormatSigned(riskli.MaliyetSapmaOrani)</td>
                                        <td class="text-end @(riskli.ToplamRevizyonBedelFarki >= 0 ? "text-success" : "text-danger")">@FormatSigned(riskli.ToplamRevizyonBedelFarki)</td>
                                        <td class="text-end @GetKarSapmaClass(riskli.KarSapmasi)">@FormatSigned(riskli.KarSapmasi)</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ProjeSecAsync(riskli.ProjeId)">
                                                <i class="bi bi-eye me-1"></i>Aç
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (projeler == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (!projeler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz ihale projesi oluşturulmamış.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var p in projeler)
            {
                <div class="col-md-6 col-xl-4 mb-3">
                    <div class="card h-100 shadow-sm border-start border-4 @GetDurumBorderColor(p.Durum)">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-0">@p.ProjeAdi</h6>
                                    <small class="text-muted">@p.ProjeKodu</small>
                                </div>
                                <span class="badge @GetDurumBadge(p.Durum)">@GetDurumMetin(p.Durum)</span>
                            </div>
                            <div class="small text-muted mb-2">
                                @if (p.Cari != null) { <span><i class="bi bi-building me-1"></i>@p.Cari.Unvan</span><br/> }
                                <span><i class="bi bi-calendar me-1"></i>@p.BaslangicTarihi.ToString("dd.MM.yyyy") - @p.BitisTarihi.ToString("dd.MM.yyyy")</span><br/>
                                <span><i class="bi bi-clock me-1"></i>@p.SozlesmeSuresiAy ay</span>
                                <span class="ms-2"><i class="bi bi-signpost me-1"></i>@p.Kalemler.Count(k => !k.IsDeleted) hat</span>
                            </div>
                            <div class="d-flex gap-1 mt-2">
                                <button class="btn btn-sm btn-outline-primary flex-fill" @onclick="() => ProjeSecAsync(p.Id)">
                                    <i class="bi bi-pencil me-1"></i>Düzenle
                                </button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => KopyalaProjeAsync(p)" title="Kopyala">
                                    <i class="bi bi-copy"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => SilProjeAsync(p.Id)" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <!-- PROJE DETAY -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <button class="btn btn-sm btn-outline-secondary me-2" @onclick="ListeyeDon">
                <i class="bi bi-arrow-left me-1"></i>Projeler
            </button>
            <span class="h5 mb-0">@secilenProje.ProjeAdi</span>
            <span class="badge @GetDurumBadge(secilenProje.Durum) ms-2">@GetDurumMetin(secilenProje.Durum)</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-info" @onclick="ProjeAyarModal">
                <i class="bi bi-gear me-1"></i>Proje Ayarları
            </button>
            @if (aiAktif)
            {
                <button class="btn btn-sm btn-purple" @onclick="AIProjeAnalizAsync" disabled="@yukleniyor">
                    <i class="bi bi-robot me-1"></i>AI Analiz
                </button>
            }
            <button class="btn btn-sm btn-success" @onclick="RaporGosterAsync">
                <i class="bi bi-file-earmark-bar-graph me-1"></i>Rapor
            </button>
        </div>
    </div>

    <!-- Proje Bilgi Kartları -->
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Müşteri</small><br/>
                    <strong>@(secilenProje.Cari?.Unvan ?? secilenProje.Firma?.FirmaAdi ?? "-")</strong>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Süre</small><br/>
                    <strong>@secilenProje.SozlesmeSuresiAy ay</strong>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Hat Sayısı</small><br/>
                    <strong>@aktifKalemler.Count</strong>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Aylık Maliyet</small><br/>
                    <strong class="text-danger">@aktifKalemler.Sum(k => k.AylikMaliyet).ToString("N0") ₺</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Aylık Teklif</small><br/>
                    <strong class="text-success">@aktifKalemler.Sum(k => k.AylikTeklifFiyati).ToString("N0") ₺</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- Rapor Bölümü -->
    @if (projeOzet != null && raporGoster)
    {
        <div id="raporKart" class="card shadow-sm mb-3 border-primary">
            <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-file-earmark-bar-graph me-2"></i>Kâr/Zarar/Masraf Tablosu - Enflasyonlu Projeksiyon</h6>
                <button class="btn btn-sm btn-outline-light" @onclick="() => raporGoster = false"><i class="bi bi-x"></i></button>
            </div>
            <div class="card-body p-0">
                @if (projeOzet.AylikProjeksiyonlar.Any())
                {
                    var ilkAy = projeOzet.AylikProjeksiyonlar.First();
                    var sonAy = projeOzet.AylikProjeksiyonlar.Last();
                    var artisTutari = sonAy.ToplamMaliyet - ilkAy.ToplamMaliyet;
                    var artisOrani = ilkAy.ToplamMaliyet > 0 ? artisTutari / ilkAy.ToplamMaliyet * 100 : 0;

                    <div class="row g-0 border-bottom">
                        <div class="col-md-4 p-3 text-center border-end">
                            <small class="text-muted d-block">İlk Ay Maliyeti</small>
                            <strong class="text-primary">@ilkAy.ToplamMaliyet.ToString("N0") ₺</strong>
                        </div>
                        <div class="col-md-4 p-3 text-center border-end">
                            <small class="text-muted d-block">Son Ay Tahmini Maliyeti</small>
                            <strong class="text-danger">@sonAy.ToplamMaliyet.ToString("N0") ₺</strong>
                        </div>
                        <div class="col-md-4 p-3 text-center">
                            <small class="text-muted d-block">Süre Sonu Maliyet Artışı</small>
                            <strong class="@(artisTutari >= 0 ? "text-warning" : "text-success")">@artisTutari.ToString("N0") ₺ (%@artisOrani.ToString("N1"))</strong>
                        </div>
                    </div>
                }

                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th>Dönem</th>
                                <th class="text-end">Maliyet</th>
                                <th class="text-end">Kâr</th>
                                <th class="text-end">Teklif</th>
                                <th class="text-end">Enflasyon Etkisi</th>
                                <th class="text-end">Küm. Maliyet</th>
                                <th class="text-end">Küm. Kâr</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ay in projeOzet.AylikProjeksiyonlar)
                            {
                                <tr>
                                    <td>@ay.DonemAdi</td>
                                    <td class="text-end text-danger">@ay.ToplamMaliyet.ToString("N0")</td>
                                    <td class="text-end text-success">@ay.ToplamKar.ToString("N0")</td>
                                    <td class="text-end fw-bold">@ay.ToplamTeklif.ToString("N0")</td>
                                    <td class="text-end @(ay.EnflasyonEtkisi > 0 ? "text-danger" : "")">
                                        @(ay.EnflasyonEtkisi > 0 ? "+" : "")@ay.EnflasyonEtkisi.ToString("N0")
                                    </td>
                                    <td class="text-end">@ay.KumulatifMaliyet.ToString("N0")</td>
                                    <td class="text-end text-success">@ay.KumulatifKar.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        @if (projeOzet.AylikProjeksiyonlar.Any())
                        {
                            <tfoot class="table-dark">
                                <tr class="fw-bold">
                                    <td>TOPLAM</td>
                                    <td class="text-end text-danger">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamMaliyet).ToString("N0")</td>
                                    <td class="text-end text-success">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamKar).ToString("N0")</td>
                                    <td class="text-end">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamTeklif).ToString("N0")</td>
                                    <td class="text-end">@projeOzet.AylikProjeksiyonlar.Sum(a => a.EnflasyonEtkisi).ToString("N0")</td>
                                    <td class="text-end">—</td>
                                    <td class="text-end text-success">@projeOzet.AylikProjeksiyonlar.Last().KumulatifKar.ToString("N0")</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        </div>

        <!-- Maliyet Dağılım Kartları -->
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Toplam Proje Maliyeti</small>
                        <h5 class="text-danger mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamMaliyet).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Toplam Proje Kârı</small>
                        <h5 class="text-success mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamKar).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Toplam Teklif Bedeli</small>
                        <h5 class="text-primary mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamTeklif).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Enflasyon Toplam Etkisi</small>
                        <h5 class="text-warning mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.EnflasyonEtkisi).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (gerceklesenAnaliz != null && (secilenProje.Durum == IhaleProjeDurum.Kazanildi || gerceklesenAnaliz.ToplamGerceklesenSeferSayisi > 0))
    {
        var enKarlıHat = gerceklesenAnaliz.Kalemler.OrderByDescending(x => x.GerceklesenKar).FirstOrDefault();
        var enRiskliHat = gerceklesenAnaliz.Kalemler.OrderBy(x => x.KarSapmasi).FirstOrDefault();
        var enYuksekMaliyetSapmaliHat = gerceklesenAnaliz.Kalemler.OrderByDescending(x => Math.Abs(x.MaliyetSapmasi)).FirstOrDefault();

        <div class="card shadow-sm mb-3 border-success-subtle">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Gerçekleşen vs Tekliflenen Analiz</h6>
                <div class="d-flex gap-2 align-items-center">
                    <small class="text-muted">@gerceklesenAnaliz.AnalizBaslangicTarihi.ToString("dd.MM.yyyy") - @gerceklesenAnaliz.AnalizBitisTarihi.ToString("dd.MM.yyyy")</small>
                    <button class="btn btn-sm btn-outline-success" @onclick="GerceklesenAnalizExcelExportAsync">
                        <i class="bi bi-file-earmark-excel me-1"></i>Excel
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <div class="card bg-light h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Geçen Ay / Sefer</small><br/>
                                <strong>@gerceklesenAnaliz.GecenAySayisi ay / @gerceklesenAnaliz.ToplamGerceklesenSeferSayisi sefer</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-danger h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Planlanan / Gerçekleşen Maliyet</small><br/>
                                <strong class="text-danger">@gerceklesenAnaliz.PlanlananToplamMaliyet.ToString("N0") / @gerceklesenAnaliz.GerceklesenToplamMaliyet.ToString("N0") ₺</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-primary h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Planlanan / Gerçekleşen Gelir</small><br/>
                                <strong class="text-primary">@gerceklesenAnaliz.PlanlananToplamTeklif.ToString("N0") / @gerceklesenAnaliz.GerceklesenToplamGelir.ToString("N0") ₺</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-warning h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Kâr Sapması</small><br/>
                                <strong class="@GetKarSapmaClass(gerceklesenAnaliz.KarSapmasi)">@FormatSigned(gerceklesenAnaliz.KarSapmasi) ₺</strong>
                            </div>
                        </div>
                    </div>
                </div>

                @if (gerceklesenAnaliz.AktifSozlesmeRevizyonSayisi > 0)
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <div class="card border-info h-100">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Aktif Revizyon Sayısı</small><br/>
                                    <strong class="text-info">@gerceklesenAnaliz.AktifSozlesmeRevizyonSayisi</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-secondary h-100">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Toplam Bedel Farkı</small><br/>
                                    <strong class="@(gerceklesenAnaliz.ToplamRevizyonBedelFarki >= 0 ? "text-success" : "text-danger")">@FormatSigned(gerceklesenAnaliz.ToplamRevizyonBedelFarki) ₺</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-dark h-100">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Toplam Süre Farkı</small><br/>
                                    <strong>@gerceklesenAnaliz.ToplamRevizyonSureFarkiAy ay</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info py-2 mb-3">
                        <strong>Revizyon etkili planlanan gelir:</strong>
                        <span class="ms-1">@gerceklesenAnaliz.RevizyonEtkiliPlanlananTeklif.ToString("N0") ₺</span>
                        <span class="mx-2">|</span>
                        <strong>Revizyon sonrası gelir sapması:</strong>
                        <span class="ms-1 @GetFarkTextClass(gerceklesenAnaliz.RevizyonEtkiliGelirSapmasi)">@FormatSigned(gerceklesenAnaliz.RevizyonEtkiliGelirSapmasi) ₺</span>
                    </div>

                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Revizyon No</th>
                                    <th>Tip</th>
                                    <th>Başlık</th>
                                    <th>Tarih</th>
                                    <th>Yürürlük</th>
                                    <th class="text-end">Bedel Farkı</th>
                                    <th class="text-center">Süre Farkı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var revizyon in gerceklesenAnaliz.AktifRevizyonlar)
                                {
                                    <tr>
                                        <td><strong>@revizyon.RevizyonNo</strong></td>
                                        <td>@revizyon.Tip</td>
                                        <td>@revizyon.Baslik</td>
                                        <td>@revizyon.RevizyonTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>@(revizyon.YurutmeTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td class="text-end @(revizyon.BedelFarki >= 0 ? "text-success" : "text-danger")">@FormatSigned(revizyon.BedelFarki)</td>
                                        <td class="text-center">@revizyon.SureFarkiAy</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="card border-success h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">En Karlı Hat</small><br/>
                                <strong class="text-success">@(enKarlıHat?.HatAdi ?? "-")</strong>
                                <div class="small text-muted">@(enKarlıHat != null ? $"{enKarlıHat.GerceklesenKar:N0} ₺" : "-")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-danger h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">En Riskli Hat</small><br/>
                                <strong class="text-danger">@(enRiskliHat?.HatAdi ?? "-")</strong>
                                <div class="small text-muted">@(enRiskliHat != null ? $"{enRiskliHat.KarSapmasi:N0} ₺ kâr sapması" : "-")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-warning h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">En Yüksek Maliyet Sapması</small><br/>
                                <strong class="text-warning">@(enYuksekMaliyetSapmaliHat?.HatAdi ?? "-")</strong>
                                <div class="small text-muted">@(enYuksekMaliyetSapmaliHat != null ? $"{enYuksekMaliyetSapmaliHat.MaliyetSapmasi:N0} ₺" : "-")</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="card border-primary h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Teklif Doğruluk Skoru</small><br/>
                                <strong class="text-primary fs-5">%@gerceklesenAnaliz.TeklifDogrulukSkoru.ToString("N1")</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-secondary h-100">
                            <div class="card-body py-2 text-center">
                                <small class="text-muted">Risk Seviyesi</small><br/>
                                <span class="badge @GetRiskBadge(gerceklesenAnaliz.RiskSeviyesi) fs-6">@GetRiskMetni(gerceklesenAnaliz.RiskSeviyesi)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="alert @(gerceklesenAnaliz.MaliyetSapmasi > 0 ? "alert-danger" : "alert-success") py-2 mb-0">
                            <strong>Maliyet Sapması:</strong>
                            <span class="ms-1">@FormatSigned(gerceklesenAnaliz.MaliyetSapmasi) ₺ (%@gerceklesenAnaliz.MaliyetSapmaOrani.ToString("N1"))</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert @(gerceklesenAnaliz.GelirSapmasi >= 0 ? "alert-success" : "alert-danger") py-2 mb-0">
                            <strong>Gelir Sapması:</strong>
                            <span class="ms-1">@FormatSigned(gerceklesenAnaliz.GelirSapmasi) ₺ (%@gerceklesenAnaliz.GelirSapmaOrani.ToString("N1"))</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert @(gerceklesenAnaliz.KarSapmasi >= 0 ? "alert-success" : "alert-danger") py-2 mb-0">
                            <strong>Gerçekleşen Kâr:</strong>
                            <span class="ms-1">@gerceklesenAnaliz.GerceklesenToplamKar.ToString("N0") ₺</span>
                        </div>
                    </div>
                </div>

                @if (gerceklesenAnaliz.Kalemler.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Hat</th>
                                    <th class="text-center">Sahiplik</th>
                                    <th class="text-center">Skor</th>
                                    <th class="text-center">Risk</th>
                                    <th class="text-center">Sefer</th>
                                    <th class="text-end">Planlanan Maliyet</th>
                                    <th class="text-end">Gerçekleşen Maliyet</th>
                                    <th class="text-end">Maliyet Sapması</th>
                                    <th class="text-end">Planlanan Gelir</th>
                                    <th class="text-end">Gerçekleşen Gelir</th>
                                    <th class="text-end">Kâr Sapması</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kalem in gerceklesenAnaliz.Kalemler.OrderByDescending(x => Math.Abs(x.KarSapmasi)))
                                {
                                    <tr>
                                        <td><strong>@kalem.HatAdi</strong></td>
                                        <td class="text-center"><span class="badge @GetSahiplikBadge(ParseSahiplik(kalem.SahiplikDurumu))">@GetSahiplikMetin(ParseSahiplik(kalem.SahiplikDurumu))</span></td>
                                        <td class="text-center"><span class="badge bg-primary-subtle text-primary border">%@kalem.TeklifDogrulukSkoru.ToString("N1")</span></td>
                                        <td class="text-center"><span class="badge @GetRiskBadge(kalem.RiskSeviyesi)">@GetRiskMetni(kalem.RiskSeviyesi)</span></td>
                                        <td class="text-center">@kalem.GerceklesenSeferSayisi</td>
                                        <td class="text-end">@kalem.PlanlananMaliyet.ToString("N0")</td>
                                        <td class="text-end">@kalem.GerceklesenMaliyet.ToString("N0")</td>
                                        <td class="text-end @GetFarkTextClass(kalem.MaliyetSapmasi)">@FormatSigned(kalem.MaliyetSapmasi)</td>
                                        <td class="text-end">@kalem.PlanlananTeklif.ToString("N0")</td>
                                        <td class="text-end">@kalem.GerceklesenGelir.ToString("N0")</td>
                                        <td class="text-end @GetKarSapmaClass(kalem.KarSapmasi)">@FormatSigned(kalem.KarSapmasi)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Teklif Versiyonları -->
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-layers me-2"></i>Teklif Versiyonları</h6>
            <div class="d-flex gap-2">
                @if (!teklifVersiyonlari.Any())
                {
                    <button class="btn btn-sm btn-primary" @onclick="IlkVersiyonOlusturAsync" disabled="@(!CanManageDraftTeklif() || yukleniyor)">
                        <i class="bi bi-plus-circle me-1"></i>İlk Versiyonu Oluştur
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="RevizyonModalAc" disabled="@(!CanManageDraftTeklif() || yukleniyor || aktifTeklifVersiyon == null)">
                        <i class="bi bi-copy me-1"></i>Yeni Revizyon
                    </button>
                }
            </div>
        </div>
        <div class="card-body">
            @if (!teklifVersiyonlari.Any())
            {
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle me-2"></i>Bu proje için henüz teklif versiyonu oluşturulmamış.
                </div>
            }
            else
            {
                <AktifTeklifVersiyonKarti AktifVersiyon="aktifTeklifVersiyon" />

                <TeklifVersiyonlariTablosu Versiyonlar="teklifVersiyonlari"
                                          CanManageDraft="CanManageDraftTeklif()"
                                          CanApprovePredicate="CanApproveTeklif"
                                          CanExportPredicate="CanExportTeklif"
                                          OnSetActive="AktifVersiyonYapAsync"
                                          OnSendToReview="IncelemeyeGonderAsync"
                                          OnApprove="OnayModalAc"
                                          OnReject="RedModalAc"
                                          OnPdfExport="PdfExportAsync"
                                          OnExcelExport="ExcelExportAsync" />

                @if (teklifVersiyonlari.Count >= 2)
                {
                    <TeklifVersiyonKarsilastirmaPaneli Versiyonlar="teklifVersiyonlari"
                                                     @bind-SolVersiyonId="karsilastirmaSolVersiyonId"
                                                     @bind-SagVersiyonId="karsilastirmaSagVersiyonId"
                                                     Yukleniyor="yukleniyor"
                                                     Karsilastirma="teklifKarsilastirma"
                                                     OnCompare="VersiyonKarsilastirAsync" />
                }

                <TeklifKararGecmisiPaneli KararLoglari="teklifKararLoglari" />
            }
        </div>
    </div>

    <!-- Rakip / Piyasa Benchmark -->
    <div class="mb-3">
        <RakipBenchmarkPaneli IhaleProjeId="secilenProje.Id"
                              BizimTeklifimiz="@(aktifTeklifVersiyon?.TeklifTutari ?? 0)" />
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Sözleşme Revizyon / Ek Protokol Takibi</h6>
            <button class="btn btn-sm btn-outline-primary" @onclick="SozlesmeRevizyonModalAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Kayıt
            </button>
        </div>
        <div class="card-body">
            @if (!sozlesmeRevizyonlari.Any())
            {
                <div class="alert alert-light border mb-0">
                    <i class="bi bi-info-circle me-2"></i>Bu proje için henüz sözleşme revizyonu veya ek protokol kaydı yok.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Tip</th>
                                <th>Başlık</th>
                                <th>Tarih</th>
                                <th>Yürürlük</th>
                                <th class="text-end">Bedel Farkı</th>
                                <th class="text-center">Süre Farkı</th>
                                <th class="text-center">Durum</th>
                                <th class="text-end">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var revizyon in sozlesmeRevizyonlari)
                            {
                                <tr>
                                    <td><strong>@revizyon.RevizyonNo</strong></td>
                                    <td><span class="badge bg-secondary">@GetSozlesmeRevizyonTipiMetni(revizyon.RevizyonTipi)</span></td>
                                    <td>
                                        <div class="fw-semibold">@revizyon.Baslik</div>
                                        @if (!string.IsNullOrWhiteSpace(revizyon.Aciklama))
                                        {
                                            <div class="small text-muted">@revizyon.Aciklama</div>
                                        }
                                    </td>
                                    <td>@revizyon.RevizyonTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@(revizyon.YurutmeTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td class="text-end @(revizyon.BedelFarki >= 0 ? "text-success" : "text-danger")">@FormatSigned(revizyon.BedelFarki)</td>
                                    <td class="text-center">@revizyon.SureFarkiAy</td>
                                    <td class="text-center"><span class="badge @(revizyon.Aktif ? "bg-success" : "bg-secondary")">@(revizyon.Aktif ? "Aktif" : "Pasif")</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => SozlesmeRevizyonDuzenle(revizyon)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => SozlesmeRevizyonSilAsync(revizyon.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Hat/Güzergah Tablosu -->
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-signpost-2 me-2"></i>Güzergah/Hat Kalemleri</h6>
            <button class="btn btn-sm btn-primary" @onclick="YeniKalemModal">
                <i class="bi bi-plus me-1"></i>Hat Ekle
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Hat Adı</th>
                            <th class="text-center">Mesafe</th>
                            <th class="text-center">Sefer</th>
                            <th class="text-center">Araç</th>
                            <th class="text-center">Sahiplik</th>
                            <th class="text-end">Yakıt</th>
                            <th class="text-end">Masraf</th>
                            <th class="text-end">Şoför</th>
                            <th class="text-end">Aylık Maliyet</th>
                            <th class="text-end">Teklif</th>
                            <th class="text-end">Kâr%</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var k in aktifKalemler)
                        {
                            var topMasraf = k.AylikBakimMasrafi + k.AylikLastikMasrafi + k.AylikSigortaMasrafi +
                                k.AylikKaskoMasrafi + k.AylikMuayeneMasrafi + k.AylikYedekParcaMasrafi + k.AylikDigerMasraf +
                                k.AylikKiraBedeli + k.AylikKomisyonToplam + k.AylikAmortisman;
                            <tr>
                                <td>
                                    <strong>@k.HatAdi</strong>
                                    @if (k.AITahminiKullanildi)
                                    {
                                        <i class="bi bi-robot text-info ms-1" title="AI tahmin kullanıldı"></i>
                                    }
                                </td>
                                <td class="text-center">@k.MesafeKm km</td>
                                <td class="text-center">@k.GunlukSeferSayisi/@k.AylikSeferGunu</td>
                                <td class="text-center small">@(k.AracModelBilgi ?? "-")</td>
                                <td class="text-center">
                                    <span class="badge @GetSahiplikBadge(k.SahiplikDurumu)">@GetSahiplikMetin(k.SahiplikDurumu)</span>
                                </td>
                                <td class="text-end">@k.AylikYakitMaliyeti.ToString("N0")</td>
                                <td class="text-end">@topMasraf.ToString("N0")</td>
                                <td class="text-end">@k.SoforToplamMaliyet.ToString("N0")</td>
                                <td class="text-end fw-bold text-danger">@k.AylikMaliyet.ToString("N0")</td>
                                <td class="text-end fw-bold text-success">@k.AylikTeklifFiyati.ToString("N0")</td>
                                <td class="text-end">%@k.KarMarjiOrani.ToString("N0")</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => DuzenleKalemModal(k)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick="() => SilKalemAsync(k.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (aktifKalemler.Any())
                    {
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="5">TOPLAM</td>
                                <td class="text-end">@aktifKalemler.Sum(k => k.AylikYakitMaliyeti).ToString("N0")</td>
                                <td class="text-end">—</td>
                                <td class="text-end">@aktifKalemler.Sum(k => k.SoforToplamMaliyet).ToString("N0")</td>
                                <td class="text-end text-danger">@aktifKalemler.Sum(k => k.AylikMaliyet).ToString("N0")</td>
                                <td class="text-end text-success">@aktifKalemler.Sum(k => k.AylikTeklifFiyati).ToString("N0")</td>
                                <td class="text-end">%@(aktifKalemler.Any() ? aktifKalemler.Average(k => k.KarMarjiOrani).ToString("N0") : "0")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

    <!-- Birim Fiyat Özeti -->
    @if (aktifKalemler.Any())
    {
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="card border-primary">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Ort. Sefer Başı Teklif</small><br/>
                        <h5 class="text-primary mb-0">@aktifKalemler.Average(k => k.SeferBasiTeklifFiyati).ToString("N2") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-info">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Ort. Saatlik Teklif</small><br/>
                        <h5 class="text-info mb-0">@aktifKalemler.Average(k => k.SaatlikTeklifFiyati).ToString("N2") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-warning">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Ort. Km Başı Maliyet</small><br/>
                        <h5 class="text-warning mb-0">@aktifKalemler.Average(k => k.KmBasiMaliyet).ToString("N2") ₺</h5>
                    </div>
                </div>
            </div>
        </div>
    }

@if (sozlesmeRevizyonModalGoster)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editSozlesmeRevizyon.Id == 0 ? "Yeni Sözleşme Revizyonu / Ek Protokol" : "Sözleşme Revizyonu Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="SozlesmeRevizyonModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Tip</label>
                            <select class="form-select" @bind="editSozlesmeRevizyon.RevizyonTipi">
                                @foreach (var tip in Enum.GetValues<IhaleSozlesmeRevizyonTipi>())
                                {
                                    <option value="@tip">@GetSozlesmeRevizyonTipiMetni(tip)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Revizyon No</label>
                            <input type="text" class="form-control" @bind="editSozlesmeRevizyon.RevizyonNo" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="sozlesmeRevizyonAktif" @bind="editSozlesmeRevizyon.Aktif" />
                                <label class="form-check-label" for="sozlesmeRevizyonAktif">Aktif kayıt</label>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Başlık</label>
                            <input type="text" class="form-control" @bind="editSozlesmeRevizyon.Baslik" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Revizyon Tarihi</label>
                            <input type="date" class="form-control" @bind="editSozlesmeRevizyon.RevizyonTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Yürürlük Tarihi</label>
                            <input type="date" class="form-control" @bind="editSozlesmeRevizyon.YurutmeTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bedel Farkı</label>
                            <input type="number" step="0.01" class="form-control" @bind="editSozlesmeRevizyon.BedelFarki" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Süre Farkı (Ay)</label>
                            <input type="number" class="form-control" @bind="editSozlesmeRevizyon.SureFarkiAy" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" rows="4" @bind="editSozlesmeRevizyon.Aciklama"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="SozlesmeRevizyonModalKapat">İptal</button>
                    <button class="btn btn-primary" @onclick="SozlesmeRevizyonKaydetAsync" disabled="@yukleniyor">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

    <!-- AI Analiz Sonucu -->
    @if (!string.IsNullOrEmpty(aiAnalizSonuc))
    {
        <div class="card shadow-sm mb-3 border-purple">
            <div class="card-header bg-purple text-white d-flex justify-content-between">
                <span><i class="bi bi-robot me-2"></i>AI Proje Analizi</span>
                <button class="btn btn-sm btn-outline-light" @onclick="() => aiAnalizSonuc = null"><i class="bi bi-x"></i></button>
            </div>
            <div class="card-body" style="white-space: pre-wrap;">@aiAnalizSonuc</div>
