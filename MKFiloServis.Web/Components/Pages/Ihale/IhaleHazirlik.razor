    private void SozlesmeRevizyonModalKapat()
    {
        sozlesmeRevizyonModalGoster = false;
        editSozlesmeRevizyon = new();
    }

    private async Task SozlesmeRevizyonKaydetAsync()
    {
        if (secilenProje == null || string.IsNullOrWhiteSpace(editSozlesmeRevizyon.Baslik))
            return;

        try
        {
            yukleniyor = true;
            editSozlesmeRevizyon.IhaleProjeId = secilenProje.Id;

            if (editSozlesmeRevizyon.Id == 0)
                await IhaleService.AddSozlesmeRevizyonAsync(editSozlesmeRevizyon);
            else
                await IhaleService.UpdateSozlesmeRevizyonAsync(editSozlesmeRevizyon);

            await RefreshSozlesmeRevizyonlariAsync();
            SozlesmeRevizyonModalKapat();
            ToastService.ShowSuccess("Sözleşme revizyon kaydı kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private async Task SozlesmeRevizyonSilAsync(int revizyonId)
    {
