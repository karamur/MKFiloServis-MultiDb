    }

    private bool HasAnyRole(params string[] roller)
    {
        var rolAdi = aktifKullanici?.Rol?.RolAdi;
        if (string.IsNullOrWhiteSpace(rolAdi))
            return false;

        return roller.Any(rol => string.Equals(rolAdi, rol, StringComparison.OrdinalIgnoreCase));
    }

