            };

            var rows = gerceklesenAnaliz.Kalemler
                .Select(x => new object[]
                {
                    x.HatAdi,
                    x.SahiplikDurumu,
                    x.TeklifDogrulukSkoru,
                    x.RiskSeviyesi,
                    x.GerceklesenSeferSayisi,
                    x.PlanlananMaliyet,
                    x.GerceklesenMaliyet,
                    x.MaliyetSapmasi,
                    x.PlanlananTeklif,
                    x.GerceklesenGelir,
                    x.GelirSapmasi,
                    x.PlanlananKar,
                    x.GerceklesenKar,
                    x.KarSapmasi
                })
                .ToList();

            rows.Add(new object[]
            {
                "TOPLAM",
                string.Empty,
                gerceklesenAnaliz.TeklifDogrulukSkoru,
                gerceklesenAnaliz.RiskSeviyesi,
                gerceklesenAnaliz.ToplamGerceklesenSeferSayisi,
                gerceklesenAnaliz.PlanlananToplamMaliyet,
                gerceklesenAnaliz.GerceklesenToplamMaliyet,
                gerceklesenAnaliz.MaliyetSapmasi,
                gerceklesenAnaliz.PlanlananToplamTeklif,
                gerceklesenAnaliz.GerceklesenToplamGelir,
                gerceklesenAnaliz.GelirSapmasi,
                gerceklesenAnaliz.PlanlananToplamKar,
                gerceklesenAnaliz.GerceklesenToplamKar,
                gerceklesenAnaliz.KarSapmasi
            });

            var bytes = ExcelService.CreateExcel(headers, rows, "GerceklesenAnaliz");
