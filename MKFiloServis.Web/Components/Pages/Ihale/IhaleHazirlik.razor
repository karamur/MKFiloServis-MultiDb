            yukleniyor = true;
            await IhaleService.DeleteSozlesmeRevizyonAsync(revizyonId);
            await RefreshSozlesmeRevizyonlariAsync();
            ToastService.ShowSuccess("Sözleşme revizyon kaydı silindi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            yukleniyor = false;
        }
    }

