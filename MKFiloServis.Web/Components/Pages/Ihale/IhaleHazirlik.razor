    private string GetTeklifExportFileName(int versiyonId, string extension)
    {
        var versiyon = teklifVersiyonlari.FirstOrDefault(x => x.Id == versiyonId);
        var projeKodu = SanitizeFileNamePart(secilenProje?.ProjeKodu);
        var revizyonKodu = SanitizeFileNamePart(versiyon?.RevizyonKodu);

        if (string.IsNullOrWhiteSpace(projeKodu))
            projeKodu = $"Proje-{secilenProje?.Id ?? 0}";

        if (string.IsNullOrWhiteSpace(revizyonKodu))
            revizyonKodu = $"Versiyon-{versiyonId}";

        return $"IhaleTeklif_{projeKodu}_{revizyonKodu}.{extension}";
    }

    private static string SanitizeFileNamePart(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var invalidChars = Path.GetInvalidFileNameChars();
        var sanitized = new string(value.Trim().Select(ch => invalidChars.Contains(ch) ? '-' : ch).ToArray());

        return sanitized.Replace(' ', '-');
    }

