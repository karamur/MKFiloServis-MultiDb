<style>
    .btn-purple { background-color: #7c3aed; color: white; border: none; }
    .btn-purple:hover { background-color: #6d28d9; color: white; }
    .bg-purple { background-color: #7c3aed !important; }
    .border-purple { border-color: #7c3aed !important; }
</style>

@code {
    [Parameter] public int? ProjeId { get; set; }

    private List<IhaleProje>? projeler;
    private IhaleProje? secilenProje;
    private List<IhaleGuzergahKalem> aktifKalemler = [];
    private List<IhaleTeklifVersiyon> teklifVersiyonlari = [];
    private List<IhaleTeklifKararLog> teklifKararLoglari = [];
    private List<Cari>? tumCariler;
    private List<Guzergah> tumGuzergahlar = [];
    private List<Arac> tumAraclar = [];
    private Kullanici? aktifKullanici;
    private IhaleTeklifVersiyon? aktifTeklifVersiyon;
    private IhaleGerceklesenAnalizOzet? gerceklesenAnaliz;
    private IhaleOperasyonDashboardOzet? operasyonDashboard;
    private List<IhaleSozlesmeRevizyon> sozlesmeRevizyonlari = [];

    private IhaleProje editProje = new();
    private IhaleGuzergahKalem editKalem = new();
    private IhaleSozlesmeRevizyon editSozlesmeRevizyon = new();

    private bool projeModalGoster;
    private bool kalemModalGoster;
    private bool revizyonModalGoster;
    private bool kararModalGoster;
    private bool sozlesmeRevizyonModalGoster;
    private bool yukleniyor;
    private bool aiAktif;
    private bool aiYukleniyor;
    private bool raporGoster;
    private bool redIslemi;

    private string? aiAnalizSonuc;
    private string? aiTahminMesaj;
    private string? aiMaasTahminMesaj;
    private string? kalemOneriMesaji;
    private string? yakitFiyatMesaji;
    private string? editKalemBolge;
    private string? revizyonNotu;
    private string kararNotu = string.Empty;
    private int? seciliTeklifVersiyonId;
    private int? karsilastirmaSolVersiyonId;
    private int? karsilastirmaSagVersiyonId;
    private IhaleTeklifKarsilastirmaDto? teklifKarsilastirma;

    private IhaleProjeOzet? projeOzet;

    protected override async Task OnInitializedAsync()
    {
        aiAktif = await OllamaService.BaglantiKontrolAsync();
        tumCariler = await CariService.GetAllAsync();
        tumGuzergahlar = await GuzergahService.GetActiveAsync();
        tumAraclar = await AracService.GetActiveAsync();
        aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();

        if (ProjeId.HasValue)
            await ProjeSecAsync(ProjeId.Value);
        else
            await LoadProjelerAsync();
    }

    private async Task LoadProjelerAsync()
    {
        projeler = await IhaleService.GetProjelerAsync();
        operasyonDashboard = await IhaleService.GetOperasyonDashboardOzetAsync();
    }

    // ===== Proje İşlemleri =====

    private void YeniProjeModal()
    {
        editProje = new IhaleProje
        {
            BaslangicTarihi = DateTime.Today,
            BitisTarihi = DateTime.Today.AddMonths(12),
            SozlesmeSuresiAy = 12,
            AylikCalismGunu = 22,
            GunlukCalismaSaati = 8,
            EnflasyonOrani = 25,
            YakitZamOrani = 30
        };
        projeModalGoster = true;
    }

    private void ProjeAyarModal()
    {
        if (secilenProje == null) return;
        editProje = secilenProje;
        projeModalGoster = true;
    }

    private async Task KaydetProjeAsync()
    {
        if (string.IsNullOrWhiteSpace(editProje.ProjeAdi)) return;
        yukleniyor = true;

        try
        {
            if (editProje.Id == 0)
            {
                var yeni = await IhaleService.CreateProjeAsync(editProje);
                await ProjeSecAsync(yeni.Id);
            }
            else
            {
                await IhaleService.UpdateProjeAsync(editProje);
                secilenProje = await IhaleService.GetProjeByIdAsync(editProje.Id);
                RefreshKalemler();
            }
            projeModalGoster = false;
            ToastService.ShowSuccess("Proje kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally { yukleniyor = false; }
    }

    private async Task ProjeSecAsync(int projeId)
    {
        secilenProje = await IhaleService.GetProjeByIdAsync(projeId);
        RefreshKalemler();
        await RefreshTeklifVersiyonlariAsync();
        await RefreshGerceklesenAnalizAsync();
        await RefreshSozlesmeRevizyonlariAsync();
    }

    private void RefreshKalemler()
    {
        aktifKalemler = secilenProje?.Kalemler?.Where(k => !k.IsDeleted).ToList() ?? [];
    }

    private async Task ListeyeDon()
    {
        secilenProje = null;
        raporGoster = false;
        aiAnalizSonuc = null;
        projeOzet = null;
        teklifVersiyonlari = [];
        teklifKararLoglari = [];
        aktifTeklifVersiyon = null;
        await LoadProjelerAsync();
    }

    private async Task RefreshTeklifVersiyonlariAsync()
    {
        if (secilenProje == null)
        {
            teklifVersiyonlari = [];
            teklifKararLoglari = [];
            aktifTeklifVersiyon = null;
            teklifKarsilastirma = null;
            sozlesmeRevizyonlari = [];
            return;
        }

        teklifVersiyonlari = await TeklifVersiyonService.GetListByIhaleProjeIdAsync(secilenProje.Id);
        aktifTeklifVersiyon = teklifVersiyonlari.FirstOrDefault(x => x.AktifVersiyon);
        teklifKararLoglari = aktifTeklifVersiyon != null
            ? await TeklifVersiyonService.GetKararLoglariAsync(aktifTeklifVersiyon.Id)
            : [];

        if (karsilastirmaSolVersiyonId.HasValue && !teklifVersiyonlari.Any(x => x.Id == karsilastirmaSolVersiyonId.Value))
            karsilastirmaSolVersiyonId = null;

        if (karsilastirmaSagVersiyonId.HasValue && !teklifVersiyonlari.Any(x => x.Id == karsilastirmaSagVersiyonId.Value))
            karsilastirmaSagVersiyonId = null;

        teklifKarsilastirma = null;
    }

