    private string GetBosDurumMesaji()
    {
        return FiltreVarMi
            ? "Filtrelere uygun teklif versiyonu bulunamadı."
            : "Gösterilecek teklif versiyonu bulunamadı.";
    }

    private string GetBosDurumIconClass()
    {
        return FiltreVarMi ? "bi-search" : "bi-inbox";
    }

    private async Task KaydetStateAsync()
    {
        try
        {
            var state = new TeklifVersiyonTabloState
            {
                DurumFiltresi = durumFiltresi,
                SadeceAktiflariGoster = sadeceAktiflariGoster,
                AramaMetni = aramaMetni,
                SiralamaAlani = siralamaAlani,
                SiralamaArtan = siralamaArtan
            };

            var stateJson = System.Text.Json.JsonSerializer.Serialize(state);
            await JS.InvokeVoidAsync("setLocalStorageItem", TableStateStorageKey, stateJson);
        }
        catch
        {
        }
    }

    private sealed class TeklifVersiyonTabloState
    {
        public string? DurumFiltresi { get; set; }
        public bool SadeceAktiflariGoster { get; set; }
        public string? AramaMetni { get; set; }
        public string SiralamaAlani { get; set; } = "Versiyon";
        public bool SiralamaArtan { get; set; }
    }

}

