@using MKFiloServis.Shared.Entities

@if (KararLoglari.Any())
{
    <div class="mt-3 border-top pt-3">
        <h6 class="mb-3"><i class="bi bi-clock-history me-2"></i>Aktif Versiyon Karar Geçmişi</h6>
        <div class="small">
            @foreach (var log in KararLoglari.Take(8))
            {
                <div class="d-flex justify-content-between align-items-start py-2 border-bottom">
                    <div>
                        <div class="fw-semibold">@GetTeklifIslemTipiMetni(log.IslemTipi)</div>
                        <div class="text-muted">@(string.IsNullOrWhiteSpace(log.Not) ? "Not girilmedi." : log.Not)</div>
                    </div>
                    <div class="text-end text-muted">
                        <div>@(log.IslemYapanKullanici?.AdSoyad ?? "-")</div>
                        <div>@log.IslemTarihi.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public List<IhaleTeklifKararLog> KararLoglari { get; set; } = [];

    private static string GetTeklifIslemTipiMetni(IhaleTeklifIslemTipi islemTipi)
    {
        return islemTipi switch
        {
            IhaleTeklifIslemTipi.Olustur => "İlk versiyon oluşturuldu",
            IhaleTeklifIslemTipi.RevizyonOlustur => "Revizyon oluşturuldu",
            IhaleTeklifIslemTipi.IncelemeyeGonder => "İncelemeye gönderildi",
            IhaleTeklifIslemTipi.Onayla => "Onaylandı",
            IhaleTeklifIslemTipi.Reddet => "Reddedildi",
            IhaleTeklifIslemTipi.AktifVersiyonDegisti => "Aktif versiyon değişti",
            _ => "İşlem"
        };
    }
}

