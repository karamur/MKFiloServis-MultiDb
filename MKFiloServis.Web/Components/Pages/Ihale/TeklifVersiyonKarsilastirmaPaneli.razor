@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Models

<div class="mt-3 border-top pt-3">
    <h6 class="mb-3"><i class="bi bi-columns-gap me-2"></i>Versiyon Karşılaştırma</h6>
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Sol Versiyon</label>
            <select class="form-select form-select-sm" @bind="SelectedSolVersiyonId">
                <option value="">-- Seçiniz --</option>
                @foreach (var item in Versiyonlar)
                {
                    <option value="@item.Id">@item.RevizyonKodu - @GetTeklifDurumMetni(item.Durum)</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Sağ Versiyon</label>
            <select class="form-select form-select-sm" @bind="SelectedSagVersiyonId">
                <option value="">-- Seçiniz --</option>
                @foreach (var item in Versiyonlar)
                {
                    <option value="@item.Id">@item.RevizyonKodu - @GetTeklifDurumMetni(item.Durum)</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <button class="btn btn-outline-secondary btn-sm w-100" @onclick="() => OnCompare.InvokeAsync()" disabled="@(!SelectedSolVersiyonId.HasValue || !SelectedSagVersiyonId.HasValue || Yukleniyor)">
                <i class="bi bi-bar-chart-line me-1"></i>Karşılaştır
            </button>
        </div>
    </div>

    @if (Karsilastirma != null)
    {
        <div class="table-responsive mt-3">
            <table class="table table-sm table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Alan</th>
                        <th class="text-end">@Karsilastirma.SolRevizyonKodu</th>
                        <th class="text-end">@Karsilastirma.SagRevizyonKodu</th>
                        <th class="text-end">Fark</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Toplam Maliyet</td>
                        <td class="text-end">@Karsilastirma.SolToplamMaliyet.ToString("N0")</td>
                        <td class="text-end">@Karsilastirma.SagToplamMaliyet.ToString("N0")</td>
                        <td class="text-end @GetFarkTextClass(Karsilastirma.ToplamMaliyetFarki)">@FormatSigned(Karsilastirma.ToplamMaliyetFarki)</td>
                    </tr>
                    <tr>
                        <td>Teklif Tutarı</td>
                        <td class="text-end">@Karsilastirma.SolTeklifTutari.ToString("N0")</td>
                        <td class="text-end">@Karsilastirma.SagTeklifTutari.ToString("N0")</td>
                        <td class="text-end @GetFarkTextClass(Karsilastirma.TeklifTutariFarki)">@FormatSigned(Karsilastirma.TeklifTutariFarki)</td>
                    </tr>
                    <tr>
                        <td>Kâr Tutarı</td>
                        <td class="text-end">@Karsilastirma.SolKarMarjiTutari.ToString("N0")</td>
                        <td class="text-end">@Karsilastirma.SagKarMarjiTutari.ToString("N0")</td>
                        <td class="text-end @GetFarkTextClass(Karsilastirma.KarMarjiTutariFarki)">@FormatSigned(Karsilastirma.KarMarjiTutariFarki)</td>
                    </tr>
                    <tr>
                        <td>Kâr Marjı %</td>
                        <td class="text-end">%@Karsilastirma.SolKarMarjiOrani.ToString("N1")</td>
                        <td class="text-end">%@Karsilastirma.SagKarMarjiOrani.ToString("N1")</td>
                        <td class="text-end @GetFarkTextClass(Karsilastirma.KarMarjiOraniFarki)">%@(FormatSigned(Karsilastirma.KarMarjiOraniFarki))</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [Parameter] public List<IhaleTeklifVersiyon> Versiyonlar { get; set; } = [];
    [Parameter] public int? SolVersiyonId { get; set; }
    [Parameter] public EventCallback<int?> SolVersiyonIdChanged { get; set; }
    [Parameter] public int? SagVersiyonId { get; set; }
    [Parameter] public EventCallback<int?> SagVersiyonIdChanged { get; set; }
    [Parameter] public bool Yukleniyor { get; set; }
    [Parameter] public EventCallback OnCompare { get; set; }
    [Parameter] public IhaleTeklifKarsilastirmaDto? Karsilastirma { get; set; }

    private int? SelectedSolVersiyonId
    {
        get => SolVersiyonId;
        set => SolVersiyonIdChanged.InvokeAsync(value);
    }

    private int? SelectedSagVersiyonId
    {
        get => SagVersiyonId;
        set => SagVersiyonIdChanged.InvokeAsync(value);
    }

    private static string GetTeklifDurumMetni(IhaleTeklifVersiyonDurum durum)
    {
        return durum switch
        {
            IhaleTeklifVersiyonDurum.Taslak => "Taslak",
            IhaleTeklifVersiyonDurum.Incelemede => "İncelemede",
            IhaleTeklifVersiyonDurum.Onaylandi => "Onaylandı",
            IhaleTeklifVersiyonDurum.Reddedildi => "Reddedildi",
            _ => "-"
        };
    }

    private static string GetFarkTextClass(decimal fark)
    {
        if (fark > 0)
            return "text-danger fw-semibold";
        if (fark < 0)
            return "text-success fw-semibold";

        return "text-muted";
    }

    private static string FormatSigned(decimal deger)
    {
        return deger > 0 ? $"+{deger:N0}" : deger.ToString("N0");
    }
}

