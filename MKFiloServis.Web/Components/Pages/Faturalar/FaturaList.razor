@page "/faturalar"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Components.Shared
@inject IFaturaService FaturaService
@inject IFirmaService FirmaService
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Faturalar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-receipt me-2"></i>Faturalar</h3>
        <button class="btn btn-primary" @onclick="YeniFatura">
            <i class="bi bi-plus-lg me-1"></i>Yeni Fatura
        </button>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-3">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Ara (Fatura No, Cari...)"
                               @bind="aramaMetni" @bind:event="oninput" @bind:after="FiltreUygula" />
                    </div>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreTip" @bind:after="() => FiltreUygulaAninda()">
                        <option value="">Tum Tipler</option>
                        <option value="SatisFaturasi">Satis</option>
                        <option value="AlisFaturasi">Alis</option>
                        <option value="SatisIadeFaturasi">Satis Iade</option>
                        <option value="AlisIadeFaturasi">Alis Iade</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreYon" @bind:after="() => FiltreUygulaAninda()">
                        <option value="">Tum Yönler</option>
                        <option value="Giden">Kesilen</option>
                        <option value="Gelen">Gelen</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreFirmaId" @bind:after="() => FiltreUygulaAninda()">
                        <option value="">Tum Firmalar</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreDurum" @bind:after="() => FiltreUygulaAninda()">
                        <option value="">Tum Durumlar</option>
                        <option value="Beklemede">Beklemede</option>
                        <option value="KismiOdendi">Kismi Odendi</option>
                        <option value="Odendi">Odendi</option>
                        <option value="IptalEdildi">Iptal</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <input type="date" class="form-control form-control-sm" @bind="baslangicTarih" @bind:after="() => FiltreUygulaAninda()" />
                </div>
                <div class="col-md-1">
                    <input type="date" class="form-control form-control-sm" @bind="bitisTarih" @bind:after="() => FiltreUygulaAninda()" />
                </div>
                <div class="col-md-1 text-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreleriTemizle" title="Temizle">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yukleniyor...</span>
            </div>
        </div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Filtrelere uygun fatura bulunamadi.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Fatura No</th>
                                <th>Tarih</th>
                                <th>Firma</th>
                                <th>Cari</th>
                                <th>Yön</th>
                                <th>Tip</th>
                                <th class="text-end">Genel Toplam</th>
                                <th class="text-end">Odenen</th>
                                <th class="text-end">Kalan</th>
                                <th>Durum</th>
                                <th style="width: 120px;">Islemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fatura in pagedResult.Items)
                            {
                                <tr>
                                    <td>
                                        <div><strong>@fatura.FaturaNo</strong></div>
                                        <div class="d-flex flex-wrap gap-1 mt-1">
                                            <span class="badge text-bg-light border">@(fatura.Firma?.FirmaAdi ?? "Firma Yok")</span>
                                            <span class="badge @(fatura.FaturaYonu == FaturaYonu.Giden ? "bg-success" : "bg-primary")">
                                                @(fatura.FaturaYonu == FaturaYonu.Giden ? "Kesilen" : "Gelen")
                                            </span>
                                            @if (fatura.FirmalarArasiFatura)
                                            {
                                                <span class="badge bg-info text-dark">Firmalar Arası</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <div>@(fatura.Firma?.FirmaAdi ?? "-")</div>
                                        @if (fatura.FirmalarArasiFatura && fatura.KarsiFirma != null)
                                        {
                                            <div class="mt-1">
                                                <span class="badge text-bg-secondary">Karşı: @fatura.KarsiFirma.FirmaAdi</span>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div>@fatura.Cari?.Unvan</div>
                                        <small class="text-muted">@GetKisaKimlikMetni(fatura)</small>
                                    </td>
                                    <td>
                                        <span class="badge @(fatura.FaturaYonu == FaturaYonu.Giden ? "bg-success" : "bg-primary")">
                                            @(fatura.FaturaYonu == FaturaYonu.Giden ? "Kesilen" : "Gelen")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetTipBadgeClass(fatura.FaturaTipi)">
                                            @GetTipText(fatura.FaturaTipi)
                                        </span>
                                    </td>
                                    <td class="text-end"><strong>@fatura.GenelToplam.ToString("N2") TL</strong></td>
                                    <td class="text-end text-success">@fatura.OdenenTutar.ToString("N2") TL</td>
                                    <td class="text-end text-danger">@fatura.KalanTutar.ToString("N2") TL</td>
                                    <td>
                                        <span class="badge @GetDurumBadgeClass(fatura.Durum)">
                                            @GetDurumText(fatura.Durum)
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-info me-1" @onclick="() => Detay(fatura.Id)" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(fatura.Id)" title="Duzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(fatura)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary">
                            <tr>
                                <td colspan="6"><strong>Sayfa Toplami (@pagedResult.Items.Count kayit)</strong></td>
                                <td class="text-end"><strong>@pagedResult.Items.Sum(f => f.GenelToplam).ToString("N2") TL</strong></td>
                                <td class="text-end text-success"><strong>@pagedResult.Items.Sum(f => f.OdenenTutar).ToString("N2") TL</strong></td>
                                <td class="text-end text-danger"><strong>@pagedResult.Items.Sum(f => f.KalanTutar).ToString("N2") TL</strong></td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Sayfalama -->
        <Pagination 
            CurrentPage="@currentPage"
            PageSize="@pageSize"
            TotalItems="@(pagedResult?.TotalCount ?? 0)"
            OnPageChanged="OnPageChanged"
            PageSizeChanged="OnPageSizeChanged" />
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayi</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekFatura?.FaturaNo</strong> numarali faturayi silmek istediginize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">Iptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<Fatura>? pagedResult;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Fatura? silinecekFatura;
    private List<Firma> firmalar = new();

    // Sayfalama
    private int currentPage = 1;
    private int pageSize = 25;

    // Filtre degiskenleri
    private string aramaMetni = "";
    private string filtreTip = "";
    private string filtreYon = "";
    private string filtreFirmaId = "";
    private string filtreDurum = "";
    private DateTime? baslangicTarih;
    private DateTime? bitisTarih;

    // Debounce icin timer
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        var filter = new FaturaFilterParams
        {
            PageNumber = currentPage,
            PageSize = pageSize,
            SearchTerm = aramaMetni,
            FaturaTipi = string.IsNullOrEmpty(filtreTip) ? null : Enum.Parse<FaturaTipi>(filtreTip),
            Yon = string.IsNullOrEmpty(filtreYon) ? null : Enum.Parse<FaturaYonu>(filtreYon),
            FirmaId = string.IsNullOrEmpty(filtreFirmaId) ? null : int.Parse(filtreFirmaId),
            Durum = string.IsNullOrEmpty(filtreDurum) ? null : Enum.Parse<FaturaDurum>(filtreDurum),
            BaslangicTarih = baslangicTarih,
            BitisTarih = bitisTarih
        };

        pagedResult = await FaturaService.GetPagedAsync(filter);
        isLoading = false;
        StateHasChanged();
    }

    private void FiltreUygula()
    {
        // Debounce: Kullanici yazmayi bitirene kadar bekle
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (s, e) =>
        {
            _debounceTimer?.Stop();
            currentPage = 1;
            await InvokeAsync(async () =>
            {
                await LoadData();
            });
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task FiltreUygulaAninda()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task FiltreleriTemizle()
    {
        aramaMetni = "";
        filtreTip = "";
        filtreYon = "";
        filtreFirmaId = "";
        filtreDurum = "";
        baslangicTarih = null;
        bitisTarih = null;
        currentPage = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int page)
    {
        currentPage = page;
        await LoadData();
    }

    private async Task OnPageSizeChanged(int size)
    {
        pageSize = size;
        currentPage = 1;
        await LoadData();
    }

    private void YeniFatura()
    {
        Navigation.NavigateTo("/faturalar/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/faturalar/{id}");
    }

    private void Detay(int id)
    {
        Navigation.NavigateTo($"/faturalar/detay/{id}");
    }

    private void SilOnay(Fatura fatura)
    {
        silinecekFatura = fatura;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekFatura != null)
        {
            await FaturaService.DeleteAsync(silinecekFatura.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekFatura = null;
    }

    public void Dispose()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
    }

    private string GetTipText(FaturaTipi tip) => tip switch
    {
        FaturaTipi.SatisFaturasi => "Satis",
        FaturaTipi.AlisFaturasi => "Alis",
        FaturaTipi.SatisIadeFaturasi => "Satis Iade",
        FaturaTipi.AlisIadeFaturasi => "Alis Iade",
        _ => tip.ToString()
    };

    private string GetTipBadgeClass(FaturaTipi tip) => tip switch
    {
        FaturaTipi.SatisFaturasi => "bg-success",
        FaturaTipi.AlisFaturasi => "bg-primary",
        FaturaTipi.SatisIadeFaturasi => "bg-warning text-dark",
        FaturaTipi.AlisIadeFaturasi => "bg-info",
        _ => "bg-secondary"
    };

    private string GetDurumText(FaturaDurum durum) => durum switch
    {
        FaturaDurum.Beklemede => "Beklemede",
        FaturaDurum.KismiOdendi => "Kismi Odendi",
        FaturaDurum.Odendi => "Odendi",
        FaturaDurum.IptalEdildi => "Iptal",
        _ => durum.ToString()
    };

    private string GetDurumBadgeClass(FaturaDurum durum) => durum switch
    {
        FaturaDurum.Beklemede => "bg-warning text-dark",
        FaturaDurum.KismiOdendi => "bg-info",
        FaturaDurum.Odendi => "bg-success",
        FaturaDurum.IptalEdildi => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetKisaKimlikMetni(Fatura fatura)
    {
        var firmaAdi = fatura.Firma?.FirmaAdi ?? "Firma Yok";
        var yonText = fatura.FaturaYonu == FaturaYonu.Giden ? "Kesilen" : "Gelen";
        return $"{firmaAdi} • {yonText}";
    }
}

