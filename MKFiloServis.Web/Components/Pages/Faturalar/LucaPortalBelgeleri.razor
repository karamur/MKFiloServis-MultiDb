@page "/faturalar/luca-portal"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject ILucaPortalService LucaService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Luca Portal Belgeleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3><i class="bi bi-cloud-download me-2"></i>Luca Portal Belgeleri</h3>
            <small class="text-muted">E-Fatura ve E-Arsiv belgelerini goruntule, indir ve sisteme aktar</small>
        </div>
        <div>
            @if (baglantiDurumu)
            {
                <span class="badge bg-success me-2"><i class="bi bi-check-circle me-1"></i>Bagli</span>
            }
            else
            {
                <span class="badge bg-danger me-2"><i class="bi bi-x-circle me-1"></i>Bagli Degil</span>
                <a href="/ayarlar/luca-portal" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-gear me-1"></i>Ayarlara Git
                </a>
            }
        </div>
    </div>

    @if (!baglantiDurumu)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Luca Portal'a bagli degilsiniz. Lutfen once <a href="/ayarlar/luca-portal">ayarlar</a> sayfasindan giris yapin.
        </div>
    }
    else
    {
        <!-- Filtre -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Belge Tipi</label>
                        <select class="form-select" @bind="filtre.BelgeTipi">
                            <option value="@LucaBelgeTipi.EFatura">E-Fatura</option>
                            <option value="@LucaBelgeTipi.EArsiv">E-Arsiv</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Belge Yonu</label>
                        <select class="form-select" @bind="filtre.BelgeYonu">
                            <option value="@LucaBelgeYonu.Gelen">Gelen</option>
                            <option value="@LucaBelgeYonu.Giden">Giden / Kesilen</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Baslangic Tarihi</label>
                        <input type="date" class="form-control" @bind="filtre.BaslangicTarihi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Bitis Tarihi</label>
                        <input type="date" class="form-control" @bind="filtre.BitisTarihi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">VKN/TCKN</label>
                        <input type="text" class="form-control" @bind="filtre.VknArama" placeholder="Ara..." />
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" @onclick="BelgeleriGetir" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-search me-1"></i>
                            }
                            Listele
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sonuc Ozeti ve Toplu Islem Butonlari -->
        @if (sonuc.Belgeler.Any())
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <span class="text-muted">
                        Toplam <strong>@sonuc.ToplamKayit</strong> belge bulundu 
                        (Sayfa @sonuc.Sayfa / @sonuc.ToplamSayfa)
                    </span>
                </div>
                <div class="btn-group">
                    <button class="btn btn-outline-success" @onclick="SecilenleriAktar" 
                            disabled="@(!secilenBelgeler.Any() || isImporting)">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-database-add me-1"></i>
                        }
                        Secilenleri Aktar (@secilenBelgeler.Count)
                    </button>
                    <button class="btn btn-outline-primary" @onclick="SecilenleriXmlIndir" 
                            disabled="@(!secilenBelgeler.Any() || isDownloading)">
                        <i class="bi bi-file-code me-1"></i>XML Indir
                    </button>
                    <button class="btn btn-outline-danger" @onclick="SecilenleriPdfIndir" 
                            disabled="@(!secilenBelgeler.Any() || isDownloading)">
                        <i class="bi bi-file-pdf me-1"></i>PDF Indir
                    </button>
                </div>
            </div>
        }

        <!-- Belge Listesi -->
        <div class="card">
            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Belgeler yukleniyor...</p>
                    </div>
                }
                else if (!sonuc.Belgeler.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox display-4"></i>
                        <p class="mt-2">Belge bulunamadi. Filtre kriterlerini degistirerek tekrar deneyin.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">
                                        <input type="checkbox" class="form-check-input" 
                                               @onchange="TumunuSecToggle" 
                                               checked="@(secilenBelgeler.Count == sonuc.Belgeler.Count && sonuc.Belgeler.Any())" />
                                    </th>
                                    <th>Fatura No</th>
                                    <th>ETTN</th>
                                    <th>Tarih</th>
                                    <th>@(filtre.BelgeYonu == LucaBelgeYonu.Gelen ? "Gonderen" : "Alici")</th>
                                    <th>VKN</th>
                                    <th class="text-end">Tutar</th>
                                    <th>Durum</th>
                                    <th class="text-center">Dosyalar</th>
                                    <th style="width: 100px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var belge in sonuc.Belgeler)
                                {
                                    <tr class="@(secilenBelgeler.Contains(belge.BelgeId) ? "table-primary" : "")">
                                        <td>
                                            <input type="checkbox" class="form-check-input" 
                                                   checked="@secilenBelgeler.Contains(belge.BelgeId)"
                                                   @onchange="() => BelgeSecimToggle(belge.BelgeId)" />
                                        </td>
                                        <td>
                                            <strong>@belge.FaturaNo</strong>
                                            @if (belge.BelgeTipi == LucaBelgeTipi.EFatura)
                                            {
                                                <span class="badge bg-primary ms-1">E-Fatura</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info ms-1">E-Arsiv</span>
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted font-monospace">@TruncateEttn(belge.EttnNo)</small>
                                        </td>
                                        <td>@belge.BelgeTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            @if (filtre.BelgeYonu == LucaBelgeYonu.Gelen)
                                            {
                                                @belge.GondericiUnvan
                                            }
                                            else
                                            {
                                                @belge.AliciUnvan
                                            }
                                        </td>
                                        <td>
                                            <small class="font-monospace">
                                                @(filtre.BelgeYonu == LucaBelgeYonu.Gelen ? belge.GondericiVkn : belge.AliciVkn)
                                            </small>
                                        </td>
                                        <td class="text-end">
                                            <strong>@belge.GenelToplam.ToString("N2") TL</strong>
                                        </td>
                                        <td>
                                            <span class="badge @GetDurumBadgeClass(belge.Durum)">@belge.Durum</span>
                                        </td>
                                        <td class="text-center">
                                            @if (belge.XmlMevcut)
                                            {
                                                <i class="bi bi-file-code text-success me-1" title="XML Mevcut"></i>
                                            }
                                            @if (belge.PdfMevcut)
                                            {
                                                <i class="bi bi-file-pdf text-danger" title="PDF Mevcut"></i>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                @if (belge.XmlMevcut)
                                                {
                                                    <button class="btn btn-outline-success" @onclick="() => XmlIndir(belge)" title="XML Indir">
                                                        <i class="bi bi-file-code"></i>
                                                    </button>
                                                }
                                                @if (belge.PdfMevcut)
                                                {
                                                    <button class="btn btn-outline-danger" @onclick="() => PdfIndir(belge)" title="PDF Indir">
                                                        <i class="bi bi-file-pdf"></i>
                                                    </button>
                                                }
                                                <button class="btn btn-outline-primary" @onclick="() => SistemeAktar(belge)" title="Sisteme Aktar">
                                                    <i class="bi bi-database-add"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Sayfalama -->
                    @if (sonuc.ToplamSayfa > 1)
                    {
                        <div class="card-footer">
                            <nav>
                                <ul class="pagination pagination-sm justify-content-center mb-0">
                                    <li class="page-item @(filtre.Sayfa <= 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => SayfaDegistir(filtre.Sayfa - 1)">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                    </li>
                                    @for (int i = 1; i <= Math.Min(sonuc.ToplamSayfa, 10); i++)
                                    {
                                        var sayfa = i;
                                        <li class="page-item @(filtre.Sayfa == sayfa ? "active" : "")">
                                            <button class="page-link" @onclick="() => SayfaDegistir(sayfa)">@sayfa</button>
                                        </li>
                                    }
                                    <li class="page-item @(filtre.Sayfa >= sonuc.ToplamSayfa ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => SayfaDegistir(filtre.Sayfa + 1)">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Indirme/Aktarma Islemi -->
        @if (!string.IsNullOrEmpty(islemMesaji))
        {
            <div class="alert alert-info mt-3">
                <i class="bi bi-info-circle me-2"></i>@islemMesaji
            </div>
        }
    }
</div>

@code {
    private LucaSorguFiltre filtre = new()
    {
        BaslangicTarihi = DateTime.Today.AddMonths(-1),
        BitisTarihi = DateTime.Today,
        BelgeTipi = LucaBelgeTipi.EFatura,
        BelgeYonu = LucaBelgeYonu.Gelen
    };
    
    private LucaSorguSonuc sonuc = new();
    private HashSet<string> secilenBelgeler = new();
    
    private bool baglantiDurumu = false;
    private bool isLoading = false;
    private bool isDownloading = false;
    private bool isImporting = false;
    private string? islemMesaji;

    protected override async Task OnInitializedAsync()
    {
        await BaglantiKontrol();
    }

    private async Task BaglantiKontrol()
    {
        baglantiDurumu = await LucaService.BaglantiTestiAsync();
    }

    private async Task BelgeleriGetir()
    {
        isLoading = true;
        secilenBelgeler.Clear();
        islemMesaji = null;
        
        try
        {
            if (filtre.BelgeTipi == LucaBelgeTipi.EFatura)
            {
                sonuc = await LucaService.EFaturaListeleAsync(filtre);
            }
            else
            {
                sonuc = await LucaService.EArsivListeleAsync(filtre);
            }
            
            if (!sonuc.Belgeler.Any())
            {
                ToastService.ShowInfo("Belirtilen kriterlere uygun belge bulunamadi");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Belgeler alinamadi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SayfaDegistir(int yeniSayfa)
    {
        filtre.Sayfa = yeniSayfa;
        await BelgeleriGetir();
    }

    private void BelgeSecimToggle(string belgeId)
    {
        if (secilenBelgeler.Contains(belgeId))
        {
            secilenBelgeler.Remove(belgeId);
        }
        else
        {
            secilenBelgeler.Add(belgeId);
        }
    }

    private void TumunuSecToggle(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false))
        {
            secilenBelgeler = sonuc.Belgeler.Select(b => b.BelgeId).ToHashSet();
        }
        else
        {
            secilenBelgeler.Clear();
        }
    }

    private async Task XmlIndir(LucaBelge belge)
    {
        try
        {
            islemMesaji = $"{belge.FaturaNo} icin XML indiriliyor...";
            
            var sonuc = await LucaService.XmlIndirAsync(belge.BelgeId, belge.BelgeTipi);
            
            if (sonuc.Basarili && sonuc.Icerik != null)
            {
                await IndirilenDosyayiKaydet(sonuc.Icerik, sonuc.DosyaAdi ?? $"{belge.EttnNo}.xml", "application/xml");
                ToastService.ShowSuccess("XML indirildi!");
            }
            else
            {
                ToastService.ShowError(sonuc.HataMesaji ?? "Indirme basarisiz");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Indirme hatasi: {ex.Message}");
        }
        finally
        {
            islemMesaji = null;
        }
    }

    private async Task PdfIndir(LucaBelge belge)
    {
        try
        {
            islemMesaji = $"{belge.FaturaNo} icin PDF indiriliyor...";
            
            var sonuc = await LucaService.PdfIndirAsync(belge.BelgeId, belge.BelgeTipi);
            
            if (sonuc.Basarili && sonuc.Icerik != null)
            {
                await IndirilenDosyayiKaydet(sonuc.Icerik, sonuc.DosyaAdi ?? $"{belge.EttnNo}.pdf", "application/pdf");
                ToastService.ShowSuccess("PDF indirildi!");
            }
            else
            {
                ToastService.ShowError(sonuc.HataMesaji ?? "Indirme basarisiz");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Indirme hatasi: {ex.Message}");
        }
        finally
        {
            islemMesaji = null;
        }
    }

    private async Task SistemeAktar(LucaBelge belge)
    {
        try
        {
            islemMesaji = $"{belge.FaturaNo} sisteme aktariliyor...";
            
            var aktarilan = await LucaService.BelgeleriSistemeAktarAsync(new List<LucaBelge> { belge });
            
            if (aktarilan > 0)
            {
                ToastService.ShowSuccess("Belge sisteme aktarildi!");
            }
            else
            {
                ToastService.ShowWarning("Belge zaten mevcut veya aktarilamadi");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Aktarma hatasi: {ex.Message}");
        }
        finally
        {
            islemMesaji = null;
        }
    }

    private async Task SecilenleriAktar()
    {
        if (!secilenBelgeler.Any()) return;
        
        isImporting = true;
        
        try
        {
            var secilenler = sonuc.Belgeler.Where(b => secilenBelgeler.Contains(b.BelgeId)).ToList();
            islemMesaji = $"{secilenler.Count} belge aktariliyor...";
            
            var aktarilan = await LucaService.BelgeleriSistemeAktarAsync(secilenler);
            
            ToastService.ShowSuccess($"{aktarilan} belge sisteme aktarildi!");
            secilenBelgeler.Clear();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Aktarma hatasi: {ex.Message}");
        }
        finally
        {
            isImporting = false;
            islemMesaji = null;
        }
    }

    private async Task SecilenleriXmlIndir()
    {
        if (!secilenBelgeler.Any()) return;
        
        isDownloading = true;
        
        try
        {
            var secilenler = sonuc.Belgeler.Where(b => secilenBelgeler.Contains(b.BelgeId)).ToList();
            islemMesaji = $"{secilenler.Count} XML indiriliyor...";
            
            var belgeIdler = secilenler.Select(b => b.BelgeId).ToList();
            var belgeTipi = filtre.BelgeTipi ?? LucaBelgeTipi.EFatura;
            
            var sonuclar = await LucaService.TopluXmlIndirAsync(belgeIdler, belgeTipi);
            var basarili = sonuclar.Count(s => s.Basarili);
            
            ToastService.ShowSuccess($"{basarili} XML indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Indirme hatasi: {ex.Message}");
        }
        finally
        {
            isDownloading = false;
            islemMesaji = null;
        }
    }

    private async Task SecilenleriPdfIndir()
    {
        if (!secilenBelgeler.Any()) return;
        
        isDownloading = true;
        
        try
        {
            var secilenler = sonuc.Belgeler.Where(b => secilenBelgeler.Contains(b.BelgeId)).ToList();
            islemMesaji = $"{secilenler.Count} PDF indiriliyor...";
            
            var belgeIdler = secilenler.Select(b => b.BelgeId).ToList();
            var belgeTipi = filtre.BelgeTipi ?? LucaBelgeTipi.EFatura;
            
            var sonuclar = await LucaService.TopluPdfIndirAsync(belgeIdler, belgeTipi);
            var basarili = sonuclar.Count(s => s.Basarili);
            
            ToastService.ShowSuccess($"{basarili} PDF indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Indirme hatasi: {ex.Message}");
        }
        finally
        {
            isDownloading = false;
            islemMesaji = null;
        }
    }

    private async Task IndirilenDosyayiKaydet(byte[] icerik, string dosyaAdi, string contentType)
    {
        var base64 = Convert.ToBase64String(icerik);
        await JS.InvokeVoidAsync("downloadFileFromBase64", base64, dosyaAdi, contentType);
    }

    private string TruncateEttn(string? ettn)
    {
        if (string.IsNullOrEmpty(ettn)) return "-";
        return ettn.Length > 20 ? $"{ettn[..8]}...{ettn[^8..]}" : ettn;
    }

    private string GetDurumBadgeClass(string? durum)
    {
        return durum?.ToLower() switch
        {
            "onaylandi" or "kabul edildi" => "bg-success",
            "beklemede" => "bg-warning",
            "reddedildi" or "iptal" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

