@page "/faturalar/efatura-xml"
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Shared.Entities
@inject IEFaturaXmlService EFaturaXmlService
@inject IFaturaService FaturaService
@inject IFirmaService FirmaService
@inject IJSRuntime JSRuntime

<PageTitle>E-Fatura XML Oluşturma</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0"><i class="bi bi-file-earmark-code me-2"></i>E-Fatura XML Oluşturma</h3>
            <small class="text-muted">GİB UBL-TR 1.2 formatında e-fatura XML oluşturma</small>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_mesaj))
    {
        <div class="alert @(_basarili ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @_mesaj
            <button type="button" class="btn-close" @onclick="() => _mesaj = null"></button>
        </div>
    }

    <div class="row">
        <!-- Filtre Paneli -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">Başlangıç Tarihi</label>
                            <input type="date" class="form-control" @bind="_baslangicTarihi" @bind:event="onchange" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Bitiş Tarihi</label>
                            <input type="date" class="form-control" @bind="_bitisTarihi" @bind:event="onchange" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Fatura Tipi</label>
                            <select class="form-select" @bind="_faturaTipi">
                                <option value="">Tümü</option>
                                <option value="@FaturaTipi.SatisFaturasi">Satış</option>
                                <option value="@FaturaTipi.AlisFaturasi">Alış</option>
                                <option value="@FaturaTipi.TevkifatliFatura">Tevkifatlı</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">XML Durumu</label>
                            <select class="form-select" @bind="_xmlDurum">
                                <option value="">Tümü</option>
                                <option value="yok">XML Oluşturulmamış</option>
                                <option value="var">XML Mevcut</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">GİB Durumu</label>
                            <select class="form-select" @bind="_gibDurum">
                                <option value="">Tümü</option>
                                @foreach (var durum in Enum.GetValues<GibGonderimDurumu>())
                                {
                                    <option value="@durum">@GetGibDurumText(durum)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Senaryo</label>
                            <select class="form-select" @bind="_senaryo">
                                <option value="@EFaturaSenaryo.Temel">Temel Fatura</option>
                                <option value="@EFaturaSenaryo.Ticari">Ticari Fatura</option>
                                <option value="@EFaturaSenaryo.Ihracat">İhracat</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-primary w-100" @onclick="FiltreleAsync">
                                <i class="bi bi-search me-1"></i> Filtrele
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fatura Listesi -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-list-ul me-2"></i>Faturalar
                        <span class="badge bg-secondary ms-2">@_faturalar.Count</span>
                    </span>
                    @if (_seciliFaturalar.Any())
                    {
                        <div>
                            <span class="me-3 text-info">
                                <i class="bi bi-check-circle me-1"></i>@_seciliFaturalar.Count seçili
                            </span>
                            <button class="btn btn-success btn-sm" @onclick="TopluXmlOlusturAsync" disabled="@_yukleniyor">
                                <i class="bi bi-file-earmark-code me-1"></i>Toplu XML Oluştur
                            </button>
                        </div>
                    }
                </div>
                <div class="card-body p-0">
                    @if (_yukleniyor)
                    {
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <div class="mt-2">Yükleniyor...</div>
                        </div>
                    }
                    else if (!_faturalar.Any())
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="bi bi-inbox display-4"></i>
                            <p class="mt-2">Filtrelere uygun fatura bulunamadı.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;">
                                            <input type="checkbox" class="form-check-input" 
                                                   @bind="_tumunuSec" 
                                                   @onclick="TumunuSecDegistir" />
                                        </th>
                                        <th>Fatura No</th>
                                        <th>Tarih</th>
                                        <th>Cari</th>
                                        <th>Tip</th>
                                        <th class="text-end">Tutar</th>
                                        <th>ETTN</th>
                                        <th>XML</th>
                                        <th>GİB</th>
                                        <th style="width: 200px;">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fatura in _faturalar)
                                    {
                                        <tr class="@(FaturaSeciliMi(fatura.Id) ? "table-primary" : "")">
                                            <td>
                                                <input type="checkbox" class="form-check-input"
                                                       checked="@FaturaSeciliMi(fatura.Id)"
                                                       @onchange="() => FaturaSecimDegistir(fatura.Id)" />
                                            </td>
                                            <td>
                                                <strong>@fatura.FaturaNo</strong>
                                            </td>
                                            <td>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                <span title="@fatura.Cari?.Unvan">
                                                    @(fatura.Cari?.Unvan?.Length > 25 ? fatura.Cari?.Unvan[..25] + "..." : fatura.Cari?.Unvan)
                                                </span>
                                            </td>
                                            <td>
                                                @switch (fatura.FaturaTipi)
                                                {
                                                    case FaturaTipi.SatisFaturasi:
                                                        <span class="badge bg-success">Satış</span>
                                                        break;
                                                    case FaturaTipi.AlisFaturasi:
                                                        <span class="badge bg-info">Alış</span>
                                                        break;
                                                    case FaturaTipi.TevkifatliFatura:
                                                        <span class="badge bg-warning text-dark">Tevkifatlı</span>
                                                        break;
                                                    case FaturaTipi.SatisIadeFaturasi:
                                                        <span class="badge bg-danger">Satış İade</span>
                                                        break;
                                                    case FaturaTipi.AlisIadeFaturasi:
                                                        <span class="badge bg-secondary">Alış İade</span>
                                                        break;
                                                }
                                                @if (fatura.EFaturaTipi == EFaturaTipi.EFatura)
                                                {
                                                    <span class="badge bg-primary ms-1">E-Fatura</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary ms-1">E-Arşiv</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <strong>@fatura.GenelToplam.ToString("N2") ₺</strong>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(fatura.EttnNo))
                                                {
                                                    <code title="@fatura.EttnNo" style="font-size: 0.75rem;">
                                                        @fatura.EttnNo[..8]...
                                                    </code>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(fatura.XmlDosyaYolu))
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle me-1"></i>Mevcut
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="bi bi-x-circle me-1"></i>Yok
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge @GetGibDurumBadge(fatura.GibDurumu)">@GetGibDurumText(fatura.GibDurumu)</span>
                                                @if (!string.IsNullOrWhiteSpace(fatura.GibKodu))
                                                {
                                                    <br /><small class="text-muted">@fatura.GibKodu</small>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    @if (string.IsNullOrEmpty(fatura.XmlDosyaYolu))
                                                    {
                                                        <button class="btn btn-outline-success" 
                                                                @onclick="() => XmlOlusturAsync(fatura.Id)"
                                                                disabled="@_islemYapiliyor"
                                                                title="XML Oluştur">
                                                            <i class="bi bi-plus-circle"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-outline-primary" 
                                                                @onclick="() => XmlOnizleAsync(fatura.Id)"
                                                                title="XML Önizle">
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                        <button class="btn btn-outline-info" 
                                                                @onclick="() => XmlIndirAsync(fatura)"
                                                                title="XML İndir">
                                                            <i class="bi bi-download"></i>
                                                        </button>
                                                        <button class="btn btn-outline-warning" 
                                                                @onclick="() => XmlYenidenOlusturAsync(fatura.Id)"
                                                                disabled="@_islemYapiliyor"
                                                                title="Yeniden Oluştur">
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        </button>
                                                        @if (fatura.GibDurumu == GibGonderimDurumu.XmlHazirlandi || fatura.GibDurumu == GibGonderimDurumu.Reddedildi)
                                                        {
                                                            <button class="btn btn-outline-secondary"
                                                                    @onclick="() => GibHazirlaAsync(fatura.Id)"
                                                                    disabled="@_islemYapiliyor"
                                                                    title="Gönderime Hazırla">
                                                                <i class="bi bi-send-check"></i>
                                                            </button>
                                                        }
                                                        @if (fatura.GibDurumu == GibGonderimDurumu.GonderimeHazir)
                                                        {
                                                            <button class="btn btn-outline-dark"
                                                                    @onclick="() => GibGonderildiIsaretleAsync(fatura.Id)"
                                                                    disabled="@_islemYapiliyor"
                                                                    title="Gönderildi Olarak İşaretle">
                                                                <i class="bi bi-box-arrow-up-right"></i>
                                                            </button>
                                                        }
                                                        @if (fatura.GibDurumu == GibGonderimDurumu.Gonderildi)
                                                        {
                                                            <button class="btn btn-outline-success"
                                                                    @onclick="() => GibKabulAsync(fatura.Id)"
                                                                    disabled="@_islemYapiliyor"
                                                                    title="Kabul Edildi">
                                                                <i class="bi bi-check2-circle"></i>
                                                            </button>
                                                            <button class="btn btn-outline-danger"
                                                                    @onclick="() => GibRedAsync(fatura.Id)"
                                                                    disabled="@_islemYapiliyor"
                                                                    title="Reddedildi">
                                                                <i class="bi bi-x-octagon"></i>
                                                            </button>
                                                        }
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- XML Önizleme Modal -->
@if (_onizlemeGoster)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-code me-2"></i>E-Fatura XML Önizleme
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => _onizlemeGoster = false"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_xmlOnizleme))
                    {
                        <pre style="max-height: 500px; overflow: auto; background: #f8f9fa; padding: 1rem; border-radius: 0.25rem;">
                            <code>@_xmlOnizleme</code>
                        </pre>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _onizlemeGoster = false">
                        <i class="bi bi-x-lg me-1"></i>Kapat
                    </button>
                    <button class="btn btn-primary" @onclick="XmlPanoyaKopyalaAsync">
                        <i class="bi bi-clipboard me-1"></i>Panoya Kopyala
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Doğrulama Raporu Modal -->
@if (_dogrulamaRaporGoster && _sonDogrulamaRapor != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header @(_sonDogrulamaRapor.Gecerli ? "bg-success" : "bg-danger") text-white">
                    <h5 class="modal-title">
                        <i class="bi @(_sonDogrulamaRapor.Gecerli ? "bi-check-circle" : "bi-x-circle") me-2"></i>
                        Doğrulama Raporu
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _dogrulamaRaporGoster = false"></button>
                </div>
                <div class="modal-body">
                    @if (_sonDogrulamaRapor.Hatalar.Any())
                    {
                        <h6 class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Hatalar</h6>
                        <ul class="list-group mb-3">
                            @foreach (var hata in _sonDogrulamaRapor.Hatalar)
                            {
                                <li class="list-group-item list-group-item-danger">
                                    <strong>[@hata.Kod]</strong> @hata.Mesaj
                                    @if (!string.IsNullOrEmpty(hata.Alan))
                                    {
                                        <span class="badge bg-secondary ms-2">@hata.Alan</span>
                                    }
                                </li>
                            }
                        </ul>
                    }

                    @if (_sonDogrulamaRapor.Uyarilar.Any())
                    {
                        <h6 class="text-warning"><i class="bi bi-info-circle me-1"></i>Uyarılar</h6>
                        <ul class="list-group">
                            @foreach (var uyari in _sonDogrulamaRapor.Uyarilar)
                            {
                                <li class="list-group-item list-group-item-warning">
                                    @uyari
                                </li>
                            }
                        </ul>
                    }

                    @if (_sonDogrulamaRapor.Gecerli && !_sonDogrulamaRapor.Uyarilar.Any())
                    {
                        <div class="text-center text-success">
                            <i class="bi bi-check-circle-fill display-4"></i>
                            <p class="mt-2">XML doğrulama başarılı!</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _dogrulamaRaporGoster = false">
                        Kapat
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Fatura> _faturalar = new();
    private HashSet<int> _seciliFaturalar = new();
    private bool _yukleniyor = false;
    private bool _islemYapiliyor = false;
    private string? _mesaj;
    private bool _basarili;
    private bool _tumunuSec = false;

    // Filtreler
    private DateTime _baslangicTarihi = DateTime.Today.AddMonths(-1);
    private DateTime _bitisTarihi = DateTime.Today;
    private FaturaTipi? _faturaTipi;
    private string _xmlDurum = "";
    private string _gibDurum = "";
    private EFaturaSenaryo _senaryo = EFaturaSenaryo.Temel;

    // Önizleme
    private bool _onizlemeGoster = false;
    private string? _xmlOnizleme;

    // Doğrulama
    private bool _dogrulamaRaporGoster = false;
    private EFaturaDogrulamaRapor? _sonDogrulamaRapor;

    protected override async Task OnInitializedAsync()
    {
        await FiltreleAsync();
    }

    private async Task FiltreleAsync()
    {
        _yukleniyor = true;
        _seciliFaturalar.Clear();
        _tumunuSec = false;

        try
        {
            var tumFaturalar = await FaturaService.GetAllAsync();

            _faturalar = tumFaturalar
                .Where(f => f.FaturaTarihi.Date >= _baslangicTarihi.Date && 
                            f.FaturaTarihi.Date <= _bitisTarihi.Date)
                .Where(f => f.FaturaYonu == FaturaYonu.Giden) // Sadece giden faturalar
                .Where(f => !_faturaTipi.HasValue || f.FaturaTipi == _faturaTipi.Value)
                .Where(f => string.IsNullOrEmpty(_xmlDurum) ||
                            (_xmlDurum == "yok" && string.IsNullOrEmpty(f.XmlDosyaYolu)) ||
                            (_xmlDurum == "var" && !string.IsNullOrEmpty(f.XmlDosyaYolu)))
                .Where(f => string.IsNullOrEmpty(_gibDurum) || f.GibDurumu.ToString() == _gibDurum)
                .OrderByDescending(f => f.FaturaTarihi)
                .ThenBy(f => f.FaturaNo)
                .ToList();
        }
        catch (Exception ex)
        {
            _mesaj = $"Faturalar yüklenirken hata: {ex.Message}";
            _basarili = false;
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private bool FaturaSeciliMi(int faturaId) => _seciliFaturalar.Contains(faturaId);

    private void FaturaSecimDegistir(int faturaId)
    {
        if (_seciliFaturalar.Contains(faturaId))
            _seciliFaturalar.Remove(faturaId);
        else
            _seciliFaturalar.Add(faturaId);

        _tumunuSec = _seciliFaturalar.Count == _faturalar.Count;
    }

    private void TumunuSecDegistir()
    {
        if (_tumunuSec)
        {
            _seciliFaturalar.Clear();
            _tumunuSec = false;
        }
        else
        {
            _seciliFaturalar = _faturalar.Select(f => f.Id).ToHashSet();
            _tumunuSec = true;
        }
    }

    private async Task XmlOlusturAsync(int faturaId)
    {
        _islemYapiliyor = true;

        try
        {
            var request = new EFaturaXmlRequest
            {
                FaturaId = faturaId,
                Senaryo = _senaryo
            };

            var sonuc = await EFaturaXmlService.XmlOlusturAsync(request);

            if (sonuc.Basarili)
            {
                _mesaj = $"E-Fatura XML başarıyla oluşturuldu. ETTN: {sonuc.EttnNo}";
                _basarili = true;
                await FiltreleAsync();
            }
            else
            {
                _mesaj = sonuc.Hata ?? "XML oluşturma başarısız.";
                _basarili = false;
                
                if (sonuc.DogrulamaRapor.Hatalar.Any() || sonuc.DogrulamaRapor.Uyarilar.Any())
                {
                    _sonDogrulamaRapor = sonuc.DogrulamaRapor;
                    _dogrulamaRaporGoster = true;
                }
            }
        }
        catch (Exception ex)
        {
            _mesaj = $"Hata: {ex.Message}";
            _basarili = false;
        }
        finally
        {
            _islemYapiliyor = false;
        }
    }

    private async Task XmlYenidenOlusturAsync(int faturaId)
    {
        await XmlOlusturAsync(faturaId);
    }

    private async Task TopluXmlOlusturAsync()
    {
        if (!_seciliFaturalar.Any())
            return;

        _islemYapiliyor = true;

        try
        {
            var faturaIdler = _seciliFaturalar.ToList();
            var sonuclar = await EFaturaXmlService.TopluXmlOlusturAsync(faturaIdler, _senaryo);

            var basarili = sonuclar.Count(s => s.Basarili);
            var basarisiz = sonuclar.Count(s => !s.Basarili);

            _mesaj = $"Toplu işlem tamamlandı: {basarili} başarılı, {basarisiz} başarısız";
            _basarili = basarisiz == 0;

            _seciliFaturalar.Clear();
            _tumunuSec = false;
            await FiltreleAsync();
        }
        catch (Exception ex)
        {
            _mesaj = $"Toplu işlem hatası: {ex.Message}";
            _basarili = false;
        }
        finally
        {
            _islemYapiliyor = false;
        }
    }

    private async Task XmlOnizleAsync(int faturaId)
    {
        try
        {
            _xmlOnizleme = await EFaturaXmlService.XmlOkuAsync(faturaId);
            if (!string.IsNullOrEmpty(_xmlOnizleme))
            {
                _onizlemeGoster = true;
            }
            else
            {
                _mesaj = "XML dosyası okunamadı.";
                _basarili = false;
            }
        }
        catch (Exception ex)
        {
            _mesaj = $"Önizleme hatası: {ex.Message}";
            _basarili = false;
        }
    }

    private async Task XmlIndirAsync(Fatura fatura)
    {
        if (string.IsNullOrEmpty(fatura.XmlDosyaYolu))
            return;

        try
        {
            var xml = await EFaturaXmlService.XmlOkuAsync(fatura.Id);
            if (!string.IsNullOrEmpty(xml))
            {
                var dosyaAdi = $"{fatura.FaturaNo}_{fatura.EttnNo ?? "efatura"}.xml";
                await JSRuntime.InvokeVoidAsync("downloadFile", dosyaAdi, xml, "application/xml");
            }
        }
        catch (Exception ex)
        {
            _mesaj = $"İndirme hatası: {ex.Message}";
            _basarili = false;
        }
    }

    private async Task XmlPanoyaKopyalaAsync()
    {
        if (!string.IsNullOrEmpty(_xmlOnizleme))
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _xmlOnizleme);
            _mesaj = "XML panoya kopyalandı.";
            _basarili = true;
        }
    }

    private async Task GibHazirlaAsync(int faturaId)
    {
        await GibDurumGuncelleAsync(faturaId, GibGonderimDurumu.GonderimeHazir, null, "XML kontrol edildi, GİB gönderimine hazır.");
    }

    private async Task GibGonderildiIsaretleAsync(int faturaId)
    {
        await GibDurumGuncelleAsync(faturaId, GibGonderimDurumu.Gonderildi, null, "GİB/entegratör tarafına gönderildi.");
    }

    private async Task GibKabulAsync(int faturaId)
    {
        var gibKodu = await JSRuntime.InvokeAsync<string>("prompt", "GİB onay kodu", "");
        if (gibKodu is null)
            return;

        await GibDurumGuncelleAsync(faturaId, GibGonderimDurumu.KabulEdildi, gibKodu, "Fatura GİB tarafından kabul edildi.");
    }

    private async Task GibRedAsync(int faturaId)
    {
        var redNedeni = await JSRuntime.InvokeAsync<string>("prompt", "Red nedeni", "Şema/doğrulama hatası");
        if (string.IsNullOrWhiteSpace(redNedeni))
            return;

        await GibDurumGuncelleAsync(faturaId, GibGonderimDurumu.Reddedildi, null, redNedeni);
    }

    private async Task GibDurumGuncelleAsync(int faturaId, GibGonderimDurumu durum, string? gibKodu, string? mesaj)
    {
        _islemYapiliyor = true;

        try
        {
            var result = await EFaturaXmlService.GibDurumGuncelleAsync(faturaId, durum, gibKodu, mesaj);
            if (!result)
            {
                _mesaj = "Fatura bulunamadı.";
                _basarili = false;
                return;
            }

            _mesaj = $"GİB durumu güncellendi: {GetGibDurumText(durum)}";
            _basarili = true;
            await FiltreleAsync();
        }
        catch (Exception ex)
        {
            _mesaj = $"GİB durum güncelleme hatası: {ex.Message}";
            _basarili = false;
        }
        finally
        {
            _islemYapiliyor = false;
        }
    }

    private static string GetGibDurumText(GibGonderimDurumu durum) => durum switch
    {
        GibGonderimDurumu.Bekliyor => "Bekliyor",
        GibGonderimDurumu.XmlHazirlandi => "XML Hazırlandı",
        GibGonderimDurumu.GonderimeHazir => "Gönderime Hazır",
        GibGonderimDurumu.Gonderildi => "Gönderildi",
        GibGonderimDurumu.KabulEdildi => "Kabul Edildi",
        GibGonderimDurumu.Reddedildi => "Reddedildi",
        _ => "Bekliyor"
    };

    private static string GetGibDurumBadge(GibGonderimDurumu durum) => durum switch
    {
        GibGonderimDurumu.Bekliyor => "bg-secondary",
        GibGonderimDurumu.XmlHazirlandi => "bg-info",
        GibGonderimDurumu.GonderimeHazir => "bg-primary",
        GibGonderimDurumu.Gonderildi => "bg-dark",
        GibGonderimDurumu.KabulEdildi => "bg-success",
        GibGonderimDurumu.Reddedildi => "bg-danger",
        _ => "bg-secondary"
    };
}

