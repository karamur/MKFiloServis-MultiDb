@page "/faturalar/yeni"
@page "/faturalar/{Id:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IFaturaService FaturaService
@inject ICariService CariService
@inject IFirmaService FirmaService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Fatura Düzenle" : "Yeni Fatura")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-receipt me-2"></i>@(IsEdit ? "Fatura Düzenle" : "Yeni Fatura")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="mb-0">Fatura Bilgileri</h6>
                </div>
                <div class="card-body">
                    <EditForm Model="fatura" OnValidSubmit="Kaydet">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrWhiteSpace(hataMesaji))
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle me-2"></i>@hataMesaji
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Fatura No *</label>
                                    <div class="input-group">
                                        <InputText @bind-Value="fatura.FaturaNo" class="form-control" readonly="@IsEdit" />
                                        @if (!IsEdit)
                                        {
                                            <button type="button" class="btn btn-outline-secondary" @onclick="NumaraUretAsync" title="Numara Üret">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Fatura Tarihi *</label>
                                    <InputDate @bind-Value="fatura.FaturaTarihi" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Vade Tarihi</label>
                                    <InputDate @bind-Value="fatura.VadeTarihi" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Fatura Yönü *</label>
                                    <InputSelect @bind-Value="fatura.FaturaYonu" class="form-select" @onchange="FaturaYonuDegisti">
                                        <option value="@FaturaYonu.Giden">Kesilen</option>
                                        <option value="@FaturaYonu.Gelen">Gelen</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Firma *</label>
                                    <InputSelect @bind-Value="fatura.FirmaId" class="form-select" @onchange="FirmaDegisti">
                                        <option value="">-- Firma Seçiniz --</option>
                                        @foreach (var firma in firmalar.Where(x => x.Aktif))
                                        {
                                            <option value="@firma.Id">@firma.FirmaAdi</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-center">
                                <div class="form-check mt-3">
                                    <InputCheckbox @bind-Value="fatura.FirmalarArasiFatura" class="form-check-input" @bind-Value:after="FirmalarArasiDurumDegisti" />
                                    <label class="form-check-label">Firmalar Arası Fatura</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Fatura Tipi *</label>
                                    <InputSelect @bind-Value="fatura.FaturaTipi" class="form-select" @onchange="TipDegisti">
                                        @foreach (var tip in TipSecenekleri())
                                        {
                                            <option value="@tip">@GetTipText(tip)</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Cari *</label>
                                    <InputSelect @bind-Value="fatura.CariId" class="form-select">
                                        <option value="0">-- Cari Seçiniz --</option>
                                        @foreach (var cari in CariSecenekleri())
                                        {
                                            <option value="@cari.Id">@cari.Unvan</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Karşı Firma</label>
                                    <InputSelect @bind-Value="fatura.KarsiFirmaId" class="form-select" disabled="@(!fatura.FirmalarArasiFatura)">
                                        <option value="">-- Karşı Firma Seçiniz --</option>
                                        @foreach (var firma in firmalar.Where(x => x.Aktif && (!fatura.FirmaId.HasValue || x.Id != fatura.FirmaId.Value)))
                                        {
                                            <option value="@firma.Id">@firma.FirmaAdi</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <h6>Fatura Kalemleri</h6>

                        <div class="table-responsive mb-3">
                            <table class="table table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40%;">Açıklama</th>
                                        <th style="width: 10%;">Miktar</th>
                                        <th style="width: 10%;">Birim</th>
                                        <th style="width: 15%;">Birim Fiyat</th>
                                        <th style="width: 10%;">KDV %</th>
                                        <th style="width: 15%;">Toplam</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < fatura.FaturaKalemleri.Count; i++)
                                    {
                                        var index = i;
                                        var kalem = fatura.FaturaKalemleri.ElementAt(index);
                                        <tr>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" @bind="kalem.Aciklama" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" @bind="kalem.Miktar" @bind:after="HesaplaToplam" step="0.01" />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" @bind="kalem.Birim" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" @bind="kalem.BirimFiyat" @bind:after="HesaplaToplam" step="0.01" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" @bind="kalem.KdvOrani" @bind:after="HesaplaToplam" />
                                            </td>
                                            <td class="text-end">
                                                <strong>@((kalem.Miktar * kalem.BirimFiyat * (1 + kalem.KdvOrani / 100)).ToString("N2")) ?</strong>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => KalemSil(index)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <button type="button" class="btn btn-outline-primary btn-sm mb-3" @onclick="KalemEkle">
                            <i class="bi bi-plus me-1"></i>Kalem Ekle
                        </button>

                        <div class="mb-3">
                            <label class="form-label">Açıklama</label>
                            <InputTextArea @bind-Value="fatura.Aciklama" class="form-control" rows="2" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Kaydet
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="Geri">
                                <i class="bi bi-x-lg me-1"></i>İptal
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">Toplam</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Ara Toplam:</span>
                        <strong>@araToplam.ToString("N2") ?</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>KDV Toplam:</span>
                        <strong>@kdvToplam.ToString("N2") ?</strong>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span class="h5">Genel Toplam:</span>
                        <strong class="h5 text-primary">@genelToplam.ToString("N2") ?</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Fatura fatura = new();
    private List<Cari> cariler = new();
    private List<Firma> firmalar = new();
    private string? hataMesaji;
    private bool IsEdit => Id.HasValue;

    private decimal araToplam => fatura.FaturaKalemleri.Sum(k => k.Miktar * k.BirimFiyat);
    private decimal kdvToplam => fatura.FaturaKalemleri.Sum(k => k.Miktar * k.BirimFiyat * k.KdvOrani / 100);
    private decimal genelToplam => araToplam + kdvToplam;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        firmalar = await FirmaService.GetAktifFirmalarAsync();

        if (IsEdit)
        {
            var existing = await FaturaService.GetByIdWithKalemlerAsync(Id!.Value);
            if (existing != null)
            {
                fatura = existing;
                UygunsuzSecimleriTemizle();
            }
            else
            {
                Navigation.NavigateTo("/faturalar");
            }
        }
        else
        {
            fatura.FaturaTipi = FaturaTipi.SatisFaturasi;
            fatura.FaturaYonu = FaturaYonu.Giden;
            fatura.FirmaId = firmalar.FirstOrDefault()?.Id;
            fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(FaturaTipi.SatisFaturasi, fatura.FaturaYonu, fatura.FirmaId);
            fatura.FaturaTarihi = DateTime.Today;
            fatura.VadeTarihi = DateTime.Today.AddDays(30);
            fatura.Durum = FaturaDurum.Beklemede;
            KalemEkle();
        }
    }

    private async Task TipDegisti(ChangeEventArgs e)
    {
        if (!IsEdit && Enum.TryParse<FaturaTipi>(e.Value?.ToString(), out var tip))
        {
            hataMesaji = null;
            fatura.FaturaTipi = tip;
            fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(tip, fatura.FaturaYonu, fatura.FirmaId);
        }
    }

    private async Task FaturaYonuDegisti(ChangeEventArgs e)
    {
        if (Enum.TryParse<FaturaYonu>(e.Value?.ToString(), out var yon))
        {
            hataMesaji = null;
            fatura.FaturaYonu = yon;

            if (!TipSecenekleri().Contains(fatura.FaturaTipi))
                fatura.FaturaTipi = VarsayilanTipGetir(yon);

            UygunsuzSecimleriTemizle();

            if (!IsEdit)
                fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(fatura.FaturaTipi, fatura.FaturaYonu, fatura.FirmaId);
        }
    }

    private async Task FirmaDegisti(ChangeEventArgs e)
    {
        hataMesaji = null;
        fatura.FirmaId = int.TryParse(e.Value?.ToString(), out var firmaId) ? firmaId : null;
        UygunsuzSecimleriTemizle();

        if (!IsEdit)
            fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(fatura.FaturaTipi, fatura.FaturaYonu, fatura.FirmaId);
    }

    private void FirmalarArasiDurumDegisti()
    {
        hataMesaji = null;
        if (!fatura.FirmalarArasiFatura)
        {
            fatura.KarsiFirmaId = null;
        }
        else if (fatura.KarsiFirmaId == fatura.FirmaId)
        {
            fatura.KarsiFirmaId = null;
        }
    }

    private async Task NumaraUretAsync()
    {
        hataMesaji = null;

        if (!fatura.FirmaId.HasValue)
        {
            hataMesaji = "Numara üretmeden önce firma seçiniz.";
            return;
        }

        fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(fatura.FaturaTipi, fatura.FaturaYonu, fatura.FirmaId);
    }

    private IEnumerable<FaturaTipi> TipSecenekleri()
    {
        return fatura.FaturaYonu == FaturaYonu.Giden
            ? new[] { FaturaTipi.SatisFaturasi, FaturaTipi.SatisIadeFaturasi, FaturaTipi.TevkifatliFatura }
            : new[] { FaturaTipi.AlisFaturasi, FaturaTipi.AlisIadeFaturasi, FaturaTipi.TevkifatliFatura };
    }

    private static FaturaTipi VarsayilanTipGetir(FaturaYonu yon)
        => yon == FaturaYonu.Giden ? FaturaTipi.SatisFaturasi : FaturaTipi.AlisFaturasi;

    private IEnumerable<Cari> CariSecenekleri()
    {
        var uygunTipler = fatura.FaturaYonu == FaturaYonu.Giden
            ? new[] { CariTipi.Musteri, CariTipi.MusteriTedarikci }
            : new[] { CariTipi.Tedarikci, CariTipi.MusteriTedarikci };

        return cariler.Where(c => uygunTipler.Contains(c.CariTipi)
            && (!fatura.FirmaId.HasValue || c.Id == fatura.CariId || c.FirmaId == null || c.FirmaId == fatura.FirmaId));
    }

    private void UygunsuzSecimleriTemizle()
    {
        if (fatura.KarsiFirmaId == fatura.FirmaId)
            fatura.KarsiFirmaId = null;

        if (!fatura.FirmalarArasiFatura)
            fatura.KarsiFirmaId = null;

        var seciliCariGecerli = fatura.CariId > 0 && CariSecenekleri().Any(c => c.Id == fatura.CariId);
        if (!seciliCariGecerli)
            fatura.CariId = 0;
    }

    private void KalemEkle()
    {
        fatura.FaturaKalemleri.Add(new FaturaKalem
        {
            SiraNo = fatura.FaturaKalemleri.Count + 1,
            Miktar = 1,
            Birim = "Adet",
            KdvOrani = 20
        });
    }

    private void KalemSil(int index)
    {
        var kalem = fatura.FaturaKalemleri.ElementAt(index);
        fatura.FaturaKalemleri.Remove(kalem);
    }

    private void HesaplaToplam()
    {
        StateHasChanged();
    }

    private async Task Kaydet()
    {
        hataMesaji = null;

        if (fatura.CariId == 0 || !fatura.FirmaId.HasValue || !fatura.FaturaKalemleri.Any())
        {
            hataMesaji = "Firma, cari ve en az bir fatura kalemi zorunludur.";
            return;
        }

        if (fatura.FirmalarArasiFatura && (!fatura.KarsiFirmaId.HasValue || fatura.KarsiFirmaId == fatura.FirmaId))
        {
            hataMesaji = "Firmalar arası faturada farklı bir karşı firma seçmelisiniz.";
            return;
        }

        if (!fatura.FirmalarArasiFatura)
            fatura.KarsiFirmaId = null;

        fatura.AraToplam = araToplam;
        fatura.KdvTutar = kdvToplam;
        fatura.GenelToplam = genelToplam;

        try
        {
            if (IsEdit)
            {
                await FaturaService.UpdateAsync(fatura);
            }
            else
            {
                await FaturaService.CreateAsync(fatura);
            }

            Navigation.NavigateTo("/faturalar");
        }
        catch (InvalidOperationException ex)
        {
            hataMesaji = ex.Message;
        }
        catch
        {
            hataMesaji = "Fatura kaydedilirken beklenmeyen bir hata oluştu.";
        }
    }

    private void Geri()
    {
        Navigation.NavigateTo("/faturalar");
    }

    private string GetTipText(FaturaTipi tip) => tip switch
    {
        FaturaTipi.SatisFaturasi => "Satış Faturası",
        FaturaTipi.AlisFaturasi => "Alış Faturası",
        FaturaTipi.SatisIadeFaturasi => "Satış İade Faturası",
        FaturaTipi.AlisIadeFaturasi => "Alış İade Faturası",
        _ => tip.ToString()
    };
}

