@page "/faturalar/toplu-fatura"
@using MKFiloServis.Web.Models
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject ITopluFaturaService TopluFaturaService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Toplu Fatura Oluşturma</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0">
                <i class="bi bi-file-earmark-plus me-2"></i>Toplu Fatura Oluşturma
            </h3>
            <small class="text-muted">Puantaj kayıtlarından otomatik fatura kesimi</small>
        </div>
        <div>
            <a href="/faturalar" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Fatura Listesi
            </a>
        </div>
    </div>

    <!-- Dönem Özeti -->
    @if (donemOzeti != null)
    {
        <div class="row g-3 mb-4">
            <!-- Gelir (Satış) Faturaları -->
            <div class="col-md-6">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-arrow-up-circle me-2"></i>Kesilecek Satış Faturaları
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-4">
                                <h4 class="text-success mb-0">@donemOzeti.GelirFaturaKesilecekCariSayisi</h4>
                                <small class="text-muted">Cari</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-success mb-0">@donemOzeti.GelirFaturaKesilecekKayitSayisi</h4>
                                <small class="text-muted">Kayıt</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-success mb-0">@donemOzeti.GelirFaturaKesilecekTutar.ToString("N2") ₺</h4>
                                <small class="text-muted">Toplam</small>
                            </div>
                        </div>
                        @if (donemOzeti.GelirFaturaKesilenSayisi > 0)
                        {
                            <hr class="my-2" />
                            <small class="text-muted">
                                <i class="bi bi-check-circle text-success me-1"></i>
                                @donemOzeti.GelirFaturaKesilenSayisi fatura kesilmiş (@donemOzeti.GelirFaturaKesilenTutar.ToString("N2") ₺)
                            </small>
                        }
                    </div>
                </div>
            </div>

            <!-- Gider (Alış) Faturaları -->
            <div class="col-md-6">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <i class="bi bi-arrow-down-circle me-2"></i>Alınacak Alış Faturaları
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-4">
                                <h4 class="text-danger mb-0">@donemOzeti.GiderFaturaAlinacakCariSayisi</h4>
                                <small class="text-muted">Tedarikçi</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-danger mb-0">@donemOzeti.GiderFaturaAlinacakKayitSayisi</h4>
                                <small class="text-muted">Kayıt</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-danger mb-0">@donemOzeti.GiderFaturaAlinacakTutar.ToString("N2") ₺</h4>
                                <small class="text-muted">Toplam</small>
                            </div>
                        </div>
                        @if (donemOzeti.GiderFaturaAlinanSayisi > 0)
                        {
                            <hr class="my-2" />
                            <small class="text-muted">
                                <i class="bi bi-check-circle text-danger me-1"></i>
                                @donemOzeti.GiderFaturaAlinanSayisi fatura alınmış (@donemOzeti.GiderFaturaAlinanTutar.ToString("N2") ₺)
                            </small>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Filtre -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Yıl</label>
                    <select class="form-select" @bind="filtre.Yil" @bind:after="OnFiltreChanged">
                        @foreach (var yil in Enumerable.Range(DateTime.Now.Year - 2, 4).Reverse())
                        {
                            <option value="@yil">@yil</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Ay</label>
                    <select class="form-select" @bind="filtre.Ay" @bind:after="OnFiltreChanged">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@(new DateTime(2024, i, 1).ToString("MMMM"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fatura Yönü</label>
                    <select class="form-select" @bind="filtre.FaturaYonu" @bind:after="OnFiltreChanged">
                        <option value="@FaturaYonu.Giden">Satış (Kesilecek)</option>
                        <option value="@FaturaYonu.Gelen">Alış (Alınacak)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kaynak</label>
                    <select class="form-select" @bind="filtre.Kaynak">
                        <option value="@TopluFaturaKaynak.Puantaj">Puantaj Kayıtları</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="sadeceFaturaKesilmemis"
                               @bind="filtre.SadeceFaturaKesilmemis" @bind:after="OnFiltreChanged" />
                        <label class="form-check-label" for="sadeceFaturaKesilmemis">
                            Sadece fatura kesilmemişler
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Önizleme Listesi -->
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-2 text-muted">Önizleme hazırlanıyor...</p>
        </div>
    }
    else if (onizlemeler.Any())
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-list-check me-2"></i>
                    Fatura Önizleme (@onizlemeler.Count(o => o.Secili) / @onizlemeler.Count seçili)
                </div>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="TumunuSec">
                        <i class="bi bi-check-all me-1"></i>Tümünü Seç
                    </button>
                    <button class="btn btn-sm btn-outline-secondary me-2" @onclick="SecimTemizle">
                        <i class="bi bi-x-lg me-1"></i>Seçimi Temizle
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th width="40">
                                    <input type="checkbox" class="form-check-input" 
                                           @bind="tumSecili" @bind:after="TumSeciliChanged" />
                                </th>
                                <th>Cari</th>
                                <th class="text-center">Kayıt</th>
                                <th class="text-end">Ara Toplam</th>
                                <th class="text-end">KDV</th>
                                <th class="text-end">Tevkifat</th>
                                <th class="text-end">Genel Toplam</th>
                                <th class="text-center">Durum</th>
                                <th width="120"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var onizleme in onizlemeler)
                            {
                                <tr class="@(onizleme.Secili ? "table-primary" : "")">
                                    <td>
                                        <input type="checkbox" class="form-check-input" 
                                               @bind="onizleme.Secili" 
                                               disabled="@(onizleme.Durum != TopluFaturaDurum.Hazir)" />
                                    </td>
                                    <td>
                                        <div class="fw-medium">@onizleme.CariUnvan</div>
                                        <small class="text-muted">@onizleme.CariKod @(onizleme.VergiNo != null ? $"• VKN: {onizleme.VergiNo}" : "")</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@onizleme.KayitSayisi</span>
                                    </td>
                                    <td class="text-end">@onizleme.AraToplam.ToString("N2") ₺</td>
                                    <td class="text-end">
                                        @onizleme.KdvToplam.ToString("N2") ₺
                                        <small class="text-muted">(%@onizleme.KdvOrani)</small>
                                    </td>
                                    <td class="text-end">
                                        @if (onizleme.TevkifatliMi)
                                        {
                                            <span class="text-danger">-@onizleme.TevkifatToplam.ToString("N2") ₺</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold">@onizleme.GenelToplam.ToString("N2") ₺</td>
                                    <td class="text-center">
                                        @if (onizleme.Durum == TopluFaturaDurum.Hazir)
                                        {
                                            <span class="badge bg-success">Hazır</span>
                                        }
                                        else if (onizleme.Durum == TopluFaturaDurum.EksikBilgi)
                                        {
                                            <span class="badge bg-warning" title="@onizleme.DurumMesaji">Eksik Bilgi</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Kesilmiş</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-info" @onclick="() => DetayGoster(onizleme)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (onizleme.Durum == TopluFaturaDurum.Hazir)
                                        {
                                            <button class="btn btn-sm btn-outline-success ms-1" 
                                                    @onclick="() => TekFaturaOlustur(onizleme)" disabled="@isProcessing">
                                                <i class="bi bi-plus"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="3" class="text-end">Seçili Toplam:</td>
                                <td class="text-end">@onizlemeler.Where(o => o.Secili).Sum(o => o.AraToplam).ToString("N2") ₺</td>
                                <td class="text-end">@onizlemeler.Where(o => o.Secili).Sum(o => o.KdvToplam).ToString("N2") ₺</td>
                                <td class="text-end text-danger">-@onizlemeler.Where(o => o.Secili).Sum(o => o.TevkifatToplam).ToString("N2") ₺</td>
                                <td class="text-end">@onizlemeler.Where(o => o.Secili).Sum(o => o.GenelToplam).ToString("N2") ₺</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted">
                        @onizlemeler.Count(o => o.Durum == TopluFaturaDurum.Hazir) adet fatura kesilebilir
                    </small>
                </div>
                <div>
                    <button class="btn btn-success btn-lg" 
                            @onclick="TopluFaturaOlustur" 
                            disabled="@(!onizlemeler.Any(o => o.Secili && o.Durum == TopluFaturaDurum.Hazir) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>İşleniyor...</span>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-plus me-2"></i>
                            <span>Seçilenleri Faturala (@onizlemeler.Count(o => o.Secili && o.Durum == TopluFaturaDurum.Hazir))</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
    else if (!isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Seçilen dönem ve filtrelere uygun fatura kesilecek kayıt bulunamadı.
        </div>
    }

    <!-- Sonuç Mesajı -->
    @if (sonucMesaji != null)
    {
        <div class="alert @(sonucBasarili ? "alert-success" : "alert-danger") alert-dismissible fade show">
            <i class="bi @(sonucBasarili ? "bi-check-circle" : "bi-exclamation-triangle") me-2"></i>
            @sonucMesaji
            <button type="button" class="btn-close" @onclick="() => sonucMesaji = null"></button>
        </div>
    }
</div>

<!-- Detay Modal -->
@if (seciliOnizleme != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-receipt me-2"></i>Fatura Detayı - @seciliOnizleme.CariUnvan
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => seciliOnizleme = null"></button>
                </div>
                <div class="modal-body">
                    <!-- Fatura Bilgileri -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label">Fatura Tarihi</label>
                            <input type="date" class="form-control" @bind="seciliOnizleme.FaturaTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Vade Tarihi</label>
                            <input type="date" class="form-control" @bind="seciliOnizleme.VadeTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">KDV Oranı</label>
                            <select class="form-select" @bind="seciliOnizleme.KdvOrani">
                                <option value="0">%0</option>
                                <option value="1">%1</option>
                                <option value="10">%10</option>
                                <option value="20">%20</option>
                            </select>
                        </div>
                    </div>

                    <!-- Tevkifat -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="tevkifatli" @bind="seciliOnizleme.TevkifatliMi" />
                                <label class="form-check-label" for="tevkifatli">Tevkifatlı</label>
                            </div>
                        </div>
                        @if (seciliOnizleme.TevkifatliMi)
                        {
                            <div class="col-md-4">
                                <label class="form-label">Tevkifat Oranı (%)</label>
                                <input type="number" class="form-control" @bind="seciliOnizleme.TevkifatOrani" step="10" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">Tevkifat Kodu</label>
                                <input type="text" class="form-control" @bind="seciliOnizleme.TevkifatKodu" placeholder="Örn: 601" />
                            </div>
                        }
                    </div>

                    <!-- Kalemler -->
                    <h6 class="mb-3">Fatura Kalemleri</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th width="30">
                                        <input type="checkbox" class="form-check-input" checked disabled />
                                    </th>
                                    <th>Açıklama</th>
                                    <th class="text-end" width="80">Miktar</th>
                                    <th width="80">Birim</th>
                                    <th class="text-end" width="120">Birim Fiyat</th>
                                    <th class="text-end" width="120">Tutar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kalem in seciliOnizleme.Kalemler)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="kalem.Secili" />
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="kalem.Aciklama" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm text-end" @bind="kalem.Miktar" step="0.5" />
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="kalem.Birim" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm text-end" @bind="kalem.BirimFiyat" step="0.01" />
                                        </td>
                                        <td class="text-end align-middle">@kalem.Tutar.ToString("N2") ₺</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <td colspan="5" class="text-end fw-bold">Ara Toplam:</td>
                                    <td class="text-end fw-bold">@seciliOnizleme.AraToplam.ToString("N2") ₺</td>
                                </tr>
                                <tr>
                                    <td colspan="5" class="text-end">KDV (%@seciliOnizleme.KdvOrani):</td>
                                    <td class="text-end">@seciliOnizleme.KdvToplam.ToString("N2") ₺</td>
                                </tr>
                                @if (seciliOnizleme.TevkifatliMi)
                                {
                                    <tr>
                                        <td colspan="5" class="text-end text-danger">Tevkifat (%@seciliOnizleme.TevkifatOrani):</td>
                                        <td class="text-end text-danger">-@seciliOnizleme.TevkifatToplam.ToString("N2") ₺</td>
                                    </tr>
                                }
                                <tr class="table-success">
                                    <td colspan="5" class="text-end fw-bold">Genel Toplam:</td>
                                    <td class="text-end fw-bold">@seciliOnizleme.GenelToplam.ToString("N2") ₺</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => seciliOnizleme = null">
                        <i class="bi bi-x-lg me-1"></i>Kapat
                    </button>
                    <button type="button" class="btn btn-success" @onclick="() => TekFaturaOlustur(seciliOnizleme)" disabled="@isProcessing">
                        <i class="bi bi-check-lg me-1"></i>Fatura Oluştur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private TopluFaturaFiltre filtre = new();
    private TopluFaturaOzet? donemOzeti;
    private List<TopluFaturaOnizleme> onizlemeler = new();
    private TopluFaturaOnizleme? seciliOnizleme;
    
    private bool isLoading = false;
    private bool isProcessing = false;
    private bool tumSecili = true;
    
    private string? sonucMesaji;
    private bool sonucBasarili;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Dönem özeti
            donemOzeti = await TopluFaturaService.GetDonemOzetiAsync(filtre.Yil, filtre.Ay);

            // Önizleme
            onizlemeler = await TopluFaturaService.GetOnizlemeAsync(filtre);
            tumSecili = onizlemeler.All(o => o.Secili);
        }
        catch (Exception ex)
        {
            sonucMesaji = $"Veri yüklenirken hata: {ex.Message}";
            sonucBasarili = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnFiltreChanged()
    {
        await LoadDataAsync();
    }

    private void TumunuSec()
    {
        foreach (var o in onizlemeler.Where(x => x.Durum == TopluFaturaDurum.Hazir))
            o.Secili = true;
        tumSecili = true;
    }

    private void SecimTemizle()
    {
        foreach (var o in onizlemeler)
            o.Secili = false;
        tumSecili = false;
    }

    private void TumSeciliChanged()
    {
        foreach (var o in onizlemeler.Where(x => x.Durum == TopluFaturaDurum.Hazir))
            o.Secili = tumSecili;
    }

    private void DetayGoster(TopluFaturaOnizleme onizleme)
    {
        seciliOnizleme = onizleme;
    }

    private async Task TekFaturaOlustur(TopluFaturaOnizleme onizleme)
    {
        isProcessing = true;
        StateHasChanged();

        try
        {
            var sonuc = await TopluFaturaService.TekFaturaOlusturAsync(onizleme);

            if (sonuc.Basarili)
            {
                sonucMesaji = $"✅ Fatura oluşturuldu: {sonuc.OlusturulanFaturalar.FirstOrDefault()?.FaturaNo}";
                sonucBasarili = true;
                seciliOnizleme = null;
                await LoadDataAsync(); // Listeyi yenile
            }
            else
            {
                sonucMesaji = $"❌ Hata: {string.Join(", ", sonuc.Hatalar)}";
                sonucBasarili = false;
            }
        }
        catch (Exception ex)
        {
            sonucMesaji = $"❌ Fatura oluşturma hatası: {ex.Message}";
            sonucBasarili = false;
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task TopluFaturaOlustur()
    {
        var secilenler = onizlemeler.Where(o => o.Secili && o.Durum == TopluFaturaDurum.Hazir).ToList();
        if (!secilenler.Any()) return;

        isProcessing = true;
        StateHasChanged();

        try
        {
            var sonuc = await TopluFaturaService.FaturaOlusturAsync(secilenler);

            if (sonuc.Basarili)
            {
                sonucMesaji = $"✅ {sonuc.OlusturulanFaturaSayisi} fatura oluşturuldu. Toplam: {sonuc.ToplamTutar:N2} ₺";
                sonucBasarili = true;
                await LoadDataAsync();
            }
            else
            {
                sonucMesaji = $"❌ {sonuc.OlusturulanFaturaSayisi} başarılı, {sonuc.BasarisizFaturaSayisi} başarısız. {string.Join(", ", sonuc.Hatalar.Take(3))}";
                sonucBasarili = false;
            }
        }
        catch (Exception ex)
        {
            sonucMesaji = $"❌ Toplu fatura hatası: {ex.Message}";
            sonucBasarili = false;
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}

