@page "/cariler/yeni"
@page "/cariler/{Id:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject ICariService CariService
@inject IMuhasebeService MuhasebeService
@inject IGuzergahService GuzergahService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Cari Düzenle" : "Yeni Cari")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-person-plus me-2 text-primary"></i>@(IsEdit ? "Cari Düzenle" : "Yeni Cari Kaydı")</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/dashboard">Ana Sayfa</a></li>
                    <li class="breadcrumb-item"><a href="/cariler">Cari Listesi</a></li>
                    <li class="breadcrumb-item active">@(IsEdit ? "Düzenle" : "Yeni Kayıt")</li>
                </ol>
            </nav>
        </div>
        <button class="btn btn-outline-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri Dön
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="cari" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Cari Kodu *</label>
                            <InputText @bind-Value="cari.CariKodu" class="form-control" />
                            <small class="text-muted">Muhasebe hesap kodu aşağıda gösterilir. Hesap planında kayıt varsa otomatik getirilir.</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Cari Tipi *</label>
                            <InputSelect @bind-Value="cari.CariTipi" class="form-select">
                                @foreach (CariTipi tip in Enum.GetValues(typeof(CariTipi)))
                                {
                                    <option value="@tip">@GetTipText(tip)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Durum</label>
                            <div class="form-check form-switch mt-2">
                                <InputCheckbox @bind-Value="cari.Aktif" class="form-check-input" id="aktifCheck" />
                                <label class="form-check-label" for="aktifCheck">@(cari.Aktif ? "Aktif" : "Pasif")</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Unvan *</label>
                    <InputText @bind-Value="cari.Unvan" class="form-control" />
                    <ValidationMessage For="@(() => cari.Unvan)" />
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Vergi Dairesi</label>
                            <InputText @bind-Value="cari.VergiDairesi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Vergi No (VKN)</label>
                            <InputText @bind-Value="cari.VergiNo" class="form-control" maxlength="11"
                                       placeholder="10 veya 11 hane" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">TC Kimlik No</label>
                            <InputText @bind-Value="cari.TcKimlikNo" class="form-control" maxlength="11"
                                       placeholder="11 hane" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="cari.Telefon" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="cari.Email" class="form-control" type="email" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Yetkili Kisi</label>
                            <InputText @bind-Value="cari.YetkiliKisi" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Adres</label>
                    <InputTextArea @bind-Value="cari.Adres" class="form-control" rows="2" />
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Muhasebe Hesap Kodu</label>
                            <input type="text" class="form-control bg-light" value="@GetMuhasebeHesapGosterim()" readonly />
                            <small class="text-muted">
                                @GetMuhasebeAciklama()
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Hesap Kodu Düzeltme</label>
                            <InputSelect @bind-Value="cari.MuhasebeHesapId" class="form-select">
                                <option value="">-- Otomatik Oluştur --</option>
                                @if (muhasebeHesaplar != null)
                                {
                                    @foreach (var hesap in muhasebeHesaplar)
                                    {
                                        <option value="@hesap.Id">@hesap.HesapKodu - @hesap.HesapAdi</option>
                                    }
                                }
                            </InputSelect>
                            <small class="text-muted">Hesap planında açılmış kod varsa seçin, yoksa `Otomatik Oluştur` bırakın.</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="cari.Notlar" class="form-control" rows="2" />
                        </div>
                    </div>
                </div>

                @if (cari.CariTipi == CariTipi.Personel)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Personel carisi icin <strong>335.XX.PRSXXXXX</strong> formatinda muhasebe hesabi otomatik
                        olusturulacaktir.
                    </div>
                }

                @if (cari.CariTipi == CariTipi.Tedarikci || cari.CariTipi == CariTipi.MusteriTedarikci)
                {
                    <hr />
                    <h5 class="mb-3"><i class="bi bi-file-earmark-medical me-2 text-info"></i>Taşıma Sözleşmesi</h5>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Sözleşme No</label>
                                <InputText @bind-Value="cari.SozlesmeNo" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Sözleşme Başlangıç</label>
                                <InputDate @bind-Value="cari.SozlesmeBaslangicTarihi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Sözleşme Bitiş</label>
                                <InputDate @bind-Value="cari.SozlesmeBitisTarihi" class="form-control" />
                            </div>
                        </div>
                    </div>

                    @if (IsEdit)
                    {
                        <h6 class="mt-4 mb-2">
                            <i class="bi bi-cash-stack me-2 text-success"></i>Sefer Ücretleri
                            <small class="text-muted">(birden fazla sefer ücreti tanımlayabilirsiniz)</small>
                        </h6>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="min-width:140px;">Tanım *</th>
                                        <th>Güzergah</th>
                                        <th class="text-end" style="width:140px;">Sefer Ücreti *</th>
                                        <th style="width:150px;">Geç. Başlangıç</th>
                                        <th style="width:150px;">Geç. Bitiş</th>
                                        <th class="text-center" style="width:80px;">Aktif</th>
                                        <th style="width:80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (seferUcretleri.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">Henüz sefer ücreti tanımı yok.</td>
                                        </tr>
                                    }
                                    @foreach (var u in seferUcretleri)
                                    {
                                        <tr>
                                            <td><input class="form-control form-control-sm" @bind="u.Tanim" placeholder="Örn. Tek yön" /></td>
                                            <td>
                                                <select class="form-select form-select-sm" @bind="u.GuzergahId">
                                                    <option value="">-- Tüm güzergahlar --</option>
                                                    @foreach (var g in guzergahlar)
                                                    {
                                                        <option value="@g.Id">@g.GuzergahAdi</option>
                                                    }
                                                </select>
                                            </td>
                                            <td><input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="u.SeferUcreti" /></td>
                                            <td><input type="date" class="form-control form-control-sm" @bind="u.GecerlilikBaslangic" /></td>
                                            <td><input type="date" class="form-control form-control-sm" @bind="u.GecerlilikBitis" /></td>
                                            <td class="text-center"><input type="checkbox" class="form-check-input" @bind="u.Aktif" /></td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => SeferUcretiSil(u)" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-success" @onclick="SeferUcretiEkle">
                            <i class="bi bi-plus-lg me-1"></i>Sefer Ücreti Ekle
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-secondary small mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Sefer ücretleri, cari kaydı oluşturulduktan sonra düzenleme ekranında tanımlanabilir.
                        </div>
                    }
                }

                <hr />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>Iptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Cari cari = new() { Aktif = true };
    private List<MuhasebeHesap>? muhasebeHesaplar;
    private List<Guzergah> guzergahlar = new();
    private List<CariSeferUcreti> seferUcretleri = new();
    private List<int> silinenSeferUcretiIdleri = new();
    private bool IsEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tumHesaplar = await MuhasebeService.GetHesapPlaniAsync();
            muhasebeHesaplar = tumHesaplar
                .Where(h => h.HesapKodu.StartsWith("120.") || h.HesapKodu.StartsWith("320.") || h.HesapKodu.StartsWith("335."))
                .OrderBy(h => h.HesapKodu)
                .ToList();
        }
        catch { }

        try
        {
            guzergahlar = await GuzergahService.GetActiveAsync();
        }
        catch
        {
            guzergahlar = new List<Guzergah>();
        }

        if (IsEdit)
        {
            var existing = await CariService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                cari = existing;
                try
                {
                    seferUcretleri = await CariService.GetSeferUcretleriAsync(cari.Id);
                }
                catch
                {
                    seferUcretleri = new List<CariSeferUcreti>();
                }
            }
            else
            {
                Navigation.NavigateTo("/cariler");
            }
        }
        else
        {
            cari.CariKodu = await CariService.GenerateNextKodAsync();
            cari.CariTipi = CariTipi.Musteri;
            cari.Aktif = true;
        }
    }

    private void SeferUcretiEkle()
    {
        seferUcretleri.Add(new CariSeferUcreti
        {
            CariId = cari.Id,
            Tanim = "Tek yön",
            GecerlilikBaslangic = DateTime.Today,
            Aktif = true
        });
    }

    private void SeferUcretiSil(CariSeferUcreti ucret)
    {
        if (ucret.Id > 0)
        {
            silinenSeferUcretiIdleri.Add(ucret.Id);
        }
        seferUcretleri.Remove(ucret);
    }

    private async Task Kaydet()
    {
        if (string.IsNullOrWhiteSpace(cari.Unvan))
        {
            ToastService.ShowWarning("Unvan alani zorunludur!");
            return;
        }

        try
        {
            if (IsEdit)
            {
                await CariService.UpdateAsync(cari);
                await SeferUcretleriniKaydetAsync();
                ToastService.ShowSuccess($"{cari.Unvan} basariyla guncellendi.");
            }
            else
            {
                var olusan = await CariService.CreateAsync(cari);
                cari.Id = olusan.Id;
                await SeferUcretleriniKaydetAsync();
                ToastService.ShowSuccess($"{cari.Unvan} basariyla olusturuldu.");
            }
            Navigation.NavigateTo("/cariler");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task SeferUcretleriniKaydetAsync()
    {
        foreach (var id in silinenSeferUcretiIdleri.Distinct())
        {
            try { await CariService.DeleteSeferUcretiAsync(id); } catch { }
        }
        silinenSeferUcretiIdleri.Clear();

        foreach (var u in seferUcretleri)
        {
            if (string.IsNullOrWhiteSpace(u.Tanim)) continue;
            u.CariId = cari.Id;
            if (u.Id == 0)
            {
                await CariService.AddSeferUcretiAsync(u);
            }
            else
            {
                await CariService.UpdateSeferUcretiAsync(u);
            }
        }
    }

    private void Geri() => Navigation.NavigateTo("/cariler");

    private string GetTipText(CariTipi tip) => tip switch
    {
        CariTipi.Musteri => "Musteri",
        CariTipi.Tedarikci => "Tedarikci",
        CariTipi.MusteriTedarikci => "Musteri + Tedarikci",
        CariTipi.Personel => "Personel",
        _ => tip.ToString()
    };
    
    private string GetMuhasebeAciklama() => cari.CariTipi switch
    {
        CariTipi.Musteri => "Hesap plan kodu yoksa otomatik olusturulur (120.01.xxx)",
        CariTipi.Tedarikci => "Hesap plan kodu yoksa otomatik olusturulur (320.01.xxx)",
        CariTipi.Personel => "Hesap plan kodu yoksa otomatik olusturulur (335.XX.xxx)",
        _ => "Hesap plan kodu yoksa otomatik olusturulur"
    };

    private string GetMuhasebeHesapGosterim()
    {
        if (muhasebeHesaplar == null)
        {
            return "Otomatik Olusturulacak";
        }

        if (cari.MuhasebeHesapId.HasValue)
        {
            var bagliHesap = muhasebeHesaplar.FirstOrDefault(h => h.Id == cari.MuhasebeHesapId.Value);
            if (bagliHesap != null)
            {
                return $"{bagliHesap.HesapKodu} - {bagliHesap.HesapAdi}";
            }
        }

        return "Otomatik Olusturulacak";
    }
}

