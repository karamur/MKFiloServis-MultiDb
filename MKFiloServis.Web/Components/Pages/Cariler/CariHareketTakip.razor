@page "/cari-hareket-takip"
@page "/cari-hareket-takip/{CariId:int}"
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@using MKFiloServis.Shared.Entities
@inject ICariHareketTakipService HareketTakipService
@inject ICariService CariService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Cari Borç/Alacak Takip - MK Filo Servis</PageTitle>

<div class="container-fluid">
    <!-- Başlık -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">
                <i class="bi bi-cash-stack me-2"></i>
                @if (CariId.HasValue && cariDetay != null)
                {
                    <span>@cariDetay.Unvan - Borç/Alacak Takip</span>
                }
                else
                {
                    <span>Cari Borç/Alacak Takip</span>
                }
            </h4>
            <small class="text-muted">Detaylı borç/alacak analizi ve tahsilat planlaması</small>
        </div>
        <div>
            @if (CariId.HasValue)
            {
                <button class="btn btn-outline-secondary me-2" @onclick="GeriDon">
                    <i class="bi bi-arrow-left me-1"></i> Tüm Cariler
                </button>
            }
            <button class="btn btn-success" @onclick="ExcelExport" disabled="@yukleniyor">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel
            </button>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-2 text-muted">Veriler yükleniyor...</p>
        </div>
    }
    else if (CariId.HasValue && cariDetay != null)
    {
        <!-- Tek Cari Detay Görünümü -->
        @CariDetayGoruntule()
    }
    else if (ozetRapor != null)
    {
        <!-- Tüm Cariler Özet Görünümü -->
        @TumCarilerGoruntule()
    }
</div>

<!-- Hareket Detay Modal -->
<div class="modal fade" id="hareketModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-list-ul me-2"></i>
                    @if (secilenCari != null)
                    {
                        <span>@secilenCari.Unvan - Hareket Detayı</span>
                    }
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (secilenCariHareketler != null && secilenCariHareketler.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Tarih</th>
                                    <th>Tip</th>
                                    <th>Açıklama</th>
                                    <th>Belge No</th>
                                    <th>Vade</th>
                                    <th class="text-end">Borç</th>
                                    <th class="text-end">Alacak</th>
                                    <th class="text-end">Bakiye</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hareket in secilenCariHareketler)
                                {
                                    <tr>
                                        <td>@hareket.Tarih.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <span class="badge bg-@hareket.HareketRengi">
                                                <i class="bi @hareket.HareketIkon me-1"></i>
                                                @hareket.HareketTipi
                                            </span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(hareket.DetayUrl))
                                            {
                                                <a href="@hareket.DetayUrl">@hareket.Aciklama</a>
                                            }
                                            else
                                            {
                                                @hareket.Aciklama
                                            }
                                        </td>
                                        <td>@hareket.BelgeNo</td>
                                        <td>@hareket.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                                        <td class="text-end">@(hareket.Borc > 0 ? hareket.Borc.ToString("N2") : "")</td>
                                        <td class="text-end">@(hareket.Alacak > 0 ? hareket.Alacak.ToString("N2") : "")</td>
                                        <td class="text-end fw-bold @(hareket.Bakiye > 0 ? "text-danger" : hareket.Bakiye < 0 ? "text-success" : "")">
                                            @hareket.Bakiye.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">Hareket bulunamadı.</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? CariId { get; set; }

    private bool yukleniyor = true;
    private CariBorcAlacakOzet? ozetRapor;
    private CariHareketTakipRapor? cariDetay;
    private List<Cari> cariler = [];

    // Filtreler
    private DateTime? baslangicTarihi;
    private DateTime? bitisTarihi;
    private CariTipi? secilenCariTipi;
    private bool sadeceBorclu;
    private bool sadeceRiskli;

    // Modal için
    private CariHareketTakipOzet? secilenCari;
    private List<CariHareketDetay>? secilenCariHareketler;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        await YenileAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        yukleniyor = true;
        StateHasChanged();

        try
        {
            if (CariId.HasValue)
            {
                cariDetay = await HareketTakipService.GetCariDetayAsync(CariId.Value, baslangicTarihi, bitisTarihi);
            }
            else
            {
                ozetRapor = await HareketTakipService.GetBorcAlacakOzetAsync(
                    baslangicTarihi, bitisTarihi, secilenCariTipi, sadeceBorclu, sadeceRiskli);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hata: {ex.Message}");
        }

        yukleniyor = false;
        StateHasChanged();
    }

    private async Task HareketleriGoster(CariHareketTakipOzet cari)
    {
        secilenCari = cari;
        secilenCariHareketler = await HareketTakipService.GetCariHareketlerAsync(cari.CariId);
        await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('hareketModal')).show()");
    }

    private void CariDetayaGit(int cariId)
    {
        Navigation.NavigateTo($"/cari-hareket-takip/{cariId}");
    }

    private void GeriDon()
    {
        Navigation.NavigateTo("/cari-hareket-takip");
    }

    private async Task ExcelExport()
    {
        byte[] bytes;
        string dosyaAdi;

        if (CariId.HasValue && cariDetay != null)
        {
            bytes = await HareketTakipService.ExportCariDetayToExcelAsync(cariDetay);
            dosyaAdi = $"Cari_Detay_{cariDetay.CariKodu}_{DateTime.Now:yyyyMMdd}.xlsx";
        }
        else if (ozetRapor != null)
        {
            bytes = await HareketTakipService.ExportToExcelAsync(ozetRapor);
            dosyaAdi = $"Cari_BorcAlacak_{DateTime.Now:yyyyMMdd}.xlsx";
        }
        else return;

        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", dosyaAdi, base64);
    }

    // Tüm Cariler Görünümü
    private RenderFragment TumCarilerGoruntule() => __builder =>
    {
        <!-- Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-1">Toplam Borç</h6>
                        <h3 class="text-danger mb-0">@ozetRapor!.ToplamBorc.ToString("N2") ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-1">Toplam Alacak</h6>
                        <h3 class="text-success mb-0">@ozetRapor.ToplamAlacak.ToString("N2") ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-1">Net Bakiye</h6>
                        <h3 class="@(ozetRapor.NetBakiye > 0 ? "text-danger" : "text-success") mb-0">
                            @ozetRapor.NetBakiye.ToString("N2") ₺
                        </h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-1">Riskli Cari</h6>
                        <h3 class="text-warning mb-0">@ozetRapor.RiskliCariSayisi</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filtreler -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label small">Başlangıç Tarihi</label>
                        <input type="date" class="form-control form-control-sm" @bind="baslangicTarihi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Bitiş Tarihi</label>
                        <input type="date" class="form-control form-control-sm" @bind="bitisTarihi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Cari Tipi</label>
                        <select class="form-select form-select-sm" @bind="secilenCariTipi">
                            <option value="">Tümü</option>
                            @foreach (CariTipi tip in Enum.GetValues<CariTipi>())
                            {
                                <option value="@tip">@tip</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">&nbsp;</label>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="sadeceBorclu" id="sadeceBorclu">
                            <label class="form-check-label small" for="sadeceBorclu">Sadece Borçlu</label>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">&nbsp;</label>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="sadeceRiskli" id="sadeceRiskli">
                            <label class="form-check-label small" for="sadeceRiskli">Sadece Riskli</label>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">&nbsp;</label>
                        <button class="btn btn-primary btn-sm w-100" @onclick="YenileAsync">
                            <i class="bi bi-funnel me-1"></i> Filtrele
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vade Analizi -->
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-bar-chart me-2"></i>Vade Analizi
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col">
                                <div class="p-3 bg-success bg-opacity-10 rounded">
                                    <small class="text-muted d-block">Vadesi Gelmemiş</small>
                                    <strong class="text-success">@ozetRapor.VadesiGelmemis.ToString("N2") ₺</strong>
                                </div>
                            </div>
                            <div class="col">
                                <div class="p-3 bg-info bg-opacity-10 rounded">
                                    <small class="text-muted d-block">0-30 Gün</small>
                                    <strong class="text-info">@ozetRapor.Vadesi0_30.ToString("N2") ₺</strong>
                                </div>
                            </div>
                            <div class="col">
                                <div class="p-3 bg-warning bg-opacity-10 rounded">
                                    <small class="text-muted d-block">31-60 Gün</small>
                                    <strong class="text-warning">@ozetRapor.Vadesi31_60.ToString("N2") ₺</strong>
                                </div>
                            </div>
                            <div class="col">
                                <div class="p-3 bg-orange bg-opacity-10 rounded" style="background-color: rgba(255,165,0,0.1);">
                                    <small class="text-muted d-block">61-90 Gün</small>
                                    <strong style="color: orange;">@ozetRapor.Vadesi61_90.ToString("N2") ₺</strong>
                                </div>
                            </div>
                            <div class="col">
                                <div class="p-3 bg-danger bg-opacity-10 rounded">
                                    <small class="text-muted d-block">90+ Gün</small>
                                    <strong class="text-danger">@ozetRapor.Vadesi90Plus.ToString("N2") ₺</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-pie-chart me-2"></i>Cari Tipi Dağılımı
                    </div>
                    <div class="card-body">
                        @if (ozetRapor.TipiDagilimi.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var tip in ozetRapor.TipiDagilimi)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                                        <span>@tip.CariTipi (@tip.CariSayisi)</span>
                                        <span class="fw-bold">@tip.NetBakiye.ToString("N2") ₺</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Cari Listesi -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-table me-2"></i>Cari Borç/Alacak Listesi
                <span class="badge bg-secondary ms-2">@ozetRapor.Cariler.Count cari</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Cari</th>
                                <th>Tip</th>
                                <th class="text-end">Borç</th>
                                <th class="text-end">Alacak</th>
                                <th class="text-end">Net Bakiye</th>
                                <th class="text-end">Vadesi Geçmiş</th>
                                <th class="text-center">Risk</th>
                                <th>Son İşlem</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cari in ozetRapor.Cariler)
                            {
                                <tr class="@(cari.RiskSkoru >= 60 ? "table-warning" : "")">
                                    <td>
                                        <strong>@cari.Unvan</strong>
                                        <br /><small class="text-muted">@cari.CariKodu</small>
                                    </td>
                                    <td><span class="badge bg-secondary">@cari.CariTipi</span></td>
                                    <td class="text-end">@cari.ToplamBorc.ToString("N2")</td>
                                    <td class="text-end">@cari.ToplamAlacak.ToString("N2")</td>
                                    <td class="text-end fw-bold @(cari.NetBakiye > 0 ? "text-danger" : "text-success")">
                                        @cari.NetBakiye.ToString("N2")
                                    </td>
                                    <td class="text-end @(cari.VadesiGecmisBakiye > 0 ? "text-danger" : "")">
                                        @cari.VadesiGecmisBakiye.ToString("N2")
                                        @if (cari.VadesiGecmisFaturaSayisi > 0)
                                        {
                                            <br /><small class="text-danger">(@cari.VadesiGecmisFaturaSayisi fatura)</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-@cari.RiskRengi">
                                            @cari.RiskSkoru - @cari.RiskSeviyesi
                                        </span>
                                    </td>
                                    <td>
                                        @if (cari.SonIslemTarihi.HasValue)
                                        {
                                            <small>@cari.SonIslemTarihi.Value.ToString("dd.MM.yyyy")</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => CariDetayaGit(cari.CariId)" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-secondary" @onclick="() => HareketleriGoster(cari)" title="Hareketler">
                                                <i class="bi bi-list-ul"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    };

    // Cari Detay Görünümü
    private RenderFragment CariDetayGoruntule() => __builder =>
    {
        <!-- Cari Bilgi ve Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-person me-2"></i>Cari Bilgileri
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless mb-0">
                            <tr><td class="text-muted">Cari Kodu:</td><td><strong>@cariDetay!.CariKodu</strong></td></tr>
                            <tr><td class="text-muted">Cari Tipi:</td><td>@cariDetay.CariTipi</td></tr>
                            <tr><td class="text-muted">Telefon:</td><td>@cariDetay.Telefon</td></tr>
                            <tr><td class="text-muted">E-posta:</td><td>@cariDetay.Email</td></tr>
                            <tr><td class="text-muted">Yetkili:</td><td>@cariDetay.YetkiliKisi</td></tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-@cariDetay.BakiyeRengi">
                    <div class="card-header">
                        <i class="bi bi-wallet2 me-2"></i>Bakiye Durumu
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6 border-end">
                                <small class="text-muted d-block">Toplam Borç</small>
                                <h5 class="text-danger mb-0">@cariDetay.ToplamBorc.ToString("N2") ₺</h5>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Toplam Alacak</small>
                                <h5 class="text-success mb-0">@cariDetay.ToplamAlacak.ToString("N2") ₺</h5>
                            </div>
                        </div>
                        <hr />
                        <div class="text-center">
                            <small class="text-muted d-block">Net Bakiye</small>
                            <h3 class="text-@cariDetay.BakiyeRengi mb-0">@cariDetay.NetBakiye.ToString("N2") ₺</h3>
                            <span class="badge bg-@cariDetay.BakiyeRengi">@cariDetay.BakiyeDurumu</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-@cariDetay.RiskRengi">
                    <div class="card-header">
                        <i class="bi bi-shield-exclamation me-2"></i>Risk Analizi
                    </div>
                    <div class="card-body text-center">
                        <div class="display-4 text-@cariDetay.RiskRengi">@cariDetay.RiskSkoru</div>
                        <span class="badge bg-@cariDetay.RiskRengi fs-6">@cariDetay.RiskSeviyesi</span>
                        <hr />
                        <div class="row small">
                            <div class="col-6">
                                <span class="text-muted">Vadesi Geçmiş:</span><br />
                                <strong class="text-danger">@cariDetay.VadesiGecmisBakiye.ToString("N2") ₺</strong>
                            </div>
                            <div class="col-6">
                                <span class="text-muted">Ort. Ödeme:</span><br />
                                <strong>@cariDetay.OrtalamaOdemeSuresi gün</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- İstatistik Kartları -->
        <div class="row mb-4">
            <div class="col-md-2">
                <div class="card bg-primary bg-opacity-10">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@cariDetay.ToplamFaturaSayisi</h5>
                        <small class="text-muted">Toplam Fatura</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning bg-opacity-10">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@cariDetay.AcikFaturaSayisi</h5>
                        <small class="text-muted">Açık Fatura</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger bg-opacity-10">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@cariDetay.VadesiGecmisFaturaSayisi</h5>
                        <small class="text-muted">Vadesi Geçmiş</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success bg-opacity-10">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@cariDetay.ToplamOdemeSayisi</h5>
                        <small class="text-muted">Toplam Ödeme</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info bg-opacity-10">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@cariDetay.SonFaturaTarihi?.ToString("dd.MM")</h5>
                        <small class="text-muted">Son Fatura</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary bg-opacity-10">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@cariDetay.SonOdemeTarihi?.ToString("dd.MM")</h5>
                        <small class="text-muted">Son Ödeme</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Hareket Listesi -->
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-list-ul me-2"></i>Hareket Listesi
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 400px;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Tip</th>
                                        <th>Açıklama</th>
                                        <th class="text-end">Borç</th>
                                        <th class="text-end">Alacak</th>
                                        <th class="text-end">Bakiye</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hareket in cariDetay.Hareketler.TakeLast(50).Reverse())
                                    {
                                        <tr>
                                            <td><small>@hareket.Tarih.ToString("dd.MM.yyyy")</small></td>
                                            <td>
                                                <span class="badge bg-@hareket.HareketRengi">
                                                    <i class="bi @hareket.HareketIkon"></i>
                                                </span>
                                            </td>
                                            <td>
                                                <small>
                                                    @if (!string.IsNullOrWhiteSpace(hareket.DetayUrl))
                                                    {
                                                        <a href="@hareket.DetayUrl">@hareket.Aciklama</a>
                                                    }
                                                    else
                                                    {
                                                        @hareket.Aciklama
                                                    }
                                                </small>
                                            </td>
                                            <td class="text-end"><small>@(hareket.Borc > 0 ? hareket.Borc.ToString("N2") : "")</small></td>
                                            <td class="text-end"><small>@(hareket.Alacak > 0 ? hareket.Alacak.ToString("N2") : "")</small></td>
                                            <td class="text-end fw-bold @(hareket.Bakiye > 0 ? "text-danger" : "text-success")">
                                                <small>@hareket.Bakiye.ToString("N2")</small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Açık Faturalar ve Tahsilat Planı -->
            <div class="col-md-4">
                <!-- Açık Faturalar -->
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-file-text me-2"></i>Açık Faturalar
                        <span class="badge bg-warning ms-1">@cariDetay.AcikFaturalar.Count</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var fatura in cariDetay.AcikFaturalar.Take(10))
                            {
                                <div class="list-group-item list-group-item-action py-2">
                                    <div class="d-flex justify-content-between">
                                        <strong>@fatura.FaturaNo</strong>
                                        <span class="badge bg-@fatura.VadeRengi">@fatura.VadeDurumu</span>
                                    </div>
                                    <div class="d-flex justify-content-between small text-muted">
                                        <span>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</span>
                                        <span class="text-danger">@fatura.KalanTutar.ToString("N2") ₺</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Tahsilat Planı -->
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-calendar-check me-2"></i>Tahsilat Planı
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var plan in cariDetay.TahsilatPlani.Take(10))
                            {
                                <div class="list-group-item py-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-@plan.OncelikRengi me-1">@plan.OncelikSirasi</span>
                                            <strong>@plan.FaturaNo</strong>
                                        </div>
                                        <strong>@plan.PlanTutar.ToString("N2") ₺</strong>
                                    </div>
                                    <small class="text-muted">@plan.Aciklama</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aylık Trend Grafiği -->
        @if (cariDetay.AylikTrendler.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <i class="bi bi-graph-up me-2"></i>Aylık Trend (Son 12 Ay)
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm text-center">
                            <thead>
                                <tr>
                                    @foreach (var trend in cariDetay.AylikTrendler)
                                    {
                                        <th>@trend.AyAdi</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    @foreach (var trend in cariDetay.AylikTrendler)
                                    {
                                        <td>
                                            <small class="d-block text-danger">+@trend.ToplamBorc.ToString("N0")</small>
                                            <small class="d-block text-success">-@trend.ToplamAlacak.ToString("N0")</small>
                                            <strong class="@(trend.AySonuBakiye > 0 ? "text-danger" : "text-success")">
                                                @trend.AySonuBakiye.ToString("N0")
                                            </strong>
                                        </td>
                                    }
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    };
}

