@page "/cari/risk-analizi"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject ICariRiskService RiskService
@inject IOllamaService OllamaService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Cari Risk Analizi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-shield-exclamation me-2 text-danger"></i>Cari Risk Analizi</h3>
            <small class="text-muted">Müşteri risk skorlaması, vadesi geçmiş alacak takibi</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm" @onclick="ExcelExport" disabled="@(isLoading || !riskKartlari.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="YenileAsync" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Risk analizi yükleniyor...</p>
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        <div class="row g-3 mb-4">
            <div class="col-md-2">
                <div class="card h-100 border-primary">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Toplam Cari</div>
                        <div class="fs-3 fw-bold text-primary">@ozet.ToplamCariSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card h-100 border-danger">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Riskli Cari</div>
                        <div class="fs-3 fw-bold text-danger">@ozet.RiskliCariSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card h-100 border-warning">
                    <div class="card-body py-2 text-center">
                        <div class="text-muted small">Vadesi Geçmiş</div>
                        <div class="fs-3 fw-bold text-warning">@ozet.VadesiGecmisCariSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 bg-danger text-white">
                    <div class="card-body py-2 text-center">
                        <div class="small opacity-75">Vadesi Geçmiş Borç</div>
                        <div class="fs-4 fw-bold">@FormatPara(ozet.ToplamVadesiGecmisBorc)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 bg-info text-white">
                    <div class="card-body py-2 text-center">
                        <div class="small opacity-75">Ort. Tahsilat Süresi</div>
                        <div class="fs-4 fw-bold">@ozet.OrtalamaTahsilatSuresi.ToString("N0") <small>gün</small></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- Sol: Risk Dağılımı & Trend -->
            <div class="col-md-4">
                <!-- Risk Dağılımı -->
                <div class="card shadow-sm mb-3">
                    <div class="card-header py-2 bg-light">
                        <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Risk Dağılımı</h6>
                    </div>
                    <div class="card-body py-2">
                        @{
                            var kritik = riskKartlari.Count(r => r.RiskSeviyesi == RiskSeviyesi.KritikRisk);
                            var yuksek = riskKartlari.Count(r => r.RiskSeviyesi == RiskSeviyesi.YuksekRisk);
                            var orta = riskKartlari.Count(r => r.RiskSeviyesi == RiskSeviyesi.OrtaRisk);
                            var dusuk = riskKartlari.Count(r => r.RiskSeviyesi == RiskSeviyesi.DusukRisk);
                            var toplam = riskKartlari.Count;
                        }
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><span class="badge bg-danger me-1">●</span>Kritik Risk</span>
                                <strong>@kritik <small class="text-muted">(%@(toplam > 0 ? (kritik * 100 / toplam) : 0))</small></strong>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-danger" style="width: @(toplam > 0 ? (kritik * 100 / toplam) : 0)%"></div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><span class="badge bg-warning text-dark me-1">●</span>Yüksek Risk</span>
                                <strong>@yuksek <small class="text-muted">(%@(toplam > 0 ? (yuksek * 100 / toplam) : 0))</small></strong>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-warning" style="width: @(toplam > 0 ? (yuksek * 100 / toplam) : 0)%"></div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><span class="badge bg-info me-1">●</span>Orta Risk</span>
                                <strong>@orta <small class="text-muted">(%@(toplam > 0 ? (orta * 100 / toplam) : 0))</small></strong>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-info" style="width: @(toplam > 0 ? (orta * 100 / toplam) : 0)%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><span class="badge bg-success me-1">●</span>Düşük Risk</span>
                                <strong>@dusuk <small class="text-muted">(%@(toplam > 0 ? (dusuk * 100 / toplam) : 0))</small></strong>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" style="width: @(toplam > 0 ? (dusuk * 100 / toplam) : 0)%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Yaşlandırma Analizi -->
                <div class="card shadow-sm mb-3">
                    <div class="card-header py-2 bg-light">
                        <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Alacak Yaşlandırma</h6>
                    </div>
                    <div class="card-body py-2">
                        @{
                            var toplamYaslandirma = riskKartlari.Sum(r => r.Vade0_30) + 
                                                    riskKartlari.Sum(r => r.Vade31_60) + 
                                                    riskKartlari.Sum(r => r.Vade61_90) + 
                                                    riskKartlari.Sum(r => r.Vade90Plus);
                        }
                        <table class="table table-sm table-borderless mb-0">
                            <tbody>
                                <tr>
                                    <td><span class="badge bg-success">0-30 gün</span></td>
                                    <td class="text-end">@FormatPara(riskKartlari.Sum(r => r.Vade0_30))</td>
                                </tr>
                                <tr>
                                    <td><span class="badge bg-info">31-60 gün</span></td>
                                    <td class="text-end">@FormatPara(riskKartlari.Sum(r => r.Vade31_60))</td>
                                </tr>
                                <tr>
                                    <td><span class="badge bg-warning text-dark">61-90 gün</span></td>
                                    <td class="text-end">@FormatPara(riskKartlari.Sum(r => r.Vade61_90))</td>
                                </tr>
                                <tr>
                                    <td><span class="badge bg-danger">90+ gün</span></td>
                                    <td class="text-end">@FormatPara(riskKartlari.Sum(r => r.Vade90Plus))</td>
                                </tr>
                                <tr class="border-top">
                                    <td><strong>TOPLAM</strong></td>
                                    <td class="text-end"><strong>@FormatPara(toplamYaslandirma)</strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- AI Analiz -->
                <div class="card shadow-sm border-info">
                    <div class="card-header py-2 bg-info bg-opacity-10">
                        <h6 class="mb-0"><i class="bi bi-robot me-2 text-info"></i>AI Risk Analizi</h6>
                    </div>
                    <div class="card-body">
                        @if (aiYukleniyor)
                        {
                            <div class="text-center py-3">
                                <div class="spinner-border spinner-border-sm text-info"></div>
                                <p class="small text-muted mt-1 mb-0">AI analiz yapılıyor...</p>
                            </div>
                        }
                        else if (string.IsNullOrEmpty(aiSonuc))
                        {
                            <div class="text-center py-2">
                                <button class="btn btn-info btn-sm" @onclick="TopluAIAnalizBaslat">
                                    <i class="bi bi-lightning-charge me-1"></i>Genel Risk Analizi Yap
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-2 bg-light" style="white-space: pre-wrap; font-size: 0.85rem; max-height: 300px; overflow-y: auto;">@aiSonuc</div>
                            <button class="btn btn-outline-secondary btn-sm mt-2 w-100" @onclick="() => aiSonuc = string.Empty">
                                <i class="bi bi-x-lg me-1"></i>Temizle
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Sağ: Risk Listesi -->
            <div class="col-md-8">
                <!-- Filtreler -->
                <div class="card shadow-sm mb-3">
                    <div class="card-body py-2 bg-light">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label small mb-1">Risk Seviyesi</label>
                                <select class="form-select form-select-sm" @bind="filtreRiskSeviyesi" @bind:after="FiltreUygula">
                                    <option value="">Tümü</option>
                                    <option value="4">Kritik Risk</option>
                                    <option value="3">Yüksek Risk</option>
                                    <option value="2">Orta Risk</option>
                                    <option value="1">Düşük Risk</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small mb-1">Min. Gecikme (gün)</label>
                                <input type="number" class="form-control form-control-sm" @bind="filtreMinGecikme" @bind:after="FiltreUygula" placeholder="0" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small mb-1">Min. Borç (₺)</label>
                                <input type="number" class="form-control form-control-sm" @bind="filtreMinBorc" @bind:after="FiltreUygula" placeholder="0" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small mb-1">Ara</label>
                                <input type="text" class="form-control form-control-sm" @bind="aramaMetni" @bind:event="oninput" @bind:after="FiltreUygula" placeholder="Cari adı..." />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Risk Kartları Listesi -->
                <div class="card shadow-sm">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Risk Kartları</h6>
                        <span class="badge bg-secondary">@filtrelenmisKartlar.Count kayıt</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 550px; overflow-y: auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th style="width: 50px;">Risk</th>
                                        <th>Cari</th>
                                        <th class="text-end">Vadesi Geçmiş</th>
                                        <th class="text-center">Gecikme</th>
                                        <th class="text-end">Bakiye</th>
                                        <th class="text-center">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var kart in filtrelenmisKartlar.Take(50))
                                    {
                                        <tr class="@GetSatirClass(kart.RiskSeviyesi)">
                                            <td class="text-center">
                                                <div class="d-flex flex-column align-items-center">
                                                    <span class="badge @GetRiskBadgeClass(kart.RiskSeviyesi)" style="font-size: 0.9rem;">@kart.RiskSkoru</span>
                                                    <small class="text-muted" style="font-size: 0.65rem;">@GetRiskSeviyesiAdi(kart.RiskSeviyesi)</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@kart.CariUnvan</strong>
                                                    <br /><small class="text-muted">@kart.CariKodu</small>
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                @if (kart.VadesiGecmisBorc > 0)
                                                {
                                                    <strong class="text-danger">@FormatPara(kart.VadesiGecmisBorc)</strong>
                                                    <br /><small class="text-muted">@kart.VadesiGecmisFaturaSayisi fatura</small>
                                                }
                                                else
                                                {
                                                    <span class="text-success">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (kart.VadesiGecmisGunSayisi > 0)
                                                {
                                                    <span class="badge @(kart.VadesiGecmisGunSayisi > 90 ? "bg-danger" : kart.VadesiGecmisGunSayisi > 30 ? "bg-warning text-dark" : "bg-info")">
                                                        @kart.VadesiGecmisGunSayisi gün
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-success">-</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <span class="@(kart.Bakiye > 0 ? "text-success" : kart.Bakiye < 0 ? "text-danger" : "")">
                                                    @FormatPara(Math.Abs(kart.Bakiye))
                                                </span>
                                                <br /><small class="text-muted">@(kart.Bakiye > 0 ? "Alacak" : kart.Bakiye < 0 ? "Borç" : "")</small>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-info py-0 px-1" @onclick="() => CariDetayAc(kart.CariId)" title="Detay">
                                                        <i class="bi bi-eye" style="font-size: 0.7rem;"></i>
                                                    </button>
                                                    <button class="btn btn-outline-primary py-0 px-1" @onclick="() => AIAnalizAc(kart)" title="AI Analiz">
                                                        <i class="bi bi-robot" style="font-size: 0.7rem;"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Cari AI Analiz Modal -->
@if (showAIModal && secilenKart != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-robot me-2"></i>AI Risk Analizi - @secilenKart.CariUnvan
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <!-- Risk Özet -->
                    <div class="row g-2 mb-3">
                        <div class="col-md-3">
                            <div class="card bg-light text-center">
                                <div class="card-body py-2">
                                    <small class="text-muted">Risk Skoru</small>
                                    <h3 class="mb-0 @GetRiskTextClass(secilenKart.RiskSeviyesi)">@secilenKart.RiskSkoru</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light text-center">
                                <div class="card-body py-2">
                                    <small class="text-muted">Vadesi Geçmiş</small>
                                    <h5 class="mb-0 text-danger">@FormatPara(secilenKart.VadesiGecmisBorc)</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light text-center">
                                <div class="card-body py-2">
                                    <small class="text-muted">Gecikme</small>
                                    <h5 class="mb-0 text-warning">@secilenKart.VadesiGecmisGunSayisi gün</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light text-center">
                                <div class="card-body py-2">
                                    <small class="text-muted">Vade Uyum</small>
                                    <h5 class="mb-0 @(secilenKart.OdemeVadeUyumOrani >= 70 ? "text-success" : "text-warning")">%@secilenKart.OdemeVadeUyumOrani.ToString("N0")</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Risk Faktörleri -->
                    @if (secilenKart.RiskFaktorleri.Any())
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <strong><i class="bi bi-exclamation-triangle me-1"></i>Risk Faktörleri:</strong>
                            <ul class="mb-0 mt-1">
                                @foreach (var faktor in secilenKart.RiskFaktorleri)
                                {
                                    <li><small>@faktor</small></li>
                                }
                            </ul>
                        </div>
                    }

                    <!-- AI Analiz -->
                    @if (aiModalYukleniyor)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-info"></div>
                            <p class="text-muted mt-2">AI analiz yapılıyor...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(aiModalSonuc))
                    {
                        <div class="card">
                            <div class="card-header bg-info bg-opacity-10 py-2">
                                <i class="bi bi-robot me-2"></i>AI Değerlendirmesi
                            </div>
                            <div class="card-body">
                                <div style="white-space: pre-wrap; font-size: 0.9rem; line-height: 1.6;">@aiModalSonuc</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <button class="btn btn-info" @onclick="CariAIAnalizBaslat">
                                <i class="bi bi-lightning-charge me-1"></i>AI Analizi Başlat
                            </button>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-primary" @onclick="() => CariDetayAc(secilenKart.CariId)">
                        <i class="bi bi-eye me-1"></i>Cari Detay
                    </button>
                    <button class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private CariRiskOzet ozet = new();
    private List<CariRiskKarti> riskKartlari = new();
    private List<CariRiskKarti> filtrelenmisKartlar = new();
    
    // Filtreler
    private string? filtreRiskSeviyesi;
    private int? filtreMinGecikme;
    private decimal? filtreMinBorc;
    private string? aramaMetni;
    
    // AI
    private bool aiYukleniyor;
    private string aiSonuc = string.Empty;
    
    // Modal
    private bool showAIModal;
    private CariRiskKarti? secilenKart;
    private bool aiModalYukleniyor;
    private string aiModalSonuc = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        try
        {
            ozet = await RiskService.GetRiskOzetAsync();
            riskKartlari = await RiskService.GetRiskKartlariAsync();
            FiltreUygula();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FiltreUygula()
    {
        var filtre = new CariRiskFilterParams
        {
            SearchTerm = aramaMetni,
            MinGecikmeGunu = filtreMinGecikme,
            MinBorcTutari = filtreMinBorc
        };
        
        if (!string.IsNullOrEmpty(filtreRiskSeviyesi) && int.TryParse(filtreRiskSeviyesi, out var seviye))
            filtre.RiskSeviyesi = (RiskSeviyesi)seviye;
        
        filtrelenmisKartlar = riskKartlari;
        
        if (filtre.RiskSeviyesi.HasValue)
            filtrelenmisKartlar = filtrelenmisKartlar.Where(r => r.RiskSeviyesi == filtre.RiskSeviyesi.Value).ToList();
        
        if (filtre.MinGecikmeGunu.HasValue && filtre.MinGecikmeGunu > 0)
            filtrelenmisKartlar = filtrelenmisKartlar.Where(r => r.VadesiGecmisGunSayisi >= filtre.MinGecikmeGunu.Value).ToList();
        
        if (filtre.MinBorcTutari.HasValue && filtre.MinBorcTutari > 0)
            filtrelenmisKartlar = filtrelenmisKartlar.Where(r => r.VadesiGecmisBorc >= filtre.MinBorcTutari.Value).ToList();
        
        if (!string.IsNullOrEmpty(filtre.SearchTerm))
            filtrelenmisKartlar = filtrelenmisKartlar.Where(r => 
                r.CariUnvan.Contains(filtre.SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                r.CariKodu.Contains(filtre.SearchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task TopluAIAnalizBaslat()
    {
        aiYukleniyor = true;
        try
        {
            aiSonuc = await RiskService.GetTopluAIRiskAnaliziAsync();
        }
        catch (Exception ex)
        {
            aiSonuc = $"AI analiz hatası: {ex.Message}";
        }
        finally
        {
            aiYukleniyor = false;
        }
    }

    private void AIAnalizAc(CariRiskKarti kart)
    {
        secilenKart = kart;
        aiModalSonuc = string.Empty;
        showAIModal = true;
    }

    private async Task CariAIAnalizBaslat()
    {
        if (secilenKart == null) return;
        
        aiModalYukleniyor = true;
        try
        {
            aiModalSonuc = await RiskService.GetAIRiskAnaliziAsync(secilenKart.CariId);
        }
        catch (Exception ex)
        {
            aiModalSonuc = $"AI analiz hatası: {ex.Message}";
        }
        finally
        {
            aiModalYukleniyor = false;
        }
    }

    private void ModalKapat()
    {
        showAIModal = false;
        secilenKart = null;
        aiModalSonuc = string.Empty;
    }

    private void CariDetayAc(int cariId)
    {
        Navigation.NavigateTo($"/cariler/form/{cariId}");
    }

    private async Task ExcelExport()
    {
        // TODO: Excel export implementasyonu
        ToastService.ShowInfo("Excel export yakında eklenecek.");
    }

    #region Helpers

    private static string FormatPara(decimal tutar) => tutar.ToString("N2") + " ₺";

    private static string GetRiskBadgeClass(RiskSeviyesi seviye) => seviye switch
    {
        RiskSeviyesi.KritikRisk => "bg-danger",
