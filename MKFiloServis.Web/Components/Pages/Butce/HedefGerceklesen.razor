@page "/butce/hedef-gerceklesen"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IBudgetService BudgetService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Bütçe Hedef / Gerçekleşen Karşılaştırma</PageTitle>

<div class="container-fluid">
    <!-- Başlık ve Butonlar -->
    <div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
        <h3><i class="bi bi-bullseye me-2"></i>Hedef / Gerçekleşen Karşılaştırma</h3>
        <div class="btn-group">
            <button class="btn btn-outline-dark" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Yazdır
            </button>
            <button class="btn btn-success" @onclick="ExcelExport">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-primary" @onclick="() => showHedefModal = true">
                <i class="bi bi-plus-circle me-1"></i>Hedef Ekle
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3 d-print-none">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Yıl</label>
                    <select class="form-select form-select-sm" @bind="seciliYil" @bind:after="Yenile">
                        @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 3; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ay</label>
                    <select class="form-select form-select-sm" @bind="seciliAy" @bind:after="Yenile">
                        <option value="0">Tüm Yıl</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="seciliFirmaId" @bind:after="Yenile">
                        <option value="">Tümü</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Görünüm</label>
                    <div class="btn-group w-100">
                        <button class="btn btn-sm @(gorunum == "ozet" ? "btn-primary" : "btn-outline-primary")" @onclick='() => gorunum = "ozet"'>
                            <i class="bi bi-card-list"></i> Özet
                        </button>
                        <button class="btn btn-sm @(gorunum == "grafik" ? "btn-primary" : "btn-outline-primary")" @onclick='() => gorunum = "grafik"'>
                            <i class="bi bi-bar-chart"></i> Grafik
                        </button>
                        <button class="btn btn-sm @(gorunum == "hedefler" ? "btn-primary" : "btn-outline-primary")" @onclick='() => gorunum = "hedefler"'>
                            <i class="bi bi-gear"></i> Hedefler
                        </button>
                    </div>
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="KopyalaOncekiYil" title="Önceki yıldan hedefleri kopyala">
                        <i class="bi bi-copy me-1"></i>@(seciliYil - 1)'den Kopyala
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <!-- Özet Kartlar -->
        @if (yillikOzet != null)
        {
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card border-primary h-100">
                        <div class="card-body text-center">
                            <h6 class="text-muted"><i class="bi bi-bullseye me-1"></i>Toplam Hedef</h6>
                            <h3 class="text-primary">@yillikOzet.ToplamHedef.ToString("N0") ₺</h3>
                            <small class="text-muted">@seciliYil yılı</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-info h-100">
                        <div class="card-body text-center">
                            <h6 class="text-muted"><i class="bi bi-cash-stack me-1"></i>Gerçekleşen</h6>
                            <h3 class="text-info">@yillikOzet.ToplamGerceklesen.ToString("N0") ₺</h3>
                            <small class="text-muted">Ödenen toplam</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card @(yillikOzet.ToplamFark <= 0 ? "border-success" : "border-danger") h-100">
                        <div class="card-body text-center">
                            <h6 class="text-muted"><i class="bi bi-arrow-left-right me-1"></i>Fark</h6>
                            <h3 class="@(yillikOzet.ToplamFark <= 0 ? "text-success" : "text-danger")">
                                @(yillikOzet.ToplamFark >= 0 ? "+" : "")@yillikOzet.ToplamFark.ToString("N0") ₺
                            </h3>
                            <small class="text-muted">@(yillikOzet.ToplamFark <= 0 ? "Hedef altında" : "Hedef aşıldı")</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <h6 class="text-muted"><i class="bi bi-percent me-1"></i>Başarı Oranı</h6>
                            <h3 class="@GetBasariRenkClass(yillikOzet.BasariOrani)">%@yillikOzet.BasariOrani.ToString("N1")</h3>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar @GetBasariBarClass(yillikOzet.BasariOrani)" 
                                     style="width: @Math.Min(100, yillikOzet.BasariOrani)%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (gorunum == "ozet")
        {
            <!-- Kategori Bazlı Karşılaştırma Tablosu -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-table me-2"></i>Kategori Bazlı Hedef / Gerçekleşen
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Masraf Kalemi</th>
                                    <th class="text-end">Hedef</th>
                                    <th class="text-end">Gerçekleşen</th>
                                    <th class="text-end">Fark</th>
                                    <th class="text-end">Oran</th>
                                    <th style="width: 200px;">İlerleme</th>
                                    <th class="text-center">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in hedefGerceklesenList.OrderByDescending(h => h.GerceklesenTutar))
                                {
                                    var oran = item.HedefTutar > 0 ? (item.GerceklesenTutar / item.HedefTutar) * 100 : 0;
                                    <tr>
                                        <td>
                                            <span class="badge me-2" style="background-color: @(item.Renk ?? "#6c757d")">
                                                <i class="bi bi-circle-fill"></i>
                                            </span>
                                            @item.MasrafKalemi
                                        </td>
                                        <td class="text-end">@item.HedefTutar.ToString("N0") ₺</td>
                                        <td class="text-end fw-bold">@item.GerceklesenTutar.ToString("N0") ₺</td>
                                        <td class="text-end @(item.Fark <= 0 ? "text-success" : "text-danger")">
                                            @(item.Fark >= 0 ? "+" : "")@item.Fark.ToString("N0") ₺
                                        </td>
                                        <td class="text-end">
                                            @if (item.HedefTutar > 0)
                                            {
                                                <span class="@(oran <= 100 ? "text-success" : "text-danger")">%@oran.ToString("N1")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.HedefTutar > 0)
                                            {
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar @(oran <= 100 ? "bg-success" : "bg-danger")" 
                                                         role="progressbar" 
                                                         style="width: @Math.Min(100, oran)%">
                                                        @if (oran >= 15)
                                                        {
                                                            <small>@oran.ToString("N0")%</small>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Hedef tanımsız</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.HedefTutar == 0)
                                            {
                                                <span class="badge bg-secondary"><i class="bi bi-question-circle"></i></span>
                                            }
                                            else if (item.Durum == "Basarili")
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Başarılı</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Aşım</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td>TOPLAM</td>
                                    <td class="text-end">@hedefGerceklesenList.Sum(h => h.HedefTutar).ToString("N0") ₺</td>
                                    <td class="text-end">@hedefGerceklesenList.Sum(h => h.GerceklesenTutar).ToString("N0") ₺</td>
                                    <td class="text-end @(hedefGerceklesenList.Sum(h => h.Fark) <= 0 ? "text-success" : "text-danger")">
                                        @{var toplamFark = hedefGerceklesenList.Sum(h => h.Fark);}
                                        @(toplamFark >= 0 ? "+" : "")@toplamFark.ToString("N0") ₺
                                    </td>
                                    <td colspan="3"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Aylık Trend Tablosu -->
            @if (yillikOzet?.AylikDetaylar?.Any() == true)
            {
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-calendar3 me-2"></i>Aylık Hedef / Gerçekleşen Trend
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th></th>
                                        @foreach (var ay in yillikOzet.AylikDetaylar)
                                        {
                                            <th class="text-center">@ay.AyAdi.Substring(0, 3)</th>
                                        }
                                        <th class="text-center table-secondary">TOPLAM</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="fw-bold">Hedef</td>
                                        @foreach (var ay in yillikOzet.AylikDetaylar)
                                        {
                                            <td class="text-center text-muted">@ay.HedefTutar.ToString("N0")</td>
                                        }
                                        <td class="text-center table-secondary fw-bold">@yillikOzet.ToplamHedef.ToString("N0")</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Gerçekleşen</td>
                                        @foreach (var ay in yillikOzet.AylikDetaylar)
                                        {
                                            <td class="text-center @(ay.GerceklesenTutar <= ay.HedefTutar ? "text-success" : "text-danger") fw-bold">
                                                @ay.GerceklesenTutar.ToString("N0")
                                            </td>
                                        }
                                        <td class="text-center table-secondary fw-bold">@yillikOzet.ToplamGerceklesen.ToString("N0")</td>
                                    </tr>
                                    <tr class="table-light">
                                        <td>Fark</td>
                                        @foreach (var ay in yillikOzet.AylikDetaylar)
                                        {
                                            <td class="text-center small @(ay.Fark <= 0 ? "text-success" : "text-danger")">
                                                @(ay.Fark >= 0 ? "+" : "")@ay.Fark.ToString("N0")
                                            </td>
                                        }
                                        <td class="text-center table-secondary small @(yillikOzet.ToplamFark <= 0 ? "text-success" : "text-danger")">
                                            @(yillikOzet.ToplamFark >= 0 ? "+" : "")@yillikOzet.ToplamFark.ToString("N0")
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
        else if (gorunum == "grafik")
        {
            <!-- Grafik Görünümü -->
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-bar-chart me-2"></i>Kategori Karşılaştırma
                        </div>
                        <div class="card-body">
                            <canvas id="kategoriChart" height="300"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-pie-chart me-2"></i>Hedef Dağılımı
                        </div>
                        <div class="card-body">
                            <canvas id="hedefPieChart" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-graph-up me-2"></i>Aylık Trend
                </div>
                <div class="card-body">
                    <canvas id="trendChart" height="200"></canvas>
                </div>
            </div>
        }
        else if (gorunum == "hedefler")
        {
            <!-- Hedef Yönetimi -->
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-gear me-2"></i>Hedef Tanımları - @seciliYil</span>
                    <button class="btn btn-sm btn-primary" @onclick="() => showHedefModal = true">
                        <i class="bi bi-plus"></i> Yeni Hedef
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Masraf Kalemi</th>
                                    <th>Dönem</th>
                                    <th class="text-end">Hedef Tutar</th>
                                    <th>Açıklama</th>
                                    <th>Firma</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!hedefler.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            Henüz hedef tanımlanmamış. 
                                            <a href="javascript:void(0)" @onclick="() => showHedefModal = true">Hedef ekleyin</a>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var hedef in hedefler.OrderBy(h => h.Ay).ThenBy(h => h.MasrafKalemi))
                                    {
                                        <tr>
                                            <td><strong>@hedef.MasrafKalemi</strong></td>
                                            <td>
                                                @if (hedef.Ay == 0)
                                                {
                                                    <span class="badge bg-primary">Yıllık</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">@GetAyAdi(hedef.Ay)</span>
                                                }
                                            </td>
                                            <td class="text-end fw-bold">@hedef.HedefTutar.ToString("N0") ₺</td>
                                            <td class="text-muted small">@hedef.Aciklama</td>
                                            <td>@(hedef.Firma?.FirmaAdi ?? "-")</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => HedefDuzenle(hedef)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => HedefSil(hedef)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Hedef Ekleme/Düzenleme Modal -->
@if (showHedefModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-bullseye me-2"></i>
                        @(editingHedef?.Id > 0 ? "Hedef Düzenle" : "Yeni Hedef")
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Masraf Kalemi <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="editingHedef!.MasrafKalemi">
                            <option value="">-- Seçiniz --</option>
                            @foreach (var kalem in masrafKalemleri)
                            {
                                <option value="@kalem.KalemAdi">@kalem.KalemAdi</option>
                            }
                        </select>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Yıl</label>
                            <select class="form-select" @bind="editingHedef.Yil">
                                @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 2; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Dönem</label>
                            <select class="form-select" @bind="editingHedef.Ay">
                                <option value="0">Yıllık Hedef</option>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@GetAyAdi(m)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hedef Tutar <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="number" class="form-control" @bind="editingHedef.HedefTutar" step="100" />
                            <span class="input-group-text">₺</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Firma (opsiyonel)</label>
                        <select class="form-select" @bind="editingHedef.FirmaId">
                            <option value="">Tüm firmalar</option>
                            @foreach (var firma in firmalar)
                            {
                                <option value="@firma.Id">@firma.FirmaAdi</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <input type="text" class="form-control" @bind="editingHedef.Aciklama" placeholder="Opsiyonel not..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="HedefKaydet">
                        <i class="bi bi-check-circle me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private int seciliYil = DateTime.Today.Year;
    private int seciliAy = 0; // 0 = Tüm yıl
    private int? seciliFirmaId;
    private string gorunum = "ozet";
    
    private List<Firma> firmalar = new();
    private List<BudgetMasrafKalemi> masrafKalemleri = new();
    private List<BudgetHedef> hedefler = new();
    private List<BudgetHedefGerceklesen> hedefGerceklesenList = new();
    private BudgetYillikHedefOzet? yillikOzet;
    
    private bool showHedefModal = false;
    private BudgetHedef? editingHedef;

    private static readonly string[] AyAdlari = { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran",
                                                   "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && gorunum == "grafik" && !isLoading)
        {
            await RenderCharts();
        }
    }

    private async Task LoadInitialData()
    {
        isLoading = true;
        
        firmalar = await FirmaService.GetAllAsync();
        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
        
        await Yenile();
    }

    private async Task Yenile()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            int? firmaId = string.IsNullOrEmpty(seciliFirmaId?.ToString()) ? null : seciliFirmaId;
            int? ay = seciliAy == 0 ? null : seciliAy;

            hedefler = await BudgetService.GetHedeflerAsync(seciliYil, ay, firmaId);
            hedefGerceklesenList = await BudgetService.GetHedefGerceklesenAsync(seciliYil, ay, firmaId);
            yillikOzet = await BudgetService.GetYillikHedefOzetAsync(seciliYil, firmaId);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yükleme hatası: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RenderCharts()
    {
        try
        {
            // Kategori karşılaştırma grafiği
            var labels = hedefGerceklesenList.Select(h => h.MasrafKalemi).ToArray();
            var hedefData = hedefGerceklesenList.Select(h => h.HedefTutar).ToArray();
            var gerceklesenData = hedefGerceklesenList.Select(h => h.GerceklesenTutar).ToArray();
            var renkler = hedefGerceklesenList.Select(h => h.Renk ?? "#6c757d").ToArray();

            await JS.InvokeVoidAsync("renderKategoriChart", "kategoriChart", labels, hedefData, gerceklesenData);
            await JS.InvokeVoidAsync("renderHedefPieChart", "hedefPieChart", labels, hedefData, renkler);

            // Aylık trend grafiği
            if (yillikOzet?.AylikDetaylar?.Any() == true)
            {
                var ayLabels = yillikOzet.AylikDetaylar.Select(a => a.AyAdi).ToArray();
                var ayHedef = yillikOzet.AylikDetaylar.Select(a => a.HedefTutar).ToArray();
                var ayGerceklesen = yillikOzet.AylikDetaylar.Select(a => a.GerceklesenTutar).ToArray();
                
                await JS.InvokeVoidAsync("renderTrendChart", "trendChart", ayLabels, ayHedef, ayGerceklesen);
            }
        }
        catch
        {
            // Chart.js yüklü değilse veya hata oluşursa sessizce devam et
        }
    }

    private void HedefDuzenle(BudgetHedef hedef)
    {
        editingHedef = new BudgetHedef
        {
            Id = hedef.Id,
            Yil = hedef.Yil,
            Ay = hedef.Ay,
            MasrafKalemi = hedef.MasrafKalemi,
            HedefTutar = hedef.HedefTutar,
            Aciklama = hedef.Aciklama,
            FirmaId = hedef.FirmaId
        };
        showHedefModal = true;
    }

    private async Task HedefSil(BudgetHedef hedef)
    {
        try
        {
            await BudgetService.DeleteHedefAsync(hedef.Id);
            ToastService.ShowSuccess("Hedef silindi");
            await Yenile();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme hatası: {ex.Message}");
        }
    }

    private async Task HedefKaydet()
    {
        if (editingHedef == null || string.IsNullOrEmpty(editingHedef.MasrafKalemi))
        {
            ToastService.ShowWarning("Masraf kalemi seçiniz");
            return;
        }

        if (editingHedef.HedefTutar <= 0)
        {
            ToastService.ShowWarning("Hedef tutar giriniz");
            return;
        }

        try
        {
            if (editingHedef.Id > 0)
            {
                await BudgetService.UpdateHedefAsync(editingHedef);
                ToastService.ShowSuccess("Hedef güncellendi");
            }
            else
            {
                await BudgetService.CreateHedefAsync(editingHedef);
                ToastService.ShowSuccess("Hedef eklendi");
            }

            ModalKapat();
            await Yenile();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kaydetme hatası: {ex.Message}");
        }
    }

    private void ModalKapat()
    {
        showHedefModal = false;
        editingHedef = new BudgetHedef { Yil = seciliYil };
    }

    private async Task KopyalaOncekiYil()
    {
        try
        {
            var kopyalanan = await BudgetService.KopyalaHedeflerAsync(seciliYil - 1, seciliYil, 10); // %10 artış
            if (kopyalanan > 0)
            {
                ToastService.ShowSuccess($"{kopyalanan} hedef %10 artışla kopyalandı");
                await Yenile();
            }
            else
            {
                ToastService.ShowInfo("Kopyalanacak hedef bulunamadı veya tümü zaten mevcut");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kopyalama hatası: {ex.Message}");
        }
    }

