        ToastService.ShowInfo("Excel export hazırlanıyor...");
        // TODO: Excel export implementasyonu
    }

    private string GetAyAdi(int ay) => ay >= 1 && ay <= 12 ? AyAdlari[ay] : "Bilinmiyor";

    private string GetBasariRenkClass(decimal oran) => oran >= 100 ? "text-success" : oran >= 80 ? "text-warning" : "text-danger";

    private string GetBasariBarClass(decimal oran) => oran >= 100 ? "bg-success" : oran >= 80 ? "bg-warning" : "bg-danger";
}

