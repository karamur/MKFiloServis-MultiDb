@page "/butce/aylik-odemeler"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IAylikOdemeService OdemeService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Aylık Ödemeler</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
        <h3><i class="bi bi-calendar-check me-2"></i>Aylık Ödemeler</h3>
        <div class="btn-group">
            <button class="btn btn-outline-dark" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Yazdır
            </button>
            <button class="btn btn-primary" @onclick="YeniPlanEkle">
                <i class="bi bi-plus-circle me-1"></i>Yeni Plan
            </button>
            <button class="btn btn-outline-primary" @onclick="YenileTakvim">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Özet Kartlar -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="text-muted">Bu Ay Ödenecek</h6>
                    <h3 class="text-primary">@buAyToplam.ToString("N2") ?</h3>
                    <small class="text-muted">@secilenAy/@secilenYil</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body">
                    <h6 class="text-muted">Bekleyen Ödemeler</h6>
                    <h3 class="text-warning">@bekleyenSayisi</h3>
                    <small class="text-muted">adet ödeme</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body">
                    <h6 class="text-muted">Geciken Ödemeler</h6>
                    <h3 class="text-danger">@gecikmisSayisi</h3>
                    <small class="text-muted">adet ödeme</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body">
                    <h6 class="text-muted">Aylık Sabit Gider</h6>
                    <h3 class="text-success">@toplamAylikGider.ToString("N2") ?</h3>
                    <small class="text-muted">@aktifPlanlar.Count plan</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Ay/Yıl Seçici -->
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <label class="form-label">Dönem Seç</label>
                    <div class="input-group">
                        <button class="btn btn-outline-secondary" @onclick="OncekiAy">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <select class="form-select" @bind="secilenAy" @bind:after="DonemDegisti">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">@GetAyAdi(i)</option>
                            }
                        </select>
                        <select class="form-select" @bind="secilenYil" @bind:after="DonemDegisti">
                            @for (int i = DateTime.Today.Year - 1; i <= DateTime.Today.Year + 2; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                        <button class="btn btn-outline-secondary" @onclick="SonrakiAy">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-8 text-end">
                    <div class="btn-group">
                        <button class="btn btn-sm btn-outline-primary @(gorunumModu == "takvim" ? "active" : "")" 
                                @onclick='() => gorunumModu = "takvim"'>
                            <i class="bi bi-calendar3"></i> Takvim
                        </button>
                        <button class="btn btn-sm btn-outline-primary @(gorunumModu == "liste" ? "active" : "")" 
                                @onclick='() => gorunumModu = "liste"'>
                            <i class="bi bi-list-ul"></i> Liste
                        </button>
                        <button class="btn btn-sm btn-outline-primary @(gorunumModu == "planlar" ? "active" : "")" 
                                @onclick='() => gorunumModu = "planlar"'>
                            <i class="bi bi-gear"></i> Planlar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        @if (gorunumModu == "takvim")
        {
            <!-- Takvim Görünümü -->
            <div class="card">
                <div class="card-body">
                    <TakvimGorunum Odemeler="@takvimOdemeleri" OnOdemeClick="@TakvimOdemeDetayGoster" />
                </div>
            </div>
        }
        else if (gorunumModu == "liste")
        {
            <!-- Liste Görünümü -->
            <div class="card">
                <div class="card-header d-none d-print-block bg-white text-center border-0">
                    <h4>@secilenAy/@secilenYil Aylık Ödeme Listesi</h4>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Ödeme</th>
                                    <th>Tarih</th>
                                    <th>Tutar</th>
                                    <th>Ödenen</th>
                                    <th>Durum</th>
                                    <th>Kalan Süre</th>
                                    <th class="d-print-none">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var odeme in odemeler.OrderBy(o => o.Plan?.OdemeGunu))
                                {
                                    int gun = odeme.Plan?.OdemeGunu ?? 1;
                                    var odemeTarihi = new DateTime(secilenYil, secilenAy, Math.Min(gun, DateTime.DaysInMonth(secilenYil, secilenAy)));
                                    int kalanGun = (odemeTarihi.Date - DateTime.Today).Days;
                                    
                                    string timeText = "-";
                                    string timeClass = "text-muted";
                                    
                                    if (odeme.Durum == OdemeDurumu.Bekleniyor || odeme.Durum == OdemeDurumu.Gecikti)
                                    {
                                        if (kalanGun < 0) { timeText = $"{Math.Abs(kalanGun)} Gün Gecikti"; timeClass = "text-danger fw-bold"; }
                                        else if (kalanGun == 0) { timeText = "Bugün"; timeClass = "text-warning fw-bold"; }
                                        else { timeText = $"{kalanGun} Gün Kaldı"; timeClass = "text-success fw-bold"; }
                                    }
                                    else if (odeme.Durum == OdemeDurumu.Odendi || odeme.Durum == OdemeDurumu.KismiOdendi)
                                    {
                                        timeText = "Ödendi/Kısmi";
                                        timeClass = "text-muted";
                                    }

                                    <tr class="@GetSatirRenk(odeme)">
                                        <td>
                                            <strong>@odeme.Plan?.OdemeAdi</strong><br />
                                            <small class="text-muted">@odeme.Plan?.Turu.ToString()</small>
                                        </td>
                                        <td>@odemeTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>@odeme.PlanlananTutar.ToString("N2") ₺</td>
                                        <td>@odeme.OdenenTutar.ToString("N2") ₺</td>
                                        <td>
                                            <span class="badge @GetDurumBadge(odeme.Durum)">
                                                @odeme.Durum.ToString()
                                            </span>
                                        </td>
                                        <td class="@timeClass">@timeText</td>
                                        <td class="d-print-none">
                                            @if (odeme.Durum != OdemeDurumu.Odendi)
                                            {
                                                <button class="btn btn-sm btn-success" @onclick="() => OdemeYap(odeme)">
                                                    <i class="bi bi-check-circle"></i> Öde
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td colspan="2">TOPLAM</td>
                                    <td>@odemeler.Sum(o => o.PlanlananTutar).ToString("N2") ₺</td>
                                    <td>@odemeler.Sum(o => o.OdenenTutar).ToString("N2") ₺</td>
                                    <td colspan="3"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Planlar Görünümü -->
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Ödeme Adı</th>
                                    <th>Tür</th>
                                    <th>Aylık Tutar</th>
                                    <th>Ödeme Günü</th>
                                    <th>Durum</th>
                                    <th>İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var plan in aktifPlanlar)
                                {
                                    <tr>
                                        <td>
                                            <strong>@plan.OdemeAdi</strong>
                                            @if (!string.IsNullOrEmpty(plan.Aciklama))
                                            {
                                                <br /><small class="text-muted">@plan.Aciklama</small>
                                            }
                                        </td>
                                        <td>@plan.Turu</td>
                                        <td>@plan.AylikTutar.ToString("N2") ?</td>
                                        <td>@plan.OdemeGunu</td>
                                        <td>
                                            <span class="badge @(plan.Aktif ? "bg-success" : "bg-secondary")">
                                                @(plan.Aktif ? "Aktif" : "Pasif")
                                            </span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" @onclick="() => PlanDuzenle(plan)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => PlanSil(plan.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td colspan="2">TOPLAM AYLIK GİDER</td>
                                    <td>@aktifPlanlar.Sum(p => p.AylikTutar).ToString("N2") ?</td>
                                    <td colspan="3"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<AylikOdemePlani> aktifPlanlar = new();
    private List<AylikOdemeGerceklesen> odemeler = new();
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;
    private string gorunumModu = "takvim";
    private bool isLoading = false;

    private decimal buAyToplam = 0;
    private int bekleyenSayisi = 0;
    private int gecikmisSayisi = 0;
    private decimal toplamAylikGider = 0;
    private IEnumerable<BudgetOdeme> takvimOdemeleri => odemeler.Select(odeme => new BudgetOdeme
    {
        Id = odeme.Id,
        OdemeAy = odeme.Ay,
        OdemeYil = odeme.Yil,
        OdemeTarihi = odeme.OdemeTarihi ?? GetPlanlananOdemeTarihi(odeme),
        MasrafKalemi = odeme.Plan?.OdemeAdi ?? "Ödeme",
        Aciklama = odeme.Aciklama ?? odeme.Plan?.Aciklama,
        Miktar = odeme.PlanlananTutar,
        OdenenTutar = odeme.OdenenTutar,
        Durum = odeme.Durum == OdemeDurumu.Odendi ? MKFiloServis.Shared.Entities.OdemeDurum.Odendi : MKFiloServis.Shared.Entities.OdemeDurum.Bekliyor
    });

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var aktifFirma = FirmaService.GetAktifFirma();

            aktifPlanlar = await OdemeService.GetAktifPlanlariAsync(aktifFirma.FirmaId);
            odemeler = await OdemeService.GetTakvimOdemeleriAsync(aktifFirma.FirmaId, secilenYil, secilenAy);

            buAyToplam = await OdemeService.GetBuAyOdenecekTutarAsync(aktifFirma.FirmaId);
            bekleyenSayisi = await OdemeService.GetBekleyenOdemeSayisiAsync(aktifFirma.FirmaId);
            var gecikmiOdemeler = await OdemeService.GetGecikmiOdemeleriAsync(aktifFirma.FirmaId);
            gecikmisSayisi = gecikmiOdemeler.Count;
            toplamAylikGider = await OdemeService.GetToplamAylikOdemeAsync(aktifFirma.FirmaId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DonemDegisti()
    {
        await LoadData();
    }

    private void OncekiAy()
    {
        if (secilenAy == 1)
        {
            secilenAy = 12;
            secilenYil--;
        }
        else
        {
            secilenAy--;
        }
        _ = DonemDegisti();
    }

    private void SonrakiAy()
    {
        if (secilenAy == 12)
        {
            secilenAy = 1;
            secilenYil++;
        }
        else
        {
            secilenAy++;
        }
        _ = DonemDegisti();
    }

    private async Task YenileTakvim()
    {
        await LoadData();
    }

    private void YeniPlanEkle()
    {
        // Modal açılacak
        ToastService.ShowInfo("Yeni plan ekleme özelliği yakında eklenecek");
    }

    private void PlanDuzenle(AylikOdemePlani plan)
    {
        ToastService.ShowInfo($"{plan.OdemeAdi} düzenleme özelliği yakında eklenecek");
    }

    private async Task PlanSil(int id)
    {
        // Onay sonrası silme
        ToastService.ShowInfo("Silme özelliği yakında eklenecek");
    }

    private void OdemeDetayGoster(AylikOdemeGerceklesen odeme)
    {
        ToastService.ShowInfo($"{odeme.Plan?.OdemeAdi} detay gösterimi yakında eklenecek");
    }

    private void TakvimOdemeDetayGoster(BudgetOdeme odeme)
    {
        var secilenOdeme = odemeler.FirstOrDefault(x => x.Id == odeme.Id);
        if (secilenOdeme is not null)
        {
            OdemeDetayGoster(secilenOdeme);
        }
    }

    private async Task OdemeYap(AylikOdemeGerceklesen odeme)
    {
        // Ödeme modal açılacak
        ToastService.ShowInfo($"{odeme.Plan?.OdemeAdi} için ödeme özelliği yakında eklenecek");
    }

    private DateTime GetPlanlananOdemeTarihi(AylikOdemeGerceklesen odeme)
    {
        int gun = odeme.Plan?.OdemeGunu ?? 1;
        return new DateTime(odeme.Yil, odeme.Ay, Math.Min(gun, DateTime.DaysInMonth(odeme.Yil, odeme.Ay)));
    }

    private string GetAyAdi(int ay) => ay switch
    {
        1 => "Ocak", 2 => "Şubat", 3 => "Mart", 4 => "Nisan",
        5 => "Mayıs", 6 => "Haziran", 7 => "Temmuz", 8 => "Ağustos",
        9 => "Eylül", 10 => "Ekim", 11 => "Kasım", 12 => "Aralık",
        _ => ""
    };

    private string GetSatirRenk(AylikOdemeGerceklesen odeme)
    {
        if (odeme.Durum == OdemeDurumu.Odendi) return "table-success";
        if (odeme.Durum == OdemeDurumu.Gecikti) return "table-danger";
        return "";
    }

    private string GetDurumBadge(OdemeDurumu durum) => durum switch
    {
        OdemeDurumu.Bekleniyor => "bg-warning text-dark",
        OdemeDurumu.Odendi => "bg-success",
        OdemeDurumu.Iptal => "bg-danger",
        OdemeDurumu.Gecikti => "bg-danger",
        OdemeDurumu.KismiOdendi => "bg-info text-dark",
        _ => "bg-secondary"
    };
}

<style>
    @@media print {
        @@page {
            size: A4 portrait;
            margin: 1cm;
        }
        .page {
            display: block !important;
        }
        .sidebar {
            display: none !important;
        }
        main {
            margin: 0 !important;
            padding: 0 !important;
        }
        .top-row {
            display: none !important;
        }
        .content {
            padding: 0 !important;
        }
        .card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

