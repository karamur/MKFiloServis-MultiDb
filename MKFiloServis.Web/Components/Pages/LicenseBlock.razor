@page "/license-block"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject MKFiloServis.Web.Services.LicenseService LicenseService
@inject NavigationManager Nav

<PageTitle>Lisans Yükleme</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:80vh; background: #f8f9fa;">
    <div style="max-width:560px; width:100%; padding: 2rem;">
        @* Icon + Başlık *@
        <div class="text-center mb-4">
            <div style="width: 72px; height: 72px; background: #fef3c7; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                <i class="bi bi-clock-history" style="font-size: 2rem; color: #e67e22;"></i>
            </div>

            @if (_isDemoExpired)
            {
                <h3 style="color: #e67e22; font-weight: 600;">Deneme süreniz sona erdi</h3>
                <p class="text-muted mb-0">
                    Sistemi kullanmaya devam etmek için lisans anahtarı girmeniz yeterlidir.
                </p>
            }
            else
            {
                <h3 style="color: #e67e22; font-weight: 600;">Lisans Gerekli</h3>
                <p class="text-muted mb-0">
                    Sistemi kullanmak için lisans anahtarı girmeniz gerekmektedir.
                </p>
            }
        </div>

        @* 3 Adım *@
        <div class="card bg-white border mb-4">
            <div class="card-body py-3">
                <div class="d-flex align-items-start gap-2 mb-2">
                    <span class="badge bg-primary rounded-pill mt-1">1</span>
                    <span>Makine kodunu <strong>kopyalayın</strong></span>
                </div>
                <div class="d-flex align-items-start gap-2 mb-2">
                    <span class="badge bg-primary rounded-pill mt-1">2</span>
                    <span>Lisans sağlayıcınıza <strong>iletin</strong></span>
                </div>
                <div class="d-flex align-items-start gap-2">
                    <span class="badge bg-primary rounded-pill mt-1">3</span>
                    <span>Gelen lisans anahtarını <strong>yapıştırın</strong></span>
                </div>
            </div>
        </div>

        @* Mesaj *@
        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert alert-info py-2 small mb-3">
                <i class="bi bi-info-circle me-1"></i>@_message
            </div>
        }

        @* 🔥 PART 8: Telefon gosterimi *@
        @if (!string.IsNullOrEmpty(_contactPhone))
        {
            <div class="alert alert-warning py-2 small mb-3">
                <i class="bi bi-telephone me-1"></i>
                Sure doldugunda arayin: <strong>@_contactPhone</strong>
            </div>
        }

        @* Lisans anahtarı girişi *@
        <div class="card">
            <div class="card-body">
                <h6 class="mb-2"><i class="bi bi-key me-1"></i>Lisans Anahtarı</h6>
                <textarea class="form-control font-monospace mb-3" rows="5"
                          placeholder="Ctrl+V ile lisans anahtarını buraya yapıştırın"
                          @bind="_licenseKey" @bind:event="oninput"></textarea>

                @if (_uploadError != null)
                {
                    <div class="alert alert-warning py-1 small mb-3">
                        <i class="bi bi-info-circle me-1"></i>@_uploadError
                    </div>
                }

                <button class="btn btn-success btn-lg w-100" @onclick="LisansAktiveEt"
                        disabled="@(string.IsNullOrWhiteSpace(_licenseKey) || _isActivating)">
                    @if (_isActivating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Doğrulanıyor...</span>
                    }
                    else
                    {
                        <i class="bi bi-rocket-takeoff me-2"></i>
                        <span>Lisansı Aktif Et ve Devam Et</span>
                    }
                </button>
            </div>
        </div>

        @* Güven *@
        <p class="text-muted small text-center mt-3 mb-0">
            <i class="bi bi-shield-check text-success me-1"></i>
            Verileriniz güvende. Sadece lisans doğrulaması yapılır.
        </p>
    </div>
</div>

