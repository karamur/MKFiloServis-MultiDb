@page "/banka-hareketleri"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@inject IBankaKasaHareketService HareketService
@inject IBankaHesapService BankaHesapService
@inject ICariService CariService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Banka/Kasa Hareketleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-arrow-left-right me-2"></i>Banka/Kasa Hareketleri</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-success" @onclick="@(() => Navigation.NavigateTo("/banka-hareketleri/import"))">
                <i class="bi bi-cloud-arrow-up me-1"></i>Excel/CSV/PDF İçeri Aktar
            </button>
            <button class="btn btn-primary" @onclick="YeniHareket">
                <i class="bi bi-plus-lg me-1"></i>Yeni Hareket
            </button>
        </div>
    </div>

    @* Filtre Alanı *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Ara (islem no, aciklama, belge no...)"
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                    </div>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="selectedHesapId" @bind:after="OnFilterChanged">
                        <option value="0">Tum Hesaplar</option>
                        @if (hesaplar != null)
                        {
                            @foreach (var hesap in hesaplar)
                            {
                                <option value="@hesap.Id">@hesap.HesapAdi</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="selectedHareketTipi" @bind:after="OnFilterChanged">
                        <option value="">Tum Tipler</option>
                        <option value="@HareketTipi.Giris">Giris</option>
                        <option value="@HareketTipi.Cikis">Cikis</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="date" class="form-control" @bind="baslangicTarihi" @bind:after="OnFilterChanged" />
                </div>
                <div class="col-md-2">
                    <input type="date" class="form-control" @bind="bitisTarihi" @bind:after="OnFilterChanged" />
                </div>
                <div class="col-md-1">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters" title="Filtreleri Temizle">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (pagedResult == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yukleniyor...</span>
            </div>
        </div>
    }
    else if (pagedResult.TotalCount == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Kayit bulunmamaktadir.
        </div>
    }
    else
    {
        @* Özet Bilgiler *@
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="alert alert-success py-2 mb-0">
                    <i class="bi bi-arrow-down me-1"></i>
                    <strong>Toplam Giris:</strong> @toplamGiris.ToString("N2") TL
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-danger py-2 mb-0">
                    <i class="bi bi-arrow-up me-1"></i>
                    <strong>Toplam Cikis:</strong> @toplamCikis.ToString("N2") TL
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-info py-2 mb-0">
                    <i class="bi bi-calculator me-1"></i>
                    <strong>Net:</strong> @((toplamGiris - toplamCikis).ToString("N2")) TL
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Islem No</th>
                                <th>Tarih</th>
                                <th>Hesap</th>
                                <th>Cari</th>
                                <th>Tip</th>
                                <th>Tutar</th>
                                <th>Aciklama</th>
                                <th>Muhasebe</th>
                                <th style="width: 120px;">Islemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hareket in pagedResult.Items)
                            {
                                <tr>
                                    <td><strong>@hareket.IslemNo</strong></td>
                                    <td>@hareket.IslemTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@hareket.BankaHesap?.HesapAdi</td>
                                    <td>@hareket.Cari?.Unvan</td>
                                    <td>
                                        @if (hareket.HareketTipi == HareketTipi.Giris)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-arrow-down me-1"></i>Giris
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-arrow-up me-1"></i>Cikis
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <strong class="@(hareket.HareketTipi == HareketTipi.Giris ? "text-success" : "text-danger")">
                                            @(hareket.HareketTipi == HareketTipi.Giris ? "+" : "-")@hareket.Tutar.ToString("N2") TL
                                        </strong>
                                    </td>
                                    <td>@hareket.Aciklama</td>
                                     <td>
                                         @if (!string.IsNullOrWhiteSpace(hareket.MuhasebeHesapKodu) || !string.IsNullOrWhiteSpace(hareket.KostMerkeziKodu))
                                         {
                                             <div><code>@hareket.MuhasebeHesapKodu</code></div>
                                             @if (!string.IsNullOrWhiteSpace(hareket.KostMerkeziKodu))
                                             {
                                                 <small class="text-muted">KM: @hareket.KostMerkeziKodu</small>
                                             }
                                         }
                                         else
                                         {
                                             <span class="text-muted">-</span>
                                         }
                                     </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(hareket.Id)" title="Duzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(hareket)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Sayfalama *@
                <MKFiloServis.Web.Components.Shared.Pagination
                    CurrentPage="currentPage"
                    PageSize="pageSize"
                    TotalItems="pagedResult.TotalCount"
                    OnPageChanged="OnPageChanged"
                    PageSizeChanged="OnPageSizeChanged" />
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayi</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekHareket?.IslemNo</strong> numarali hareketi silmek istediginize emin misiniz?</p>
                    <p class="text-danger"><strong>@silinecekHareket?.Tutar.ToString("N2") TL</strong> tutarindaki bu islem kalici olarak silinecektir.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">Iptal</button>
                    <button type="button" class="btn btn-danger" @onclick="SilAsync" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<BankaKasaHareket>? pagedResult;
    private List<BankaHesap>? hesaplar;
    private bool showDeleteModal = false;
    private bool isDeleting = false;
    private BankaKasaHareket? silinecekHareket;

    // Sayfalama
    private int currentPage = 1;
    private int pageSize = 20;

    // Filtreler
    private string searchTerm = "";
    private int selectedHesapId = 0;
    private HareketTipi? selectedHareketTipi;
    private DateTime? baslangicTarihi;
    private DateTime? bitisTarihi;

    // Özet bilgiler
    private decimal toplamGiris = 0;
    private decimal toplamCikis = 0;

    // Debounce için timer
    private System.Timers.Timer? _debounceTimer;
    private const int DebounceDelay = 300;

    protected override async Task OnInitializedAsync()
    {
        hesaplar = await BankaHesapService.GetActiveAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        var filter = new BankaHareketFilterParams
        {
            PageNumber = currentPage,
            PageSize = pageSize,
            SearchTerm = searchTerm,
            HesapId = selectedHesapId > 0 ? selectedHesapId : null,
            HareketTipi = selectedHareketTipi,
            BaslangicTarihi = baslangicTarihi,
            BitisTarihi = bitisTarihi
        };

        pagedResult = await HareketService.GetPagedAsync(filter);

        // Sayfa toplamlarını hesapla
        toplamGiris = pagedResult.Items.Where(h => h.HareketTipi == HareketTipi.Giris).Sum(h => h.Tutar);
        toplamCikis = pagedResult.Items.Where(h => h.HareketTipi == HareketTipi.Cikis).Sum(h => h.Tutar);
    }

    private void OnSearchChanged()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(DebounceDelay);
        _debounceTimer.Elapsed += async (s, e) =>
        {
            _debounceTimer?.Stop();
            currentPage = 1;
            await InvokeAsync(async () =>
            {
                await LoadData();
                StateHasChanged();
            });
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task OnFilterChanged()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task ClearFilters()
    {
        searchTerm = "";
        selectedHesapId = 0;
        selectedHareketTipi = null;
        baslangicTarihi = null;
        bitisTarihi = null;
        currentPage = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int page)
    {
        currentPage = page;
        await LoadData();
    }

    private async Task OnPageSizeChanged(int size)
    {
        pageSize = size;
        currentPage = 1;
        await LoadData();
    }

    private void YeniHareket()
    {
        Navigation.NavigateTo("/banka-hareketleri/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/banka-hareketleri/{id}");
    }

    private void SilOnay(BankaKasaHareket hareket)
    {
        silinecekHareket = hareket;
        showDeleteModal = true;
    }

    private async Task SilAsync()
    {
        if (silinecekHareket == null) return;

        isDeleting = true;
        StateHasChanged();

        try
        {
            await HareketService.DeleteAsync(silinecekHareket.Id);
            ToastService.ShowSuccess("Hareket silindi.");
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Silme hatasi: " + ex.Message);
        }
        finally
        {
            isDeleting = false;
            showDeleteModal = false;
            silinecekHareket = null;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}

