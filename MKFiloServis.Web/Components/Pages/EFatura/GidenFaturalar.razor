            (c.CariTipi == CariTipi.Musteri || c.CariTipi == CariTipi.MusteriTedarikci) &&
            (!editFatura.FirmaId.HasValue || c.Id == editFatura.CariId || c.FirmaId == null || c.FirmaId == editFatura.FirmaId));
