        var kaydedilen = await CariService.CreateAsync(yeniCari);
        cariler = await CariService.GetAllAsync();
        editFatura.CariId = kaydedilen.Id;

        ToastService.ShowSuccess($"Musteri eklendi: {yeniCari.Unvan}");
        showCariModal = false;
        isSavingCari = false;
        StateHasChanged();
    }

    private async Task FaturaKaydet()
    {
        faturaFormHataMesaji = null;

        if (string.IsNullOrWhiteSpace(editFatura.FaturaNo) || editFatura.CariId <= 0 || editFatura.GenelToplam <= 0 || !editFatura.FirmaId.HasValue)
        {
            faturaFormHataMesaji = "Fatura no, firma, cari ve tutar alanlari zorunludur!";
            return;
        }

        if (editFatura.FirmalarArasiFatura && (!editFatura.KarsiFirmaId.HasValue || editFatura.KarsiFirmaId == editFatura.FirmaId))
        {
            faturaFormHataMesaji = "Firmalar arası faturada farklı bir karşı firma seçin.";
            return;
        }

        if (!editFatura.FirmalarArasiFatura)
            editFatura.KarsiFirmaId = null;

        try
        {
            editFatura.FaturaYonu = FaturaYonu.Giden;
            editFatura.FaturaTipi = FaturaTipi.SatisFaturasi;
            editFatura.FaturaTarihi = DateTime.SpecifyKind(editFatura.FaturaTarihi, DateTimeKind.Utc);
            if (editFatura.VadeTarihi.HasValue)
                editFatura.VadeTarihi = DateTime.SpecifyKind(editFatura.VadeTarihi.Value, DateTimeKind.Utc);

            if (editFatura.Id > 0)
                await FaturaService.UpdateAsync(editFatura);
            else
                await FaturaService.CreateAsync(editFatura);

            ToastService.ShowSuccess("Fatura kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (InvalidOperationException ex)
        {
            faturaFormHataMesaji = ex.Message;
        }
        catch (Exception)
        {
            faturaFormHataMesaji = "Fatura kaydedilirken beklenmeyen bir hata oluştu.";
        }
    }

    private async Task TahsilatKaydetAsync()
    {
        if (tahsilatFatura == null || tahsilatHesapId <= 0 || tahsilatTutar <= 0)
        {
            ToastService.ShowWarning("Lutfen tum alanlari doldurun!");
            return;
        }

        try
        {
            var hareket = new BankaKasaHareket
            {
                BankaHesapId = tahsilatHesapId,
                IslemTarihi = DateTime.SpecifyKind(tahsilatTarihi, DateTimeKind.Utc),
                HareketTipi = HareketTipi.Giris,
                IslemKaynak = IslemKaynak.FaturaTahsilat,
                Tutar = tahsilatTutar,
                Aciklama = tahsilatAciklama,
                CariId = tahsilatFatura.CariId
            };
            await BankaKasaService.CreateAsync(hareket);
            await FaturaService.UpdateOdenenTutarAsync(tahsilatFatura.Id);

            ToastService.ShowSuccess("Tahsilat kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ExcelImportAc()
    {
        importFile = null;
        importXmlFiles = null;
        importXmlPdfFiles = null;
        importResult = null;
        importFirmaId = filtreFirmaId > 0 ? filtreFirmaId : (firmalar?.FirstOrDefault()?.Id ?? 0); // Filtredeki firma veya ilk firma
        showImportModal = true;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        importFile = e.File;
        importResult = null;
    }

    private void XmlDosyalariSecildi(InputFileChangeEventArgs e)
    {
        importXmlFiles = e.GetMultipleFiles(500); // multiple support limit
        importResult = null;
    }

    private void XmlPdfDosyalariSecildi(InputFileChangeEventArgs e)
    {
        importXmlPdfFiles = e.GetMultipleFiles(1000); // XML + PDF
        importResult = null;
    }

    private async Task ImportYap()
    {
        // Firma seçimi kontrolü
        if (importFirmaId == 0)
        {
            ToastService.ShowWarning("Lütfen bir firma seçin!");
            return;
        }

        if (importTipi == "excel" && importFile == null) return;
        if (importTipi == "xml" && (importXmlFiles == null || !importXmlFiles.Any())) return;
        if (importTipi == "xmlpdf" && (importXmlPdfFiles == null || !importXmlPdfFiles.Any())) return;

        isImporting = true;
        importResult = null;
        StateHasChanged();

        try
        {
            var firmaId = importFirmaId; // Modaldan seçilen firma
            var eFaturaTip = (EFaturaTipi)importEFaturaTipi;

            if (importTipi == "excel")
            {
                using var stream = new MemoryStream();
                await importFile!.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
                var fileContent = stream.ToArray();
                importResult = await FaturaService.ImportFromExcelAsync(fileContent, FaturaYonu.Giden, firmaId, eFaturaTip);
            }
            else if(importTipi == "xml")
            {
                var xmlContents = new List<MKFiloServis.Web.Services.Interfaces.XmlFileContent>();
                foreach (var f in importXmlFiles!)
                {
                    using var ms = new MemoryStream();
                    await f.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(ms); // 5mb max
                    xmlContents.Add(new MKFiloServis.Web.Services.Interfaces.XmlFileContent { FileName = f.Name, Content = ms.ToArray() });
                }
                importResult = await FaturaService.ImportFromXmlAsync(xmlContents, FaturaYonu.Giden, firmaId, eFaturaTip);
            }
            else if(importTipi == "xmlpdf")
            {
                // XML ve PDF dosyalarını grupla
                var xmlFiles = importXmlPdfFiles!.Where(f => IsXmlFileName(f.Name)).ToList();
                var pdfFiles = importXmlPdfFiles!.Where(f => f.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase)).ToList();

                if (!xmlFiles.Any())
                {
                    ToastService.ShowWarning("Aktarim icin en az bir XML/XLM dosyasi secin!");
                    return;
                }

                var xmlPdfContents = new List<MKFiloServis.Web.Services.Interfaces.XmlPdfFileContent>();
                foreach (var xmlFile in xmlFiles)
                {
                    using var xmlMs = new MemoryStream();
                    await xmlFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(xmlMs);

                    var xmlBaseName = Path.GetFileNameWithoutExtension(xmlFile.Name);
                    var matchingPdf = pdfFiles.FirstOrDefault(p => 
                        Path.GetFileNameWithoutExtension(p.Name).Equals(xmlBaseName, StringComparison.OrdinalIgnoreCase));

                    byte[]? pdfContent = null;
                    string? pdfFileName = null;
                    if (matchingPdf != null)
                    {
                        using var pdfMs = new MemoryStream();
                        await matchingPdf.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(pdfMs);
                        pdfContent = pdfMs.ToArray();
                        pdfFileName = matchingPdf.Name;
                    }

                    xmlPdfContents.Add(new MKFiloServis.Web.Services.Interfaces.XmlPdfFileContent
                    { 
                        XmlFileName = xmlFile.Name, 
                        XmlContent = xmlMs.ToArray(),
                        PdfFileName = pdfFileName,
                        PdfContent = pdfContent
                    });
                }
                importResult = await FaturaService.ImportFromXmlWithPdfAsync(xmlPdfContents, FaturaYonu.Giden, firmaId, eFaturaTip);
            }

            if (importResult != null && importResult.Success)
            {
                ToastService.ShowSuccess($"{importResult.ImportedCount} fatura aktarıldı.");
                await YenileAsync();
            }
            else if (importResult != null && importResult.ImportedCount == 0 && importResult.SkippedCount > 0)
            {
                ToastService.ShowWarning($"{importResult.SkippedCount} fatura zaten mevcut.");
            }
        }
        catch (Exception ex)
        {
            importResult = new EFaturaImportResult { Success = false, Errors = new List<string> { ex.Message } };
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

