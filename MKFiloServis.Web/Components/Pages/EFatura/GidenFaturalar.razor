@page "/efatura/giden"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IFaturaService FaturaService
@inject ICariService CariService
@inject IBankaKasaHareketService BankaKasaService
@inject IFirmaService FirmaService
@inject IMuhasebeService MuhasebeService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Kesilen Faturalar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-file-earmark-arrow-up text-success me-2"></i>Kesilen Faturalar (Satış)</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/dashboard">Ana Sayfa</a></li>
                    <li class="breadcrumb-item"><a href="/cariler">Cari Yönetimi</a></li>
                    <li class="breadcrumb-item active">Kesilen Faturalar</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniFaturaAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni Fatura
            </button>
            <div class="btn-group">
                <button class="btn btn-outline-info" @onclick="SablonIndir" title="Excel Şablon İndir">
                    <i class="bi bi-download"></i>
                </button>
                <button class="btn btn-outline-success" @onclick="ExcelImportAc" title="Excel Yükle">
                    <i class="bi bi-upload"></i>
                </button>
                <button class="btn btn-success" @onclick="ExcelExport" disabled="@(!filtreliFaturalar.Any())" title="Excel İndir">
                    <i class="bi bi-file-earmark-excel"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Gelismis Filtreler -->
    <div class="card mb-3">
        <div class="card-header bg-primary text-white py-2">
            <i class="bi bi-funnel me-2"></i>Filtreler
        </div>
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Yil</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="YilAyDegisti">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAy" @bind:after="YilAyDegisti">
                        <option value="0">Tum Yil</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Baslangic</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBaslangic" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bitis</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBitis" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tumu</option>
                        <option value="1">Tahsil Edilmedi</option>
                        <option value="2">Kismi Tahsilat</option>
                        <option value="3">Tahsil Edildi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ara (Fatura/Cari)</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Fatura No / Cari" @bind="aramaMetni" />
                </div>
            </div>
            <div class="row g-2 mt-1 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="filtreFirmaId">
                        <option value="0">Tum Firmalar</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Vergi No / TC</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Vergi/TC No" @bind="filtreVergiNo" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Vergi Dairesi</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Vergi Dairesi" @bind="filtreVergiDairesi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">E-Fatura Tipi</label>
                    <select class="form-select form-select-sm" @bind="filtreEFaturaTipi">
                        <option value="">Tumu</option>
                        <option value="1">E-Fatura</option>
                        <option value="2">E-Arsiv</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="Filtrele"><i class="bi bi-search me-1"></i>Ara</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreTemizle"><i class="bi bi-x-lg me-1"></i>Temizle</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Ozet Kartlari -->
    <div class="row mb-3 g-2">
        <div class="col-6 col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body py-2 text-center">
                    <small>Toplam Fatura</small>
                    <h4 class="mb-0">@filtreliFaturalar.Count</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body py-2 text-center">
                    <small>Toplam Tutar</small>
                    <h4 class="mb-0">@FormatPara(filtreliFaturalar.Sum(f => f.GenelToplam))</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body py-2 text-center">
                    <small>Tahsil Edilen</small>
                    <h4 class="mb-0">@FormatPara(filtreliFaturalar.Sum(f => f.OdenenTutar))</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body py-2 text-center">
                    <small>Tahsil Bekleyen</small>
                    <h4 class="mb-0">@FormatPara(filtreliFaturalar.Sum(f => f.KalanTutar))</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Fatura Listesi -->
        <div class="@(pdfOnizlemeFatura != null ? "col-md-7" : "col-12")">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 65vh; overflow-y: auto;">
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Fatura No</th>
                                        <th>Tarih</th>
                                        <th>Cari</th>
                                        <th>Vade</th>
                                        <th class="text-end">Tutar</th>
                                        <th class="text-end">Kalan</th>
                                        <th class="text-center">Durum</th>
                                        <th class="text-center">Islem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fatura in filtreliFaturalar)
                                    {
                                        var vadeGecmis = fatura.VadeTarihi.HasValue && fatura.VadeTarihi.Value < DateTime.Today && fatura.KalanTutar > 0;
                                        var isSelected = pdfOnizlemeFatura?.Id == fatura.Id;
                                        <tr class="@(isSelected ? "table-primary" : vadeGecmis ? "table-warning" : "")" 
                                            @onclick="() => FaturaSecildi(fatura)" style="cursor: pointer;">
                                            <td>
                                                <strong>@fatura.FaturaNo</strong>
                                                @if (fatura.FirmalarArasiFatura)
                                                {
                                                    <span class="badge bg-info ms-1" title="Firmalar Arası Fatura - @(fatura.KarsiFirma?.FirmaAdi ?? "Karşı Firma")">
                                                        <i class="bi bi-building"></i>
                                                    </span>
                                                }
                                                @if (!string.IsNullOrEmpty(fatura.PdfDosyaYolu))
                                                {
                                                    <i class="bi bi-file-pdf text-danger ms-1" title="PDF Mevcut"></i>
                                                }
                                            </td>
                                            <td>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @if (fatura.Cari != null)
                                                {
                                                    <span class="text-truncate d-inline-block" style="max-width: 120px;" title="@fatura.Cari.Unvan">
                                                        @fatura.Cari.Unvan
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (fatura.VadeTarihi.HasValue)
                                                {
                                                    <span class="@(vadeGecmis ? "text-danger fw-bold" : "")">
                                                        @fatura.VadeTarihi.Value.ToString("dd.MM.yy")
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-end">@FormatPara(fatura.GenelToplam)</td>
                                            <td class="text-end text-danger"><strong>@FormatPara(fatura.KalanTutar)</strong></td>
                                            <td class="text-center">
                                                <span class="badge @GetDurumClass(fatura.Durum)">@GetDurumKisaAdi(fatura.Durum)</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm">
                                                    @if (fatura.KalanTutar > 0)
                                                    {
                                                        <button class="btn btn-success btn-sm" @onclick="() => TahsilatYapAc(fatura)" @onclick:stopPropagation title="Tahsilat Yap">
                                                            <i class="bi bi-cash-coin"></i>
                                                        </button>
                                                    }
                                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => FaturaDetayAc(fatura)" @onclick:stopPropagation title="Detay">
                                                        <i class="bi bi-eye"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => FaturaSilOnay(fatura)" @onclick:stopPropagation title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- PDF Önizleme Paneli -->
        @if (pdfOnizlemeFatura != null)
        {
            <div class="col-md-5">
                <div class="card h-100">
                    <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-file-pdf text-danger me-1"></i>
                            <strong>@pdfOnizlemeFatura.FaturaNo</strong>
                            <small class="text-muted ms-2">@pdfOnizlemeFatura.Cari?.Unvan</small>
                        </div>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" @onclick="() => FaturaDetayAc(pdfOnizlemeFatura)" title="Detay">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="() => FaturaDuzenle(pdfOnizlemeFatura)" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </button>
                            @if (!string.IsNullOrEmpty(pdfOnizlemeBase64))
                            {
                                <button class="btn btn-outline-danger" @onclick="PdfIndirAsync" title="PDF İndir">
                                    <i class="bi bi-download"></i>
                                </button>
                            }
                            <button class="btn btn-outline-dark" @onclick="PdfOnizlemeKapat" title="Kapat">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0" style="height: 60vh;">
                        @if (pdfOnizlemeYukleniyor)
                        {
                            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                                <div class="spinner-border text-danger mb-3" role="status"></div>
                                <h5>PDF yükleniyor</h5>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(pdfOnizlemeUrl))
                        {
                            <iframe src="@pdfOnizlemeUrl" style="width: 100%; height: 100%; border: none;"></iframe>
                        }
                        else
                        {
                            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-file-earmark-x display-1 mb-3"></i>
                                <h5>PDF Dosyası Yok</h5>
                                <p class="text-center small">Bu fatura için henüz PDF yüklenmemiş.</p>
                                <label class="btn btn-outline-primary">
                                    <i class="bi bi-upload me-1"></i>PDF Yükle
                                    <InputFile class="d-none" OnChange="e => PdfYukle(e, pdfOnizlemeFatura.Id)" accept=".pdf" />
                                </label>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-light py-2">
                        <div class="row text-center small">
                            <div class="col-4">
                                <div class="text-muted">Toplam</div>
                                <strong>@FormatPara(pdfOnizlemeFatura.GenelToplam)</strong>
                            </div>
                            <div class="col-4">
                                <div class="text-muted">Tahsil</div>
                                <strong class="text-success">@FormatPara(pdfOnizlemeFatura.OdenenTutar)</strong>
                            </div>
                            <div class="col-4">
                                <div class="text-muted">Kalan</div>
                                <strong class="text-danger">@FormatPara(pdfOnizlemeFatura.KalanTutar)</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Yeni/Duzenle Fatura Modal -->
@if (showFaturaModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editFatura.Id > 0 ? "Fatura Duzenle" : "Yeni Fatura")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(faturaFormHataMesaji))
                    {
                        <div class="alert alert-warning py-2">
                            <i class="bi bi-exclamation-triangle me-1"></i>@faturaFormHataMesaji
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Fatura No *</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" @bind="editFatura.FaturaNo" />
                                    <button type="button" class="btn btn-outline-secondary" @onclick="GidenFaturaNoUretAsync" title="Numara Üret">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Fatura Tarihi *</label>
                                <input type="date" class="form-control" @bind="editFatura.FaturaTarihi" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Vade Tarihi</label>
                                <input type="date" class="form-control" @bind="editFatura.VadeTarihi" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Firma *</label>
                                <select class="form-select" @bind="editFatura.FirmaId" @bind:after="GidenFirmaDegistiAsync">
                                    <option value="">Secin...</option>
                                    @foreach (var firma in firmalar.Where(f => f.Aktif))
                                    {
                                        <option value="@firma.Id">@firma.FirmaAdi</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3 form-check mt-4 pt-2">
                                <input class="form-check-input" type="checkbox" @bind="editFatura.FirmalarArasiFatura" @bind:after="GidenFirmalarArasiDurumDegisti" id="gidenFirmalarArasiFatura" />
                                <label class="form-check-label" for="gidenFirmalarArasiFatura">Firmalar Arası Fatura</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Karşı Firma</label>
                                <select class="form-select" @bind="editFatura.KarsiFirmaId" disabled="@(!editFatura.FirmalarArasiFatura)">
                                    <option value="">Secin...</option>
                                    @foreach (var firma in firmalar.Where(f => f.Aktif && (!editFatura.FirmaId.HasValue || f.Id != editFatura.FirmaId.Value)))
                                    {
                                        <option value="@firma.Id">@firma.FirmaAdi</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label class="form-label">Cari * <button class="btn btn-sm btn-outline-primary ms-2" @onclick="YeniCariAc"><i class="bi bi-plus"></i> Yeni</button></label>
                                <select class="form-select" @bind="editFatura.CariId">
                                    <option value="0">Secin...</option>
                                    @foreach (var cari in GetGidenCariSecenekleri())
                                    {
                                        <option value="@cari.Id">@cari.Unvan</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">E-Fatura Tipi</label>
                                <select class="form-select" @bind="editFatura.EFaturaTipi">
                                    <option value="@EFaturaTipi.EFatura">E-Fatura</option>
                                    <option value="@EFaturaTipi.EArsiv">E-Arsiv</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Durum</label>
                                <select class="form-select" @bind="editFatura.Durum">
                                    <option value="@FaturaDurum.Beklemede">Beklemede</option>
                                    <option value="@FaturaDurum.KismiOdendi">Kismi Tahsilat</option>
                                    <option value="@FaturaDurum.Odendi">Tahsil Edildi</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Ara Toplam</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editFatura.AraToplam" step="0.01" />
                                    <span class="input-group-text">?</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">KDV Tutar</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editFatura.KdvTutar" step="0.01" />
                                    <span class="input-group-text">?</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Genel Toplam *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editFatura.GenelToplam" step="0.01" />
                                    <span class="input-group-text">?</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">ETTN No</label>
                                <input type="text" class="form-control" @bind="editFatura.EttnNo" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Aciklama</label>
                                <input type="text" class="form-control" @bind="editFatura.Aciklama" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="FaturaKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni Cari Modal -->
@if (showCariModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Yeni Musteri Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCariModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Unvan / Ad Soyad *</label>
                            <input type="text" class="form-control" @bind="yeniCari.Unvan" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Vergi No</label>
                            <input type="text" class="form-control" @bind="yeniCari.VergiNo" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">TC Kimlik No</label>
                            <input type="text" class="form-control" @bind="yeniCari.TcKimlikNo" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Vergi Dairesi</label>
                            <input type="text" class="form-control" @bind="yeniCari.VergiDairesi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" @bind="yeniCari.Telefon" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="yeniCari.Email" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Adres</label>
                            <textarea class="form-control" rows="2" @bind="yeniCari.Adres"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Muhasebe Hesabi</label>
                            <select class="form-select" @bind="secilenHesapId">
                                <option value="0">-- Hesap Sec veya Otomatik Olustur --</option>
                                @foreach (var hesap in musteriHesaplari)
                                {
                                    <option value="@hesap.Id">@hesap.HesapKodu - @hesap.HesapAdi</option>
                                }
                            </select>
                            <small class="text-muted">Bos birakirsaniz 120.xxx altinda otomatik hesap olusturulur</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showCariModal = false">Iptal</button>
                    <button type="button" class="btn btn-success" @onclick="CariKaydet" disabled="@isSavingCari">
                        @if (isSavingCari)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Hesap Olusturma Onay Modal -->
@if (showHesapOnayModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-question-circle me-2"></i>Hesap Olustur</h5>
