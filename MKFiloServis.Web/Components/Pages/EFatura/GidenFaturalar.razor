    private async Task CariKaydet()
    {
        if (string.IsNullOrWhiteSpace(yeniCari.Unvan))
        {
            ToastService.ShowWarning("Unvan zorunludur!");
            return;
        }

        isSavingCari = true;
        StateHasChanged();

        try
        {
            // Hesap secilmemisse otomatik olusturma sor
            if (secilenHesapId == 0)
            {
                // Yeni hesap kodu olustur
                var sonHesap = musteriHesaplari
                    .Where(h => h.HesapKodu.StartsWith("120.") && h.HesapKodu.Length > 4)
                    .OrderByDescending(h => h.HesapKodu)
                    .FirstOrDefault();

                if (sonHesap != null)
                {
                    var sonNumara = int.Parse(sonHesap.HesapKodu.Split('.').Last());
                    yeniHesapKodu = $"120.{(sonNumara + 1):D3}";
                }
                else
                {
                    yeniHesapKodu = "120.001";
                }

                showCariModal = false;
                showHesapOnayModal = true;
                isSavingCari = false;
                return;
            }

            // Hesap secilmis, direkt kaydet
            yeniCari.MuhasebeHesapId = secilenHesapId;
            await CariKaydetDevam();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
