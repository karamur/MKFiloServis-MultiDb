    private void TemizleGidenFaturaSecimleri()
    {
        if (!editFatura.FirmalarArasiFatura || editFatura.KarsiFirmaId == editFatura.FirmaId)
            editFatura.KarsiFirmaId = null;

        var seciliCariGecerli = editFatura.CariId > 0 && GetGidenCariSecenekleri().Any(c => c.Id == editFatura.CariId);
        if (!seciliCariGecerli)
            editFatura.CariId = 0;
