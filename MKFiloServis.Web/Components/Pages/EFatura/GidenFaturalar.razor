    private async Task FaturaSecildi(Fatura fatura)
    {
        pdfOnizlemeFatura = fatura;
        await PdfOnizlemeYukleAsync(fatura);
    }

    private void PdfOnizlemeKapat()
    {
        pdfOnizlemeFatura = null;
        pdfOnizlemeUrl = null;
        pdfOnizlemeBase64 = null;
        pdfOnizlemeDosyaAdi = null;
        pdfOnizlemeYukleniyor = false;
    }

    private async Task PdfYukle(InputFileChangeEventArgs e, int faturaId)
    {
        try
        {
            using var stream = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
            var pdfContent = stream.ToArray();

            var result = await FaturaService.UploadFaturaPdfAsync(faturaId, e.File.Name, pdfContent);
            if (result)
            {
                ToastService.ShowSuccess("PDF yüklendi.");
                await YenileAsync();
                // Seçili faturayı güncelle
                pdfOnizlemeFatura = filtreliFaturalar.FirstOrDefault(f => f.Id == faturaId);
                if (pdfOnizlemeFatura != null)
                    await PdfOnizlemeYukleAsync(pdfOnizlemeFatura);
            }
            else
            {
                ToastService.ShowError("PDF yüklenemedi.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task PdfOnizlemeYukleAsync(Fatura fatura)
    {
        pdfOnizlemeUrl = null;
        pdfOnizlemeBase64 = null;
        pdfOnizlemeDosyaAdi = null;

        if (string.IsNullOrWhiteSpace(fatura.PdfDosyaYolu))
            return;

        pdfOnizlemeYukleniyor = true;
        StateHasChanged();

        try
        {
            var dosya = await FaturaService.GetFaturaDosyaAsync(fatura.Id, FaturaDosyaTuru.Pdf);
            if (dosya == null)
                return;

            pdfOnizlemeBase64 = Convert.ToBase64String(dosya.Content);
            pdfOnizlemeDosyaAdi = dosya.FileName;
            pdfOnizlemeUrl = $"data:{dosya.ContentType};base64,{pdfOnizlemeBase64}";
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF açılamadı: {ex.Message}");
        }
        finally
        {
            pdfOnizlemeYukleniyor = false;
            StateHasChanged();
        }
    }

    private async Task PdfIndirAsync()
    {
        if (string.IsNullOrWhiteSpace(pdfOnizlemeBase64))
            return;

        await JS.InvokeVoidAsync("downloadFile", pdfOnizlemeDosyaAdi ?? "fatura.pdf", pdfOnizlemeBase64, "application/pdf");
    }

