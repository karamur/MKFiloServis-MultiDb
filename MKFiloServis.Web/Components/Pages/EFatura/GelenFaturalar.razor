    private async Task FirmaBazliXmlPdfAktarAsync()
    {
        if (!filtreliFaturalar.Any())
        {
            ToastService.ShowWarning("Aktarilacak fatura yok!");
            return;
        }

        try
        {
            using var zipStream = new MemoryStream();

            var xmlSayisi = 0;
            var pdfSayisi = 0;
            var dosyaliFaturaSayisi = 0;

            using (var zip = new ZipArchive(zipStream, ZipArchiveMode.Create, true))
            {
                foreach (var fatura in filtreliFaturalar)
                {
                    var firmaKlasoru = GetFaturaFirmaKlasoru(fatura);
                    var faturaKlasoru = SanitizePathSegment($"{fatura.FaturaTarihi:yyyyMMdd}_{fatura.FaturaNo}");
                    var hedefKlasor = $"{firmaKlasoru}/{faturaKlasoru}";

                    var xmlDosya = await FaturaService.GetFaturaDosyaAsync(fatura.Id, FaturaDosyaTuru.Xml);
                    var pdfDosya = await FaturaService.GetFaturaDosyaAsync(fatura.Id, FaturaDosyaTuru.Pdf);

                    var buFaturadaDosyaVar = false;

                    if (xmlDosya != null)
                    {
                        var xmlEntry = zip.CreateEntry($"{hedefKlasor}/{SanitizePathSegment(xmlDosya.FileName)}", CompressionLevel.Optimal);
                        await using var xmlEntryStream = xmlEntry.Open();
                        await xmlEntryStream.WriteAsync(xmlDosya.Content);
                        xmlSayisi++;
                        buFaturadaDosyaVar = true;
                    }

                    if (pdfDosya != null)
                    {
                        var pdfEntry = zip.CreateEntry($"{hedefKlasor}/{SanitizePathSegment(pdfDosya.FileName)}", CompressionLevel.Optimal);
                        await using var pdfEntryStream = pdfEntry.Open();
                        await pdfEntryStream.WriteAsync(pdfDosya.Content);
                        pdfSayisi++;
                        buFaturadaDosyaVar = true;
                    }

                    if (buFaturadaDosyaVar)
                        dosyaliFaturaSayisi++;
                }
            }

            if (xmlSayisi == 0 && pdfSayisi == 0)
            {
                ToastService.ShowWarning("Seçili faturalarda aktarılacak XML veya PDF bulunamadı.");
                return;
            }

            var zipDosyaAdi = $"gelen_faturalar_xml_pdf_{DateTime.Now:yyyyMMdd_HHmmss}.zip";
            await JS.InvokeVoidAsync("downloadFile", zipDosyaAdi, Convert.ToBase64String(zipStream.ToArray()), "application/zip");
            ToastService.ShowSuccess($"{dosyaliFaturaSayisi} faturaya ait {xmlSayisi} XML ve {pdfSayisi} PDF aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Aktarım hatası: {ex.Message}");
        }
    }

    private string GetFaturaFirmaKlasoru(Fatura fatura)
    {
        var firmaId = fatura.FirmaId ?? fatura.Cari?.FirmaId;
        var firmaAdi = firmalar.FirstOrDefault(x => x.Id == firmaId)?.FirmaAdi;

        if (string.IsNullOrWhiteSpace(firmaAdi))
            firmaAdi = "Firma_Bilinmiyor";

        return SanitizePathSegment(firmaAdi);
    }

    private static string SanitizePathSegment(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Bilinmiyor";

        var invalidChars = Path.GetInvalidFileNameChars();
        var sanitized = new string(value.Trim().Select(ch => invalidChars.Contains(ch) ? '_' : ch).ToArray());

        return string.IsNullOrWhiteSpace(sanitized) ? "Bilinmiyor" : sanitized;
    }

