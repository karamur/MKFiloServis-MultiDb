    private async Task FaturaKaydet()
    {
        faturaFormHataMesaji = null;

        if (string.IsNullOrWhiteSpace(editFatura.FaturaNo) || editFatura.CariId <= 0 || editFatura.GenelToplam <= 0 || !editFatura.FirmaId.HasValue)
        {
            faturaFormHataMesaji = "Fatura no, firma, cari ve tutar alanlari zorunludur!";
            return;
        }

        if (editFatura.FirmalarArasiFatura && (!editFatura.KarsiFirmaId.HasValue || editFatura.KarsiFirmaId == editFatura.FirmaId))
        {
            faturaFormHataMesaji = "Firmalar arası faturada farklı bir karşı firma seçin.";
            return;
        }

        if (!editFatura.FirmalarArasiFatura)
            editFatura.KarsiFirmaId = null;

        try
        {
            editFatura.FaturaYonu = FaturaYonu.Gelen;
            editFatura.FaturaTipi = FaturaTipi.AlisFaturasi;
            editFatura.FaturaTarihi = DateTime.SpecifyKind(editFatura.FaturaTarihi, DateTimeKind.Utc);
            if (editFatura.VadeTarihi.HasValue)
                editFatura.VadeTarihi = DateTime.SpecifyKind(editFatura.VadeTarihi.Value, DateTimeKind.Utc);

            if (editFatura.Id > 0)
                await FaturaService.UpdateAsync(editFatura);
            else
                await FaturaService.CreateAsync(editFatura);

            ToastService.ShowSuccess("Fatura kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (InvalidOperationException ex)
        {
            faturaFormHataMesaji = ex.Message;
        }
        catch (Exception)
        {
            faturaFormHataMesaji = "Fatura kaydedilirken beklenmeyen bir hata oluştu.";
        }
    }

