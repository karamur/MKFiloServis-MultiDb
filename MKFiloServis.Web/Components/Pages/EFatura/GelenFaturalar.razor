    private async Task PdfOnizlemeYukleAsync(Fatura fatura)
    {
        pdfOnizlemeUrl = null;
        pdfOnizlemeBase64 = null;
        pdfOnizlemeDosyaAdi = null;

        if (string.IsNullOrWhiteSpace(fatura.PdfDosyaYolu))
            return;

        pdfOnizlemeYukleniyor = true;
        StateHasChanged();

        try
        {
            var dosya = await FaturaService.GetFaturaDosyaAsync(fatura.Id, FaturaDosyaTuru.Pdf);
            if (dosya == null)
                return;

            pdfOnizlemeBase64 = Convert.ToBase64String(dosya.Content);
            pdfOnizlemeDosyaAdi = dosya.FileName;
            pdfOnizlemeUrl = $"data:{dosya.ContentType};base64,{pdfOnizlemeBase64}";
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF açılamadı: {ex.Message}");
        }
        finally
        {
            pdfOnizlemeYukleniyor = false;
            StateHasChanged();
        }
    }

    private async Task PdfIndirAsync()
    {
        if (string.IsNullOrWhiteSpace(pdfOnizlemeBase64))
            return;

        await JS.InvokeVoidAsync("downloadFile", pdfOnizlemeDosyaAdi ?? "fatura.pdf", pdfOnizlemeBase64, "application/pdf");
    }

    private void CariKartAc(Cari cari)
    {
        cariKartCari = cari;
        cariKartBaslangic = new DateTime(DateTime.Today.Year, 1, 1);
        cariKartBitis = DateTime.Today;
        showCariKartModal = true;
        _ = CariKartEkstreYukle();
    }

    private async Task CariKartEkstreYukle()
    {
        if (cariKartCari == null) return;

        cariKartYukleniyor = true;
        cariKartHareketler.Clear();
        StateHasChanged();

        try
        {
            // Faturalari getir
            var faturalarList = await FaturaService.GetByCariIdAsync(cariKartCari.Id);
            var donemFaturalar = faturalarList
                .Where(f => f.FaturaTarihi >= cariKartBaslangic && f.FaturaTarihi <= cariKartBitis)
                .ToList();

            foreach (var fatura in donemFaturalar)
            {
                cariKartHareketler.Add(new CariEkstreHareket
                {
                    Tarih = fatura.FaturaTarihi,
                    IslemTipi = fatura.FaturaTipi == FaturaTipi.SatisFaturasi ? "Satis Faturasi" : "Alis Faturasi",
                    BelgeNo = fatura.FaturaNo,
                    Aciklama = fatura.Aciklama ?? fatura.FaturaNo,
                    Alacak = fatura.FaturaTipi == FaturaTipi.SatisFaturasi ? fatura.GenelToplam : 0,
                    Borc = fatura.FaturaTipi == FaturaTipi.AlisFaturasi ? fatura.GenelToplam : 0
                });
            }

            // Odemeleri getir
            var odemeler = await BankaKasaService.GetByCariIdAsync(cariKartCari.Id);
            var donemOdemeler = odemeler
                .Where(o => o.IslemTarihi >= cariKartBaslangic && o.IslemTarihi <= cariKartBitis)
                .ToList();

            foreach (var odeme in donemOdemeler)
            {
                cariKartHareketler.Add(new CariEkstreHareket
                {
                    Tarih = odeme.IslemTarihi,
                    IslemTipi = odeme.HareketTipi == HareketTipi.Giris ? "Tahsilat" : "Odeme",
                    BelgeNo = odeme.IslemNo,
                    Aciklama = odeme.Aciklama ?? odeme.IslemNo,
                    Borc = odeme.HareketTipi == HareketTipi.Giris ? odeme.Tutar : 0,
                    Alacak = odeme.HareketTipi == HareketTipi.Cikis ? odeme.Tutar : 0
                });
            }

            // Sirala
            cariKartHareketler = cariKartHareketler.OrderBy(h => h.Tarih).ThenBy(h => h.BelgeNo).ToList();

            // Toplamlari hesapla
            cariKartToplamAlacak = cariKartHareketler.Sum(h => h.Alacak);
            cariKartToplamBorc = cariKartHareketler.Sum(h => h.Borc);
            cariKartBakiye = cariKartToplamAlacak - cariKartToplamBorc;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Ekstre yuklenemedi: {ex.Message}");
        }
        finally
        {
            cariKartYukleniyor = false;
            StateHasChanged();
        }
    }

    private async Task CariKartExcelExport()
    {
        if (cariKartCari == null || !cariKartHareketler.Any())
        {
            ToastService.ShowWarning("Indirilecek hareket yok!");
            return;
        }

        try
        {
            using var workbook = new ClosedXML.Excel.XLWorkbook();
            var ws = workbook.Worksheets.Add("Cari Ekstre");

            ws.Cell(1, 1).Value = $"CARi EKSTRE - {cariKartCari.Unvan}";
            ws.Range(1, 1, 1, 7).Merge();
            ws.Cell(1, 1).Style.Font.Bold = true;
            ws.Cell(2, 1).Value = $"Tarih: {cariKartBaslangic:dd.MM.yyyy} - {cariKartBitis:dd.MM.yyyy}";

            var row = 4;
            var headers = new[] { "Tarih", "Islem Turu", "Belge No", "Aciklama", "Borc", "Alacak", "Bakiye" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(row, i + 1).Value = headers[i];
                ws.Cell(row, i + 1).Style.Font.Bold = true;
                ws.Cell(row, i + 1).Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightBlue;
            }
            row++;

            decimal bakiye = 0;
            foreach (var h in cariKartHareketler)
            {
                bakiye += h.Alacak - h.Borc;
                ws.Cell(row, 1).Value = h.Tarih;
                ws.Cell(row, 1).Style.DateFormat.Format = "dd.MM.yyyy";
                ws.Cell(row, 2).Value = h.IslemTipi;
                ws.Cell(row, 3).Value = h.BelgeNo;
                ws.Cell(row, 4).Value = h.Aciklama;
                ws.Cell(row, 5).Value = h.Borc > 0 ? (double)h.Borc : 0;
                ws.Cell(row, 6).Value = h.Alacak > 0 ? (double)h.Alacak : 0;
                ws.Cell(row, 7).Value = (double)bakiye;
                ws.Cell(row, 5).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 6).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 7).Style.NumberFormat.Format = "#,##0.00";
                row++;
            }

            ws.Cell(row, 1).Value = "TOPLAM";
            ws.Range(row, 1, row, 4).Merge();
            ws.Cell(row, 5).Value = (double)cariKartToplamBorc;
            ws.Cell(row, 6).Value = (double)cariKartToplamAlacak;
            ws.Cell(row, 7).Value = (double)cariKartBakiye;
            ws.Row(row).Style.Font.Bold = true;

            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"CariEkstre_{cariKartCari.CariKodu}_{DateTime.Now:yyyyMMdd}.xlsx", base64);
            ToastService.ShowSuccess("Excel indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel hatasi: {ex.Message}");
        }
    }

    private async Task CariKartYazdir()
    {
        if (cariKartCari == null) return;

        var yazdirIcerik = $@"
            <html><head><title>Cari Ekstre</title>
            <style>body{{font-family:Arial;margin:20px;}} table{{width:100%;border-collapse:collapse;font-size:12px;}} 
            th,td{{border:1px solid #000;padding:6px;}} th{{background:#f0f0f0;}}</style></head>
            <body>
            <h2>CARi EKSTRE</h2>
            <p><strong>Cari:</strong> {cariKartCari.CariKodu} - {cariKartCari.Unvan}</p>
            <p><strong>Tarih:</strong> {cariKartBaslangic:dd.MM.yyyy} - {cariKartBitis:dd.MM.yyyy}</p>
            <table>
            <tr><th>Tarih</th><th>Islem</th><th>Belge No</th><th>Aciklama</th><th>Borc</th><th>Alacak</th><th>Bakiye</th></tr>";

        decimal bakiye = 0;
        foreach (var h in cariKartHareketler)
        {
            bakiye += h.Alacak - h.Borc;
            yazdirIcerik += $@"<tr>
                <td>{h.Tarih:dd.MM.yyyy}</td><td>{h.IslemTipi}</td><td>{h.BelgeNo}</td><td>{h.Aciklama}</td>
                <td style='text-align:right'>{(h.Borc > 0 ? FormatPara(h.Borc) : "-")}</td>
                <td style='text-align:right'>{(h.Alacak > 0 ? FormatPara(h.Alacak) : "-")}</td>
                <td style='text-align:right;font-weight:bold'>{FormatPara(bakiye)}</td>
            </tr>";
        }

        yazdirIcerik += $@"<tr style='background:#ffffa0;font-weight:bold;'>
            <td colspan='4'>TOPLAM</td>
            <td style='text-align:right'>{FormatPara(cariKartToplamBorc)}</td>
            <td style='text-align:right'>{FormatPara(cariKartToplamAlacak)}</td>
            <td style='text-align:right'>{FormatPara(cariKartBakiye)}</td>
        </tr></table></body></html>";

        await JS.InvokeVoidAsync("eval", $@"
            var w = window.open('', '_blank', 'width=900,height=700');
            w.document.write(`{yazdirIcerik.Replace("`", "\\`")}`);
            w.document.close();
            w.focus();
            setTimeout(function(){{w.print();}},300);
        ");
    }

    private string GetIslemTipiBadge(string islemTipi) => islemTipi switch
    {
        "Satis Faturasi" => "bg-success",
        "Alis Faturasi" => "bg-primary",
        "Tahsilat" => "bg-info",
        "Odeme" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    #region Detay Modal Islemleri

    private void DetayFaturaDuzenle()
    {
        if (detayFatura == null) return;
        FaturaDuzenle(detayFatura);
        showDetayModal = false;
    }

    private void DetayFaturaOdemeYap()
    {
        if (detayFatura == null) return;
        OdemeYapAc(detayFatura);
        showDetayModal = false;
    }

    private async Task DetayFaturaSil()
    {
        if (detayFatura == null) return;
        
        var result = await JS.InvokeAsync<bool>("confirm", $"'{detayFatura.FaturaNo}' numarali faturayi silmek istediginizden emin misiniz?");
        if (!result) return;
        
        try
        {
            await FaturaService.DeleteAsync(detayFatura.Id);
            ToastService.ShowSuccess("Fatura silindi.");
            showDetayModal = false;
            detayFatura = null;
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task DetayFaturaMuhasebeles()
    {
        if (detayFatura == null) return;
        
        isMuhasebeLeniyor = true;
        StateHasChanged();
        
        try
        {
            if (detayFatura.Cari == null)
            {
                ToastService.ShowError("Faturaya ait cari bulunamadi!");
                return;
            }
            
            var fis = await MuhasebeService.CreateFaturaFisiAsync(detayFatura);
            
            detayFatura.MuhasebeFisiOlusturuldu = true;
            detayFatura.MuhasebeFisId = fis.Id;
            await FaturaService.UpdateAsync(detayFatura);
            
            ToastService.ShowSuccess($"Muhasebe fisi olusturuldu. Fis No: {fis.FisNo}");
            await YenileAsync();
            
            detayFatura = await FaturaService.GetByIdWithKalemlerAsync(detayFatura.Id);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Muhaselelestirme hatasi: {ex.Message}");
        }
        finally
        {
            isMuhasebeLeniyor = false;
            StateHasChanged();
        }
    }

    #endregion

