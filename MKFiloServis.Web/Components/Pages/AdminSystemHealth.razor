@page "/admin/system-health"
@using MKFiloServis.Web.Components.Pages
@rendermode InteractiveServer
@attribute [StreamRendering(enabled: true)]

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1>🛠️ Sistem Sağlığı & Recovery</h1>
            <hr />
        </div>
    </div>

    <!-- Recovery Bölümü -->
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">📋 Şifrelenmiş Dosya Recovery</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Master key değişikliğinden sonra, eski anahtarla şifrelenmiş dosyaları yeni anahtarla
                        yeniden şifrelemek için bu aracı kullanın.
                    </p>

                    <div class="mb-3">
                        <label class="form-label"><strong>Eski Master Key (HEX)</strong></label>
                        <textarea class="form-control" rows="3" @bind="oldMasterKeyHex" placeholder="64 karakterlik HEX string..."></textarea>
                        <small class="form-text text-muted">
                            Örn: <code>EE4461E47C5DDF6C5750EE9403735642171A5399FD9292F0C7631B2F181B8415</code>
                        </small>
                    </div>

                    <button class="btn btn-warning" 
                            @onclick="TriggerRecoveryAsync" 
                            disabled="@isRecoveryInProgress">
                        @if (isRecoveryInProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Recovery Çalışıyor...</span>
                        }
                        else
                        {
                            <span>🔄 Recovery Başlat</span>
                        }
                    </button>
                </div>
            </div>

            <!-- Status Mesajı -->
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-info mt-3 alert-dismissible fade show" role="alert">
                    @statusMessage
                    <button type="button" class="btn-close" @onclick="() => statusMessage = \"\""></button>
                </div>
            }

            <!-- Recovery Sonuçları -->
            @if (recoveryResult != null)
            {
                <div class="card mt-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">📊 Recovery Sonuçları</h6>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-md-4">
                                <div class="badge bg-success p-2">
                                    <h5>@recoveryResult.SuccessCount</h5>
                                    <small>Başarılı</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="badge bg-danger p-2">
                                    <h5>@recoveryResult.FailedCount</h5>
                                    <small>Başarısız</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="badge bg-secondary p-2">
                                    <h5>@recoveryResult.SkippedCount</h5>
                                    <small>Skip</small>
                                </div>
                            </div>
                        </div>

                        @if (recoveryResult.RecoveredFiles.Any())
                        {
                            <div class="mt-3">
                                <h6>✅ Kurtarılan Dosyalar</h6>
                                <ul class="list-group">
                                    @foreach (var file in recoveryResult.RecoveredFiles.Take(10))
                                    {
                                        <li class="list-group-item text-success">
                                            <small>@file</small>
                                        </li>
                                    }
                                </ul>
                                @if (recoveryResult.RecoveredFiles.Count > 10)
                                {
                                    <small class="text-muted">... ve @(recoveryResult.RecoveredFiles.Count - 10) daha fazla</small>
                                }
                            </div>
                        }

                        @if (recoveryResult.FailedFiles.Any())
                        {
                            <div class="mt-3">
                                <h6>❌ Başarısız Dosyalar</h6>
                                <ul class="list-group">
                                    @foreach (var failedFile in recoveryResult.FailedFiles.Take(5))
                                    {
                                        <li class="list-group-item text-danger">
                                            <small>@failedFile</small>
                                        </li>
                                    }
                                </ul>
                                @if (recoveryResult.FailedFiles.Count > 5)
                                {
                                    <small class="text-muted">... ve @(recoveryResult.FailedFiles.Count - 5) daha fazla</small>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Info Paneli -->
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-header">
                    <h6 class="mb-0">ℹ️ Bilgi</h6>
                </div>
                <div class="card-body small">
                    <p>
                        <strong>Recovery nedir?</strong><br />
                        Eski anahtarla şifrelenmiş dosyaları okur ve yeni anahtarla yeniden şifreler.
                    </p>
                    <p>
                        <strong>Ne zaman kullanmalı?</strong><br />
                        Master key değişikliğinden sonra dosya açılamıyor ise.
                    </p>
                    <p>
                        <strong>Eski anahtarı nereden bulsam?</strong><br />
                        <code>C:\MKFiloServis_yedekleme\keys\raw-key.txt.bak</code>
                    </p>
                    <p>
                        <strong>⚠️ DİKKAT:</strong><br />
                        Bu işlem zaman alabilir. İşlem sırasında uygulamayı kapatmayın.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Kod AdminSystemHealth.razor.cs dosyasında
}

