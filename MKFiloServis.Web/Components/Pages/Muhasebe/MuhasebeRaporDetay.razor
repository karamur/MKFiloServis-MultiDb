@page "/muhasebe/raporlar/muavin"
@page "/muhasebe/raporlar/mizan"
@page "/muhasebe/raporlar/bilanco"
@page "/muhasebe/raporlar/yevmiye-detay"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMuhasebeService MuhasebeService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Muhasebe Resmi Raporlar</PageTitle>

<div class="container-fluid" id="print-area">
    <div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
        <div>
            <h3><i class="bi bi-file-earmark-bar-graph me-2"></i>@Baslik</h3>
            <small class="text-muted">Resmi muhasebe rapor görüntüleme ekranı</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/muhasebe/raporlar")'>
                <i class="bi bi-arrow-left me-1"></i>Geri
            </button>
            <button class="btn btn-primary" @onclick="YukleAsync">
                <i class="bi bi-search me-1"></i>Getir
            </button>
            @if (RaporTip != "resmi-raporlar" && !isLoading)
            {
                <button class="btn btn-success" @onclick="ExceleAktar">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
                <button class="btn btn-dark" onclick="window.print()">
                    <i class="bi bi-printer me-1"></i>Yazdır
                </button>
            }
        </div>
    </div>

    <div class="card mb-3 d-print-none">
        <div class="card-body">
            @if (RaporTip == "muavin")
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Hesap Kodu</label>
                        <input class="form-control" @bind="hesapKodu" placeholder="100, 120, 320..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Başlangıç</label>
                        <input type="date" class="form-control" @bind="baslangicTarih" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Bitiş</label>
                        <input type="date" class="form-control" @bind="bitisTarih" />
                    </div>
                </div>
            }
            else if (RaporTip == "bilanco")
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Tarih</label>
                        <input type="date" class="form-control" @bind="tarih" />
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Başlangıç</label>
                        <input type="date" class="form-control" @bind="baslangicTarih" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Bitiş</label>
                        <input type="date" class="form-control" @bind="bitisTarih" />
                    </div>
                </div>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (RaporTip == "muavin" && muavinRapor != null)
    {
        <div class="card">
            <div class="card-header bg-primary text-white">@muavinRapor.HesapKodu - @muavinRapor.HesapAdi</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Tarih</th><th>Fiş No</th><th>Açıklama</th><th class="text-end">Borç</th><th class="text-end">Alacak</th><th class="text-end">Bakiye</th></tr></thead>
                    <tbody>
                        @foreach (var s in muavinRapor.Satirlar)
                        {
                            <tr>
                                <td>@s.Tarih.ToString("dd.MM.yyyy")</td>
                                <td>@s.FisNo</td>
                                <td>@s.Aciklama</td>
                                <td class="text-end">@(s.Borc > 0 ? FormatPara(s.Borc) : "")</td>
                                <td class="text-end">@(s.Alacak > 0 ? FormatPara(s.Alacak) : "")</td>
                                <td class="text-end">@FormatPara(s.Bakiye)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (RaporTip == "yevmiye" && yevmiyeRapor != null)
    {
        <div class="card">
            <div class="card-header bg-success text-white">Yevmiye Defteri ( Dönem: @baslangicTarih.ToString("dd.MM.yyyy") - @bitisTarih.ToString("dd.MM.yyyy") )</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Tarih</th><th>Fiş No</th><th>Hesap</th><th>Açıklama</th><th class="text-end">Borç</th><th class="text-end">Alacak</th></tr></thead>
                    <tbody>
                        @foreach (var s in yevmiyeRapor.Satirlar)
                        {
                            <tr>
                                <td>@s.Tarih.ToString("dd.MM.yyyy")</td>
                                <td>@s.FisNo</td>
                                <td>@s.HesapKodu - @s.HesapAdi</td>
                                <td>@s.Aciklama</td>
                                <td class="text-end">@(s.Borc > 0 ? FormatPara(s.Borc) : "")</td>
                                <td class="text-end">@(s.Alacak > 0 ? FormatPara(s.Alacak) : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (RaporTip == "mizan" && mizanRapor != null)
    {
        <div class="card">
            <div class="card-header bg-info text-white">Mizan</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Hesap Kodu</th><th>Hesap Adı</th><th class="text-end">Borç</th><th class="text-end">Alacak</th><th class="text-end">Borç Bakiye</th><th class="text-end">Alacak Bakiye</th></tr></thead>
                    <tbody>
                        @foreach (var s in mizanRapor.Satirlar)
                        {
                            <tr>
                                <td>@s.HesapKodu</td>
                                <td>@s.HesapAdi</td>
                                <td class="text-end">@FormatPara(s.Borc)</td>
                                <td class="text-end">@FormatPara(s.Alacak)</td>
                                <td class="text-end">@FormatPara(s.BorcBakiye)</td>
                                <td class="text-end">@FormatPara(s.AlacakBakiye)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (RaporTip == "bilanco" && bilancoRapor != null)
    {
        <div class="row g-3">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-light"><strong>Aktifler</strong></div>
                    <ul class="list-group list-group-flush">
                        @foreach (var k in bilancoRapor.DonenVarliklar.Concat(bilancoRapor.DuranVarliklar))
                        {
                            <li class="list-group-item d-flex justify-content-between"><span>@k.HesapKodu - @k.HesapAdi</span><strong>@FormatPara(k.Tutar)</strong></li>
                        }
                    </ul>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-light"><strong>Pasifler</strong></div>
                    <ul class="list-group list-group-flush">
                        @foreach (var k in bilancoRapor.KisaVadeliYabanciKaynaklar.Concat(bilancoRapor.UzunVadeliYabanciKaynaklar).Concat(bilancoRapor.Ozkaynaklar))
                        {
                            <li class="list-group-item d-flex justify-content-between"><span>@k.HesapKodu - @k.HesapAdi</span><strong>@FormatPara(k.Tutar)</strong></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
    else if (RaporTip == "resmi-raporlar")
    {
        <div class="row g-3 d-print-none">
            <div class="col-md-3"><a class="btn btn-outline-primary w-100 py-3" href="/muhasebe/raporlar/muavin"><i class="bi bi-journal-bookmark me-2"></i>Muavin</a></div>
            <div class="col-md-3"><a class="btn btn-outline-success w-100 py-3" href="/muhasebe/raporlar/yevmiye"><i class="bi bi-journal-text me-2"></i>Yevmiye Defteri</a></div>
            <div class="col-md-3"><a class="btn btn-outline-info w-100 py-3" href="/muhasebe/raporlar/mizan"><i class="bi bi-calculator me-2"></i>Mizan</a></div>
            <div class="col-md-3"><a class="btn btn-outline-danger w-100 py-3" href="/muhasebe/raporlar/bilanco"><i class="bi bi-bar-chart me-2"></i>Bilanço</a></div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? hesapKodu { get; set; }
    [SupplyParameterFromQuery] public string? baslangic { get; set; }
    [SupplyParameterFromQuery] public string? bitis { get; set; }
    [SupplyParameterFromQuery] public bool yazdir { get; set; } = false;

    private string RaporTip => Navigation.ToBaseRelativePath(Navigation.Uri).Split('?').First().Split('/').Last().ToLowerInvariant();
    private string Baslik => RaporTip switch { "muavin" => "Muavin Raporu", "yevmiye" => "Yevmiye Defteri", "mizan" => "Mizan", "bilanco" => "Bilanço", _ => "Resmi Muhasebe Raporları" };
    private bool isLoading;
    private DateTime baslangicTarih = new(DateTime.Today.Year, 1, 1);
    private DateTime bitisTarih = DateTime.Today;
    private DateTime tarih = DateTime.Today;
    private MuavinRapor? muavinRapor;
    private YevmiyeRapor? yevmiyeRapor;
    private MizanRapor? mizanRapor;
    private BilancoRapor? bilancoRapor;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(baslangic) && DateTime.TryParse(baslangic, out var b)) baslangicTarih = b;
        if (!string.IsNullOrEmpty(bitis) && DateTime.TryParse(bitis, out var bt)) bitisTarih = bt;
        if (RaporTip != "resmi-raporlar")
            await YukleAsync();

        if (yazdir)
        {
            await Task.Delay(500); // Sayfanın yüklenmesini bekle
            await JSRuntime.InvokeVoidAsync("eval", "window.print()");
        }
    }

    private async Task YukleAsync()
    {
        isLoading = true;
        try
        {
            switch (RaporTip)
            {
                case "muavin":
                    if (string.IsNullOrWhiteSpace(hesapKodu)) { ToastService.ShowWarning("Hesap kodu girin."); return; }
                    muavinRapor = await MuhasebeService.GetMuavinRaporuAsync(hesapKodu, baslangicTarih, bitisTarih);
                    break;
                case "yevmiye":
                    yevmiyeRapor = await MuhasebeService.GetYevmiyeRaporuAsync(baslangicTarih, bitisTarih);
                    break;
                case "mizan":
                    mizanRapor = await MuhasebeService.GetMizanRaporuAsync(baslangicTarih, bitisTarih);
                    break;
                case "bilanco":
                    bilancoRapor = await MuhasebeService.GetBilancoRaporuAsync(tarih);
                    break;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Rapor yüklenemedi: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExceleAktar()
    {
        ToastService.ShowSuccess("Rapor arka planda Excel'e aktarılıyor...");
        
        string csvContent = "";
        
        if (RaporTip == "muavin" && muavinRapor != null)
        {
            csvContent = "Tarih;Fiş No;Açıklama;Borç;Alacak;Bakiye\n";
            foreach (var s in muavinRapor.Satirlar)
            {
                csvContent += $"{s.Tarih:dd.MM.yyyy};{s.FisNo};{s.Aciklama};{s.Borc};{s.Alacak};{s.Bakiye}\n";
            }
        }
        else if (RaporTip == "yevmiye" && yevmiyeRapor != null)
        {
            csvContent = "Tarih;Fiş No;Hesap Kodu;Hesap Adı;Açıklama;Borç;Alacak\n";
            foreach (var s in yevmiyeRapor.Satirlar)
            {
                csvContent += $"{s.Tarih:dd.MM.yyyy};{s.FisNo};{s.HesapKodu};{s.HesapAdi};{s.Aciklama};{s.Borc};{s.Alacak}\n";
            }
        }
        else if (RaporTip == "mizan" && mizanRapor != null)
        {
            csvContent = "Hesap Kodu;Hesap Adı;Borç;Alacak;Borç Bakiye;Alacak Bakiye\n";
            foreach (var s in mizanRapor.Satirlar)
            {
                csvContent += $"{s.HesapKodu};{s.HesapAdi};{s.Borc};{s.Alacak};{s.BorcBakiye};{s.AlacakBakiye}\n";
            }
        }
        else if (RaporTip == "bilanco" && bilancoRapor != null)
        {
            csvContent = "Hesap Kodu;Hesap Adı;Tutar;Tip\n";
            foreach (var k in bilancoRapor.DonenVarliklar) csvContent += $"{k.HesapKodu};{k.HesapAdi};{k.Tutar};Dönen Varlıklar\n";
            foreach (var k in bilancoRapor.DuranVarliklar) csvContent += $"{k.HesapKodu};{k.HesapAdi};{k.Tutar};Duran Varlıklar\n";
            foreach (var k in bilancoRapor.KisaVadeliYabanciKaynaklar) csvContent += $"{k.HesapKodu};{k.HesapAdi};{k.Tutar};Kısa Vadeli YK\n";
            foreach (var k in bilancoRapor.UzunVadeliYabanciKaynaklar) csvContent += $"{k.HesapKodu};{k.HesapAdi};{k.Tutar};Uzun Vadeli YK\n";
            foreach (var k in bilancoRapor.Ozkaynaklar) csvContent += $"{k.HesapKodu};{k.HesapAdi};{k.Tutar};Özkaynaklar\n";
        }
        
        // BOM (Byte Order Mark) eklendi -> Türkçe karakterlerin Excel'de düzgün görünmesi için.
        string fileName = $"{RaporTip}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        var bytes = System.Text.Encoding.UTF8.GetPreamble().Concat(System.Text.Encoding.UTF8.GetBytes(csvContent)).ToArray();
        var base64 = Convert.ToBase64String(bytes);
        
        // JS ile indirme tetikle
        await JSRuntime.InvokeVoidAsync("eval", $@"
            var a = document.createElement('a');
            a.href = 'data:text/csv;base64,{base64}';
            a.download = '{fileName}';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        ");
    }

    private static string FormatPara(decimal tutar) => tutar.ToString("N2") + " TL";
}

