@page "/muhasebe/resmi-raporlar/ise-giris-cikis"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@inject IRaporService RaporService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>İşe Giriş / Çıkış Bildirge</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3><i class="bi bi-person-vcard me-2"></i>İşe Giriş / Çıkış Bildirge</h3>
            <small class="text-muted">SGK bildirge hazırlığı için personel giriş ve çıkış hareketleri</small>
        </div>
        <a href="/muhasebe/resmi-raporlar" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Resmi Raporlara Dön
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Başlangıç</label>
                    <input type="date" class="form-control" @bind="baslangicTarihi" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bitiş</label>
                    <input type="date" class="form-control" @bind="bitisTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Kayıt Tipi</label>
                    <select class="form-select" @bind="filtreTipi">
                        <option value="@IseGirisCikisFiltreTipi.Tumu">Tümü</option>
                        <option value="@IseGirisCikisFiltreTipi.IseGiris">İşe Giriş</option>
                        <option value="@IseGirisCikisFiltreTipi.IstenCikis">İşten Çıkış</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Görev</label>
                    <select class="form-select" @bind="seciliGorevInt">
                        <option value="">Tüm Görevler</option>
                        @foreach (PersonelGorev gorev in Enum.GetValues<PersonelGorev>())
                        {
                            <option value="@((int)gorev)">@GetGorevAdi(gorev)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid gap-2">
                    <button class="btn btn-primary" @onclick="RaporYukle">
                        <i class="bi bi-search me-1"></i>Listele
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (rapor != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@rapor.ToplamKayit</h3>
                        <small>Toplam Kayıt</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@rapor.IseGirisSayisi</h3>
                        <small>İşe Giriş</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@rapor.IstenCikisSayisi</h3>
                        <small>İşten Çıkış</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@rapor.AktifPersonelSayisi</h3>
                        <small>Aktif Personel</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mb-3">
            <button class="btn btn-outline-dark" @onclick="Yazdir">
                <i class="bi bi-printer me-1"></i>Yazdır
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelIndir" disabled="@(!rapor.Kayitlar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel İndir
            </button>
        </div>

        @if (!rapor.Kayitlar.Any())
        {
            <div class="alert alert-info">
                Seçilen kriterlere uygun kayıt bulunamadı.
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Bildirge Tarihi</th>
                                    <th>Tip</th>
                                    <th>Personel</th>
                                    <th>TC</th>
                                    <th>Görev</th>
                                    <th>Departman</th>
                                    <th>İşe Başlama</th>
                                    <th>Çıkış Tarihi</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kayit in rapor.Kayitlar)
                                {
                                    <tr>
                                        <td>@kayit.BildirgeTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <span class="badge @(kayit.KayitTipi == IseGirisCikisKayitTipi.IseGiris ? "bg-success" : "bg-danger")">
                                                @(kayit.KayitTipi == IseGirisCikisKayitTipi.IseGiris ? "İşe Giriş" : "İşten Çıkış")
                                            </span>
                                        </td>
                                        <td>
                                            <strong>@kayit.PersonelAdi</strong>
                                            <br /><small class="text-muted">@kayit.PersonelKodu</small>
                                        </td>
                                        <td>@(kayit.TcKimlikNo ?? "-")</td>
                                        <td>@GetGorevAdi(kayit.Gorev)</td>
                                        <td>@(string.IsNullOrWhiteSpace(kayit.Departman) ? "-" : kayit.Departman)</td>
                                        <td>@(kayit.IseBaslamaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>@((kayit.SgkCikisTarihi ?? kayit.IstenAyrilmaTarihi)?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>
                                            <span class="badge @(kayit.AktifMi ? "bg-primary" : "bg-secondary")">
                                                @(kayit.AktifMi ? "Aktif" : "Pasif")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private DateTime baslangicTarihi = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bitisTarihi = new(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
    private IseGirisCikisFiltreTipi filtreTipi = IseGirisCikisFiltreTipi.Tumu;
    private int? seciliGorevInt;
    private IseGirisCikisBildirgeRaporu? rapor;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await RaporYukle();
    }

    private async Task RaporYukle()
    {
        isLoading = true;
        try
        {
            rapor = await RaporService.GetIseGirisCikisBildirgeAsync(baslangicTarihi, bitisTarihi, filtreTipi, seciliGorevInt.HasValue ? (PersonelGorev)seciliGorevInt.Value : null);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Rapor yüklenemedi: {ex.GetBaseException().Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExcelIndir()
    {
        try
        {
            var bytes = await RaporService.ExportIseGirisCikisBildirgeExcelAsync(baslangicTarihi, bitisTarihi, filtreTipi, seciliGorevInt.HasValue ? (PersonelGorev)seciliGorevInt.Value : null);
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"ise_giris_cikis_bildirge_{DateTime.Now:yyyyMMdd}.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel indirilemedi: {ex.GetBaseException().Message}");
        }
    }

    private async Task Yazdir()
    {
        await JS.InvokeVoidAsync("eval", "window.print()");
    }

    private static string GetGorevAdi(PersonelGorev gorev) => gorev switch
    {
        PersonelGorev.Sofor => "Şoför",
        PersonelGorev.OfisCalisani => "Ofis Çalışanı",
        PersonelGorev.Muhasebe => "Muhasebe",
        PersonelGorev.Yonetici => "Yönetici",
        PersonelGorev.Teknik => "Teknik",
        _ => "Diğer"
    };
}

