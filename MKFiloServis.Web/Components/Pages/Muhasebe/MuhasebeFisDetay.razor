@page "/muhasebe/fisler/{FisId:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMuhasebeService MuhasebeService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Muhasebe Fiş Detay</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-receipt me-2"></i>Muhasebe Fiş Detayı</h3>
            @if (fis != null)
            {
                <small class="text-muted">@fis.FisNo</small>
            }
        </div>
        <div class="d-flex gap-2">
            @if (fis?.Kalemler?.Any(k => k.CariId.HasValue) == true)
            {
                <button class="btn btn-outline-secondary" @onclick="CariEkstreAc">
                    <i class="bi bi-file-text me-1"></i>Cari Ekstre
                </button>
            }
            @if (fis != null)
            {
                <button class="btn btn-outline-primary" @onclick="DuzenleAc" disabled="@(fis.Durum == FisDurum.Onaylandi)">
                    <i class="bi bi-pencil me-1"></i>Düzenle
                </button>
                <button class="btn btn-outline-danger" @onclick="SilFis" disabled="@(fis.Durum == FisDurum.Onaylandi)">
                    <i class="bi bi-trash me-1"></i>Sil
                </button>
            }
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/muhasebe/fisler")'>
                <i class="bi bi-arrow-left me-1"></i>Listeye Dön
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (fis == null)
    {
        <div class="alert alert-warning">Fiş bulunamadı.</div>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card"><div class="card-body"><small class="text-muted">Fiş No</small><div class="fw-bold">@fis.FisNo</div></div></div>
            </div>
            <div class="col-md-3">
                <div class="card"><div class="card-body"><small class="text-muted">Tarih</small><div class="fw-bold">@fis.FisTarihi.ToLocalTime().ToString("dd.MM.yyyy")</div></div></div>
            </div>
            <div class="col-md-3">
                <div class="card"><div class="card-body"><small class="text-muted">Tip</small><div class="fw-bold">@GetFisTipAdi(fis.FisTipi)</div></div></div>
            </div>
            <div class="col-md-3">
                <div class="card"><div class="card-body"><small class="text-muted">Durum</small><div><span class="badge @GetDurumClass(fis.Durum)">@GetDurumAdi(fis.Durum)</span></div></div></div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>Açıklama</strong></div>
            <div class="card-body">@(string.IsNullOrWhiteSpace(fis.Aciklama) ? "-" : fis.Aciklama)</div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Fiş Kalemleri</strong>
                <span class="text-muted">Borç: @FormatPara(fis.ToplamBorc) | Alacak: @FormatPara(fis.ToplamAlacak)</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sıra</th>
                            <th>Hesap Kodu</th>
                            <th>Hesap Adı</th>
                            <th>Açıklama</th>
                            <th class="text-end">Borç</th>
                            <th class="text-end">Alacak</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (fis.Kalemler != null && fis.Kalemler.Any())
                        {
                            @foreach (var kalem in fis.Kalemler.OrderBy(k => k.SiraNo))
                            {
                                <tr>
                                    <td>@kalem.SiraNo</td>
                                    <td><code>@kalem.Hesap?.HesapKodu</code></td>
                                    <td>@kalem.Hesap?.HesapAdi</td>
                                    <td>@kalem.Aciklama</td>
                                    <td class="text-end">@FormatPara(kalem.Borc)</td>
                                    <td class="text-end">@FormatPara(kalem.Alacak)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">Kalem bulunamadı.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int FisId { get; set; }

    private MuhasebeFis? fis;
    private bool isLoading = true;
    private bool isLoadInProgress;

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (isLoadInProgress)
            return;

        isLoadInProgress = true;
        isLoading = true;

        try
        {
            fis = await MuhasebeService.GetFisByIdAsync(FisId);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Fiş yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            isLoadInProgress = false;
        }
    }

    private void DuzenleAc()
    {
        Navigation.NavigateTo($"/muhasebe/fisler?editId={FisId}");
    }

    private async Task SilFis()
    {
        var onay = await JS.InvokeAsync<bool>("confirm", "Bu fiş silinsin mi?");
        if (!onay)
            return;

        try
        {
            await MuhasebeService.DeleteFisAsync(FisId);
            ToastService.ShowSuccess("Fiş silindi.");
            Navigation.NavigateTo("/muhasebe/fisler");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme hatası: {ex.Message}");
        }
    }

    private void CariEkstreAc()
    {
        var cariId = fis?.Kalemler?.FirstOrDefault(k => k.CariId.HasValue)?.CariId;
        if (cariId.HasValue)
            Navigation.NavigateTo($"/raporlar/cari-ekstre?cariId={cariId.Value}");
    }

    private static string GetFisTipAdi(FisTipi tip) => tip switch
    {
        FisTipi.Mahsup => "Mahsup",
        FisTipi.Tahsilat => "Tahsilat",
        FisTipi.Tediye => "Tediye",
        FisTipi.Acilis => "Acilis",
        FisTipi.Kapanis => "Kapanis",
        FisTipi.Devir => "Devir",
        _ => tip.ToString()
    };

    private static string GetDurumAdi(FisDurum durum) => durum switch
    {
        FisDurum.Taslak => "Taslak",
        FisDurum.Onaylandi => "Onaylandi",
        FisDurum.IptalEdildi => "Iptal",
        _ => durum.ToString()
    };

    private static string GetDurumClass(FisDurum durum) => durum switch
    {
        FisDurum.Taslak => "bg-warning text-dark",
        FisDurum.Onaylandi => "bg-success",
        FisDurum.IptalEdildi => "bg-danger",
        _ => "bg-secondary"
    };

    private static string FormatPara(decimal tutar) => tutar.ToString("N2");
}

