@page "/muhasebe/cari-mutabakat"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMuhasebeService MuhasebeService
@inject ICariService CariService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject IBudgetService BudgetService
@inject IExcelService ExcelService
@inject IPdfService PdfService
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Cari Hesap Mutabakat</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-check2-square me-2"></i>Cari Hesap Mutabakat</h3>
    </div>

    <!-- Filtreler -->
    <div class="card mb-4">
        <div class="card-body">
            @if (tedarikciler.Any())
            {
                <div class="row g-3 mb-2">
                    <div class="col-md-6">
                        <label class="form-label">
                            <i class="bi bi-truck me-1"></i>Taşıma Tedarikçisi (hızlı seçim)
                        </label>
                        <select class="form-select" @bind="seciliTedarikciId" @bind:after="TedarikciSecildi">
                            <option value="0">-- Tedarikçi seçerek bağlı cariyi otomatik doldur --</option>
                            @foreach (var t in tedarikciler)
                            {
                                <option value="@t.Id">
                                    @t.Unvan (@t.TedarikciKodu) @(t.CariId.HasValue ? "" : "— cari bağlı değil")
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <small class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            Tedarikçi seçildiğinde bağlı cari otomatik seçilir. Seçilen cari için altta bekleyen
                            <strong>Taşıma Tedarikçi Hakediş</strong> ödemeleri listelenir.
                        </small>
                    </div>
                </div>
                <hr class="my-2" />
            }
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Cari Seçimi</label>
                    <select class="form-select" @bind="seciliCariId">
                        <option value="0">-- Cari Seçin --</option>
                        @foreach (var cari in cariler)
                        {
                            <option value="@cari.Id">@cari.Unvan (@cari.CariKodu)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Başlangıç</label>
                    <input type="date" class="form-control" @bind="baslangicTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bitiş</label>
                    <input type="date" class="form-control" @bind="bitisTarihi" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="MutabakatOlustur" disabled="@(seciliCariId == 0)">
                        <i class="bi bi-search me-1"></i>Mutabakat Oluştur
                    </button>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="btn-group w-100">
                        <button class="btn btn-outline-success" @onclick="ExcelIndir" disabled="@(mutabakatRapor == null)">
                            <i class="bi bi-file-earmark-excel"></i>
                        </button>
                        <button class="btn btn-outline-danger" @onclick="PdfIndir" disabled="@(mutabakatRapor == null)">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </button>
                        <button class="btn btn-outline-primary" @onclick="EmailGonder" disabled="@(mutabakatRapor == null)">
                            <i class="bi bi-envelope"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (mutabakatRapor != null)
    {
        @if (tedarikciHakedisleri.Any())
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-truck me-2"></i>
                        Bu Cariye Bağlı Taşıma Tedarikçi Hakedişleri
                        <span class="badge bg-dark ms-2">@tedarikciHakedisleri.Count kayıt</span>
                    </span>
                    <span class="fw-bold">
                        Bekleyen Toplam:
                        @FormatPara(tedarikciHakedisleri
                            .Where(o => o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi)
                            .Sum(o => o.KalanTutar))
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Dönem</th>
                                    <th>Açıklama</th>
                                    <th class="text-end">Tutar</th>
                                    <th class="text-end">Ödenen</th>
                                    <th class="text-end">Kalan</th>
                                    <th>Durum</th>
                                    <th class="text-end"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in tedarikciHakedisleri.OrderBy(x => x.OdemeYil).ThenBy(x => x.OdemeAy))
                                {
                                    <tr>
                                        <td>@($"{o.OdemeAy:D2}/{o.OdemeYil}")</td>
                                        <td><small>@o.Aciklama</small></td>
                                        <td class="text-end">@FormatPara(o.Miktar)</td>
                                        <td class="text-end text-success">@FormatPara(o.ToplamKismiOdenen + (o.Durum == OdemeDurum.Odendi ? (o.Miktar - o.ToplamKismiOdenen) : 0))</td>
                                        <td class="text-end fw-bold @(o.KalanTutar > 0 ? "text-danger" : "text-muted")">@FormatPara(o.KalanTutar)</td>
                                        <td>
                                            @switch (o.Durum)
                                            {
                                                case OdemeDurum.Odendi:
                                                    <span class="badge bg-success">Ödendi</span>
                                                    break;
                                                case OdemeDurum.KismiOdendi:
                                                    <span class="badge bg-info">Kısmi (%@o.OdemeYuzdesi.ToString("N0"))</span>
                                                    break;
                                                case OdemeDurum.Iptal:
                                                    <span class="badge bg-secondary">İptal</span>
                                                    break;
                                                case OdemeDurum.Ertelendi:
                                                    <span class="badge bg-dark">Ertelendi</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-warning text-dark">Bekliyor</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => OdemeyeGit(o.Id)" title="Ödeme Yönetimi'nde aç">
                                                <i class="bi bi-arrow-right"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer text-end bg-transparent">
                    <a href="/butce/odemeler" class="btn btn-sm btn-warning">
                        <i class="bi bi-wallet2 me-1"></i>Tüm Ödemeleri Yönet
                    </a>
                    <a href="/rapor/tasima-tedarikci" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-truck me-1"></i>Tedarikçi Raporu
                    </a>
                </div>
            </div>
        }

        <!-- Mutabakat Özeti -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h6>Dönem Başı Bakiye</h6>
                        <h4>@FormatPara(mutabakatRapor.DonemBasiBakiye)</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Borç</h6>
                        <h4>@FormatPara(mutabakatRapor.ToplamBorc)</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Alacak</h6>
                        <h4>@FormatPara(mutabakatRapor.ToplamAlacak)</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(mutabakatRapor.DonemSonuBakiye >= 0 ? "bg-info" : "bg-warning") text-white">
                    <div class="card-body text-center">
                        <h6>Dönem Sonu Bakiye</h6>
                        <h4>@FormatPara(mutabakatRapor.DonemSonuBakiye)</h4>
                        <small>@(mutabakatRapor.DonemSonuBakiye >= 0 ? "Alacaklıyız" : "Borçluyuz")</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cari Bilgileri -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-building me-2"></i>Cari Bilgileri
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr>
                                <th width="150">Cari Kodu</th>
                                <td>@mutabakatRapor.CariKodu</td>
                            </tr>
                            <tr>
                                <th>Ünvan</th>
                                <td><strong>@mutabakatRapor.CariUnvan</strong></td>
                            </tr>
                            <tr>
                                <th>Vergi No</th>
                                <td>@mutabakatRapor.VergiNo</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr>
                                <th width="150">Dönem</th>
                                <td>@mutabakatRapor.BaslangicTarihi.ToString("dd.MM.yyyy") - @mutabakatRapor.BitisTarihi.ToString("dd.MM.yyyy")</td>
                            </tr>
                            <tr>
                                <th>Hareket Sayısı</th>
                                <td>@mutabakatRapor.Hareketler.Count</td>
                            </tr>
                            <tr>
                                <th>Oluşturma</th>
                                <td>@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hareket Listesi -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-list-ul me-2"></i>Hesap Hareketleri</span>
                <span class="badge bg-secondary">@mutabakatRapor.Hareketler.Count hareket</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th width="100">Tarih</th>
                                <th width="120">Belge No</th>
                                <th>Açıklama</th>
                                <th width="100">Vade</th>
                                <th class="text-end" width="120">Borç</th>
                                <th class="text-end" width="120">Alacak</th>
                                <th class="text-end" width="130">Bakiye</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (mutabakatRapor.DonemBasiBakiye != 0)
                            {
                                <tr class="table-secondary">
                                    <td>@mutabakatRapor.BaslangicTarihi.AddDays(-1).ToString("dd.MM.yyyy")</td>
                                    <td>-</td>
                                    <td><em>Dönem Başı Devir</em></td>
                                    <td>-</td>
                                    <td class="text-end">@(mutabakatRapor.DonemBasiBakiye > 0 ? FormatPara(mutabakatRapor.DonemBasiBakiye) : "")</td>
                                    <td class="text-end">@(mutabakatRapor.DonemBasiBakiye < 0 ? FormatPara(Math.Abs(mutabakatRapor.DonemBasiBakiye)) : "")</td>
                                    <td class="text-end fw-bold">@FormatPara(mutabakatRapor.DonemBasiBakiye)</td>
                                </tr>
                            }
                            @foreach (var hareket in mutabakatRapor.Hareketler)
                            {
                                <tr>
                                    <td>@hareket.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td>@hareket.BelgeNo</td>
                                    <td>@hareket.Aciklama</td>
                                    <td>@(hareket.VadeTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td class="text-end">@(hareket.Borc > 0 ? FormatPara(hareket.Borc) : "")</td>
                                    <td class="text-end">@(hareket.Alacak > 0 ? FormatPara(hareket.Alacak) : "")</td>
                                    <td class="text-end fw-bold @(hareket.Bakiye >= 0 ? "text-success" : "text-danger")">
                                        @FormatPara(hareket.Bakiye)
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-warning">
                            <tr class="fw-bold">
                                <td colspan="4" class="text-end">TOPLAM:</td>
                                <td class="text-end">@FormatPara(mutabakatRapor.ToplamBorc)</td>
                                <td class="text-end">@FormatPara(mutabakatRapor.ToplamAlacak)</td>
                                <td class="text-end">@FormatPara(mutabakatRapor.DonemSonuBakiye)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Mutabakat Onay Bölümü -->
        <div class="card mt-4">
            <div class="card-header bg-success text-white">
                <i class="bi bi-check-circle me-2"></i>Mutabakat Onay
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="border p-3 rounded">
                            <h6>FİRMAMIZ</h6>
                            <p class="mb-1"><strong>Dönem Sonu Bakiye:</strong> @FormatPara(mutabakatRapor.DonemSonuBakiye)</p>
                            <p class="mb-3 text-muted">@(mutabakatRapor.DonemSonuBakiye >= 0 ? "Alacaklıyız" : "Borçluyuz")</p>
                            <div class="border-top pt-3 mt-3">
                                <small class="text-muted">İmza / Kaşe</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border p-3 rounded">
                            <h6>@mutabakatRapor.CariUnvan.ToUpper()</h6>
                            <p class="mb-1"><strong>Dönem Sonu Bakiye:</strong> @FormatPara(-mutabakatRapor.DonemSonuBakiye)</p>
                            <p class="mb-3 text-muted">@(mutabakatRapor.DonemSonuBakiye >= 0 ? "Borçlu" : "Alacaklı")</p>
                            <div class="border-top pt-3 mt-3">
                                <small class="text-muted">İmza / Kaşe</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center mt-3 text-muted">
                    <small>
                        Bu mutabakat @DateTime.Now.ToString("dd.MM.yyyy") tarihinde oluşturulmuştur.
                        Yukarıdaki bakiye bilgileri tarafımızca doğrulanmıştır.
                    </small>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-check2-square fs-1"></i>
            <p class="mt-3">Mutabakat oluşturmak için cari seçin ve tarihleri belirleyin</p>
        </div>
    }
</div>

@code {
    private List<Cari> cariler = new();
    private List<TasimaTedarikci> tedarikciler = new();
    private List<BudgetOdeme> tedarikciHakedisleri = new();
    private const string TasimaTedarikciHakedisKalemi = "Taşıma Tedarikçi Hakediş";
    private int seciliCariId = 0;
    private int seciliTedarikciId = 0;
    private DateTime baslangicTarihi = new DateTime(DateTime.Today.Year, 1, 1);
    private DateTime bitisTarihi = DateTime.Today;
    private MutabakatRapor? mutabakatRapor;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        try
        {
            tedarikciler = await TasimaTedarikciService.GetAllAsync(sadeceAktif: true);
        }
        catch
        {
            tedarikciler = new List<TasimaTedarikci>();
        }
    }

    private void TedarikciSecildi()
    {
        if (seciliTedarikciId == 0) return;
        var t = tedarikciler.FirstOrDefault(x => x.Id == seciliTedarikciId);
        if (t?.CariId is int cariId && cariler.Any(c => c.Id == cariId))
        {
            seciliCariId = cariId;
        }
        else
        {
            ToastService.ShowWarning("Seçilen tedarikçinin cari kaydı tanımlı değil.");
        }
    }

    private async Task LoadTedarikciHakedisleriAsync(int cariId)
    {
        tedarikciHakedisleri = new();
        if (cariId == 0) return;

        try
        {
            var cari = cariler.FirstOrDefault(c => c.Id == cariId);
            if (cari?.FirmaId is null) return;

            var tumOdemeler = new List<BudgetOdeme>();
            for (int yil = baslangicTarihi.Year; yil <= bitisTarihi.Year; yil++)
            {
                var yilOdemeleri = await BudgetService.GetOdemelerAsync(yil, null, cari.FirmaId);
                tumOdemeler.AddRange(yilOdemeleri);
            }

            tedarikciHakedisleri = tumOdemeler
                .Where(o => string.Equals(o.MasrafKalemi, TasimaTedarikciHakedisKalemi, StringComparison.OrdinalIgnoreCase))
                .Where(o => o.OdemeTarihi.Date >= baslangicTarihi.Date && o.OdemeTarihi.Date <= bitisTarihi.Date)
                .ToList();
        }
        catch
        {
            tedarikciHakedisleri = new();
        }
    }

    private void OdemeyeGit(int odemeId)
    {
        Navigation.NavigateTo($"/butce/odemeler?odemeId={odemeId}");
    }

    private async Task MutabakatOlustur()
    {
        if (seciliCariId == 0)
        {
            ToastService.ShowWarning("Lütfen bir cari seçin");
            return;
        }

        try
        {
            var cari = cariler.FirstOrDefault(c => c.Id == seciliCariId);
            if (cari == null) return;

            // Cari hesap kodunu bul (120.xxx formatında)
            var hesapKodu = $"120.{cari.CariKodu}";
            
            // Muavin raporu al
            var muavin = await MuhasebeService.GetMuavinRaporuAsync(hesapKodu, baslangicTarihi, bitisTarihi);

            mutabakatRapor = new MutabakatRapor
            {
                CariId = cari.Id,
                CariKodu = cari.CariKodu,
                CariUnvan = cari.Unvan,
                VergiNo = cari.VergiNo ?? "",
                BaslangicTarihi = baslangicTarihi,
                BitisTarihi = bitisTarihi,
                DonemBasiBakiye = muavin.DevirBorc - muavin.DevirAlacak,
                ToplamBorc = muavin.ToplamBorc,
                ToplamAlacak = muavin.ToplamAlacak,
                DonemSonuBakiye = muavin.Bakiye,
                Hareketler = muavin.Satirlar.Select(s => new MutabakatHareket
                {
                    Tarih = s.Tarih,
                    BelgeNo = s.FisNo,
                    Aciklama = s.Aciklama,
                    Borc = s.Borc,
                    Alacak = s.Alacak,
                    Bakiye = s.Bakiye
                }).ToList()
            };

            ToastService.ShowSuccess("Mutabakat raporu oluşturuldu");
            await LoadTedarikciHakedisleriAsync(seciliCariId);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Mutabakat oluşturulurken hata: " + ex.Message);
        }
    }

    private async Task ExcelIndir()
    {
        if (mutabakatRapor == null)
        {
            ToastService.ShowWarning("Önce mutabakat oluşturun");
            return;
        }

        try
        {
            var headers = new[] { "Tarih", "Belge No", "Açıklama", "Borç", "Alacak", "Bakiye" };
            var rows = new List<object[]>
            {
                new object[] { mutabakatRapor.BaslangicTarihi.AddDays(-1).ToString("dd.MM.yyyy"), "", "DEVİR", 0m, 0m, mutabakatRapor.DonemBasiBakiye }
            };
            rows.AddRange(mutabakatRapor.Hareketler.Select(h => new object[]
            {
                h.Tarih.ToString("dd.MM.yyyy"),
                h.BelgeNo,
                h.Aciklama,
                h.Borc,
                h.Alacak,
                h.Bakiye
            }));
            rows.Add(new object[] { "", "", "TOPLAM", mutabakatRapor.ToplamBorc, mutabakatRapor.ToplamAlacak, mutabakatRapor.DonemSonuBakiye });

            var sheetName = $"Mutabakat_{mutabakatRapor.CariKodu}";
            var bytes = ExcelService.CreateExcel(headers, rows, sheetName.Length > 31 ? sheetName[..31] : sheetName);
            var fileName = $"Mutabakat_{mutabakatRapor.CariKodu}_{mutabakatRapor.BaslangicTarihi:yyyyMMdd}_{mutabakatRapor.BitisTarihi:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(bytes),
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            ToastService.ShowSuccess("Excel indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Excel oluşturulamadı: " + ex.Message);
        }
    }

    private async Task PdfIndir()
    {
        if (mutabakatRapor == null)
        {
            ToastService.ShowWarning("Önce mutabakat oluşturun");
            return;
        }

        try
        {
            var model = new MutabakatPdfModel
            {
                CariKodu = mutabakatRapor.CariKodu,
                CariUnvan = mutabakatRapor.CariUnvan,
                VergiNo = mutabakatRapor.VergiNo,
                BaslangicTarihi = mutabakatRapor.BaslangicTarihi,
                BitisTarihi = mutabakatRapor.BitisTarihi,
                DonemBasiBakiye = mutabakatRapor.DonemBasiBakiye,
                ToplamBorc = mutabakatRapor.ToplamBorc,
                ToplamAlacak = mutabakatRapor.ToplamAlacak,
                DonemSonuBakiye = mutabakatRapor.DonemSonuBakiye,
                Hareketler = mutabakatRapor.Hareketler.Select(h => new MutabakatPdfHareket
                {
                    Tarih = h.Tarih,
                    BelgeNo = h.BelgeNo,
                    Aciklama = h.Aciklama,
                    Borc = h.Borc,
                    Alacak = h.Alacak,
                    Bakiye = h.Bakiye
                }).ToList()
            };

            var bytes = PdfService.GenerateMutabakatPdf(model);
            var fileName = $"Mutabakat_{mutabakatRapor.CariKodu}_{mutabakatRapor.BaslangicTarihi:yyyyMMdd}_{mutabakatRapor.BitisTarihi:yyyyMMdd}.pdf";
            await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(bytes), "application/pdf");
            ToastService.ShowSuccess("PDF indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("PDF oluşturulamadı: " + ex.Message);
        }
    }

    private async Task EmailGonder()
    {
        if (mutabakatRapor == null) return;
        
        var cari = cariler.FirstOrDefault(c => c.Id == seciliCariId);
        if (cari?.Email == null)
        {
            ToastService.ShowWarning("Carinin email adresi tanımlı değil");
            return;
        }

        ToastService.ShowInfo($"Mutabakat emaili gönderiliyor: {cari.Email}");
        // Email gönderme implementasyonu
        await Task.CompletedTask;
    }

    private string FormatPara(decimal tutar) => tutar.ToString("N2") + " ₺";

    // DTO Sınıfları
    private class MutabakatRapor
    {
        public int CariId { get; set; }
        public string CariKodu { get; set; } = "";
        public string CariUnvan { get; set; } = "";
        public string VergiNo { get; set; } = "";
        public DateTime BaslangicTarihi { get; set; }
        public DateTime BitisTarihi { get; set; }
        public decimal DonemBasiBakiye { get; set; }
        public decimal ToplamBorc { get; set; }
        public decimal ToplamAlacak { get; set; }
        public decimal DonemSonuBakiye { get; set; }
        public List<MutabakatHareket> Hareketler { get; set; } = new();
    }

    private class MutabakatHareket
    {
        public DateTime Tarih { get; set; }
        public string BelgeNo { get; set; } = "";
        public string Aciklama { get; set; } = "";
        public DateTime? VadeTarihi { get; set; }
        public decimal Borc { get; set; }
        public decimal Alacak { get; set; }
        public decimal Bakiye { get; set; }
    }
}

