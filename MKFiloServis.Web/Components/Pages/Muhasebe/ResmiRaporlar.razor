@page "/muhasebe/resmi-raporlar"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMuhasebeService MuhasebeService
@inject ICariService CariService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Resmi Raporlar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-journal-richtext me-2"></i>Resmi Raporlar</h3>
        <a href="/muhasebe/raporlar" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Muhasebe Raporlarına Dön
        </a>
    </div>

    <!-- Dönem Seçimi -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-calendar3 me-2"></i>Dönem Seçimi
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Yıl</label>
                    <select class="form-select" @bind="seciliYil">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ay</label>
                    <select class="form-select" @bind="seciliAy">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary" @onclick="DonemYukle">
                        <i class="bi bi-search me-1"></i>Dönemi Yükle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100 border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-person-vcard me-2"></i>İşe Giriş / Çıkış Bildirge</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Personel işe başlama ve işten ayrılma kayıtlarını SGK bildirge hazırlığı için listeleyin.</p>
                    <ul class="small text-muted mb-0 ps-3">
                        <li>Tarih aralığına göre giriş / çıkış listesi</li>
                        <li>Görev bazlı filtreleme</li>
                        <li>Excel çıktısı</li>
                    </ul>
                </div>
                <div class="card-footer">
                    <a href="/muhasebe/resmi-raporlar/ise-giris-cikis" class="btn btn-danger w-100">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Raporu Aç
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-calendar2-week me-2"></i>Yıllık İzin Takip</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Personel bazında yıllık hak, devreden, kullanılan ve kalan izin günlerini raporlayın.</p>
                    <ul class="small text-muted mb-0 ps-3">
                        <li>Yıl bazlı izin hakkı özeti</li>
                        <li>Kritik kalan izin takibi</li>
                        <li>İzin geçmişi detay görünümü</li>
                    </ul>
                </div>
                <div class="card-footer">
                    <a href="/muhasebe/resmi-raporlar/yillik-izin" class="btn btn-success w-100">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Raporu Aç
                    </a>
                </div>
            </div>
        </div>

        <!-- e-Defter XML Export -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-code me-2"></i>e-Defter XML</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">GİB formatına uygun e-Defter XML dosyası oluşturur.</p>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="eDefterYevmiye" id="eDefterYevmiye">
                            <label class="form-check-label" for="eDefterYevmiye">
                                <i class="bi bi-journal-text text-primary me-1"></i>Yevmiye Defteri
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="eDefterKebir" id="eDefterKebir">
                            <label class="form-check-label" for="eDefterKebir">
                                <i class="bi bi-journal-bookmark text-info me-1"></i>Defteri Kebir
                            </label>
                        </div>
                    </div>

                    @if (eDefterOzet != null)
                    {
                        <div class="alert alert-info">
                            <div class="row text-center">
                                <div class="col-4">
                                    <small>Fiş Sayısı</small>
                                    <h5>@eDefterOzet.FisSayisi</h5>
                                </div>
                                <div class="col-4">
                                    <small>Toplam Borç</small>
                                    <h5>@FormatPara(eDefterOzet.ToplamBorc)</h5>
                                </div>
                                <div class="col-4">
                                    <small>Toplam Alacak</small>
                                    <h5>@FormatPara(eDefterOzet.ToplamAlacak)</h5>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn btn-success w-100" @onclick="EDefterOlustur" disabled="@(!eDefterYevmiye && !eDefterKebir)">
                        <i class="bi bi-download me-1"></i>XML İndir
                    </button>
                </div>
            </div>
        </div>

        <!-- BA-BS Formları -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-spreadsheet me-2"></i>BA-BS Formları</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Mal/Hizmet alım ve satımlarına ilişkin bildirim formları.</p>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="baBS" value="BA" @onchange="SetBaBsSecim" checked="@(baBsSecim == "BA")" id="baForm">
                            <label class="form-check-label" for="baForm">
                                <span class="badge bg-danger me-1">BA</span>Mal/Hizmet Alımları
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="baBS" value="BS" @onchange="SetBaBsSecim" checked="@(baBsSecim == "BS")" id="bsForm">
                            <label class="form-check-label" for="bsForm">
                                <span class="badge bg-success me-1">BS</span>Mal/Hizmet Satışları
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Minimum Tutar (TL)</label>
                        <input type="number" class="form-control" @bind="baBsMinTutar" placeholder="5000">
                        <small class="text-muted">GİB limiti: 5.000 TL ve üzeri işlemler</small>
                    </div>

                    @if (baBsOzet != null)
                    {
                        <div class="alert alert-warning">
                            <div class="row text-center">
                                <div class="col-6">
                                    <small>Mükellef Sayısı</small>
                                    <h5>@baBsOzet.MukellefSayisi</h5>
                                </div>
                                <div class="col-6">
                                    <small>Toplam Tutar</small>
                                    <h5>@FormatPara(baBsOzet.ToplamTutar)</h5>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <div class="btn-group w-100">
                        <button class="btn btn-warning" @onclick="BaBsHesapla">
                            <i class="bi bi-calculator me-1"></i>Hesapla
                        </button>
                        <button class="btn btn-outline-warning" @onclick="BaBsExcelIndir" disabled="@(baBsOzet == null)">
                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- KDV Beyanname Özeti -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-percent me-2"></i>KDV Beyanname Özeti</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Aylık KDV beyanname hesaplama özeti.</p>

                    @if (kdvOzet != null)
                    {
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td>Hesaplanan KDV</td>
                                    <td class="text-end fw-bold text-primary">@FormatPara(kdvOzet.HesaplananKdv)</td>
                                </tr>
                                <tr>
                                    <td>İndirilecek KDV</td>
                                    <td class="text-end fw-bold text-danger">@FormatPara(kdvOzet.IndirilecekKdv)</td>
                                </tr>
                                <tr>
                                    <td>Tevkifat KDV</td>
                                    <td class="text-end">@FormatPara(kdvOzet.TevkifatKdv)</td>
                                </tr>
                                <tr class="table-active">
                                    <td><strong>Ödenecek/Devreden KDV</strong></td>
                                    <td class="text-end fw-bold @(kdvOzet.OdenecekKdv >= 0 ? "text-danger" : "text-success")">
                                        @FormatPara(kdvOzet.OdenecekKdv)
                                        @if (kdvOzet.OdenecekKdv < 0)
                                        {
                                            <small class="text-muted">(Devreden)</small>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <h6 class="mt-3">KDV Oranlarına Göre Dağılım</h6>
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Oran</th>
                                    <th class="text-end">Matrah</th>
                                    <th class="text-end">KDV</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detay in kdvOzet.OranDetaylari)
                                {
                                    <tr>
                                        <td>%@detay.Oran</td>
                                        <td class="text-end">@FormatPara(detay.Matrah)</td>
                                        <td class="text-end">@FormatPara(detay.Kdv)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-info-circle fs-1"></i>
                            <p class="mt-2">Dönemi yükleyerek KDV özetini görüntüleyin</p>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn btn-info w-100" @onclick="KdvDetayGoster" disabled="@(kdvOzet == null)">
                        <i class="bi bi-eye me-1"></i>Detaylı Görüntüle
                    </button>
                </div>
            </div>
        </div>

        <!-- Yıllık KDV Özeti -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-calendar-range me-2"></i>Yıllık KDV Özeti (@seciliYil)</h5>
                </div>
                <div class="card-body">
                    @if (yillikKdvOzeti != null && yillikKdvOzeti.Any())
                    {
                        <div class="table-responsive" style="max-height: 300px;">
                            <table class="table table-sm table-striped">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th>Ay</th>
                                        <th class="text-end">Hesaplanan</th>
                                        <th class="text-end">İndirilecek</th>
                                        <th class="text-end">Ödenecek/Devreden</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ay in yillikKdvOzeti)
                                    {
                                        <tr>
                                            <td>@GetAyAdi(ay.Ay)</td>
                                            <td class="text-end">@FormatPara(ay.HesaplananKdv)</td>
                                            <td class="text-end">@FormatPara(ay.IndirilecekKdv)</td>
                                            <td class="text-end @(ay.OdenecekKdv >= 0 ? "text-danger" : "text-success")">
                                                @FormatPara(ay.OdenecekKdv)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-warning fw-bold">
                                    <tr>
                                        <td>TOPLAM</td>
                                        <td class="text-end">@FormatPara(yillikKdvOzeti.Sum(x => x.HesaplananKdv))</td>
                                        <td class="text-end">@FormatPara(yillikKdvOzeti.Sum(x => x.IndirilecekKdv))</td>
                                        <td class="text-end">@FormatPara(yillikKdvOzeti.Sum(x => x.OdenecekKdv))</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-bar-chart fs-1"></i>
                            <p class="mt-2">Yıllık KDV özeti için dönemi yükleyin</p>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn btn-dark w-100" @onclick="YillikKdvExcelIndir" disabled="@(yillikKdvOzeti == null || !yillikKdvOzeti.Any())">
                        <i class="bi bi-file-earmark-excel me-1"></i>Excel İndir
                    </button>
                </div>
            </div>
        </div>

        <!-- Damga Vergisi -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-stamp me-2"></i>Damga Vergisi Listesi</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Dönem içinde düzenlenen belgelerin damga vergisi hesaplaması.</p>
                    
                    @if (damgaVergisiOzet != null)
                    {
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td>Sözleşme Damga Vergisi</td>
                                    <td class="text-end">@FormatPara(damgaVergisiOzet.SozlesmeDV)</td>
                                </tr>
                                <tr>
                                    <td>Fatura Damga Vergisi</td>
                                    <td class="text-end">@FormatPara(damgaVergisiOzet.FaturaDV)</td>
                                </tr>
                                <tr>
                                    <td>Makbuz Damga Vergisi</td>
                                    <td class="text-end">@FormatPara(damgaVergisiOzet.MakbuzDV)</td>
                                </tr>
                                <tr class="table-secondary fw-bold">
                                    <td>TOPLAM</td>
                                    <td class="text-end">@FormatPara(damgaVergisiOzet.Toplam)</td>
                                </tr>
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-stamp fs-1"></i>
                            <p class="mt-2">Damga vergisi hesaplaması için dönemi yükleyin</p>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn btn-secondary w-100" @onclick="DamgaVergisiHesapla">
                        <i class="bi bi-calculator me-1"></i>Hesapla
                    </button>
                </div>
            </div>
        </div>

        <!-- Geçici Vergi -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-purple text-white" style="background-color: #6f42c1;">
                    <h5 class="mb-0"><i class="bi bi-calendar-check me-2"></i>Geçici Vergi Hesaplama</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Üç aylık dönemler için geçici vergi matrahı hesaplaması.</p>
                    
                    <div class="mb-3">
                        <label class="form-label">Dönem</label>
                        <select class="form-select" @bind="geciciVergiDonem">
                            <option value="1">1. Dönem (Ocak-Şubat-Mart)</option>
                            <option value="2">2. Dönem (Nisan-Mayıs-Haziran)</option>
                            <option value="3">3. Dönem (Temmuz-Ağustos-Eylül)</option>
                            <option value="4">4. Dönem (Ekim-Kasım-Aralık)</option>
                        </select>
                    </div>

                    @if (geciciVergiOzet != null)
                    {
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td>Toplam Gelir</td>
                                    <td class="text-end text-success">@FormatPara(geciciVergiOzet.ToplamGelir)</td>
                                </tr>
                                <tr>
                                    <td>Toplam Gider</td>
                                    <td class="text-end text-danger">@FormatPara(geciciVergiOzet.ToplamGider)</td>
                                </tr>
                                <tr class="table-active">
                                    <td><strong>Vergi Matrahı</strong></td>
                                    <td class="text-end fw-bold">@FormatPara(geciciVergiOzet.VergiMatrahi)</td>
                                </tr>
                                <tr>
                                    <td>Hesaplanan Vergi (%20)</td>
                                    <td class="text-end fw-bold text-primary">@FormatPara(geciciVergiOzet.HesaplananVergi)</td>
                                </tr>
                            </tbody>
                        </table>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn w-100" style="background-color: #6f42c1; color: white;" @onclick="GeciciVergiHesapla">
                        <i class="bi bi-calculator me-1"></i>Hesapla
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int seciliYil = DateTime.Today.Year;
    private int seciliAy = DateTime.Today.Month;

    // e-Defter
    private bool eDefterYevmiye = true;
    private bool eDefterKebir = true;
    private EDefterOzet? eDefterOzet;

    // BA-BS
    private string baBsSecim = "BA";
    private decimal baBsMinTutar = 5000;
    private BaBsOzet? baBsOzet;
    private List<BaBsKayit>? baBsKayitlar;

    // KDV
    private KdvBeyanOzet? kdvOzet;
    private List<KdvAylikOzet>? yillikKdvOzeti;

    // Damga Vergisi
    private DamgaVergisiOzet? damgaVergisiOzet;

    // Geçici Vergi
    private int geciciVergiDonem = (DateTime.Today.Month - 1) / 3 + 1;
    private GeciciVergiOzet? geciciVergiOzet;

    private void SetBaBsSecim(ChangeEventArgs e)
    {
        baBsSecim = e.Value?.ToString() ?? "BA";
    }

    protected override async Task OnInitializedAsync()
    {
        await DonemYukle();
    }

    private async Task DonemYukle()
    {
        try
        {
            // e-Defter özeti
            var fisler = await MuhasebeService.GetFislerAsync(seciliYil, seciliAy);
            eDefterOzet = new EDefterOzet
            {
                FisSayisi = fisler.Count,
                ToplamBorc = fisler.SelectMany(f => f.Kalemler).Sum(k => k.Borc),
                ToplamAlacak = fisler.SelectMany(f => f.Kalemler).Sum(k => k.Alacak)
            };

            // KDV özeti
            var kdvRapor = await MuhasebeService.GetKdvBeyanRaporuAsync(seciliYil, seciliAy);
            kdvOzet = new KdvBeyanOzet
            {
                HesaplananKdv = kdvRapor.HesaplananKdv,
                IndirilecekKdv = kdvRapor.IndirilecekKdv,
                TevkifatKdv = kdvRapor.TevkifatKdv,
                OdenecekKdv = kdvRapor.OdenecekKdv,
                OranDetaylari = kdvRapor.HesaplananKdvDetay.Select(d => new KdvOranDetay
                {
                    Oran = (int)d.KdvOrani,
                    Matrah = d.Matrah,
                    Kdv = d.KdvTutar
                }).ToList()
            };

            // Yıllık KDV özeti
            yillikKdvOzeti = await MuhasebeService.GetYillikKdvOzetiAsync(seciliYil);

            ToastService.ShowSuccess($"{seciliYil} {GetAyAdi(seciliAy)} dönemi yüklendi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Dönem yüklenirken hata: " + ex.Message);
        }
    }

    private async Task EDefterOlustur()
    {
        try
        {
            ToastService.ShowInfo("e-Defter XML hazırlanıyor...");

            var xml = await GenerateEDefterXmlAsync();
            var fileName = $"e-Defter_{seciliYil}_{seciliAy:D2}.xml";
            
            await JS.InvokeVoidAsync("downloadFile", fileName, "application/xml", xml);
            ToastService.ShowSuccess("e-Defter XML indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("e-Defter oluşturulurken hata: " + ex.Message);
        }
    }

    private async Task<string> GenerateEDefterXmlAsync()
    {
        var fisler = await MuhasebeService.GetFislerAsync(seciliYil, seciliAy);
        
        var xml = new System.Text.StringBuilder();
        xml.AppendLine("<?xml version=\"1.0\" encoding=\"UTF-8\"?>");
        xml.AppendLine("<edefter xmlns=\"http://www.gib.gov.tr/edefter\">");
        xml.AppendLine($"  <donem yil=\"{seciliYil}\" ay=\"{seciliAy}\" />");
        xml.AppendLine($"  <olusturmaTarihi>{DateTime.Now:yyyy-MM-ddTHH:mm:ss}</olusturmaTarihi>");

        if (eDefterYevmiye)
        {
            xml.AppendLine("  <yevmiyeDefteri>");
            int siraNo = 1;
            foreach (var fis in fisler.OrderBy(f => f.FisTarihi).ThenBy(f => f.FisNo))
            {
                xml.AppendLine($"    <yevmiyeMaddesi siraNo=\"{siraNo++}\">");
                xml.AppendLine($"      <tarih>{fis.FisTarihi:yyyy-MM-dd}</tarih>");
                xml.AppendLine($"      <fisNo>{fis.FisNo}</fisNo>");
                xml.AppendLine($"      <aciklama>{System.Security.SecurityElement.Escape(fis.Aciklama ?? "")}</aciklama>");
                xml.AppendLine("      <kalemler>");
                foreach (var kalem in fis.Kalemler)
                {
                    xml.AppendLine("        <kalem>");
                    xml.AppendLine($"          <hesapKodu>{kalem.Hesap?.HesapKodu}</hesapKodu>");
                    xml.AppendLine($"          <hesapAdi>{System.Security.SecurityElement.Escape(kalem.Hesap?.HesapAdi ?? "")}</hesapAdi>");
                    xml.AppendLine($"          <borc>{kalem.Borc:F2}</borc>");
                    xml.AppendLine($"          <alacak>{kalem.Alacak:F2}</alacak>");
                    xml.AppendLine("        </kalem>");
                }
                xml.AppendLine("      </kalemler>");
                xml.AppendLine("    </yevmiyeMaddesi>");
            }
            xml.AppendLine("  </yevmiyeDefteri>");
        }

        if (eDefterKebir)
        {
            xml.AppendLine("  <defteriKebir>");
            var hesaplar = await MuhasebeService.GetHesapPlaniAsync();
            foreach (var hesap in hesaplar.Where(h => !h.AltHesapVar))
            {
                var muavin = await MuhasebeService.GetMuavinRaporuAsync(
                    hesap.HesapKodu,
                    new DateTime(seciliYil, seciliAy, 1),
                    new DateTime(seciliYil, seciliAy, DateTime.DaysInMonth(seciliYil, seciliAy)));
                
                if (muavin.Satirlar.Any())
                {
                    xml.AppendLine($"    <hesap kodu=\"{hesap.HesapKodu}\" adi=\"{System.Security.SecurityElement.Escape(hesap.HesapAdi)}\">");
                    xml.AppendLine($"      <borc>{muavin.ToplamBorc:F2}</borc>");
                    xml.AppendLine($"      <alacak>{muavin.ToplamAlacak:F2}</alacak>");
                    xml.AppendLine($"      <bakiye>{muavin.Bakiye:F2}</bakiye>");
                    xml.AppendLine("    </hesap>");
                }
            }
            xml.AppendLine("  </defteriKebir>");
        }

        xml.AppendLine("</edefter>");
        return xml.ToString();
    }

    private async Task BaBsHesapla()
    {
        try
        {
            var baslangic = new DateTime(seciliYil, seciliAy, 1);
            var bitis = baslangic.AddMonths(1).AddDays(-1);
            
            // Faturaları al
            var faturalar = await GetFaturalarAsync(baslangic, bitis);
            
            // BA veya BS'e göre filtrele
            var filtreliFaturalar = baBsSecim == "BA" 
                ? faturalar.Where(f => f.FaturaTipi == FaturaTipi.AlisFaturasi || f.FaturaTipi == FaturaTipi.AlisIadeFaturasi)
                : faturalar.Where(f => f.FaturaTipi == FaturaTipi.SatisFaturasi || f.FaturaTipi == FaturaTipi.SatisIadeFaturasi);

            // Cariye göre grupla ve minimum tutarı aşanları al
            var gruplar = filtreliFaturalar
                .GroupBy(f => f.CariId)
                .Select(g => new BaBsKayit
                {
                    CariId = g.Key,
                    CariUnvan = g.First().Cari?.Unvan ?? "",
                    VergiNo = g.First().Cari?.VergiNo ?? "",
                    FaturaSayisi = g.Count(),
                    ToplamTutar = g.Sum(f => f.GenelToplam)
                })
                .Where(k => k.ToplamTutar >= baBsMinTutar)
                .OrderByDescending(k => k.ToplamTutar)
                .ToList();

            baBsKayitlar = gruplar;
            baBsOzet = new BaBsOzet
            {
                MukellefSayisi = gruplar.Count,
                ToplamTutar = gruplar.Sum(k => k.ToplamTutar)
            };

            ToastService.ShowSuccess($"{baBsSecim} formu hesaplandı: {gruplar.Count} mükellef");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("BA-BS hesaplanırken hata: " + ex.Message);
        }
    }

