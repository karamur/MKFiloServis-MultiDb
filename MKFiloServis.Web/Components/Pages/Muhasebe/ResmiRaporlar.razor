    private async Task GeciciVergiHesapla()
    {
        try
        {
            var baslangicAy = (geciciVergiDonem - 1) * 3 + 1;
            var bitisAy = geciciVergiDonem * 3;

            decimal toplamGelir = 0;
            decimal toplamGider = 0;

            for (int ay = baslangicAy; ay <= bitisAy; ay++)
            {
                var rapor = await MuhasebeService.GetGelirGiderRaporuAsync(seciliYil, ay);
                toplamGelir += rapor.ToplamGelir;
                toplamGider += rapor.ToplamGider;
            }

            var matrah = toplamGelir - toplamGider;
            
            geciciVergiOzet = new GeciciVergiOzet
            {
                ToplamGelir = toplamGelir,
                ToplamGider = toplamGider,
                VergiMatrahi = matrah > 0 ? matrah : 0,
                HesaplananVergi = matrah > 0 ? matrah * 0.20m : 0
            };

            ToastService.ShowSuccess($"{geciciVergiDonem}. dönem geçici vergi hesaplandı");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Geçici vergi hesaplanırken hata: " + ex.Message);
        }
    }

