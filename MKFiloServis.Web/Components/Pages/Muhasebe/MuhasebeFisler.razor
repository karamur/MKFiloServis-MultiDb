@page "/muhasebe/fisler"
@page "/muhasebe/fisler/yeni"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMuhasebeService MuhasebeService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Muhasebe Fisleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-receipt me-2"></i>Muhasebe Fisleri</h3>
            <small class="text-muted">Fişleri listeleyin, onaylayın ve yeni fiş oluşturun</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm" style="width: 120px;" @bind="secilenYil" @bind:after="LoadDataAsync">
                @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 5; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 140px;" @bind="secilenAy" @bind:after="LoadDataAsync">
                <option value="0">Tüm Aylar</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@GetAyAdi(m)</option>
                }
            </select>
            <div class="btn-group">
                <button class="btn btn-outline-secondary btn-sm" @onclick="YevmiyeYazdir" title="Yevmiye Yazdır" disabled="@(!fisler.Any())">
                    <i class="bi bi-printer"></i>
                </button>
                <button class="btn btn-outline-success btn-sm" @onclick="YevmiyeExcelExport" title="Excel Export" disabled="@(!fisler.Any())">
                    <i class="bi bi-file-earmark-excel"></i>
                </button>
            </div>
            <button class="btn btn-primary btn-sm" @onclick="YeniFisAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni Fiş
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="card bg-primary text-white"><div class="card-body py-2"><small>Fiş Sayısı</small><h5 class="mb-0">@fisler.Count</h5></div></div>
            </div>
            <div class="col-md-4">
                <div class="card bg-success text-white"><div class="card-body py-2"><small>Onaylı</small><h5 class="mb-0">@fisler.Count(f => f.Durum == FisDurum.Onaylandi)</h5></div></div>
            </div>
            <div class="col-md-4">
                <div class="card bg-warning text-dark"><div class="card-body py-2"><small>Taslak</small><h5 class="mb-0">@fisler.Count(f => f.Durum == FisDurum.Taslak)</h5></div></div>
            </div>
        </div>

        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Fiş No</th>
                            <th>Tip</th>
                            <th>Açıklama</th>
                            <th class="text-end">Borç</th>
                            <th class="text-end">Alacak</th>
                            <th>Durum</th>
                            <th class="text-center">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!fisler.Any())
                        {
                            <tr><td colspan="8" class="text-center text-muted py-4">Fiş bulunamadı.</td></tr>
                        }
                        @foreach (var fis in fisler)
                        {
                            <tr style="cursor: pointer;" @onclick="() => FisDetayAc(fis.Id)">
                                <td>@fis.FisTarihi.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td><strong>@fis.FisNo</strong></td>
                                <td>@GetFisTipAdi(fis.FisTipi)</td>
                                <td>@fis.Aciklama</td>
                                <td class="text-end">@FormatPara(fis.ToplamBorc)</td>
                                <td class="text-end">@FormatPara(fis.ToplamAlacak)</td>
                                <td><span class="badge @GetDurumBadge(fis.Durum)">@GetDurumAdi(fis.Durum)</span></td>
                                <td class="text-center">
                                    <button class="btn btn-outline-info btn-sm me-1" title="Detay" @onclick="() => FisDetayAc(fis.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (fis.Durum != FisDurum.Onaylandi)
                                    {
                                        <button class="btn btn-outline-primary btn-sm me-1" title="Düzenle" @onclick="() => FisDuzenle(fis.Id)" @onclick:stopPropagation="true">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                    @{
                                        var cariId = fis.Kalemler?.FirstOrDefault(k => k.CariId.HasValue)?.CariId;
                                    }
                                    @if (cariId.HasValue)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm me-1" title="Cari Ekstre" @onclick="() => CariEkstreAc(cariId.Value)" @onclick:stopPropagation="true">
                                            <i class="bi bi-file-text"></i>
                                        </button>
                                    }
                                    @if (fis.Durum != FisDurum.Onaylandi)
                                    {
                                        <button class="btn btn-outline-success btn-sm me-1" @onclick="() => FisOnayla(fis.Id)" @onclick:stopPropagation="true" title="Onayla">
                                            <i class="bi bi-check2-circle"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => FisSil(fis.Id)" @onclick:stopPropagation="true" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-warning btn-sm" @onclick="() => FisOnayGeriAl(fis.Id)" @onclick:stopPropagation="true" title="Onayı Geri Al">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showYeniFisModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,.5)">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(yeniFis.Id > 0 ? "Muhasebe Fişi Düzenle" : "Yeni Muhasebe Fişi")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fiş Tarihi</label>
                            <input type="date" class="form-control" @bind="yeniFis.FisTarihi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fiş Tipi</label>
                            <select class="form-select" @bind="yeniFis.FisTipi">
                                @foreach (var tip in Enum.GetValues<FisTipi>())
                                {
                                    <option value="@tip">@GetFisTipAdi(tip)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Açıklama / Belge</label>
                            <input type="text" class="form-control" @bind="yeniFis.Aciklama" placeholder="Fiş Geneli Açıklama..." />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Fiş No</label>
                            <input type="text" class="form-control bg-light" @bind="yeniFis.FisNo" readonly placeholder="Oto" />
                        </div>
                    </div>

                    <div class="table-responsive border border-secondary rounded" style="max-height: 400px;">
                        <table class="table table-sm table-bordered table-hover align-middle mb-0" style="font-size: 0.9rem;">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th width="50" class="text-center">#</th>
                                    <th width="150">Tarih</th>
                                    <th width="300">Hesap Kodu - Adı</th>
                                    <th>Satır Açıklaması</th>
                                    <th width="150" class="text-end">Borç (₺)</th>
                                    <th width="150" class="text-end">Alacak (₺)</th>
                                    <th width="60" class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kalem in yeniFis.Kalemler.OrderBy(k => k.SiraNo).ToList())
                                {
                                    <tr class="@(kalem.Borc > 0 ? "table-success bg-opacity-10" : kalem.Alacak > 0 ? "table-warning bg-opacity-10" : "")">
                                        <td class="text-center fw-bold text-muted border-end">@kalem.SiraNo</td>
                                        <td class="p-0 border-end">
                                            <input type="date" class="form-control form-control-sm border-0 shadow-none bg-transparent" @bind="kalem.Tarih" />
                                        </td>
                                        <td class="p-0 border-end">
                                            <select class="form-select form-select-sm border-0 shadow-none bg-transparent" @bind="kalem.HesapId">
                                                <option value="0">--- Hesap Seçiniz ---</option>
                                                @foreach (var hesap in hesaplar)
                                                {
                                                    <option value="@hesap.Id">@hesap.HesapKodu - @hesap.HesapAdi</option>
                                                }
                                            </select>
                                        </td>
                                        <td class="p-0 border-end">
                                            <input class="form-control form-control-sm border-0 shadow-none bg-transparent" @bind="kalem.Aciklama" placeholder="Detay..." />
                                        </td>
                                        <td class="p-0 border-end">
                                            <input type="number" step="0.01" class="form-control form-control-sm border-0 shadow-none bg-transparent text-end fw-bold" @bind="kalem.Borc" @onblur="() => BakiyeHesapla()" />
                                        </td>
                                        <td class="p-0 border-end">
                                            <input type="number" step="0.01" class="form-control form-control-sm border-0 shadow-none bg-transparent text-end fw-bold" @bind="kalem.Alacak" @onblur="() => BakiyeHesapla()" />
                                        </td>
                                        <td class="text-center p-1">
                                            <button class="btn btn-outline-danger btn-sm p-0 px-2" @onclick="() => KalemSil(kalem)" title="Satırı Sil"><i class="bi bi-x-lg"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3 p-3 bg-light border rounded">
                        <button class="btn btn-outline-primary" @onclick="KalemEkle"><i class="bi bi-plus-lg me-1"></i>Yeni Satır Ekle (F2)</button>
                        
                        @{
                            var tipBorcToplami = yeniFis.Kalemler.Sum(x => x.Borc);
                            var tipAlacakToplami = yeniFis.Kalemler.Sum(x => x.Alacak);
                            var bakiye = tipBorcToplami - tipAlacakToplami;
                        }
                        
                        <div class="d-flex gap-4 fs-5 text-end">
                            <div class="text-success"><small class="text-muted d-block" style="font-size: 0.7rem;">Toplam Borç</small><strong>@FormatPara(tipBorcToplami)</strong></div>
                            <div class="text-warning"><small class="text-muted d-block" style="font-size: 0.7rem;">Toplam Alacak</small><strong>@FormatPara(tipAlacakToplami)</strong></div>
                            <div class=@(bakiye == 0 ? "text-primary" : "text-danger")>
                                <small class="text-muted d-block" style="font-size: 0.7rem;">Bakiye Farkı</small>
                                <strong>@FormatPara(bakiye)</strong>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div>
                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Muhasebe fişini kaydetmek için Bakiye Farkının 0 olması gerekir.</small>
                    </div>
                    <div>
                        <button class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                        <button class="btn btn-success ms-2" @onclick="FisKaydet" disabled="@(isSaving || bakiye != 0)">
                            @if(isSaving) { <span class="spinner-border spinner-border-sm"></span> } 
                            <i class="bi bi-save me-1"></i>@(yeniFis.Id > 0 ? "Değişiklikleri Kaydet" : "Fişi Kaydet")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "editId")]
    public int? EditId { get; set; }

    private List<MuhasebeFis> fisler = new();
    private List<MuhasebeHesap> hesaplar = new();
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;
    private bool isLoading = true;
    private bool isSaving;
    private bool showYeniFisModal;
    private MuhasebeFis yeniFis = new();

    protected override async Task OnInitializedAsync()
    {
        hesaplar = await MuhasebeService.GetHesapPlaniAsync();
        await LoadDataAsync();
        if (Navigation.Uri.EndsWith("/muhasebe/fisler/yeni", StringComparison.OrdinalIgnoreCase))
        {
            YeniFisAc();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (EditId.HasValue && EditId.Value > 0 && !showYeniFisModal)
        {
            await FisDuzenle(EditId.Value);
        }
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            fisler = await MuhasebeService.GetFislerAsync(secilenYil, secilenAy > 0 ? secilenAy : null);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Fişler yüklenemedi: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void YeniFisAc()
    {
        yeniFis = new MuhasebeFis
        {
            Id = 0,
            FisTarihi = DateTime.Today,
            FisTipi = FisTipi.Mahsup,
            FisNo = string.Empty,
            Kalemler = new List<MuhasebeFisKalem>
            {
                new() { SiraNo = 1 },
                new() { SiraNo = 2 }
            }
        };
        showYeniFisModal = true;
    }

    private void FisDetayAc(int fisId)
    {
        Navigation.NavigateTo($"/muhasebe/fisler/{fisId}");
    }

    private async Task FisDuzenle(int fisId)
    {
        try
        {
            var fis = await MuhasebeService.GetFisByIdAsync(fisId);
            if (fis == null)
            {
                ToastService.ShowWarning("Fiş bulunamadı.");
                return;
            }

            yeniFis = new MuhasebeFis
            {
                Id = fis.Id,
                FisNo = fis.FisNo,
                FisTarihi = fis.FisTarihi.ToLocalTime(),
                FisTipi = fis.FisTipi,
                Aciklama = fis.Aciklama,
                Durum = fis.Durum,
                Kalemler = fis.Kalemler
                    .OrderBy(k => k.SiraNo)
                    .Select(k => new MuhasebeFisKalem
                    {
                        Id = k.Id,
                        FisId = k.FisId,
                        HesapId = k.HesapId,
                        SiraNo = k.SiraNo,
                        Borc = k.Borc,
                        Alacak = k.Alacak,
                        Tarih = k.Tarih?.ToLocalTime() ?? fis.FisTarihi.ToLocalTime(),
                        Aciklama = k.Aciklama,
                        CariId = k.CariId
                    })
                    .ToList()
            };

            if (!yeniFis.Kalemler.Any())
            {
                yeniFis.Kalemler = new List<MuhasebeFisKalem> { new() { SiraNo = 1 }, new() { SiraNo = 2 } };
            }

            showYeniFisModal = true;
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Fiş düzenleme açılırken hata: " + ex.Message);
        }
    }

    private async Task FisSil(int fisId)
    {
        var onay = await JS.InvokeAsync<bool>("confirm", "Bu fiş silinsin mi?");
        if (!onay)
            return;

        try
        {
            await MuhasebeService.DeleteFisAsync(fisId);
            ToastService.ShowSuccess("Fiş silindi.");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Silme hatası: " + ex.Message);
        }
    }

    private void CariEkstreAc(int cariId)
    {
        Navigation.NavigateTo($"/raporlar/cari-ekstre?cariId={cariId}");
    }

    private void KalemEkle() => yeniFis.Kalemler.Add(new MuhasebeFisKalem { SiraNo = yeniFis.Kalemler.Count + 1 });

    private void KalemSil(MuhasebeFisKalem kalem)
    {
        yeniFis.Kalemler.Remove(kalem);
        if (!yeniFis.Kalemler.Any())
            KalemEkle();
    }

    private async Task FisKaydet()
    {
        if (!yeniFis.Kalemler.Any(k => k.HesapId > 0))
        {
            ToastService.ShowWarning("En az bir hesap seçin.");
            return;
        }

        yeniFis.Kalemler = yeniFis.Kalemler
            .Where(k => k.HesapId > 0 && (k.Borc > 0 || k.Alacak > 0))
            .Select((k, i) => { k.SiraNo = i + 1; return k; })
            .ToList();

        if (!yeniFis.Kalemler.Any())
        {
            ToastService.ShowWarning("Borç veya alacak tutarı girin.");
            return;
        }

        isSaving = true;
        try
        {
            if (yeniFis.Id > 0)
            {
                await MuhasebeService.UpdateFisAsync(yeniFis);
                ToastService.ShowSuccess("Fiş güncellendi.");
            }
            else
            {
                yeniFis.FisNo = await MuhasebeService.GenerateNextFisNoAsync(yeniFis.FisTipi);
                await MuhasebeService.CreateFisAsync(yeniFis);
                ToastService.ShowSuccess("Fiş kaydedildi.");
            }
            ModalKapat();
            await LoadDataAsync();
            Navigation.NavigateTo("/muhasebe/fisler", false);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Kaydetme hatası: " + ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task FisOnayla(int fisId)
    {
        try
        {
            await MuhasebeService.OnayliFisAsync(fisId);
            ToastService.ShowSuccess("Fiş onaylandı.");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Onay hatası: " + ex.Message);
        }
    }

    private async Task FisOnayGeriAl(int fisId)
    {
        var onay = await JS.InvokeAsync<bool>("confirm", "Fişin onayı geri alınarak taslak durumuna çekilsin mi?");
        if (!onay)
            return;

        try
        {
            await MuhasebeService.OnayGeriAlFisAsync(fisId);
            ToastService.ShowSuccess("Fiş onayı geri alındı.");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Onay geri alma hatası: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showYeniFisModal = false;
        if (EditId.HasValue)
            Navigation.NavigateTo("/muhasebe/fisler", false);
        if (Navigation.Uri.EndsWith("/muhasebe/fisler/yeni", StringComparison.OrdinalIgnoreCase))
            Navigation.NavigateTo("/muhasebe/fisler", false);
    }

    private static string GetAyAdi(int ay) => new DateTime(2000, ay, 1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR"));
    private static string FormatPara(decimal value) => value.ToString("N2") + " TL";
    private static string GetDurumAdi(FisDurum durum) => durum switch { FisDurum.Taslak => "Taslak", FisDurum.Onaylandi => "Onaylı", FisDurum.IptalEdildi => "İptal", _ => durum.ToString() };
    private static string GetDurumBadge(FisDurum durum) => durum switch { FisDurum.Taslak => "bg-warning text-dark", FisDurum.Onaylandi => "bg-success", FisDurum.IptalEdildi => "bg-danger", _ => "bg-secondary" };
    private static string GetFisTipAdi(FisTipi tip) => tip switch { FisTipi.Mahsup => "Mahsup", FisTipi.Tahsilat => "Tahsilat", FisTipi.Tediye => "Tediye", FisTipi.Acilis => "Açılış", FisTipi.Kapanis => "Kapanış", FisTipi.Devir => "Devir", _ => tip.ToString() };

    private void BakiyeHesapla()
    {
        // Tetikleyici tetiklendiğinde StateHasChanged çalışır ve toplam bakiye yenilenir.
    }

    private void YevmiyeYazdir()
    {
        // Seçilen yıl ve aya göre tarih aralığı oluştur
        var baslangic = secilenAy > 0 
            ? new DateTime(secilenYil, secilenAy, 1) 
            : new DateTime(secilenYil, 1, 1);
        var bitis = secilenAy > 0 
            ? baslangic.AddMonths(1).AddDays(-1) 
            : new DateTime(secilenYil, 12, 31);

        Navigation.NavigateTo($"/muhasebe/raporlar/yevmiye?baslangic={baslangic:yyyy-MM-dd}&bitis={bitis:yyyy-MM-dd}&yazdir=true");
    }

    private async Task YevmiyeExcelExport()
    {
        try
        {
            var baslangic = secilenAy > 0 
                ? new DateTime(secilenYil, secilenAy, 1) 
                : new DateTime(secilenYil, 1, 1);
            var bitis = secilenAy > 0 
                ? baslangic.AddMonths(1).AddDays(-1) 
                : new DateTime(secilenYil, 12, 31);

            var excelBytes = await MuhasebeService.ExportYevmiyeToExcelAsync(baslangic, bitis);
            var fileName = secilenAy > 0 
                ? $"Yevmiye_{secilenYil}_{secilenAy:D2}.xlsx" 
                : $"Yevmiye_{secilenYil}.xlsx";

            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", excelBytes);
            ToastService.ShowSuccess("Yevmiye Excel dosyası indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Excel export hatası: " + ex.Message);
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "F2")
        {
            KalemEkle();
        }
    }
}

