@page "/masraf-kalemleri"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMasrafKalemiService MasrafKalemiService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Masraf Kalemleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-list-task me-2"></i>Masraf Kalemleri</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-warning" @onclick="DuplicateTemizleAsync">
                <i class="bi bi-filter-circle me-1"></i>Duplicate Temizle
            </button>
            <button class="btn btn-primary" @onclick="YeniKalem">
                <i class="bi bi-plus-lg me-1"></i>Yeni Masraf Kalemi
            </button>
        </div>
    </div>

    @if (kalemler == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!kalemler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz masraf kalemi bulunmamaktAdır.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Masraf Kodu</th>
                                <th>Masraf Adı</th>
                                <th>Kategori</th>
                                <th>Durum</th>
                                <th style="width: 120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kalem in kalemler)
                            {
                                <tr>
                                    <td><strong>@kalem.MasrafKodu</strong></td>
                                    <td>@kalem.MasrafAdi</td>
                                    <td>
                                        <span class="badge @GetKategoriBadgeClass(kalem.Kategori)">
                                            @GetKategoriText(kalem.Kategori)
                                        </span>
                                    </td>
                                    <td>
                                        @if (kalem.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pasif</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(kalem.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(kalem)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekKalem?.MasrafAdi</strong> masraf kalemini silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MasrafKalemi>? kalemler;
    private bool showDeleteModal = false;
    private MasrafKalemi? silinecekKalem;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        kalemler = await MasrafKalemiService.GetAllAsync();
    }

    private async Task DuplicateTemizleAsync()
    {
        var silinen = await MasrafKalemiService.DeleteDuplicatesAsync();
        if (silinen > 0)
        {
            await LoadData();
        }
    }

    private void YeniKalem()
    {
        Navigation.NavigateTo("/masraf-kalemleri/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/masraf-kalemleri/{id}");
    }

    private void SilOnay(MasrafKalemi kalem)
    {
        silinecekKalem = kalem;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekKalem != null)
        {
            await MasrafKalemiService.DeleteAsync(silinecekKalem.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekKalem = null;
    }

    private string GetKategoriText(MasrafKategori kategori) => kategori switch
    {
        MasrafKategori.Yakit => "Yakıt",
        MasrafKategori.Bakim => "Bakım",
        MasrafKategori.Tamir => "Tamir",
        MasrafKategori.Sigorta => "Sigorta",
        MasrafKategori.Vergi => "Vergi",
        MasrafKategori.Personel => "Personel Ulaşım",
        MasrafKategori.Lastik => "Lastik",
        MasrafKategori.YedekParca => "Yedek Parça",
        MasrafKategori.Diger => "Diğer",
        _ => kategori.ToString()
    };

    private string GetKategoriBadgeClass(MasrafKategori kategori) => kategori switch
    {
        MasrafKategori.Yakit => "bg-warning text-dark",
        MasrafKategori.Bakim => "bg-info",
        MasrafKategori.Tamir => "bg-danger",
        MasrafKategori.Sigorta => "bg-primary",
        MasrafKategori.Vergi => "bg-secondary",
        MasrafKategori.Personel => "bg-success",
        _ => "bg-secondary"
    };
}







