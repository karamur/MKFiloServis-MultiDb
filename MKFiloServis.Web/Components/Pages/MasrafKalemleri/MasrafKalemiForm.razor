@page "/masraf-kalemleri/yeni"
@page "/masraf-kalemleri/{Id:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IMasrafKalemiService MasrafKalemiService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Masraf Kalemi Düzenle" : "Yeni Masraf Kalemi")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-list-task me-2"></i>@(IsEdit ? "Masraf Kalemi Düzenle" : "Yeni Masraf Kalemi")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="kalem" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Masraf Kodu *</label>
                            <InputText @bind-Value="kalem.MasrafKodu" class="form-control" readonly="@IsEdit" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Masraf Adı *</label>
                            <InputText @bind-Value="kalem.MasrafAdi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Kategori *</label>
                            <InputSelect @bind-Value="kalem.Kategori" class="form-select">
                                @foreach (MasrafKategori kat in Enum.GetValues(typeof(MasrafKategori)))
                                {
                                    <option value="@kat">@GetKategoriText(kat)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <InputCheckbox @bind-Value="kalem.Aktif" class="form-check-input" id="aktif" />
                        <label class="form-check-label" for="aktif">Aktif</label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notlar</label>
                    <InputTextArea @bind-Value="kalem.Notlar" class="form-control" rows="2" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private MasrafKalemi kalem = new();
    private bool IsEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var existing = await MasrafKalemiService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                kalem = existing;
            }
            else
            {
                Navigation.NavigateTo("/masraf-kalemleri");
            }
        }
        else
        {
            kalem.MasrafKodu = await MasrafKalemiService.GenerateNextKodAsync();
            kalem.Aktif = true;
            kalem.Kategori = MasrafKategori.Diger;
        }
    }

    private async Task Kaydet()
    {
        if (string.IsNullOrWhiteSpace(kalem.MasrafAdi))
            return;

        if (IsEdit)
        {
            await MasrafKalemiService.UpdateAsync(kalem);
        }
        else
        {
            await MasrafKalemiService.CreateAsync(kalem);
        }
        Navigation.NavigateTo("/masraf-kalemleri");
    }

    private void Geri()
    {
        Navigation.NavigateTo("/masraf-kalemleri");
    }

    private string GetKategoriText(MasrafKategori kategori) => kategori switch
    {
        MasrafKategori.Yakit => "Yakıt",
        MasrafKategori.Bakim => "Bakım",
        MasrafKategori.Tamir => "Tamir",
        MasrafKategori.Sigorta => "Sigorta",
        MasrafKategori.Vergi => "Vergi",
        MasrafKategori.Personel => "Personel Ulaşım",
        MasrafKategori.Lastik => "Lastik",
        MasrafKategori.YedekParca => "Yedek Parça",
        MasrafKategori.Diger => "Diğer",
        _ => kategori.ToString()
    };
}







