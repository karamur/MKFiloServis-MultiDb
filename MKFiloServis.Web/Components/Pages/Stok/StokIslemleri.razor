@page "/stok/islemler"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@inject IStokService StokService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Stok İşlemleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-sliders me-2"></i>Stok İşlemleri</h3>
        <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/stok")'>
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item"><button class="nav-link @(aktifTab=="operasyon"?"active":"")" @onclick='() => aktifTab="operasyon"'>Sayım / Fire / Zarar</button></li>
        <li class="nav-item"><button class="nav-link @(aktifTab=="uretim"?"active":"")" @onclick='() => aktifTab="uretim"'>Üretim Reçetesi</button></li>
    </ul>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (aktifTab == "operasyon")
    {
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Stok Kartı</label>
                        <select class="form-select" @bind="operasyon.StokKartiId" @bind:after="SeciliStokDegistiAsync">
                            <option value="0">Seçiniz</option>
                            @foreach (var stok in stokKartlari)
                            {
                                <option value="@stok.Id">@stok.StokKodu - @stok.StokAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">İşlem Tipi</label>
                        <select class="form-select" @bind="operasyon.HareketTipi">
                            <option value="@StokHareketTipi.SayimFazlasi">Stok Sayım / Fazla</option>
                            <option value="@StokHareketTipi.SayimNoksani">Stok Sayım / Noksan</option>
                            <option value="@StokHareketTipi.FireZayiat">Fire</option>
                            <option value="@StokHareketTipi.StokZarari">Stok Zararı</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Tarih</label>
                        <input type="date" class="form-control" @bind="operasyon.IslemTarihi" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Mevcut Stok</label>
                        <input type="text" class="form-control bg-light" value="@mevcutStok.ToString("N2")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Miktar / Sayım Sonucu</label>
                        <input type="number" step="0.01" class="form-control" @bind="operasyon.Miktar" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Birim Fiyat</label>
                        <input type="number" step="0.01" class="form-control" @bind="operasyon.BirimFiyat" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Belge No</label>
                        <input type="text" class="form-control" @bind="operasyon.BelgeNo" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" rows="2" @bind="operasyon.Aciklama"></textarea>
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary" @onclick="OperasyonKaydet" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-save me-1"></i>Kaydet ve Muhasebeleştir
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Mamul Stok Kartı</label>
                        <select class="form-select" @bind="recete.MamulStokKartiId">
                            <option value="0">Seçiniz</option>
                            @foreach (var stok in stokKartlari)
                            {
                                <option value="@stok.Id">@stok.StokKodu - @stok.StokAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Mamul Miktarı</label>
                        <input type="number" step="0.01" class="form-control" @bind="recete.MamulMiktari" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Mamul Birim Maliyeti</label>
                        <input type="number" step="0.01" class="form-control" @bind="recete.MamulBirimMaliyeti" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Belge No</label>
                        <input type="text" class="form-control" @bind="recete.BelgeNo" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Açıklama</label>
                        <input type="text" class="form-control" @bind="recete.Aciklama" />
                    </div>
                </div>

                <div class="table-responsive border rounded">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Bileşen Stok</th>
                                <th>Miktar</th>
                                <th>Birim Fiyat</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kalem in recete.Kalemler)
                            {
                                <tr>
                                    <td>
                                        <select class="form-select form-select-sm" @bind="kalem.StokKartiId">
                                            <option value="0">Seçiniz</option>
                                            @foreach (var stok in stokKartlari)
                                            {
                                                <option value="@stok.Id">@stok.StokKodu - @stok.StokAdi</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="kalem.Miktar" /></td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="kalem.BirimFiyat" /></td>
                                    <td class="text-center"><button class="btn btn-outline-danger btn-sm" @onclick="() => KalemSil(kalem)"><i class="bi bi-trash"></i></button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-outline-primary" @onclick="KalemEkle"><i class="bi bi-plus-lg me-1"></i>Bileşen Ekle</button>
                    <button class="btn btn-success" @onclick="ReceteKaydet" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-gear-wide-connected me-1"></i>Üretimi Kaydet ve Muhasebeleştir
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<StokKarti> stokKartlari = new();
    private bool isLoading = true;
    private bool isSaving;
    private string aktifTab = "operasyon";
    private decimal mevcutStok;

    private StokOperasyonModel operasyon = new()
    {
        IslemTarihi = DateTime.Today,
        HareketTipi = StokHareketTipi.SayimFazlasi
    };

    private UretimReceteModel recete = new()
    {
        IslemTarihi = DateTime.Today,
        MamulMiktari = 1,
        Kalemler = new() { new UretimReceteKalemModel() }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stokKartlari = await StokService.GetStokKartlariAsync(aktif: true);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veriler yüklenemedi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SeciliStokDegistiAsync()
    {
        mevcutStok = 0;
        if (operasyon.StokKartiId <= 0)
            return;

        mevcutStok = await StokService.GetMevcutStokAsync(operasyon.StokKartiId);
        var stok = stokKartlari.FirstOrDefault(s => s.Id == operasyon.StokKartiId);
        if (stok != null && operasyon.BirimFiyat <= 0)
            operasyon.BirimFiyat = stok.AlisFiyati;
    }

    private async Task OperasyonKaydet()
    {
        try
        {
            isSaving = true;
            await StokService.CreateStokOperasyonAsync(operasyon);
            ToastService.ShowSuccess("Stok işlemi ve muhasebe fişi oluşturuldu.");
            operasyon = new StokOperasyonModel { IslemTarihi = DateTime.Today, HareketTipi = StokHareketTipi.SayimFazlasi };
            mevcutStok = 0;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt hatası: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void KalemEkle() => recete.Kalemler.Add(new MKFiloServis.Web.Models.UretimReceteKalemModel());

    private void KalemSil(MKFiloServis.Web.Models.UretimReceteKalemModel kalem)
    {
        recete.Kalemler.Remove(kalem);
        if (!recete.Kalemler.Any())
            recete.Kalemler.Add(new MKFiloServis.Web.Models.UretimReceteKalemModel());
    }

    private async Task ReceteKaydet()
    {
        try
        {
            isSaving = true;
            recete.Kalemler = recete.Kalemler.Where(k => k.StokKartiId > 0 && k.Miktar > 0).ToList();
            await StokService.CreateUretimRecetesiAsync(recete);
            ToastService.ShowSuccess("Üretim reçetesi ve muhasebe fişi oluşturuldu.");
            recete = new UretimReceteModel { IslemTarihi = DateTime.Today, MamulMiktari = 1, Kalemler = new() { new UretimReceteKalemModel() } };
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Üretim kayıt hatası: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }
}

