@page "/stok"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IStokService StokService
@inject NavigationManager Navigation
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Stok/Envanter Yönetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-box-seam me-2"></i>Stok/Envanter Yönetimi
        </h3>
        <div>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/stok/kartlar")'>
                <i class="bi bi-list-ul me-1"></i>Stok Kartları
            </button>
            <button class="btn btn-outline-primary ms-2" @onclick='() => Navigation.NavigateTo("/stok/islemler")'>
                <i class="bi bi-sliders me-1"></i>Stok İşlemleri
            </button>
            <button class="btn btn-success ms-2" @onclick='() => Navigation.NavigateTo("/stok/arac-islem")'>
                <i class="bi bi-truck me-1"></i>Araç Alış/Satış
            </button>
            <button class="btn btn-info ms-2" @onclick='() => Navigation.NavigateTo("/stok/servis")'>
                <i class="bi bi-tools me-1"></i>Servis Kayıtları
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Özet Kartlar -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title">Toplam Stok Kartı</h6>
                                <h2>@dashboard.ToplamStokKarti</h2>
                                <small>Aktif: @dashboard.AktifStokKarti</small>
                            </div>
                            <i class="bi bi-box-seam" style="font-size: 3rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title">Düşük Stoklu</h6>
                                <h2>@dashboard.DusukStoklu</h2>
                                <small>Kritik seviye altı</small>
                            </div>
                            <i class="bi bi-exclamation-triangle" style="font-size: 3rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title">Stok Değeri</h6>
                                <h2>@dashboard.ToplamStokDegeri.ToString("N0") ₺</h2>
                                <small>Toplam envanter değeri</small>
                            </div>
                            <i class="bi bi-currency-exchange" style="font-size: 3rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card bg-info text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title">Bu Ay Servis</h6>
                                <h2>@dashboard.AylikServisKaydi</h2>
                                <small>@dashboard.AylikServisTutari.ToString("N0") ₺</small>
                            </div>
                            <i class="bi bi-tools" style="font-size: 3rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Araç Alış/Satış Özeti -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-truck me-2"></i>Bu Ay Araç Hareketleri</span>
                        <button class="btn btn-sm btn-outline-primary" @onclick='() => Navigation.NavigateTo("/stok/arac-islem")'>
                            Tümü
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="p-3 bg-success bg-opacity-10 rounded">
                                    <i class="bi bi-arrow-down-circle text-success" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0 text-success">@dashboard.AylikAracAlis</h4>
                                    <small class="text-muted">Araç Alış</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-danger bg-opacity-10 rounded">
                                    <i class="bi bi-arrow-up-circle text-danger" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0 text-danger">@dashboard.AylikAracSatis</h4>
                                    <small class="text-muted">Araç Satış</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-tools me-2"></i>Son Servis Kayıtları</span>
                        <button class="btn btn-sm btn-outline-primary" @onclick='() => Navigation.NavigateTo("/stok/servis")'>
                            Tümü
                        </button>
                    </div>
                    <div class="card-body p-0">
                        @if (dashboard.SonServisler?.Any() == true)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Araç</th>
                                            <th>Servis</th>
                                            <th class="text-end">Tutar</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var servis in dashboard.SonServisler.Take(5))
                                        {
                                            <tr>
                                                <td>@servis.ServisTarihi.ToString("dd.MM.yyyy")</td>
                                                <td>@servis.Arac?.AktifPlaka</td>
                                                <td>@servis.ServisAdi</td>
                                                <td class="text-end">@servis.ToplamTutar.ToString("N2") ₺</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted p-4">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-2">Henüz servis kaydı yok</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Son Stok Hareketleri -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-arrow-left-right me-2"></i>Son Stok Hareketleri</span>
                <button class="btn btn-sm btn-outline-primary" @onclick='() => Navigation.NavigateTo("/stok/hareketler")'>
                    Tümünü Gör
                </button>
            </div>
            <div class="card-body p-0">
                @if (dashboard.SonHareketler?.Any() == true)
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tarih</th>
                                    <th>Stok Kodu</th>
                                    <th>Stok Adı</th>
                                    <th>Hareket Tipi</th>
                                    <th class="text-end">Miktar</th>
                                    <th class="text-end">Birim Fiyat</th>
                                    <th class="text-end">Toplam</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hareket in dashboard.SonHareketler)
                                {
                                    var isGiris = hareket.Miktar > 0;
                                    <tr>
                                        <td>@hareket.IslemTarihi.ToString("dd.MM.yyyy")</td>
                                        <td><code>@hareket.StokKarti?.StokKodu</code></td>
                                        <td>@hareket.StokKarti?.StokAdi</td>
                                        <td>
                                            <span class="badge @(isGiris ? "bg-success" : "bg-danger")">
                                                @GetHareketTipiAdi(hareket.HareketTipi)
                                            </span>
                                        </td>
                                        <td class="text-end @(isGiris ? "text-success" : "text-danger")">
                                            @(isGiris ? "+" : "")@hareket.Miktar.ToString("N2")
                                        </td>
                                        <td class="text-end">@hareket.BirimFiyat.ToString("N2") ₺</td>
                                        <td class="text-end">@hareket.ToplamTutar.ToString("N2") ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">Henüz stok hareketi yok</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private MKFiloServis.Web.Models.StokDashboard dashboard = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            dashboard = await StokService.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetHareketTipiAdi(StokHareketTipi tip) => tip switch
    {
        StokHareketTipi.Giris => "Giriş",
        StokHareketTipi.Cikis => "Çıkış",
        StokHareketTipi.SatisIade => "Satış İade",
        StokHareketTipi.AlisIade => "Alış İade",
        StokHareketTipi.SayimFazlasi => "Sayım Fazlası",
        StokHareketTipi.SayimNoksani => "Sayım Noksanı",
        StokHareketTipi.FireZayiat => "Fire/Zayiat",
        StokHareketTipi.StokZarari => "Stok Zararı",
        StokHareketTipi.DepoTransferi => "Depo Transferi",
        StokHareketTipi.AracAlis => "Araç Alış",
        StokHareketTipi.AracSatis => "Araç Satış",
        StokHareketTipi.ServisGiris => "Servis Giriş",
        StokHareketTipi.UretimGiris => "Üretim Giriş",
        StokHareketTipi.UretimCikis => "Üretim Çıkış",
        _ => tip.ToString()
    };
}

