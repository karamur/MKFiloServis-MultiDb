@page "/kapasiteler"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IKapasiteService KapasiteService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Kapasiteler</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-layers me-2 text-primary"></i>Kapasiteler</h3>
        <button class="btn btn-primary" @onclick="YeniKapasite">
            <i class="bi bi-plus-lg me-1"></i>Yeni Kapasite
        </button>
    </div>

    @if (kapasiteler == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Kapasiteler yükleniyor...</p>
        </div>
    }
    else if (!kapasiteler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz kapasite kaydı bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Kapasite Adı</th>
                                <th>Açıklama</th>
                                <th>Çarpan</th>
                                <th>Durum</th>
                                <th class="text-center" style="width: 120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kapasite in kapasiteler)
                            {
                                <tr>
                                    <td class="fw-semibold">@kapasite.KapasiteAdi</td>
                                    <td>@kapasite.Aciklama</td>
                                    <td><span class="badge bg-info text-dark">@kapasite.Carpan.ToString("N2")</span></td>
                                    <td>
                                        @if (kapasite.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pasif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(kapasite.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(kapasite)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekKapasite?.KapasiteAdi</strong> kapasitesini silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Kapasite>? kapasiteler;
    private bool showDeleteModal;
    private Kapasite? silinecekKapasite;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        kapasiteler = await KapasiteService.GetAllAsync();
    }

    private void YeniKapasite() => Navigation.NavigateTo("/kapasiteler/yeni");

    private void Duzenle(int id) => Navigation.NavigateTo($"/kapasiteler/{id}");

    private void SilOnay(Kapasite kapasite)
    {
        silinecekKapasite = kapasite;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekKapasite != null)
        {
            await KapasiteService.DeleteAsync(silinecekKapasite.Id);
            await LoadData();
        }

        showDeleteModal = false;
        silinecekKapasite = null;
    }
}
