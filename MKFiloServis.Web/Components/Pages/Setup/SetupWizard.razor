@page "/setup"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IPasswordHasher<Kullanici> PasswordHasher
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject BrandingService BrandingService

<PageTitle>Kurulum - MK Filo Servis</PageTitle>

<div class="setup-container">
    <div class="setup-background">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <div class="setup-card">
        <!-- Header -->
        <div class="setup-header">
            <div class="logo-container logo-branding-preview">
                <img src="@setupIconSrc" alt="Amblem" class="setup-logo-icon" />
                <img src="@setupTextLogoSrc" alt="Yazı Logo" class="setup-logo-text" />
            </div>
            <h1>MK Filo Servis</h1>
            <p>İlk Kurulum Sihirbazı</p>
        </div>

        <!-- Adım Göstergesi -->
        <div class="setup-steps-bar">
            <div class="step-item @(aktifAdim >= 1 ? "active" : "") @(aktifAdim > 1 ? "completed" : "")">
                <div class="step-circle">
                    @if (aktifAdim > 1) { <i class="bi bi-check-lg"></i> } else { <span>1</span> }
                </div>
                <span class="step-label">Firma Bilgileri</span>
            </div>
            <div class="step-line @(aktifAdim > 1 ? "completed" : "")"></div>
            <div class="step-item @(aktifAdim >= 2 ? "active" : "") @(aktifAdim > 2 ? "completed" : "")">
                <div class="step-circle">
                    @if (aktifAdim > 2) { <i class="bi bi-check-lg"></i> } else { <span>2</span> }
                </div>
                <span class="step-label">Admin Kullanıcı</span>
            </div>
            <div class="step-line @(aktifAdim > 2 ? "completed" : "")"></div>
            <div class="step-item @(aktifAdim >= 3 ? "active" : "")">
                <div class="step-circle"><span>3</span></div>
                <span class="step-label">Tamamlandı</span>
            </div>
        </div>

        <!-- Hata / Bilgi Mesajı -->
        @if (!string.IsNullOrEmpty(hataMesaji))
        {
            <div class="alert alert-danger mt-3 mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@hataMesaji
            </div>
        }

        <!-- ADIM 1: FİRMA BİLGİLERİ -->
        @if (aktifAdim == 1)
        {
            <div class="setup-step-body">
                <h5 class="step-title"><i class="bi bi-building me-2"></i>Firma Bilgileri</h5>
                <p class="step-desc text-muted">Uygulamanızda kullanılacak firma bilgilerini girin.</p>

                <div class="mb-3">
                    <label class="form-label">Firma Adı <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" placeholder="Örn: ABC Lojistik A.Ş."
                           @bind="firmaAdi" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Vergi No</label>
                    <input type="text" class="form-control" placeholder="10 veya 11 hane"
                           @bind="firmaVergiNo" @bind:event="oninput" maxlength="11" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Vergi Dairesi</label>
                    <input type="text" class="form-control" placeholder="Örn: Kadıköy VD"
                           @bind="firmaVergiDairesi" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Telefon</label>
                    <input type="text" class="form-control" placeholder="+90 212 000 00 00"
                           @bind="firmaTelefon" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">E-posta</label>
                    <input type="email" class="form-control" placeholder="info@firma.com"
                           @bind="firmaEmail" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Adres</label>
                    <textarea class="form-control" rows="2" placeholder="Firma adresi..."
                              @bind="firmaAdres" @bind:event="oninput"></textarea>
                </div>

                <div class="card border-0 bg-light mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3"><i class="bi bi-images me-2"></i>Login ve uygulama markalama</h6>
                        <p class="text-muted small mb-3">Giriş ekranı ve menüde kullanılacak amblem ile yazı logosunu kullanıcıdan isteyip burada yükleyin. Yüklemezseniz varsayılan görseller kullanılır.</p>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Amblem / Sembol</label>
                                <InputFile OnChange="BrandingAmblemYukle" accept="image/*" class="form-control" />
                                <div class="form-text">PNG, JPG, SVG veya WebP. Maks 2 MB.</div>
                                <div class="mt-2 border rounded bg-white p-2 text-center" style="min-height:60px;">
                                    @if (HasBrandingPreview(brandingIconLogo))
                                    {
                                        <img src="@brandingIconLogo" alt="Amblem" style="max-height:80px;max-width:100%;object-fit:contain;" />
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Yazı Logosu</label>
                                <InputFile OnChange="BrandingYaziLogosuYukle" accept="image/*" class="form-control" />
                                <div class="form-text">Firma adı veya yatay logo görseli yükleyin.</div>
                                <div class="mt-2 border rounded bg-white p-2 text-center" style="min-height:60px;">
                                    @if (HasBrandingPreview(brandingTextLogo))
                                    {
                                        <img src="@brandingTextLogo" alt="Yazı Logosu" style="max-height:80px;max-width:100%;object-fit:contain;" />
                                    }
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(brandingHataMesaji))
                        {
                            <div class="alert alert-warning py-2 small mt-3 mb-0">@brandingHataMesaji</div>
                        }
                    </div>
                </div>

                <button class="btn btn-primary w-100 mt-2" @onclick="Adim1IleriAsync" disabled="@islemDevamEdiyor">
                    @if (islemDevamEdiyor)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-arrow-right me-1"></i>İleri
                </button>
            </div>
        }

        <!-- ADIM 2: ADMİN KULLANICI -->
        @if (aktifAdim == 2)
        {
            <div class="setup-step-body">
                <h5 class="step-title"><i class="bi bi-person-gear me-2"></i>Admin Kullanıcı</h5>
                <p class="step-desc text-muted">Sisteme giriş yapacak yönetici hesabını tanımlayın.</p>

                <div class="mb-3">
                    <label class="form-label">Ad Soyad <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" placeholder="Ahmet Yılmaz"
                           @bind="adminAdSoyad" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" placeholder="admin"
                           @bind="adminKullaniciAdi" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">E-posta</label>
                    <input type="email" class="form-control" placeholder="admin@firma.com"
                           @bind="adminEmail" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Şifre <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="@(sifreGoster ? "text" : "password")" class="form-control"
                               placeholder="En az 6 karakter" @bind="adminSifre" @bind:event="oninput" />
                        <button class="btn btn-outline-secondary" type="button"
                                @onclick="() => sifreGoster = !sifreGoster">
                            <i class="bi @(sifreGoster ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Şifre Tekrar <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" placeholder="Şifreyi tekrar girin"
                           @bind="adminSifreTekrar" @bind:event="oninput" />
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button class="btn btn-outline-secondary flex-fill"
                            @onclick="() => { aktifAdim = 1; hataMesaji = string.Empty; }">
                        <i class="bi bi-arrow-left me-1"></i>Geri
                    </button>
                    <button class="btn btn-primary flex-fill" @onclick="Adim2TamamlaAsync"
                            disabled="@islemDevamEdiyor">
                        @if (islemDevamEdiyor)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kurulumu Tamamla
                    </button>
                </div>
            </div>
        }

        <!-- ADIM 3: TAMAMLANDI -->
        @if (aktifAdim == 3)
        {
            <div class="setup-step-body text-center">
                <div class="success-icon mb-3">
                    <i class="bi bi-check-circle-fill text-success"></i>
                </div>
                <h5 class="fw-bold text-success">Kurulum Tamamlandı!</h5>
                <p class="text-muted mb-2">
                    <strong>@firmaAdi</strong> firması başarıyla oluşturuldu.<br />
                    Yönetici hesabı <strong>@adminKullaniciAdi</strong> aktif edildi.
                </p>
                <hr />
                <p class="text-muted small mb-3">
                    Sistemi kullanmaya başlamadan önce lisansınızı aktive etmeniz önerilir.
                </p>
                <div class="d-grid gap-2">
                    <button class="btn btn-warning" @onclick="LisansSetupGit">
                        <i class="bi bi-shield-check me-2"></i>Lisansı Aktive Et
                    </button>
                    <button class="btn btn-outline-primary" @onclick="GirisYap">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Sayfasına Git
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .setup-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        overflow: hidden;
        padding: 2rem 1rem;
    }

    .setup-background {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
    }

    .shape-1 { width: 400px; height: 400px; top: -100px; right: -80px; }
    .shape-2 { width: 250px; height: 250px; bottom: -60px; left: -60px; }
    .shape-3 { width: 150px; height: 150px; top: 50%; left: 10%; }

    .setup-card {
        background: #fff;
        border-radius: 1.5rem;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        position: relative;
        z-index: 10;
    }

    .setup-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .logo-container {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
    }

    .logo-branding-preview {
        width: auto;
        height: auto;
        padding: 0.75rem 1rem;
        border-radius: 20px;
        background: #fff;
        display: inline-flex;
        flex-direction: column;
        gap: 0.5rem;
        box-shadow: 0 8px 25px rgba(15, 23, 42, 0.08);
    }

    .setup-logo-icon {
        width: 88px;
        height: 88px;
        object-fit: contain;
        margin: 0 auto;
    }

    .setup-logo-text {
        max-width: 240px;
        max-height: 72px;
        object-fit: contain;
    }

    .setup-header h1 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.25rem;
    }

    .setup-header p { color: #6c757d; font-size: 0.95rem; }

    .setup-steps-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .step-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #e9ecef;
        color: #adb5bd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        transition: all 0.3s;
    }

    .step-item.active .step-circle { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
    .step-item.completed .step-circle { background: #198754; color: #fff; }

    .step-label {
        font-size: 0.72rem;
        color: #6c757d;
        white-space: nowrap;
    }

    .step-item.active .step-label { color: #667eea; font-weight: 600; }

    .step-line {
        flex: 1;
        height: 2px;
        background: #e9ecef;
        margin: 0 6px;
        margin-bottom: 18px;
        transition: background 0.3s;
    }

    .step-line.completed { background: #198754; }

    .setup-step-body { margin-top: 0.5rem; }

    .step-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.25rem;
    }

    .step-desc { font-size: 0.875rem; margin-bottom: 1.25rem; }

    .success-icon i { font-size: 4rem; }
</style>

@code {
    private int aktifAdim = 1;
    private bool islemDevamEdiyor = false;
    private string hataMesaji = string.Empty;
    private string setupIconSrc = BrandingService.DefaultIconPath;
    private string setupTextLogoSrc = BrandingService.DefaultTextLogoPath;

    // Adım 1 - Firma
    private string firmaAdi = string.Empty;
    private string firmaVergiNo = string.Empty;
    private string firmaVergiDairesi = string.Empty;
    private string firmaTelefon = string.Empty;
    private string firmaEmail = string.Empty;
    private string firmaAdres = string.Empty;
    private string? brandingIconLogo;
    private string? brandingTextLogo;
    private string? brandingHataMesaji;

    // Adım 2 - Admin
    private string adminAdSoyad = string.Empty;
    private string adminKullaniciAdi = "admin";
    private string adminEmail = string.Empty;
    private string adminSifre = string.Empty;
    private string adminSifreTekrar = string.Empty;
    private bool sifreGoster = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var branding = await BrandingService.GetAsync();
            setupIconSrc = branding.ResolvedIconLogo;
            setupTextLogoSrc = branding.ResolvedTextLogo;

            using var ctx = await DbContextFactory.CreateDbContextAsync();
            if (await ctx.Firmalar.IgnoreQueryFilters().AnyAsync())
            {
                Navigation.NavigateTo("/login", replace: true);
            }
        }
        catch { /* DB bağlantı hatası → setup devam et */ }
    }

    private async Task Adim1IleriAsync()
    {
        hataMesaji = string.Empty;
        if (string.IsNullOrWhiteSpace(firmaAdi))
        {
            hataMesaji = "Firma adı zorunludur.";
            return;
        }
        islemDevamEdiyor = true;
        await Task.Delay(150);
        aktifAdim = 2;
        islemDevamEdiyor = false;
    }

    private async Task Adim2TamamlaAsync()
    {
        hataMesaji = string.Empty;

        if (string.IsNullOrWhiteSpace(adminAdSoyad))   { hataMesaji = "Ad Soyad zorunludur."; return; }
        if (string.IsNullOrWhiteSpace(adminKullaniciAdi)) { hataMesaji = "Kullanıcı adı zorunludur."; return; }
        if (adminSifre.Length < 6)                      { hataMesaji = "Şifre en az 6 karakter olmalıdır."; return; }
        if (adminSifre != adminSifreTekrar)             { hataMesaji = "Şifreler eşleşmiyor."; return; }

        islemDevamEdiyor = true;
        try
        {
            using var ctx = await DbContextFactory.CreateDbContextAsync();

            // 1. Firma
            var firma = new Firma
            {
                FirmaKodu = await GenerateSetupFirmaCodeAsync(ctx),
                FirmaAdi = firmaAdi.Trim(),
                VergiNo = string.IsNullOrWhiteSpace(firmaVergiNo) ? null : firmaVergiNo.Trim(),
                VergiDairesi = string.IsNullOrWhiteSpace(firmaVergiDairesi) ? null : firmaVergiDairesi.Trim(),
                Telefon = string.IsNullOrWhiteSpace(firmaTelefon) ? null : firmaTelefon.Trim(),
                Email = string.IsNullOrWhiteSpace(firmaEmail) ? null : firmaEmail.Trim(),
                Adres = string.IsNullOrWhiteSpace(firmaAdres) ? null : firmaAdres.Trim(),
                OrganizasyonId = await EnsureSetupOrganizasyonIdAsync(ctx),
                VarsayilanFirma = true,
                Aktif = true,
                AktifDonemYil = DateTime.Today.Year,
                AktifDonemAy = DateTime.Today.Month,
                CreatedAt = DateTime.UtcNow
            };
            ctx.Firmalar.Add(firma);
            await ctx.SaveChangesAsync();

            // 2. Roller
            var roller = new List<Rol>
            {
                new() { RolAdi = "Admin",     Aciklama = "Sistem yöneticisi",  CreatedAt = DateTime.UtcNow },
                new() { RolAdi = "Muhasebe",  Aciklama = "Muhasebe personeli", CreatedAt = DateTime.UtcNow },
                new() { RolAdi = "Kullanici", Aciklama = "Standart kullanıcı", CreatedAt = DateTime.UtcNow }
            };
            ctx.Roller.AddRange(roller);
            await ctx.SaveChangesAsync();

            // 3. Admin kullanıcı
            var adminRol = roller.First(r => r.RolAdi == "Admin");
            ctx.Kullanicilar.Add(new Kullanici
            {
                KullaniciAdi = adminKullaniciAdi.Trim().ToLowerInvariant(),
                AdSoyad      = adminAdSoyad.Trim(),
                Email        = string.IsNullOrWhiteSpace(adminEmail) ? null : adminEmail.Trim(),
                SifreHash    = PasswordHasher.HashPassword(new Kullanici(), adminSifre),
                RolId        = adminRol.Id,
                Aktif        = true,
                CreatedAt    = DateTime.UtcNow
            });
            await ctx.SaveChangesAsync();

            await BrandingService.SaveAsync(brandingIconLogo, brandingTextLogo);
            aktifAdim = 3;
        }
        catch (Exception ex)
        {
            hataMesaji = $"Kurulum sırasında hata: {ex.Message}";
        }
        finally
        {
            islemDevamEdiyor = false;
        }
    }

    private async Task<int> EnsureSetupOrganizasyonIdAsync(ApplicationDbContext ctx)
    {
        var organizasyon = await ctx.Organizasyonlar
            .IgnoreQueryFilters()
            .Where(o => !o.IsDeleted)
            .OrderBy(o => o.Id)
            .FirstOrDefaultAsync();

        if (organizasyon != null)
            return organizasyon.Id;

        organizasyon = new Organizasyon
        {
            Adi = "Ustun Holding",
            Kod = "USTUNHOLDING",
            Aciklama = "Kurulum sirasinda otomatik olusturuldu",
            CreatedAt = DateTime.UtcNow
        };

        ctx.Organizasyonlar.Add(organizasyon);
        await ctx.SaveChangesAsync();
        return organizasyon.Id;
    }

    private static async Task<string> GenerateSetupFirmaCodeAsync(ApplicationDbContext ctx)
    {
        var existingCodes = await ctx.Firmalar
            .IgnoreQueryFilters()
            .Select(f => f.FirmaKodu)
            .ToListAsync();

        var nextNumber = 1;
        foreach (var code in existingCodes)
        {
            if (string.IsNullOrWhiteSpace(code) || !code.StartsWith("F", StringComparison.OrdinalIgnoreCase))
                continue;

            if (int.TryParse(code[1..], out var parsed) && parsed >= nextNumber)
            {
                nextNumber = parsed + 1;
            }
        }

        var candidate = $"F{nextNumber:000}";
        while (existingCodes.Contains(candidate, StringComparer.OrdinalIgnoreCase))
        {
            nextNumber++;
            candidate = $"F{nextNumber:000}";
        }

        return candidate;
    }

    private async Task BrandingAmblemYukle(InputFileChangeEventArgs e)
    {
        var yeniGorsel = await ReadImageAsDataUrlAsync(e.File);
        if (yeniGorsel != null)
        {
            brandingIconLogo = yeniGorsel;
        }
    }

    private async Task BrandingYaziLogosuYukle(InputFileChangeEventArgs e)
    {
        var yeniGorsel = await ReadImageAsDataUrlAsync(e.File);
        if (yeniGorsel != null)
        {
            brandingTextLogo = yeniGorsel;
        }
    }

    private async Task<string?> ReadImageAsDataUrlAsync(IBrowserFile? file)
    {
        brandingHataMesaji = null;
        if (file == null)
            return null;

        if (file.Size > 2 * 1024 * 1024)
        {
            brandingHataMesaji = "Gorsel dosyasi 2 MB'dan buyuk olamaz.";
            return null;
        }

        var izinliTipler = new[] { "image/png", "image/jpeg", "image/jpg", "image/svg+xml", "image/webp" };
        if (!izinliTipler.Contains(file.ContentType))
        {
            brandingHataMesaji = "Sadece PNG, JPG, SVG veya WebP yukleyebilirsiniz.";
            return null;
        }

        using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private static bool HasBrandingPreview(string? currentValue)
        => !string.IsNullOrWhiteSpace(currentValue);

    private void LisansSetupGit() => Navigation.NavigateTo("/setup/lisans");
    private void GirisYap()       => Navigation.NavigateTo("/login");
}



