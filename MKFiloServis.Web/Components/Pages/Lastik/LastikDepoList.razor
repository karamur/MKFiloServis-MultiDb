@page "/lastik/depolar"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject ILastikService LastikService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Lastik Depoları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-building me-2"></i>Lastik Depoları</h3>
        <button class="btn btn-primary" @onclick="YeniDepo">
            <i class="bi bi-plus-lg me-1"></i>Yeni Depo
        </button>
    </div>

    @if (depolar == null)
    {
        <div class="text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Yükleniyor...</span></div></div>
    }
    else if (!depolar.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Henüz depo kaydı bulunmamaktadır.</div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Depo Adı</th>
                                <th>Adres</th>
                                <th>Sorumlu</th>
                                <th>Telefon</th>
                                <th>Durum</th>
                                <th style="width:120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in depolar)
                            {
                                <tr>
                                    <td><strong>@d.DepoAdi</strong></td>
                                    <td>@d.Adres</td>
                                    <td>@d.SorumluKisi</td>
                                    <td>@d.Telefon</td>
                                    <td>
                                        @if (d.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pasif</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(d)" title="Düzenle"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(d)" title="Sil"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Form Modal -->
@if (showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-building me-2"></i>@(editDepo.Id == 0 ? "Yeni Depo" : "Depo Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="() => showForm = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editDepo" OnValidSubmit="Kaydet">
                        <DataAnnotationsValidator />
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Depo Adı *</label>
                                <InputText @bind-Value="editDepo.DepoAdi" class="form-control" />
                                <ValidationMessage For="@(() => editDepo.DepoAdi)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Sorumlu Kişi</label>
                                <InputText @bind-Value="editDepo.SorumluKisi" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label">Adres</label>
                                <InputText @bind-Value="editDepo.Adres" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Telefon</label>
                                <InputText @bind-Value="editDepo.Telefon" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="editDepo.Notlar" class="form-control" rows="2" />
                        </div>
                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="editDepo.Aktif" class="form-check-input" id="aktif" />
                            <label class="form-check-label" for="aktif">Aktif</label>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@kaydediliyor">
                                @if (kaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Kaydet
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onayı -->
@if (showDeleteModal && silinecek != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <strong>@silinecek.DepoAdi</strong> deposunu silmek istediğinizden emin misiniz?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LastikDepo>? depolar;
    private LastikDepo editDepo = new();
    private LastikDepo? silinecek;
    private bool showForm;
    private bool showDeleteModal;
    private bool kaydediliyor;

    protected override async Task OnInitializedAsync()
    {
        depolar = await LastikService.GetDepoListAsync();
    }

    private void YeniDepo()
    {
        editDepo = new LastikDepo { Aktif = true };
        showForm = true;
    }

    private void Duzenle(LastikDepo d)
    {
        editDepo = new LastikDepo
        {
            Id = d.Id, DepoAdi = d.DepoAdi, Adres = d.Adres,
            SorumluKisi = d.SorumluKisi, Telefon = d.Telefon,
            Notlar = d.Notlar, Aktif = d.Aktif
        };
        showForm = true;
    }

    private async Task Kaydet()
    {
        kaydediliyor = true;
        try
        {
            if (editDepo.Id == 0)
                await LastikService.CreateDepoAsync(editDepo);
            else
                await LastikService.UpdateDepoAsync(editDepo);

            showForm = false;
            depolar = await LastikService.GetDepoListAsync();
            ToastService.ShowSuccess("Depo kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            kaydediliyor = false;
        }
    }

    private void SilOnay(LastikDepo d)
    {
        silinecek = d;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecek == null) return;
        await LastikService.DeleteDepoAsync(silinecek.Id);
        showDeleteModal = false;
        depolar = await LastikService.GetDepoListAsync();
        ToastService.ShowSuccess("Depo silindi.");
    }
}

