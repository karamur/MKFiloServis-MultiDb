    private async Task Kaydet()
    {
        kaydediliyor = true;
        try
        {
            if (editDegisim.AracId <= 0)
            {
                ToastService.ShowWarning("Araç seçimi zorunludur.");
                return;
            }

            var gecerliSatirlar = degisimSatirlari
                .Where(s => s.IslemYapilsin)
                .ToList();

            if (!gecerliSatirlar.Any())
            {
                ToastService.ShowWarning("En az bir pozisyonda değişim işaretlenmelidir.");
                return;
            }

            var stoktanSatirlar = gecerliSatirlar
                .Where(s => s.TeminSekli != "satinalma")
                .ToList();

            if (stoktanSatirlar.Any(s => !s.TakilanStokId.HasValue))
            {
                ToastService.ShowWarning("Stoktan değişim seçilen satırlarda takılan stok zorunludur.");
                return;
            }

            if (gecerliSatirlar.Where(s => s.TakilanStokId.HasValue).GroupBy(s => s.TakilanStokId).Any(g => g.Key.HasValue && g.Count() > 1))
            {
                ToastService.ShowWarning("Aynı takılan stok birden fazla pozisyonda kullanılamaz.");
                return;
            }

            if (gecerliSatirlar.Where(s => s.SokulenStokId.HasValue).GroupBy(s => s.SokulenStokId).Any(g => g.Key.HasValue && g.Count() > 1))
            {
                ToastService.ShowWarning("Aynı sökülen stok birden fazla pozisyonda seçilemez.");
                return;
            }

            var satinAlmaSatirlari = gecerliSatirlar
                .Where(s => s.TeminSekli == "satinalma")
                .ToList();

            if (satinAlmaSatirlari.Any())
            {
                if (string.IsNullOrWhiteSpace(satinAlmaForm.Marka) || string.IsNullOrWhiteSpace(satinAlmaForm.Ebat))
                {
                    ToastService.ShowWarning("Satın alma seçiliyse marka ve ebat bilgisi zorunludur.");
                    return;
                }

                if (satinAlmaSatirlari.Any(s => !s.KaynakDepoId.HasValue))
                {
                    ToastService.ShowWarning("Satın alma seçilen her satır için giriş deposu seçilmelidir.");
                    return;
                }

                if (satinAlmaForm.OdemeYapildi && !satinAlmaForm.OdemeHesapId.HasValue)
                {
                    ToastService.ShowWarning("Ödeme yapıldı seçiliyse ödeme hesabı zorunludur.");
                    return;
                }
            }

            var ilkSatir = gecerliSatirlar.First();
            editDegisim.TakilanStokId = ilkSatir.TakilanStokId;
            editDegisim.SokulenStokId = ilkSatir.SokulenStokId;
            editDegisim.KaynakDepoId = ilkSatir.KaynakDepoId;
            editDegisim.HedefDepoId = ilkSatir.HedefDepoId;
            editDegisim.TakilanPozisyon = ilkSatir.Pozisyon;
            editDegisim.SokulenPozisyon = ilkSatir.Pozisyon;

            var payload = new LastikDegisimNotPayload
            {
                GirisTipi = degisimGirisSekli,
                Adet = degisimSatirlari.Count,
                SetAdedi = degisimSatirlari.Count,
                IslemGorenAdet = gecerliSatirlar.Count,
                UserNot = serbestNot,
                SatinAlma = satinAlmaSatirlari.Any()
                    ? new LastikDegisimSatinAlmaForm
                    {
                        TedarikciAdi = satinAlmaForm.TedarikciAdi,
                        Marka = satinAlmaForm.Marka,
                        Ebat = satinAlmaForm.Ebat,
                        Sezon = satinAlmaForm.Sezon,
                        FaturasizMi = satinAlmaForm.FaturasizMi,
                        FaturaNo = satinAlmaForm.FaturaNo,
                        FaturaTarihi = satinAlmaForm.FaturaTarihi,
                        ToplamTutar = satinAlmaForm.ToplamTutar,
                        OdemeYapildi = satinAlmaForm.OdemeYapildi,
                        OdemeTarihi = satinAlmaForm.OdemeTarihi,
                        OdemeHesapId = satinAlmaForm.OdemeHesapId,
                        OdemeHesapAdi = GetBankaHesapAdi(satinAlmaForm.OdemeHesapId),
                        OdemeHesapTipi = GetBankaHesapTipi(satinAlmaForm.OdemeHesapId),
                        MasrafId = satinAlmaForm.MasrafId,
                        OdemeNotu = satinAlmaForm.OdemeNotu
                    }
                    : null,
                Satirlar = degisimSatirlari.Select(s => new LastikDegisimNotSatir
                {
                    IslemYapildiMi = s.IslemYapilsin,
                    Pozisyon = s.Pozisyon,
                    TeminSekli = s.TeminSekli,
                    TakilanStokId = s.TakilanStokId,
                    TakilanEtiket = GetStokEtiket(s.TakilanStokId),
                    KaynakDepoId = s.KaynakDepoId,
                    KaynakDepoAdi = GetDepoAdi(s.KaynakDepoId),
                    SokulenStokId = s.SokulenStokId,
                    SokulenEtiket = GetStokEtiket(s.SokulenStokId),
                    HedefDepoId = s.HedefDepoId,
                    HedefDepoAdi = GetDepoAdi(s.HedefDepoId),
                    SokulenAkibet = s.SokulenAkibet,
                    SatinAlmaTedarikciAdi = s.TeminSekli == "satinalma" ? satinAlmaForm.TedarikciAdi : null,
                    SatinAlmaMarka = s.TeminSekli == "satinalma" ? satinAlmaForm.Marka : null,
                    SatinAlmaEbat = s.TeminSekli == "satinalma" ? satinAlmaForm.Ebat : null,
                    SatinAlmaSezon = s.TeminSekli == "satinalma" ? satinAlmaForm.Sezon : null,
                    SatinAlmaNotu = s.TeminSekli == "satinalma" ? satinAlmaForm.OdemeNotu : null
                }).ToList()
            };

            editDegisim.Notlar = JsonSerializer.Serialize(payload);

            if (editDegisim.Id == 0)
                await LastikService.CreateDegisimAsync(editDegisim);
            else
                await LastikService.UpdateDegisimAsync(editDegisim);

            showForm = false;
            await Filtrele();
            if (showAracDetayModal && seciliAracDetay != null)
                await AracDetayAc(seciliAracDetay.AracId);
            ToastService.ShowSuccess("Değişim kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally { kaydediliyor = false; }
    }

