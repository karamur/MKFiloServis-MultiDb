    private async Task HizliDegisimKaydet()
    {
        if (string.IsNullOrWhiteSpace(hizliNeden) || seciliAracDetay == null || hizliSokulenStok == null)
            return;

        hizliKaydediliyor = true;
        try
        {
            var payload = new LastikDegisimNotPayload
            {
                GirisTipi = "hizli",
                Adet = 1,
                SetAdedi = 1,
                IslemGorenAdet = 1,
                UserNot = hizliNeden,
                Satirlar = new List<LastikDegisimNotSatir>
                {
                    new()
                    {
                        IslemYapildiMi = true,
                        Pozisyon = hizliSokulenStok.Notlar ?? "?",
                        TakilanStokId = hizliTakilanStokId,
                        KaynakDepoId = null,
                        SokulenStokId = hizliSokulenStok.Id,
                        SokulenEtiket = $"{hizliSokulenStok.Marka} {hizliSokulenStok.Ebat}",
                        HedefDepoId = hizliHedefDepoId,
                        SokulenAkibet = hizliAkibet
                    }
                }
            };

            var degisim = new LastikDegisim
            {
                AracId = seciliAracDetay.AracId,
                DegisimTarihi = hizliTarih,
                DegisimTipi = hizliDegisimTipi,
                KmDurumu = hizliKm,
                YapilanYer = hizliYer,
                TakilanStokId = hizliTakilanStokId,
                SokulenStokId = hizliSokulenStok.Id,
                HedefDepoId = hizliHedefDepoId,
                Notlar = System.Text.Json.JsonSerializer.Serialize(payload)
            };

            await LastikService.CreateDegisimAsync(degisim);
            ToastService.ShowSuccess("Lastik değişimi kaydedildi.");

            // Detay modalını yenile
            showHizliDegisimModal = false;
            hizliSokulenStok = null;
            seciliAracDetay = await LastikService.GetAracDetayAsync(seciliAracDetay.AracId, null, null);
            degisimler = await LastikService.GetDegisimListAsync(filtreAracId, filtreBaslangic, filtreBitis);
            stoklar = await LastikService.GetStokListAsync();
            await YukleAracDonemOzeti();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            hizliKaydediliyor = false;
        }
    }

