@page "/lastik/degisimler"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using System.Text.Json
@inject ILastikService LastikService
@inject IAracService AracService
@inject IBankaHesapService BankaHesapService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Lastik Değişimleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-arrow-repeat me-2"></i>Lastik Değişim Kayıtları</h3>
        <button class="btn btn-primary" @onclick="YeniDegisim">
            <i class="bi bi-plus-lg me-1"></i>Yeni Değişim
        </button>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label mb-1">Araç</label>
                    <div class="position-relative">
                        <input type="text" class="form-control form-control-sm" placeholder="Plaka veya araç ara..."
                               value="@filtreAracArama"
                               @oninput="FiltreAracAramaGuncelle"
                               @onfocus="() => filtreAracDropAcik = true"
                               @onblur="FiltreAracDropKapat" />
                        @if (filtreAracDropAcik && filtreliAraclar.Any())
                        {
                            <div class="dropdown-menu show w-100" style="max-height:200px;overflow-y:auto;z-index:1060;">
                                <button type="button" class="dropdown-item" @onmousedown="() => FiltreAracSec(null)">
                                    <span class="text-muted">-- Tüm Araçlar --</span>
                                </button>
                                @foreach (var a in filtreliAraclar)
                                {
                                    <button type="button" class="dropdown-item" @onmousedown="() => FiltreAracSec(a)">
                                        <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    @if (filtreAracId.HasValue)
                    {
                        <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @filtreAracArama</small>
                    }
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" value="@filtreBaslangicStr" @onchange="BaslangicDegisti" />
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" value="@filtreBitisStr" @onchange="BitisDegisti" />
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Sahiplik</label>
                    <select class="form-select form-select-sm" @bind="filtreSahiplikTipi">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                        {
                            <option value="@sahiplik.ToString()">@GetSahiplikText(sahiplik)</option>
                        }
                    </select>
                    <div class="form-check form-check-sm mt-1">
                        <input class="form-check-input" type="checkbox" id="chkLastikSahiplikHaric" @bind="filtreSahiplikHaric" disabled="@(filtreSahiplikTipi == "Tumu")" />
                        <label class="form-check-label small text-muted" for="chkLastikSahiplikHaric">Hariç tut</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="FiltreSifirla">
                        <i class="bi bi-x-circle me-1"></i>Temizle
                    </button>
                    <button class="btn btn-sm btn-outline-info ms-1" @onclick="SecilenPlakaGecmisiAc" disabled="@(filtreAracId == null)" title="Secilen plakanin tum lastik gecmisi">
                        <i class="bi bi-clock-history me-1"></i>Plaka Gecmisi
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-truck me-2"></i>Araç Bazlı Lastik Dönem Özeti</h6>
            <span class="badge bg-secondary">@aracDonemOzetleri.Count araç</span>
        </div>
        <div class="card-body p-0">
            @if (!aracDonemOzetleri.Any())
            {
                <div class="p-3 text-muted">Dönem özeti için araç kaydı bulunamadı.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Plaka</th>
                                <th>Araç</th>
                                <th class="text-center">Dönem</th>
                                <th class="text-center">Takılı Lastik</th>
                                <th class="text-center">4 Lastik Aynı mı?</th>
                                <th>Takılı Lastik Özeti</th>
                                <th style="width:110px;">Detay</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in aracDonemOzetleri)
                            {
                                <tr>
                                    <td><strong>@o.Plaka</strong></td>
                                    <td>@o.AracBilgisi</td>
                                    <td class="text-center">
                                        @if (o.BuSezonDegisimYapildi == null)
                                        {
                                            <span class="badge bg-secondary">Sezon Yok</span>
                                        }
                                        else if (o.BuSezonDegisimYapildi.Value)
                                        {
                                            <span class="badge bg-success" title="@o.AktifSezonAdi">Yapıldı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" title="@o.AktifSezonAdi">Yapılmadı</span>
                                        }
                                    </td>
                                    <td class="text-center">@o.TakiliLastikSayisi</td>
                                    <td class="text-center">
                                        @if (o.DortLastikAyniMi)
                                        {
                                            <span class="badge bg-success">Evet</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Hayir</span>
                                        }
                                    </td>
                                    <td><small>@o.TakiliLastikOzeti</small></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => AracDetayAc(o.AracId)">
                                            <i class="bi bi-list-ul me-1"></i>Detay
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (degisimler == null)
    {
        <div class="text-center"><div class="spinner-border" role="status"></div></div>
    }
    else if (!GosterilenDegisimler.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Değişim kaydı bulunamadı.</div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Tarih</th>
                                <th>Araç (Plaka)</th>
                                <th>Tür</th>
                                <th>KM</th>
                                <th>Takilan Lastik</th>
                                <th>Sokulen Lastik</th>
                                <th>Yapılan Yer</th>
                                <th class="text-end">Ücret</th>
                                <th>Alım / Ödeme</th>
                                <th style="width:100px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in GosterilenDegisimler)
                            {
                                <tr>
                                    <td><strong>@d.DegisimTarihi.ToString("dd.MM.yyyy")</strong></td>
                                    <td>@d.Arac?.AktifPlaka <small class="text-muted">@d.Arac?.Marka @d.Arac?.Model</small></td>
                                    <td><span class="badge @GetTurBadge(d.DegisimTipi)">@GetTurText(d.DegisimTipi)</span></td>
                                    <td>@(d.KmDurumu.HasValue ? d.KmDurumu.Value.ToString("N0") + " km" : "-")</td>
                                    <td>
                                        @{
                                            var takilanSatirlari = GetTakilanOzetSatirlari(d);
                                        }
                                        @if (takilanSatirlari.Any())
                                        {
                                            foreach (var satir in takilanSatirlari)
                                            {
                                                <small>@satir</small><br />
                                            }
                                        }
                                        else { <span class="text-muted">-</span> }
                                    </td>
                                    <td>
                                        @{
                                            var sokulenSatirlari = GetSokulenOzetSatirlari(d);
                                        }
                                        @if (sokulenSatirlari.Any())
                                        {
                                            foreach (var satir in sokulenSatirlari)
                                            {
                                                <small>@satir</small><br />
                                            }
                                        }
                                        else { <span class="text-muted">-</span> }
                                    </td>
                                    <td>@d.YapilanYer</td>
                                    <td class="text-end">@(d.Ucret.HasValue ? d.Ucret.Value.ToString("N2") + " ₺" : "-")</td>
                                    <td>
                                        @{
                                            var alimSatirlari = GetAlimOdemeOzetSatirlari(d);
                                            var masrafId = GetDegisimMasrafId(d);
                                        }
                                        @foreach (var satir in alimSatirlari)
                                        {
                                            <small class="d-block">@satir</small>
                                        }
                                        @if (masrafId.HasValue)
                                        {
                                            <a href="/arac-masraflari/@masrafId.Value" class="badge bg-success text-decoration-none mt-1" title="Araç masraf kaydına git">
                                                <i class="bi bi-receipt me-1"></i>Masraf #@masrafId.Value
                                            </a>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(d)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(d)"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Form Modal -->
@if (showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>@(editDegisim.Id == 0 ? "Yeni Değişim" : "Değişim Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="() => showForm = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editDegisim" OnValidSubmit="Kaydet">
                        <DataAnnotationsValidator />
                        <!-- Temel bilgiler -->
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Araç *</label>
                                <div class="position-relative">
                                    <input type="text" class="form-control" placeholder="Plaka veya araç ara..."
                                           value="@formAracArama"
                                           @oninput="FormAracAramaGuncelle"
                                           @onfocus="() => formAracDropAcik = true"
                                           @onblur="FormAracDropKapat" />
                                    @if (formAracDropAcik && formFiltreliAraclar.Any())
                                    {
                                        <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1060;">
                                            @foreach (var a in formFiltreliAraclar)
                                            {
                                                <button type="button" class="dropdown-item" @onmousedown="() => FormAracSec(a)">
                                                    <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (editDegisim.AracId > 0)
                                {
                                    <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @formAracArama</small>
                                }
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Değişim Tarihi *</label>
                                <InputDate @bind-Value="editDegisim.DegisimTarihi" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Değişim Türü</label>
                                <InputSelect @bind-Value="editDegisim.DegisimTipi" class="form-select">
                                    <option value="@LastikDegisimTipi.Mevsimlik">Mevsimlik</option>
                                    <option value="@LastikDegisimTipi.Periyodik">Periyodik</option>
                                    <option value="@LastikDegisimTipi.Ariza">Arıza</option>
                                    <option value="@LastikDegisimTipi.Diger">Diğer</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-2 mb-3">
                                <label class="form-label">KM Durumu</label>
                                <InputNumber @bind-Value="editDegisim.KmDurumu" class="form-control" />
                            </div>
                        </div>

                        <!-- Araçta takılı + depoda mevcut lastikler özeti -->
                        @if (editDegisim.AracId > 0)
                        {
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="card border-primary">
                                        <div class="card-header py-1 bg-primary text-white small">
                                            <i class="bi bi-truck me-1"></i>Araçta Takılı Lastikler
                                            <span class="badge bg-white text-primary ms-1">@formAracTakiliLastikler.Count</span>
                                        </div>
                                        <div class="card-body py-2 px-2">
                                            @if (!formAracTakiliLastikler.Any())
                                            {
                                                <span class="text-muted small">Bu araçta kayıtlı takılı lastik yok.</span>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var t in formAracTakiliLastikler)
                                                    {
                                                        <span class="badge bg-primary">
                                                            @(t.Marka ?? "(?)") @t.Ebat
                                                            <span class="ms-1 fw-normal">@GetSezonText(t.Sezon)</span>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card border-secondary">
                                        <div class="card-header py-1 bg-secondary text-white small">
                                            <i class="bi bi-archive me-1"></i>Depoda Kullanılabilir
                                            <span class="badge bg-white text-secondary ms-1">@formDepoLastikleri.Count</span>
                                        </div>
                                        <div class="card-body py-2 px-2">
                                            @if (!formDepoLastikleri.Any())
                                            {
                                                <span class="text-muted small">Depoda kullanılabilir lastik yok.</span>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var dep in formDepoLastikleri.Take(8))
                                                    {
                                                        <span class="badge bg-secondary">
                                                            @(dep.Marka ?? "(?)") @dep.Ebat
                                                            <span class="ms-1 fw-normal">@GetSezonText(dep.Sezon)</span>
                                                            @if (!string.IsNullOrWhiteSpace(dep.Depo?.DepoAdi))
                                                            {
                                                                <small class="ms-1 opacity-75">(@dep.Depo!.DepoAdi)</small>
                                                            }
                                                        </span>
                                                    }
                                                    @if (formDepoLastikleri.Count > 8)
                                                    {
                                                        <span class="badge bg-light text-dark border">+@(formDepoLastikleri.Count - 8) daha</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="card mb-3">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-grid-3x2-gap me-2"></i>4'lü Lastik Seti
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="StandartDortluUygula">
                                    4 Pozisyonu Sıfırla
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="alert alert-light border py-2 mb-3">
                                    <div class="small text-muted mb-2">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Araç 4 pozisyon bazında takip edilir. Değişecek satırları işaretleyin; satır bazında stoktan kullanım veya satın alma seçebilirsiniz.
                                    </div>
                                    <div class="row g-2 align-items-end">
                                        <div class="col-md-4">
                                            <label class="form-label mb-1">Ortak Takılan Stok</label>
                                            <select class="form-select form-select-sm" value="@ortakTakilanStokId" @onchange="OrtakTakilanStokDegisti">
                                                <option value="">-- Seçim yok --</option>
                                                @foreach (var s in GetTakilabilirStoklar(null))
                                                {
                                                    <option value="@s.Id">@s.Ebat @s.Marka (@s.Depo?.DepoAdi)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label mb-1">Ortak Kaynak Depo</label>
                                            <select class="form-select form-select-sm" value="@ortakKaynakDepoId" @onchange="OrtakKaynakDepoDegisti">
                                                <option value="">-- Seçim yok --</option>
                                                @foreach (var d in depolar)
                                                {
                                                    <option value="@d.Id">@d.DepoAdi</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label mb-1">Ortak Hedef Depo (Sökülen)</label>
                                            <select class="form-select form-select-sm" value="@ortakHedefDepoId" @onchange="OrtakHedefDepoDegisti">
                                                <option value="">-- Seçim yok --</option>
                                                @foreach (var d in depolar)
                                                {
                                                    <option value="@d.Id">@d.DepoAdi</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" class="btn btn-sm btn-outline-primary w-100" @onclick="OrtakAlanlariUygula">
                                                <i class="bi bi-arrow-down-square me-1"></i>Hepsine Uygula
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width:140px;">Pozisyon</th>
                                                <th class="text-center" style="width:90px;">Değişim</th>
                                                <th style="width:160px;">Temin</th>
                                                <th>Takılan Lastik</th>
                                                <th style="width:180px;">Takılan Kaynak Depo</th>
                                                <th>Sökülen Stok</th>
                                                <th style="width:180px;">Sökülen Hedef Depo</th>
                                                <th style="width:140px;">Sökülen Akibet</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < degisimSatirlari.Count; i++)
                                            {
                                                var satir = degisimSatirlari[i];
                                                <tr>
                                                    <td>
                                                        <InputText @bind-Value="satir.Pozisyon" class="form-control form-control-sm" />
                                                    </td>
                                                    <td class="text-center">
                                                        <InputCheckbox @bind-Value="satir.IslemYapilsin" class="form-check-input" />
                                                    </td>
                                                    <td>
                                                        <InputSelect @bind-Value="satir.TeminSekli" class="form-select form-select-sm" disabled="@(!satir.IslemYapilsin)">
                                                            <option value="stok">Stoktan</option>
                                                            <option value="satinalma">Satın alma</option>
                                                        </InputSelect>
                                                    </td>
                                                    <td>
                                                        @if (!satir.IslemYapilsin)
                                                        {
                                                            <span class="text-muted small">Bu pozisyonda lastik değişmeyecek.</span>
                                                        }
                                                        else if (satir.TeminSekli == "satinalma")
                                                        {
                                                            <div class="small text-primary">
                                                                <i class="bi bi-cart-check me-1"></i>Ortak satın alma bilgisi kullanılacak
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <InputSelect @bind-Value="satir.TakilanStokId" class="form-select form-select-sm">
                                                                <option value="">-- Stok Seçin --</option>
                                                                @foreach (var s in GetTakilabilirStoklar(satir))
                                                                {
                                                                    var yedekLabel = s.YedekMi ? " [Yedek]" : "";
                                                                    var depoLabel = s.Depo?.DepoAdi ?? "Depo?";
                                                                    <option value="@s.Id">@s.Ebat @s.Marka @GetSezonText(s.Sezon)@yedekLabel — @depoLabel</option>
                                                                }
                                                            </InputSelect>
                                                        }
                                                    </td>
                                                    <td>
                                                        <InputSelect @bind-Value="satir.KaynakDepoId" class="form-select form-select-sm" disabled="@(!satir.IslemYapilsin)">
                                                            <option value="">-- Depo Seçin --</option>
                                                            @foreach (var d in depolar)
                                                            {
                                                                <option value="@d.Id">@d.DepoAdi</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                    <td>
                                                        <InputSelect @bind-Value="satir.SokulenStokId" class="form-select form-select-sm" disabled="@(!satir.IslemYapilsin)">
                                                            <option value="">— Sökülen yok / seçiniz —</option>
                                                            @foreach (var s in GetSokulebilirStoklar(satir))
                                                            {
                                                                var lokasyon = s.AracId.HasValue ? $"Takılı: {s.Arac?.AktifPlaka ?? "?"}" : (s.Depo?.DepoAdi ?? "Depo?");
                                                                <option value="@s.Id">@s.Ebat @s.Marka @GetSezonText(s.Sezon) — @lokasyon</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                    <td>
                                                        <InputSelect @bind-Value="satir.HedefDepoId" class="form-select form-select-sm" disabled="@(!satir.IslemYapilsin)">
                                                            <option value="">-- Depo Seçin --</option>
                                                            @foreach (var d in depolar)
                                                            {
                                                                <option value="@d.Id">@d.DepoAdi</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                    <td>
                                                        <InputSelect @bind-Value="satir.SokulenAkibet" class="form-select form-select-sm" disabled="@(!satir.IslemYapilsin || !satir.SokulenStokId.HasValue)">
                                                            <option value="depo">Depoda (kullanılabilir)</option>
                                                            <option value="tamir">Tamire gönderildi</option>
                                                            <option value="cop">Hurdaya çıkarıldı</option>
                                                        </InputSelect>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                @if (SatinAlmaAktifMi)
                                {
                                    <div class="card mt-3 border-warning">
                                        <div class="card-header bg-warning bg-opacity-10">
                                            <i class="bi bi-cart-plus me-2"></i>Satın Alma ve Stok Girişi
                                        </div>
                                        <div class="card-body">
                                            <div class="row g-2 mb-2">
                                                <div class="col-md-4">
                                                    <label class="form-label">Tedarikçi / Satıcı</label>
                                                    <InputText @bind-Value="satinAlmaForm.TedarikciAdi" class="form-control form-control-sm" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Marka *</label>
                                                    <InputText @bind-Value="satinAlmaForm.Marka" class="form-control form-control-sm" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Ebat *</label>
                                                    <InputText @bind-Value="satinAlmaForm.Ebat" class="form-control form-control-sm" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label">Sezon *</label>
                                                    <InputSelect @bind-Value="satinAlmaForm.Sezon" class="form-select form-select-sm">
                                                        <option value="@LastikSezon.YazLastigi">Yaz</option>
                                                        <option value="@LastikSezon.KisLastigi">Kış</option>
                                                        <option value="@LastikSezon.DortMevsim">4 Mevsim</option>
                                                    </InputSelect>
                                                </div>
                                            </div>

                                            <div class="row g-2 mb-2 align-items-end">
                                                <div class="col-md-2">
                                                    <div class="form-check mt-4">
                                                        <InputCheckbox @bind-Value="satinAlmaForm.FaturasizMi" class="form-check-input" id="faturasizAlim" />
                                                        <label class="form-check-label" for="faturasizAlim">Faturasız alım</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Fatura No</label>
                                                    <InputText @bind-Value="satinAlmaForm.FaturaNo" class="form-control form-control-sm" disabled="@satinAlmaForm.FaturasizMi" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Fatura Tarihi</label>
                                                    <InputDate @bind-Value="satinAlmaForm.FaturaTarihi" class="form-control form-control-sm" disabled="@satinAlmaForm.FaturasizMi" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label">Alım Tutarı</label>
                                                    <InputNumber @bind-Value="satinAlmaForm.ToplamTutar" class="form-control form-control-sm" />
                                                </div>
                                                <div class="col-md-2">
                                                    <div class="form-check mt-4">
                                                        <InputCheckbox @bind-Value="satinAlmaForm.OdemeYapildi" class="form-check-input" id="odemeYapildi" />
                                                        <label class="form-check-label" for="odemeYapildi">Ödeme yapıldı</label>
                                                    </div>
                                                </div>
                                            </div>

                                            @if (satinAlmaForm.OdemeYapildi)
                                            {
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label">Ödeme Hesabı *</label>
                                                        <InputSelect @bind-Value="satinAlmaForm.OdemeHesapId" class="form-select form-select-sm">
                                                            <option value="">-- Hesap Seçin --</option>
                                                            @foreach (var hesap in bankaHesaplari)
                                                            {
                                                                <option value="@hesap.Id">@hesap.HesapAdi (@GetHesapTipiText(hesap.HesapTipi))</option>
                                                            }
                                                        </InputSelect>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label">Ödeme Tarihi</label>
                                                        <InputDate @bind-Value="satinAlmaForm.OdemeTarihi" class="form-control form-control-sm" />
                                                    </div>
                                                    <div class="col-md-5">
                                                        <label class="form-label">Ödeme Notu</label>
                                                        <InputText @bind-Value="satinAlmaForm.OdemeNotu" class="form-control form-control-sm" placeholder="Nereden veya nasıl ödendi" />
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Yapılan Yer / Servis</label>
                                <InputText @bind-Value="editDegisim.YapilanYer" class="form-control" placeholder="Servis adı veya lokasyon" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">İşlem Ücreti (₺)</label>
                                <InputNumber @bind-Value="editDegisim.Ucret" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="serbestNot" class="form-control" rows="2" />
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@kaydediliyor">
                                @if (kaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Kaydet
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showAracDetayModal && seciliAracDetay != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-truck me-2"></i>Lastik Detay - @seciliAracDetay.Plaka
                        <small class="text-muted ms-2">@seciliAracDetay.AracBilgisi</small>
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showAracDetayModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Anlik Takili Lastikler</h6>
                        <div class="d-flex align-items-center gap-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="detayTumGecmisChk"
                                       checked="@detayTumGecmis"
                                       @onchange="DetayKapsamiDegisti" />
                                <label class="form-check-label small" for="detayTumGecmisChk">
                                    Tum Gecmisi Goster
                                </label>
                            </div>
                            <button class="btn btn-sm btn-primary" @onclick="() => YeniDegisimAracIcin(seciliAracDetay.AracId)">
                                <i class="bi bi-plus-lg me-1"></i>Bu Arac Icin Yeni Degisim
                            </button>
                        </div>
                    </div>

                    @if (!seciliAracDetay.TakiliLastikler.Any())
                    {
                        <div class="alert alert-warning py-2">Bu araca takili aktif lastik kaydi yok.</div>
                    }
                    else
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Marka</th>
                                        <th>Ebat</th>
                                        <th>Sezon</th>
                                        <th>Seri No</th>
                                        <th>Durum</th>
                                        <th style="width:90px;">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in seciliAracDetay.TakiliLastikler)
                                    {
                                        <tr>
                                            <td>@s.Marka</td>
                                            <td>@s.Ebat</td>
                                            <td><span class="badge @GetSezonBadge(s.Sezon)">@GetSezonText(s.Sezon)</span></td>
                                            <td>@s.SeriNo</td>
                                            <td><span class="badge @GetDurumBadge(s.Durum)">@GetDurumText(s.Durum)</span></td>
                                            <td>
                                                <button class="btn btn-xs btn-outline-warning py-0 px-1" title="Bu lastiği değiştir"
                                                        @onclick="() => HizliDegisimAc(s)">
                                                    <i class="bi bi-arrow-repeat"></i> Değiştir
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Depodaki Lastikler -->
                    <h6 class="mb-2 mt-2">
                        <i class="bi bi-box-seam me-1"></i>Depodaki Kullanılabilir Lastikler
                        <span class="badge bg-secondary ms-1">@seciliAracDetay.DepoLastikler.Count(x => x.Durum == LastikDurum.Kullanilabilir)</span>
                    </h6>
                    @if (!seciliAracDetay.DepoLastikler.Any(x => x.Durum == LastikDurum.Kullanilabilir))
                    {
                        <div class="alert alert-secondary py-2 mb-2">Depoda kullanılabilir lastik bulunmuyor.</div>
                    }
                    else
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Marka</th>
                                        <th>Ebat</th>
                                        <th>Sezon</th>
                                        <th>Seri No</th>
                                        <th>Depo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in seciliAracDetay.DepoLastikler.Where(x => x.Durum == LastikDurum.Kullanilabilir))
                                    {
                                        <tr>
                                            <td>@d.Marka</td>
                                            <td>@d.Ebat</td>
                                            <td><span class="badge @GetSezonBadge(d.Sezon)">@GetSezonText(d.Sezon)</span></td>
                                            <td>@d.SeriNo</td>
                                            <td><small class="text-muted">@(d.Depo?.DepoAdi ?? "-")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <h6 class="mb-2 mt-3">Plaka Gecmisi (En son plaka ustte)</h6>
                    @if (!seciliAracDetay.PlakaGecmisi.Any())
                    {
                        <div class="alert alert-secondary py-2">Plaka gecmisi kaydi bulunamadi.</div>
                    }
                    else
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Plaka</th>
                                        <th>Giris</th>
                                        <th>Cikis</th>
                                        <th>Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in seciliAracDetay.PlakaGecmisi)
                                    {
                                        <tr>
                                            <td><strong>@p.Plaka</strong></td>
                                            <td>@p.GirisTarihi.ToString("dd.MM.yyyy")</td>
                                            <td>@(p.CikisTarihi.HasValue ? p.CikisTarihi.Value.ToString("dd.MM.yyyy") : "-")</td>
                                            <td>
                                                @if (p.Aktif)
                                                {
                                                    <span class="badge bg-success">Aktif</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Gecmis</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <h6 class="mb-2">
                        Degisim Hareketleri
                        @if (detayTumGecmis)
                        {
                            <span class="badge bg-info text-dark ms-1">Tum Gecmis</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-1">Donemsel</span>
                        }
                        <span class="badge bg-light text-dark border ms-1">@seciliAracDetay.Hareketler.Count kayit</span>
                    </h6>
                    @if (!seciliAracDetay.Hareketler.Any())
                    {
                        <div class="alert alert-info py-2 mb-0">@(detayTumGecmis ? "Bu arac icin hic hareket bulunamadi." : "Secili donemde hareket bulunamadi.")</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Tur</th>
                                        <th>KM</th>
                                        <th>Takilan</th>
                                        <th>Sokulen</th>
                                        <th>Yer</th>
                                        <th class="text-end">Ucret</th>
                                        <th style="width:70px;">Sil</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in seciliAracDetay.Hareketler)
                                    {
                                        <tr>
                                            <td>@h.Tarih.ToString("dd.MM.yyyy")</td>
                                            <td><span class="badge @GetTurBadge(h.DegisimTipi)">@GetTurText(h.DegisimTipi)</span></td>
                                            <td>@(h.KmDurumu.HasValue ? h.KmDurumu.Value.ToString("N0") : "-")</td>
                                            <td><small>@h.TakilanAciklama</small></td>
                                            <td><small>@h.SokulenAciklama</small></td>
                                            <td>@h.YapilanYer</td>
                                            <td class="text-end">@(h.Ucret.HasValue ? h.Ucret.Value.ToString("N2") + " ₺" : "-")</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnayById(h.DegisimId)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Hızlı Değişim Modal -->
@if (showHizliDegisimModal && hizliSokulenStok != null && seciliAracDetay != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.7); z-index: 1060;">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning-subtle">
                    <h5 class="modal-title">
                        <i class="bi bi-arrow-repeat me-2"></i>Hızlı Lastik Değişimi
                        <small class="text-muted ms-2">@seciliAracDetay.Plaka</small>
                    </h5>
                    <button type="button" class="btn-close" @onclick="HizliDegisimKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <!-- Sökülen lastik (bilgi) -->
                        <div class="col-12">
                            <div class="alert alert-warning py-2 mb-0">
                                <strong>Sökülecek Lastik:</strong>
                                @(hizliSokulenStok.Marka ?? "(Bilinmeyen)") — @hizliSokulenStok.Ebat
                                <span class="badge @GetSezonBadge(hizliSokulenStok.Sezon) ms-1">@GetSezonText(hizliSokulenStok.Sezon)</span>
                                @if (!string.IsNullOrWhiteSpace(hizliSokulenStok.SeriNo))
                                {
                                    <small class="text-muted ms-1">(@hizliSokulenStok.SeriNo)</small>
                                }
                            </div>
                        </div>

                        <!-- Takılan lastik seç -->
                        <div class="col-md-6">
                            <label class="form-label">Takılacak Lastik <small class="text-muted">(depoda)</small></label>
                            <select class="form-select form-select-sm" @bind="hizliTakilanStokId">
                                <option value="">— Seçiniz (takılacak lastik yok) —</option>
                                @foreach (var d in seciliAracDetay.DepoLastikler.Where(x => x.Durum == LastikDurum.Kullanilabilir))
                                {
                                    <option value="@d.Id">@(d.Marka ?? "(Bilinmeyen)") — @d.Ebat [@GetSezonText(d.Sezon)] @(d.Depo != null ? $"({d.Depo.DepoAdi})" : "")</option>
                                }
                            </select>
                        </div>

                        <!-- Sökülenin gideceği depo -->
                        <div class="col-md-6">
                            <label class="form-label">Sökülenin Gideceği Depo <small class="text-muted">(boş = kayıp)</small></label>
                            <select class="form-select form-select-sm" @bind="hizliHedefDepoId">
                                <option value="">— Kayıp / Belirsiz —</option>
                                @foreach (var dep in depolar)
                                {
                                    <option value="@dep.Id">@dep.DepoAdi</option>
                                }
                            </select>
                        </div>

                        <!-- Sökülenin akibeti -->
                        <div class="col-md-6">
                            <label class="form-label">Sökülenin Akibeti</label>
                            <select class="form-select form-select-sm" @bind="hizliAkibet">
                                <option value="depo">Depoda (kullanılabilir)</option>
                                <option value="tamir">Tamire gönderildi</option>
                                <option value="cop">Hurdaya çıkarıldı</option>
                            </select>
                        </div>

                        <!-- Değişim türü -->
                        <div class="col-md-4">
                            <label class="form-label">Değişim Türü</label>
                            <select class="form-select form-select-sm" @bind="hizliDegisimTipi">
                                <option value="@LastikDegisimTipi.Mevsimlik">Mevsimlik</option>
                                <option value="@LastikDegisimTipi.Periyodik">Periyodik</option>
                                <option value="@LastikDegisimTipi.Ariza">Arıza</option>
                                <option value="@LastikDegisimTipi.Diger">Diğer</option>
                            </select>
                        </div>

                        <!-- Tarih -->
                        <div class="col-md-4">
                            <label class="form-label">Tarih</label>
                            <input type="date" class="form-control form-control-sm"
                                   value="@hizliTarih.ToString("yyyy-MM-dd")"
                                   @onchange="e => hizliTarih = DateTime.TryParse(e.Value?.ToString(), out var d2) ? d2 : DateTime.Today" />
                        </div>

                        <!-- KM -->
                        <div class="col-md-4">
                            <label class="form-label">KM</label>
                            <input type="number" class="form-control form-control-sm" placeholder="KM durumu"
                                   @bind="hizliKm" @bind:event="oninput" />
                        </div>

                        <!-- Yapılan Yer -->
                        <div class="col-md-6">
                            <label class="form-label">Yapılan Yer</label>
                            <input type="text" class="form-control form-control-sm" placeholder="Servis adı / yer"
                                   @bind="hizliYer" @bind:event="oninput" />
                        </div>

                        <!-- Neden -->
                        <div class="col-md-6">
                            <label class="form-label">Değişim Nedeni <span class="text-danger">*</span></label>
                            <textarea class="form-control form-control-sm" rows="2" placeholder="Neden değiştiriliyor? (Mevsim geçişi, hasar, vb.)"
                                      @bind="hizliNeden" @bind:event="oninput"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="HizliDegisimKapat" disabled="@hizliKaydediliyor">İptal</button>
                    <button class="btn btn-warning btn-sm" @onclick="HizliDegisimKaydet" disabled="@(hizliKaydediliyor || string.IsNullOrWhiteSpace(hizliNeden))">
                        @if (hizliKaydediliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Değişimi Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onayı -->
@if (showDeleteModal && silinecek != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <strong>@silinecek.DegisimTarihi.ToString("dd.MM.yyyy")</strong> tarihli değişim kaydını silmek istediğinizden emin misiniz?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LastikDegisim>? degisimler;
    private List<Arac> araclar = new();
    private List<LastikDepo> depolar = new();
    private List<LastikStok> stoklar = new();
    private List<BankaHesap> bankaHesaplari = new();
    private List<LastikAracDonemOzet> aracDonemOzetleri = new();
    private LastikAracDetay? seciliAracDetay;
    private int? seciliAracDetayId;
    private bool detayTumGecmis = true;
    private LastikDegisim editDegisim = new();
    private LastikDegisim? silinecek;
    private bool showForm;
    private bool showDeleteModal;
    private bool showAracDetayModal;
    private bool kaydediliyor;

    // Form: araçta takılı lastikler (seçili araç için)
    private List<LastikStok> formAracTakiliLastikler = new();
    private List<LastikStok> formDepoLastikleri = new();

    // Hızlı değişim alanları
    private bool showHizliDegisimModal;
    private bool hizliKaydediliyor;
    private LastikStok? hizliSokulenStok;
    private int? hizliTakilanStokId;
    private int? hizliHedefDepoId;
    private string hizliAkibet = "depo";
    private DateTime hizliTarih = DateTime.Today;
    private int? hizliKm;
    private string hizliYer = string.Empty;
    private string hizliNeden = string.Empty;
    private LastikDegisimTipi hizliDegisimTipi = LastikDegisimTipi.Mevsimlik;
    private int? filtreAracId;
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private string degisimGirisSekli = "standart";
    private int degisimAdet = 4;
    private string serbestNot = string.Empty;
    private LastikDegisimSatinAlmaForm satinAlmaForm = new();
    private List<LastikDegisimSatirForm> degisimSatirlari = new();
    private int? ortakTakilanStokId;
    private int? ortakKaynakDepoId;
    private int? ortakHedefDepoId;
    private static readonly string[] StandartPozisyonlar = ["On Sol", "On Sag", "Arka Sol", "Arka Sag"];
    private string filtreBaslangicStr => filtreBaslangic?.ToString("yyyy-MM-dd") ?? string.Empty;
    private string filtreBitisStr => filtreBitis?.ToString("yyyy-MM-dd") ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetAllAsync();
        filtreliAraclar = araclar;
        formFiltreliAraclar = araclar;
        depolar = await LastikService.GetDepoListAsync();
        stoklar = await LastikService.GetStokListAsync();
        bankaHesaplari = await BankaHesapService.GetActiveAsync();
        degisimler = await LastikService.GetDegisimListAsync();
        HazirlaDegisimSatirlari(degisimAdet);
        await YukleAracDonemOzeti();
    }

    private string filtreAracArama = string.Empty;
    private bool filtreAracDropAcik = false;
    private List<Arac> filtreliAraclar = new();

    private void FiltreAracAramaGuncelle(ChangeEventArgs e)
    {
        filtreAracArama = e.Value?.ToString() ?? string.Empty;
        filtreliAraclar = string.IsNullOrWhiteSpace(filtreAracArama)
            ? araclar
            : araclar.Where(a =>
                (a.AktifPlaka?.Contains(filtreAracArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Marka?.Contains(filtreAracArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
