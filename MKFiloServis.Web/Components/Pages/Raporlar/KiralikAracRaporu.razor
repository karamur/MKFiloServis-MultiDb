@page "/rapor/kiralik-arac"
@using MKFiloServis.Web.Services
@using Models = MKFiloServis.Web.Models
@inject IMaliAnalizService MaliAnalizService
@rendermode InteractiveServer

<PageTitle>kiral©k Araç Raporu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-building me-2"></i>kiral©k Araç Raporu</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 120px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select" style="width: 150px;" @bind="secilenAy" @bind:after="YenileData">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <a href="/mali-analiz" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Dashboard
            </a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (rapor != null)
    {
        <!-- Özet -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h6 class="text-white-50">Müşteriden Al©nacak</h6>
                        <h3>@rapor.ToplamMusteriddenAlinacak.ToString("N0") ?</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center">
                        <h6 class="text-white-50">Firmaya ©denecek</h6>
                        <h3>@rapor.ToplamFirmayaOdenecek.ToString("N0") ?</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(rapor.NetKar >= 0 ? "bg-primary" : "bg-warning") text-white">
                    <div class="card-body text-center">
                        <h6 class="text-white-50">Net Kar</h6>
                        <h3>@rapor.NetKar.ToString("N0") ?</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h6 class="text-white-50">Toplam Sefer</h6>
                        <h3>@rapor.ToplamSefer</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Firma Bazl© Detaylar -->
        @foreach (var firma in rapor.FirmaDetaylari.OrderByDescending(f => f.Kar))
        {
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">
                            <i class="bi bi-building me-2"></i>@firma.FirmaUnvan
                            <small class="ms-2">(@firma.FirmaKodu)</small>
                        </h5>
                    </div>
                    <div class="text-end">
                        <span class="badge @(firma.Kar >= 0 ? "bg-success" : "bg-danger") fs-6">
                            Net Kar: @firma.Kar.ToString("N0") ?
                        </span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Araç Plaka</th>
                                    <th>Şoför</th>
                                    <th>Güzergah</th>
                                    <th>Müşteri</th>
                                    <th class="text-center">Sefer</th>
                                    <th class="text-end">Birim Fiyat</th>
                                    <th class="text-end">kira Bedeli</th>
                                    <th class="text-end text-success">Müşteriden</th>
                                    <th class="text-end text-danger">Firmaya</th>
                                    <th class="text-end">Kar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var arac in firma.AracDetaylari)
                                {
                                    @foreach (var guzergah in arac.GuzergahDetaylari)
                                    {
                                        <tr>
                                            <td><strong>@arac.Plaka</strong></td>
                                            <td>@arac.SoforAdSoyad</td>
                                            <td>@guzergah.GuzergahAdi</td>
                                            <td>@guzergah.MusteriUnvan</td>
                                            <td class="text-center">@guzergah.SeferSayisi</td>
                                            <td class="text-end">@guzergah.BirimFiyat.ToString("N0") ?</td>
                                            <td class="text-end">@guzergah.KiraBedeli.ToString("N0") ₺</td>
                                            <td class="text-end text-success">@guzergah.MusteridenAlinacak.ToString("N0") ?</td>
                                            <td class="text-end text-danger">@guzergah.FirmayaOdenecek.ToString("N0") ?</td>
                                            <td class="text-end">
                                                <strong class="@((guzergah.MusteridenAlinacak - guzergah.FirmayaOdenecek) >= 0 ? "text-success" : "text-danger")">
                                                    @((guzergah.MusteridenAlinacak - guzergah.FirmayaOdenecek).ToString("N0")) ?
                                                </strong>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot class="table-warning">
                                <tr>
                                    <th colspan="4">TOPLAM</th>
                                    <th class="text-center">@firma.ToplamSefer</th>
                                    <th></th>
                                    <th></th>
                                    <th class="text-end text-success">@firma.MusteriddenAlinacak.ToString("N0") ?</th>
                                    <th class="text-end text-danger">@firma.FirmayaOdenecek.ToString("N0") ?</th>
                                    <th class="text-end">
                                        <strong class="@(firma.Kar >= 0 ? "text-success" : "text-danger")">
                                            @firma.Kar.ToString("N0") ?
                                        </strong>
                                    </th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (!rapor.FirmaDetaylari.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>Bu d©nemde kiral©k Araç verisi bulunmuyor.
            </div>
        }
    }
</div>

@code {
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;
    private Models.KiralikAracRaporu? rapor;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await YenileData();
    }

    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            rapor = await MaliAnalizService.GetKiralikAracRaporuAsync(secilenYil, secilenAy);
        }
        finally
        {
            isLoading = false;
        }
    }
}












