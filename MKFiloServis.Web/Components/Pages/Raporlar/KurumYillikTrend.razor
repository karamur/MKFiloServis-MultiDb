@page "/raporlar/kurum-yillik-trend"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IServisCalismaService ServisCalismaService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Kurum Yıllık Trend</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-graph-up me-2 text-primary"></i>Kurum Yıllık Gelir Trendi</h2>
            <p class="text-muted mb-0">Firma bazında 12 aylık gelir karşılaştırması (servis çalışmalarından)</p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Yıl</label>
                    <select class="form-select form-select-sm" @bind="yil" @bind:after="LoadAsync">
                        @for (int y = DateTime.Today.Year - 3; y <= DateTime.Today.Year + 1; y++)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Karşılaştırma Yılı</label>
                    <select class="form-select form-select-sm" @bind="onceYil" @bind:after="LoadAsync">
                        <option value="0">— Yok —</option>
                        @for (int y = DateTime.Today.Year - 3; y <= DateTime.Today.Year + 1; y++)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Metrik</label>
                    <select class="form-select form-select-sm" @bind="metrik" @bind:after="ChartCiz">
                        <option value="tutar">Aylık Gelir (₺)</option>
                        <option value="sefer">Aylık Sefer Sayısı</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="cbBosGizle"
                               @bind="bosFirmaGizle" @bind:after="ChartCiz" />
                        <label class="form-check-label small" for="cbBosGizle">Sıfır firmaları gizle</label>
                    </div>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-outline-primary btn-sm w-100" @onclick="ExcelIndir" disabled="@yukleniyor">
                        <i class="bi bi-file-earmark-excel"></i> Excel
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="card"><div class="card-body p-4 text-center text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
        </div></div>
    }
    else
    {
        var matris = HesaplaMatris();
        var gosterilen = bosFirmaGizle ? matris.Where(m => m.Yillik > 0).ToList() : matris;

        <!-- Özet kartlar -->
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-primary shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Aktif Firma (@yil)</div>
                        <div class="fs-4 fw-bold text-primary">@gosterilen.Count(m => m.Yillik > 0)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Yıllık Toplam Sefer</div>
                        <div class="fs-4 fw-bold text-info">@gosterilen.Sum(m => m.AylikSefer.Sum())</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Yıllık Toplam Gelir</div>
                        <div class="fs-4 fw-bold text-success">@gosterilen.Sum(m => m.Yillik).ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Aylık Ortalama</div>
                        <div class="fs-4 fw-bold text-warning">@((gosterilen.Sum(m => m.Yillik) / 12m).ToString("N2")) ₺</div>
                    </div>
                </div>
            </div>
        </div>

        @if (onceYil > 0 && onceMatris.Any())
        {
            var oToplam = onceMatris.Sum(m => m.Yillik);
            var yToplam = matris.Sum(m => m.Yillik);
            var fark = yToplam - oToplam;
            var yuzde = oToplam > 0 ? (fark / oToplam * 100m) : 0m;
            var renkClass = fark >= 0 ? "text-success" : "text-danger";
            var icon = fark >= 0 ? "bi-arrow-up-right" : "bi-arrow-down-right";

            <div class="alert alert-light border mb-3 d-flex align-items-center justify-content-between">
                <div>
                    <i class="bi @icon @renkClass me-1"></i>
                    <strong>@yil</strong> vs <strong>@onceYil</strong>:
                    <span class="@renkClass fw-bold">@fark.ToString("N2") ₺ (@yuzde.ToString("N1")%)</span>
                </div>
                <small class="text-muted">@yil: @yToplam.ToString("N0") ₺ &nbsp;|&nbsp; @onceYil: @oToplam.ToString("N0") ₺</small>
            </div>
        }

        <!-- Grafikler -->
        <div class="row g-3 mb-3">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <strong><i class="bi bi-graph-up me-1"></i>Aylık Trend (Top @top firma)</strong>
                    </div>
                    <div class="card-body" style="height: 360px;">
                        <canvas id="kurumTrendChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <strong><i class="bi bi-bar-chart me-1"></i>Yıllık Toplam (Top @top)</strong>
                    </div>
                    <div class="card-body" style="height: 360px;">
                        <canvas id="kurumYillikChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Matris tablo -->
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between">
                <strong><i class="bi bi-table me-1"></i>Aylık Matris — @yil</strong>
                <span class="text-muted small">@gosterilen.Count firma</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="min-width:60px;">#</th>
                                <th style="min-width:220px;">Firma</th>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <th class="text-end" style="min-width:90px;">
                                        @(new DateTime(2000, m, 1).ToString("MMM", new CultureInfo("tr-TR")))
                                    </th>
                                }
                                <th class="text-end" style="min-width:110px;">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!gosterilen.Any())
                            {
                                <tr><td colspan="15" class="text-center text-muted p-4">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                    Bu yıl için kayıt bulunamadı.
                                </td></tr>
                            }
                            else
                            {
                                int sira = 1;
                                foreach (var f in gosterilen.OrderByDescending(x => x.Yillik).ThenBy(x => x.FirmaAdi))
                                {
                                    <tr>
                                        <td>@(sira++)</td>
                                        <td><strong>@f.FirmaAdi</strong></td>
                                        @for (int m = 0; m < 12; m++)
                                        {
                                            decimal v = metrik == "sefer" ? f.AylikSefer[m] : f.AylikTutar[m];
                                            <td class="text-end @(v > 0 ? "" : "text-muted")">
                                                @(v > 0 ? v.ToString("N2") : "-")
                                            </td>
                                        }
                                        <td class="text-end fw-bold text-success">
                                            @(metrik == "sefer" ? f.AylikSefer.Sum().ToString("N0") : f.Yillik.ToString("N2"))
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="2">TOPLAM</td>
                                @for (int m = 0; m < 12; m++)
                                {
                                    decimal sum = metrik == "sefer"
                                        ? gosterilen.Sum(x => (decimal)x.AylikSefer[m])
                                        : gosterilen.Sum(x => x.AylikTutar[m]);
                                    <td class="text-end">@(sum > 0 ? sum.ToString("N2") : "-")</td>
                                }
                                <td class="text-end text-success">
                                    @(metrik == "sefer"
                                        ? gosterilen.Sum(x => x.AylikSefer.Sum()).ToString("N0")
                                        : gosterilen.Sum(x => x.Yillik).ToString("N2"))
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-2 small text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Veri: <strong>ServisCalisma</strong> (iptal/yapılamayan hariç). Tutar = (Fiyat ?? Guzergah.BirimFiyat) × sefer çarpanı.
            Sefer: Sabah/Akşam = 1, SabahAksam = 2.
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private int yil = DateTime.Today.Year;
    private int onceYil = 0;
    private string metrik = "tutar";
    private bool bosFirmaGizle = true;
    private const int top = 8;

    private List<ServisCalisma> kayitlar = new();
    private List<ServisCalisma> onceKayitlar = new();
    private List<Firma> firmalar = new();
    private List<FirmaTrendRow> matrisCache = new();
    private List<FirmaTrendRow> onceMatris = new();
    private bool firstRenderDone = false;

    protected override async Task OnInitializedAsync()
    {
        try { firmalar = await FirmaService.GetAllAsync(); }
        catch { firmalar = new(); }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            var bas = new DateTime(yil, 1, 1);
            var bit = new DateTime(yil, 12, 31, 23, 59, 59);
            kayitlar = await ServisCalismaService.GetByDateRangeAsync(bas, bit);

            if (onceYil > 0 && onceYil != yil)
            {
                var b2 = new DateTime(onceYil, 1, 1);
                var s2 = new DateTime(onceYil, 12, 31, 23, 59, 59);
                onceKayitlar = await ServisCalismaService.GetByDateRangeAsync(b2, s2);
                onceMatris = HesaplaMatrisFromList(onceKayitlar);
            }
            else
            {
                onceKayitlar = new();
                onceMatris = new();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenemedi: {ex.Message}");
            kayitlar = new();
        }
        finally { yukleniyor = false; }

        if (firstRenderDone)
            await ChartCiz();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            firstRenderDone = true;
            await ChartCiz();
        }
    }

    private static int SeferSayisinaCevir(ServisTuru t) => t switch
    {
        ServisTuru.SabahAksam => 2,
        _ => 1
    };

    private record FirmaTrendRow(int FirmaId, string FirmaAdi, string FirmaKodu, decimal[] AylikTutar, int[] AylikSefer)
    {
        public decimal Yillik => AylikTutar.Sum();
    }

    private List<FirmaTrendRow> HesaplaMatris()
    {
        matrisCache = HesaplaMatrisFromList(kayitlar);
        return matrisCache;
    }

    private List<FirmaTrendRow> HesaplaMatrisFromList(List<ServisCalisma> liste)
    {
        var aktif = liste
            .Where(k => k.Durum != CalismaDurum.IptalEdildi && k.Durum != CalismaDurum.ArizaNedeniyleYapilamadi)
            .ToList();

        var gruplar = aktif
            .GroupBy(k => new
            {
                FirmaId = k.Guzergah?.FirmaId ?? 0,
                FirmaAdi = k.Guzergah?.Firma?.FirmaAdi ?? "(Firmasız)",
                FirmaKodu = k.Guzergah?.Firma?.FirmaKodu ?? ""
            })
            .ToList();

        var result = new List<FirmaTrendRow>();
        foreach (var g in gruplar)
        {
            var aylikT = new decimal[12];
            var aylikS = new int[12];
            foreach (var k in g)
            {
                int idx = k.CalismaTarihi.Month - 1;
                if (idx < 0 || idx > 11) continue;
                int sefer = SeferSayisinaCevir(k.ServisTuru);
                decimal birim = k.Fiyat ?? k.Guzergah?.BirimFiyat ?? 0m;
                aylikT[idx] += birim * sefer;
                aylikS[idx] += sefer;
            }
            result.Add(new FirmaTrendRow(g.Key.FirmaId, g.Key.FirmaAdi, g.Key.FirmaKodu, aylikT, aylikS));
        }
        return result;
    }

    private async Task ChartCiz()
    {
        if (!firstRenderDone || yukleniyor) return;
        try
        {
            var matris = HesaplaMatris();
            var aktif = matris.Where(m => m.Yillik > 0).ToList();
            var topN = aktif.OrderByDescending(m => m.Yillik).Take(top).ToList();

            var labels = Enumerable.Range(1, 12)
                .Select(m => new DateTime(2000, m, 1).ToString("MMM", new CultureInfo("tr-TR")))
                .ToArray();

            var datasets = topN.Select(f => new
            {
                label = f.FirmaAdi,
                data = (metrik == "sefer"
                    ? f.AylikSefer.Select(x => (decimal)x).ToArray()
                    : f.AylikTutar)
            }).ToArray();

            await JS.InvokeVoidAsync("filoKpiCharts.renderKurumTrend", "kurumTrendChart", labels, datasets);

            var barLabels = topN.Select(f => f.FirmaAdi).ToArray();
            var barData = topN.Select(f => metrik == "sefer" ? (decimal)f.AylikSefer.Sum() : f.Yillik).ToArray();
            await JS.InvokeVoidAsync("filoKpiCharts.renderKurumToplamBar", "kurumYillikChart", barLabels, barData);
        }
        catch
        {
            // Chart.js yüklenmemiş olabilir; sessiz geç.
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("filoKpiCharts.destroyAll"); } catch { }
    }

    private async Task ExcelIndir()
    {
        try
        {
            var matris = HesaplaMatris();
            if (bosFirmaGizle) matris = matris.Where(m => m.Yillik > 0).ToList();

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add($"Trend {yil}");

            ws.Cell(1, 1).Value = $"Kurum Yıllık Trend — {yil} ({(metrik == "sefer" ? "Sefer" : "Tutar")})";
            ws.Cell(1, 1).Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 13;
            ws.Range(1, 1, 1, 15).Merge();

            ws.Cell(3, 1).Value = "#";
            ws.Cell(3, 2).Value = "Firma Kodu";
            ws.Cell(3, 3).Value = "Firma Adı";
            for (int m = 1; m <= 12; m++)
                ws.Cell(3, 3 + m).Value = new DateTime(2000, m, 1).ToString("MMMM", new CultureInfo("tr-TR"));
            ws.Cell(3, 16).Value = "Toplam";

            var hr = ws.Range(3, 1, 3, 16);
            hr.Style.Font.Bold = true;
            hr.Style.Fill.BackgroundColor = XLColor.LightSteelBlue;

            int r = 4, sira = 1;
            foreach (var f in matris.OrderByDescending(x => x.Yillik).ThenBy(x => x.FirmaAdi))
            {
                ws.Cell(r, 1).Value = sira++;
                ws.Cell(r, 2).Value = f.FirmaKodu;
                ws.Cell(r, 3).Value = f.FirmaAdi;
                for (int m = 0; m < 12; m++)
                {
                    decimal v = metrik == "sefer" ? f.AylikSefer[m] : f.AylikTutar[m];
                    ws.Cell(r, 4 + m).Value = v;
                }
                ws.Cell(r, 16).Value = metrik == "sefer" ? f.AylikSefer.Sum() : f.Yillik;
                r++;
            }

            // Toplam satırı
            ws.Cell(r, 3).Value = "TOPLAM";
            for (int m = 0; m < 12; m++)
            {
                decimal sum = metrik == "sefer"
                    ? matris.Sum(x => (decimal)x.AylikSefer[m])
                    : matris.Sum(x => x.AylikTutar[m]);
                ws.Cell(r, 4 + m).Value = sum;
            }
            ws.Cell(r, 16).Value = metrik == "sefer"
                ? matris.Sum(x => x.AylikSefer.Sum())
                : matris.Sum(x => x.Yillik);
            ws.Range(r, 1, r, 16).Style.Font.Bold = true;
            ws.Range(r, 1, r, 16).Style.Fill.BackgroundColor = XLColor.LightYellow;

            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            wb.SaveAs(stream);
            var fileName = $"kurum_yillik_trend_{yil}_{metrik}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(stream.ToArray()));
            ToastService.ShowSuccess("Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel indirilemedi: {ex.GetBaseException().Message}");
        }
    }
}

