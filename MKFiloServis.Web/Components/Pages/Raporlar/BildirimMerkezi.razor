@page "/raporlar/bildirim-merkezi"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@inject IBelgeUyariService BelgeUyariService
@inject IFaturaService FaturaService
@inject ITasimaTedarikciService TedarikciService
@inject IKiralikPlakaTakipService KiralikService
@inject IServisCalismaService ServisCalismaService
@inject IOperasyonelHakedisService HakedisService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Bildirim Merkezi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-bell-fill me-2 text-warning"></i>Bildirim Merkezi
            </h2>
            <p class="text-muted mb-0">Tüm operasyonel ve finansal alarmlar tek akışta — öncelikli aksiyonlarınız</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync" disabled="@yukleniyor">
                <i class="bi bi-arrow-clockwise me-1"></i>Yenile
            </button>
            <button class="btn btn-success btn-sm" @onclick="ExcelIndir" disabled="@(!alarmlar.Any())">
                <i class="bi bi-file-earmark-excel-fill me-1"></i>Excel
            </button>
        </div>
    </div>

    <!-- ÖZET KARTLARI -->
    <div class="row g-2 mb-3">
        <div class="col-md-3">
            <div class="card border-danger bg-danger text-white">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small">Kritik (Süresi geçmiş)</div>
                            <h3 class="mb-0">@kritikSayi</h3>
                        </div>
                        <i class="bi bi-exclamation-octagon-fill" style="font-size:2rem;opacity:.6"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning bg-warning">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small">Acil (≤7 gün)</div>
                            <h3 class="mb-0">@acilSayi</h3>
                        </div>
                        <i class="bi bi-exclamation-triangle-fill" style="font-size:2rem;opacity:.6"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info bg-info text-white">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small">Uyarı (≤30 gün)</div>
                            <h3 class="mb-0">@uyariSayi</h3>
                        </div>
                        <i class="bi bi-info-circle-fill" style="font-size:2rem;opacity:.6"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small text-muted">Toplam Alarm</div>
                            <h3 class="mb-0">@alarmlar.Count</h3>
                        </div>
                        <i class="bi bi-bell" style="font-size:2rem;opacity:.4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FİLTRELER -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Kategori</label>
                    <select class="form-select form-select-sm" @bind="kategoriFiltre" @bind:after="FiltreUygula">
                        <option value="">Tümü</option>
                        <option value="Belge">Belge</option>
                        <option value="Sözleşme">Sözleşme</option>
                        <option value="Fatura">Fatura</option>
                        <option value="Operasyon">Operasyon</option>
                        <option value="Hakediş">Hakediş</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Seviye</label>
                    <select class="form-select form-select-sm" @bind="seviyeFiltre" @bind:after="FiltreUygula">
                        <option value="">Tümü</option>
                        <option value="Kritik">Kritik</option>
                        <option value="Acil">Acil</option>
                        <option value="Uyari">Uyarı</option>
                        <option value="Bilgi">Bilgi</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Arama</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Başlık / detay..." @bind="aramaMetni" @bind:after="FiltreUygula" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sırala</label>
                    <select class="form-select form-select-sm" @bind="siralamaTipi" @bind:after="FiltreUygula">
                        <option value="oncelik">Öncelik (Kritik üstte)</option>
                        <option value="tarih">Bitiş Tarihi</option>
                        <option value="kategori">Kategori</option>
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="FiltreSifirla">
                        <i class="bi bi-x-circle me-1"></i>Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Bildirimler toplanıyor...</p>
        </div>
    }
    else
    {
        <!-- KATEGORİ ÖZETİ -->
        <div class="card mb-3">
            <div class="card-header bg-light">
                <strong><i class="bi bi-pie-chart-fill me-2"></i>Kategori Dağılımı</strong>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    @foreach (var k in kategoriDagilim)
                    {
                        <div class="col">
                            <div class="card border-@k.Renk">
                                <div class="card-body p-2 text-center">
                                    <div class="small text-muted">@k.Ad</div>
                                    <h4 class="mb-0 text-@k.Renk">@k.Adet</h4>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ALARM LİSTESİ -->
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-list-ul me-2"></i>Bildirim Listesi</strong>
                <span class="badge bg-primary">@filtreliAlarmlar.Count / @alarmlar.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:90px">Seviye</th>
                                <th style="width:100px">Kategori</th>
                                <th>Başlık</th>
                                <th>Detay</th>
                                <th style="width:110px">Tarih</th>
                                <th class="text-end" style="width:110px">Kalan</th>
                                <th style="width:60px">Aksiyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in filtreliAlarmlar)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @SeviyeClass(a.Seviye)">
                                            <i class="bi @SeviyeIcon(a.Seviye) me-1"></i>@a.Seviye
                                        </span>
                                    </td>
                                    <td><span class="badge bg-secondary">@a.Kategori</span></td>
                                    <td><strong>@a.Baslik</strong></td>
                                    <td><small class="text-muted">@a.Detay</small></td>
                                    <td><small>@(a.Tarih?.ToString("dd.MM.yyyy") ?? "—")</small></td>
                                    <td class="text-end">
                                        @if (a.KalanGun.HasValue)
                                        {
                                            @if (a.KalanGun.Value < 0)
                                            {
                                                <span class="text-danger fw-bold">@(-a.KalanGun.Value) gün geçti</span>
                                            }
                                            else
                                            {
                                                <span class="@(a.KalanGun.Value <= 7 ? "text-warning fw-bold" : "")">@a.KalanGun.Value gün</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(a.DetayUrl))
                                        {
                                            <a href="@a.DetayUrl" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-arrow-right"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!filtreliAlarmlar.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-5">
                                        <i class="bi bi-check-circle-fill text-success" style="font-size:2rem"></i>
                                        <div class="mt-2">Aktif bildirim yok 🎉</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private string kategoriFiltre = "";
    private string seviyeFiltre = "";
    private string aramaMetni = "";
    private string siralamaTipi = "oncelik";

    private List<Alarm> alarmlar = new();
    private List<Alarm> filtreliAlarmlar = new();
    private List<KategoriOzet> kategoriDagilim = new();

    private int kritikSayi;
    private int acilSayi;
    private int uyariSayi;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        yukleniyor = true;
        try
        {
            var bugun = DateTime.Today;
            var liste = new List<Alarm>();

            // 1) Belge uyarıları
            try
            {
                var belge = await BelgeUyariService.GetBelgeUyarilarAsync(60);
                foreach (var u in belge.TumUyarilar)
                {
                    var sev = u.KalanGun < 0 ? "Kritik" : u.KalanGun <= 7 ? "Acil" : u.KalanGun <= 30 ? "Uyari" : "Bilgi";
                    var kategori = (u.BelgeTuru?.Contains("Sözleşme", StringComparison.OrdinalIgnoreCase) ?? false)
                                || u.Kaynak == "TasimaTedarikci" || u.Kaynak == "KiralikPlaka"
                        ? "Sözleşme" : "Belge";
                    liste.Add(new Alarm
                    {
                        Kategori = kategori,
                        Seviye = sev,
                        Baslik = u.Baslik,
                        Detay = $"{u.BelgeTuru}{(string.IsNullOrEmpty(u.TasimaTedarikciUnvan) ? "" : " • " + u.TasimaTedarikciUnvan)}",
                        Tarih = u.BitisTarihi,
                        KalanGun = u.KalanGun,
                        DetayUrl = u.DetayUrl
                    });
                }
            }
            catch { /* sessizce geç */ }

            // 2) Vade geçmiş / yaklaşan faturalar
            try
            {
                var faturalar = await FaturaService.GetOdenmemisFaturalarAsync();
                foreach (var f in faturalar.Where(x => x.VadeTarihi.HasValue))
                {
                    var kalan = (f.VadeTarihi!.Value.Date - bugun).Days;
                    if (kalan > 60) continue;
                    var sev = kalan < 0 ? "Kritik" : kalan <= 7 ? "Acil" : kalan <= 30 ? "Uyari" : "Bilgi";
                    var kalanTutar = f.KalanTutar > 0 ? f.KalanTutar : f.GenelToplam;
                    liste.Add(new Alarm
                    {
                        Kategori = "Fatura",
                        Seviye = sev,
                        Baslik = $"Fatura #{(string.IsNullOrEmpty(f.FaturaNo) ? f.Id.ToString() : f.FaturaNo)} — {f.Cari?.Unvan ?? f.Firma?.FirmaAdi ?? "-"}",
                        Detay = $"{kalanTutar.ToString("N2", new CultureInfo("tr-TR"))} ₺ • {f.FaturaTipi} • {f.Durum}",
                        Tarih = f.VadeTarihi,
                        KalanGun = kalan,
                        DetayUrl = "/finans/faturalar"
                    });
                }
            }
            catch { }

            // 3) Tedarikçi sözleşme bitişleri (belge servisi kapsamadıysa garanti)
            try
            {
                var tedarikciler = await TedarikciService.GetAllAsync(false);
                foreach (var t in tedarikciler.Where(x => x.SozlesmeBitisTarihi.HasValue))
                {
                    var kalan = (t.SozlesmeBitisTarihi!.Value.Date - bugun).Days;
                    if (kalan > 90) continue;
                    if (liste.Any(a => a.Kategori == "Sözleşme" && a.Baslik.Contains(t.Unvan, StringComparison.OrdinalIgnoreCase))) continue;
                    var sev = kalan < 0 ? "Kritik" : kalan <= 7 ? "Acil" : kalan <= 30 ? "Uyari" : "Bilgi";
                    liste.Add(new Alarm
                    {
                        Kategori = "Sözleşme",
                        Seviye = sev,
                        Baslik = $"Tedarikçi sözleşmesi: {t.Unvan}",
                        Detay = $"Sözleşme No: {t.SozlesmeNo ?? "—"}",
                        Tarih = t.SozlesmeBitisTarihi,
                        KalanGun = kalan,
                        DetayUrl = "/tedarikciler"
                    });
                }
            }
            catch { }

            // 4) Kiralık plaka sözleşme bitişleri
            try
            {
                var kiraliklar = await KiralikService.GetAllAsync();
                foreach (var k in kiraliklar)
                {
                    var kalan = (k.BitisTarihi.Date - bugun).Days;
                    if (kalan > 90) continue;
                    var sev = kalan < 0 ? "Kritik" : kalan <= 7 ? "Acil" : kalan <= 30 ? "Uyari" : "Bilgi";
                    liste.Add(new Alarm
                    {
                        Kategori = "Sözleşme",
                        Seviye = sev,
                        Baslik = $"Kiralık plaka: {k.Plaka} — {k.IsimSoyisim}",
                        Detay = $"{k.Toplam.ToString("N2", new CultureInfo("tr-TR"))} ₺ • {k.Periyot}",
                        Tarih = k.BitisTarihi,
                        KalanGun = kalan,
                        DetayUrl = "/kiralik-plaka-takip"
                    });
                }
            }
            catch { }

            // 5) Operasyon: son 7 gün arızalı seferler
            try
            {
                var seferler = await ServisCalismaService.GetAllAsync();
                var son7 = bugun.AddDays(-7);
                foreach (var s in seferler.Where(x => x.ArizaOlduMu && x.CalismaTarihi >= son7).OrderByDescending(x => x.CalismaTarihi).Take(20))
                {
                    liste.Add(new Alarm
                    {
                        Kategori = "Operasyon",
                        Seviye = "Acil",
                        Baslik = $"Arıza: {s.Arac?.AktifPlaka ?? "?"} — {s.CalismaTarihi:dd.MM.yyyy}",
                        Detay = string.IsNullOrEmpty(s.ArizaAciklamasi) ? "Açıklama yok" : s.ArizaAciklamasi,
                        Tarih = s.CalismaTarihi,
                        KalanGun = (s.CalismaTarihi.Date - bugun).Days,
                        DetayUrl = "/servis-calismalar"
                    });
                }
            }
            catch { }

            // 6) Hakediş: önceki ayda taslak (onay bekleyen)
            try
            {
                var oncekiAy = bugun.AddMonths(-1);
                var hakedisler = await HakedisService.GetHakedislerAsync(oncekiAy.Year, oncekiAy.Month);
                foreach (var h in hakedisler.Where(x => x.Durum == HakedisDurum.Taslak).Take(20))
                {
                    liste.Add(new Alarm
                    {
                        Kategori = "Hakediş",
                        Seviye = "Uyari",
                        Baslik = $"Taslak hakediş: {h.Tip} #{h.ReferansId}",
                        Detay = $"{new DateTime(h.Yil, h.Ay, 1):MMM yyyy} • {h.GenelToplam.ToString("N2", new CultureInfo("tr-TR"))} ₺ • Onay bekliyor",
                        Tarih = h.CreatedAt,
                        KalanGun = null,
                        DetayUrl = "/operasyonel-hakedis"
                    });
                }
                // Onaylanmış ama faturalanmamış
                foreach (var h in hakedisler.Where(x => x.Durum == HakedisDurum.Onaylandi && x.FaturaId == null).Take(20))
                {
                    liste.Add(new Alarm
                    {
                        Kategori = "Hakediş",
                        Seviye = "Acil",
                        Baslik = $"Faturalanmamış hakediş: {h.Tip} #{h.ReferansId}",
                        Detay = $"{new DateTime(h.Yil, h.Ay, 1):MMM yyyy} • {h.GenelToplam.ToString("N2", new CultureInfo("tr-TR"))} ₺",
                        Tarih = h.OnayTarihi ?? h.CreatedAt,
                        KalanGun = null,
                        DetayUrl = "/operasyonel-hakedis"
                    });
                }
            }
            catch { }

            alarmlar = liste;

            kritikSayi = alarmlar.Count(x => x.Seviye == "Kritik");
            acilSayi = alarmlar.Count(x => x.Seviye == "Acil");
            uyariSayi = alarmlar.Count(x => x.Seviye == "Uyari");

            kategoriDagilim = alarmlar.GroupBy(x => x.Kategori)
                .Select(g => new KategoriOzet
                {
                    Ad = g.Key,
                    Adet = g.Count(),
                    Renk = g.Any(x => x.Seviye == "Kritik") ? "danger"
                          : g.Any(x => x.Seviye == "Acil") ? "warning"
                          : g.Any(x => x.Seviye == "Uyari") ? "info" : "secondary"
                }).OrderByDescending(x => x.Adet).ToList();

            FiltreUygula();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Yükleme hatası: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void FiltreUygula()
    {
        IEnumerable<Alarm> q = alarmlar;
        if (!string.IsNullOrEmpty(kategoriFiltre)) q = q.Where(x => x.Kategori == kategoriFiltre);
        if (!string.IsNullOrEmpty(seviyeFiltre)) q = q.Where(x => x.Seviye == seviyeFiltre);
        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            var k = aramaMetni.Trim().ToLowerInvariant();
            q = q.Where(x => x.Baslik.ToLowerInvariant().Contains(k)
                          || (x.Detay?.ToLowerInvariant().Contains(k) ?? false));
        }
        q = siralamaTipi switch
        {
            "tarih" => q.OrderBy(x => x.Tarih ?? DateTime.MaxValue),
            "kategori" => q.OrderBy(x => x.Kategori).ThenBy(x => SeviyeSira(x.Seviye)),
            _ => q.OrderBy(x => SeviyeSira(x.Seviye)).ThenBy(x => x.KalanGun ?? int.MaxValue)
        };
        filtreliAlarmlar = q.ToList();
    }

    private void FiltreSifirla()
    {
        kategoriFiltre = "";
        seviyeFiltre = "";
        aramaMetni = "";
        siralamaTipi = "oncelik";
        FiltreUygula();
    }

    private static int SeviyeSira(string s) => s switch
    {
        "Kritik" => 0,
        "Acil" => 1,
        "Uyari" => 2,
        _ => 3
    };

    private string SeviyeClass(string s) => s switch
    {
        "Kritik" => "bg-danger",
        "Acil" => "bg-warning text-dark",
        "Uyari" => "bg-info",
        _ => "bg-secondary"
    };

    private string SeviyeIcon(string s) => s switch
    {
        "Kritik" => "bi-exclamation-octagon-fill",
        "Acil" => "bi-exclamation-triangle-fill",
        "Uyari" => "bi-info-circle-fill",
        _ => "bi-info-circle"
    };

    private async Task ExcelIndir()
    {
        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Bildirimler");
            string[] headers = { "Seviye", "Kategori", "Başlık", "Detay", "Tarih", "Kalan Gün" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int row = 2;
            foreach (var a in filtreliAlarmlar)
            {
                ws.Cell(row, 1).Value = a.Seviye;
                ws.Cell(row, 2).Value = a.Kategori;
                ws.Cell(row, 3).Value = a.Baslik;
                ws.Cell(row, 4).Value = a.Detay ?? "";
                if (a.Tarih.HasValue) ws.Cell(row, 5).Value = a.Tarih.Value;
                if (a.KalanGun.HasValue) ws.Cell(row, 6).Value = a.KalanGun.Value;
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            await JS.InvokeVoidAsync("downloadFileFromBytes",
                $"Bildirim_Merkezi_{DateTime.Today:yyyyMMdd}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(ms.ToArray()));
            ToastService.ShowSuccess("Excel indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel hatası: {ex.Message}");
        }
    }

    private class Alarm
    {
        public string Kategori { get; set; } = "";
        public string Seviye { get; set; } = "Bilgi";
        public string Baslik { get; set; } = "";
        public string? Detay { get; set; }
        public DateTime? Tarih { get; set; }
        public int? KalanGun { get; set; }
        public string? DetayUrl { get; set; }
    }

    private class KategoriOzet
    {
        public string Ad { get; set; } = "";
        public int Adet { get; set; }
        public string Renk { get; set; } = "secondary";
    }
}

