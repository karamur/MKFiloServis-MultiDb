@page "/raporlar/vade-risk-merkezi"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IBelgeUyariService BelgeUyariService
@inject IToastService ToastService
@inject NavigationManager Nav
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Vade Risk Merkezi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-shield-exclamation me-2 text-danger"></i>Vade Risk Komuta Merkezi</h2>
            <p class="text-muted mb-0">Tüm belge & vade uyarıları tek panelde — risk piramidi, kategori dağılımı, kritik liste</p>
        </div>
        <div class="d-flex gap-2">
            <a href="raporlar/belge-uyarilari" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-list-ul me-1"></i>Klasik Görünüm
            </a>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Bakış Penceresi</label>
                    <select class="form-select form-select-sm" @bind="ufukGun" @bind:after="LoadAsync">
                        <option value="7">7 gün</option>
                        <option value="15">15 gün</option>
                        <option value="30">30 gün</option>
                        <option value="60">60 gün</option>
                        <option value="90">90 gün</option>
                        <option value="180">180 gün</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Risk Seviyesi</label>
                    <select class="form-select form-select-sm" @bind="seviyeFiltre" @bind:after="ChartCiz">
                        <option value="-1">Tümü</option>
                        <option value="3">Sadece Kritik (geçmiş)</option>
                        <option value="2">Acil (≤7 gün)</option>
                        <option value="1">Uyarı (≤30 gün)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Kaynak</label>
                    <select class="form-select form-select-sm" @bind="kaynakFiltre" @bind:after="ChartCiz">
                        <option value="">Tümü</option>
                        @foreach (var k in TumKaynaklar())
                        {
                            <option value="@k">@k</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Arama</label>
                    <input type="text" class="form-control form-control-sm"
                           placeholder="başlık / tedarikçi..."
                           @bind="arama" @bind:event="oninput" @bind:after="ChartCiz" />
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-outline-primary btn-sm w-100" @onclick="ExcelIndir" disabled="@yukleniyor">
                        <i class="bi bi-file-earmark-excel"></i> Excel
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="card"><div class="card-body p-4 text-center text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
        </div></div>
    }
    else if (ozet == null)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i>Veri bulunamadı.
        </div>
    }
    else
    {
        var hepsi = ozet.TumUyarilar;
        var filtreli = FiltreUygula(hepsi);

        // Risk seviyeleri
        int kritik = filtreli.Count(u => u.Seviye == BelgeUyariSeviye.Kritik);
        int acil = filtreli.Count(u => u.Seviye == BelgeUyariSeviye.Acil);
        int uyari = filtreli.Count(u => u.Seviye == BelgeUyariSeviye.Uyari);
        int bilgi = filtreli.Count(u => u.Seviye == BelgeUyariSeviye.Bilgi);

        <!-- Risk Piramidi (4 büyük kart) -->
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-danger shadow @(kritik > 0 ? "bg-danger bg-opacity-10" : "")"
                     style="cursor:pointer" @onclick="@(() => HizliFiltre(3))">
                    <div class="card-body py-3 text-center">
                        <i class="bi bi-exclamation-octagon-fill text-danger" style="font-size:2rem;"></i>
                        <div class="text-muted small mt-1">KRİTİK (Süresi Geçmiş)</div>
                        <div class="display-6 fw-bold text-danger">@kritik</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning shadow @(acil > 0 ? "bg-warning bg-opacity-10" : "")"
                     style="cursor:pointer" @onclick="@(() => HizliFiltre(2))">
                    <div class="card-body py-3 text-center">
                        <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size:2rem;"></i>
                        <div class="text-muted small mt-1">ACİL (≤7 gün)</div>
                        <div class="display-6 fw-bold text-warning">@acil</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info shadow @(uyari > 0 ? "bg-info bg-opacity-10" : "")"
                     style="cursor:pointer" @onclick="@(() => HizliFiltre(1))">
                    <div class="card-body py-3 text-center">
                        <i class="bi bi-info-circle-fill text-info" style="font-size:2rem;"></i>
                        <div class="text-muted small mt-1">UYARI (≤30 gün)</div>
                        <div class="display-6 fw-bold text-info">@uyari</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-secondary shadow"
                     style="cursor:pointer" @onclick="@(() => HizliFiltre(-1))">
                    <div class="card-body py-3 text-center">
                        <i class="bi bi-clock-history text-secondary" style="font-size:2rem;"></i>
                        <div class="text-muted small mt-1">İLERİ TAKİP</div>
                        <div class="display-6 fw-bold text-secondary">@bilgi</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grafikler -->
        <div class="row g-3 mb-3">
            <div class="col-lg-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light">
                        <strong><i class="bi bi-pie-chart me-1"></i>Belge Türü Dağılımı</strong>
                    </div>
                    <div class="card-body" style="height: 320px;">
                        <canvas id="vadeKategoriChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light">
                        <strong><i class="bi bi-bar-chart me-1"></i>Vade Pencereleri (Belge Sayısı)</strong>
                    </div>
                    <div class="card-body" style="height: 320px;">
                        <canvas id="vadePencereChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Üst Riskli Tedarikçiler -->
        @if (TedarikciRiskHesapla(filtreli) is { Count: > 0 } tedRiskListe)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-light">
                    <strong><i class="bi bi-truck me-1"></i>En Riskli Tedarikçiler (Top 5)</strong>
                </div>
                <div class="card-body p-2">
                    <div class="row g-2">
                        @foreach (var t in tedRiskListe)
                        {
                            <div class="col-md-4 col-lg-2 col-xl">
                                <div class="border rounded p-2 h-100">
                                    <div class="small fw-semibold text-truncate" title="@t.Ad">@t.Ad</div>
                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <span class="badge bg-danger">@t.Kritik kritik</span>
                                        <span class="badge bg-secondary">@t.Sayi toplam</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Liste -->
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-table me-1"></i>Vade Listesi</strong>
                <span class="text-muted small">@filtreli.Count satır</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 600px;">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="min-width:60px;">Seviye</th>
                                <th style="min-width:120px;">Kaynak</th>
                                <th style="min-width:140px;">Belge Türü</th>
                                <th style="min-width:240px;">Başlık</th>
                                <th style="min-width:140px;">Tedarikçi</th>
                                <th class="text-center" style="min-width:110px;">Bitiş</th>
                                <th class="text-center" style="min-width:90px;">Kalan Gün</th>
                                <th style="min-width:80px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filtreli.Any())
                            {
                                <tr><td colspan="8" class="text-center text-muted p-4">
                                    <i class="bi bi-check-circle fs-3 d-block mb-2 text-success"></i>
                                    Filtreye uyan vade kaydı yok. 👌
                                </td></tr>
                            }
                            else
                            {
                                foreach (var u in filtreli.OrderBy(x => x.KalanGun))
                                {
                                    <tr class="@(u.Seviye == BelgeUyariSeviye.Kritik ? "table-danger" : (u.Seviye == BelgeUyariSeviye.Acil ? "table-warning" : ""))">
                                        <td>
                                            <span class="badge @u.SeviyeClass">
                                                <i class="bi @u.Icon me-1"></i>@u.Seviye
                                            </span>
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@u.Kaynak</span></td>
                                        <td>@u.BelgeTuru</td>
                                        <td>
                                            <strong>@u.Baslik</strong>
                                        </td>
                                        <td class="small text-muted">@(u.TasimaTedarikciUnvan ?? "-")</td>
                                        <td class="text-center">@u.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                        <td class="text-center">
                                            @if (u.KalanGun < 0)
                                            {
                                                <span class="text-danger fw-bold">@Math.Abs(u.KalanGun) gün geçti</span>
                                            }
                                            else if (u.KalanGun == 0)
                                            {
                                                <span class="text-danger fw-bold">BUGÜN</span>
                                            }
                                            else
                                            {
                                                <span class="@(u.KalanGun <= 7 ? "text-warning fw-semibold" : "")">@u.KalanGun</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(u.DetayUrl))
                                            {
                                                <a href="@u.DetayUrl" class="btn btn-sm btn-outline-primary py-0 px-1" title="Detay">
                                                    <i class="bi bi-arrow-right-short"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-2 small text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Veri kaynağı: <code>IBelgeUyariService.GetBelgeUyarilarAsync(@ufukGun)</code>.
            Seviye: Kritik (geçmiş) · Acil (≤7g) · Uyarı (≤30g) · Bilgi (>30g).
            Üstteki kartlara tıklayarak hızlı filtreleyebilirsiniz.
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private int ufukGun = 30;
    private int seviyeFiltre = -1;
    private string kaynakFiltre = "";
    private string arama = "";
    private BelgeUyariOzet? ozet;
    private bool firstRenderDone = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private record TedarikciRiskRow(string Ad, int Sayi, int Kritik);

    private List<TedarikciRiskRow> TedarikciRiskHesapla(List<BelgeUyari> liste)
    {
        return liste
            .Where(u => u.TasimaTedarikciId.HasValue)
            .GroupBy(u => new { u.TasimaTedarikciId, u.TasimaTedarikciUnvan })
            .Select(g => new TedarikciRiskRow(
                g.Key.TasimaTedarikciUnvan ?? $"#{g.Key.TasimaTedarikciId}",
                g.Count(),
                g.Count(x => x.Seviye == BelgeUyariSeviye.Kritik)))
            .OrderByDescending(x => x.Kritik)
            .ThenByDescending(x => x.Sayi)
            .Take(5)
            .ToList();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            ozet = await BelgeUyariService.GetBelgeUyarilarAsync(ufukGun);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Vade verisi yüklenemedi: {ex.Message}");
            ozet = null;
        }
        finally { yukleniyor = false; }

        if (firstRenderDone)
            await ChartCiz();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            firstRenderDone = true;
            await ChartCiz();
        }
    }

    private void HizliFiltre(int seviye)
    {
        seviyeFiltre = seviye;
        _ = ChartCiz();
        StateHasChanged();
    }

    private List<string> TumKaynaklar()
    {
        if (ozet == null) return new();
        return ozet.TumUyarilar
            .Select(u => u.Kaynak)
            .Where(k => !string.IsNullOrWhiteSpace(k))
            .Distinct()
            .OrderBy(k => k)
            .ToList();
    }

    private List<BelgeUyari> FiltreUygula(List<BelgeUyari> liste)
    {
        IEnumerable<BelgeUyari> q = liste;
        if (seviyeFiltre >= 0)
            q = q.Where(u => (int)u.Seviye == seviyeFiltre);
        if (!string.IsNullOrWhiteSpace(kaynakFiltre))
            q = q.Where(u => u.Kaynak == kaynakFiltre);
        if (!string.IsNullOrWhiteSpace(arama))
        {
            var a = arama.Trim().ToLowerInvariant();
            q = q.Where(u =>
                (u.Baslik ?? "").ToLowerInvariant().Contains(a) ||
                (u.BelgeTuru ?? "").ToLowerInvariant().Contains(a) ||
                (u.TasimaTedarikciUnvan ?? "").ToLowerInvariant().Contains(a));
        }
        return q.ToList();
    }

    private async Task ChartCiz()
    {
        if (!firstRenderDone || yukleniyor || ozet == null) return;
        try
        {
            var filtreli = FiltreUygula(ozet.TumUyarilar);

            // Kategori dağılımı (BelgeTuru bazlı)
            var katGrup = filtreli
                .GroupBy(u => string.IsNullOrWhiteSpace(u.BelgeTuru) ? u.Kaynak : u.BelgeTuru)
                .Select(g => new { Ad = g.Key, Sayi = g.Count() })
                .OrderByDescending(x => x.Sayi)
                .Take(10)
                .ToList();
            var katLabels = katGrup.Select(x => x.Ad).ToArray();
            var katData = katGrup.Select(x => (decimal)x.Sayi).ToArray();
            await JS.InvokeVoidAsync("filoKpiCharts.renderVadeKategori", "vadeKategoriChart", katLabels, katData);

            // Vade pencereleri (5 grup)
            int gecmis = filtreli.Count(u => u.KalanGun < 0);
            int g7 = filtreli.Count(u => u.KalanGun >= 0 && u.KalanGun <= 7);
            int g15 = filtreli.Count(u => u.KalanGun > 7 && u.KalanGun <= 15);
            int g30 = filtreli.Count(u => u.KalanGun > 15 && u.KalanGun <= 30);
            int g60 = filtreli.Count(u => u.KalanGun > 30 && u.KalanGun <= 60);
            int g90 = filtreli.Count(u => u.KalanGun > 60 && u.KalanGun <= 90);
            int gIleri = filtreli.Count(u => u.KalanGun > 90);

            var pLabels = new[] { "Süresi Geçmiş", "0-7 gün", "8-15 gün", "16-30 gün", "31-60 gün", "61-90 gün", "90+ gün" };
            var pData = new[] { (decimal)gecmis, g7, g15, g30, g60, g90, gIleri };
            await JS.InvokeVoidAsync("filoKpiCharts.renderVadePencere", "vadePencereChart", pLabels, pData);
        }
        catch
        {
            // chart.js yüklü değilse sessiz geç
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("filoKpiCharts.destroyAll"); } catch { }
    }

    private async Task ExcelIndir()
    {
        if (ozet == null) return;
        try
        {
            var filtreli = FiltreUygula(ozet.TumUyarilar);

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Vade Risk");

            ws.Cell(1, 1).Value = $"Vade Risk Merkezi — {DateTime.Today:dd.MM.yyyy} (Pencere: {ufukGun} gün)";
            ws.Cell(1, 1).Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 13;
            ws.Range(1, 1, 1, 8).Merge();

            string[] basliklar = { "Seviye", "Kaynak", "Belge Türü", "Başlık", "Tedarikçi", "Bitiş", "Kalan Gün", "Detay URL" };
            for (int i = 0; i < basliklar.Length; i++)
                ws.Cell(3, i + 1).Value = basliklar[i];
            var hr = ws.Range(3, 1, 3, basliklar.Length);
            hr.Style.Font.Bold = true;
            hr.Style.Fill.BackgroundColor = XLColor.LightSteelBlue;

            int r = 4;
            foreach (var u in filtreli.OrderBy(x => x.KalanGun))
            {
                ws.Cell(r, 1).Value = u.Seviye.ToString();
                ws.Cell(r, 2).Value = u.Kaynak;
                ws.Cell(r, 3).Value = u.BelgeTuru;
                ws.Cell(r, 4).Value = u.Baslik;
                ws.Cell(r, 5).Value = u.TasimaTedarikciUnvan ?? "";
                ws.Cell(r, 6).Value = u.BitisTarihi;
                ws.Cell(r, 6).Style.DateFormat.Format = "dd.MM.yyyy";
                ws.Cell(r, 7).Value = u.KalanGun;
                ws.Cell(r, 8).Value = u.DetayUrl;

                if (u.Seviye == BelgeUyariSeviye.Kritik)
                {
                    ws.Range(r, 1, r, 8).Style.Fill.BackgroundColor = XLColor.LightPink;
                    ws.Range(r, 1, r, 8).Style.Font.FontColor = XLColor.DarkRed;
                }
                else if (u.Seviye == BelgeUyariSeviye.Acil)
                {
                    ws.Range(r, 1, r, 8).Style.Fill.BackgroundColor = XLColor.LightYellow;
                }
                r++;
            }

            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(3);

            // Sayfa 2: Pencere özeti
            var ws2 = wb.Worksheets.Add("Pencere Ozeti");
            int gecmis = filtreli.Count(u => u.KalanGun < 0);
            int g7 = filtreli.Count(u => u.KalanGun >= 0 && u.KalanGun <= 7);
            int g15 = filtreli.Count(u => u.KalanGun > 7 && u.KalanGun <= 15);
            int g30 = filtreli.Count(u => u.KalanGun > 15 && u.KalanGun <= 30);
            int g60 = filtreli.Count(u => u.KalanGun > 30 && u.KalanGun <= 60);
            int g90 = filtreli.Count(u => u.KalanGun > 60 && u.KalanGun <= 90);
            int gIleri = filtreli.Count(u => u.KalanGun > 90);

            ws2.Cell(1, 1).Value = "Vade Penceresi";
            ws2.Cell(1, 2).Value = "Sayı";
            ws2.Range(1, 1, 1, 2).Style.Font.Bold = true;
            ws2.Cell(2, 1).Value = "Süresi Geçmiş"; ws2.Cell(2, 2).Value = gecmis;
            ws2.Cell(3, 1).Value = "0-7 gün"; ws2.Cell(3, 2).Value = g7;
            ws2.Cell(4, 1).Value = "8-15 gün"; ws2.Cell(4, 2).Value = g15;
            ws2.Cell(5, 1).Value = "16-30 gün"; ws2.Cell(5, 2).Value = g30;
            ws2.Cell(6, 1).Value = "31-60 gün"; ws2.Cell(6, 2).Value = g60;
            ws2.Cell(7, 1).Value = "61-90 gün"; ws2.Cell(7, 2).Value = g90;
            ws2.Cell(8, 1).Value = "90+ gün"; ws2.Cell(8, 2).Value = gIleri;
            ws2.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            wb.SaveAs(stream);
            var fileName = $"vade_risk_merkezi_{DateTime.Today:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(stream.ToArray()));
            ToastService.ShowSuccess("Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel indirilemedi: {ex.GetBaseException().Message}");
        }
    }
}

