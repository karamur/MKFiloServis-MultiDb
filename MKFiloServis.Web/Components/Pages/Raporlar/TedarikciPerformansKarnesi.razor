@page "/raporlar/tedarikci-performans-karnesi"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IServisCalismaService ServisCalismaService
@inject ITasimaTedarikciService TedarikciService
@inject IAracService AracService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Tedarikçi Performans Karnesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-award-fill me-2 text-primary"></i>Tedarikçi Performans Karnesi</h2>
            <p class="text-muted mb-0">Sefer + tamamlanma + arıza + iptal + maliyet bazlı tedarikçi skorları</p>
        </div>
        <div>
            <button class="btn btn-success btn-sm" @onclick="ExcelIndir" disabled="@(!satirlar.Any())">
                <i class="bi bi-file-earmark-excel-fill me-1"></i>Excel
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="basTarih" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="bitTarih" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Hızlı Seçim</label>
                    <div class="btn-group btn-group-sm w-100" role="group">
                        <button class="btn btn-outline-secondary" @onclick='() => HizliSecim("buAy")'>Bu Ay</button>
                        <button class="btn btn-outline-secondary" @onclick='() => HizliSecim("oncekiAy")'>Önceki Ay</button>
                        <button class="btn btn-outline-secondary" @onclick='() => HizliSecim("sonCeyrek")'>Son 3 Ay</button>
                        <button class="btn btn-outline-secondary" @onclick='() => HizliSecim("buYil")'>Bu Yıl</button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sıralama</label>
                    <select class="form-select form-select-sm" @bind="siralamaModu" @bind:after="ChartCiz">
                        <option value="skor">Skor</option>
                        <option value="sefer">Sefer</option>
                        <option value="maliyet">Maliyet</option>
                        <option value="ariza">Arıza %</option>
                        <option value="tamamlanma">Tamamlanma %</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="cbBosGizle" @bind="bosGizle" @bind:after="ChartCiz" />
                        <label class="form-check-label small" for="cbBosGizle">Sıfır seferli gizle</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Tedarikçi performansı hesaplanıyor...</p>
        </div>
    }
    else
    {
        <!-- ÖZET -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body py-3">
                        <div class="text-muted small">Aktif Tedarikçi</div>
                        <h4 class="mb-0">@aktifTedarikciSayisi <small class="text-muted">/ @toplamTedarikciSayisi</small></h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body py-3">
                        <div class="text-muted small">Toplam Sefer</div>
                        <h4 class="mb-0">@toplamSefer.ToString("N0")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body py-3">
                        <div class="text-muted small">Toplam Maliyet</div>
                        <h4 class="mb-0">@toplamMaliyet.ToString("N0") ₺</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body py-3">
                        <div class="text-muted small">Ortalama Arıza</div>
                        <h4 class="mb-0">%@ortArizaOran.ToString("N1")</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- TOP 3 -->
        @if (siraliSatirlar.Any(x => x.ToplamSefer > 0))
        {
            <div class="row g-3 mb-3">
                @foreach (var (s, idx) in siraliSatirlar.Where(x => x.ToplamSefer > 0).Take(3).Select((s, i) => (s, i)))
                {
                    var renk = idx == 0 ? "warning" : idx == 1 ? "secondary" : "info";
                    var madalya = idx == 0 ? "🥇" : idx == 1 ? "🥈" : "🥉";
                    <div class="col-md-4">
                        <div class="card border-@renk shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="small text-muted">@madalya #@(idx + 1)</div>
                                        <h5 class="mb-1">@s.TedarikciUnvan</h5>
                                        <small class="text-muted">@s.TedarikciKodu</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="display-6 text-@SkorRenk(s.Skor)">@s.Skor.ToString("N0")</div>
                                        <small class="text-muted">/ 100</small>
                                    </div>
                                </div>
                                <hr class="my-2" />
                                <div class="row text-center small">
                                    <div class="col-4">
                                        <div class="text-muted">Sefer</div>
                                        <strong>@s.ToplamSefer</strong>
                                    </div>
                                    <div class="col-4">
                                        <div class="text-muted">Tamamlanma</div>
                                        <strong>%@s.TamamlanmaOran.ToString("N1")</strong>
                                    </div>
                                    <div class="col-4">
                                        <div class="text-muted">Arıza</div>
                                        <strong>%@s.ArizaOran.ToString("N1")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- GRAFİKLER -->
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-light"><strong>Performans Skoru</strong></div>
                    <div class="card-body" style="height: 320px;">
                        <canvas id="tedarikciSkorChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-light"><strong>Sefer Dağılımı</strong></div>
                    <div class="card-body" style="height: 320px;">
                        <canvas id="tedarikciSeferChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- TABLO -->
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-table me-2"></i>Tedarikçi Detay Karneleri</strong>
                <span class="badge bg-primary">@siraliSatirlar.Count tedarikçi</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Kod</th>
                                <th>Tedarikçi</th>
                                <th class="text-center">Araç</th>
                                <th class="text-center">Şoför</th>
                                <th class="text-end">Sefer</th>
                                <th class="text-end">Tamam</th>
                                <th class="text-end">Arıza</th>
                                <th class="text-end">İptal</th>
                                <th class="text-end">Tamamlanma %</th>
                                <th class="text-end">Arıza %</th>
                                <th class="text-end">KM</th>
                                <th class="text-end">Maliyet</th>
                                <th class="text-end">Sefer Başı</th>
                                <th class="text-center">Skor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (s, i) in siraliSatirlar.Select((s, i) => (s, i)))
                            {
                                <tr class="@(s.ToplamSefer == 0 ? "text-muted" : "")">
                                    <td>@(i + 1)</td>
                                    <td><small>@s.TedarikciKodu</small></td>
                                    <td><strong>@s.TedarikciUnvan</strong></td>
                                    <td class="text-center">@s.AracSayisi</td>
                                    <td class="text-center">@s.SoforSayisi</td>
                                    <td class="text-end">@s.ToplamSefer</td>
                                    <td class="text-end text-success">@s.TamamlananSefer</td>
                                    <td class="text-end text-warning">@s.ArizaSefer</td>
                                    <td class="text-end text-danger">@s.IptalSefer</td>
                                    <td class="text-end">%@s.TamamlanmaOran.ToString("N1")</td>
                                    <td class="text-end">%@s.ArizaOran.ToString("N1")</td>
                                    <td class="text-end">@s.ToplamKm.ToString("N0")</td>
                                    <td class="text-end">@s.ToplamMaliyet.ToString("N0") ₺</td>
                                    <td class="text-end">@s.SeferBasiMaliyet.ToString("N0") ₺</td>
                                    <td class="text-center">
                                        <span class="badge bg-@SkorRenk(s.Skor)">@s.Skor.ToString("N0")</span>
                                    </td>
                                </tr>
                            }
                            @if (!siraliSatirlar.Any())
                            {
                                <tr>
                                    <td colspan="15" class="text-center text-muted py-4">Veri yok</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private DateTime basTarih = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bitTarih = DateTime.Today;
    private string siralamaModu = "skor";
    private bool bosGizle = true;

    private List<KarneSatir> satirlar = new();
    private List<KarneSatir> siraliSatirlar = new();

    private int aktifTedarikciSayisi;
    private int toplamTedarikciSayisi;
    private int toplamSefer;
    private decimal toplamMaliyet;
    private decimal ortArizaOran;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void HizliSecim(string s)
    {
        var bugun = DateTime.Today;
        switch (s)
        {
            case "buAy":
                basTarih = new DateTime(bugun.Year, bugun.Month, 1);
                bitTarih = bugun;
                break;
            case "oncekiAy":
                var oncekiAy = bugun.AddMonths(-1);
                basTarih = new DateTime(oncekiAy.Year, oncekiAy.Month, 1);
                bitTarih = basTarih.AddMonths(1).AddDays(-1);
                break;
            case "sonCeyrek":
                basTarih = bugun.AddMonths(-3);
                bitTarih = bugun;
                break;
            case "buYil":
                basTarih = new DateTime(bugun.Year, 1, 1);
                bitTarih = bugun;
                break;
        }
        _ = LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        try
        {
            var tedarikciler = await TedarikciService.GetAllAsync(false);
            toplamTedarikciSayisi = tedarikciler.Count;
            aktifTedarikciSayisi = tedarikciler.Count(t => t.Aktif);

            var seferler = await ServisCalismaService.GetByDateRangeAsync(basTarih, bitTarih);
            seferler ??= new();

            // Tedarikçi araçlarına ait seferler
            var tedarikciSeferleri = seferler
                .Where(s => s.Arac != null
                            && s.Arac.SahiplikTipi == AracSahiplikTipi.Tedarikci
                            && s.Arac.TasimaTedarikciId.HasValue)
                .ToList();

            satirlar = tedarikciler.Select(t =>
            {
                var sList = tedarikciSeferleri.Where(x => x.Arac.TasimaTedarikciId == t.Id).ToList();
                var toplam = sList.Count;
                var tamamlanan = sList.Count(x => x.Durum == CalismaDurum.Tamamlandi);
                var ariza = sList.Count(x => x.ArizaOlduMu || x.Durum == CalismaDurum.ArizaNedeniyleYapilamadi);
                var iptal = sList.Count(x => x.Durum == CalismaDurum.IptalEdildi);
                var km = sList.Where(x => x.KmBaslangic.HasValue && x.KmBitis.HasValue && x.KmBitis > x.KmBaslangic)
                              .Sum(x => (long)(x.KmBitis!.Value - x.KmBaslangic!.Value));
                var maliyet = sList.Sum(x => x.HesaplananFiyat);
                var aracSay = sList.Select(x => x.AracId).Distinct().Count();
                var soforSay = sList.Select(x => x.SoforId).Distinct().Count();

                var tamamlanmaOran = toplam > 0 ? (decimal)tamamlanan / toplam * 100m : 0m;
                var arizaOran = toplam > 0 ? (decimal)ariza / toplam * 100m : 0m;
                var iptalOran = toplam > 0 ? (decimal)iptal / toplam * 100m : 0m;
                var seferBasi = toplam > 0 ? maliyet / toplam : 0m;

                // Skor: tamamlanma * 0.6 - ariza * 0.3 - iptal * 0.3, 0-100 arası
                var skor = (tamamlanmaOran * 0.6m) + ((100 - arizaOran) * 0.25m) + ((100 - iptalOran) * 0.15m);
                if (toplam == 0) skor = 0;
                skor = Math.Max(0, Math.Min(100, skor));

                return new KarneSatir
                {
                    TedarikciId = t.Id,
                    TedarikciKodu = t.TedarikciKodu,
                    TedarikciUnvan = t.Unvan,
                    AracSayisi = aracSay,
                    SoforSayisi = soforSay,
                    ToplamSefer = toplam,
                    TamamlananSefer = tamamlanan,
                    ArizaSefer = ariza,
                    IptalSefer = iptal,
                    TamamlanmaOran = tamamlanmaOran,
                    ArizaOran = arizaOran,
                    ToplamKm = km,
                    ToplamMaliyet = maliyet,
                    SeferBasiMaliyet = seferBasi,
                    Skor = skor
                };
            }).ToList();

            toplamSefer = satirlar.Sum(x => x.ToplamSefer);
            toplamMaliyet = satirlar.Sum(x => x.ToplamMaliyet);
            var izinli = satirlar.Where(x => x.ToplamSefer > 0).ToList();
            ortArizaOran = izinli.Any() ? izinli.Average(x => x.ArizaOran) : 0m;

            ChartCiz();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Yükleme hatası: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void SiralaUygula()
    {
        var kaynak = bosGizle ? satirlar.Where(x => x.ToplamSefer > 0) : satirlar.AsEnumerable();
        siraliSatirlar = siralamaModu switch
        {
            "sefer" => kaynak.OrderByDescending(x => x.ToplamSefer).ToList(),
            "maliyet" => kaynak.OrderByDescending(x => x.ToplamMaliyet).ToList(),
            "ariza" => kaynak.OrderByDescending(x => x.ArizaOran).ToList(),
            "tamamlanma" => kaynak.OrderByDescending(x => x.TamamlanmaOran).ToList(),
            _ => kaynak.OrderByDescending(x => x.Skor).ToList()
        };
    }

    private async void ChartCiz()
    {
        SiralaUygula();
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            var top10 = siraliSatirlar.Where(x => x.ToplamSefer > 0).Take(10).ToList();
            var labels = top10.Select(x => x.TedarikciUnvan).ToArray();
            var skorData = top10.Select(x => (double)x.Skor).ToArray();
            await JS.InvokeVoidAsync("filoKpiCharts.renderSoforSkor", "tedarikciSkorChart", labels, skorData);

            var seferData = top10.Select(x => (double)x.ToplamSefer).ToArray();
            await JS.InvokeVoidAsync("filoKpiCharts.renderVadeKategori", "tedarikciSeferChart", labels, seferData);
        }
        catch { }
    }

    private string SkorRenk(decimal s) => s switch
    {
        >= 80 => "success",
        >= 60 => "info",
        >= 40 => "warning",
        _ => "danger"
    };

    private async Task ExcelIndir()
    {
        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Tedarikçi Karne");
            string[] headers = { "Sıra", "Kod", "Tedarikçi", "Araç", "Şoför", "Sefer", "Tamamlanan",
                "Arıza", "İptal", "Tamamlanma %", "Arıza %", "KM", "Maliyet ₺", "Sefer Başı ₺", "Skor" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int row = 2;
            foreach (var (s, idx) in siraliSatirlar.Select((s, i) => (s, i)))
            {
                ws.Cell(row, 1).Value = idx + 1;
                ws.Cell(row, 2).Value = s.TedarikciKodu;
                ws.Cell(row, 3).Value = s.TedarikciUnvan;
                ws.Cell(row, 4).Value = s.AracSayisi;
                ws.Cell(row, 5).Value = s.SoforSayisi;
                ws.Cell(row, 6).Value = s.ToplamSefer;
                ws.Cell(row, 7).Value = s.TamamlananSefer;
                ws.Cell(row, 8).Value = s.ArizaSefer;
                ws.Cell(row, 9).Value = s.IptalSefer;
                ws.Cell(row, 10).Value = (double)s.TamamlanmaOran;
                ws.Cell(row, 11).Value = (double)s.ArizaOran;
                ws.Cell(row, 12).Value = s.ToplamKm;
                ws.Cell(row, 13).Value = (double)s.ToplamMaliyet;
                ws.Cell(row, 14).Value = (double)s.SeferBasiMaliyet;
                ws.Cell(row, 15).Value = (double)s.Skor;
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var bytes = ms.ToArray();
            var fileName = $"Tedarikci_Karne_{basTarih:yyyyMMdd}_{bitTarih:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Excel indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel hatası: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("filoKpiCharts.destroyAll"); } catch { }
    }

    private class KarneSatir
    {
        public int TedarikciId { get; set; }
        public string TedarikciKodu { get; set; } = "";
        public string TedarikciUnvan { get; set; } = "";
        public int AracSayisi { get; set; }
        public int SoforSayisi { get; set; }
        public int ToplamSefer { get; set; }
        public int TamamlananSefer { get; set; }
        public int ArizaSefer { get; set; }
        public int IptalSefer { get; set; }
        public decimal TamamlanmaOran { get; set; }
        public decimal ArizaOran { get; set; }
        public long ToplamKm { get; set; }
        public decimal ToplamMaliyet { get; set; }
        public decimal SeferBasiMaliyet { get; set; }
        public decimal Skor { get; set; }
    }
}

