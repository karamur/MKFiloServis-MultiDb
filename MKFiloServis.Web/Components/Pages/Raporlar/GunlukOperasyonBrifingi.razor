@page "/raporlar/gunluk-brifing"
@using System.Globalization
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IServisCalismaService ServisCalismaService
@inject IBelgeUyariService BelgeUyariService
@inject IFaturaService FaturaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IToastService ToastService
@attribute [Authorize]

<PageTitle>Günlük Operasyon Brifingi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-clipboard-data-fill me-2 text-primary"></i>Günlük Operasyon Brifingi</h2>
            <p class="text-muted mb-0">@DateTime.Today.ToString("dd MMMM yyyy dddd", new CultureInfo("tr-TR")) — sabah/öğle tek ekran özeti</p>
        </div>
        <div>
            <button class="btn btn-outline-primary btn-sm" @onclick="LoadAsync" disabled="@yukleniyor">
                <i class="bi bi-arrow-clockwise me-1"></i>Yenile
            </button>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Brifing hazırlanıyor...</p>
        </div>
    }
    else
    {
        <!-- ÖZET KARTLAR -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Bugünkü Sefer</div>
                                <h3 class="mb-0">@bugunSeferSayisi</h3>
                                <small class="@(bugunSeferSayisi >= dunSeferSayisi ? "text-success" : "text-danger")">
                                    <i class="bi @(bugunSeferSayisi >= dunSeferSayisi ? "bi-arrow-up" : "bi-arrow-down")"></i>
                                    Dün: @dunSeferSayisi
                                </small>
                            </div>
                            <i class="bi bi-truck-front-fill display-4 text-primary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Aktif Araç / Şoför</div>
                                <h3 class="mb-0">@bugunAracSayisi <small class="text-muted">/ @bugunSoforSayisi</small></h3>
                                <small class="text-muted">Toplam: @toplamAktifArac / @toplamAktifSofor</small>
                            </div>
                            <i class="bi bi-people-fill display-4 text-success opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Bugün Arıza / İptal</div>
                                <h3 class="mb-0">@bugunArizaSayisi <small class="text-muted">/ @bugunIptalSayisi</small></h3>
                                <small class="text-muted">Tamamlanan: @bugunTamamlananSayisi</small>
                            </div>
                            <i class="bi bi-exclamation-triangle-fill display-4 text-warning opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-danger h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Kritik Belge / Vade</div>
                                <h3 class="mb-0">@kritikBelgeSayisi <small class="text-muted">/ @vadesiGecenSayisi</small></h3>
                                <small class="text-danger">Müdahale gerekli</small>
                            </div>
                            <i class="bi bi-shield-exclamation display-4 text-danger opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- BUGÜNKÜ SEFER LİSTESİ -->
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <strong><i class="bi bi-list-check me-2"></i>Bugünkü Sefer Akışı</strong>
                        <span class="badge bg-primary">@bugunSeferler.Count</span>
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        @if (!bugunSeferler.Any())
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-inbox display-5"></i>
                                <p class="mb-0 mt-2">Bugün henüz sefer yok</p>
                            </div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Saat</th>
                                        <th>Araç</th>
                                        <th>Şoför</th>
                                        <th>Güzergah</th>
                                        <th>Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in bugunSeferler.OrderBy(x => x.BaslangicSaati ?? TimeSpan.Zero))
                                    {
                                        <tr>
                                            <td><small>@(s.BaslangicSaati?.ToString(@"hh\:mm") ?? "—")</small></td>
                                            <td><small>@(s.Arac?.AktifPlaka ?? "—")</small></td>
                                            <td><small>@(s.Sofor?.TamAd ?? "—")</small></td>
                                            <td><small>@(s.Guzergah?.SeferTipi.ToString() ?? "—")</small></td>
                                            <td>
                                                @if (s.ArizaOlduMu)
                                                {
                                                    <span class="badge bg-warning text-dark">Arıza</span>
                                                }
                                                else if (s.Durum == CalismaDurum.IptalEdildi)
                                                {
                                                    <span class="badge bg-danger">İptal</span>
                                                }
                                                else if (s.Durum == CalismaDurum.Tamamlandi)
                                                {
                                                    <span class="badge bg-success">Tamam</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@s.Durum</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- KRİTİK BELGELER -->
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                        <strong><i class="bi bi-shield-exclamation me-2"></i>Kritik Belge & Vade Alarmları</strong>
                        <a href="/raporlar/vade-risk-merkezi" class="btn btn-sm btn-light">Detay <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        @if (kritikUyarilar == null || !kritikUyarilar.Any())
                        {
                            <div class="text-center py-4 text-success">
                                <i class="bi bi-check-circle-fill display-5"></i>
                                <p class="mb-0 mt-2">Kritik belge alarmı yok</p>
                            </div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Kalan</th>
                                        <th>Belge</th>
                                        <th>Sahip</th>
                                        <th>Bitiş</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var u in kritikUyarilar.Take(15))
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge @u.SeviyeClass">
                                                    @(u.KalanGun < 0 ? $"{-u.KalanGun} gün geçti" : $"{u.KalanGun} gün")
                                                </span>
                                            </td>
                                            <td><small>@u.BelgeTuru</small></td>
                                            <td><small>@u.Baslik</small></td>
                                            <td><small>@u.BitisTarihi.ToString("dd.MM.yyyy")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- VADESİ GEÇEN FATURALAR -->
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                        <strong><i class="bi bi-cash-coin me-2"></i>Vadesi Geçen / Yaklaşan Faturalar</strong>
                        <span class="badge bg-dark">@vadesiGecenFaturalar.Count + @vadesiYaklasanFaturalar.Count</span>
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        @if (!vadesiGecenFaturalar.Any() && !vadesiYaklasanFaturalar.Any())
                        {
                            <div class="text-center py-4 text-success">
                                <i class="bi bi-check-circle-fill display-5"></i>
                                <p class="mb-0 mt-2">Vade alarmı yok</p>
                            </div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Durum</th>
                                        <th>No</th>
                                        <th>Cari</th>
                                        <th>Vade</th>
                                        <th class="text-end">Kalan</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in vadesiGecenFaturalar.Concat(vadesiYaklasanFaturalar)
                                                                          .OrderBy(x => x.VadeTarihi).Take(15))
                                    {
                                        var gecmis = f.VadeTarihi.HasValue && f.VadeTarihi.Value.Date < DateTime.Today;
                                        <tr>
                                            <td>
                                                <span class="badge @(gecmis ? "bg-danger" : "bg-warning text-dark")">
                                                    @(gecmis ? "Geçti" : "Yaklaşıyor")
                                                </span>
                                            </td>
                                            <td><small>@f.FaturaNo</small></td>
                                            <td><small>@(f.Cari?.Unvan ?? f.Firma?.FirmaAdi ?? "—")</small></td>
                                            <td><small>@(f.VadeTarihi?.ToString("dd.MM.yyyy") ?? "—")</small></td>
                                            <td class="text-end"><small><strong>@f.KalanTutar.ToString("N2") ₺</strong></small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- HIZLI ERİŞİM -->
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header bg-light">
                        <strong><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Hızlı Erişim</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-6">
                                <a href="/filo-puantaj" class="btn btn-outline-primary w-100 text-start">
                                    <i class="bi bi-calendar-check me-2"></i>Filo Puantaj
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/operasyonel-hakedis" class="btn btn-outline-primary w-100 text-start">
                                    <i class="bi bi-receipt me-2"></i>Operasyonel Hakediş
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/raporlar/filo-kpi" class="btn btn-outline-success w-100 text-start">
                                    <i class="bi bi-speedometer2 me-2"></i>Filo KPI
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/raporlar/sofor-performans-360" class="btn btn-outline-success w-100 text-start">
                                    <i class="bi bi-person-badge me-2"></i>Şoför Performans
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/raporlar/vade-risk-merkezi" class="btn btn-outline-danger w-100 text-start">
                                    <i class="bi bi-shield-exclamation me-2"></i>Vade Risk Merkezi
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/raporlar/arac-yillik-karlilik" class="btn btn-outline-info w-100 text-start">
                                    <i class="bi bi-graph-up me-2"></i>Araç Karlılık
                                </a>
                            </div>
                        </div>

                        <hr />

                        <h6 class="mb-2">Bugünkü Durum Özeti</h6>
                        <ul class="list-unstyled small mb-0">
                            <li><i class="bi bi-circle-fill text-success me-2"></i>Tamamlanan sefer: <strong>@bugunTamamlananSayisi</strong></li>
                            <li><i class="bi bi-circle-fill text-warning me-2"></i>Arızalı sefer: <strong>@bugunArizaSayisi</strong></li>
                            <li><i class="bi bi-circle-fill text-danger me-2"></i>İptal sefer: <strong>@bugunIptalSayisi</strong></li>
                            <li><i class="bi bi-circle-fill text-primary me-2"></i>Toplam KM: <strong>@bugunToplamKm.ToString("N0")</strong></li>
                            <li><i class="bi bi-circle-fill text-info me-2"></i>Tahmini ciro: <strong>@bugunTahminiCiro.ToString("N2") ₺</strong></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;

    private List<ServisCalisma> bugunSeferler = new();
    private int bugunSeferSayisi;
    private int dunSeferSayisi;
    private int bugunAracSayisi;
    private int bugunSoforSayisi;
    private int bugunArizaSayisi;
    private int bugunIptalSayisi;
    private int bugunTamamlananSayisi;
    private int bugunToplamKm;
    private decimal bugunTahminiCiro;

    private int toplamAktifArac;
    private int toplamAktifSofor;

    private List<BelgeUyari> kritikUyarilar = new();
    private int kritikBelgeSayisi;

    private List<Fatura> vadesiGecenFaturalar = new();
    private List<Fatura> vadesiYaklasanFaturalar = new();
    private int vadesiGecenSayisi;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        yukleniyor = true;
        try
        {
            var bugun = DateTime.Today;
            var dun = bugun.AddDays(-1);

            // Sefer verileri
            var bugunList = await ServisCalismaService.GetByDateRangeAsync(bugun, bugun);
            var dunList = await ServisCalismaService.GetByDateRangeAsync(dun, dun);

            bugunSeferler = bugunList ?? new();
            bugunSeferSayisi = bugunSeferler.Count;
            dunSeferSayisi = dunList?.Count ?? 0;
            bugunAracSayisi = bugunSeferler.Select(x => x.AracId).Distinct().Count();
            bugunSoforSayisi = bugunSeferler.Select(x => x.SoforId).Distinct().Count();
            bugunArizaSayisi = bugunSeferler.Count(x => x.ArizaOlduMu);
            bugunIptalSayisi = bugunSeferler.Count(x => x.Durum == CalismaDurum.IptalEdildi);
            bugunTamamlananSayisi = bugunSeferler.Count(x => x.Durum == CalismaDurum.Tamamlandi);
            bugunToplamKm = bugunSeferler
                .Where(x => x.KmBaslangic.HasValue && x.KmBitis.HasValue && x.KmBitis > x.KmBaslangic)
                .Sum(x => (x.KmBitis!.Value - x.KmBaslangic!.Value));
            bugunTahminiCiro = bugunSeferler.Sum(x => x.HesaplananFiyat);

            // Kapasite
            toplamAktifArac = await AracService.GetActiveCountAsync();
            toplamAktifSofor = await SoforService.GetActiveCountAsync();

            // Belge uyarıları
            try
            {
                var ozet = await BelgeUyariService.GetBelgeUyarilarAsync(30);
                kritikUyarilar = ozet?.TumUyarilar
                    .Where(u => u.Seviye == BelgeUyariSeviye.Kritik || u.Seviye == BelgeUyariSeviye.Acil)
                    .OrderBy(u => u.KalanGun)
                    .ToList() ?? new();
                kritikBelgeSayisi = kritikUyarilar.Count(u => u.Seviye == BelgeUyariSeviye.Kritik);
            }
            catch { }

            // Faturalar
            try
            {
                var tumFaturalar = await FaturaService.GetOdenmemisFaturalarAsync();
                vadesiGecenFaturalar = (tumFaturalar ?? new())
                    .Where(f => f.VadeTarihi.HasValue && f.VadeTarihi.Value.Date < bugun
                                && f.Durum != FaturaDurum.IptalEdildi
                                && f.KalanTutar > 0)
                    .ToList();
                vadesiYaklasanFaturalar = (tumFaturalar ?? new())
                    .Where(f => f.VadeTarihi.HasValue
                                && f.VadeTarihi.Value.Date >= bugun
                                && f.VadeTarihi.Value.Date <= bugun.AddDays(7)
                                && f.Durum != FaturaDurum.IptalEdildi
                                && f.KalanTutar > 0)
                    .ToList();
                vadesiGecenSayisi = vadesiGecenFaturalar.Count;
            }
            catch { }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Brifing yüklenemedi: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }
}

