@page "/fatura-taslaklari"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IFaturaService FaturaService
@inject ICariService CariService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Fatura Taslaklari</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-file-earmark-plus me-2"></i>Fatura Taslaklari</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniTaslakAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni Taslak
            </button>
            <button class="btn btn-outline-secondary" @onclick="GeriDon">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </button>
        </div>
    </div>

    <div class="alert alert-info py-2 mb-3">
        <i class="bi bi-info-circle me-1"></i>
        Taslaklar, kesilmesi planlanan ancak henuz resmilesmemis faturalardir. Duzenleme yapabilir ve hazir olunca faturaya donusturebilirsiniz.
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (!taslaklar.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                <p class="mt-3 text-muted">Henuz taslak fatura bulunmuyor.</p>
                <button class="btn btn-primary" @onclick="YeniTaslakAc">
                    <i class="bi bi-plus-lg me-1"></i>Ilk Taslagi Olustur
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var taslak in taslaklar)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-warning">
                        <div class="card-header bg-warning text-dark d-flex justify-content-between">
                            <span><i class="bi bi-file-earmark me-1"></i>@taslak.FaturaNo</span>
                            <span class="badge bg-dark">Taslak</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@taslak.Cari?.Unvan</h5>
                            <table class="table table-sm table-borderless mb-0">
                                <tr>
                                    <td class="text-muted">Tarih:</td>
                                    <td>@taslak.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Tip:</td>
                                    <td>
                                        @if (taslak.FaturaYonu == FaturaYonu.Giden)
                                        {
                                            <span class="badge bg-success">Satis</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Alis</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Tutar:</td>
                                    <td><strong class="text-primary fs-5">@FormatPara(taslak.GenelToplam)</strong></td>
                                </tr>
                            </table>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group btn-group-sm w-100">
                                <button class="btn btn-outline-primary" @onclick="() => TaslakDuzenle(taslak)">
                                    <i class="bi bi-pencil me-1"></i>Duzenle
                                </button>
                                <button class="btn btn-success" @onclick="() => FaturayaDonusturOnay(taslak)">
                                    <i class="bi bi-check-lg me-1"></i>Faturaya Donustur
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => TaslakSilOnay(taslak)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Taslak Duzenleme Modal -->
@if (showModal && editTaslak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">@(editTaslak.Id > 0 ? "Taslak Duzenle" : "Yeni Taslak")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Taslak No *</label>
                            <input type="text" class="form-control" @bind="editTaslak.FaturaNo" placeholder="TASLAK-001" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tarih *</label>
                            <input type="date" class="form-control" @bind="editTaslak.FaturaTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fatura Yonu *</label>
                            <select class="form-select" @bind="editTaslak.FaturaYonu">
                                <option value="@FaturaYonu.Giden">Satis (Giden)</option>
                                <option value="@FaturaYonu.Gelen">Alis (Gelen)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Cari *</label>
                            <select class="form-select" @bind="editTaslak.CariId">
                                <option value="0">Secin...</option>
                                @foreach (var cari in cariler)
                                {
                                    <option value="@cari.Id">@cari.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-Fatura Tipi</label>
                            <select class="form-select" @bind="editTaslak.EFaturaTipi">
                                <option value="@EFaturaTipi.EFatura">E-Fatura</option>
                                <option value="@EFaturaTipi.EArsiv">E-Arsiv</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ara Toplam</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editTaslak.AraToplam" step="0.01" />
                                <span class="input-group-text">?</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">KDV Tutar</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editTaslak.KdvTutar" step="0.01" />
                                <span class="input-group-text">?</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Genel Toplam *</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editTaslak.GenelToplam" step="0.01" />
                                <span class="input-group-text">?</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Aciklama</label>
                            <textarea class="form-control" rows="2" @bind="editTaslak.Aciklama"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-warning" @onclick="TaslakKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Taslak Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (showSilModal && silinecekTaslak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Taslak Sil</h5>
                </div>
                <div class="modal-body text-center">
                    <p>Bu taslagi silmek istediginize emin misiniz?</p>
                    <p class="text-muted">@silinecekTaslak.FaturaNo</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showSilModal = false">Iptal</button>
                    <button class="btn btn-danger" @onclick="TaslakSil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Faturaya Donusturme Onay Modal -->
@if (showDonusturModal && donusturulecekTaslak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>Faturaya Donustur</h5>
                </div>
                <div class="modal-body">
                    <p>Bu taslak faturaya donusturulecek.</p>
                    <div class="alert alert-info py-2">
                        <strong>@donusturulecekTaslak.FaturaNo</strong><br/>
                        @donusturulecekTaslak.Cari?.Unvan - @FormatPara(donusturulecekTaslak.GenelToplam)
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fatura No *</label>
                        <input type="text" class="form-control" @bind="yeniFaturaNo" placeholder="F-2024-001" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDonusturModal = false">Iptal</button>
                    <button class="btn btn-success" @onclick="FaturayaDonustur" disabled="@isDonusturuluyor">
                        @if (isDonusturuluyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Donustur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Fatura> taslaklar = new();
    private List<Cari> cariler = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isDonusturuluyor = false;

    private bool showModal = false;
    private bool showSilModal = false;
    private bool showDonusturModal = false;

    private Fatura? editTaslak;
    private Fatura? silinecekTaslak;
    private Fatura? donusturulecekTaslak;
    private string yeniFaturaNo = "";

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        await YenileAsync();
    }

    private void GeriDon()
    {
        Navigation.NavigateTo("/faturalar");
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Taslaklari getir (FaturaNo TASLAK ile baslayan)
            var tumFaturalar = await FaturaService.GetAllAsync();
            taslaklar = tumFaturalar
                .Where(f => f.FaturaNo.StartsWith("TASLAK", StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(f => f.CreatedAt)
                .ToList();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void YeniTaslakAc()
    {
        var nextNum = taslaklar.Count + 1;
        editTaslak = new Fatura
        {
            FaturaNo = $"TASLAK-{nextNum:D3}",
            FaturaTarihi = DateTime.Today,
            FaturaYonu = FaturaYonu.Giden,
            FaturaTipi = FaturaTipi.SatisFaturasi,
            EFaturaTipi = EFaturaTipi.EFatura,
            Durum = FaturaDurum.Beklemede
        };
        showModal = true;
    }

    private void TaslakDuzenle(Fatura taslak)
    {
        editTaslak = new Fatura
        {
            Id = taslak.Id,
            FaturaNo = taslak.FaturaNo,
            FaturaTarihi = taslak.FaturaTarihi,
            FaturaYonu = taslak.FaturaYonu,
            FaturaTipi = taslak.FaturaYonu == FaturaYonu.Giden ? FaturaTipi.SatisFaturasi : FaturaTipi.AlisFaturasi,
            CariId = taslak.CariId,
            EFaturaTipi = taslak.EFaturaTipi,
            AraToplam = taslak.AraToplam,
            KdvTutar = taslak.KdvTutar,
            GenelToplam = taslak.GenelToplam,
            Aciklama = taslak.Aciklama,
            Durum = FaturaDurum.Beklemede
        };
        showModal = true;
    }

    private async Task TaslakKaydet()
    {
        if (editTaslak == null) return;

        if (string.IsNullOrWhiteSpace(editTaslak.FaturaNo) || editTaslak.CariId <= 0)
        {
            ToastService.ShowWarning("Taslak No ve Cari zorunludur!");
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            editTaslak.FaturaTarihi = DateTime.SpecifyKind(editTaslak.FaturaTarihi, DateTimeKind.Utc);
            editTaslak.FaturaTipi = editTaslak.FaturaYonu == FaturaYonu.Giden ? FaturaTipi.SatisFaturasi : FaturaTipi.AlisFaturasi;

            if (editTaslak.Id > 0)
                await FaturaService.UpdateAsync(editTaslak);
            else
                await FaturaService.CreateAsync(editTaslak);

            ToastService.ShowSuccess("Taslak kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void TaslakSilOnay(Fatura taslak)
    {
        silinecekTaslak = taslak;
        showSilModal = true;
    }

    private async Task TaslakSil()
    {
        if (silinecekTaslak == null) return;

        try
        {
            await FaturaService.DeleteAsync(silinecekTaslak.Id);
            ToastService.ShowSuccess("Taslak silindi.");
            showSilModal = false;
            silinecekTaslak = null;
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void FaturayaDonusturOnay(Fatura taslak)
    {
        donusturulecekTaslak = taslak;
        yeniFaturaNo = $"F-{DateTime.Today:yyyy}-{taslaklar.IndexOf(taslak) + 1:D3}";
        showDonusturModal = true;
    }

    private async Task FaturayaDonustur()
    {
        if (donusturulecekTaslak == null || string.IsNullOrWhiteSpace(yeniFaturaNo)) return;

        isDonusturuluyor = true;
        StateHasChanged();

        try
        {
            // Taslagi guncelle - fatura numarasini degistir
            donusturulecekTaslak.FaturaNo = yeniFaturaNo;
            await FaturaService.UpdateAsync(donusturulecekTaslak);

            ToastService.ShowSuccess($"Fatura olusturuldu: {yeniFaturaNo}");
            showDonusturModal = false;
            donusturulecekTaslak = null;
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isDonusturuluyor = false;
            StateHasChanged();
        }
    }

    private void ModalKapat()
    {
        showModal = false;
        showSilModal = false;
        showDonusturModal = false;
        editTaslak = null;
        silinecekTaslak = null;
        donusturulecekTaslak = null;
    }

    private string FormatPara(decimal tutar) => tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " TL";
}

