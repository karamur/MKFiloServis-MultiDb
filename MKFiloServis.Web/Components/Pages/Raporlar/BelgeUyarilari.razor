@page "/raporlar/belge-uyarilari"
@attribute [Authorize]
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IBelgeUyariService BelgeUyariService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Belge Uyarıları ve Hatırlatmalar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0"><i class="bi bi-bell-fill me-2 text-warning"></i>Belge Uyarıları ve Hatırlatmalar</h3>
            <small class="text-muted">Süresi yaklaşan ve geçen belgeler</small>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 180px;" @bind="gunFiltre" @bind:after="FiltreleAsync">
                <option value="7">7 Gün İçinde</option>
                <option value="15">15 Gün İçinde</option>
                <option value="30">30 Gün İçinde</option>
                <option value="60">60 Gün İçinde</option>
                <option value="90">90 Gün İçinde</option>
            </select>
            <button class="btn btn-outline-primary" @onclick="YenileAsync">
                <i class="bi bi-arrow-clockwise me-1"></i>Yenile
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelExport">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Belgeler yükleniyor...</p>
        </div>
    }
    else if (uyariOzet == null)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Belge uyarısı bulunamadı.
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-danger h-100 @(uyariOzet.ToplamKritikUyari > 0 ? "bg-danger bg-opacity-10" : "")">
                    <div class="card-body text-center">
                        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 2rem;"></i>
                        <h2 class="mb-0 text-danger">@uyariOzet.ToplamKritikUyari</h2>
                        <small class="text-muted">Kritik (Süresi Geçmiş / 7 Gün)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-exclamation-circle-fill text-warning" style="font-size: 2rem;"></i>
                        <h2 class="mb-0 text-warning">@uyariOzet.TumUyarilar.Count(u => u.KalanGun > 7 && u.KalanGun <= 30)</h2>
                        <small class="text-muted">Uyarı (8-30 Gün)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-info-circle-fill text-info" style="font-size: 2rem;"></i>
                        <h2 class="mb-0 text-info">@uyariOzet.TumUyarilar.Count(u => u.KalanGun > 30)</h2>
                        <small class="text-muted">Bilgi (30+ Gün)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-secondary h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-file-earmark-text text-secondary" style="font-size: 2rem;"></i>
                        <h2 class="mb-0">@uyariOzet.ToplamUyari</h2>
                        <small class="text-muted">Toplam Uyarı</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Kategori Tabs -->
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button class="nav-link @(aktifTab == "tumu" ? "active" : "")" @onclick='() => aktifTab = "tumu"'>
                    <i class="bi bi-list-ul me-1"></i>Tümü
                    <span class="badge bg-secondary ms-1">@uyariOzet.TumUyarilar.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(aktifTab == "personel" ? "active" : "")" @onclick='() => aktifTab = "personel"'>
                    <i class="bi bi-person-badge me-1"></i>Personel
                    <span class="badge bg-primary ms-1">@PersonelUyariSayisi</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(aktifTab == "arac" ? "active" : "")" @onclick='() => aktifTab = "arac"'>
                    <i class="bi bi-truck me-1"></i>Araç
                    <span class="badge bg-success ms-1">@AracUyariSayisi</span>
                </button>
            </li>
        </ul>

        <!-- Uyarı Listesi -->
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 50px;">Durum</th>
                                <th>Kaynak</th>
                                <th>Belge Türü</th>
                                <th>Bitiş Tarihi</th>
                                <th>Kalan Gün</th>
                                <th class="text-end">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var uyari in FiltrelenmisUyarilar)
                            {
                                <tr class="@GetRowClass(uyari)">
                                    <td>
                                        @if (uyari.KalanGun < 0)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-circle-fill"></i></span>
                                        }
                                        else if (uyari.KalanGun <= 7)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill"></i></span>
                                        }
                                        else if (uyari.KalanGun <= 30)
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-circle-fill"></i></span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info"><i class="bi bi-info-circle-fill"></i></span>
                                        }
                                    </td>
                                    <td>
                                        <strong>@uyari.Baslik</strong>
                                        <br />
                                        <small class="text-muted">@uyari.Kaynak</small>
                                    </td>
                                    <td>@uyari.BelgeTuru</td>
                                    <td>@uyari.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @if (uyari.KalanGun < 0)
                                        {
                                            <span class="text-danger fw-bold">@Math.Abs(uyari.KalanGun) gün geçti!</span>
                                        }
                                        else if (uyari.KalanGun == 0)
                                        {
                                            <span class="text-danger fw-bold">Bugün!</span>
                                        }
                                        else
                                        {
                                            <span class="@(uyari.KalanGun <= 7 ? "text-danger fw-bold" : uyari.KalanGun <= 30 ? "text-warning fw-bold" : "")">
                                                @uyari.KalanGun gün
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (!string.IsNullOrEmpty(uyari.DetayUrl))
                                        {
                                            <a href="@uyari.DetayUrl" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye me-1"></i>Detay
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (!FiltrelenmisUyarilar.Any())
        {
            <div class="alert alert-success mt-3">
                <i class="bi bi-check-circle me-2"></i>
                Seçilen kriterlere göre belge uyarısı bulunmuyor. Tüm belgeler güncel!
            </div>
        }

        <!-- Detaylı Kategori Özeti -->
        <div class="row mt-4">
            <!-- Personel Belgeleri -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0"><i class="bi bi-person-badge me-2"></i>Personel Belgeleri Özeti</h6>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-3">
                                <div class="border-end">
                                    <h4 class="mb-0 @(uyariOzet.EhliyetUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                        @uyariOzet.EhliyetUyarilari.Count
                                    </h4>
                                    <small class="text-muted">Ehliyet</small>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border-end">
                                    <h4 class="mb-0 @(uyariOzet.MykBelgesiUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                        @uyariOzet.MykBelgesiUyarilari.Count
                                    </h4>
                                    <small class="text-muted">MYK</small>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border-end">
                                    <h4 class="mb-0 @(uyariOzet.PsikoteknikUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                        @uyariOzet.PsikoteknikUyarilari.Count
                                    </h4>
                                    <small class="text-muted">Psikoteknik</small>
                                </div>
                            </div>
                            <div class="col-3">
                                <h4 class="mb-0 @(uyariOzet.SaglikRaporuUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                    @uyariOzet.SaglikRaporuUyarilari.Count
                                </h4>
                                <small class="text-muted">Sağlık</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Araç Belgeleri -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="bi bi-truck me-2"></i>Araç Belgeleri Özeti</h6>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-3">
                                <div class="border-end">
                                    <h4 class="mb-0 @(uyariOzet.MuayeneUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                        @uyariOzet.MuayeneUyarilari.Count
                                    </h4>
                                    <small class="text-muted">Muayene</small>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border-end">
                                    <h4 class="mb-0 @(uyariOzet.KaskoUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                        @uyariOzet.KaskoUyarilari.Count
                                    </h4>
                                    <small class="text-muted">Kasko</small>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border-end">
                                    <h4 class="mb-0 @(uyariOzet.TrafikSigortasiUyarilari.Count > 0 ? "text-danger" : "text-success")">
                                        @uyariOzet.TrafikSigortasiUyarilari.Count
                                    </h4>
                                    <small class="text-muted">Trafik Sig.</small>
                                </div>
                            </div>
                            <div class="col-3">
                                <h4 class="mb-0 @(uyariOzet.DigerAracEvrakUyarilari.Count > 0 ? "text-warning" : "text-success")">
                                    @uyariOzet.DigerAracEvrakUyarilari.Count
                                </h4>
                                <small class="text-muted">Diğer</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private BelgeUyariOzet? uyariOzet;
    private int gunFiltre = 30;
    private string aktifTab = "tumu";

    private int PersonelUyariSayisi => uyariOzet?.EhliyetUyarilari.Count 
        + uyariOzet?.MykBelgesiUyarilari.Count 
        + uyariOzet?.YayginEgitimUyarilari.Count 
        + uyariOzet?.PsikoteknikUyarilari.Count 
        + uyariOzet?.SaglikRaporuUyarilari.Count ?? 0;

    private int AracUyariSayisi => uyariOzet?.MuayeneUyarilari.Count 
        + uyariOzet?.KaskoUyarilari.Count 
        + uyariOzet?.TrafikSigortasiUyarilari.Count 
        + uyariOzet?.DigerAracEvrakUyarilari.Count ?? 0;

    private IEnumerable<BelgeUyari> FiltrelenmisUyarilar
    {
        get
        {
            if (uyariOzet == null) return Enumerable.Empty<BelgeUyari>();

            var liste = aktifTab switch
            {
                "personel" => uyariOzet.EhliyetUyarilari
                    .Concat(uyariOzet.MykBelgesiUyarilari)
                    .Concat(uyariOzet.YayginEgitimUyarilari)
                    .Concat(uyariOzet.PsikoteknikUyarilari)
                    .Concat(uyariOzet.SaglikRaporuUyarilari),
                "arac" => uyariOzet.MuayeneUyarilari
                    .Concat(uyariOzet.KaskoUyarilari)
                    .Concat(uyariOzet.TrafikSigortasiUyarilari)
                    .Concat(uyariOzet.DigerAracEvrakUyarilari),
                _ => uyariOzet.TumUyarilar
            };

            return liste.Where(u => u.KalanGun <= gunFiltre).OrderBy(u => u.KalanGun);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        try
        {
            uyariOzet = await BelgeUyariService.GetBelgeUyarilarAsync(gunFiltre);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Belge uyarıları yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FiltreleAsync()
    {
        await YenileAsync();
    }

    private string GetRowClass(BelgeUyari uyari)
    {
        if (uyari.KalanGun < 0) return "table-danger";
        if (uyari.KalanGun <= 7) return "table-warning";
        return "";
    }

    private async Task ExcelExport()
    {
        if (uyariOzet == null) return;

        var csvContent = "Durum;Kaynak;Baslik;Belge Türü;Bitiş Tarihi;Kalan Gün\n";
        foreach (var uyari in FiltrelenmisUyarilar)
        {
            var durum = uyari.KalanGun < 0 ? "Süresi Geçmiş" : uyari.KalanGun <= 7 ? "Kritik" : uyari.KalanGun <= 30 ? "Uyarı" : "Bilgi";
            csvContent += $"{durum};{uyari.Kaynak};{uyari.Baslik};{uyari.BelgeTuru};{uyari.BitisTarihi:dd.MM.yyyy};{uyari.KalanGun}\n";
        }

        var fileName = $"BelgeUyarilari_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        var bytes = System.Text.Encoding.UTF8.GetBytes(csvContent);
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", base64);
    }
}

