@page "/raporlar/nakit-akis"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.Extensions.Logging
@inject IBankaHesapService BankaHesapService
@inject IBankaKasaHareketService BankaHareketService
@inject IFaturaService FaturaService
@inject IAylikOdemeService AylikOdemeService
@inject IFirmaService FirmaService
@inject ILogger<NakitAkisDashboard> Logger

<PageTitle>Nakit Akış Dashboard</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-cash-coin text-success me-2"></i>Nakit Akış Dashboard</h3>
            <small class="text-muted">Banka/Kasa pozisyonu + bekleyen tahsilat/ödeme + 30 günlük projeksiyon</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <label class="small text-muted mb-0">Projeksiyon (gün):</label>
            <select class="form-select form-select-sm" style="width:90px" @bind="projeksiyonGun" @bind:after="LoadAsync">
                <option value="7">7</option>
                <option value="15">15</option>
                <option value="30">30</option>
                <option value="60">60</option>
                <option value="90">90</option>
            </select>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise"></i> Yenile
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-success"></div></div>
    }
    else
    {
        <!-- KPI -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card border-success shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Mevcut Nakit Pozisyonu</div>
                        <div class="display-6 text-success fw-bold">@toplamBakiye.ToString("N2") ₺</div>
                        <small class="text-muted">Banka: @toplamBanka.ToString("N0") ₺ • Kasa: @toplamKasa.ToString("N0") ₺</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-primary shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Beklenen Tahsilat (@projeksiyonGun gün)</div>
                        <div class="display-6 text-primary fw-bold">@beklenenTahsilat.ToString("N2") ₺</div>
                        <small class="text-muted">@tahsilatSayisi adet vadeli fatura</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Beklenen Ödeme (@projeksiyonGun gün)</div>
                        <div class="display-6 text-warning fw-bold">@beklenenOdeme.ToString("N2") ₺</div>
                        <small class="text-muted">Bütçe: @butceAylikGider.ToString("N0") ₺/ay</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(netNakit >= 0 ? "border-success" : "border-danger") shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Tahmini Net Pozisyon</div>
                        <div class="display-6 fw-bold @(netNakit >= 0 ? "text-success" : "text-danger")">
                            @netNakit.ToString("N2") ₺
                        </div>
                        <small class="text-muted">Mevcut + Tahsilat − Ödeme</small>
                    </div>
                </div>
            </div>
        </div>

        @if (netNakit < 0)
        {
            <div class="alert alert-danger d-flex align-items-center">
                <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
                <div>
                    <strong>Likidite uyarısı:</strong> @projeksiyonGun gün içinde nakit açığı oluşması bekleniyor:
                    <strong>@Math.Abs(netNakit).ToString("N2") ₺</strong>. Tahsilatları hızlandırmayı veya ödemeleri ertelemeyi düşünün.
                </div>
            </div>
        }

        <div class="row g-3">
            <!-- Banka/Kasa Pozisyonu -->
            <div class="col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light"><i class="bi bi-bank2 me-1"></i><strong>Hesap Bakiyeleri</strong></div>
                    <div class="card-body p-0">
                        @if (!hesapBakiyeleri.Any())
                        {
                            <div class="text-muted text-center py-4 small">Aktif hesap yok.</div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light"><tr><th>Hesap</th><th>Tip</th><th class="text-end">Bakiye</th></tr></thead>
                                <tbody>
                                    @foreach (var h in hesapBakiyeleri.OrderByDescending(x => x.Bakiye))
                                    {
                                        <tr>
                                            <td><small>@h.Ad</small></td>
                                            <td><span class="badge bg-@(h.Tip == HesapTipi.Kasa ? "success" : "primary")">@h.Tip</span></td>
                                            <td class="text-end fw-semibold @(h.Bakiye < 0 ? "text-danger" : "")">@h.Bakiye.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr><th colspan="2">TOPLAM</th><th class="text-end">@toplamBakiye.ToString("N2") ₺</th></tr>
                                </tfoot>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- Yaklaşan Tahsilatlar -->
            <div class="col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light"><i class="bi bi-arrow-down-circle text-success me-1"></i><strong>Yaklaşan Tahsilatlar</strong></div>
                    <div class="card-body p-0" style="max-height:420px; overflow-y:auto;">
                        @if (!yaklasanTahsilatlar.Any())
                        {
                            <div class="text-muted text-center py-4 small">Bekleyen tahsilat yok.</div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light"><tr><th>Vade</th><th>Müşteri</th><th class="text-end">Tutar</th></tr></thead>
                                <tbody>
                                    @foreach (var f in yaklasanTahsilatlar)
                                    {
                                        var kalan = (f.VadeTarihi!.Value.Date - DateTime.Today).Days;
                                        <tr>
                                            <td>
                                                <small>@f.VadeTarihi.Value.ToString("dd.MM")</small>
                                                <span class="badge @(kalan < 0 ? "bg-danger" : kalan <= 7 ? "bg-warning text-dark" : "bg-secondary") ms-1">
                                                    @(kalan < 0 ? $"{-kalan} gün geçti" : $"{kalan} gün")
                                                </span>
                                            </td>
                                            <td><small>@(f.Cari?.Unvan ?? f.Firma?.FirmaAdi ?? "-")</small></td>
                                            <td class="text-end fw-semibold text-success">@((f.KalanTutar > 0 ? f.KalanTutar : f.GenelToplam).ToString("N2"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- Yaklaşan Ödemeler -->
            <div class="col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light"><i class="bi bi-arrow-up-circle text-warning me-1"></i><strong>Yaklaşan Ödemeler</strong></div>
                    <div class="card-body p-0" style="max-height:420px; overflow-y:auto;">
                        @if (!yaklasanOdemeler.Any())
                        {
                            <div class="text-muted text-center py-4 small">Bekleyen ödeme yok.</div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light"><tr><th>Tarih</th><th>Açıklama</th><th class="text-end">Tutar</th></tr></thead>
                                <tbody>
                                    @foreach (var o in yaklasanOdemeler)
                                    {
                                        <tr>
                                            <td><small>@o.Tarih.ToString("dd.MM")</small></td>
                                            <td>
                                                <small>@o.Aciklama</small>
                                                <span class="badge bg-light text-muted ms-1">@o.Kategori</span>
                                            </td>
                                            <td class="text-end fw-semibold text-warning">@o.Tutar.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Haftalık projeksiyon -->
        <div class="card shadow-sm mt-3">
            <div class="card-header bg-light"><i class="bi bi-calendar3 me-1"></i><strong>Haftalık Nakit Projeksiyonu</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Hafta</th>
                            <th class="text-end text-success">Tahsilat (+)</th>
                            <th class="text-end text-warning">Ödeme (−)</th>
                            <th class="text-end">Net</th>
                            <th class="text-end">Kümülatif Bakiye</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ decimal kumulatif = toplamBakiye; }
                        @foreach (var h in haftalikProjeksiyon)
                        {
                            var net = h.Tahsilat - h.Odeme;
                            kumulatif += net;
                            <tr>
                                <td><small>@h.HaftaBaslangic.ToString("dd.MM") - @h.HaftaBaslangic.AddDays(6).ToString("dd.MM")</small></td>
                                <td class="text-end text-success">@h.Tahsilat.ToString("N2")</td>
                                <td class="text-end text-warning">@h.Odeme.ToString("N2")</td>
                                <td class="text-end fw-semibold @(net >= 0 ? "text-success" : "text-danger")">@net.ToString("N2")</td>
                                <td class="text-end fw-bold @(kumulatif >= 0 ? "text-dark" : "text-danger")">@kumulatif.ToString("N2") ₺</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private int projeksiyonGun = 30;

    private decimal toplamBakiye, toplamBanka, toplamKasa;
    private decimal beklenenTahsilat, beklenenOdeme, butceAylikGider;
    private int tahsilatSayisi;
    private decimal netNakit => toplamBakiye + beklenenTahsilat - beklenenOdeme;

    private List<HesapBakiyeItem> hesapBakiyeleri = new();
    private List<Fatura> yaklasanTahsilatlar = new();
    private List<OdemeItem> yaklasanOdemeler = new();
    private List<HaftalikItem> haftalikProjeksiyon = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        try
        {
            var bugun = DateTime.Today;
            var bitis = bugun.AddDays(projeksiyonGun);

            // Banka/Kasa
            try
            {
                var hesaplar = await BankaHesapService.GetActiveAsync();
                var bakiyeler = await BankaHesapService.GetTumHesapBakiyeleriAsync();
                hesapBakiyeleri = hesaplar.Select(h => new HesapBakiyeItem
                {
                    Id = h.Id,
                    Ad = string.IsNullOrEmpty(h.HesapAdi) ? (h.HesapKodu ?? "") : h.HesapAdi,
                    Tip = h.HesapTipi,
                    Bakiye = bakiyeler.TryGetValue(h.Id, out var b) ? b : 0m
                }).ToList();
                toplamBakiye = hesapBakiyeleri.Sum(x => x.Bakiye);
                toplamBanka = hesapBakiyeleri.Where(x => x.Tip != HesapTipi.Kasa).Sum(x => x.Bakiye);
                toplamKasa = hesapBakiyeleri.Where(x => x.Tip == HesapTipi.Kasa).Sum(x => x.Bakiye);
            }
            catch (Exception ex) { Logger.LogWarning(ex, "Banka bakiye yuklenemedi"); }

            // Yaklaşan tahsilatlar (vadeli faturalar)
            try
            {
                var faturalar = await FaturaService.GetOdenmemisFaturalarAsync();
                yaklasanTahsilatlar = faturalar
                    .Where(f => f.VadeTarihi.HasValue && f.VadeTarihi.Value.Date <= bitis)
                    .OrderBy(f => f.VadeTarihi)
                    .ToList();
                beklenenTahsilat = yaklasanTahsilatlar.Sum(f => f.KalanTutar > 0 ? f.KalanTutar : f.GenelToplam);
                tahsilatSayisi = yaklasanTahsilatlar.Count;
            }
            catch (Exception ex) { Logger.LogWarning(ex, "Tahsilat yuklenemedi"); }

            // Yaklaşan ödemeler (aylık ödeme planı + bekleyen ödemeler)
            try
            {
                var aktifFirma = FirmaService.GetAktifFirma();
                if (aktifFirma is not null)
                {
                    butceAylikGider = await AylikOdemeService.GetToplamAylikOdemeAsync(aktifFirma.FirmaId);

                    // Projeksiyon dönemini ay ay tara
                    var odemeler = new List<OdemeItem>();
                    var d = bugun;
                    while (d <= bitis)
                    {
                        var liste = await AylikOdemeService.GetTakvimOdemeleriAsync(aktifFirma.FirmaId, d.Year, d.Month);
                        foreach (var o in liste)
                        {
                            if (o.Durum == OdemeDurumu.Odendi || o.Durum == OdemeDurumu.Iptal) continue;
                            var gun = o.Plan?.OdemeGunu ?? 1;
                            var maxGun = DateTime.DaysInMonth(o.Yil, o.Ay);
                            var tarih = o.OdemeTarihi ?? new DateTime(o.Yil, o.Ay, Math.Min(gun, maxGun));
                            if (tarih.Date > bitis) continue;
                            // Geçmiş tarihliler de eklensin (gecikmiş ödeme), bugünden eski olsa bile
                            odemeler.Add(new OdemeItem
                            {
                                Tarih = tarih,
                                Aciklama = o.Plan?.OdemeAdi ?? o.Aciklama ?? "Aylık Ödeme",
                                Kategori = o.Plan?.Turu.ToString() ?? "Genel",
                                Tutar = o.PlanlananTutar > 0 ? o.PlanlananTutar : o.OdenenTutar
                            });
                        }
                        d = new DateTime(d.Year, d.Month, 1).AddMonths(1);
                    }
                    yaklasanOdemeler = odemeler.OrderBy(x => x.Tarih).ToList();
                    beklenenOdeme = yaklasanOdemeler.Sum(x => x.Tutar);
                }
            }
            catch (Exception ex) { Logger.LogWarning(ex, "Odeme yuklenemedi"); }

            // Haftalık projeksiyon
            haftalikProjeksiyon = new();
            var haftaBas = bugun;
            while (haftaBas < bitis)
            {
                var haftaSon = haftaBas.AddDays(6);
                var hT = yaklasanTahsilatlar
                    .Where(f => f.VadeTarihi!.Value.Date >= haftaBas && f.VadeTarihi.Value.Date <= haftaSon)
                    .Sum(f => f.KalanTutar > 0 ? f.KalanTutar : f.GenelToplam);
                var hO = yaklasanOdemeler
                    .Where(o => o.Tarih.Date >= haftaBas && o.Tarih.Date <= haftaSon)
                    .Sum(o => o.Tutar);
                haftalikProjeksiyon.Add(new HaftalikItem { HaftaBaslangic = haftaBas, Tahsilat = hT, Odeme = hO });
                haftaBas = haftaBas.AddDays(7);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Nakit Akis Dashboard yuklenirken hata");
        }
        finally
        {
            isLoading = false;
        }
    }

    private class HesapBakiyeItem
    {
        public int Id { get; set; }
        public string Ad { get; set; } = "";
        public HesapTipi Tip { get; set; }
        public decimal Bakiye { get; set; }
    }

    private class OdemeItem
    {
        public DateTime Tarih { get; set; }
        public string Aciklama { get; set; } = "";
        public string Kategori { get; set; } = "";
        public decimal Tutar { get; set; }
    }

    private class HaftalikItem
    {
        public DateTime HaftaBaslangic { get; set; }
        public decimal Tahsilat { get; set; }
        public decimal Odeme { get; set; }
    }
}

