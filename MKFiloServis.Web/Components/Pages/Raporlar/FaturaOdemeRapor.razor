@page "/rapor/fatura-odeme"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@using Microsoft.JSInterop
@inject IRaporService RaporService
@inject ICariService CariService
@inject IExcelService ExcelService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Fatura Odeme Raporu</PageTitle>

<div class="container-fluid">
    <h3 class="mb-3"><i class="bi bi-file-earmark-text me-2"></i>Fatura Odeme Raporu</h3>

    <div class="card mb-3">
        <div class="card-header">
            <h6 class="mb-0">Filtre</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Baslangic Tarihi</label>
                        <input type="date" class="form-control" @bind="baslangicTarihi" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Bitis Tarihi</label>
                        <input type="date" class="form-control" @bind="bitisTarihi" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Cari</label>
                        <select class="form-select" @bind="secilenCariId">
                            <option value="0">Tumu</option>
                            @foreach (var cari in cariler)
                            {
                                <option value="@cari.Id">@cari.Unvan</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select class="form-select" @bind="sadeceBekleyenler">
                            <option value="false">Tumu</option>
                            <option value="true">Sadece Bekleyenler</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" @onclick="RaporGetir">
                                <i class="bi bi-search me-1"></i>Rapor Al
                            </button>
                            <button class="btn btn-success" @onclick="ExceleAktar" disabled="@(raporData == null || !raporData.Any())">
                                <i class="bi bi-file-earmark-excel me-1"></i>Excel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yukleniyor...</span>
            </div>
        </div>
    }
    else if (raporData != null)
    {
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Fatura</h6>
                        <h3>@raporData.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Tutar</h6>
                        <h3>@raporData.Sum(r => r.GenelToplam).ToString("N2") TL</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h6>Odenen</h6>
                        <h3>@raporData.Sum(r => r.OdenenTutar).ToString("N2") TL</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center">
                        <h6>Kalan</h6>
                        <h3>@raporData.Sum(r => r.KalanTutar).ToString("N2") TL</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Fatura No</th>
                                <th>Tarih</th>
                                <th>Vade</th>
                                <th>Cari</th>
                                <th>Tip</th>
                                <th class="text-end">Genel Toplam</th>
                                <th class="text-end">Odenen</th>
                                <th class="text-end">Kalan</th>
                                <th>Durum</th>
                                <th class="text-center">Vade Gunu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in raporData)
                            {
                                <tr class="@(item.VadeGunu < 0 && item.KalanTutar > 0 ? "table-danger" : "")">
                                    <td><strong>@item.FaturaNo</strong></td>
                                    <td>@item.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@item.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td>@item.CariUnvan</td>
                                    <td><span class="badge bg-secondary">@item.FaturaTipi</span></td>
                                    <td class="text-end">@item.GenelToplam.ToString("N2") TL</td>
                                    <td class="text-end text-success">@item.OdenenTutar.ToString("N2") TL</td>
                                    <td class="text-end text-danger"><strong>@item.KalanTutar.ToString("N2") TL</strong></td>
                                    <td>
                                        <span class="badge @GetDurumBadgeClass(item.Durum)">@item.Durum</span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.KalanTutar > 0)
                                        {
                                            <span class="badge @(item.VadeGunu < 0 ? "bg-danger" : item.VadeGunu < 7 ? "bg-warning text-dark" : "bg-success")">
                                                @(item.VadeGunu < 0 ? Math.Abs(item.VadeGunu) + " gun gecikmis" : item.VadeGunu + " gun")
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary">
                            <tr>
                                <td colspan="5" class="text-end"><strong>TOPLAM:</strong></td>
                                <td class="text-end"><strong>@raporData.Sum(r => r.GenelToplam).ToString("N2") TL</strong></td>
                                <td class="text-end"><strong class="text-success">@raporData.Sum(r => r.OdenenTutar).ToString("N2") TL</strong></td>
                                <td class="text-end"><strong class="text-danger">@raporData.Sum(r => r.KalanTutar).ToString("N2") TL</strong></td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DateTime? baslangicTarihi;
    private DateTime? bitisTarihi;
    private int secilenCariId = 0;
    private bool sadeceBekleyenler = true;
    private bool isLoading = false;

    private List<Cari> cariler = new();
    private List<FaturaOdemeRaporItem>? raporData;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        await RaporGetir();
    }

    private async Task RaporGetir()
    {
        isLoading = true;
        try
        {
            raporData = await RaporService.GetFaturaOdemeRaporuAsync(
                baslangicTarihi,
                bitisTarihi,
                secilenCariId > 0 ? secilenCariId : null,
                sadeceBekleyenler
            );
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExceleAktar()
    {
        if (raporData == null || !raporData.Any())
            return;

        var excelBytes = ExcelService.ExportFaturaOdemeRaporu(raporData);
        var fileName = "FaturaOdemeRaporu_" + DateTime.Now.ToString("yyyyMMdd_HHmmss") + ".xlsx";

        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(excelBytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private string GetDurumBadgeClass(string durum) => durum switch
    {
        "Beklemede" => "bg-warning text-dark",
        "KismiOdendi" => "bg-info",
        "Odendi" => "bg-success",
        "IptalEdildi" => "bg-danger",
        _ => "bg-secondary"
    };
}

