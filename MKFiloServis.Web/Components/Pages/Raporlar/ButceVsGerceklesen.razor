@page "/raporlar/butce-vs-gerceklesen"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.Extensions.Logging
@inject IAylikOdemeService AylikOdemeService
@inject IFirmaService FirmaService
@inject ILogger<ButceVsGerceklesen> Logger

<PageTitle>Bütçe vs Gerçekleşen</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-bar-chart-line text-primary me-2"></i>Bütçe vs Gerçekleşen</h3>
            <small class="text-muted">Aylık ödeme planı ile gerçekleşen ödemelerin kategori bazlı karşılaştırması</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm" style="width:120px" @bind="secilenYil" @bind:after="LoadAsync">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width:140px" @bind="secilenAy" @bind:after="LoadAsync">
                <option value="0">Tüm Yıl</option>
                @for (int a = 1; a <= 12; a++)
                {
                    <option value="@a">@(new DateTime(2000, a, 1).ToString("MMMM"))</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <!-- Üst KPI -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card border-primary shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Planlanan Toplam</div>
                        <div class="fs-3 text-primary fw-bold">@toplamPlanlanan.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Gerçekleşen</div>
                        <div class="fs-3 text-success fw-bold">@toplamGerceklesen.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(toplamSapma >= 0 ? "border-success" : "border-danger") shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Sapma</div>
                        <div class="fs-3 fw-bold @(toplamSapma >= 0 ? "text-success" : "text-danger")">
                            @(toplamSapma >= 0 ? "+" : "")@toplamSapma.ToString("N2") ₺
                        </div>
                        <small class="text-muted">@(toplamPlanlanan == 0 ? "—" : $"%{(toplamSapma * 100m / toplamPlanlanan):N1}")</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Bekleyen / Gecikmiş</div>
                        <div class="fs-3 text-warning fw-bold">@bekleyenSayisi <small class="text-muted">/ @gecikmisSayisi</small></div>
                        <small class="text-muted">adet ödeme</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- Kategori Bazlı -->
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light"><i class="bi bi-tags me-1"></i><strong>Kategori Bazlı Karşılaştırma</strong></div>
                    <div class="card-body p-0">
                        @if (!kategoriler.Any())
                        {
                            <div class="text-muted text-center py-4 small">Kayıt yok.</div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Kategori</th>
                                        <th class="text-end">Plan</th>
                                        <th class="text-end">Gerçek</th>
                                        <th class="text-end">Sapma</th>
                                        <th style="width:120px">Doluluk</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var k in kategoriler.OrderByDescending(x => x.Planlanan))
                                    {
                                        var sapma = k.Planlanan - k.Gerceklesen;
                                        var pct = k.Planlanan == 0 ? 0 : (double)(k.Gerceklesen * 100m / k.Planlanan);
                                        var pctClamp = Math.Min(100, Math.Max(0, pct));
                                        var renk = pct > 100 ? "bg-danger" : pct >= 90 ? "bg-warning" : "bg-success";
                                        <tr>
                                            <td><small><strong>@k.Kategori</strong></small></td>
                                            <td class="text-end">@k.Planlanan.ToString("N0")</td>
                                            <td class="text-end">@k.Gerceklesen.ToString("N0")</td>
                                            <td class="text-end fw-semibold @(sapma >= 0 ? "text-success" : "text-danger")">@(sapma >= 0 ? "+" : "")@sapma.ToString("N0")</td>
                                            <td>
                                                <div class="progress" style="height:14px" title="@pct.ToString("N1")%">
                                                    <div class="progress-bar @renk" style="width:@pctClamp.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%">
                                                        <small>@pct.ToString("N0")%</small>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th>TOPLAM</th>
                                        <th class="text-end">@toplamPlanlanan.ToString("N0")</th>
                                        <th class="text-end">@toplamGerceklesen.ToString("N0")</th>
                                        <th class="text-end @(toplamSapma >= 0 ? "text-success" : "text-danger")">@(toplamSapma >= 0 ? "+" : "")@toplamSapma.ToString("N0")</th>
                                        <th></th>
                                    </tr>
                                </tfoot>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- En Büyük Sapmalar -->
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light"><i class="bi bi-exclamation-diamond text-danger me-1"></i><strong>En Büyük Sapmalar (Top 10)</strong></div>
                    <div class="card-body p-0" style="max-height:480px; overflow-y:auto;">
                        @if (!enBuyukSapmalar.Any())
                        {
                            <div class="text-muted text-center py-4 small">Sapma yok.</div>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ödeme</th>
                                        <th>Kategori</th>
                                        <th class="text-end">Plan</th>
                                        <th class="text-end">Gerçek</th>
                                        <th class="text-end">Fark</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in enBuyukSapmalar)
                                    {
                                        var fark = d.Planlanan - d.Gerceklesen;
                                        <tr>
                                            <td>
                                                <small><strong>@d.Ad</strong></small>
                                                <div><small class="text-muted">@d.Donem</small></div>
                                            </td>
                                            <td><span class="badge bg-secondary">@d.Kategori</span></td>
                                            <td class="text-end"><small>@d.Planlanan.ToString("N0")</small></td>
                                            <td class="text-end"><small>@d.Gerceklesen.ToString("N0")</small></td>
                                            <td class="text-end fw-bold @(fark >= 0 ? "text-success" : "text-danger")">@(fark >= 0 ? "+" : "")@fark.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (secilenAy == 0 && aylikOzet.Any())
        {
            <div class="card shadow-sm mt-3">
                <div class="card-header bg-light"><i class="bi bi-calendar3 me-1"></i><strong>Aylık Trend (@secilenYil)</strong></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ay</th>
                                <th class="text-end">Plan</th>
                                <th class="text-end">Gerçek</th>
                                <th class="text-end">Sapma</th>
                                <th class="text-end">% Gerçekleşme</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in aylikOzet.OrderBy(x => x.Ay))
                            {
                                var sapma = a.Planlanan - a.Gerceklesen;
                                var pct = a.Planlanan == 0 ? 0 : (double)(a.Gerceklesen * 100m / a.Planlanan);
                                <tr>
                                    <td><small><strong>@(new DateTime(secilenYil, a.Ay, 1).ToString("MMMM"))</strong></small></td>
                                    <td class="text-end">@a.Planlanan.ToString("N2")</td>
                                    <td class="text-end">@a.Gerceklesen.ToString("N2")</td>
                                    <td class="text-end fw-semibold @(sapma >= 0 ? "text-success" : "text-danger")">@(sapma >= 0 ? "+" : "")@sapma.ToString("N2")</td>
                                    <td class="text-end"><span class="badge bg-@(pct > 100 ? "danger" : pct >= 90 ? "warning text-dark" : "success")">%@pct.ToString("N1")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private int secilenYil = DateTime.Now.Year;
    private int secilenAy = 0; // 0 = tüm yıl

    private decimal toplamPlanlanan;
    private decimal toplamGerceklesen;
    private decimal toplamSapma => toplamPlanlanan - toplamGerceklesen;
    private int bekleyenSayisi;
    private int gecikmisSayisi;

    private List<KategoriOzet> kategoriler = new();
    private List<DetaySatir> enBuyukSapmalar = new();
    private List<AylikOzet> aylikOzet = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        try
        {
            var aktifFirma = FirmaService.GetAktifFirma();
            if (aktifFirma is null)
            {
                kategoriler.Clear(); enBuyukSapmalar.Clear(); aylikOzet.Clear();
                toplamPlanlanan = toplamGerceklesen = 0;
                bekleyenSayisi = gecikmisSayisi = 0;
                return;
            }

            var tumKayitlar = new List<AylikOdemeGerceklesen>();
            int aBas = secilenAy == 0 ? 1 : secilenAy;
            int aBit = secilenAy == 0 ? 12 : secilenAy;

            for (int a = aBas; a <= aBit; a++)
            {
                try
                {
                    var liste = await AylikOdemeService.GetAylikOdemeleriAsync(aktifFirma.FirmaId, secilenYil, a);
                    tumKayitlar.AddRange(liste);
                }
                catch (Exception ex) { Logger.LogWarning(ex, "Ay {Ay} okunamadi", a); }
            }

            toplamPlanlanan = tumKayitlar.Sum(x => x.PlanlananTutar);
            toplamGerceklesen = tumKayitlar.Sum(x => x.OdenenTutar);
            bekleyenSayisi = tumKayitlar.Count(x => x.Durum == OdemeDurumu.Bekleniyor);
            gecikmisSayisi = tumKayitlar.Count(x => x.Durum == OdemeDurumu.Gecikti);

            // Kategori bazlı
            kategoriler = tumKayitlar
                .GroupBy(x => x.Plan?.Turu.ToString() ?? "Diger")
                .Select(g => new KategoriOzet
                {
                    Kategori = g.Key,
                    Planlanan = g.Sum(x => x.PlanlananTutar),
                    Gerceklesen = g.Sum(x => x.OdenenTutar)
                })
                .ToList();

            // En büyük sapmalar (mutlak değer)
            enBuyukSapmalar = tumKayitlar
                .Select(x => new DetaySatir
                {
                    Ad = x.Plan?.OdemeAdi ?? x.Aciklama ?? "Ödeme",
                    Kategori = x.Plan?.Turu.ToString() ?? "Diger",
                    Donem = $"{x.Yil}/{x.Ay:00}",
                    Planlanan = x.PlanlananTutar,
                    Gerceklesen = x.OdenenTutar
                })
                .Where(x => Math.Abs(x.Planlanan - x.Gerceklesen) > 0.01m)
                .OrderByDescending(x => Math.Abs(x.Planlanan - x.Gerceklesen))
                .Take(10)
                .ToList();

            // Aylık özet
            aylikOzet = tumKayitlar
                .GroupBy(x => x.Ay)
                .Select(g => new AylikOzet
                {
                    Ay = g.Key,
                    Planlanan = g.Sum(x => x.PlanlananTutar),
                    Gerceklesen = g.Sum(x => x.OdenenTutar)
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Butce vs Gerceklesen yuklenirken hata");
        }
        finally
        {
            isLoading = false;
        }
    }

    private class KategoriOzet
    {
        public string Kategori { get; set; } = "";
        public decimal Planlanan { get; set; }
        public decimal Gerceklesen { get; set; }
    }

    private class DetaySatir
    {
        public string Ad { get; set; } = "";
        public string Kategori { get; set; } = "";
        public string Donem { get; set; } = "";
        public decimal Planlanan { get; set; }
        public decimal Gerceklesen { get; set; }
    }

    private class AylikOzet
    {
        public int Ay { get; set; }
        public decimal Planlanan { get; set; }
        public decimal Gerceklesen { get; set; }
    }
}

