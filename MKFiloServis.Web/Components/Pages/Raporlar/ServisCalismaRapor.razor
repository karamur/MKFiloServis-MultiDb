@page "/rapor/servis-calisma"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@using Microsoft.JSInterop
@inject IRaporService RaporService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject ICariService CariService
@inject IExcelService ExcelService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Servis Çalışma Raporu</PageTitle>

<div class="container-fluid">
    <h3 class="mb-3"><i class="bi bi-file-earmark-bar-graph me-2"></i>Servis Çalışma Raporu</h3>

    <div class="card mb-3">
        <div class="card-header">
            <h6 class="mb-0">Filtre</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Başlangıç Tarihi</label>
                        <input type="date" class="form-control" @bind="baslangicTarihi" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Bitiş Tarihi</label>
                        <input type="date" class="form-control" @bind="bitisTarihi" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Firma</label>
                        <select class="form-select" @bind="secilenCariId">
                            <option value="0">Tümü</option>
                            @foreach (var cari in cariler)
                            {
                                <option value="@cari.Id">@cari.Unvan</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Araç</label>
                        <select class="form-select" @bind="secilenAracId">
                            <option value="0">Tümü</option>
                            @foreach (var arac in araclar)
                            {
                                <option value="@arac.Id">@arac.AktifPlaka</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Şoför</label>
                        <select class="form-select" @bind="secilenSoforId">
                            <option value="0">Tümü</option>
                            @foreach (var sofor in soforler)
                            {
                                <option value="@sofor.Id">@sofor.TamAd</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Sahiplik</label>
                        <select class="form-select" @bind="secilenSahiplikTipi">
                            <option value="">Tümü</option>
                            <option value="Ozmal">Özmal</option>
                            <option value="Kiralik">Kiralık</option>
                            <option value="Komisyon">Komisyon</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" @onclick="RaporGetir">
                                <i class="bi bi-search"></i>
                            </button>
                            <button class="btn btn-success" @onclick="ExceleAktar" disabled="@(raporData == null || !raporData.Any())">
                                <i class="bi bi-file-earmark-excel"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (raporData != null)
    {
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Çalışılan Gün</h6>
                        <h3>@raporData.Sum(r => r.CalisilanGun)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Tutar</h6>
                        <h3>@raporData.Sum(r => r.ToplamTutar).ToString("N2") ?</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h6>Güzergah Sayısı</h6>
                        <h3>@raporData.Select(r => r.GuzergahAdi).Distinct().Count()</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center">
                        <h6>Araç Sayısı</h6>
                        <h3>@raporData.Select(r => r.Plaka).Distinct().Count()</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Firma</th>
                                <th>Güzergah</th>
                                <th>Plaka</th>
                                <th>Şoför</th>
                                <th>Servis Türü</th>
                                <th class="text-end">Birim Fiyat</th>
                                <th class="text-center">Çalışılan Gün</th>
                                <th class="text-end">Toplam Tutar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in raporData)
                            {
                                <tr>
                                    <td>@item.FirmaAdi</td>
                                    <td>@item.GuzergahAdi</td>
                                    <td><strong>@item.Plaka</strong></td>
                                    <td>@item.SoforAdi</td>
                                    <td>@item.ServisTuru</td>
                                    <td class="text-end">@item.BirimFiyat.ToString("N2") ?</td>
                                    <td class="text-center"><strong>@item.CalisilanGun</strong></td>
                                    <td class="text-end"><strong class="text-success">@item.ToplamTutar.ToString("N2") ?</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary">
                            <tr>
                                <td colspan="6" class="text-end"><strong>TOPLAM:</strong></td>
                                <td class="text-center"><strong>@raporData.Sum(r => r.CalisilanGun)</strong></td>
                                <td class="text-end"><strong class="text-primary">@raporData.Sum(r => r.ToplamTutar).ToString("N2") ?</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-30);
    private DateTime bitisTarihi = DateTime.Today;
    private int secilenCariId = 0;
    private int secilenAracId = 0;
    private int secilenSoforId = 0;
    private string secilenSahiplikTipi = "";
    private bool isLoading = false;

    private List<Cari> cariler = new();
    private List<Arac> araclar = new();
    private List<Sofor> soforler = new();
    private List<ServisCalismaRaporItem>? raporData;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetByTipAsync(CariTipi.Musteri);
        araclar = await AracService.GetActiveAsync();
        soforler = await SoforService.GetActiveAsync();
    }

    private async Task RaporGetir()
    {
        isLoading = true;
        try
        {
            AracSahiplikTipi? sahiplikTipi = null;
            if (!string.IsNullOrEmpty(secilenSahiplikTipi) && Enum.TryParse<AracSahiplikTipi>(secilenSahiplikTipi, out var parsed))
                sahiplikTipi = parsed;

            raporData = await RaporService.GetServisCalismaRaporuAsync(
                baslangicTarihi,
                bitisTarihi,
                secilenAracId > 0 ? secilenAracId : null,
                secilenSoforId > 0 ? secilenSoforId : null,
                null,
                secilenCariId > 0 ? secilenCariId : null,
                sahiplikTipi
            );
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExceleAktar()
    {
        if (raporData == null || !raporData.Any())
            return;

        var excelBytes = ExcelService.ExportServisCalismaRaporu(raporData);
        var fileName = $"ServisCalismaRaporu_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(excelBytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }
}

