@page "/raporlar/arac-karlilik"
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@using MKFiloServis.Shared.Entities
@inject IRaporService RaporService
@inject IAracService AracService
@inject IExcelService ExcelService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Araç Karlılık Raporu - Koa Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-graph-up-arrow me-2"></i>Araç Karlılık Raporu</h2>
    </div>

    <!-- Filtre Alanı -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Başlangıç Tarihi</label>
                    <input type="date" class="form-control" @bind="baslangicTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bitiş Tarihi</label>
                    <input type="date" class="form-control" @bind="bitisTarihi" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Araç Seçimi</label>
                    <select class="form-select" @bind="seciliAracId">
                        <option value="0">-- Tüm Araçlar (Karşılaştırma) --</option>
                        @foreach (var arac in filtreliAraclar)
                        {
                            <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Sahiplik Tipi</label>
                    <select class="form-select" @bind="seciliSahiplikTipi" @bind:after="SahiplikDegisti">
                        <option value="">Tümü</option>
                        <option value="Ozmal">Özmal</option>
                        <option value="Kiralik">Kiralık</option>
                        <option value="Komisyon">Komisyon</option>
                        <option value="Tedarikci">Tedarikçi</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" @onclick="RaporGetir">
                        <i class="bi bi-search me-1"></i>Rapor Getir
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-2">Rapor hazırlanıyor...</p>
        </div>
    }
    else if (seciliAracId > 0 && aracOzet != null)
    {
        <!-- Tekil Araç Detaylı Raporu -->
        <div class="row g-4 mb-4">
            <!-- Özet Kartları -->
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Gelir</h6>
                        <h3 class="card-title mb-0">@aracOzet.ToplamGelir.ToString("N2") ₺</h3>
                        <small>@aracOzet.ToplamSeferSayisi sefer</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Gider</h6>
                        <h3 class="card-title mb-0">@aracOzet.ToplamGider.ToString("N2") ₺</h3>
                        <small>Masraf + Kira + Komisyon</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(aracOzet.NetKar >= 0 ? "bg-success" : "bg-warning") text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Net Kar</h6>
                        <h3 class="card-title mb-0">@aracOzet.NetKar.ToString("N2") ₺</h3>
                        <small>Kar Marjı: %@aracOzet.KarMarji.ToString("N1")</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Arıza Oranı</h6>
                        <h3 class="card-title mb-0">%@aracOzet.ArizaOrani.ToString("N1")</h3>
                        <small>@aracOzet.ArizaSayisi arıza / @aracOzet.CalismaGunSayisi gün</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Araç Bilgileri -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-truck me-2"></i>Araç Bilgileri</span>
                <button class="btn btn-sm btn-success" @onclick="ExcelExport">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <p><strong>Plaka:</strong> @aracOzet.Plaka</p>
                    </div>
                    <div class="col-md-3">
                        <p><strong>Marka/Model:</strong> @aracOzet.Marka @aracOzet.Model</p>
                    </div>
                    <div class="col-md-3">
                        <p><strong>Sahiplik:</strong> @aracOzet.SahiplikTipi</p>
                    </div>
                    <div class="col-md-3">
                        <p><strong>Son Çalışma:</strong> @(aracOzet.SonCalismaTarihi?.ToString("dd.MM.yyyy") ?? "-")</p>
                    </div>
                </div>
                @if (aracOzet.KiraBedeli > 0 || aracOzet.KomisyonTutari > 0)
                {
                    <div class="row mt-2">
                        @if (aracOzet.KiraBedeli > 0)
                        {
                            <div class="col-md-3">
                                <p><strong>Kira Bedeli:</strong> @aracOzet.KiraBedeli.ToString("N2") ₺</p>
                            </div>
                        }
                        @if (aracOzet.KomisyonTutari > 0)
                        {
                            <div class="col-md-3">
                                <p><strong>Komisyon:</strong> @aracOzet.KomisyonTutari.ToString("N2") ₺</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="row">
            <!-- Aylık Karlılık Grafiği -->
            <div class="col-md-8 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-bar-chart me-2"></i>Aylık Karlılık Trendi
                    </div>
                    <div class="card-body">
                        <canvas id="aylikKarlilikChart" height="250"></canvas>
                    </div>
                </div>
            </div>

            <!-- Masraf Dağılımı -->
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-pie-chart me-2"></i>Masraf Dağılımı
                    </div>
                    <div class="card-body">
                        @if (aracOzet.MasrafDetaylari.Any())
                        {
                            <canvas id="masrafDagilimChart" height="250"></canvas>
                        }
                        else
                        {
                            <p class="text-muted text-center">Masraf kaydı bulunmamaktadır.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Güzergah Performansları -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-signpost-split me-2"></i>Güzergah Performansları
            </div>
            <div class="card-body">
                @if (aracOzet.GuzergahPerformanslari.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Güzergah</th>
                                    <th>Firma</th>
                                    <th class="text-end">Sefer</th>
                                    <th class="text-end">Toplam Gelir</th>
                                    <th class="text-end">Ort. Gelir/Sefer</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var guzergah in aracOzet.GuzergahPerformanslari)
                                {
                                    <tr>
                                        <td>@guzergah.GuzergahAdi</td>
                                        <td>@guzergah.FirmaAdi</td>
                                        <td class="text-end">@guzergah.SeferSayisi</td>
                                        <td class="text-end">@guzergah.ToplamGelir.ToString("N2") ₺</td>
                                        <td class="text-end">@guzergah.OrtalamaGelir.ToString("N2") ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">Güzergah performans verisi bulunmamaktadır.</p>
                }
            </div>
        </div>

        <!-- Masraf Detayları -->
        @if (aracOzet.MasrafDetaylari.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-cash-stack me-2"></i>Masraf Detayları
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Masraf Kalemi</th>
                                    <th class="text-end">Adet</th>
                                    <th class="text-end">Toplam Tutar</th>
                                    <th class="text-end">Oran</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var masraf in aracOzet.MasrafDetaylari)
                                {
                                    <tr>
                                        <td>@masraf.MasrafKalemiAdi</td>
                                        <td class="text-end">@masraf.Adet</td>
                                        <td class="text-end">@masraf.ToplamTutar.ToString("N2") ₺</td>
                                        <td class="text-end">
                                            <div class="progress" style="width: 100px; display: inline-block;">
                                                <div class="progress-bar" role="progressbar" style="width: @masraf.Oran%"></div>
                                            </div>
                                            %@masraf.Oran.ToString("N1")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th>Toplam</th>
                                    <th class="text-end">@aracOzet.MasrafDetaylari.Sum(m => m.Adet)</th>
                                    <th class="text-end">@aracOzet.ToplamMasraf.ToString("N2") ₺</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
    else if (karsilastirmaListesi != null && karsilastirmaListesi.Any())
    {
        <!-- Tüm Araçlar Karşılaştırma Raporu -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Araç</h6>
                        <h3 class="card-title mb-0">@karsilastirmaListesi.Count</h3>
                        <small>Aktif çalışan araç</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Gelir</h6>
                        <h3 class="card-title mb-0">@karsilastirmaListesi.Sum(k => k.ToplamGelir).ToString("N0") ₺</h3>
                        <small>Tüm araçlar</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Gider</h6>
                        <h3 class="card-title mb-0">@karsilastirmaListesi.Sum(k => k.ToplamGider).ToString("N0") ₺</h3>
                        <small>Tüm araçlar</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white h-100">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Net Kar</h6>
                        <h3 class="card-title mb-0">@karsilastirmaListesi.Sum(k => k.NetKar).ToString("N0") ₺</h3>
                        <small>Filo geneli</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-table me-2"></i>Araç Karşılaştırma Tablosu</span>
                <button class="btn btn-sm btn-success" @onclick="ExcelExportKarsilastirma">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Sıra</th>
                                <th>Plaka</th>
                                <th>Marka/Model</th>
                                <th>Sahiplik</th>
                                <th class="text-end">Sefer</th>
                                <th class="text-end">Gelir</th>
                                <th class="text-end">Gider</th>
                                <th class="text-end">Net Kar</th>
                                <th class="text-end">Kar %</th>
                                <th class="text-end">Arıza %</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var arac in karsilastirmaListesi)
                            {
                                <tr class="@(arac.NetKar < 0 ? "table-danger" : "")">
                                    <td>
                                        <span class="badge @(arac.KarlilikSirasi <= 3 ? "bg-success" : "bg-secondary")">
                                            @arac.KarlilikSirasi
                                        </span>
                                    </td>
                                    <td><strong>@arac.Plaka</strong></td>
                                    <td>@arac.MarkaModel</td>
                                    <td>
                                        <span class="badge @(arac.SahiplikTipi == "Özmal" ? "bg-primary" : "bg-warning text-dark")">
                                            @arac.SahiplikTipi
                                        </span>
                                    </td>
                                    <td class="text-end">@arac.SeferSayisi</td>
                                    <td class="text-end text-success">@arac.ToplamGelir.ToString("N0") ₺</td>
                                    <td class="text-end text-danger">@arac.ToplamGider.ToString("N0") ₺</td>
                                    <td class="text-end @(arac.NetKar >= 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                                        @arac.NetKar.ToString("N0") ₺
                                    </td>
                                    <td class="text-end">%@arac.KarMarji.ToString("N1")</td>
                                    <td class="text-end">
                                        @if (arac.ArizaOrani > 10)
                                        {
                                            <span class="text-danger">%@arac.ArizaOrani.ToString("N1")</span>
                                        }
                                        else
                                        {
                                            <span>%@arac.ArizaOrani.ToString("N1")</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" 
                                                @onclick="() => AracDetayGoster(arac.AracId)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="4">Toplam</td>
                                <td class="text-end">@karsilastirmaListesi.Sum(k => k.SeferSayisi)</td>
                                <td class="text-end text-success">@karsilastirmaListesi.Sum(k => k.ToplamGelir).ToString("N0") ₺</td>
                                <td class="text-end text-danger">@karsilastirmaListesi.Sum(k => k.ToplamGider).ToString("N0") ₺</td>
                                <td class="text-end">@karsilastirmaListesi.Sum(k => k.NetKar).ToString("N0") ₺</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (!yukleniyor)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Rapor görüntülemek için tarih aralığı seçip "Rapor Getir" butonuna tıklayın.
        </div>
    }
</div>

@code {
    private List<Arac> araclar = [];
    private DateTime baslangicTarihi = new DateTime(DateTime.Today.Year, 1, 1);
    private DateTime bitisTarihi = DateTime.Today;
    private int seciliAracId = 0;
    private string seciliSahiplikTipi = "";
    private bool yukleniyor = false;

    private AracKarlilikOzet? aracOzet;
    private List<AracKarsilastirmaOzeti>? karsilastirmaListesi;

    // Sahiplik tipine göre filtrelenmiş araçlar
    private IEnumerable<Arac> filtreliAraclar => string.IsNullOrEmpty(seciliSahiplikTipi) 
        ? araclar 
        : araclar.Where(a => a.SahiplikTipi.ToString() == seciliSahiplikTipi);

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetAllAsync();
    }

    private void SahiplikDegisti()
    {
        // Eğer seçili araç, yeni sahiplik tipine uygun değilse sıfırla
        if (seciliAracId > 0 && !string.IsNullOrEmpty(seciliSahiplikTipi))
        {
            var seciliArac = araclar.FirstOrDefault(a => a.Id == seciliAracId);
            if (seciliArac != null && seciliArac.SahiplikTipi.ToString() != seciliSahiplikTipi)
            {
                seciliAracId = 0;
            }
        }
    }

    private async Task RaporGetir()
    {
        yukleniyor = true;
        aracOzet = null;
        karsilastirmaListesi = null;
        StateHasChanged();

        try
        {
            AracSahiplikTipi? sahiplikTipi = null;
            if (!string.IsNullOrEmpty(seciliSahiplikTipi) && Enum.TryParse<AracSahiplikTipi>(seciliSahiplikTipi, out var parsed))
                sahiplikTipi = parsed;

            if (seciliAracId > 0)
            {
                aracOzet = await RaporService.GetAracKarlilikAsync(seciliAracId, baslangicTarihi, bitisTarihi);
            }
            else
            {
                karsilastirmaListesi = await RaporService.GetAracKarsilastirmaAsync(baslangicTarihi, bitisTarihi, sahiplikTipi);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Rapor getirme hatası: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && aracOzet != null)
        {
            await RenderChartsAsync();
        }
    }

    private async Task RenderChartsAsync()
    {
        if (aracOzet == null) return;

        // Aylık Karlılık Chart
        if (aracOzet.AylikKarlilik.Any())
        {
            var labels = aracOzet.AylikKarlilik.Select(a => a.AyAdi).ToArray();
            var gelirData = aracOzet.AylikKarlilik.Select(a => (double)a.Gelir).ToArray();
            var giderData = aracOzet.AylikKarlilik.Select(a => (double)a.ToplamGider).ToArray();
            var karData = aracOzet.AylikKarlilik.Select(a => (double)a.NetKar).ToArray();

            await JS.InvokeVoidAsync("createMultiBarChart", "aylikKarlilikChart", labels,
                new[] { "Gelir", "Gider", "Net Kar" },
                new[] { gelirData, giderData, karData },
                new[] { "#198754", "#dc3545", "#0d6efd" });
        }

        // Masraf Dağılımı Chart
        if (aracOzet.MasrafDetaylari.Any())
        {
            var labels = aracOzet.MasrafDetaylari.Select(m => m.MasrafKalemiAdi).ToArray();
            var data = aracOzet.MasrafDetaylari.Select(m => (double)m.ToplamTutar).ToArray();

            await JS.InvokeVoidAsync("createDoughnutChart", "masrafDagilimChart", labels, data);
        }
    }

    private async Task AracDetayGoster(int aracId)
    {
        seciliAracId = aracId;
        await RaporGetir();
    }

    private async Task ExcelExport()
    {
        if (aracOzet == null) return;

        var fileName = $"AracKarlilik_{aracOzet.Plaka}_{baslangicTarihi:yyyyMMdd}_{bitisTarihi:yyyyMMdd}.xlsx";
        var bytes = ExcelService.ExportAracKarlilikRaporu(aracOzet);
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExcelExportKarsilastirma()
    {
        if (karsilastirmaListesi == null || !karsilastirmaListesi.Any()) return;

        var fileName = $"AracKarsilastirma_{baslangicTarihi:yyyyMMdd}_{bitisTarihi:yyyyMMdd}.xlsx";
        var bytes = ExcelService.ExportAracKarlilikKarsilastirmaRaporu(karsilastirmaListesi);
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }
}

