    private async Task ExcelExport()
    {
        try
        {
            // EPPlus 8+ için yeni lisans ayar©
            OfficeOpenXml.ExcelPackage.License.SetNonCommercialPersonal("MKFiloServis");
            using var package = new ExcelPackage();
            var ws = package.Workbook.Worksheets.Add("Cari Ekstre");

            int row = 1;

            // Baslik
            ws.Cells[row, 1].Value = firma?.FirmaAdi ?? "CRM Filo Servis";
            ws.Cells[row, 1, row, 7].Merge = true;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 1].Style.Font.Size = 16;
            ws.Cells[row, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;
            row += 2;

            ws.Cells[row, 1].Value = "CARI EKSTRE RAPORU";
            ws.Cells[row, 1, row, 7].Merge = true;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;
            row++;

            ws.Cells[row, 1].Value = $"Tarih Araligi: {baslangicTarihi:dd.MM.yyyy} - {bitisTarihi:dd.MM.yyyy}";
            ws.Cells[row, 1, row, 7].Merge = true;
            ws.Cells[row, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;
            row += 2;

            foreach (var cariGrup in tumEkstreHareketleri.GroupBy(e => e.CariId))
            {
                var cari = cariler.FirstOrDefault(c => c.Id == cariGrup.Key);
                var cariHareketler = cariGrup.OrderBy(e => e.Tarih).ToList();
                var cariOncekiBakiye = oncekiBakiyeler.GetValueOrDefault(cariGrup.Key, 0);
                var cariToplamAlacak = cariHareketler.Sum(e => e.Alacak);
                var cariToplamBorc = cariHareketler.Sum(e => e.Borc);
                var cariBakiye = cariOncekiBakiye + cariToplamAlacak - cariToplamBorc;

                // Cari baslik
                ws.Cells[row, 1].Value = $"{cari?.CariKodu} - {cari?.Unvan}";
                ws.Cells[row, 1, row, 7].Merge = true;
                ws.Cells[row, 1].Style.Font.Bold = true;
                ws.Cells[row, 1].Style.Fill.PatternType = ExcelFillStyle.Solid;
                ws.Cells[row, 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGray);
                row++;

                // Basliklar
                var headers = new[] { "Tarih", "Islem Turu", "Belge No", "Aciklama", "Borc", "Alacak", "Bakiye" };
                for (int i = 0; i < headers.Length; i++)
                {
                    ws.Cells[row, i + 1].Value = headers[i];
                    ws.Cells[row, i + 1].Style.Font.Bold = true;
                    ws.Cells[row, i + 1].Style.Fill.PatternType = ExcelFillStyle.Solid;
                    ws.Cells[row, i + 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightBlue);
                }
                row++;

                // Onceki donem
                ws.Cells[row, 1].Value = "Onceki Donem";
                ws.Cells[row, 1, row, 4].Merge = true;
                ws.Cells[row, 7].Value = cariOncekiBakiye;
                ws.Cells[row, 7].Style.Numberformat.Format = "#,##0.00";
                row++;

                // Hareketler
                var runningBakiye = cariOncekiBakiye;
                foreach (var h in cariHareketler)
                {
                    runningBakiye += h.Alacak - h.Borc;
                    ws.Cells[row, 1].Value = h.Tarih;
                    ws.Cells[row, 1].Style.Numberformat.Format = "dd.MM.yyyy";
                    ws.Cells[row, 2].Value = h.IslemTipi;
                    ws.Cells[row, 3].Value = h.BelgeNo;
                    ws.Cells[row, 4].Value = h.Aciklama;
                    ws.Cells[row, 5].Value = h.Borc > 0 ? h.Borc : null;
                    ws.Cells[row, 6].Value = h.Alacak > 0 ? h.Alacak : null;
                    ws.Cells[row, 7].Value = runningBakiye;
                    ws.Cells[row, 5, row, 7].Style.Numberformat.Format = "#,##0.00";
                    row++;
                }

                // Toplam
                ws.Cells[row, 1].Value = "TOPLAM";
                ws.Cells[row, 1, row, 4].Merge = true;
                ws.Cells[row, 1].Style.Font.Bold = true;
                ws.Cells[row, 5].Value = cariToplamBorc;
                ws.Cells[row, 6].Value = cariToplamAlacak;
                ws.Cells[row, 7].Value = cariBakiye;
                ws.Cells[row, 5, row, 7].Style.Numberformat.Format = "#,##0.00";
                ws.Cells[row, 5, row, 7].Style.Font.Bold = true;
                ws.Cells[row, 1, row, 7].Style.Fill.PatternType = ExcelFillStyle.Solid;
                ws.Cells[row, 1, row, 7].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightYellow);
                row += 2;
            }

            // Genel Toplam
            ws.Cells[row, 1].Value = "GENEL TOPLAM";
            ws.Cells[row, 1, row, 4].Merge = true;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 1].Style.Font.Size = 12;
            ws.Cells[row, 5].Value = genelToplamBorc;
            ws.Cells[row, 6].Value = genelToplamAlacak;
            ws.Cells[row, 7].Value = genelNetBakiye;
            ws.Cells[row, 5, row, 7].Style.Numberformat.Format = "#,##0.00";
            ws.Cells[row, 5, row, 7].Style.Font.Bold = true;
            ws.Cells[row, 1, row, 7].Style.Fill.PatternType = ExcelFillStyle.Solid;
            ws.Cells[row, 1, row, 7].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGreen);

            // Kolon genislik
            ws.Cells.AutoFitColumns();
            ws.Column(4).Width = 40; // Aciklama

            // Border
            var dataRange = ws.Cells[1, 1, row, 7];
            dataRange.Style.Border.Top.Style = ExcelBorderStyle.Thin;
            dataRange.Style.Border.Bottom.Style = ExcelBorderStyle.Thin;
            dataRange.Style.Border.Left.Style = ExcelBorderStyle.Thin;
            dataRange.Style.Border.Right.Style = ExcelBorderStyle.Thin;

            var bytes = package.GetAsByteArray();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"CariEkstre_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Excel export hatasi: {ex.Message}");
        }
    }

    private string GetIslemTipiBadge(string islemTipi) => islemTipi switch
    {
        "Satis" => "bg-success",
        "Alis" => "bg-primary",
        "Tahsilat" => "bg-info",
        "Odeme" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private class EkstreHareket
    {
        public int CariId { get; set; }
        public DateTime Tarih { get; set; }
        public string IslemTipi { get; set; } = "";
        public string? BelgeNo { get; set; }
        public string? Aciklama { get; set; }
        public decimal Borc { get; set; }
        public decimal Alacak { get; set; }
    }
}












