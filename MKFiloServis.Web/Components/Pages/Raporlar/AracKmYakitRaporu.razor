@page "/raporlar/arac-km-yakit"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@inject IServisCalismaService ServisCalismaService
@inject IAracMasrafService AracMasrafService
@inject IAracService AracService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Araç KM & Yakıt Raporu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-fuel-pump-fill me-2"></i>Araç KM & Yakıt Raporu</h2>
            <p class="text-muted mb-0">Puantaj km ölçümleri ve yakıt masrafları üzerinden tüketim/maliyet analizi</p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="bas" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="bit" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Hızlı Seçim</label>
                    <select class="form-select form-select-sm" @bind="hizliSecim" @bind:after="HizliSecimUygula">
                        <option value="">— Seç —</option>
                        <option value="buay">Bu Ay</option>
                        <option value="gecenay">Geçen Ay</option>
                        <option value="son30">Son 30 Gün</option>
                        <option value="buyil">Bu Yıl</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Plaka Filtre</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Plaka ile ara..." @bind="plakaFiltre" @bind:after="StateHasChanged" />
                </div>
                <div class="col-md-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="cbBosGizle" @bind="bosSatirGizle" @bind:after="StateHasChanged" />
                        <label class="form-check-label small" for="cbBosGizle">KM yok ise gizle</label>
                    </div>
                </div>
                <div class="col-md-1 text-end">
                    <button class="btn btn-outline-primary btn-sm w-100" @onclick="ExcelIndir" disabled="@yukleniyor" title="Excel indir">
                        <i class="bi bi-file-earmark-excel"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="card"><div class="card-body p-4 text-center text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
        </div></div>
    }
    else
    {
        var satirlar = HesaplaSatirlar();
        var gosterilen = bosSatirGizle ? satirlar.Where(s => s.ToplamKm > 0 || s.YakitTutar > 0).ToList() : satirlar;
        if (!string.IsNullOrWhiteSpace(plakaFiltre))
        {
            var f = plakaFiltre.Trim().ToLowerInvariant();
            gosterilen = gosterilen.Where(s => (s.Plaka ?? "").ToLowerInvariant().Contains(f)).ToList();
        }

        var topKm = gosterilen.Sum(s => s.ToplamKm);
        var topYakit = gosterilen.Sum(s => s.YakitTutar);
        var topSefer = gosterilen.Sum(s => s.SeferSayisi);
        var ortMaliyet = topKm > 0 ? topYakit / topKm : 0;

        <!-- Özet kartlar -->
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-primary shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Aktif Araç</div>
                        <div class="fs-4 fw-bold text-primary">@gosterilen.Count(s => s.ToplamKm > 0)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Toplam KM</div>
                        <div class="fs-4 fw-bold text-info">@topKm.ToString("N0") km</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Toplam Yakıt Gideri</div>
                        <div class="fs-4 fw-bold text-warning">@topYakit.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Ortalama ₺/km</div>
                        <div class="fs-4 fw-bold text-success">@ortMaliyet.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between">
                <strong><i class="bi bi-table me-1"></i>Araç Bazında KM & Yakıt Detayı</strong>
                <span class="text-muted small">@gosterilen.Count satır — @bas:dd.MM.yyyy / @bit:dd.MM.yyyy</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Plaka</th>
                                <th>Marka/Model</th>
                                <th class="text-center">Sefer</th>
                                <th class="text-center">Çalışılan Gün</th>
                                <th class="text-end">Toplam KM</th>
                                <th class="text-end">Ort. Günlük KM</th>
                                <th class="text-end">Yakıt Gideri</th>
                                <th class="text-end">₺/km</th>
                                <th class="text-end">Sefer Başı KM</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!gosterilen.Any())
                            {
                                <tr><td colspan="9" class="text-center text-muted p-4">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                    Bu dönem için kayıt bulunamadı.
                                </td></tr>
                            }
                            else
                            {
                                foreach (var s in gosterilen.OrderByDescending(x => x.ToplamKm).ThenBy(x => x.Plaka))
                                {
                                    <tr>
                                        <td><strong>@s.Plaka</strong></td>
                                        <td><span class="text-muted small">@s.MarkaModel</span></td>
                                        <td class="text-center"><span class="badge bg-primary">@s.SeferSayisi</span></td>
                                        <td class="text-center">@s.CalisilanGun</td>
                                        <td class="text-end fw-bold">@s.ToplamKm.ToString("N0")</td>
                                        <td class="text-end">@(s.CalisilanGun > 0 ? (s.ToplamKm / (decimal)s.CalisilanGun).ToString("N1") : "-")</td>
                                        <td class="text-end text-warning fw-bold">@s.YakitTutar.ToString("N2")</td>
                                        <td class="text-end @(s.MaliyetPerKm > 0 ? "text-success fw-bold" : "text-muted")">
                                            @(s.MaliyetPerKm > 0 ? s.MaliyetPerKm.ToString("N2") : "-")
                                        </td>
                                        <td class="text-end">@(s.SeferSayisi > 0 ? (s.ToplamKm / (decimal)s.SeferSayisi).ToString("N1") : "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="2">TOPLAM</td>
                                <td class="text-center text-primary">@topSefer</td>
                                <td class="text-center">@gosterilen.Sum(s => s.CalisilanGun)</td>
                                <td class="text-end">@topKm.ToString("N0")</td>
                                <td></td>
                                <td class="text-end text-warning">@topYakit.ToString("N2")</td>
                                <td class="text-end text-success">@ortMaliyet.ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-2 small text-muted">
            <i class="bi bi-info-circle me-1"></i>
            <strong>KM:</strong> Puantaj kayıtlarındaki <code>KmBitis - KmBaslangic</code> toplamıdır.
            <strong>Yakıt:</strong> Dönemdeki <code>MasrafKategori = Yakit</code> kalemli araç masraflarının toplamıdır.
            <strong>₺/km:</strong> Yakıt gideri ÷ toplam km. Yakıt veya KM verisi eksik araçlarda hesap yapılamaz.
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private DateTime bas = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bit = DateTime.Today;
    private string hizliSecim = "";
    private string plakaFiltre = "";
    private bool bosSatirGizle = true;

    private List<ServisCalisma> kayitlar = new();
    private List<AracMasraf> yakitMasraflari = new();
    private List<Arac> araclar = new();

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetActiveAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            var bb = bas.Date;
            var bs = bit.Date.AddDays(1).AddSeconds(-1);
            kayitlar = await ServisCalismaService.GetByDateRangeAsync(bb, bs);
            yakitMasraflari = await AracMasrafService.GetByKategoriAsync(MasrafKategori.Yakit, bb, bs);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenemedi: {ex.Message}");
        }
        finally { yukleniyor = false; }
    }

    private async Task HizliSecimUygula()
    {
        var bugun = DateTime.Today;
        switch (hizliSecim)
        {
            case "buay":
                bas = new DateTime(bugun.Year, bugun.Month, 1); bit = bugun; break;
            case "gecenay":
                var gecenAy = bugun.AddMonths(-1);
                bas = new DateTime(gecenAy.Year, gecenAy.Month, 1);
                bit = bas.AddMonths(1).AddDays(-1); break;
            case "son30":
                bas = bugun.AddDays(-30); bit = bugun; break;
            case "buyil":
                bas = new DateTime(bugun.Year, 1, 1); bit = bugun; break;
            default:
                return;
        }
        await LoadAsync();
    }

    private record AracKmRow(
        int AracId, string Plaka, string MarkaModel,
        int SeferSayisi, int CalisilanGun, decimal ToplamKm,
        decimal YakitTutar, decimal MaliyetPerKm);

    private List<AracKmRow> HesaplaSatirlar()
    {
        var aracIds = kayitlar.Select(k => k.AracId)
            .Concat(yakitMasraflari.Select(m => m.AracId))
            .Distinct().ToHashSet();

        var havuz = araclar
            .Where(a => aracIds.Contains(a.Id) || !bosSatirGizle)
            .Concat(kayitlar.Where(k => k.Arac != null && !araclar.Any(a => a.Id == k.AracId))
                            .Select(k => k.Arac!).Distinct())
            .DistinctBy(a => a.Id)
            .ToList();

        var liste = new List<AracKmRow>();
        foreach (var a in havuz)
        {
            var ks = kayitlar.Where(k => k.AracId == a.Id).ToList();
            int sefer = ks.Sum(k => SeferSayisinaCevir(k.ServisTuru));
            int gun = ks.Select(k => k.CalismaTarihi.Date).Distinct().Count();

            decimal toplamKm = ks
                .Where(k => k.KmBaslangic.HasValue && k.KmBitis.HasValue && k.KmBitis > k.KmBaslangic)
                .Sum(k => (decimal)(k.KmBitis!.Value - k.KmBaslangic!.Value));

            decimal yakit = yakitMasraflari.Where(m => m.AracId == a.Id).Sum(m => m.Tutar);
            decimal perKm = toplamKm > 0 && yakit > 0 ? yakit / toplamKm : 0m;

            liste.Add(new AracKmRow(a.Id, a.AktifPlaka ?? $"#{a.Id}",
                $"{a.Marka} {a.Model}".Trim(), sefer, gun, toplamKm, yakit, perKm));
        }
        return liste;
    }

    private static int SeferSayisinaCevir(ServisTuru t) => t switch
    {
        ServisTuru.SabahAksam => 2,
        _ => 1
    };

    private async Task ExcelIndir()
    {
        try
        {
            var satirlar = HesaplaSatirlar();
            if (bosSatirGizle) satirlar = satirlar.Where(s => s.ToplamKm > 0 || s.YakitTutar > 0).ToList();
            if (!string.IsNullOrWhiteSpace(plakaFiltre))
            {
                var f = plakaFiltre.Trim().ToLowerInvariant();
                satirlar = satirlar.Where(s => (s.Plaka ?? "").ToLowerInvariant().Contains(f)).ToList();
            }

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Arac KM Yakit");

            ws.Cell(1, 1).Value = $"Araç KM & Yakıt Raporu — {bas:dd.MM.yyyy} - {bit:dd.MM.yyyy}";
            ws.Cell(1, 1).Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 13;
            ws.Range(1, 1, 1, 9).Merge();

            string[] hd = { "Plaka", "Marka/Model", "Sefer", "Çalışılan Gün",
                "Toplam KM", "Ort. Günlük KM", "Yakıt Gideri (₺)", "₺/km", "Sefer Başı KM" };
            for (int i = 0; i < hd.Length; i++) ws.Cell(3, i + 1).Value = hd[i];
            var hr = ws.Range(3, 1, 3, hd.Length);
            hr.Style.Font.Bold = true;
            hr.Style.Fill.BackgroundColor = XLColor.LightSteelBlue;

            int r = 4;
            foreach (var s in satirlar.OrderByDescending(x => x.ToplamKm).ThenBy(x => x.Plaka))
            {
                ws.Cell(r, 1).Value = s.Plaka;
                ws.Cell(r, 2).Value = s.MarkaModel;
                ws.Cell(r, 3).Value = s.SeferSayisi;
                ws.Cell(r, 4).Value = s.CalisilanGun;
                ws.Cell(r, 5).Value = s.ToplamKm;
                ws.Cell(r, 6).Value = s.CalisilanGun > 0 ? Math.Round(s.ToplamKm / s.CalisilanGun, 1) : 0;
                ws.Cell(r, 7).Value = s.YakitTutar;
                ws.Cell(r, 8).Value = s.MaliyetPerKm;
                ws.Cell(r, 9).Value = s.SeferSayisi > 0 ? Math.Round(s.ToplamKm / s.SeferSayisi, 1) : 0;
                r++;
            }

            // Toplam
            ws.Cell(r, 1).Value = "TOPLAM";
            ws.Cell(r, 3).Value = satirlar.Sum(s => s.SeferSayisi);
            ws.Cell(r, 4).Value = satirlar.Sum(s => s.CalisilanGun);
            ws.Cell(r, 5).Value = satirlar.Sum(s => s.ToplamKm);
            ws.Cell(r, 7).Value = satirlar.Sum(s => s.YakitTutar);
            var topKm = satirlar.Sum(s => s.ToplamKm);
            var topYk = satirlar.Sum(s => s.YakitTutar);
            ws.Cell(r, 8).Value = topKm > 0 ? Math.Round(topYk / topKm, 2) : 0;
            ws.Range(r, 1, r, 9).Style.Font.Bold = true;
            ws.Range(r, 1, r, 9).Style.Fill.BackgroundColor = XLColor.LightYellow;

            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            wb.SaveAs(stream);
            var fileName = $"arac_km_yakit_{bas:yyyyMMdd}_{bit:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(stream.ToArray()));
            ToastService.ShowSuccess("Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel indirilemedi: {ex.GetBaseException().Message}");
        }
    }
}

