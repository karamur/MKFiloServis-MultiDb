@page "/tedarikci-servis/belgeler"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject ITasimaTedarikciService TasimaTedarikciService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Tedarikçi Belgeleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-folder2-open me-2"></i>Tedarikçi Belgeleri</h3>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-success" @onclick="YeniBelgeEkle" disabled="@(!tedarikciler.Any())">
                <i class="bi bi-plus-lg me-1"></i>Yeni Tedarikçi Belgesi
            </button>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/personel-tasima/tedarikciler")'>
                <i class="bi bi-truck me-1"></i>Tedarikçi Yönetimi
            </button>
            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/tedarikci-servis/arac-evraklari")'>
                <i class="bi bi-table me-1"></i>Tedarikçi Araç Evrakları
            </button>
        </div>
    </div>

    <div class="card mb-3 border-info">
        <div class="card-header py-2 bg-info bg-opacity-10">
            <strong><i class="bi bi-plus-circle me-1"></i>Hızlı Belge Ekle</strong>
            <span class="text-muted small ms-2">Tedarikçi seçip evrak yönetimine geçin veya mevcut belgeyi başka tedarikçiye taşıyın</span>
        </div>
        <div class="card-body py-2">
            <ul class="nav nav-tabs nav-sm mb-2">
                <li class="nav-item">
                    <button class="nav-link @(hizliTab == "yeni" ? "active" : "")" @onclick='() => hizliTab = "yeni"'>
                        <i class="bi bi-file-earmark-plus me-1"></i>Yeni Belge
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(hizliTab == "tasi" ? "active" : "")" @onclick='() => hizliTab = "tasi"'>
                        <i class="bi bi-arrow-left-right me-1"></i>Mevcut Belgeyi Tedarikçiye Taşı
                    </button>
                </li>
            </ul>

            @if (hizliTab == "yeni")
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label small mb-1">Tedarikçi *</label>
                        <select class="form-select form-select-sm" @bind="hizliTedarikciId">
                            <option value="0">— Tedarikçi seçin —</option>
                            @foreach (var t in tedarikciler.Where(t => t.Aktif))
                            {
                                <option value="@t.Id">@(string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-auto">
                        <button class="btn btn-sm btn-success" @onclick="HizliEvrakSayfasinaGit" disabled="@(hizliTedarikciId == 0)">
                            <i class="bi bi-arrow-right-circle me-1"></i>Evrak Sayfasına Git
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Belge Ara (Kategori, Adı, Açıklama)</label>
                        <input type="text" class="form-control form-control-sm"
                               @bind="tasiBelgeArama" @bind:event="oninput" placeholder="Örn: Vergi, Ticaret..." />
                        @if (FiltreliTasinacakBelgeler.Any() && tasinacakBelgeId == null)
                        {
                            <div class="border rounded mt-1 bg-white shadow-sm" style="max-height:220px;overflow-y:auto;z-index:100;position:relative">
                                @foreach (var e in FiltreliTasinacakBelgeler)
                                {
                                    <div class="px-2 py-1 border-bottom" @onclick="() => TasinacakBelgeSec(e)" style="cursor:pointer;font-size:.85rem">
                                        <span class="badge bg-secondary me-1" style="font-size:.7rem">@e.EvrakKategorisi</span>
                                        <strong>@(e.EvrakAdi ?? "-")</strong>
                                        <span class="text-muted ms-1" style="font-size:.75rem">(@e.TasimaTedarikci?.Unvan)</span>
                                    </div>
                                }
                            </div>
                        }
                        @if (tasinacakBelgeId.HasValue)
                        {
                            var b = tumBelgeler.FirstOrDefault(x => x.Id == tasinacakBelgeId.Value);
                            <div class="mt-1 px-2 py-1 bg-success bg-opacity-10 border border-success rounded d-flex justify-content-between align-items-center" style="font-size:.85rem">
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><strong>@b?.EvrakKategorisi</strong> — @(b?.EvrakAdi ?? "-") <small class="text-muted ms-1">(şu an: @b?.TasimaTedarikci?.Unvan)</small></span>
                                <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" @onclick="() => tasinacakBelgeId = null" title="Seçimi temizle">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Hedef Tedarikçi *</label>
                        <select class="form-select form-select-sm" @bind="tasiHedefTedarikciId">
                            <option value="0">— Tedarikçi seçin —</option>
                            @foreach (var t in tedarikciler.Where(t => t.Aktif))
                            {
                                <option value="@t.Id">@(string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-auto">
                        <button class="btn btn-sm btn-primary" @onclick="BelgeyiTasiAsync"
                                disabled="@(tasinacakBelgeId is null || tasiHedefTedarikciId == 0 || tasiYukleniyor)">
                            @if (tasiYukleniyor)
                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-link-45deg me-1"></i>Belgeyi Taşı
                        </button>
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(hizliMesaj))
            {
                <div class="alert alert-success py-1 mb-0 mt-2 small">@hizliMesaj</div>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="filtreTedarikciId">
                        <option value="0">Tümü</option>
                        @foreach (var t in tedarikciler)
                        {
                            <option value="@t.Id">@t.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filtreKategori">
                        <option value="">Tümü</option>
                        @foreach (var k in TedarikciEvrakKategorileri.TumKategoriler)
                        {
                            <option value="@k">@k</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="Tumu">Tümü</option>
                        <option value="Dolmus">Süresi Dolmuş</option>
                        <option value="Yaklasan">30 Gün İçinde Bitiyor</option>
                        <option value="Gecerli">Geçerli</option>
                        <option value="Eksik">Eksik (Tarih Yok)</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-1">
                    <input class="form-control form-control-sm" placeholder="Ara (Adı, Açıklama)" @bind="arama" @bind:event="oninput" />
                    <button class="btn btn-secondary btn-sm" @onclick="FiltreleriTemizle" title="Temizle">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-primary"><div class="card-body py-2">
                    <small class="text-muted">Filtre Sonucu</small>
                    <div class="fs-4 fw-bold text-primary">@FiltreliBelgeler.Count</div>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card border-success"><div class="card-body py-2">
                    <small class="text-muted">Geçerli</small>
                    <div class="fs-4 fw-bold text-success">@FiltreliBelgeler.Count(e => GetDurum(e) == "Gecerli")</div>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning"><div class="card-body py-2">
                    <small class="text-muted">30 Gün İçinde</small>
                    <div class="fs-4 fw-bold text-warning">@FiltreliBelgeler.Count(e => GetDurum(e) == "Yaklasan")</div>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card border-danger"><div class="card-body py-2">
                    <small class="text-muted">Süresi Dolmuş</small>
                    <div class="fs-4 fw-bold text-danger">@FiltreliBelgeler.Count(e => GetDurum(e) == "Dolmus")</div>
                </div></div>
            </div>
        </div>

        @if (!FiltreliBelgeler.Any())
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.</div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Tedarikçi</th>
                                    <th>Kategori</th>
                                    <th>Belge Adı</th>
                                    <th>Başlangıç</th>
                                    <th>Bitiş</th>
                                    <th class="text-center">Dosya</th>
                                    <th class="text-center">Durum</th>
                                    <th class="text-end">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var e in FiltreliBelgeler)
                            {
                                <tr>
                                    <td><strong>@e.TasimaTedarikci?.Unvan</strong></td>
                                    <td><span class="badge bg-secondary">@e.EvrakKategorisi</span></td>
                                    <td>@(e.EvrakAdi ?? "-")</td>
                                    <td>@e.BaslangicTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td>@e.BitisTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td class="text-center">@(e.Dosyalar?.Count ?? 0)</td>
                                    <td class="text-center">
                                        @{ var d = GetDurum(e); }
                                        <span class="badge @(d == "Dolmus" ? "bg-danger" : d == "Yaklasan" ? "bg-warning text-dark" : d == "Gecerli" ? "bg-success" : "bg-secondary")">
                                            @GetDurumText(d)
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@($"/personel-tasima/tedarikciler/{e.TasimaTedarikciId}/evraklar")"
                                           title="Tedarikçi belgelerini aç">
                                            <i class="bi bi-folder2-open"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool yukleniyor = true;
    private List<TasimaTedarikci> tedarikciler = new();
    private List<TedarikciEvrak> tumBelgeler = new();

    // Filtreler
    private int filtreTedarikciId;
    private string filtreKategori = string.Empty;
    private string filtreDurum = "Tumu";
    private string arama = string.Empty;

    // Hızlı ekleme/taşıma
    private string hizliTab = "yeni";
    private int hizliTedarikciId;
    private string tasiBelgeArama = string.Empty;
    private int? tasinacakBelgeId;
    private int tasiHedefTedarikciId;
    private bool tasiYukleniyor;
    private string? hizliMesaj;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            tedarikciler = await TasimaTedarikciService.GetAllAsync();
            tumBelgeler = await TasimaTedarikciService.GetAllTedarikciEvraklariAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Veri yüklenemedi: " + ex.Message);
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private List<TedarikciEvrak> FiltreliBelgeler => tumBelgeler
        .Where(e => filtreTedarikciId == 0 || e.TasimaTedarikciId == filtreTedarikciId)
        .Where(e => string.IsNullOrEmpty(filtreKategori) || e.EvrakKategorisi == filtreKategori)
        .Where(e => string.IsNullOrWhiteSpace(arama)
            || (e.EvrakAdi?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (e.Aciklama?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (e.EvrakKategorisi?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(e => filtreDurum == "Tumu" || GetDurum(e) == filtreDurum)
        .ToList();

    private List<TedarikciEvrak> FiltreliTasinacakBelgeler => string.IsNullOrWhiteSpace(tasiBelgeArama)
        ? new()
        : tumBelgeler
            .Where(e =>
                (e.EvrakKategorisi?.Contains(tasiBelgeArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.EvrakAdi?.Contains(tasiBelgeArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.Aciklama?.Contains(tasiBelgeArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.TasimaTedarikci?.Unvan?.Contains(tasiBelgeArama, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(20)
            .ToList();

    private void TasinacakBelgeSec(TedarikciEvrak e)
    {
        tasinacakBelgeId = e.Id;
        tasiBelgeArama = $"{e.EvrakKategorisi} - {e.EvrakAdi}";
    }

    private void YeniBelgeEkle()
    {
        var hedef = filtreTedarikciId > 0 ? filtreTedarikciId : tedarikciler.FirstOrDefault(t => t.Aktif)?.Id ?? 0;
        if (hedef <= 0)
        {
            ToastService.ShowWarning("Önce aktif bir tedarikçi tanımlayın.");
            return;
        }
        Navigation.NavigateTo($"/personel-tasima/tedarikciler/{hedef}/evraklar");
    }

    private void HizliEvrakSayfasinaGit()
    {
        if (hizliTedarikciId <= 0) return;
        Navigation.NavigateTo($"/personel-tasima/tedarikciler/{hizliTedarikciId}/evraklar");
    }

    private async Task BelgeyiTasiAsync()
    {
        if (!tasinacakBelgeId.HasValue || tasiHedefTedarikciId <= 0) return;
        try
        {
            tasiYukleniyor = true;
            var belge = tumBelgeler.FirstOrDefault(x => x.Id == tasinacakBelgeId.Value);
            if (belge == null)
            {
                ToastService.ShowError("Belge bulunamadı.");
                return;
            }
            if (belge.TasimaTedarikciId == tasiHedefTedarikciId)
            {
                ToastService.ShowInfo("Belge zaten bu tedarikçide.");
                return;
            }

            var eskiTed = belge.TasimaTedarikci?.Unvan ?? "-";
            belge.TasimaTedarikciId = tasiHedefTedarikciId;
            await TasimaTedarikciService.UpdateTedarikciEvrakAsync(belge);

            var yeniTed = tedarikciler.FirstOrDefault(t => t.Id == tasiHedefTedarikciId)?.Unvan ?? "Tedarikçi";
            hizliMesaj = $"Belge taşındı: {eskiTed} → {yeniTed}";
            ToastService.ShowSuccess(hizliMesaj);

            tasinacakBelgeId = null;
            tasiBelgeArama = string.Empty;
            tasiHedefTedarikciId = 0;

            tumBelgeler = await TasimaTedarikciService.GetAllTedarikciEvraklariAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Belge taşınamadı: " + ex.Message);
        }
        finally
        {
            tasiYukleniyor = false;
        }
    }

    private void FiltreleriTemizle()
    {
        filtreTedarikciId = 0;
        filtreKategori = string.Empty;
        filtreDurum = "Tumu";
        arama = string.Empty;
    }

    private string GetDurum(TedarikciEvrak e)
    {
        if (!e.BitisTarihi.HasValue) return "Eksik";
        var gun = (e.BitisTarihi.Value.Date - DateTime.Today).Days;
        if (gun < 0) return "Dolmus";
        if (gun <= 30) return "Yaklasan";
        return "Gecerli";
    }

    private string GetDurumText(string d) => d switch
    {
        "Dolmus" => "Süresi Dolmuş",
        "Yaklasan" => "30 Gün İçinde",
        "Gecerli" => "Geçerli",
        _ => "Eksik"
    };
}

