@page "/tedarikci-servis/personel"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject ISoforService SoforService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Tedarikçi Personel Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people me-2"></i>Tedarikçi Personel Listesi</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="YeniTedarikciPersonelEkle" disabled="@(!tedarikciler.Any())">
                <i class="bi bi-plus-lg me-1"></i>Yeni Tedarikçi Personeli
            </button>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/personel-tasima/tedarikciler")'>
                <i class="bi bi-truck me-1"></i>Tedarikçi Yönetimi
            </button>
            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/personel")'>
                <i class="bi bi-grid me-1"></i>Tüm Personel
            </button>
        </div>
    </div>

    <div class="card mb-3 border-info">
        <div class="card-header py-2 bg-info bg-opacity-10">
            <strong><i class="bi bi-person-plus me-1"></i>Hızlı Tedarikçi Personeli Ekle</strong>
            <span class="text-muted small ms-2">Yeni personel açın veya mevcut personeli bir tedarikçiye atayın</span>
        </div>
        <div class="card-body py-2">
            <ul class="nav nav-tabs nav-sm mb-2">
                <li class="nav-item">
                    <button class="nav-link @(hizliTab == "yeni" ? "active" : "")" @onclick='() => hizliTab = "yeni"'>
                        <i class="bi bi-person-plus me-1"></i>Yeni Personel
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(hizliTab == "mevcut" ? "active" : "")" @onclick='() => hizliTab = "mevcut"'>
                        <i class="bi bi-person-lines-fill me-1"></i>Mevcut Personelden Ata
                    </button>
                </li>
            </ul>

            @if (hizliTab == "yeni")
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label small mb-1">Tedarikçi Seç *</label>
                        <select class="form-select form-select-sm" @bind="hizliYeniTedarikciId">
                            <option value="0">— Tedarikçi seçin —</option>
                            @foreach (var t in tedarikciler.Where(t => t.Aktif))
                            {
                                <option value="@t.Id">@(string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-auto">
                        <button class="btn btn-sm btn-success" @onclick="YeniPersonelFormunaGit" disabled="@(hizliYeniTedarikciId == 0)">
                            <i class="bi bi-arrow-right-circle me-1"></i>Personel Formuna Git
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Tedarikçisi Olmayan Personel Ara</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Ad, soyad, kod, telefon..."
                               @bind="atanacakPersonelArama" @bind:event="oninput" />
                        @if (FiltreliAtanacakPersoneller.Any() && atanacakPersonelId == null)
                        {
                            <div class="border rounded mt-1 bg-white shadow-sm" style="max-height:200px;overflow-y:auto;z-index:100;position:relative">
                                @foreach (var p in FiltreliAtanacakPersoneller)
                                {
                                    <div class="px-2 py-1 border-bottom" @onclick="() => AtanacakPersonelSec(p)" style="cursor:pointer;font-size:.85rem">
                                        <span class="badge bg-secondary me-1" style="font-size:.7rem">@p.SoforKodu</span>
                                        <strong>@p.Ad @p.Soyad</strong>
                                        <span class="text-muted ms-1" style="font-size:.75rem">(@GetGorevAdi(p.Gorev))</span>
                                    </div>
                                }
                            </div>
                        }
                        @if (atanacakPersonelId.HasValue)
                        {
                            var sp = tumPersoneller.FirstOrDefault(p => p.Id == atanacakPersonelId.Value);
                            <div class="mt-1 px-2 py-1 bg-success bg-opacity-10 border border-success rounded d-flex justify-content-between align-items-center" style="font-size:.85rem">
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><strong>@sp?.SoforKodu</strong> — @sp?.Ad @sp?.Soyad</span>
                                <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" @onclick="() => atanacakPersonelId = null" title="Seçimi temizle">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Hedef Tedarikçi *</label>
                        <select class="form-select form-select-sm" @bind="atanacakHedefTedarikciId">
                            <option value="0">— Tedarikçi seçin —</option>
                            @foreach (var t in tedarikciler.Where(t => t.Aktif))
                            {
                                <option value="@t.Id">@(string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-auto">
                        <button class="btn btn-sm btn-primary" @onclick="MevcutPersoneliAtaAsync"
                                disabled="@(atanacakPersonelId is null || atanacakHedefTedarikciId == 0 || atamaYukleniyor)">
                            @if (atamaYukleniyor)
                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-link-45deg me-1"></i>Tedarikçiye Ata
                        </button>
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(hizliMesaj))
            {
                <div class="alert alert-success py-1 mb-0 mt-2 small">@hizliMesaj</div>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="seciliTedarikciId">
                        <option value="0">Tümü</option>
                        @foreach (var t in tedarikciler)
                        {
                            <option value="@t.Id">@t.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Ara (Ad, Kod, Telefon)</label>
                    <input class="form-control form-control-sm" @bind="arama" @bind:event="oninput" placeholder="Arama..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Görev</label>
                    <select class="form-select form-select-sm" @bind="secilenGorev">
                        <option value="">Tüm Görevler</option>
                        @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                        {
                            <option value="@gorev">@GetGorevAdi(gorev)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex justify-content-between align-items-end gap-2">
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn @(secilenAktifDurum == "" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => secilenAktifDurum = ""'>Tümü</button>
                        <button type="button" class="btn @(secilenAktifDurum == "aktif" ? "btn-success" : "btn-outline-success")" @onclick='() => secilenAktifDurum = "aktif"'>Aktif</button>
                        <button type="button" class="btn @(secilenAktifDurum == "pasif" ? "btn-danger" : "btn-outline-danger")" @onclick='() => secilenAktifDurum = "pasif"'>Pasif</button>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="FiltreleriTemizle">
                        <i class="bi bi-x-circle me-1"></i>Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!yukleniyor)
    {
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body py-2">
                        <small class="text-muted">Filtre Sonucu</small>
                        <div class="fs-4 fw-bold text-primary">@filtreliPersonel.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body py-2">
                        <small class="text-muted">Aktif Personel</small>
                        <div class="fs-4 fw-bold text-success">@filtreliPersonel.Count(p => p.Aktif)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body py-2">
                        <small class="text-muted">Pasif Personel</small>
                        <div class="fs-4 fw-bold text-danger">@filtreliPersonel.Count(p => !p.Aktif)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body py-2">
                        <small class="text-muted">Tedarikçi Sayısı</small>
                        <div class="fs-4 fw-bold text-warning">@filtreliPersonel.Select(p => p.TasimaTedarikciId).Distinct().Count()</div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!filtreliPersonel.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <span>
                    <i class="bi bi-people me-1"></i>Tedarikçi Personeli
                    <span class="badge bg-secondary ms-1">@filtreliPersonel.Count kayıt</span>
                </span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Kod</th>
                                <th>Ad Soyad</th>
                                <th>Görev</th>
                                <th>Firma</th>
                                <th>Telefon</th>
                                <th>İşe Başlama</th>
                                <th>İşten Çıkış</th>
                                <th class="text-end">Maaş</th>
                                <th class="text-center">Belgeler</th>
                                <th>Tedarikçi</th>
                                <th>Cari</th>
                                <th>Durum</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in filtreliPersonel)
                            {
                                <tr>
                                    <td><strong>@p.SoforKodu</strong></td>
                                    <td>@p.TamAd</td>
                                    <td>
                                        <span class="badge @GetGorevBadgeClass(p.Gorev)">@GetGorevAdi(p.Gorev)</span>
                                    </td>
                                    <td>@(p.Firma?.FirmaAdi ?? "-")</td>
                                    <td>@(p.Telefon ?? "-")</td>
                                    <td>@p.IseBaslamaTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td>@p.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end">@p.NetMaas.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</td>
                                    <td class="text-center">
                                        @if (p.IsSofor)
                                        {
                                            @if (p.EhliyetGecerlilikTarihi.HasValue)
                                            {
                                                var gunKaldiE = (p.EhliyetGecerlilikTarihi.Value - DateTime.Today).Days;
                                                <span class="badge @(gunKaldiE < 30 ? "bg-danger" : gunKaldiE < 60 ? "bg-warning text-dark" : "bg-success")"
                                                      title="Ehliyet: @p.EhliyetGecerlilikTarihi.Value.ToString("dd.MM.yyyy")">
                                                    <i class="bi bi-card-text"></i>
                                                </span>
                                            }
                                            @if (p.MykBelgesiGecerlilikTarihi.HasValue)
                                            {
                                                var gunKaldiM = (p.MykBelgesiGecerlilikTarihi.Value - DateTime.Today).Days;
                                                <span class="badge @(gunKaldiM < 30 ? "bg-danger" : gunKaldiM < 60 ? "bg-warning text-dark" : "bg-success") ms-1"
                                                      title="MYK: @p.MykBelgesiGecerlilikTarihi.Value.ToString("dd.MM.yyyy")">
                                                    <i class="bi bi-award"></i>
                                                </span>
                                            }
                                            @if (p.YayginEgitimSertifikasiVarMi)
                                            {
                                                <span class="badge bg-success ms-1" title="Yaygın Eğitim Sertifikası Var">
                                                    <i class="bi bi-mortarboard"></i>
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-info text-dark">@GetTedarikciEtiket(p.TasimaTedarikciId)</span></td>
                                    <td><small class="text-muted">@GetTedarikciCariEtiket(p.TasimaTedarikciId)</small></td>
                                    <td>
                                        <span class="badge @(p.Aktif ? "bg-success" : "bg-danger")">@(p.Aktif ? "Aktif" : "Pasif")</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-info" @onclick='() => Navigation.NavigateTo($"/personel/{p.Id}")' title="Evraklar / Özlük">
                                                <i class="bi bi-folder2-open"></i>
                                            </button>
                                            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo($"/personel/{p.Id}")' title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Tedarikçi Personel Raporu</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Tedarikçi Başına Personel</th></tr></thead>
                            <tbody>
                                @foreach (var t in tedarikciler.Where(t => filtreliPersonel.Any(p => p.TasimaTedarikciId == t.Id)))
                                {
                                    var adet = filtreliPersonel.Count(p => p.TasimaTedarikciId == t.Id);
                                    <tr><td>@t.Unvan</td><td class="text-end fw-bold">@adet</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Görev Dağılımı</th></tr></thead>
                            <tbody>
                                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                                {
                                    var adet = filtreliPersonel.Count(p => p.Gorev == gorev);
                                    if (adet > 0)
                                    {
                                        <tr><td>@GetGorevAdi(gorev)</td><td class="text-end fw-bold">@adet</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Durum Özeti</th></tr></thead>
                            <tbody>
                                <tr><td>Aktif</td><td class="text-end fw-bold text-success">@filtreliPersonel.Count(p => p.Aktif)</td></tr>
                                <tr><td>Pasif</td><td class="text-end fw-bold text-danger">@filtreliPersonel.Count(p => !p.Aktif)</td></tr>
                                <tr><td>Şoför</td><td class="text-end fw-bold">@filtreliPersonel.Count(p => p.IsSofor)</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private string arama = string.Empty;
    private int seciliTedarikciId;
    private string secilenAktifDurum = string.Empty;
    private PersonelGorev? secilenGorev;
    private List<Sofor> tumPersoneller = new();
    private List<Sofor> filtreliPersonel = new();
    private List<TasimaTedarikci> tedarikciler = new();

    // Hızlı ekleme/atama
    private string hizliTab = "yeni";
    private int hizliYeniTedarikciId;
    private int? atanacakPersonelId;
    private string atanacakPersonelArama = string.Empty;
    private int atanacakHedefTedarikciId;
    private bool atamaYukleniyor;
    private string? hizliMesaj;

    private List<Sofor> FiltreliAtanacakPersoneller => string.IsNullOrWhiteSpace(atanacakPersonelArama)
        ? new()
        : tumPersoneller
            .Where(p => !p.TasimaTedarikciId.HasValue && p.Aktif)
            .Where(p =>
                (p.SoforKodu?.Contains(atanacakPersonelArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Ad?.Contains(atanacakPersonelArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Soyad?.Contains(atanacakPersonelArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Telefon?.Contains(atanacakPersonelArama, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(20)
            .ToList();

    private void YeniTedarikciPersonelEkle()
    {
        var hedef = seciliTedarikciId > 0 ? seciliTedarikciId : tedarikciler.FirstOrDefault(t => t.Aktif)?.Id ?? 0;
        if (hedef <= 0)
        {
            ToastService.ShowWarning("Önce aktif bir tedarikçi tanımlayın.");
            return;
        }
        Navigation.NavigateTo($"/personel/yeni?tedarikciId={hedef}");
    }

    private void YeniPersonelFormunaGit()
    {
        if (hizliYeniTedarikciId <= 0) return;
        Navigation.NavigateTo($"/personel/yeni?tedarikciId={hizliYeniTedarikciId}");
    }

    private void AtanacakPersonelSec(Sofor p)
    {
        atanacakPersonelId = p.Id;
        atanacakPersonelArama = $"{p.Ad} {p.Soyad}";
    }

    private async Task MevcutPersoneliAtaAsync()
    {
        if (!atanacakPersonelId.HasValue || atanacakHedefTedarikciId <= 0) return;
        try
        {
            atamaYukleniyor = true;
            var sofor = await SoforService.GetByIdAsync(atanacakPersonelId.Value);
            if (sofor == null)
            {
                ToastService.ShowError("Personel bulunamadı.");
                return;
            }
            sofor.TasimaTedarikciId = atanacakHedefTedarikciId;
            await SoforService.UpdateAsync(sofor);

            var tedAdi = tedarikciler.FirstOrDefault(t => t.Id == atanacakHedefTedarikciId)?.Unvan ?? "Tedarikçi";
            hizliMesaj = $"{sofor.Ad} {sofor.Soyad} → {tedAdi} tedarikçisine atandı.";
            ToastService.ShowSuccess(hizliMesaj);

            atanacakPersonelId = null;
            atanacakPersonelArama = string.Empty;
            atanacakHedefTedarikciId = 0;

            tumPersoneller = await SoforService.GetAllAsync();
            Filtrele();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Atama yapılamadı: " + ex.Message);
        }
        finally
        {
            atamaYukleniyor = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        tedarikciler = await TasimaTedarikciService.GetAllAsync(sadeceAktif: false);
        tumPersoneller = await SoforService.GetAllAsync();
        Filtrele();
        yukleniyor = false;
    }

    private void Filtrele()
    {
        IEnumerable<Sofor> sorgu = tumPersoneller.Where(p => p.TasimaTedarikciId.HasValue);

        if (seciliTedarikciId != 0)
            sorgu = sorgu.Where(p => p.TasimaTedarikciId == seciliTedarikciId);

        if (secilenGorev.HasValue)
            sorgu = sorgu.Where(p => p.Gorev == secilenGorev.Value);

        if (secilenAktifDurum == "aktif")
            sorgu = sorgu.Where(p => p.Aktif);
        else if (secilenAktifDurum == "pasif")
            sorgu = sorgu.Where(p => !p.Aktif);

        if (!string.IsNullOrWhiteSpace(arama))
        {
            sorgu = sorgu.Where(p =>
                (p.SoforKodu?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Ad?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Soyad?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Telefon?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                GetTedarikciUnvan(p.TasimaTedarikciId).Contains(arama, StringComparison.OrdinalIgnoreCase));
        }

        filtreliPersonel = sorgu.OrderBy(p => p.Ad).ThenBy(p => p.Soyad).ToList();
    }

    private void FiltreleriTemizle()
    {
        arama = string.Empty;
        seciliTedarikciId = 0;
        secilenGorev = null;
        secilenAktifDurum = string.Empty;
        Filtrele();
    }

    private string GetTedarikciUnvan(int? id)
    {
        if (!id.HasValue) return "-";
        return tedarikciler.FirstOrDefault(t => t.Id == id.Value)?.Unvan ?? "-";
    }

    private string GetTedarikciEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t is null) return "-";
        return string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}";
    }

    private string GetTedarikciCariEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t?.Cari is null) return "-";
        return string.IsNullOrWhiteSpace(t.Cari.CariKodu) ? t.Cari.Unvan : $"{t.Cari.CariKodu} - {t.Cari.Unvan}";
    }

    private static string GetGorevAdi(PersonelGorev gorev) => gorev switch
    {
        PersonelGorev.Sofor => "Şoför",
        PersonelGorev.OfisCalisani => "Ofis Çalışanı",
        PersonelGorev.Yonetici => "Yönetici",
        PersonelGorev.Muhasebe => "Muhasebe",
        PersonelGorev.Teknik => "Teknik",
        PersonelGorev.Diger => "Diğer",
        _ => gorev.ToString()
    };

    private static string GetGorevBadgeClass(PersonelGorev gorev) => gorev switch
    {
        PersonelGorev.Sofor => "bg-primary",
        PersonelGorev.OfisCalisani => "bg-info",
        PersonelGorev.Yonetici => "bg-danger",
        PersonelGorev.Muhasebe => "bg-success",
        PersonelGorev.Teknik => "bg-warning text-dark",
        PersonelGorev.Diger => "bg-secondary",
        _ => "bg-secondary"
    };
}

