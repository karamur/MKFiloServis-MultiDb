    private async Task ExcelAktar()
    {
        try
        {
            var data = filtreliAraclar;
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            using var workbook = new XLWorkbook();

            // Özet
            var ozet = workbook.Worksheets.Add("Özet");
            ozet.Cell(1, 1).Value = "TEDARİKÇİ ARAÇ RAPORU";
            ozet.Range(1, 1, 1, 4).Merge();
            ozet.Cell(1, 1).Style.Font.Bold = true;
            ozet.Cell(1, 1).Style.Font.FontSize = 16;
            ozet.Cell(1, 1).Style.Fill.BackgroundColor = XLColor.DarkBlue;
            ozet.Cell(1, 1).Style.Font.FontColor = XLColor.White;
            ozet.Cell(1, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ozet.Row(1).Height = 28;

            ozet.Cell(2, 1).Value = $"Oluşturma: {DateTime.Now:dd.MM.yyyy HH:mm}";
            ozet.Range(2, 1, 2, 4).Merge();
            ozet.Cell(2, 1).Style.Font.Italic = true;

            int r = 4;
            ozet.Cell(r, 1).Value = "GENEL İSTATİSTİKLER";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;

            void Stat(string label, object value)
            {
                ozet.Cell(r, 1).Value = label;
                ozet.Cell(r, 2).Value = XLCellValue.FromObject(value);
                ozet.Cell(r, 1).Style.Font.Bold = true;
                r++;
            }
            Stat("Toplam Araç", data.Count);
            Stat("Aktif Araç", data.Count(a => a.Aktif));
            Stat("Pasif Araç", data.Count(a => !a.Aktif));
            Stat("Boşta", data.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0));
            Stat("Operasyon", data.Count(a => a.Durumu == AracDurumu.Operasyon));
            Stat("Tedarikçi Sayısı", data.Select(a => a.TasimaTedarikciId).Distinct().Count());

            r += 2;
            ozet.Cell(r, 1).Value = "TEDARİKÇİYE GÖRE DAĞILIM";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;
            ozet.Cell(r, 1).Value = "Tedarikçi";
            ozet.Cell(r, 2).Value = "Adet";
            ozet.Cell(r, 3).Value = "Aktif";
            ozet.Cell(r, 4).Value = "Boşta";
            ozet.Range(r, 1, r, 4).Style.Font.Bold = true;
            ozet.Range(r, 1, r, 4).Style.Fill.BackgroundColor = XLColor.Gainsboro;
            r++;
            foreach (var g in data.GroupBy(a => GetTedarikciEtiket(a.TasimaTedarikciId)).OrderByDescending(g => g.Count()))
            {
                ozet.Cell(r, 1).Value = g.Key;
                ozet.Cell(r, 2).Value = g.Count();
                ozet.Cell(r, 3).Value = g.Count(a => a.Aktif);
                ozet.Cell(r, 4).Value = g.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0);
                r++;
            }

            ozet.Columns().AdjustToContents();

            // Detay
            var ws = workbook.Worksheets.Add("Detay");
            var headers = new[] { "S.NO", "TEDARİKÇİ", "ŞASE NO", "PLAKA", "MARKA", "MODEL", "TİP", "SINIF", "SAHİPLİK", "DURUM", "MODEL YILI", "KOLTUK", "MUAYENE" };
            for (int i = 0; i < headers.Length; i++)
                ws.Cell(1, i + 1).Value = headers[i];

            var hr = ws.Range(1, 1, 1, headers.Length);
            hr.Style.Font.Bold = true;
            hr.Style.Font.FontColor = XLColor.White;
            hr.Style.Fill.BackgroundColor = XLColor.DarkBlue;
            hr.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ws.Row(1).Height = 22;

            int row = 2;
            int sira = 1;
            foreach (var a in data)
            {
                ws.Cell(row, 1).Value = sira++;
                ws.Cell(row, 2).Value = GetTedarikciEtiket(a.TasimaTedarikciId);
                ws.Cell(row, 3).Value = a.SaseNo;
                ws.Cell(row, 4).Value = a.AktifPlaka ?? string.Empty;
                ws.Cell(row, 5).Value = a.Marka ?? string.Empty;
                ws.Cell(row, 6).Value = a.Model ?? string.Empty;
                ws.Cell(row, 7).Value = GetTipText(a.AracTipi);
                ws.Cell(row, 8).Value = GetSinifText(a.AracSinifi);
                ws.Cell(row, 9).Value = GetSahiplikText(a.SahiplikTipi);
                ws.Cell(row, 10).Value = GetAracDurumuText(a.Durumu);
                ws.Cell(row, 11).Value = a.ModelYili;
                ws.Cell(row, 12).Value = a.KoltukSayisi;
                if (a.MuayeneBitisTarihi.HasValue)
                {
                    ws.Cell(row, 13).Value = a.MuayeneBitisTarihi.Value;
                    ws.Cell(row, 13).Style.DateFormat.Format = "dd.MM.yyyy";
                    var gun = (a.MuayeneBitisTarihi.Value - DateTime.Today).Days;
                    if (gun < 0) ws.Cell(row, 13).Style.Fill.BackgroundColor = XLColor.LightPink;
                    else if (gun < 30) ws.Cell(row, 13).Style.Fill.BackgroundColor = XLColor.LightYellow;
                }
                if (!a.Aktif) ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightGray;
                row++;
            }

            ws.Range(1, 1, row - 1, headers.Length).Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
            ws.Range(1, 1, row - 1, headers.Length).Style.Border.InsideBorder = XLBorderStyleValues.Thin;
            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(1);
            ws.RangeUsed()!.SetAutoFilter();

            using var ms = new MemoryStream();
            workbook.SaveAs(ms);
            var bytes = ms.ToArray();
            var fileName = $"tedarikci-arac-rapor-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
            ToastService.ShowSuccess("Excel raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel aktarım hatası: {ex.Message}");
        }
    }

    private async Task PdfAktar()
    {
        try
        {
            var data = filtreliAraclar;
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            QuestPDF.Settings.License = LicenseType.Community;

            var tedarikciGruplari = data
                .GroupBy(a => GetTedarikciEtiket(a.TasimaTedarikciId))
                .OrderByDescending(g => g.Count())
                .ToList();

            var document = Document.Create(container =>
            {
                container.Page(page =>
                {
                    page.Size(PageSizes.A4.Landscape());
                    page.Margin(20);
                    page.DefaultTextStyle(x => x.FontSize(8));

                    page.Header().Column(col =>
                    {
                        col.Item().Background(Colors.Blue.Darken3).Padding(10).Column(c =>
                        {
                            c.Item().Text("TEDARİKÇİ ARAÇ RAPORU").Bold().FontSize(16).FontColor(Colors.White);
                            c.Item().Text("MK Filo Servis").FontSize(9).FontColor(Colors.Grey.Lighten2);
                        });
                        col.Item().PaddingTop(4).Row(row =>
                        {
                            row.RelativeItem().Text($"Oluşturma: {DateTime.Now:dd.MM.yyyy HH:mm}").FontSize(8).FontColor(Colors.Grey.Darken2);
                            row.RelativeItem().AlignRight().Text($"Toplam Kayıt: {data.Count}").Bold().FontSize(9);
                        });
                    });

                    page.Content().PaddingVertical(8).Column(content =>
                    {
                        content.Spacing(8);

                        // Özet kartlar
                        content.Item().Row(row =>
                        {
                            row.Spacing(5);
                            void Kart(QuestPDF.Infrastructure.IContainer c, string baslik, string deger, string bg)
                            {
                                c.Background(bg).Padding(6).Column(k =>
                                {
                                    k.Item().Text(baslik).FontSize(7).FontColor(Colors.White);
                                    k.Item().Text(deger).Bold().FontSize(13).FontColor(Colors.White);
                                });
                            }
                            Kart(row.RelativeItem(), "Toplam", data.Count.ToString(), Colors.Blue.Darken2);
                            Kart(row.RelativeItem(), "Aktif", data.Count(a => a.Aktif).ToString(), Colors.Green.Darken1);
                            Kart(row.RelativeItem(), "Pasif", data.Count(a => !a.Aktif).ToString(), Colors.Red.Darken1);
                            Kart(row.RelativeItem(), "Boşta", data.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0).ToString(), Colors.Grey.Darken2);
                            Kart(row.RelativeItem(), "Operasyon", data.Count(a => a.Durumu == AracDurumu.Operasyon).ToString(), Colors.Indigo.Darken1);
                            Kart(row.RelativeItem(), "Tedarikçi", data.Select(a => a.TasimaTedarikciId).Distinct().Count().ToString(), Colors.Teal.Darken2);
                        });

                        // Tedarikçi dağılım
                        content.Item().Border(1).BorderColor(Colors.Grey.Lighten1).Column(col =>
                        {
                            col.Item().Background(Colors.Blue.Lighten4).Padding(5).Text("TEDARİKÇİYE GÖRE DAĞILIM").Bold().FontSize(9);
                            col.Item().Table(t =>
                            {
                                t.ColumnsDefinition(c =>
                                {
                                    c.RelativeColumn(4);
                                    c.RelativeColumn(1);
                                    c.RelativeColumn(1);
                                    c.RelativeColumn(1);
                                });
                                t.Header(h =>
                                {
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text("Tedarikçi").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Adet").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Aktif").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Boşta").Bold().FontSize(8);
                                });
                                foreach (var g in tedarikciGruplari)
                                {
                                    t.Cell().Padding(3).Text(g.Key).FontSize(8);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count().ToString()).FontSize(8);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count(a => a.Aktif).ToString()).FontSize(8);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0).ToString()).FontSize(8);
                                }
                            });
                        });

                        content.Item().Background(Colors.Blue.Darken3).Padding(5).Text("DETAY LİSTE").Bold().FontSize(10).FontColor(Colors.White);

                        content.Item().Table(table =>
                        {
                            table.ColumnsDefinition(c =>
                            {
                                c.ConstantColumn(20);
                                c.RelativeColumn(3);
                                c.RelativeColumn(2);
                                c.RelativeColumn(2);
                                c.RelativeColumn(2);
                                c.RelativeColumn(2);
                                c.RelativeColumn(2);
                                c.RelativeColumn(2);
                                c.RelativeColumn(2);
                                c.RelativeColumn(1);
                                c.RelativeColumn(1);
                                c.RelativeColumn(2);
                            });

                            table.Header(h =>
                            {
                                string[] hs = { "#", "TEDARİKÇİ", "ŞASE NO", "PLAKA", "MARKA", "MODEL", "TİP", "SAHİPLİK", "DURUM", "YIL", "KLT", "MUAYENE" };
                                foreach (var head in hs)
                                    h.Cell().Background(Colors.Blue.Darken2).Padding(4).AlignCenter().Text(head).Bold().FontSize(8).FontColor(Colors.White);
                            });

                            int sira = 1;
                            foreach (var a in data)
                            {
                                string bg = !a.Aktif ? Colors.Grey.Lighten3 : (sira % 2 == 0 ? Colors.Grey.Lighten4 : Colors.White);
                                QuestPDF.Infrastructure.IContainer Cell() => table.Cell().Background(bg).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3);

                                Cell().AlignCenter().Text(sira++.ToString()).FontSize(7);
                                Cell().Text(GetTedarikciEtiket(a.TasimaTedarikciId)).FontSize(7);
                                Cell().Text(a.SaseNo ?? "").FontSize(7);
                                Cell().Text(a.AktifPlaka ?? "-").Bold().FontSize(7);
                                Cell().Text(a.Marka ?? "").FontSize(7);
                                Cell().Text(a.Model ?? "").FontSize(7);
                                Cell().Text(GetTipText(a.AracTipi)).FontSize(7);
                                Cell().Text(GetSahiplikText(a.SahiplikTipi)).FontSize(7);
                                Cell().Text(GetAracDurumuText(a.Durumu)).FontSize(7);
                                Cell().AlignCenter().Text(a.ModelYili.ToString()).FontSize(7);
                                Cell().AlignCenter().Text(a.KoltukSayisi.ToString()).FontSize(7);
                                Cell().Text(a.MuayeneBitisTarihi?.ToString("dd.MM.yyyy") ?? "-").FontSize(7);
                            }
                        });
                    });

                    page.Footer().Row(row =>
                    {
                        row.RelativeItem().Text("MK Filo Servis - Tedarikçi Araç Raporu").FontSize(7).FontColor(Colors.Grey.Darken1);
                        row.RelativeItem().AlignRight().Text(t =>
                        {
                            t.Span("Sayfa ").FontSize(7);
                            t.CurrentPageNumber().FontSize(7).Bold();
                            t.Span(" / ").FontSize(7);
                            t.TotalPages().FontSize(7).Bold();
                        });
                    });
                });
            });

            var bytes = document.GeneratePdf();
            var fileName = $"tedarikci-arac-rapor-{DateTime.Now:yyyyMMdd-HHmm}.pdf";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/pdf", base64);
            ToastService.ShowSuccess("PDF raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF aktarım hatası: {ex.Message}");
        }
    }
}

