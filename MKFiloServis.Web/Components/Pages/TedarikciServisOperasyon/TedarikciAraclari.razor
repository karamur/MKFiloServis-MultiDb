@page "/tedarikci-servis/araclar"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using ClosedXML.Excel
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@inject IAracService AracService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Tedarikçi Araç Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-truck-front me-2"></i>Tedarikçi Araç Listesi</h3>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-success" @onclick="YeniAracEkle">
                <i class="bi bi-plus-lg me-1"></i>Yeni Tedarikçi Aracı
            </button>
            <button class="btn btn-outline-secondary" @onclick="OnizlemeAc" disabled="@(!filtreliAraclar.Any())">
                <i class="bi bi-eye me-1"></i>Önizleme
            </button>
            <button class="btn btn-outline-danger" @onclick="PdfAktar" disabled="@(!filtreliAraclar.Any())">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelAktar" disabled="@(!filtreliAraclar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/personel-tasima/tedarikciler")'>
                <i class="bi bi-truck me-1"></i>Tedarikçi Yönetimi
            </button>
            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/araclar")'>
                <i class="bi bi-grid me-1"></i>Tüm Araçlar
            </button>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="seciliTedarikciId">
                        <option value="0">Tümü</option>
                        @foreach (var t in tedarikciler)
                        {
                            <option value="@t.Id">@t.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Ara (Plaka, Şase, Marka, Model)</label>
                    <input class="form-control form-control-sm" @bind="arama" @bind:event="oninput" placeholder="Arama..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="Tumu">Tümü</option>
                        <option value="Bosta">Boşta</option>
                        <option value="Operasyon">Operasyon</option>
                        <option value="Yonetim">Yönetim</option>
                        <option value="Satis">Satış</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Araç Tipi</label>
                    <select class="form-select form-select-sm" @bind="filtreAracTipi">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracTipi tip in Enum.GetValues(typeof(AracTipi)))
                        {
                            <option value="@tip.ToString()">@GetTipText(tip)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sahiplik</label>
                    <select class="form-select form-select-sm" @bind="filtreSahiplikTipi">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                        {
                            <option value="@sahiplik.ToString()">@GetSahiplikText(sahiplik)</option>
                        }
                    </select>
                    <div class="form-check form-check-sm mt-1">
                        <input class="form-check-input" type="checkbox" id="chkTedSahiplikHaric" @bind="filtreSahiplikHaric" disabled="@(filtreSahiplikTipi == "Tumu")" />
                        <label class="form-check-label small text-muted" for="chkTedSahiplikHaric">Hariç tut</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sınıf</label>
                    <select class="form-select form-select-sm" @bind="filtreSinif">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracSinifi sinif in Enum.GetValues(typeof(AracSinifi)))
                        {
                            <option value="@sinif.ToString()">@GetSinifText(sinif)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Şase No</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreSase" placeholder="Şase ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Marka</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreMarka" placeholder="Marka ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Model Yılı</label>
                    <input type="number" class="form-control form-control-sm" @bind="filtreModelYili" placeholder="Örn: 2020" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Koltuk</label>
                    <input type="number" class="form-control form-control-sm" @bind="filtreKoltuk" placeholder="Örn: 27" min="0" />
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button class="btn btn-primary btn-sm w-100" @onclick="Filtrele">
                        <i class="bi bi-search"></i> Ara
                    </button>
                    <button class="btn btn-secondary btn-sm w-100" @onclick="FiltreleriTemizle">
                        <i class="bi bi-x-circle"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!yukleniyor)
    {
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body py-2">
                        <small class="text-muted">Filtre Sonucu</small>
                        <div class="fs-4 fw-bold text-primary">@filtreliAraclar.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body py-2">
                        <small class="text-muted">Aktif Araç</small>
                        <div class="fs-4 fw-bold text-success">@filtreliAraclar.Count(a => a.Aktif)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body py-2">
                        <small class="text-muted">Boşta</small>
                        <div class="fs-4 fw-bold text-info">@filtreliAraclar.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body py-2">
                        <small class="text-muted">Tedarikçi Sayısı</small>
                        <div class="fs-4 fw-bold text-warning">@filtreliAraclar.Select(a => a.TasimaTedarikciId).Distinct().Count()</div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!filtreliAraclar.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <span>
                    <i class="bi bi-truck-front me-1"></i>Tedarikçi Araçları
                    <span class="badge bg-secondary ms-1">@filtreliAraclar.Count kayıt</span>
                </span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Şase No</th>
                                <th>Aktif Plaka</th>
                                <th>Geçmiş Plakalar</th>
                                <th>Marka</th>
                                <th>Model</th>
                                <th>Araç Tipi</th>
                                <th>Sınıf</th>
                                <th>Sahiplik</th>
                                <th>Durum</th>
                                <th>Model Yılı</th>
                                <th>Koltuk</th>
                                <th>Muayene</th>
                                <th>Tedarikçi</th>
                                <th>Cari</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var arac in filtreliAraclar)
                            {
                                <tr>
                                    <td><small class="text-muted">@arac.SaseNo</small></td>
                                    <td><span class="badge bg-primary fs-6">@(arac.AktifPlaka ?? "PLAKASIZ")</span></td>
                                    <td>
                                        <small class="text-muted">
                                            @{
                                                var gecmisPlakalar = arac.PlakaGecmisi.Where(p => p.Plaka != arac.AktifPlaka).Select(p => p.Plaka).Distinct().ToList();
                                            }
                                            @(gecmisPlakalar.Any() ? string.Join(", ", gecmisPlakalar) : "-")
                                        </small>
                                    </td>
                                    <td><strong>@arac.Marka</strong></td>
                                    <td><span class="text-muted">@arac.Model</span></td>
                                    <td><span class="badge @GetTipBadgeClass(arac.AracTipi)">@GetTipText(arac.AracTipi)</span></td>
                                    <td><span class="badge @GetSinifBadgeClass(arac.AracSinifi)">@GetSinifText(arac.AracSinifi)</span></td>
                                    <td><span class="badge @GetSahiplikBadgeClass(arac.SahiplikTipi)">@GetSahiplikText(arac.SahiplikTipi)</span></td>
                                    <td>
                                        <span class="badge @GetDurumBadgeClass(arac)">@GetAracDurumuText(arac.Durumu)</span>
                                        @if (!arac.Aktif)
                                        {
                                            <span class="badge bg-danger ms-1">Pasif</span>
                                        }
                                    </td>
                                    <td>@arac.ModelYili</td>
                                    <td>@arac.KoltukSayisi</td>
                                    <td>
                                        @if (arac.MuayeneBitisTarihi.HasValue)
                                        {
                                            var gunKaldi = (arac.MuayeneBitisTarihi.Value - DateTime.Today).Days;
                                            <span class="badge @(gunKaldi < 30 ? "bg-danger" : gunKaldi < 60 ? "bg-warning text-dark" : "bg-success")">
                                                @arac.MuayeneBitisTarihi.Value.ToString("dd.MM.yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-info text-dark">@GetTedarikciEtiket(arac.TasimaTedarikciId)</span></td>
                                    <td><small class="text-muted">@GetTedarikciCariEtiket(arac.TasimaTedarikciId)</small></td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-info" @onclick='() => Navigation.NavigateTo($"/araclar/{arac.Id}/evraklar")' title="Evraklar">
                                                <i class="bi bi-folder2-open"></i>
                                            </button>
                                            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo($"/araclar/{arac.Id}")' title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Tedarikçi Araç Raporu</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Tedarikçi Başına Araç</th></tr></thead>
                            <tbody>
                                @foreach (var t in tedarikciler.Where(t => filtreliAraclar.Any(a => a.TasimaTedarikciId == t.Id)))
                                {
                                    var adet = filtreliAraclar.Count(a => a.TasimaTedarikciId == t.Id);
                                    <tr><td>@t.Unvan</td><td class="text-end fw-bold">@adet</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Araç Tipi Dağılımı</th></tr></thead>
                            <tbody>
                                @foreach (AracTipi tip in Enum.GetValues(typeof(AracTipi)))
                                {
                                    var adet = filtreliAraclar.Count(a => a.AracTipi == tip);
                                    if (adet > 0)
                                    {
                                        <tr><td>@GetTipText(tip)</td><td class="text-end fw-bold">@adet</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Sahiplik Dağılımı</th></tr></thead>
                            <tbody>
                                @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                                {
                                    var adet = filtreliAraclar.Count(a => a.SahiplikTipi == sahiplik);
                                    if (adet > 0)
                                    {
                                        <tr><td>@GetSahiplikText(sahiplik)</td><td class="text-end fw-bold">@adet</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showOnizlemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Rapor Önizleme - Tedarikçi Araçları (@filtreliAraclar.Count kayıt)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOnizlemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-primary">Toplam: @filtreliAraclar.Count</span>
                        <span class="badge bg-success">Aktif: @filtreliAraclar.Count(a => a.Aktif)</span>
                        <span class="badge bg-info text-dark">Boşta: @filtreliAraclar.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0)</span>
                        <span class="badge bg-warning text-dark">Tedarikçi: @filtreliAraclar.Select(a => a.TasimaTedarikciId).Distinct().Count()</span>
                    </div>

                    @{
                        var tedarikciGruplari = filtreliAraclar
                            .GroupBy(a => GetTedarikciEtiket(a.TasimaTedarikciId))
                            .OrderByDescending(g => g.Count())
                            .ToList();
                    }

                    <div class="card mb-3">
                        <div class="card-header py-2 bg-light"><strong><i class="bi bi-truck me-1"></i>Tedarikçiye Göre Dağılım</strong></div>
                        <div class="card-body py-2">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Tedarikçi</th><th class="text-end">Adet</th><th class="text-end">Aktif</th><th class="text-end">Boşta</th></tr></thead>
                                <tbody>
                                    @foreach (var g in tedarikciGruplari)
                                    {
                                        <tr>
                                            <td>@g.Key</td>
                                            <td class="text-end">@g.Count()</td>
                                            <td class="text-end">@g.Count(a => a.Aktif)</td>
                                            <td class="text-end">@g.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Şase No</th>
                                    <th>Plaka</th>
                                    <th>Marka</th>
                                    <th>Model</th>
                                    <th>Tip</th>
                                    <th>Sahiplik</th>
                                    <th>Durum</th>
                                    <th>Yıl</th>
                                    <th>Koltuk</th>
                                    <th>Muayene</th>
                                    <th>Tedarikçi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var ix = 1; }
                                @foreach (var a in filtreliAraclar)
                                {
                                    <tr>
                                        <td>@(ix++)</td>
                                        <td><small>@a.SaseNo</small></td>
                                        <td><strong>@(a.AktifPlaka ?? "-")</strong></td>
                                        <td>@a.Marka</td>
                                        <td>@a.Model</td>
                                        <td><span class="badge @GetTipBadgeClass(a.AracTipi)">@GetTipText(a.AracTipi)</span></td>
                                        <td><span class="badge @GetSahiplikBadgeClass(a.SahiplikTipi)">@GetSahiplikText(a.SahiplikTipi)</span></td>
                                        <td><span class="badge @GetDurumBadgeClass(a)">@GetAracDurumuText(a.Durumu)</span></td>
                                        <td>@a.ModelYili</td>
                                        <td>@a.KoltukSayisi</td>
                                        <td>@(a.MuayeneBitisTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td><small>@GetTedarikciEtiket(a.TasimaTedarikciId)</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger" @onclick="PdfAktar"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</button>
                    <button class="btn btn-outline-success" @onclick="ExcelAktar"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary" @onclick="() => showOnizlemeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showOnizlemeModal;
    private bool yukleniyor = true;
    private string arama = string.Empty;
    private int seciliTedarikciId;
    private string filtreDurum = "Tumu";
    private string filtreAracTipi = "Tumu";
    private string filtreSahiplikTipi = nameof(AracSahiplikTipi.Tedarikci);
    private bool filtreSahiplikHaric;
    private string filtreSinif = "Tumu";
    private string? filtreSase;
    private string? filtreMarka;
    private int? filtreModelYili;
    private int? filtreKoltuk;
    private List<Arac> tumAraclar = new();
    private List<Arac> filtreliAraclar = new();
    private List<TasimaTedarikci> tedarikciler = new();

    protected override async Task OnInitializedAsync()
    {
        tedarikciler = await TasimaTedarikciService.GetAllAsync(sadeceAktif: false);
        tumAraclar = await AracService.GetAllAsync();
        Filtrele();
        yukleniyor = false;
    }

    private void Filtrele()
    {
        IEnumerable<Arac> sorgu = tumAraclar.Where(a => a.TasimaTedarikciId.HasValue);

        if (seciliTedarikciId != 0)
            sorgu = sorgu.Where(a => a.TasimaTedarikciId == seciliTedarikciId);

        if (filtreDurum == "Bosta")
            sorgu = sorgu.Where(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0);
        else if (filtreDurum != "Tumu" && Enum.TryParse<AracDurumu>(filtreDurum, out var durum))
            sorgu = sorgu.Where(a => a.Durumu == durum);

        if (filtreAracTipi != "Tumu" && Enum.TryParse<AracTipi>(filtreAracTipi, out var aracTipi))
            sorgu = sorgu.Where(a => a.AracTipi == aracTipi);

        if (filtreSahiplikTipi != "Tumu" && Enum.TryParse<AracSahiplikTipi>(filtreSahiplikTipi, out var sahiplik))
            sorgu = filtreSahiplikHaric ? sorgu.Where(a => a.SahiplikTipi != sahiplik) : sorgu.Where(a => a.SahiplikTipi == sahiplik);

        if (filtreSinif != "Tumu" && Enum.TryParse<AracSinifi>(filtreSinif, out var sinif))
            sorgu = sorgu.Where(a => a.AracSinifi == sinif);

        if (!string.IsNullOrWhiteSpace(filtreSase))
            sorgu = sorgu.Where(a => a.SaseNo != null && a.SaseNo.Contains(filtreSase, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(filtreMarka))
            sorgu = sorgu.Where(a => a.Marka != null && a.Marka.Contains(filtreMarka, StringComparison.OrdinalIgnoreCase));

        if (filtreModelYili.HasValue)
            sorgu = sorgu.Where(a => a.ModelYili == filtreModelYili.Value);

        if (filtreKoltuk.HasValue)
            sorgu = sorgu.Where(a => a.KoltukSayisi == filtreKoltuk.Value);

        if (!string.IsNullOrWhiteSpace(arama))
        {
            sorgu = sorgu.Where(a =>
                (a.AktifPlaka?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.SaseNo?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Marka?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Model?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                a.PlakaGecmisi.Any(p => p.Plaka.Contains(arama, StringComparison.OrdinalIgnoreCase)) ||
                GetTedarikciUnvan(a.TasimaTedarikciId).Contains(arama, StringComparison.OrdinalIgnoreCase));
        }

        filtreliAraclar = sorgu.OrderBy(a => a.AktifPlaka).ToList();
    }

    private void FiltreleriTemizle()
    {
        arama = string.Empty;
        seciliTedarikciId = 0;
        filtreDurum = "Tumu";
        filtreAracTipi = "Tumu";
        filtreSahiplikTipi = nameof(AracSahiplikTipi.Tedarikci);
        filtreSahiplikHaric = false;
        filtreSinif = "Tumu";
        filtreSase = null;
        filtreMarka = null;
        filtreModelYili = null;
        filtreKoltuk = null;
        Filtrele();
    }

    private string GetTedarikciUnvan(int? id)
    {
        if (!id.HasValue) return "-";
        return tedarikciler.FirstOrDefault(t => t.Id == id.Value)?.Unvan ?? "-";
    }

    private string GetTedarikciEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t is null) return "-";
        return string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}";
    }

    private string GetTedarikciCariEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t?.Cari is null) return "-";
        return string.IsNullOrWhiteSpace(t.Cari.CariKodu) ? t.Cari.Unvan : $"{t.Cari.CariKodu} - {t.Cari.Unvan}";
    }

