    private static string GetOperasyonFirmaAdi(FiloGuzergahEslestirme eslestirme)
    {
        if (eslestirme.Arac?.TasimaTedarikci is not null)
            return eslestirme.Arac.TasimaTedarikci.Unvan;

        if (eslestirme.Arac?.KomisyoncuCari is not null)
            return eslestirme.Arac.KomisyoncuCari.Unvan;

        if (eslestirme.Arac?.KiralikCari is not null)
            return eslestirme.Arac.KiralikCari.Unvan;

        if (eslestirme.Sofor?.Firma is not null)
            return eslestirme.Sofor.Firma.FirmaAdi;

        return "Özmal";
    }

    private static string GetKapasiteMetni(string? not)
    {
        if (string.IsNullOrWhiteSpace(not))
            return "-";

        const string prefix = "Kapasite: ";
        return not.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? not[prefix.Length..]
            : "-";
    }

    private static List<AylikPuantajGridModel> BuildAylikGrid(List<FiloGunlukPuantaj> puantajlar)
    {
        return puantajlar
            .GroupBy(p => new { p.Tarih.Year, p.Tarih.Month })
            .OrderByDescending(g => g.Key.Year)
            .ThenByDescending(g => g.Key.Month)
            .Select(g =>
            {
                var gunMap = g
                    .GroupBy(x => x.Tarih.Day)
                    .ToDictionary(x => x.Key, x => x.OrderByDescending(i => i.UpdatedAt ?? i.CreatedAt).First());

                return new AylikPuantajGridModel
                {
                    Yil = g.Key.Year,
                    Ay = g.Key.Month,
                    GunSayisi = DateTime.DaysInMonth(g.Key.Year, g.Key.Month),
                    GunMap = gunMap,
                    ToplamSefer = gunMap.Values.Sum(x => x.SeferSayisi)
                };
            })
            .ToList();
    }

    private async Task KaydetOlusanPuantajGridAsync(int eslestirmeId)
    {
        if (!olusanPuantajlarByEslestirme.TryGetValue(eslestirmeId, out var puantajlar) || !puantajlar.Any())
            return;

        try
        {
            var guncellenecekler = puantajlar.Where(p => p.Id > 0).ToList();
            await FiloKomisyonService.UpdateGunlukPuantajlarAsync(guncellenecekler);
            ToastService.ShowSuccess("Gün bazlı puantaj değişiklikleri kaydedildi.");
            await ListeYenile();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Gün bazlı puantaj kaydı sırasında hata oluştu: " + ex.GetBaseException().Message);
        }
    }

