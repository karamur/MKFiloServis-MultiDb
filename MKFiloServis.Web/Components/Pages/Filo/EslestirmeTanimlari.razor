@page "/filo/komisyon-eslestirme"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Services
@inject IFiloKomisyonService FiloKomisyonService
@inject IGuzergahService GuzergahService
@inject IKapasiteService KapasiteService

@inject IFirmaService FirmaService
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

<PageTitle>Servis Operasyon Güzergahları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-link-45deg me-2 text-primary"></i>Araç, Şoför ve Güzergah Eşleme Havuzu</h3>
            <small class="text-muted">Özmal veya komisyonlu (taşeron) servislerin otomatik puantaj üretmeden önceki şablon tanımları</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="PuantajModalAcAsync">
                <i class="bi bi-calendar-plus me-1"></i> Puantaj Oluştur
            </button>
            <button class="btn btn-primary" @onclick="YeniEkleModalAc">
                <i class="bi bi-plus-lg me-1"></i> Yeni Eşleşme Ekle
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Arama yapılıyor...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Durum</th>
                                <th>Müşteri Kurum</th>
                                <th>Güzergah</th>
                                <th>Araç Plakası</th>
                                <th>Sahiplik</th>
                                <th>Şoför</th>
                                <th>Kuruma Kesilecek Ücret</th>
                                <th>Taşerona/Şoföre Ödenen</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!eslestirmeler.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-4 text-muted">
                                        <em>Kayıtlı eşleştirme bulunamadı.</em>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var e in eslestirmeler)
                                {
                                    <tr>
                                        <td>
                                            @if(e.IsActive) { <span class="badge bg-success">Aktif</span> } else { <span class="badge bg-secondary">Pasif</span> }
                                        </td>
                                        <td class="fw-bold text-primary">@e.MusteriCari?.Unvan</td>
                                        <td>@e.Guzergah?.GuzergahAdi</td>
                                        <td class="fw-bold">@(e.Arac?.AktifPlaka ?? e.Arac?.AktifPlakaKaydi?.Plaka)</td>
                                        <td>
                                            @if (e.Arac != null)
                                            {
                                                <span class="badge @GetSahiplikBadge(e.Arac.SahiplikTipi)">@GetSahiplikText(e.Arac.SahiplikTipi)</span>
                                            }
                                        </td>
                                        <td>@e.Sofor?.TamAd</td>
                                        <td class="text-success fw-bold">@e.KurumaKesilecekUcret.ToString("N2") TL</td>
                                        <td class="text-danger fw-bold">@e.TaseronaOdenenUcret.ToString("N2") TL</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => DuzenleModalAc(e)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SilModalAc(e)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>

                                    @if (olusanPuantajlarByEslestirme.TryGetValue(e.Id, out var olusanPuantajlar) && olusanPuantajlar.Any())
                                    {
                                        <tr class="table-light">
                                            <td></td>
                                            <td colspan="8">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <div class="small text-muted">Oluşturulan puantaj kayıtları (gün bazlı düzenlenebilir)</div>
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => KaydetOlusanPuantajGridAsync(e.Id)">
                                                        <i class="bi bi-save me-1"></i>Günleri Kaydet
                                                    </button>
                                                </div>

                                                @foreach (var aylik in BuildAylikGrid(olusanPuantajlar))
                                                {
                                                    <div class="small fw-semibold text-primary mb-1">@aylik.AyEtiket</div>
                                                    <div class="table-responsive mb-2">
                                                        <table class="table table-sm table-bordered align-middle mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th style="min-width:220px;">Güzergah</th>
                                                                    <th style="min-width:110px;">Plaka</th>
                                                                    <th style="min-width:150px;">Şoför</th>
                                                                    @for (var day = 1; day <= aylik.GunSayisi; day++)
                                                                    {
                                                                        <th class="text-center" style="min-width:58px;">@day</th>
                                                                    }
                                                                    <th class="text-center" style="min-width:85px;">Toplam</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <tr>
                                                                    <td>@(e.Guzergah?.GuzergahAdi ?? "-")</td>
                                                                    <td>@(e.Arac?.AktifPlaka ?? e.Arac?.AktifPlakaKaydi?.Plaka ?? "-")</td>
                                                                    <td>@(e.Sofor?.TamAd ?? "-")</td>
                                                                    @for (var day = 1; day <= aylik.GunSayisi; day++)
                                                                    {
                                                                        if (aylik.GunMap.TryGetValue(day, out var p))
                                                                        {
                                                                            <td>
                                                                                <input type="number" min="0" step="0.5" class="form-control form-control-sm text-center" @bind="p.SeferSayisi" />
                                                                            </td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td class="bg-light"></td>
                                                                        }
                                                                    }
                                                                    <td class="fw-semibold text-center">@aylik.ToplamSefer.ToString("N1")</td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (isModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">@(model.Id == 0 ? "Yeni Eşleştirme Şablonu" : "Eşleştirme Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kurum (Müşteri) Kartları <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.KurumFirmaId" @bind:after="KurumSecimiDegistiAsync">
                                <option value="0">-- Kurum (Müşteri) Seçin --</option>
                                @foreach(var k in kurumFirmaListesi) {
                                    <option value="@k.Id">@k.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Güzergah <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.GuzergahId" @bind:after="GuzergahSecimiDegistiAsync">
                                <option value="0">-- Güzergah Seçin --</option>
                                @foreach(var g in guzergahListesi) {
                                    <option value="@g.Id">@g.GuzergahAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Çalışacak Araç <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.AracId" @bind:after="AracSecimiDegistiAsync">
                                <option value="0">-- Araç Seçin --</option>
                                @foreach(var a in aracListesi) {
                                    <option value="@a.Id">@(a.AktifPlaka ?? a.AktifPlakaKaydi?.Plaka ?? a.SaseNo)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Görevli Şoför <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.SoforId">
                                <option value="0">-- Şoför Seçin --</option>
                                @foreach(var s in soforListesi) {
                                    <option value="@s.Id">@s.TamAd</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-success fw-bold">Kuruma Kesilecek Ücret (1 Sefer) ₺</label>
                            <input type="number" step="0.01" class="form-control text-success fw-bold" @bind="model.KurumaKesilecekUcret" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-danger fw-bold">Taşerona/Şoföre Ödenen Ücret ₺</label>
                            <input type="number" step="0.01" class="form-control text-danger fw-bold" @bind="model.TaseronaOdenenUcret" disabled="@(!SecilenAracKomisyonMu())" />
                            <small class="text-muted">Komisyon araçlarda aktif olur. Özmal ve kiralıkta otomatik 0 kabul edilir.</small>
                        </div>
                        <div class="col-md-12">
                            @if (GetSecilenArac() is Arac secilenArac)
                            {
                                <div class="alert @GetSahiplikAlertClass(secilenArac.SahiplikTipi) py-2 mb-2">
                                    <strong>@GetSahiplikText(secilenArac.SahiplikTipi)</strong> kuralı: @GetSahiplikAciklama(secilenArac.SahiplikTipi)
                                </div>
                            }
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" @bind="model.IsActive">
                                <label class="form-check-label" for="flexSwitchCheckChecked">Bu Eşleşme Aktif Çalışıyor Mu?</label>
                            </div>
                            <small class="text-muted">Pasif konumdaki eşleşmelere puantaj dağılımı yansıtılmaz.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="Kaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

@if (isPuantajModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">Toplu Puantaj Oluştur</h5>
                    <button type="button" class="btn-close" @onclick="PuantajModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Kurum <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="seciliPuantajKurumFirmaId" @bind:after="PuantajKurumDegistiAsync">
                                <option value="0">-- Önce Kurum Seçin --</option>
                                @foreach (var kurum in puantajKurumListesi)
                                {
                                    <option value="@kurum.Id">@kurum.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Dönem Tipi</label>
                            <select class="form-select" @bind="donemTipi" @bind:after="DonemTipiDegisti">
                                <option value="Gunluk">Günlük</option>
                                <option value="Haftalik">Haftalık</option>
                                <option value="Aylik">Aylık</option>
                            </select>
                        </div>
                        @if (donemTipi == "Gunluk")
                        {
                            <div class="col-md-3">
                                <label class="form-label">Tarih</label>
                                <input type="date" class="form-control" @bind="puantajBaslangicTarihi" @bind:after="DonemTipiDegisti" />
                            </div>
                        }
                        else if (donemTipi == "Haftalik")
                        {
                            <div class="col-md-2">
                                <label class="form-label">Başlangıç</label>
                                <input type="date" class="form-control" @bind="puantajBaslangicTarihi" @bind:after="DonemTipiDegisti" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Bitiş</label>
                                <input type="date" class="form-control" @bind="puantajBitisTarihi" @bind:after="DonemTipiDegisti" />
                            </div>
                        }
                        else
                        {
                            <div class="col-md-2">
                                <label class="form-label">Yıl</label>
                                <input type="number" class="form-control" @bind="puantajYil" @bind:after="DonemTipiDegisti" min="2000" max="2100" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Ay</label>
                                <select class="form-select" @bind="puantajAy" @bind:after="DonemTipiDegisti">
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        var ay = m;
                                        var ayAdi = new DateTime(2000, ay, 1).ToString("MMMM");
                                        <option value="@ay">@ayAdi</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="col-12">
                            <div class="alert alert-info mb-0 py-2 small">
                                @if (donemTipi == "Gunluk")
                                {
                                    <span>Seçili gün için eşleştirme başına 1 puantaj satırı oluşturulur.</span>
                                }
                                else if (donemTipi == "Haftalik")
                                {
                                    <span>Başlangıç–Bitiş arasındaki seçili haftalık günlerde eşleştirme başına satır oluşturulur.</span>
                                }
                                else
                                {
                                    <span>@puantajYil/@puantajAy ayındaki seçili çalışma günlerinde eşleştirme başına satır oluşturulur.</span>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label mb-1">Çalışılan Hafta Günleri</label>
                            <div class="d-flex flex-wrap gap-3 small">
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunPzt" @bind="calismaPazartesi" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunPzt">Pzt</label></div>
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunSal" @bind="calismaSali" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunSal">Sal</label></div>
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunCar" @bind="calismaCarsamba" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunCar">Çar</label></div>
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunPer" @bind="calismaPersembe" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunPer">Per</label></div>
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunCum" @bind="calismaCuma" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunCum">Cum</label></div>
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunCmt" @bind="calismaCumartesi" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunCmt">Cmt</label></div>
                                <div class="form-check"><input class="form-check-input" type="checkbox" id="gunPaz" @bind="calismaPazar" @bind:after="GunFiltreleriDegisti" /><label class="form-check-label" for="gunPaz">Paz</label></div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SecHaftaIci">Hafta İçi</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SecTumGunler">Tüm Günler</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SecHaftaSonuHaric">Hafta Sonu Hariç</button>
                            </div>
                        </div>

                        @if (donemTipi == "Aylik")
                        {
                            <div class="col-12">
                                <label class="form-label">Hariç Tutulacak Gün Numaraları (opsiyonel)</label>
                                <input class="form-control" @bind="haricGunNumaralariText" @bind:after="GunFiltreleriDegisti" placeholder="Örn: 5,12,19" />
                                <small class="text-muted">Ay içinde çalışılmayan günleri virgülle yazın.</small>
                            </div>
                        }
                    </div>

                    @if (seciliPuantajKurumFirmaId > 0)
                    {
                        <div class="table-responsive border rounded">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 45px;">
                                            <input type="checkbox" class="form-check-input" checked="@tumSatirlarSecili" @onchange="TumSatirlariSec" />
                                        </th>
                                        <th>Güzergah</th>
                                        <th>Araç</th>
                                        <th>Şoför</th>
                                        <th>Firma</th>
                                        <th>Gelir/Sefer</th>
                                        <th>Gider/Sefer</th>
                                        <th style="min-width: 170px;">Kapasite</th>
                                        @foreach (var gun in puantajGunKolonlari)
                                        {
                                            <th class="text-center" style="min-width: 72px;">
                                                <div>@gun.ToString("dd")</div>
                                                <small class="text-muted">@gun.ToString("ddd", new System.Globalization.CultureInfo("tr-TR"))</small>
                                            </th>
                                        }
                                        <th class="text-center" style="min-width: 90px;">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!puantajSatirlari.Any())
                                    {
                                        <tr>
                                            <td colspan="@(9 + puantajGunKolonlari.Count)" class="text-center py-3 text-muted">Seçilen kurum için aktif eşleştirme bulunamadı.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var grup in GetPuantajGruplari())
                                        {
                                            var grupSatirlari = grup.ToList();
                                            for (var i = 0; i < grupSatirlari.Count; i++)
                                            {
                                                var satir = grupSatirlari[i];
                                                <tr>
                                                    <td>
                                                        <input type="checkbox" class="form-check-input" @bind="satir.Secili" />
                                                    </td>
                                                    @if (i == 0)
                                                    {
                                                        <td rowspan="@grupSatirlari.Count" class="fw-semibold bg-light">@satir.GuzergahAdi</td>
                                                    }
                                                    <td>@satir.AracPlaka</td>
                                                    <td>@satir.SoforAdi</td>
                                                    <td>@satir.FirmaAdi</td>
                                                    <td class="text-success fw-semibold">@satir.GelirFiyati.ToString("N2")</td>
                                                    <td class="text-danger fw-semibold">@satir.GiderFiyati.ToString("N2")</td>
                                                    <td>
                                                        <select class="form-select form-select-sm" @bind="satir.KapasiteId">
                                                            <option value="">-- Kapasite --</option>
                                                            @foreach (var kapasite in kapasiteListesi)
                                                            {
                                                                <option value="@kapasite.Id">@kapasite.KapasiteAdi</option>
                                                            }
                                                        </select>
                                                    </td>
                                                    @foreach (var gun in puantajGunKolonlari)
                                                    {
                                                        var hucre = GetOrCreateGunHucre(satir, gun);
                                                        <td>
                                                            <input type="number" min="0" step="0.5" class="form-control form-control-sm text-center" @bind="hucre.SeferSayisi" />
                                                        </td>
                                                    }
                                                    <td class="fw-semibold text-center">@satir.GunlukHucreler.Sum(h => h.SeferSayisi).ToString("N1")</td>
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="PuantajModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TopluPuantajOlusturAsync" disabled="@(!puantajSatirlari.Any(s => s.Secili))">
                        <i class="bi bi-calendar-plus me-1"></i>Seçili Satırlardan Puantaj Oluştur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isModalOpen = false;
    private bool isPuantajModalOpen = false;
    private int aktifFirmaId;
    private List<FiloGuzergahEslestirme> eslestirmeler = new();
    private Kullanici? aktifKullanici;

    // Lookups
    private List<Cari> kurumFirmaListesi = new();   // KurumFirmaId -> Cari.Id (musteri cari)
    private List<Guzergah> guzergahListesi = new();
    private List<Arac> aracListesi = new();
    private List<Sofor> soforListesi = new();
    private List<Kapasite> kapasiteListesi = new();

    private List<Cari> puantajKurumListesi = new();
    private int seciliPuantajKurumFirmaId;
    private bool tumSatirlarSecili = true;
    private List<PuantajSatirModel> puantajSatirlari = new();
    private List<DateTime> puantajGunKolonlari = new();
    private readonly Dictionary<int, List<FiloGunlukPuantaj>> olusanPuantajlarByEslestirme = new();

    // Puantaj modalı dönem seçimi
    private string donemTipi = "Gunluk"; // Gunluk | Haftalik | Aylik
    private DateTime puantajBaslangicTarihi = DateTime.Today;
    private DateTime puantajBitisTarihi = DateTime.Today;
    private int puantajAy = DateTime.Today.Month;
    private int puantajYil = DateTime.Today.Year;

    private bool calismaPazartesi = true;
    private bool calismaSali = true;
    private bool calismaCarsamba = true;
    private bool calismaPersembe = true;
    private bool calismaCuma = true;
    private bool calismaCumartesi;
    private bool calismaPazar;
    private string haricGunNumaralariText = string.Empty;

    private FiloGuzergahEslestirme model = new();

    protected override async Task OnInitializedAsync()
    {
        AktifFirmaBaglaminiYenile();
        aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();
        await LoadLookups();
        await ListeYenile();
    }

    private void AktifFirmaBaglaminiYenile()
    {
        var af = FirmaService.GetAktifFirma();
        aktifFirmaId = af.TumFirmalar || af.FirmaId <= 0 ? 0 : af.FirmaId;
    }

    private async Task LoadLookups()
    {
        // KurumFirmaId -> Cari.Id: musteri carileri (Musteri/MusteriTedarikci)
        kurumFirmaListesi = await FiloKomisyonService.GetKurumlarAsync(aktifFirmaId);
        aracListesi = await FiloKomisyonService.GetAraclarAsync(aktifFirmaId);
        guzergahListesi = await FiloKomisyonService.GetGuzergahlarAsync();
        soforListesi = await FiloKomisyonService.GetSoforlerAsync(aktifFirmaId);
        kapasiteListesi = await KapasiteService.GetActiveAsync();
    }

    private async Task ListeYenile()
    {
        isLoading = true;
        try
        {
            eslestirmeler = await FiloKomisyonService.GetEslestirmelerAsync(aktifFirmaId, sadeceAktifler: false);

            olusanPuantajlarByEslestirme.Clear();
            if (aktifFirmaId > 0)
            {
                var baslangic = new DateTime(DateTime.Today.Year, 1, 1);
                var bitis = baslangic.AddYears(1).AddDays(-1);
                var tumPuantajlar = await FiloKomisyonService.GetPuantajlarByTarihAraligiAsync(aktifFirmaId, baslangic, bitis);

                foreach (var grup in tumPuantajlar
                    .Where(p => p.FiloGuzergahEslestirmeId.HasValue)
                    .GroupBy(p => p.FiloGuzergahEslestirmeId!.Value))
                {
                    olusanPuantajlarByEslestirme[grup.Key] = grup.OrderBy(p => p.Tarih).ToList();
                }
            }
        }
        catch
        {
            ToastService.ShowError("Veriler yüklenirken hata oluştu.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PuantajModalAcAsync()
    {
        AktifFirmaBaglaminiYenile();

        if (aktifFirmaId <= 0)
        {
            ToastService.ShowError("Puantaj oluşturmak için önce aktif firma seçiniz.");
            return;
        }

        // Her açılışta hem eşleştirmeleri hem lookup listelerini taze çek
        await LoadLookups();
        await ListeYenile();

        var aktifKurumIdSet = eslestirmeler
            .Where(e => e.IsActive && e.KurumFirmaId > 0)
            .Select(e => e.KurumFirmaId)
            .Distinct()
            .ToHashSet();

        puantajKurumListesi = kurumFirmaListesi
            .Where(k => aktifKurumIdSet.Contains(k.Id))
            .OrderBy(k => k.Unvan)
            .ToList();

        if (!puantajKurumListesi.Any())
        {
            ToastService.ShowWarning("Aktif eşleştirme bulunan kurum yok. Önce 'Yeni Eşleşme Ekle' ile eşleştirme tanımlayınız.");
            return;
        }

        seciliPuantajKurumFirmaId = 0;
        puantajSatirlari.Clear();
        puantajGunKolonlari = HesaplaHedefGunler(true);
        tumSatirlarSecili = true;
        isPuantajModalOpen = true;
    }

    private void PuantajModalKapat()
    {
        isPuantajModalOpen = false;
    }

    private Task PuantajKurumDegistiAsync()
    {
        puantajSatirlari = eslestirmeler
            .Where(e => e.IsActive && e.KurumFirmaId == seciliPuantajKurumFirmaId)
            .Select(e =>
            {
                var guzergah = guzergahListesi.FirstOrDefault(g => g.Id == e.GuzergahId);
                var varsayilanSefer = guzergah?.SeferTipi switch
                {
                    SeferTipi.SabahAksam => 2m,
                    _                    => 1m
                };

                var kurumAdi = e.MusteriCari?.Unvan
                    ?? kurumFirmaListesi.FirstOrDefault(k => k.Id == e.KurumFirmaId)?.Unvan
                    ?? "-";

                return new PuantajSatirModel
                {
                    Secili = true,
                    EslestirmeId = e.Id,
                    KurumFirmaId = e.KurumFirmaId,
                    KurumAdi = kurumAdi,
                    GuzergahId = e.GuzergahId,
                    GuzergahAdi = e.Guzergah?.GuzergahAdi ?? "-",
                    AracId = e.AracId,
                    AracPlaka = e.Arac?.AktifPlaka ?? e.Arac?.AktifPlakaKaydi?.Plaka ?? "-",
                    SoforId = e.SoforId,
                    SoforAdi = e.Sofor?.TamAd ?? "-",
                    FirmaAdi = GetOperasyonFirmaAdi(e),
                    GelirFiyati = e.KurumaKesilecekUcret,
                    GiderFiyati = e.TaseronaOdenenUcret,
                    ServisTuru = e.ServisTuru,
                    VarsayilanSeferSayisi = varsayilanSefer
                };
            })
            .ToList();

        tumSatirlarSecili = puantajSatirlari.Any();
        PuantajGunKolonlariniHazirla();
        return Task.CompletedTask;
    }

    private Task DonemTipiDegisti()
    {
        if (donemTipi == "Gunluk")
        {
            puantajBitisTarihi = puantajBaslangicTarihi;
        }
        else if (donemTipi == "Haftalik")
        {
            if (puantajBitisTarihi < puantajBaslangicTarihi)
                puantajBitisTarihi = puantajBaslangicTarihi.AddDays(6);
        }

        PuantajGunKolonlariniHazirla();
        return Task.CompletedTask;
    }

    private Task GunFiltreleriDegisti()
    {
        PuantajGunKolonlariniHazirla();
        return Task.CompletedTask;
    }

    private void SecHaftaIci()
    {
        calismaPazartesi = true;
        calismaSali = true;
        calismaCarsamba = true;
        calismaPersembe = true;
        calismaCuma = true;
        calismaCumartesi = false;
        calismaPazar = false;
        PuantajGunKolonlariniHazirla();
    }

    private void SecTumGunler()
    {
        calismaPazartesi = true;
        calismaSali = true;
        calismaCarsamba = true;
        calismaPersembe = true;
        calismaCuma = true;
        calismaCumartesi = true;
        calismaPazar = true;
        PuantajGunKolonlariniHazirla();
    }

    private void SecHaftaSonuHaric() => SecHaftaIci();

    private bool IsCalismaGunu(DayOfWeek dayOfWeek)
    {
        return dayOfWeek switch
        {
            DayOfWeek.Monday => calismaPazartesi,
            DayOfWeek.Tuesday => calismaSali,
            DayOfWeek.Wednesday => calismaCarsamba,
            DayOfWeek.Thursday => calismaPersembe,
            DayOfWeek.Friday => calismaCuma,
            DayOfWeek.Saturday => calismaCumartesi,
            DayOfWeek.Sunday => calismaPazar,
            _ => false
        };
    }

    private HashSet<int> ParseHaricGunNumaralari()
    {
        if (string.IsNullOrWhiteSpace(haricGunNumaralariText))
            return new HashSet<int>();

        return haricGunNumaralariText
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(x => int.TryParse(x, out var day) ? day : 0)
            .Where(day => day is >= 1 and <= 31)
            .ToHashSet();
    }

    private List<DateTime> HesaplaHedefGunler(bool filtreUygula)
    {
        List<DateTime> hedefGunler;
        if (donemTipi == "Aylik")
        {
            var gunSayisi = DateTime.DaysInMonth(puantajYil, puantajAy);
            hedefGunler = Enumerable.Range(1, gunSayisi)
                .Select(d => new DateTime(puantajYil, puantajAy, d))
                .ToList();
        }
        else if (donemTipi == "Haftalik")
        {
            var bas = puantajBaslangicTarihi.Date;
            var bit = puantajBitisTarihi.Date;
            if (bit < bas) bit = bas;
            hedefGunler = Enumerable.Range(0, (bit - bas).Days + 1)
                .Select(i => bas.AddDays(i))
                .ToList();
        }
        else
        {
            hedefGunler = new List<DateTime> { puantajBaslangicTarihi.Date };
        }

        if (!filtreUygula)
            return hedefGunler;

        var haricGunler = ParseHaricGunNumaralari();
        return hedefGunler
            .Where(g => IsCalismaGunu(g.DayOfWeek))
            .Where(g => donemTipi != "Aylik" || !haricGunler.Contains(g.Day))
            .Distinct()
            .OrderBy(g => g)
            .ToList();
    }

    private void PuantajGunKolonlariniHazirla()
    {
        puantajGunKolonlari = HesaplaHedefGunler(true);

        foreach (var satir in puantajSatirlari)
        {
            var mevcutMap = satir.GunlukHucreler.ToDictionary(h => h.Tarih.Date, h => h.SeferSayisi);
            satir.GunlukHucreler = puantajGunKolonlari
                .Select(g => new PuantajGunHucreModel
                {
                    Tarih = g,
                    SeferSayisi = mevcutMap.TryGetValue(g.Date, out var mevcut)
                        ? mevcut
                        : satir.VarsayilanSeferSayisi
                })
                .ToList();
        }
    }

    private IEnumerable<IGrouping<int, PuantajSatirModel>> GetPuantajGruplari()
    {
        return puantajSatirlari
            .OrderBy(s => s.GuzergahAdi)
            .ThenBy(s => s.AracPlaka)
            .ThenBy(s => s.SoforAdi)
            .GroupBy(s => s.GuzergahId);
    }

    private PuantajGunHucreModel GetOrCreateGunHucre(PuantajSatirModel satir, DateTime gun)
    {
        var hucre = satir.GunlukHucreler.FirstOrDefault(h => h.Tarih.Date == gun.Date);
        if (hucre is not null)
            return hucre;

        hucre = new PuantajGunHucreModel { Tarih = gun, SeferSayisi = satir.VarsayilanSeferSayisi };
        satir.GunlukHucreler.Add(hucre);
        return hucre;
    }

    private void TumSatirlariSec(ChangeEventArgs args)
