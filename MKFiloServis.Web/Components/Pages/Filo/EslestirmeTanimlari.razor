@page "/filo/komisyon-eslestirme"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Services
@inject IFiloKomisyonService FiloKomisyonService
@inject IGuzergahService GuzergahService
@inject IKapasiteService KapasiteService
@inject IFirmaService FirmaService
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

<PageTitle>Servis Operasyon Güzergahları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-link-45deg me-2 text-primary"></i>Araç, Şoför ve Güzergah Eşleme Havuzu</h3>
            <small class="text-muted">Özmal veya komisyonlu (taşeron) servislerin otomatik puantaj üretmeden önceki şablon tanımları</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="PuantajModalAcAsync">
                <i class="bi bi-calendar-plus me-1"></i> Puantaj Oluştur
            </button>
            <button class="btn btn-primary" @onclick="YeniEkleModalAc">
                <i class="bi bi-plus-lg me-1"></i> Yeni Eşleşme Ekle
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Arama yapılıyor...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Durum</th>
                                <th>Müşteri Kurum</th>
                                <th>Güzergah</th>
                                <th>Araç Plakası</th>
                                <th>Sahiplik</th>
                                <th>Şoför</th>
                                <th>Kuruma Kesilecek Ücret</th>
                                <th>Taşerona/Şoföre Ödenen</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!eslestirmeler.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-4 text-muted">
                                        <em>Kayıtlı eşleştirme bulunamadı.</em>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var e in eslestirmeler)
                                {
                                    <tr>
                                        <td>
                                            @if(e.IsActive) { <span class="badge bg-success">Aktif</span> } else { <span class="badge bg-secondary">Pasif</span> }
                                        </td>
                                        <td class="fw-bold text-primary">@e.KurumFirma?.KurumAdi</td>
                                        <td>@e.Guzergah?.GuzergahAdi</td>
                                        <td class="fw-bold">@(e.Arac?.AktifPlaka ?? e.Arac?.AktifPlakaKaydi?.Plaka)</td>
                                        <td>
                                            @if (e.Arac != null)
                                            {
                                                <span class="badge @GetSahiplikBadge(e.Arac.SahiplikTipi)">@GetSahiplikText(e.Arac.SahiplikTipi)</span>
                                            }
                                        </td>
                                        <td>@e.Sofor?.TamAd</td>
                                        <td class="text-success fw-bold">@e.KurumaKesilecekUcret.ToString("N2") TL</td>
                                        <td class="text-danger fw-bold">@e.TaseronaOdenenUcret.ToString("N2") TL</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => DuzenleModalAc(e)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SilModalAc(e)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>

                                    @if (olusanPuantajlarByEslestirme.TryGetValue(e.Id, out var olusanPuantajlar) && olusanPuantajlar.Any())
                                    {
                                        <tr class="table-light">
                                            <td></td>
                                            <td colspan="8">
                                                <div class="small text-muted mb-1">Oluşturulan puantaj kayıtları</div>
                                                <table class="table table-sm mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 180px;">Gün</th>
                                                            <th style="width: 120px;">Sefer Sayısı</th>
                                                            <th style="width: 220px;">Kapasite</th>
                                                            <th>Not</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var puantaj in olusanPuantajlar.OrderByDescending(p => p.Tarih))
                                                        {
                                                            <tr>
                                                                <td>@puantaj.Tarih.ToString("dd.MM.yyyy")</td>
                                                                <td>@puantaj.SeferSayisi.ToString("N2")</td>
                                                                <td>@GetKapasiteMetni(puantaj.Notlar)</td>
                                                                <td>@(string.IsNullOrWhiteSpace(puantaj.Notlar) ? "-" : puantaj.Notlar)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (isModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">@(model.Id == 0 ? "Yeni Eşleştirme Şablonu" : "Eşleştirme Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Müşteri/Kurum <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.KurumFirmaId" @bind:after="KurumSecimiDegistiAsync">
                                <option value="0">-- Kurum Seçin --</option>
                                @foreach(var k in kurumFirmaListesi) {
                                    <option value="@k.Id">@k.KurumAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Güzergah <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.GuzergahId" @bind:after="GuzergahSecimiDegistiAsync">
                                <option value="0">-- Güzergah Seçin --</option>
                                @foreach(var g in guzergahListesi) {
                                    <option value="@g.Id">@g.GuzergahAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Çalışacak Araç <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.AracId" @bind:after="AracSecimiDegistiAsync">
                                <option value="0">-- Araç Seçin --</option>
                                @foreach(var a in aracListesi) {
                                    <option value="@a.Id">@(a.AktifPlaka ?? a.AktifPlakaKaydi?.Plaka ?? a.SaseNo)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Görevli Şoför <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="model.SoforId">
                                <option value="0">-- Şoför Seçin --</option>
                                @foreach(var s in soforListesi) {
                                    <option value="@s.Id">@s.TamAd</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-success fw-bold">Kuruma Kesilecek Ücret (1 Sefer) ₺</label>
                            <input type="number" step="0.01" class="form-control text-success fw-bold" @bind="model.KurumaKesilecekUcret" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-danger fw-bold">Taşerona/Şoföre Ödenen Ücret ₺</label>
                            <input type="number" step="0.01" class="form-control text-danger fw-bold" @bind="model.TaseronaOdenenUcret" disabled="@(!SecilenAracKomisyonMu())" />
                            <small class="text-muted">Komisyon araçlarda aktif olur. Özmal ve kiralıkta otomatik 0 kabul edilir.</small>
                        </div>
                        <div class="col-md-12">
                            @if (GetSecilenArac() is Arac secilenArac)
                            {
                                <div class="alert @GetSahiplikAlertClass(secilenArac.SahiplikTipi) py-2 mb-2">
                                    <strong>@GetSahiplikText(secilenArac.SahiplikTipi)</strong> kuralı: @GetSahiplikAciklama(secilenArac.SahiplikTipi)
                                </div>
                            }
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" @bind="model.IsActive">
                                <label class="form-check-label" for="flexSwitchCheckChecked">Bu Eşleşme Aktif Çalışıyor Mu?</label>
                            </div>
                            <small class="text-muted">Pasif konumdaki eşleşmelere puantaj dağılımı yansıtılmaz.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="Kaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

@if (isPuantajModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">Toplu Puantaj Oluştur</h5>
                    <button type="button" class="btn-close" @onclick="PuantajModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Kurum <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="seciliPuantajKurumFirmaId" @bind:after="PuantajKurumDegistiAsync">
                                <option value="0">-- Önce Kurum Seçin --</option>
                                @foreach (var kurum in puantajKurumListesi)
                                {
                                    <option value="@kurum.Id">@kurum.KurumAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Dönem Tipi</label>
                            <select class="form-select" @bind="donemTipi" @bind:after="DonemTipiDegisti">
                                <option value="Gunluk">Günlük</option>
                                <option value="Haftalik">Haftalık</option>
                                <option value="Aylik">Aylık</option>
                            </select>
                        </div>
                        @if (donemTipi == "Gunluk")
                        {
                            <div class="col-md-3">
                                <label class="form-label">Tarih</label>
                                <input type="date" class="form-control" @bind="puantajBaslangicTarihi" @bind:after="DonemTipiDegisti" />
                            </div>
                        }
                        else if (donemTipi == "Haftalik")
                        {
                            <div class="col-md-2">
                                <label class="form-label">Başlangıç</label>
                                <input type="date" class="form-control" @bind="puantajBaslangicTarihi" @bind:after="DonemTipiDegisti" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Bitiş</label>
                                <input type="date" class="form-control" @bind="puantajBitisTarihi" @bind:after="DonemTipiDegisti" />
                            </div>
                        }
                        else
                        {
                            <div class="col-md-2">
                                <label class="form-label">Yıl</label>
                                <input type="number" class="form-control" @bind="puantajYil" min="2000" max="2100" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Ay</label>
                                <select class="form-select" @bind="puantajAy">
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        var ay = m;
                                        var ayAdi = new DateTime(2000, ay, 1).ToString("MMMM");
                                        <option value="@ay">@ayAdi</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="col-12">
                            <div class="alert alert-info mb-0 py-2 small">
                                @if (donemTipi == "Gunluk")
                                {
                                    <span>Seçili gün için eşleştirme başına 1 puantaj satırı oluşturulur.</span>
                                }
                                else if (donemTipi == "Haftalik")
                                {
                                    <span>Başlangıç–Bitiş arasındaki her gün için eşleştirme başına birer satır oluşturulur. (@((puantajBitisTarihi - puantajBaslangicTarihi).Days + 1) gün)</span>
                                }
                                else
                                {
                                    <span>@puantajYil/@puantajAy ayındaki her gün için eşleştirme başına birer satır oluşturulur. (@DateTime.DaysInMonth(puantajYil, puantajAy) gün)</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (seciliPuantajKurumFirmaId > 0)
                    {
                        <div class="table-responsive border rounded">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 45px;">
                                            <input type="checkbox" class="form-check-input" checked="@tumSatirlarSecili" @onchange="TumSatirlariSec" />
                                        </th>
                                        <th>Kurum</th>
                                        <th>Güzergah</th>
                                        <th>Araç</th>
                                        <th>Şoför</th>
                                        <th>Firma</th>
                                        <th>Gelir/Sefer</th>
                                        <th>Gider/Sefer</th>
                                        <th style="min-width: 170px;">Kapasite</th>
                                        <th style="min-width: 130px;">Sefer Sayısı</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!puantajSatirlari.Any())
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center py-3 text-muted">Seçilen kurum için aktif eşleştirme bulunamadı.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var satir in puantajSatirlari)
                                        {
                                            <tr>
                                                <td>
                                                    <input type="checkbox" class="form-check-input" @bind="satir.Secili" />
                                                </td>
                                                <td>@satir.KurumAdi</td>
                                                <td>@satir.GuzergahAdi</td>
                                                <td>@satir.AracPlaka</td>
                                                <td>@satir.SoforAdi</td>
                                                <td>@satir.FirmaAdi</td>
                                                <td class="text-success fw-semibold">@satir.GelirFiyati.ToString("N2")</td>
                                                <td class="text-danger fw-semibold">@satir.GiderFiyati.ToString("N2")</td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="satir.KapasiteId">
                                                        <option value="">-- Kapasite --</option>
                                                        @foreach (var kapasite in kapasiteListesi)
                                                        {
                                                            <option value="@kapasite.Id">@kapasite.KapasiteAdi</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" min="0.01" step="0.5" class="form-control form-control-sm" @bind="satir.SeferSayisi" />
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="PuantajModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TopluPuantajOlusturAsync" disabled="@(!puantajSatirlari.Any(s => s.Secili))">
                        <i class="bi bi-calendar-plus me-1"></i>Seçili Satırlardan Puantaj Oluştur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isModalOpen = false;
    private bool isPuantajModalOpen = false;
    private int aktifFirmaId;
    private List<FiloGuzergahEslestirme> eslestirmeler = new();
    private Kullanici? aktifKullanici;

    // Lookups
    private List<Kurum> kurumFirmaListesi = new();   // KurumFirmaId → Kurum.Id FK eşleşmesi
    private List<Guzergah> guzergahListesi = new();
    private List<Arac> aracListesi = new();
    private List<Sofor> soforListesi = new();
    private List<Kapasite> kapasiteListesi = new();

    private List<Kurum> puantajKurumListesi = new();
    private int seciliPuantajKurumFirmaId;
    private bool tumSatirlarSecili = true;
    private List<PuantajSatirModel> puantajSatirlari = new();
    private readonly Dictionary<int, List<FiloGunlukPuantaj>> olusanPuantajlarByEslestirme = new();

    // Puantaj modalı dönem seçimi
    private string donemTipi = "Gunluk"; // Gunluk | Haftalik | Aylik
    private DateTime puantajBaslangicTarihi = DateTime.Today;
    private DateTime puantajBitisTarihi = DateTime.Today;
    private int puantajAy = DateTime.Today.Month;
    private int puantajYil = DateTime.Today.Year;

    private FiloGuzergahEslestirme model = new();

    protected override async Task OnInitializedAsync()
    {
        AktifFirmaBaglaminiYenile();
        aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();
        await LoadLookups();
        await ListeYenile();
    }

    private void AktifFirmaBaglaminiYenile()
    {
        var af = FirmaService.GetAktifFirma();
        aktifFirmaId = af.TumFirmalar || af.FirmaId <= 0 ? 0 : af.FirmaId;
    }

    private async Task LoadLookups()
    {
        // KurumFirmaId → Kurum.Id FK: kurum listesi Kurumlar tablosundan alınır
        kurumFirmaListesi = await KurumService.GetAktifAsync();
        aracListesi = await FiloKomisyonService.GetAraclarAsync(aktifFirmaId);
        guzergahListesi = await FiloKomisyonService.GetGuzergahlarAsync();
        soforListesi = await FiloKomisyonService.GetSoforlerAsync();
        kapasiteListesi = await KapasiteService.GetActiveAsync();
    }

    private async Task ListeYenile()
    {
        isLoading = true;
        try
        {
            eslestirmeler = await FiloKomisyonService.GetEslestirmelerAsync(aktifFirmaId, sadeceAktifler: false);
        }
        catch
        {
            ToastService.ShowError("Veriler yüklenirken hata oluştu.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PuantajModalAcAsync()
    {
        AktifFirmaBaglaminiYenile();

        if (aktifFirmaId <= 0)
        {
            ToastService.ShowError("Puantaj oluşturmak için önce aktif firma seçiniz.");
            return;
        }

        await ListeYenile();

        puantajKurumListesi = eslestirmeler
            .Where(e => e.IsActive && e.KurumFirma is not null)
            .Select(e => e.KurumFirma!)
            .DistinctBy(k => k.Id)
            .OrderBy(k => k.KurumAdi)
            .ToList();

        if (!puantajKurumListesi.Any())
        {
            ToastService.ShowInfo("Aktif eşleştirme bulunan kurum yok. Önce aktif eşleştirme kaydı oluşturunuz.");
            return;
        }

        seciliPuantajKurumFirmaId = 0;
        puantajSatirlari.Clear();
        tumSatirlarSecili = true;
        isPuantajModalOpen = true;
    }

    private void PuantajModalKapat()
    {
        isPuantajModalOpen = false;
    }

    private Task PuantajKurumDegistiAsync()
    {
        puantajSatirlari = eslestirmeler
            .Where(e => e.IsActive && e.KurumFirmaId == seciliPuantajKurumFirmaId)
            .Select(e =>
            {
                var guzergah = guzergahListesi.FirstOrDefault(g => g.Id == e.GuzergahId);
                var varsayilanSefer = guzergah?.SeferTipi switch
                {
                    SeferTipi.SabahAksam => 2m,
                    _                    => 1m
                };

                return new PuantajSatirModel
                {
                    Secili = true,
                    EslestirmeId = e.Id,
                    KurumFirmaId = e.KurumFirmaId,
                    KurumAdi = e.KurumFirma?.KurumAdi ?? "-",
                    GuzergahId = e.GuzergahId,
                    GuzergahAdi = e.Guzergah?.GuzergahAdi ?? "-",
                    AracId = e.AracId,
                    AracPlaka = e.Arac?.AktifPlaka ?? e.Arac?.AktifPlakaKaydi?.Plaka ?? "-",
                    SoforId = e.SoforId,
                    SoforAdi = e.Sofor?.TamAd ?? "-",
                    FirmaAdi = GetOperasyonFirmaAdi(e),
                    GelirFiyati = e.KurumaKesilecekUcret,
                    GiderFiyati = e.TaseronaOdenenUcret,
                    ServisTuru = e.ServisTuru,
                    SeferSayisi = varsayilanSefer
                };
            })
            .ToList();

        tumSatirlarSecili = puantajSatirlari.Any();
        return Task.CompletedTask;
    }

    private Task DonemTipiDegisti()
    {
        if (donemTipi == "Gunluk")
        {
            puantajBitisTarihi = puantajBaslangicTarihi;
        }
        else if (donemTipi == "Haftalik")
        {
            if (puantajBitisTarihi < puantajBaslangicTarihi)
                puantajBitisTarihi = puantajBaslangicTarihi.AddDays(6);
        }
        return Task.CompletedTask;
    }

    private void TumSatirlariSec(ChangeEventArgs args)
    {
        var secili = args.Value is bool b && b;
        tumSatirlarSecili = secili;

        foreach (var satir in puantajSatirlari)
            satir.Secili = secili;
    }

    private async Task TopluPuantajOlusturAsync()
    {
        AktifFirmaBaglaminiYenile();

        if (aktifFirmaId <= 0)
        {
            ToastService.ShowError("Aktif firma seçilmediği için puantaj oluşturulamaz.");
            return;
        }

        if (seciliPuantajKurumFirmaId == 0)
        {
            ToastService.ShowError("Önce kurum seçiniz.");
            return;
        }

        var secilenSatirlar = puantajSatirlari.Where(s => s.Secili).ToList();
        if (!secilenSatirlar.Any())
        {
            ToastService.ShowError("Puantaj üretmek için en az bir satır seçiniz.");
            return;
        }

        // Dönem aralığı hesapla
        List<DateTime> hedefGunler;
        if (donemTipi == "Aylik")
        {
            var gunSayisi = DateTime.DaysInMonth(puantajYil, puantajAy);
            hedefGunler = Enumerable.Range(1, gunSayisi)
                .Select(d => new DateTime(puantajYil, puantajAy, d))
                .ToList();
        }
        else if (donemTipi == "Haftalik")
        {
            var bas = puantajBaslangicTarihi.Date;
            var bit = puantajBitisTarihi.Date;
            if (bit < bas) bit = bas;
            hedefGunler = Enumerable.Range(0, (bit - bas).Days + 1)
                .Select(i => bas.AddDays(i))
                .ToList();
        }
        else
        {
            hedefGunler = new List<DateTime> { puantajBaslangicTarihi.Date };
        }

        try
        {
            var mevcutEslestirmeByTarih = new Dictionary<DateTime, HashSet<int>>();
            foreach (var tarih in hedefGunler)
            {
                var mevcutPuantajlar = await FiloKomisyonService.GetGunlukPuantajlarSiraliAsync(aktifFirmaId, tarih);
                mevcutEslestirmeByTarih[tarih] = mevcutPuantajlar
                    .Where(p => p.FiloGuzergahEslestirmeId.HasValue)
                    .Select(p => p.FiloGuzergahEslestirmeId!.Value)
                    .ToHashSet();
            }

            var olusturulan = 0;
            var atlanan = 0;

            foreach (var gun in hedefGunler)
            {
                foreach (var satir in secilenSatirlar)
                {
                    if (mevcutEslestirmeByTarih.TryGetValue(gun, out var mevcutSet)
                        && mevcutSet.Contains(satir.EslestirmeId))
                    {
                        atlanan++;
                        continue;
                    }

                    var kapasiteAdi = satir.KapasiteId.HasValue
                        ? kapasiteListesi.FirstOrDefault(k => k.Id == satir.KapasiteId.Value)?.KapasiteAdi
                        : null;

                    var puantaj = new FiloGunlukPuantaj
                    {
                        FirmaId = aktifFirmaId,
                        Tarih = gun,
                        FiloGuzergahEslestirmeId = satir.EslestirmeId,
                        KurumFirmaId = satir.KurumFirmaId,
                        GuzergahId = satir.GuzergahId,
                        AracId = satir.AracId,
                        SoforId = satir.SoforId,
                        Durum = OperasyonDurumu.Gitti,
                        ServisTuru = satir.ServisTuru,
                        SeferSayisi = satir.SeferSayisi <= 0 ? 1m : satir.SeferSayisi,
                        PuantajCarpani = 1m,
                        Notlar = string.IsNullOrWhiteSpace(kapasiteAdi) ? null : $"Kapasite: {kapasiteAdi}"
                    };

                    var kaydedilen = await FiloKomisyonService.CreatePuantajAsync(puantaj);
                    if (!olusanPuantajlarByEslestirme.TryGetValue(satir.EslestirmeId, out var liste))
                    {
                        liste = new List<FiloGunlukPuantaj>();
                        olusanPuantajlarByEslestirme[satir.EslestirmeId] = liste;
                    }
                    liste.Add(kaydedilen);
                    mevcutEslestirmeByTarih[gun].Add(satir.EslestirmeId);
                    olusturulan++;
                }
            }

            if (olusturulan == 0 && atlanan > 0)
            {
                ToastService.ShowInfo("Seçili satırların tamamı seçilen dönem için zaten oluşturulmuş.");
                return;
            }

            ToastService.ShowSuccess($"{olusturulan} puantaj kaydı oluşturuldu ({hedefGunler.Count} gün, {secilenSatirlar.Count} eşleştirme). Atlanan: {atlanan}");
            isPuantajModalOpen = false;
            await ListeYenile();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Toplu puantaj oluşturulurken hata oluştu: " + ex.GetBaseException().Message);
        }
    }

    private async Task YeniEkleModalAc()
    {
        model = new FiloGuzergahEslestirme { FirmaId = aktifFirmaId, IsActive = true };
        await KurumSecimiDegistiAsync();
        VarsayilanSoforuAta();
        isModalOpen = true;
    }

    private async Task DuzenleModalAc(FiloGuzergahEslestirme esleme)
    {
        model = new FiloGuzergahEslestirme
        {
            Id = esleme.Id,
            FirmaId = esleme.FirmaId,
            KurumFirmaId = esleme.KurumFirmaId,
            GuzergahId = esleme.GuzergahId,
            AracId = esleme.AracId,
            SoforId = esleme.SoforId,
            KurumaKesilecekUcret = esleme.KurumaKesilecekUcret,
            TaseronaOdenenUcret = esleme.TaseronaOdenenUcret,
            IsActive = esleme.IsActive
        };
        await KurumSecimiDegistiAsync();
        if (!SecilenAracKomisyonMu())
            model.TaseronaOdenenUcret = 0;
        isModalOpen = true;
    }

    private void ModalKapat()
    {
        isModalOpen = false;
    }

    private async Task SilModalAc(FiloGuzergahEslestirme esleme)
    {
        await FiloKomisyonService.DeleteEslestirmeAsync(esleme.Id);
        ToastService.ShowSuccess("Kayıt Silindi.");
        await ListeYenile();
    }

    private async Task Kaydet()
    {
        if(model.KurumFirmaId == 0 || model.GuzergahId == 0 || model.AracId == 0 || model.SoforId == 0)
        {
            ToastService.ShowError("Lütfen tüm zorunlu alanları seçiniz!");
            return;
        }

        try
        {
            if (model.Id == 0)
                await FiloKomisyonService.CreateEslestirmeAsync(model);
            else
                await FiloKomisyonService.UpdateEslestirmeAsync(model);

            ToastService.ShowSuccess("Eşleştirme Kaydedildi!");
            isModalOpen = false;
            await ListeYenile();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Kayıt sırasında bir hata oluştu: " + ex.Message);
        }
    }

    private async Task KurumSecimiDegistiAsync()
    {
        // KurumFirmaId = Firma.Id; Guzergah.CariId = Cari.Id farklı tablolar.
        // Kurum değişince tüm aktif güzergahları listele, kullanıcı seçsin.
        guzergahListesi = await FiloKomisyonService.GetGuzergahlarAsync();

        model.GuzergahId = 0;
        model.KurumaKesilecekUcret = 0;
        model.TaseronaOdenenUcret = 0;
        model.ServisTuru = ServisTuru.SabahAksam;
    }

    private void VarsayilanSoforuAta()
    {
        if (model.SoforId > 0)
            return;

        var aktifKullaniciSoforId = aktifKullanici?.SoforId;
        if (!aktifKullaniciSoforId.HasValue)
            return;

        if (soforListesi.Any(s => s.Id == aktifKullaniciSoforId.Value))
            model.SoforId = aktifKullaniciSoforId.Value;
    }

    private Task AracSecimiDegistiAsync()
    {
        if (!SecilenAracKomisyonMu())
            model.TaseronaOdenenUcret = 0;

        return Task.CompletedTask;
    }

    private Task GuzergahSecimiDegistiAsync()
    {
        var guzergah = guzergahListesi.FirstOrDefault(g => g.Id == model.GuzergahId);
        if (guzergah is null)
            return Task.CompletedTask;

        if (guzergah.BirimFiyat > 0)
            model.KurumaKesilecekUcret = guzergah.BirimFiyat;

        if (SecilenAracKomisyonMu() && guzergah.GiderFiyat > 0)
            model.TaseronaOdenenUcret = guzergah.GiderFiyat;

        model.ServisTuru = guzergah.SeferTipi switch
        {
            SeferTipi.Sabah      => ServisTuru.Sabah,
            SeferTipi.Aksam      => ServisTuru.Aksam,
            SeferTipi.SabahAksam => ServisTuru.SabahAksam,
            SeferTipi.Saatlik    => ServisTuru.Ozel,
            SeferTipi.Mesai      => ServisTuru.YardaMesai,
            _                    => ServisTuru.SabahAksam
        };

        return Task.CompletedTask;
    }

    private Arac? GetSecilenArac() => aracListesi.FirstOrDefault(a => a.Id == model.AracId);

    private bool SecilenAracKomisyonMu() => GetSecilenArac()?.SahiplikTipi == AracSahiplikTipi.Komisyon;

    private static string GetSahiplikText(AracSahiplikTipi sahiplikTipi) => SahiplikHelper.GetMetin(sahiplikTipi);

    private static string GetSahiplikBadge(AracSahiplikTipi sahiplikTipi) => SahiplikHelper.GetBadgeClass(sahiplikTipi);

    private static string GetSahiplikAlertClass(AracSahiplikTipi sahiplikTipi) => SahiplikHelper.GetAlertClass(sahiplikTipi);

    private static string GetSahiplikAciklama(AracSahiplikTipi sahiplikTipi) => SahiplikHelper.GetAciklama(sahiplikTipi);

    private static string GetOperasyonFirmaAdi(FiloGuzergahEslestirme eslestirme)
    {
        if (eslestirme.Arac?.TasimaTedarikci is not null)
            return eslestirme.Arac.TasimaTedarikci.Unvan;

        if (eslestirme.Arac?.KomisyoncuCari is not null)
            return eslestirme.Arac.KomisyoncuCari.Unvan;

        if (eslestirme.Arac?.KiralikCari is not null)
            return eslestirme.Arac.KiralikCari.Unvan;

        if (eslestirme.Sofor?.Firma is not null)
            return eslestirme.Sofor.Firma.FirmaAdi;

        return "Özmal";
    }

    private static string GetKapasiteMetni(string? not)
    {
        if (string.IsNullOrWhiteSpace(not))
            return "-";

        const string prefix = "Kapasite: ";
        return not.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? not[prefix.Length..]
            : "-";
    }

