    private bool SatirDuzenleniyorMu(int id) => duzenlenenSatirlar.Contains(id);

    private void SatirDuzenleAc(int id)
    {
        var k = kayitlar.FirstOrDefault(x => x.Id == id);
        if (k == null) return;
        if (k.Onaylandi || k.KurumFaturaKesildiMi || k.TaseronOdemeYapildiMi)
        {
            ToastService.ShowWarning("Onaylı / faturalı / ödenmiş kayıt hızlı düzenlenemez.");
            return;
        }
        orijinalSatirlar[id] = new FiloGunlukPuantaj
        {
            Id = k.Id,
            Tarih = k.Tarih,
            ServisTuru = k.ServisTuru,
            SeferSayisi = k.SeferSayisi,
            SoforId = k.SoforId,
            TahakkukEdenKurumUcreti = k.TahakkukEdenKurumUcreti,
            TahakkukEdenTaseronUcreti = k.TahakkukEdenTaseronUcreti,
            MaliyetOzmalKiralik = k.MaliyetOzmalKiralik,
            Durum = k.Durum
        };
        duzenlenenSatirlar.Add(id);
    }

    private void SatirDuzenleIptal(int id)
    {
        if (orijinalSatirlar.TryGetValue(id, out var orj))
        {
            var k = kayitlar.FirstOrDefault(x => x.Id == id);
            if (k != null)
            {
                k.Tarih = orj.Tarih;
                k.ServisTuru = orj.ServisTuru;
                k.SeferSayisi = orj.SeferSayisi;
                k.SoforId = orj.SoforId;
                k.TahakkukEdenKurumUcreti = orj.TahakkukEdenKurumUcreti;
                k.TahakkukEdenTaseronUcreti = orj.TahakkukEdenTaseronUcreti;
                k.MaliyetOzmalKiralik = orj.MaliyetOzmalKiralik;
                k.Durum = orj.Durum;
            }
            orijinalSatirlar.Remove(id);
        }
        duzenlenenSatirlar.Remove(id);
    }

    private async Task SatirHizliKaydet(FiloGunlukPuantaj k)
    {
        if (k.SeferSayisi <= 0) { ToastService.ShowWarning("Sefer sayısı 0'dan büyük olmalı."); return; }
        isSaving = true;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var entity = await ctx.FiloGunlukPuantajlar.FirstOrDefaultAsync(x => x.Id == k.Id);
            if (entity == null) { ToastService.ShowError("Kayıt bulunamadı."); return; }
            entity.Tarih = k.Tarih;
            entity.ServisTuru = k.ServisTuru;
            entity.SeferSayisi = k.SeferSayisi;
            entity.SoforId = k.SoforId;
            entity.TahakkukEdenKurumUcreti = k.TahakkukEdenKurumUcreti;
            entity.TahakkukEdenTaseronUcreti = k.TahakkukEdenTaseronUcreti;
            entity.MaliyetOzmalKiralik = k.MaliyetOzmalKiralik;
            entity.Durum = k.Durum;
            await ctx.SaveChangesAsync();
            ToastService.ShowSuccess("Satır güncellendi.");
            duzenlenenSatirlar.Remove(k.Id);
            orijinalSatirlar.Remove(k.Id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            var inner = ex.InnerException?.Message;
            ToastService.ShowError($"Güncelleme hatası: {ex.Message}{(string.IsNullOrWhiteSpace(inner) ? "" : " | " + inner)}");
        }
        finally { isSaving = false; }
    }

