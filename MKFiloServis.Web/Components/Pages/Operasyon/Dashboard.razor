@page "/operasyon/dashboard"
@using MKFiloServis.Web.Services
@inject IHakedisRaporService HakedisRaporService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Operasyon Dashboard</PageTitle>

<div class="container-fluid">
    <h3 class="mb-3"><i class="bi bi-speedometer2 me-2 text-primary"></i>Operasyon Dashboard</h3>
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-3 small">
        <li class="breadcrumb-item"><a href="/dashboard">Ana Sayfa</a></li>
        <li class="breadcrumb-item">Operasyonlar</li>
        <li class="breadcrumb-item active">Dashboard</li>
    </ol></nav>

    <!-- Filtre -->
    <div class="row mb-4">
        <div class="col-md-2">
            <label class="form-label small">Yıl</label>
            <input type="number" class="form-control form-control-sm" @bind="Yil" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Ay</label>
            <input type="number" class="form-control form-control-sm" @bind="Ay" min="1" max="12" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary btn-sm w-100" @onclick="LoadData" disabled="@isLoading">
                <i class="bi bi-search me-1"></i>Yükle
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted">Yükleniyor...</p></div>
    }
    else if (kpi == null)
    {
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>Veri bulunamadı veya bu dönemde kayıt yok.</div>
    }
    else
    {
        <!-- KPI Kartları -->
        <div class="row g-3 mb-4">
            <div class="col-md">
                <div class="card text-center shadow-sm border-primary">
                    <div class="card-body py-3">
                        <h6 class="text-muted">Toplam Sefer</h6>
                        <h3 class="text-primary mb-0">@kpi.ToplamSefer.ToString("N0")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md">
                <div class="card text-center shadow-sm border-success">
                    <div class="card-body py-3">
                        <h6 class="text-muted">Gelir</h6>
                        <h3 class="text-success mb-0">@kpi.ToplamGelir.ToString("N0") ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md">
                <div class="card text-center shadow-sm border-danger">
                    <div class="card-body py-3">
                        <h6 class="text-muted">Gider</h6>
                        <h3 class="text-danger mb-0">@kpi.ToplamGider.ToString("N0") ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md">
                <div class="card text-center shadow-sm @(kpi.ToplamKar >= 0 ? "border-info" : "border-warning")">
                    <div class="card-body py-3">
                        <h6 class="text-muted">Kar</h6>
                        <h3 class="@(kpi.ToplamKar >= 0 ? "text-info" : "text-warning") mb-0">@kpi.ToplamKar.ToString("N0") ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md">
                <div class="card text-center shadow-sm border-secondary">
                    <div class="card-body py-3">
                        <h6 class="text-muted">Ort. Maliyet</h6>
                        <h3 class="text-secondary mb-0">@OrtalamaMaliyet.ToString("N0") ₺</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Karlılık Özeti -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card text-center shadow-sm"><div class="card-body py-3">
                    <h6 class="text-muted">Karlılık Oranı</h6>
                    <h4 class="@(kpi.KarlilikOrani >= 0 ? "text-success" : "text-danger") mb-0">%@kpi.KarlilikOrani.ToString("N1")</h4>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="card text-center shadow-sm"><div class="card-body py-3">
                    <h6 class="text-muted">Sefer Başı Gelir</h6>
                    <h4 class="mb-0">@SeferBasiGelir.ToString("N0") ₺</h4>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="card text-center shadow-sm"><div class="card-body py-3">
                    <h6 class="text-muted">Sefer Başı Gider</h6>
                    <h4 class="mb-0">@kpi.OrtalamaSeferMaliyeti.ToString("N0") ₺</h4>
                </div></div>
            </div>
        </div>

        <!-- Gelir vs Gider Grafiği -->
        @if (kpi.GunlukTrend?.Any() == true)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light"><strong><i class="bi bi-graph-up me-1"></i>Gelir vs Gider</strong></div>
                <div class="card-body" style="height:300px;">
                    <canvas id="gelirGiderChart"></canvas>
                </div>
            </div>
        }

        <!-- Günlük Özet Tablosu -->
        @if (kpi.GunlukTrend?.Any() == true)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-light"><strong><i class="bi bi-calendar3 me-1"></i>Günlük Özet</strong></div>
                <div class="card-body p-0">
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Gün</th>
                                <th class="text-end">Sefer</th>
                                <th class="text-end">Gelir</th>
                                <th class="text-end">Gider</th>
                                <th class="text-end">Kar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in kpi.GunlukTrend)
                            {
                                <tr>
                                    <td>@g.Gun</td>
                                    <td class="text-end">@g.Sefer</td>
                                    <td class="text-end">@g.Gelir.ToString("N0")</td>
                                    <td class="text-end">@g.Gider.ToString("N0")</td>
                                    <td class="text-end @(g.Kar >= 0 ? "text-success" : "text-danger")">@g.Kar.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary fw-bold">
                            <tr>
                                <td>Toplam</td>
                                <td class="text-end">@kpi.GunlukTrend.Sum(g => g.Sefer)</td>
                                <td class="text-end">@kpi.GunlukTrend.Sum(g => g.Gelir).ToString("N0")</td>
                                <td class="text-end">@kpi.GunlukTrend.Sum(g => g.Gider).ToString("N0")</td>
                                <td class="text-end">@kpi.GunlukTrend.Sum(g => g.Kar).ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private HakedisDashboardKpi? kpi;
    private bool isLoading;
    private int Yil = DateTime.Now.Year;
    private int Ay = DateTime.Now.Month;

    private decimal OrtalamaMaliyet =>
        kpi == null || kpi.ToplamSefer == 0 ? 0 : kpi.ToplamGider / kpi.ToplamSefer;

    private decimal SeferBasiGelir =>
        kpi == null || kpi.ToplamSefer == 0 ? 0 : kpi.ToplamGelir / kpi.ToplamSefer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try { kpi = await HakedisRaporService.GetDashboardKpiAsync(Yil, Ay); }
        catch { kpi = null; }
        isLoading = false;

        if (kpi?.GunlukTrend?.Any() == true)
        {
            await JS.InvokeVoidAsync("renderGelirGiderChart",
                kpi.GunlukTrend.Select(x => x.Gun).ToArray(),
                kpi.GunlukTrend.Select(x => x.Gelir).ToArray(),
                kpi.GunlukTrend.Select(x => x.Gider).ToArray());
        }
    }
}

