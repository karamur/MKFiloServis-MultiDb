    private static string GetFiyatTipText(ServisFiyatTip t) => t switch
    {
        ServisFiyatTip.Aylik => "aylık",
        ServisFiyatTip.SeferBazi => "sefer başı",
        ServisFiyatTip.Gunluk => "günlük",
