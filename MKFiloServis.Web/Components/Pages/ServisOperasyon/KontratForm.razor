    private static string GetCariEtiket(Cari cari)
        => string.IsNullOrWhiteSpace(cari.CariKodu)
            ? cari.Unvan
            : $"{cari.Unvan} [{cari.CariKodu}]";

    private static string GetGuzergahEtiket(Guzergah guzergah)
        => $"{guzergah.GuzergahKodu} - {guzergah.GuzergahAdi}";

    private static string GetAracEtiket(Arac arac)
    {
        var plaka = arac.AktifPlaka ?? arac.AktifPlakaKaydi?.Plaka ?? arac.SaseNo;
        return string.IsNullOrWhiteSpace(arac.Marka) ? plaka : $"{plaka} - {arac.Marka}";
    }

    private Cari? CariBul(string? metin)
    {
        if (string.IsNullOrWhiteSpace(metin))
        {
            return null;
        }

        var temiz = metin.Trim();
        return cariler.FirstOrDefault(c => string.Equals(GetCariEtiket(c), temiz, StringComparison.OrdinalIgnoreCase))
            ?? cariler.FirstOrDefault(c => string.Equals(c.Unvan, temiz, StringComparison.OrdinalIgnoreCase))
            ?? cariler.FirstOrDefault(c => !string.IsNullOrWhiteSpace(c.CariKodu) && string.Equals(c.CariKodu, temiz, StringComparison.OrdinalIgnoreCase));
    }

    private Guzergah? GuzergahBul(string? metin)
    {
        if (string.IsNullOrWhiteSpace(metin))
        {
            return null;
        }

        var temiz = metin.Trim();
        return FiltreliGuzergahOnerileri.FirstOrDefault(g => string.Equals(GetGuzergahEtiket(g), temiz, StringComparison.OrdinalIgnoreCase))
            ?? FiltreliGuzergahOnerileri.FirstOrDefault(g => string.Equals(g.GuzergahAdi, temiz, StringComparison.OrdinalIgnoreCase))
            ?? FiltreliGuzergahOnerileri.FirstOrDefault(g => string.Equals(g.GuzergahKodu, temiz, StringComparison.OrdinalIgnoreCase));
    }

    private Arac? AracBul(string? metin)
    {
        if (string.IsNullOrWhiteSpace(metin))
        {
            return null;
        }

        var temiz = metin.Trim();
        return araclar.FirstOrDefault(a => string.Equals(GetAracEtiket(a), temiz, StringComparison.OrdinalIgnoreCase))
            ?? araclar.FirstOrDefault(a => string.Equals(a.AktifPlaka, temiz, StringComparison.OrdinalIgnoreCase))
            ?? araclar.FirstOrDefault(a => a.AktifPlakaKaydi != null && string.Equals(a.AktifPlakaKaydi.Plaka, temiz, StringComparison.OrdinalIgnoreCase));
    }

    private string GetCariTipText(CariTipi cariTipi) => cariTipi switch
    {
        CariTipi.Musteri => "Cari / Müşteri",
        CariTipi.Tedarikci => "Cari / Tedarikçi",
        CariTipi.MusteriTedarikci => "Cari / Müşteri+Tedarikçi",
        CariTipi.Personel => "Cari / Personel",
        _ => "Cari"
    };

    private string GetFirmaBaglantiMetni()
    {
        if (kontrat.Tip == ServisKontratTip.Tedarikci && SecilenTedarikci is not null)
        {
            return SecilenTedarikci.Unvan;
        }

        if (SecilenArac?.TasimaTedarikciId is int tasimaTedarikciId)
        {
            return tedarikciler.FirstOrDefault(x => x.Id == tasimaTedarikciId)?.Unvan ?? $"Tedarikçi #{tasimaTedarikciId}";
        }

        if (SecilenArac?.KiralikCariId is int kiralikCariId)
        {
            return cariler.FirstOrDefault(x => x.Id == kiralikCariId)?.Unvan ?? $"Cari #{kiralikCariId}";
        }

        if (SecilenArac?.KomisyoncuCariId is int komisyonCariId)
        {
            return cariler.FirstOrDefault(x => x.Id == komisyonCariId)?.Unvan ?? $"Cari #{komisyonCariId}";
        }

        if (SecilenSofor?.TasimaTedarikciId is int soforTedarikciId)
        {
            return tedarikciler.FirstOrDefault(x => x.Id == soforTedarikciId)?.Unvan ?? $"Tedarikçi #{soforTedarikciId}";
        }

        return "İç kaynak / özmal";
    }

    private string GetFirmaBaglantiTipi()
    {
        if (kontrat.Tip == ServisKontratTip.Tedarikci || SecilenArac?.TasimaTedarikciId != null || SecilenSofor?.TasimaTedarikciId != null)
        {
            return "Tedarikçi";
        }

        if (SecilenArac?.KiralikCariId != null || SecilenArac?.KomisyoncuCariId != null)
        {
            return "Cari";
        }

        return "Özmal";
    }

    private string GetFirmaBaglantiBadge() => GetFirmaBaglantiTipi() switch
    {
        "Tedarikçi" => "bg-success",
        "Cari" => "bg-primary",
        _ => "bg-secondary"
    };

    private static string BuildGuzergahKodu(string? kurumAdi, string? guzergahAdi)
    {
        static string NormalizePart(string? value)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return string.Empty;
            }

            var chars = value
                .ToUpperInvariant()
                .Where(char.IsLetterOrDigit)
                .Take(6)
                .ToArray();

            return new string(chars);
        }

        var kurumParca = NormalizePart(kurumAdi);
        var guzergahParca = NormalizePart(guzergahAdi);

        if (string.IsNullOrWhiteSpace(kurumParca) && string.IsNullOrWhiteSpace(guzergahParca))
        {
            return string.Empty;
        }

        if (string.IsNullOrWhiteSpace(kurumParca))
        {
            return $"GZR-{guzergahParca}";
        }

        if (string.IsNullOrWhiteSpace(guzergahParca))
        {
            return $"{kurumParca}-GZR";
        }

        return $"{kurumParca}-{guzergahParca}";
    }
}

