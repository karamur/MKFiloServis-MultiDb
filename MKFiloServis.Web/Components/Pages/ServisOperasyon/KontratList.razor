@page "/servis-operasyon/kontratlar"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IServisKontratService KontratService
@inject ITasimaTedarikciService TedarikciService
@inject IGuzergahService GuzergahService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Servis Operasyon - Kontratlar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-clipboard2-data me-2"></i>Servis Operasyon Kontratları</h3>
        <button class="btn btn-success" @onclick='() => Navigation.NavigateTo("/servis-operasyon/kontratlar/yeni")'>
            <i class="bi bi-plus-circle me-1"></i>Yeni Kontrat
        </button>
    </div>

    @* Filtreler *@
    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Arama</label>
                    <input class="form-control form-control-sm" @bind="arama" @bind:event="oninput"
                           placeholder="Güzergah, kurum, kod ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Tip</label>
                    <select class="form-select form-select-sm" @bind="seciliTip">
                        <option value="-1">Tüm Tipler</option>
                        <option value="0">Özmal</option>
                        <option value="1">Kiralık (C)</option>
                        <option value="2">Tedarikçi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" @bind="seciliDurum">
                        <option value="-1">Tüm Durumlar</option>
                        <option value="0">Aktif</option>
                        <option value="1">Tamamlandı</option>
                        <option value="2">İptal</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="seciliTedarikciId">
                        <option value="0">Tüm Tedarikçiler</option>
                        @foreach (var t in tedarikciler)
                        {
                            <option value="@t.Id">@t.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Güzergah</label>
                    <select class="form-select form-select-sm" @bind="seciliGuzergahId">
                        <option value="0">Tüm Güzergahlar</option>
                        @foreach (var g in guzergahlar)
                        {
                            <option value="@g.Id">@g.GuzergahKodu - @g.GuzergahAdi</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row g-2 align-items-end mt-1">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Başlangıç (dan)</label>
                    <input type="date" class="form-control form-control-sm" @bind="baslangicDan" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Başlangıç (e)</label>
                    <input type="date" class="form-control form-control-sm" @bind="baslangicE" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Bitiş Tarihi</label>
                    <select class="form-select form-select-sm" @bind="bitisTarihiFiltre">
                        <option value="">Tümü</option>
                        <option value="gecmis">Süresi Dolmuş</option>
                        <option value="bu_ay">Bu Ay Bitiyor</option>
                        <option value="30gun">30 Gün İçinde</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-sm btn-outline-secondary w-100" @onclick="FiltreleriTemizle">
                        <i class="bi bi-x-circle me-1"></i>Temizle
                    </button>
                </div>
                <div class="col text-end">
                    <span class="text-muted small">@Filtrele().Count kayıt</span>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        @* Özet kartlar *@
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card border-0 bg-primary text-white shadow-sm">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small opacity-75">Özmal</div>
                            <div class="fs-4 fw-bold">@kontratlar.Count(k => k.Tip == ServisKontratTip.Ozmal && k.Durum == ServisKontratDurum.Aktif)</div>
                        </div>
                        <i class="bi bi-truck fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-info text-white shadow-sm">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small opacity-75">Kiralık (C)</div>
                            <div class="fs-4 fw-bold">@kontratlar.Count(k => k.Tip == ServisKontratTip.Kiralik && k.Durum == ServisKontratDurum.Aktif)</div>
                        </div>
                        <i class="bi bi-signpost-2 fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-success text-white shadow-sm">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small opacity-75">Tedarikçi</div>
                            <div class="fs-4 fw-bold">@kontratlar.Count(k => k.Tip == ServisKontratTip.Tedarikci && k.Durum == ServisKontratDurum.Aktif)</div>
                        </div>
                        <i class="bi bi-diagram-3 fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-warning text-dark shadow-sm">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small">Toplam Aktif</div>
                            <div class="fs-4 fw-bold">@kontratlar.Count(k => k.Durum == ServisKontratDurum.Aktif)</div>
                        </div>
                        <i class="bi bi-check-circle fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Kod</th>
                        <th>Tip</th>
                        <th>Güzergah</th>
                        <th>Kurum</th>
                        <th>Araç</th>
                        <th>Şoför/Tedarikçi</th>
                        <th>Başlangıç</th>
                        <th>Bitiş</th>
                        <th class="text-end">Tahsilat Fiyat</th>
                        <th class="text-end">Ödeme Fiyat</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var k in Filtrele())
                    {
                        <tr>
                            <td><a href="/servis-operasyon/kontratlar/@k.Id" class="text-decoration-none fw-semibold">@k.KontratKodu</a></td>
                            <td><span class="badge @GetTipBadge(k.Tip)">@GetTipText(k.Tip)</span></td>
                            <td>
                                <span class="fw-semibold small">@k.Guzergah?.GuzergahKodu</span>
                                <div class="text-muted" style="font-size:.75rem">@k.Guzergah?.GuzergahAdi</div>
                            </td>
                            <td class="small">@k.KurumCari?.Unvan</td>
                            <td class="small">
                                @if (k.Arac != null)
                                { <span class="badge bg-light text-dark border">@k.Arac.AktifPlaka</span> }
                                else if (k.Tip == ServisKontratTip.Tedarikci)
                                { <span class="text-muted">—</span> }
                                else
                                { <span class="text-warning small"><i class="bi bi-exclamation-triangle me-1"></i>Atanmadı</span> }
                            </td>
                            <td class="small">
                                @if (k.Tip == ServisKontratTip.Tedarikci)
                                { <span>@k.TasimaTedarikci?.Unvan</span> }
                                else if (k.Sofor != null)
                                { <span>@k.Sofor.Ad @k.Sofor.Soyad</span> }
                                else
                                { <span class="text-muted">—</span> }
                            </td>
                            <td class="small">@k.BaslangicTarihi.ToString("dd.MM.yyyy")</td>
                            <td class="small">
                                @if (k.BitisTarihi.HasValue)
                                {
                                    <span class="@(k.BitisTarihi < DateTime.Today ? "text-danger" : "")">
                                        @k.BitisTarihi.Value.ToString("dd.MM.yyyy")
                                    </span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-end small">
                                @if (k.TahsilatBirimFiyat.HasValue)
                                {
                                    <strong>@k.TahsilatBirimFiyat.Value.ToString("N2")</strong>
                                    <div class="text-muted" style="font-size:.7rem">@GetFiyatTipText(k.TahsilatTip)</div>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-end small">
                                @if (k.OdemeBirimFiyat.HasValue)
                                {
                                    <strong>@k.OdemeBirimFiyat.Value.ToString("N2")</strong>
                                    <div class="text-muted" style="font-size:.7rem">@(k.OdemeTip.HasValue ? GetFiyatTipText(k.OdemeTip.Value) : "")</div>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td><span class="badge @GetDurumBadge(k.Durum)">@GetDurumText(k.Durum)</span></td>
                            <td class="text-end" style="white-space:nowrap">
                                <a href="/servis-operasyon/kontratlar/@k.Id" class="btn btn-sm btn-outline-primary" title="Detay/Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Filtrele().Any())
        {
            <div class="alert alert-info mt-2">
                <i class="bi bi-info-circle me-2"></i>Filtre kriterlerine uygun kayıt bulunamadı.
                <a href="/servis-operasyon/kontratlar/yeni" class="btn btn-sm btn-success ms-3">
                    <i class="bi bi-plus-circle me-1"></i>İlk Kontratı Oluştur
                </a>
            </div>
        }
    }
</div>

@code {
    private bool yukleniyor = true;
    private List<ServisKontrat> kontratlar = new();
    private List<TasimaTedarikci> tedarikciler = new();
    private List<Guzergah> guzergahlar = new();
    private string arama = "";
    private int seciliTip = -1;
    private int seciliDurum = 0; // Varsayılan: Aktif
    private int seciliTedarikciId = 0;
    private int seciliGuzergahId = 0;
    private DateTime? baslangicDan;
    private DateTime? baslangicE;
    private string bitisTarihiFiltre = "";

    protected override async Task OnInitializedAsync()
    {
        var tasks = Task.WhenAll(
            KontratService.GetAllAsync().ContinueWith(t => kontratlar = t.Result),
            TedarikciService.GetAllAsync(sadeceAktif: false).ContinueWith(t => tedarikciler = t.Result),
            GuzergahService.GetAllAsync().ContinueWith(t => guzergahlar = t.Result)
        );
        await tasks;
        yukleniyor = false;
    }

    private void FiltreleriTemizle()
    {
        arama = "";
        seciliTip = -1;
        seciliDurum = 0;
        seciliTedarikciId = 0;
        seciliGuzergahId = 0;
        baslangicDan = null;
        baslangicE = null;
        bitisTarihiFiltre = "";
    }

    private List<ServisKontrat> Filtrele()
    {
        var q = kontratlar.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(arama))
            q = q.Where(k =>
                (k.KontratKodu?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (k.Guzergah?.GuzergahKodu?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (k.Guzergah?.GuzergahAdi?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (k.KurumCari?.Unvan?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (k.TasimaTedarikci?.Unvan?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false));
        if (seciliTip >= 0)
            q = q.Where(k => (int)k.Tip == seciliTip);
        if (seciliDurum >= 0)
            q = q.Where(k => (int)k.Durum == seciliDurum);
        if (seciliTedarikciId > 0)
            q = q.Where(k => k.TasimaTedarikciId == seciliTedarikciId);
        if (seciliGuzergahId > 0)
            q = q.Where(k => k.GuzergahId == seciliGuzergahId);
        if (baslangicDan.HasValue)
            q = q.Where(k => k.BaslangicTarihi >= baslangicDan.Value);
        if (baslangicE.HasValue)
            q = q.Where(k => k.BaslangicTarihi <= baslangicE.Value);
        if (!string.IsNullOrEmpty(bitisTarihiFiltre))
        {
            var bugun = DateTime.Today;
            q = bitisTarihiFiltre switch
            {
                "gecmis" => q.Where(k => k.BitisTarihi.HasValue && k.BitisTarihi.Value < bugun),
                "bu_ay" => q.Where(k => k.BitisTarihi.HasValue &&
                    k.BitisTarihi.Value.Year == bugun.Year &&
                    k.BitisTarihi.Value.Month == bugun.Month),
                "30gun" => q.Where(k => k.BitisTarihi.HasValue &&
                    k.BitisTarihi.Value >= bugun &&
                    k.BitisTarihi.Value <= bugun.AddDays(30)),
                _ => q
            };
        }
        return q.ToList();
    }

    private static string GetTipText(ServisKontratTip tip) => tip switch
    {
        ServisKontratTip.Ozmal => "Özmal",
        ServisKontratTip.Kiralik => "Kiralık",
        ServisKontratTip.Tedarikci => "Tedarikçi",
        _ => tip.ToString()
    };

    private static string GetTipBadge(ServisKontratTip tip) => tip switch
    {
        ServisKontratTip.Ozmal => "bg-primary",
        ServisKontratTip.Kiralik => "bg-info text-dark",
        ServisKontratTip.Tedarikci => "bg-success",
        _ => "bg-secondary"
    };

    private static string GetDurumText(ServisKontratDurum d) => d switch
    {
        ServisKontratDurum.Aktif => "Aktif",
        ServisKontratDurum.Tamamlandi => "Tamamlandı",
        ServisKontratDurum.IptalEdildi => "İptal",
        _ => d.ToString()
    };

    private static string GetDurumBadge(ServisKontratDurum d) => d switch
    {
        ServisKontratDurum.Aktif => "bg-success",
        ServisKontratDurum.Tamamlandi => "bg-secondary",
        ServisKontratDurum.IptalEdildi => "bg-danger",
        _ => "bg-light text-dark"
    };

    private static string GetFiyatTipText(ServisFiyatTip t) => t switch
    {
        ServisFiyatTip.Aylik => "aylık",
        ServisFiyatTip.SeferBazi => "sefer başı",
        ServisFiyatTip.Gunluk => "günlük",
        _ => t.ToString()
    };
}

