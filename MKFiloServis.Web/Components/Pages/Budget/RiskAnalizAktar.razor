@page "/butce/risk-analiz-aktar"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IBudgetService BudgetService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Bütçe Risk Analizi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-shield-exclamation me-2 text-danger"></i>Bütçe Risk Analizi</h4>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenFirmaId" @bind:after="YenileAsync">
                <option value="0">Tüm Firmalar</option>
                @if (firmalar != null)
                {
                    @foreach (var firma in firmalar)
                    {
                        <option value="@firma.Id">@firma.FirmaAdi</option>
                    }
                }
            </select>
            <select class="form-select form-select-sm" style="width: 100px;" @bind="secilenYil" @bind:after="YenileAsync">
                @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 120px;" @bind="secilenAy" @bind:after="YenileAsync">
                <option value="">Tüm Yıl</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@GetAyAdi(m)</option>
                }
            </select>
            <button class="btn btn-primary btn-sm" @onclick="ExcelAktar" disabled="@(analiz == null)">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-danger btn-sm" @onclick="PdfAktar" disabled="@(analiz == null)">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Risk analizi yapılıyor...</p>
        </div>
    }
    else if (analiz != null)
    {
        <!-- Risk Skoru Kartları -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card h-100 @GetRiskCardClass(analiz.GenelRiskSkoru)">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Genel Risk Skoru</h6>
                        <h2 class="mb-0">%@analiz.GenelRiskSkoru</h2>
                        <small>@GetRiskSeviyeAdi(analiz.GenelRiskSkoru)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Ödeme Gecikmesi Riski</h6>
                        <h2 class="mb-0 @GetRiskTextClass(analiz.OdemeGecikmesiRiski)">%@analiz.OdemeGecikmesiRiski</h2>
                        <small>@analiz.GecikenKayit gecikmiş ödeme</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Likidite Riski</h6>
                        <h2 class="mb-0 @GetRiskTextClass(analiz.LikiditeRiski)">%@analiz.LikiditeRiski</h2>
                        <small>@FormatPara(analiz.ToplamBekleyen) bekleyen</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Bütçe Sapma Riski</h6>
                        <h2 class="mb-0 @GetRiskTextClass(analiz.BudceSapmaRiski)">%@analiz.BudceSapmaRiski</h2>
                        <small>Hedeften sapma</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Özet Bilgiler -->
        <div class="row g-3 mb-4">
            <div class="col-md-2">
                <div class="card bg-light">
                    <div class="card-body py-2">
                        <small class="text-muted">Toplam Kayıt</small>
                        <h5 class="mb-0">@analiz.ToplamKayit</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2">
                        <small>Bekleyen</small>
                        <h5 class="mb-0">@FormatPara(analiz.ToplamBekleyen)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger text-white">
                    <div class="card-body py-2">
                        <small>Geciken</small>
                        <h5 class="mb-0">@FormatPara(analiz.ToplamGeciken)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body py-2">
                        <small>Kısmi Ödenen</small>
                        <h5 class="mb-0">@FormatPara(analiz.ToplamKismiOdenen)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body py-2">
                        <small>Geciken Adet</small>
                        <h5 class="mb-0">@analiz.GecikenKayit</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2">
                        <small>Kısmi Adet</small>
                        <h5 class="mb-0">@analiz.KismiOdenenKayit</h5>
                    </div>
                </div>
            </div>
        </div>

        <!-- Uyarılar ve Öneriler -->
        @if (analiz.Uyarilar.Any() || analiz.Oneriler.Any())
        {
            <div class="row g-3 mb-4">
                @if (analiz.Uyarilar.Any())
                {
                    <div class="col-md-6">
                        <div class="card border-warning">
                            <div class="card-header bg-warning text-dark">
                                <i class="bi bi-exclamation-triangle me-2"></i>Uyarılar
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    @foreach (var uyari in analiz.Uyarilar)
                                    {
                                        <li class="mb-2">@uyari</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
                @if (analiz.Oneriler.Any())
                {
                    <div class="col-md-6">
                        <div class="card border-info">
                            <div class="card-header bg-info text-white">
                                <i class="bi bi-lightbulb me-2"></i>Öneriler
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    @foreach (var oneri in analiz.Oneriler)
                                    {
                                        <li class="mb-2">@oneri</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="row g-3">
            <!-- Riskli Ödemeler -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-danger text-white">
                        <i class="bi bi-exclamation-circle me-2"></i>Riskli Ödemeler (En Yüksek 20)
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        @if (analiz.RiskliOdemeler.Any())
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Masraf Kalemi</th>
                                        <th class="text-end">Kalan</th>
                                        <th class="text-center">Gecikme</th>
                                        <th class="text-center">Risk</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var odeme in analiz.RiskliOdemeler)
                                    {
                                        <tr>
                                            <td>
                                                <div>@odeme.MasrafKalemi</div>
                                                <small class="text-muted">@(odeme.Aciklama?.Length > 30 ? odeme.Aciklama.Substring(0, 30) + "..." : odeme.Aciklama)</small>
                                            </td>
                                            <td class="text-end">@FormatPara(odeme.KalanTutar)</td>
                                            <td class="text-center">@odeme.GecikmeGunu gün</td>
                                            <td class="text-center">
                                                <span class="badge @GetRiskBadgeClass(odeme.RiskSeviyesi)">@odeme.RiskSeviyesi</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-4 text-success">
                                <i class="bi bi-check-circle fs-1"></i>
                                <p class="mb-0 mt-2">Riskli ödeme bulunmuyor</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Kategori Risk Özeti -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <i class="bi bi-pie-chart me-2"></i>Kategori Bazlı Risk
                        @if (!string.IsNullOrEmpty(secilenKategori))
                        {
                            <button class="btn btn-sm btn-outline-light float-end" @onclick="() => secilenKategori = null">
                                <i class="bi bi-x"></i> Seçimi Kaldır
                            </button>
                        }
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        @if (analiz.KategoriRiskleri.Any())
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Kategori</th>
                                        <th class="text-end">Toplam</th>
                                        <th class="text-end">Geciken</th>
                                        <th class="text-center">Risk %</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var kategori in analiz.KategoriRiskleri.OrderByDescending(k => k.RiskSkoru))
                                    {
                                        <tr class="@(secilenKategori == kategori.Kategori ? "table-primary" : "")" 
                                            style="cursor: pointer;" 
                                            @onclick="() => secilenKategori = secilenKategori == kategori.Kategori ? null : kategori.Kategori"
                                            title="Detayları görmek için tıklayın">
                                            <td><i class="bi bi-chevron-right me-1 @(secilenKategori == kategori.Kategori ? "text-primary" : "text-muted")" style="font-size:0.75rem;"></i>@kategori.Kategori</td>
                                            <td class="text-end">@FormatPara(kategori.ToplamTutar)</td>
                                            <td class="text-end text-danger">@FormatPara(kategori.GecikenTutar)</td>
                                            <td class="text-center">
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar @GetProgressBarClass(kategori.RiskSkoru)" 
                                                         role="progressbar" 
                                                         style="width: @Math.Min(kategori.RiskSkoru, 100)%">
                                                        @kategori.RiskSkoru%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <p class="text-muted mb-0">Veri bulunamadı</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Seçilen Kategori Ödeme Detayları -->
        @if (!string.IsNullOrEmpty(secilenKategori) && analiz.KategoriOdemeleri.TryGetValue(secilenKategori, out var kategoriOdemeleri))
        {
            <div class="card mt-3">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-list-ul me-2 text-primary"></i><strong>@secilenKategori</strong> — Ödeme Listesi (@kategoriOdemeleri.Count kayıt)</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => secilenKategori = null">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Açıklama</th>
                                    <th class="text-end">Tutar</th>
                                    <th class="text-end">Kalan</th>
                                    <th class="text-center">Vade</th>
                                    <th class="text-center">Durum</th>
                                    <th class="text-center">Gecikme</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var odeme in kategoriOdemeleri)
                                {
                                    <tr class="@(odeme.GecikmeGunu > 0 ? "table-danger" : odeme.Durum == OdemeDurum.Bekliyor ? "table-warning" : odeme.Durum == OdemeDurum.Odendi ? "table-success" : "")">
                                        <td>
                                            @(odeme.Aciklama?.Length > 40 ? odeme.Aciklama.Substring(0, 40) + "..." : odeme.Aciklama)
                                            @if (odeme.TaksitliMi)
                                            {
                                                <span class="badge bg-info ms-1" style="font-size:0.65rem;">Taksit</span>
                                            }
                                        </td>
                                        <td class="text-end">@FormatPara(odeme.Miktar)</td>
                                        <td class="text-end @(odeme.KalanTutar > 0 ? "text-warning fw-bold" : "text-success")">@FormatPara(odeme.KalanTutar)</td>
                                        <td class="text-center">@odeme.OdemeTarihi.ToString("dd.MM.yyyy")</td>
                                        <td class="text-center">
                                            <span class="badge @GetDurumBadgeClass(odeme.Durum)">@GetDurumAdi(odeme.Durum)</span>
                                        </td>
                                        <td class="text-center">
                                            @if (odeme.GecikmeGunu > 0)
                                            {
                                                <span class="text-danger fw-bold">@odeme.GecikmeGunu gün</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Aylık Trend -->
        @if (analiz.AylikTrendler.Any())
        {
            <div class="card mt-4">
                <div class="card-header bg-secondary text-white">
                    <i class="bi bi-graph-up me-2"></i>Aylık Risk Trendi
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Ay</th>
                                    <th class="text-end">Beklenen</th>
                                    <th class="text-end">Gerçekleşen</th>
                                    <th class="text-end">Geciken</th>
                                    <th class="text-center">Risk Skoru</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trend in analiz.AylikTrendler)
                                {
                                    <tr>
                                        <td>@trend.AyAdi</td>
                                        <td class="text-end">@FormatPara(trend.BeklenenOdeme)</td>
                                        <td class="text-end text-success">@FormatPara(trend.GerceklesenOdeme)</td>
                                        <td class="text-end text-danger">@FormatPara(trend.GecikenOdeme)</td>
                                        <td class="text-center">
                                            <span class="badge @GetRiskBadgeClassByScore(trend.RiskSkoru)">%@trend.RiskSkoru</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private BudgetRiskAnalizi? analiz;
    private List<Firma> firmalar = new();
    private int secilenYil = DateTime.Today.Year;
    private int? secilenAy;
    private int secilenFirmaId = 0;
    private bool isLoading = false;
    private string? secilenKategori;

    private static readonly string[] AyAdlari = { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", 
                                                   "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        var aktifFirma = FirmaService.GetAktifFirma();
        if (!aktifFirma.TumFirmalar && aktifFirma.FirmaId > 0)
            secilenFirmaId = aktifFirma.FirmaId;

        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            analiz = await BudgetService.GetRiskAnaliziAsync(
                secilenYil, 
                secilenAy, 
                secilenFirmaId > 0 ? secilenFirmaId : null);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetAyAdi(int ay) => ay >= 1 && ay <= 12 ? AyAdlari[ay] : "";

    private string FormatPara(decimal tutar) => tutar.ToString("N2") + " ₺";

    private string GetRiskCardClass(decimal skor) => skor switch
    {
        <= 20 => "bg-success text-white",
        <= 40 => "bg-info text-white",
        <= 60 => "bg-warning text-dark",
        _ => "bg-danger text-white"
    };

    private string GetRiskTextClass(decimal skor) => skor switch
    {
        <= 20 => "text-success",
        <= 40 => "text-info",
        <= 60 => "text-warning",
        _ => "text-danger"
    };

    private string GetRiskSeviyeAdi(decimal skor) => skor switch
    {
        <= 20 => "Düşük Risk",
        <= 40 => "Orta-Düşük Risk",
        <= 60 => "Orta-Yüksek Risk",
        _ => "Yüksek Risk"
    };

    private string GetRiskBadgeClass(string seviye) => seviye switch
    {
        "Normal" => "bg-success",
        "Orta" => "bg-warning text-dark",
        "Yüksek" => "bg-danger",
        "Kritik" => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetRiskBadgeClassByScore(decimal skor) => skor switch
    {
        <= 10 => "bg-success",
        <= 30 => "bg-info",
        <= 50 => "bg-warning text-dark",
        _ => "bg-danger"
    };

    private string GetProgressBarClass(decimal skor) => skor switch
    {
        <= 20 => "bg-success",
        <= 40 => "bg-info",
        <= 60 => "bg-warning",
        _ => "bg-danger"
    };

    private string GetDurumBadgeClass(OdemeDurum durum) => durum switch
    {
        OdemeDurum.Odendi => "bg-success",
        OdemeDurum.KismiOdendi => "bg-warning text-dark",
        OdemeDurum.Bekliyor => "bg-secondary",
        OdemeDurum.Iptal => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetDurumAdi(OdemeDurum durum) => durum switch
    {
        OdemeDurum.Odendi => "Ödendi",
        OdemeDurum.KismiOdendi => "Kısmi",
        OdemeDurum.Bekliyor => "Bekliyor",
        OdemeDurum.Iptal => "İptal",
        _ => durum.ToString()
    };

    private async Task ExcelAktar()
    {
        if (analiz == null) return;

        try
        {
            var csv = new System.Text.StringBuilder();
            csv.AppendLine("BÜTÇE RİSK ANALİZİ RAPORU");
            csv.AppendLine($"Tarih:;{analiz.AnalizTarihi:dd.MM.yyyy HH:mm}");
            csv.AppendLine($"Dönem:;{secilenYil} {(secilenAy.HasValue ? GetAyAdi(secilenAy.Value) : "Tüm Yıl")}");
            csv.AppendLine();

            csv.AppendLine("RİSK SKORLARI");
            csv.AppendLine($"Genel Risk Skoru:;%{analiz.GenelRiskSkoru}");
            csv.AppendLine($"Ödeme Gecikmesi Riski:;%{analiz.OdemeGecikmesiRiski}");
            csv.AppendLine($"Likidite Riski:;%{analiz.LikiditeRiski}");
            csv.AppendLine($"Bütçe Sapma Riski:;%{analiz.BudceSapmaRiski}");
            csv.AppendLine();

            csv.AppendLine("ÖZET BİLGİLER");
            csv.AppendLine($"Toplam Kayıt:;{analiz.ToplamKayit}");
            csv.AppendLine($"Toplam Bekleyen:;{analiz.ToplamBekleyen:N2} TL");
            csv.AppendLine($"Toplam Geciken:;{analiz.ToplamGeciken:N2} TL");
            csv.AppendLine($"Kısmi Ödenen:;{analiz.ToplamKismiOdenen:N2} TL");
            csv.AppendLine();

            if (analiz.RiskliOdemeler.Any())
            {
                csv.AppendLine("RİSKLİ ÖDEMELER");
                csv.AppendLine("Masraf Kalemi;Açıklama;Tutar;Kalan;Vade Tarihi;Gecikme Günü;Risk Seviyesi");
                foreach (var odeme in analiz.RiskliOdemeler)
                {
                    csv.AppendLine($"{odeme.MasrafKalemi};{odeme.Aciklama};{odeme.Tutar:N2};{odeme.KalanTutar:N2};{odeme.VadeTarihi:dd.MM.yyyy};{odeme.GecikmeGunu};{odeme.RiskSeviyesi}");
                }
                csv.AppendLine();
            }

            if (analiz.KategoriRiskleri.Any())
            {
                csv.AppendLine("KATEGORİ BAZLI RİSK");
                csv.AppendLine("Kategori;Toplam Tutar;Bekleyen;Geciken;Geciken Adet;Risk Skoru %");
                foreach (var kategori in analiz.KategoriRiskleri)
                {
                    csv.AppendLine($"{kategori.Kategori};{kategori.ToplamTutar:N2};{kategori.BekleyenTutar:N2};{kategori.GecikenTutar:N2};{kategori.GecikenKayit};{kategori.RiskSkoru}");
                }
            }

            var bytes = System.Text.Encoding.UTF8.GetBytes(csv.ToString());
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"ButceRiskAnalizi_{secilenYil}_{DateTime.Now:yyyyMMdd}.csv";

            await JS.InvokeVoidAsync("eval", $@"
                var a = document.createElement('a');
                a.href = 'data:text/csv;charset=utf-8;base64,{base64}';
                a.download = '{fileName}';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            ");

            ToastService.ShowSuccess("Excel dosyası indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task PdfAktar()
    {
        if (analiz == null) return;

        try
        {
            // PDF için yazdırma penceresini aç
            await JS.InvokeVoidAsync("eval", @"
                var printContents = document.querySelector('.container-fluid').innerHTML;
                var printWindow = window.open('', '_blank');
                printWindow.document.write('<html><head><title>Bütçe Risk Analizi</title>');
                printWindow.document.write('<link href=""https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"" rel=""stylesheet"">');
                printWindow.document.write('<link href=""https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"" rel=""stylesheet"">');
                printWindow.document.write('<style>@media print { .btn { display: none !important; } select { display: none !important; } }</style>');
                printWindow.document.write('</head><body class=""p-3"">');
                printWindow.document.write(printContents);
                printWindow.document.write('</body></html>');
                printWindow.document.close();
                setTimeout(function() { printWindow.print(); }, 500);
            ");

            ToastService.ShowInfo("PDF yazdırma penceresi açıldı");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }
}

