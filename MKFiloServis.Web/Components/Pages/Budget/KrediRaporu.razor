@page "/butce/kredi-raporu"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IBudgetService BudgetService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Kredi Taksit Raporu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-credit-card me-2"></i>Kredi Taksit Raporu</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 100px;" @bind="secilenYil" @bind:after="YenileDataAsync">
                @for (int y = DateTime.Today.Year + 2; y >= DateTime.Today.Year - 5; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select" style="width: 130px;" @bind="secilenAy" @bind:after="AylikListeYenile">
                <option value="0">Tum Aylar</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@GetAyAdi(m)</option>
                }
            </select>
            <a href="/butce" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left me-1"></i>Butce Analiz
            </a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Ozet Kartlari -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <h6 class="card-title">Aktif Kredi</h6>
                        <h3 class="mb-0">@aktifKrediler.Count</h3>
                        <small>devam eden taksitli odeme</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body">
                        <h6 class="card-title">Toplam Kalan Borc</h6>
                        <h3 class="mb-0">@FormatPara(aktifKrediler.Sum(k => k.KalanTutar))</h3>
                        <small>@aktifKrediler.Sum(k => k.KalanTaksitSayisi) taksit</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body">
                        <h6 class="card-title">@(secilenAy > 0 ? GetAyAdi(secilenAy) : "Bu Ay") Taksit</h6>
                        <h3 class="mb-0">@FormatPara(GetSecilenAyTaksit())</h3>
                        <small>@GetSecilenAyTaksitSayisi() adet</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body">
                        <h6 class="card-title">@secilenYil Odenen</h6>
                        <h3 class="mb-0">@FormatPara(aylikRapor.Sum(a => a.OdenenTutar))</h3>
                        <small>toplam odenen</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Sol: Aktif Krediler -->
            <div class="col-md-5">
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-credit-card-2-front me-2"></i>Aktif Krediler</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                            @foreach (var kredi in aktifKrediler)
                            {
                                <div class="list-group-item @(secilenKrediId == kredi.TaksitGrupId ? "active" : "")" 
                                     style="cursor: pointer;" @onclick="() => KrediSec(kredi)">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@kredi.MasrafKalemi</strong>
                                            @if (!string.IsNullOrEmpty(kredi.Aciklama))
                                            {
                                                <br /><small class="@(secilenKrediId == kredi.TaksitGrupId ? "" : "text-muted")">@kredi.Aciklama</small>
                                            }
                                            <br />
                                            <small class="@(secilenKrediId == kredi.TaksitGrupId ? "" : "text-muted")">
                                                @kredi.BaslangicTarihi.ToString("MM/yyyy") - @kredi.BitisTarihi.ToString("MM/yyyy")
                                            </small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-danger">@FormatPara(kredi.KalanTutar)</span>
                                            <br /><small>@kredi.KalanTaksitSayisi / @kredi.ToplamTaksitSayisi taksit</small>
                                        </div>
                                    </div>
                                    <div class="progress mt-2" style="height: 8px;">
                                        <div class="progress-bar bg-success" style="width: @kredi.TamamlanmaYuzdesi%"></div>
                                    </div>
                                </div>
                            }
                            @if (!aktifKrediler.Any())
                            {
                                <div class="list-group-item text-center text-muted py-4">
                                    <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Aktif kredi bulunmuyor</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sag: Ay/Yil Bazli Taksit Listesi -->
            <div class="col-md-7">
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">
                            <i class="bi bi-calendar3 me-2"></i>
                            @if (secilenAy > 0)
                            {
                                <text>@GetAyAdi(secilenAy) @secilenYil Taksitleri</text>
                            }
                            else
                            {
                                <text>@secilenYil Yili Tum Taksitler</text>
                            }
                            @if (secilenKrediId.HasValue)
                            {
                                <span class="badge bg-info ms-2">Filtrelendi</span>
                            }
                        </h6>
                        @if (secilenKrediId.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="FiltreTemizle">
                                <i class="bi bi-x-lg me-1"></i>Filtreyi Kaldir
                            </button>
                        }
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Kredi / Odeme</th>
                                        <th class="text-center">Taksit</th>
                                        <th class="text-end">Tutar</th>
                                        <th class="text-center">Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var taksit in filtrelenmisListe)
                                    {
                                        var gecikmisMi = (taksit.Durum == OdemeDurum.Bekliyor || taksit.Durum == OdemeDurum.KismiOdendi) && taksit.OdemeTarihi.Date < DateTime.Today;
                                        var bugunMu = taksit.OdemeTarihi.Date == DateTime.Today;
                                        <tr class="@(gecikmisMi ? "table-danger" : bugunMu ? "table-warning" : taksit.Durum == OdemeDurum.Odendi ? "table-success" : taksit.Durum == OdemeDurum.KismiOdendi ? "table-info" : "")">
                                            <td>
                                                <strong>@taksit.OdemeTarihi.ToString("dd.MM.yyyy")</strong>
                                                @if (gecikmisMi)
                                                {
                                                    <br /><span class="badge bg-danger">Gecikti</span>
                                                }
                                                else if (bugunMu)
                                                {
                                                    <br /><span class="badge bg-warning text-dark">Bugun</span>
                                                }
                                            </td>
                                            <td>
                                                <strong>@taksit.MasrafKalemi</strong>
                                                @if (!string.IsNullOrEmpty(taksit.Aciklama))
                                                {
                                                    <br /><small class="text-muted">@taksit.Aciklama</small>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary">@taksit.KacinciTaksit / @taksit.ToplamTaksitSayisi</span>
                                            </td>
                                            <td class="text-end"><strong>@FormatPara(GetGorunenTutar(taksit))</strong></td>
                                            <td class="text-center">
                                                <span class="badge @(taksit.Durum == OdemeDurum.Odendi ? "bg-success" : taksit.Durum == OdemeDurum.KismiOdendi ? "bg-info text-white" : "bg-warning text-dark")">
                                                    @(taksit.Durum == OdemeDurum.Odendi ? "Odendi" : taksit.Durum == OdemeDurum.KismiOdendi ? "Kısmi Ödendi" : "Bekliyor")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                    @if (!filtrelenmisListe.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center text-muted py-4">
                                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                                <p class="mb-0 mt-2">Bu donemde taksit bulunmuyor</p>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                @if (filtrelenmisListe.Any())
                                {
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="3"><strong>TOPLAM</strong></td>
                                            <td class="text-end"><strong>@FormatPara(filtrelenmisListe.Sum(GetGorunenTutar))</strong></td>
                                            <td class="text-center">
                                                <span class="badge bg-success">@filtrelenmisListe.Count(t => t.Durum == OdemeDurum.Odendi)</span>
                                                <span class="badge bg-info text-white">@filtrelenmisListe.Count(t => t.Durum == OdemeDurum.KismiOdendi)</span>
                                                <span class="badge bg-warning text-dark">@filtrelenmisListe.Count(t => t.Durum == OdemeDurum.Bekliyor)</span>
                                            </td>
                                        </tr>
                                    </tfoot>
                                }
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Aylik Ozet Grafigi -->
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>@secilenYil Aylik Taksit Ozeti</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ay</th>
                                        <th class="text-center">Adet</th>
                                        <th class="text-end">Toplam</th>
                                        <th class="text-end">Odenen</th>
                                        <th class="text-end">Bekleyen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ay in aylikRapor.Where(a => a.TaksitSayisi > 0))
                                    {
                                        var aktifMi = (secilenAy == 0 || secilenAy == ay.Ay);
                                        var buAyMi = ay.Ay == DateTime.Today.Month && secilenYil == DateTime.Today.Year;
                                        <tr class="@(buAyMi ? "table-primary" : "") @(!aktifMi ? "text-muted" : "")" 
                                            style="cursor: pointer;" @onclick="() => AySec(ay.Ay)">
                                            <td>
                                                <strong>@ay.AyAdi</strong>
                                                @if (buAyMi)
                                                {
                                                    <span class="badge bg-primary ms-1">Simdi</span>
                                                }
                                                @if (secilenAy == ay.Ay)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success ms-1"></i>
                                                }
                                            </td>
                                            <td class="text-center"><span class="badge bg-secondary">@ay.TaksitSayisi</span></td>
                                            <td class="text-end">@FormatPara(ay.ToplamTaksitTutari)</td>
                                            <td class="text-end text-success">@FormatPara(ay.OdenenTutar)</td>
                                            <td class="text-end text-warning">@FormatPara(ay.BekleyenTutar)</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td><strong>TOPLAM</strong></td>
                                        <td class="text-center"><strong>@aylikRapor.Sum(a => a.TaksitSayisi)</strong></td>
                                        <td class="text-end"><strong>@FormatPara(aylikRapor.Sum(a => a.ToplamTaksitTutari))</strong></td>
                                        <td class="text-end text-success"><strong>@FormatPara(aylikRapor.Sum(a => a.OdenenTutar))</strong></td>
                                        <td class="text-end text-warning"><strong>@FormatPara(aylikRapor.Sum(a => a.BekleyenTutar))</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private decimal GetGorunenTutar(KrediTaksitDetay taksit) => taksit.Durum == OdemeDurum.KismiOdendi ? taksit.KalanTutar : taksit.Tutar;
    private int secilenYil;
    private int secilenAy = 0;
    private bool isLoading = true;

    private List<KrediOzet> aktifKrediler = new();
    private List<AylikKrediTaksitRapor> aylikRapor = new();
    private List<KrediTaksitDetay> tumTaksitler = new();
    private List<KrediTaksitDetay> filtrelenmisListe = new();

    private Guid? secilenKrediId = null;

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    protected override async Task OnInitializedAsync()
    {
        secilenYil = DateTime.Today.Year;
        secilenAy = DateTime.Today.Month;
        await YenileDataAsync();
    }

    private async Task YenileDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            aktifKrediler = await BudgetService.GetAktifKredilerAsync();
            aylikRapor = await BudgetService.GetAylikKrediTaksitRaporuAsync(secilenYil);

            // Tum taksitleri topla
            tumTaksitler = aylikRapor
                .SelectMany(a => a.Taksitler)
                .OrderBy(t => t.OdemeTarihi)
                .ToList();

            AylikListeYenile();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void AylikListeYenile()
    {
        var liste = tumTaksitler.AsEnumerable();

        // Ay filtresi
        if (secilenAy > 0)
        {
            liste = liste.Where(t => t.OdemeTarihi.Month == secilenAy);
        }

        // Kredi filtresi
        if (secilenKrediId.HasValue)
        {
            var kredi = aktifKrediler.FirstOrDefault(k => k.TaksitGrupId == secilenKrediId);
            if (kredi != null)
            {
                liste = liste.Where(t => t.MasrafKalemi == kredi.MasrafKalemi && t.Aciklama == kredi.Aciklama);
            }
        }

        filtrelenmisListe = liste.OrderBy(t => t.OdemeTarihi).ToList();
        StateHasChanged();
    }

    private void KrediSec(KrediOzet kredi)
    {
        if (secilenKrediId == kredi.TaksitGrupId)
        {
            secilenKrediId = null;
        }
        else
        {
            secilenKrediId = kredi.TaksitGrupId;
        }
        AylikListeYenile();
    }

    private void AySec(int ay)
    {
        if (secilenAy == ay)
        {
            secilenAy = 0; // Tum aylar
        }
        else
        {
            secilenAy = ay;
        }
        AylikListeYenile();
    }

    private void FiltreTemizle()
    {
        secilenKrediId = null;
        AylikListeYenile();
    }

    private decimal GetSecilenAyTaksit()
    {
        var ay = secilenAy > 0 ? secilenAy : DateTime.Today.Month;
        var ayRapor = aylikRapor.FirstOrDefault(a => a.Ay == ay);
        return ayRapor?.ToplamTaksitTutari ?? 0;
    }

    private int GetSecilenAyTaksitSayisi()
    {
        var ay = secilenAy > 0 ? secilenAy : DateTime.Today.Month;
        var ayRapor = aylikRapor.FirstOrDefault(a => a.Ay == ay);
        return ayRapor?.TaksitSayisi ?? 0;
    }

    private string GetAyAdi(int ay) => AyAdlari[ay];

    private string FormatPara(decimal tutar)
    {
        return $"{tutar:N2} TL";
    }
}

