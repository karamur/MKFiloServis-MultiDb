    private async Task OdemeYapAsync()
    {
        if (odemeYapilacak == null) return;

        if (odemeYapRequest.OdemeTipi == BudgetOdemeTipi.CariMahsup)
        {
            if (!odemeYapRequest.CariId.HasValue || odemeYapRequest.CariId == 0)
            {
                ToastService.ShowWarning("Lütfen cari hesap seçin!");
                return;
            }

            if (!odemeYapRequest.BankaHesapId.HasValue || odemeYapRequest.BankaHesapId == 0)
            {
                ToastService.ShowWarning("Lütfen işlem yapılacak hesabı seçin!");
                return;
            }
        }
        else if (odemeYapRequest.OdemeTipi != BudgetOdemeTipi.Mahsup && !odemeYapRequest.BankaHesapId.HasValue)
        {
            ToastService.ShowWarning("Lütfen hesap seçin!");
            return;
        }

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            await BudgetService.OdemeYapAsync(odemeYapilacak.Id, odemeYapRequest);

            var mesaj = odemeYapRequest.OdemeTipi == BudgetOdemeTipi.CariMahsup
                ? $"{(odemeYapRequest.CaridenTahsilat ? "Cari mahsup tahsilat" : "Cari mahsup odeme")} kaydedildi! ({FormatPara(NetOdemeTutari)})"
                : $"{odemeYapilacak.MasrafKalemi} odendi! ({FormatPara(NetOdemeTutari)})";
            if (ToplamEkMasraf > 0)
                mesaj += $" - Ek Masraf: {FormatPara(ToplamEkMasraf)}";

            ToastService.ShowSuccess(mesaj);
            ModalKapat();
            hesapBakiyeleri = await BankaHesapService.GetTumHesapBakiyeleriAsync();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

