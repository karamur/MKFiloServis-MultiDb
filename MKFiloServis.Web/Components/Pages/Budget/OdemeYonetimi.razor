                    @if (IsFinansmanKalemi(editOdeme.MasrafKalemi))
                    {
                        <div class="mb-3">
                            <label class="form-label">Bağlı Banka / Kredi Kartı</label>
                            <select class="form-select" @bind="editOdeme.OdemeYapildigiHesapId">
                                <option value="">Secin...</option>
                                @if (bankaHesaplari != null)
                                {
                                    @foreach (var hesap in GetFinansHesaplari(editOdeme.MasrafKalemi))
                                    {
                                        <option value="@hesap.Id">@hesap.HesapAdi</option>
                                    }
                                }
                            </select>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Miktar *</label>
                        <div class="input-group">
                            <input type="number" class="form-control" @bind="editOdeme.Miktar" step="0.01" />
                            <span class="input-group-text">TL</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select class="form-select" @bind="editOdeme.Durum">
                            <option value="@OdemeDurum.Bekliyor">Bekliyor</option>
                            <option value="@OdemeDurum.Odendi">Odendi</option>
                            <option value="@OdemeDurum.Ertelendi">Ertelendi</option>
                            <option value="@OdemeDurum.Iptal">Iptal</option>
