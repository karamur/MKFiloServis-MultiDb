    private string BuildExportFileName(string extension)
    {
        var ayMetni = filtreAy > 0 ? $"_{filtreAy:D2}" : "_TumYil";
        return $"ButceOdemeleri_{filtreYil}{ayMetni}_{DateTime.Now:yyyyMMddHHmmss}.{extension}";
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            odemeler = await BudgetService.GetOdemelerAsync(filtreYil, filtreAy > 0 ? filtreAy : null);
            FiltreUygula();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FiltreUygula()
    {
        var query = odemeler.AsEnumerable();

        // Durum filtresi
        if (!string.IsNullOrEmpty(filtreDurum))
        {
            var durum = Enum.Parse<OdemeDurum>(filtreDurum);
            query = query.Where(o => o.Durum == durum);
        }

        // Tip filtresi
        if (filtreTip == "kredi")
            query = query.Where(o => o.TaksitliMi);
        else if (filtreTip == "normal")
            query = query.Where(o => !o.TaksitliMi);

        // Firma filtresi
        if (filtreFirmaId > 0)
            query = query.Where(o => o.FirmaId == filtreFirmaId || o.FirmaId == null);

        // Masraf Kalemi filtresi
        if (!string.IsNullOrWhiteSpace(filtreMasrafKalemi))
            query = query.Where(o => string.Equals(o.MasrafKalemi, filtreMasrafKalemi, StringComparison.OrdinalIgnoreCase));

        // Coklu Aciklama filtresi (OR mantığı: seçilen açıklamalardan herhangi biri)
        if (seciliAciklamalar.Any())
        {
            query = query.Where(o => !string.IsNullOrWhiteSpace(o.Aciklama)
                && seciliAciklamalar.Contains(o.Aciklama.Trim(), StringComparer.OrdinalIgnoreCase));
        }

        // Arama
        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            var aranan = aramaMetni.ToLower();
            query = query.Where(o => 
                (o.MasrafKalemi?.ToLower().Contains(aranan) ?? false) ||
                (o.Aciklama?.ToLower().Contains(aranan) ?? false));
        }

        filtrelenmisOdemeler = query.OrderBy(o => o.OdemeTarihi).ToList();
        StateHasChanged();
    }

