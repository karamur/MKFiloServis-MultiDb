                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="OdemeKaydetAsync">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Taksitli Odeme Modal -->
@if (showTaksitModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Taksitli Odeme</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Baslangic *</label>
                                        <input type="date" class="form-control" @bind="taksitRequest.BaslangicTarihi" @bind:after="TaksitListesiHesapla" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Sayisi *</label>
                                        <input type="number" class="form-control" @bind="taksitRequest.TaksitSayisi" min="2" max="60" @bind:after="TaksitListesiHesapla" />
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Masraf Kalemi *</label>
                                <input type="text" class="form-control" @bind="taksitRequest.MasrafKalemi" list="masrafList2" />
                                <datalist id="masrafList2">
                                    @if (masrafKalemleri != null)
                                    {
                                        @foreach (var k in masrafKalemleri)
                                        {
                                            <option value="@k.KalemAdi" />
                                        }
                                    }
                                </datalist>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Aciklama</label>
                                <input type="text" class="form-control" @bind="taksitRequest.Aciklama" />
                            </div>
                            @if (IsFinansmanKalemi(taksitRequest.MasrafKalemi))
                            {
                                <div class="mb-3">
                                    <label class="form-label">Banka / Kredi Kartı Eşleştirmesi</label>
                                    <select class="form-select" @bind="taksitRequest.BagliBankaHesapId">
                                        <option value="">Secin...</option>
                                        @if (bankaHesaplari != null)
                                        {
                                            @foreach (var hesap in GetFinansHesaplari(taksitRequest.MasrafKalemi))
                                            {
                                                <option value="@hesap.Id">@hesap.HesapAdi</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            <div class="mb-3">
                                <label class="form-label">Toplam Tutar *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="taksitRequest.ToplamTutar" step="0.01" @bind:after="TaksitListesiHesapla" />
                                    <span class="input-group-text">TL</span>
                                </div>
                            </div>
                            @if (IsKrediKalemi(taksitRequest.MasrafKalemi))
                            {
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Kredi Ana Para</label>
                                            <div class="input-group">
                                                <input type="number" class="form-control" @bind="taksitRequest.KrediAnaParaTutari" step="0.01" />
                                                <span class="input-group-text">TL</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Bankaya Yatan Net Tutar</label>
                                            <div class="input-group">
                                                <input type="number" class="form-control" @bind="taksitRequest.KrediNetGecenTutar" step="0.01" />
                                                <span class="input-group-text">TL</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Peşin Faiz</label>
                                            <div class="input-group">
                                                <input type="number" class="form-control" @bind="taksitRequest.PesinFaizTutari" step="0.01" />
                                                <span class="input-group-text">TL</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Peşin Masraf</label>
                                            <div class="input-group">
                                                <input type="number" class="form-control" @bind="taksitRequest.PesinMasrafTutari" step="0.01" />
                                                <span class="input-group-text">TL</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            @if (taksitRequest.TaksitSayisi > 1 && taksitListesi.Any())
                            {
                                var taksitToplam = taksitListesi.Sum(t => t.Tutar);
                                var fark = taksitRequest.ToplamTutar - taksitToplam;
                                var farkSifir = Math.Abs(fark) < 0.01m;
                                
                                <div class="card">
                                    <div class="card-header py-2 bg-info text-white d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0"><i class="bi bi-list-ol me-2"></i>Taksit Plani (@taksitListesi.Count Taksit)</h6>
                                        <button type="button" class="btn btn-sm btn-light" @onclick="TaksitListesiSifirla" title="Taksitleri Sifirla">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </div>
                                    <div class="card-body p-0" style="max-height: 280px; overflow-y: auto;">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th width="40">#</th>
                                                    <th>Tarih</th>
                                                    <th class="text-end">Tutar (TL)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var taksit in taksitListesi)
                                                {
                                                    <tr>
                                                        <td><span class="badge bg-secondary">@taksit.Sira</span></td>
                                                        <td>
                                                            <input type="date" class="form-control form-control-sm" 
                                                                   value="@taksit.Tarih.ToString("yyyy-MM-dd")" 
                                                                   @onchange="@(e => TaksitTarihDegistir(taksit, e))" />
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm text-end" 
                                                                   value="@taksit.Tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))"
                                                                   @onchange="@(e => TaksitTutarDegistir(taksit, e))" 
                                                                   style="width: 120px;" />
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="card-footer p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small class="text-muted">Taksit Toplami:</small>
                                                <strong class="ms-1">@taksitToplam.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) TL</strong>
                                            </div>
                                            <div>
                                                <small class="text-muted">Fark:</small>
                                                <strong class="ms-1 @(farkSifir ? "text-success" : "text-danger")">
                                                    @fark.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) TL
                                                    @if (farkSifir)
                                                    {
                                                        <i class="bi bi-check-circle-fill ms-1"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                                    }
                                                </strong>
                                            </div>
                                        </div>
                                        @if (!farkSifir)
                                        {
                                            <div class="alert alert-warning py-1 px-2 mt-2 mb-0" style="font-size: 11px;">
                                                <i class="bi bi-info-circle me-1"></i>
                                                Taksit toplamı ile toplam tutar eşit olmalı!
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info text-center mt-5">
                                    <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Taksit sayisi 2 veya daha fazla olduğunda taksit plani burada gorunecek</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TaksitliOdemeKaydetAsync" disabled="@(!TaksitKaydetmeGecerliMi())">
                        <i class="bi bi-check-lg me-1"></i>@(taksitRequest.TaksitSayisi > 1 ? $"{taksitRequest.TaksitSayisi} Taksit Olustur" : "Kaydet")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "odemeId")]
    public int? VurguOdemeId { get; set; }

    private int? sonVurgulananOdemeId;

    private string GetSatirClass(BudgetOdeme odeme)
    {
        var temel = odeme.Durum == OdemeDurum.Odendi ? "table-success"
            : odeme.Durum == OdemeDurum.KismiOdendi ? "table-warning"
            : odeme.Durum == OdemeDurum.Iptal ? "table-secondary"
            : "";
        if (VurguOdemeId.HasValue && odeme.Id == VurguOdemeId.Value)
        {
            temel += " border border-2 border-primary";
        }
        return temel;
    }

    private decimal GetBekleyenTutar(BudgetOdeme odeme) => odeme.Durum == OdemeDurum.KismiOdendi ? odeme.KalanTutar : odeme.Miktar;
    private decimal GetOdenenTutar(BudgetOdeme odeme) => odeme.Durum == OdemeDurum.KismiOdendi ? odeme.ToplamKismiOdenen : (odeme.OdenenTutar ?? odeme.Miktar);
    private decimal GetGorunenTutar(BudgetOdeme odeme) => odeme.Durum == OdemeDurum.KismiOdendi ? odeme.KalanTutar : odeme.Miktar;
    private bool isLoading = true;
    private List<BudgetOdeme> odemeler = new();
    private List<BudgetOdeme> filtrelenmisOdemeler = new();
    private List<BudgetMasrafKalemi>? masrafKalemleri;
    private List<BankaHesap>? bankaHesaplari;
    private Dictionary<int, decimal> hesapBakiyeleri = new();
    private List<Cari>? cariler;
    private bool isKaydediliyor = false;

    // Filtreler
    private int filtreYil = DateTime.Today.Year;
    private int filtreAy = DateTime.Today.Month;
    private string filtreDurum = "";
    private string filtreTip = "";
    private string aramaMetni = "";
    private int filtreFirmaId = 0;
    private string filtreMasrafKalemi = "";
    private const string TasimaTedarikciHakedisKalemi = "Taşıma Tedarikçi Hakediş";
    private List<Firma>? firmalar;
    private HashSet<string> seciliAciklamalar = new();
    private bool showAciklamaSecim = false;
    private string aciklamaArama = string.Empty;

    private List<string> TumAciklamalar => odemeler
        .Where(o => !string.IsNullOrWhiteSpace(o.Aciklama))
        .Select(o => o.Aciklama!.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private void AciklamaToggle(string aciklama, bool secili)
    {
        if (secili) seciliAciklamalar.Add(aciklama);
        else seciliAciklamalar.Remove(aciklama);
        FiltreUygula();
    }

    private void AciklamaTumunuSec()
    {
        foreach (var a in TumAciklamalar) seciliAciklamalar.Add(a);
        FiltreUygula();
    }

    private void AciklamaTumunuKaldir()
    {
        seciliAciklamalar.Clear();
        FiltreUygula();
    }

    // Modal degiskenleri
    private bool showOdemeModal = false;
    private bool showOdemeYapModal = false;
    private bool showTaksitModal = false;
    private BudgetOdeme editOdeme = new();
    private BudgetOdeme? odemeYapilacak;
    private OdemeYapRequest odemeYapRequest = new();
    private TaksitliOdemeRequest taksitRequest = new();

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    protected override async Task OnInitializedAsync()
    {
        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
        bankaHesaplari = await BankaHesapService.GetAllAsync();
        hesapBakiyeleri = await BankaHesapService.GetTumHesapBakiyeleriAsync();
        cariler = (await CariService.GetAllAsync()).Where(c => c.Aktif).OrderBy(c => c.Unvan).ToList();
        firmalar = (await FirmaService.GetAktifFirmalarAsync()).OrderBy(f => f.FirmaAdi).ToList();

        if (VurguOdemeId.HasValue)
        {
            var hedef = await BudgetService.GetOdemeByIdAsync(VurguOdemeId.Value);
            if (hedef != null)
            {
                filtreYil = hedef.OdemeYil;
                filtreAy = 0;
                filtreDurum = "";
                filtreTip = "";
                filtreFirmaId = 0;
                filtreMasrafKalemi = "";
                aramaMetni = "";
                seciliAciklamalar.Clear();
            }
        }

        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (VurguOdemeId.HasValue && VurguOdemeId.Value != sonVurgulananOdemeId &&
            filtrelenmisOdemeler.Any(o => o.Id == VurguOdemeId.Value))
        {
            sonVurgulananOdemeId = VurguOdemeId.Value;
            try
            {
                await JS.InvokeVoidAsync("scrollToElementById", $"odeme-row-{VurguOdemeId.Value}");
            }
            catch
            {
                // JS helper yoksa sessiz geç
            }
        }
    }

    private async Task ExportCsvAsync()
    {
        await ExportAsync("csv", "text/csv", data => Task.FromResult(DataExportService.ExportToCsv(data)));
    }

    private async Task ExportJsonAsync()
    {
        await ExportAsync("json", "application/json", data => Task.FromResult(DataExportService.ExportToJson(data)));
    }

    private async Task ExportParquetAsync()
    {
        await ExportAsync("parquet", "application/octet-stream", data => DataExportService.ExportToParquetAsync(data));
    }

    private async Task ExportAsync(string extension, string contentType, Func<List<OdemeExportSatiri>, Task<byte[]>> exporter)
    {
        try
        {
            var exportData = BuildExportRows();
            if (!exportData.Any())
            {
                ToastService.ShowWarning("Dışa aktarılacak kayıt bulunamadı.");
                return;
            }

            var bytes = await exporter(exportData);
            var fileName = BuildExportFileName(extension);
            await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(bytes), contentType);
            ToastService.ShowSuccess($"{extension.ToUpperInvariant()} dosyası indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"{extension.ToUpperInvariant()} export hatası: {ex.Message}");
        }
    }

    private List<OdemeExportSatiri> BuildExportRows()
    {
        return filtrelenmisOdemeler.Select(o => new OdemeExportSatiri
        {
            Id = o.Id,
            OdemeTarihi = o.OdemeTarihi,
            Yil = o.OdemeYil,
            Ay = o.OdemeAy,
            MasrafKalemi = o.MasrafKalemi,
            Aciklama = o.Aciklama,
            Miktar = o.Miktar,
            Durum = o.Durum.ToString(),
            TaksitliMi = o.TaksitliMi,
            KacinciTaksit = o.KacinciTaksit,
            ToplamTaksitSayisi = o.ToplamTaksitSayisi,
            OdenenTutar = o.OdenenTutar,
