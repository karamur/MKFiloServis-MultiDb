    private async Task OdemeKaydetAsync()
    {
        if (string.IsNullOrWhiteSpace(editOdeme.MasrafKalemi) || editOdeme.Miktar <= 0)
        {
            ToastService.ShowWarning("Masraf kalemi ve miktar zorunlu!");
            return;
        }

        if (IsFinansmanKalemi(editOdeme.MasrafKalemi) && !editOdeme.OdemeYapildigiHesapId.HasValue)
        {
            ToastService.ShowWarning("Finansman kalemleri için bağlı banka/kredi kartı seçin!");
            return;
        }

        try
        {
            editOdeme.Notlar = BuildFinansNotu(editOdeme.Notlar, editOdeme.OdemeYapildigiHesapId);

            if (editOdeme.Id > 0)
                await BudgetService.UpdateOdemeAsync(editOdeme);
            else
                await BudgetService.CreateOdemeAsync(editOdeme);

            ToastService.ShowSuccess("Kaydedildi.");
            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
