    private IEnumerable<BankaHesap> GetFiltrelenmisHesaplar()
    {
        if (bankaHesaplari == null) return Enumerable.Empty<BankaHesap>();

        return odemeYapRequest.OdemeTipi switch
        {
            BudgetOdemeTipi.Kasa => bankaHesaplari.Where(h => h.HesapTipi == HesapTipi.Kasa),
            BudgetOdemeTipi.KrediKarti => bankaHesaplari.Where(h => h.HesapTipi == HesapTipi.KrediKarti),
            _ => bankaHesaplari.Where(h => h.HesapTipi != HesapTipi.Kasa && h.HesapTipi != HesapTipi.KrediKarti)
        };
    }

    private IEnumerable<BankaHesap> GetFinansHesaplari(string? masrafKalemi)
    {
        if (bankaHesaplari == null)
            return Enumerable.Empty<BankaHesap>();

        if (IsKrediKartiKalemi(masrafKalemi))
            return bankaHesaplari.Where(h => h.HesapTipi == HesapTipi.KrediKarti);

        if (IsKrediKalemi(masrafKalemi))
            return bankaHesaplari.Where(h => h.HesapTipi == HesapTipi.KrediHesabi || h.HesapTipi == HesapTipi.VadesizHesap || h.HesapTipi == HesapTipi.VadeliHesap);

        return bankaHesaplari;
    }

    private static bool IsKrediKalemi(string? masrafKalemi)
        => !string.IsNullOrWhiteSpace(masrafKalemi)
           && (masrafKalemi.Contains("Banka Kredisi", StringComparison.OrdinalIgnoreCase)
               || masrafKalemi.Contains("Araç Kredisi", StringComparison.OrdinalIgnoreCase)
               || masrafKalemi.Contains("Arac Kredisi", StringComparison.OrdinalIgnoreCase));

    private static bool IsKrediKartiKalemi(string? masrafKalemi)
        => !string.IsNullOrWhiteSpace(masrafKalemi)
           && masrafKalemi.Contains("Kredi Kartı", StringComparison.OrdinalIgnoreCase);

    private static bool IsFinansmanKalemi(string? masrafKalemi)
        => IsKrediKalemi(masrafKalemi) || IsKrediKartiKalemi(masrafKalemi);

    private static string? BuildFinansNotu(string? notlar, int? bagliHesapId)
    {
        if (!bagliHesapId.HasValue)
            return notlar;

        var yeniSatir = $"[FinansKaynakHesapId:{bagliHesapId.Value}]";
        var satirlar = string.IsNullOrWhiteSpace(notlar)
            ? new List<string>()
            : notlar.Split('\n', StringSplitOptions.RemoveEmptyEntries)
                .Where(x => !x.StartsWith("[FinansKaynakHesapId:", StringComparison.OrdinalIgnoreCase))
                .ToList();
        satirlar.Add(yeniSatir);
        return string.Join("\n", satirlar);
    }

    private IEnumerable<BankaHesap> GetCariMahsupHesaplar()
    {
        if (bankaHesaplari == null) return Enumerable.Empty<BankaHesap>();

        return bankaHesaplari.Where(h => h.HesapTipi != HesapTipi.KrediKarti);
    }

    private void CariMahsupHesapDegisti()
    {
        if (!odemeYapRequest.BankaHesapId.HasValue || bankaHesaplari == null)
            return;

        var seciliHesap = bankaHesaplari.FirstOrDefault(h => h.Id == odemeYapRequest.BankaHesapId.Value);
        if (seciliHesap == null)
            return;

        odemeYapRequest.MuhasebeHesapKodu = seciliHesap.VarsayilanMuhasebeKodu ?? string.Empty;
        odemeYapRequest.KostMerkeziKodu = seciliHesap.VarsayilanKostMerkezi ?? string.Empty;
    }

    private decimal ToplamEkMasraf => Math.Abs(odemeYapRequest.MasrafKesintisi) + Math.Abs(odemeYapRequest.CezaKesintisi) + Math.Abs(odemeYapRequest.DigerKesinti);
    private decimal NetOdemeTutari => (odemeYapilacak?.Miktar ?? 0) + ToplamEkMasraf;

    private string GetAyAdi(int ay) => AyAdlari[ay];
    private string GetDurumAdi(BudgetOdeme o) 
    { 
        if (o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi) 
        { 
            var gun = (o.OdemeTarihi.Date - DateTime.Today).Days; 
            if(gun < 0) return $"{-gun} Gün Gecikti"; 
            if(gun == 0) return "Bugün Son"; 
            return $"{gun} Gün Kaldı"; 
        } 
        return o.Durum switch
        {
            OdemeDurum.Odendi => "Ödendi",
            OdemeDurum.KismiOdendi => "Kısmi Ödendi",
            OdemeDurum.Ertelendi => "Ertelendi",
            OdemeDurum.Iptal => "İptal",
            _ => o.Durum.ToString()
        };
    }

    private string GetDurumClass(BudgetOdeme o) 
    { 
        if (o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi) 
        { 
            var gun = (o.OdemeTarihi.Date - DateTime.Today).Days; 
            if(gun < 0) return "bg-danger text-white"; 
            if(gun == 0) return "bg-warning text-dark"; 
            return o.Durum == OdemeDurum.KismiOdendi ? "bg-warning text-dark" : "bg-info text-white"; 
        } 
        return o.Durum switch
        {
            OdemeDurum.Odendi => "bg-success text-white",
            OdemeDurum.KismiOdendi => "bg-warning text-dark",
            OdemeDurum.Ertelendi => "bg-secondary",
            OdemeDurum.Iptal => "bg-danger",
            _ => "bg-light text-dark"
        };
    }
    private string FormatPara(decimal t) => t.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " TL";

    // Taksit Planlama Islemleri
    private List<TaksitBilgisi> taksitListesi = new();

    private void TaksitListesiHesapla()
    {
        taksitListesi.Clear();

        if (taksitRequest.TaksitSayisi <= 1 || taksitRequest.ToplamTutar <= 0)
            return;

        var ilkOdemeTarihi = taksitRequest.BaslangicTarihi;
        var taksitTutari = Math.Round(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi, 2);

        for (int i = 0; i < taksitRequest.TaksitSayisi; i++)
        {
            taksitListesi.Add(new TaksitBilgisi
            {
                Sira = i + 1,
                Tarih = ilkOdemeTarihi.AddMonths(i),
                Tutar = taksitTutari
            });
        }

        // Son taksitte yuvarlama farkini duzelt (toplam tam tutsun)
        var fark = taksitRequest.ToplamTutar - taksitListesi.Sum(t => t.Tutar);
        if (fark != 0 && taksitListesi.Any())
        {
            taksitListesi.Last().Tutar += fark;
        }
    }

    private void TaksitListesiSifirla()
    {
        taksitListesi.Clear();
        TaksitListesiHesapla();
        StateHasChanged();
    }

    private void TaksitTarihDegistir(TaksitBilgisi taksit, ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var yeniTarih))
        {
            taksit.Tarih = yeniTarih;
            StateHasChanged();
        }
    }

    private void TaksitTutarDegistir(TaksitBilgisi taksit, ChangeEventArgs e)
    {
        var valueStr = e.Value?.ToString() ?? "0";
        if (decimal.TryParse(valueStr, System.Globalization.NumberStyles.Any, 
            new System.Globalization.CultureInfo("tr-TR"), out var yeniTutar) && yeniTutar >= 0)
        {
            taksit.Tutar = yeniTutar;
            StateHasChanged();
        }
    }

    private bool TaksitKaydetmeGecerliMi()
    {
        if (taksitRequest.TaksitSayisi < 1 || taksitRequest.ToplamTutar <= 0)
            return false;

        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi))
            return false;

        if (!taksitListesi.Any())
            return false;

        // Fark kontrolu - 0.01 TL tolerans
        var taksitToplam = taksitListesi.Sum(t => t.Tutar);
        var fark = Math.Abs(taksitRequest.ToplamTutar - taksitToplam);
        
        return fark < 0.01m;
    }

