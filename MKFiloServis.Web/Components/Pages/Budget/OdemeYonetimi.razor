@page "/butce/odemeler"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject IBudgetService BudgetService
@inject IBankaHesapService BankaHesapService
@inject ICariService CariService
@inject IFirmaService FirmaService
@inject IDataExportService DataExportService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Odeme Yonetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-credit-card me-2"></i>Odeme Yonetimi</h3>
            <p class="text-muted mb-0">Tum odemeleri goruntule, duzenle ve yonet</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="ExportCsvAsync" disabled="@(isLoading || !filtrelenmisOdemeler.Any())">
                <i class="bi bi-filetype-csv me-1"></i>CSV
            </button>
            <button class="btn btn-outline-secondary" @onclick="ExportJsonAsync" disabled="@(isLoading || !filtrelenmisOdemeler.Any())">
                <i class="bi bi-filetype-json me-1"></i>JSON
            </button>
            <button class="btn btn-outline-secondary" @onclick="ExportParquetAsync" disabled="@(isLoading || !filtrelenmisOdemeler.Any())">
                <i class="bi bi-file-earmark-binary me-1"></i>Parquet
            </button>
            <button class="btn btn-primary" @onclick="YeniOdemeAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni Odeme
            </button>
            <button class="btn btn-success" @onclick="TaksitliOdemeAc">
                <i class="bi bi-calendar-plus me-1"></i>Taksitli Odeme
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreYil">
                        @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 3; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreAy">
                        <option value="0">Tum Yil</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tum Durumlar</option>
                        <option value="Bekliyor">Bekliyor</option>
                        <option value="Odendi">Odendi</option>
                        <option value="Ertelendi">Ertelendi</option>
                        <option value="Iptal">Iptal</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreTip">
                        <option value="">Tum Tipler</option>
                        <option value="kredi">Kredi/Taksit</option>
                        <option value="normal">Normal</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="text" class="form-control form-control-sm" placeholder="Ara..." 
                           @bind="aramaMetni" @onkeypress="@(async (e) => await AramaKeyPress(e))" />
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreFirmaId">
                        <option value="0">Tum Firmalar</option>
                        @if (firmalar != null)
                        {
                            @foreach (var f in firmalar)
                            {
                                <option value="@f.Id">@f.FirmaAdi</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreMasrafKalemi" @bind:after="FiltreUygula">
                        <option value="">Tum Masraf Kalemleri</option>
                        @if (masrafKalemleri != null)
                        {
                            @foreach (var k in masrafKalemleri.OrderBy(x => x.KalemAdi))
                            {
                                <option value="@k.KalemAdi">@k.KalemAdi</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 position-relative">
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100 d-flex justify-content-between align-items-center"
                            @onclick="() => showAciklamaSecim = !showAciklamaSecim">
                        <span>
                            @if (seciliAciklamalar.Any())
                            {
                                <i class="bi bi-chat-square-text me-1"></i>
                                <span>@seciliAciklamalar.Count seçili açıklama</span>
                            }
                            else
                            {
                                <span><i class="bi bi-chat-square-text me-1"></i>Açıklama Seç</span>
                            }
                        </span>
                        <i class="bi @(showAciklamaSecim ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                    @if (showAciklamaSecim)
                    {
                        <div class="position-absolute bg-white border rounded shadow p-2 mt-1" style="z-index:1050; max-height:300px; overflow-y:auto; width:100%; min-width:260px;">
                            <input type="text" class="form-control form-control-sm mb-2" placeholder="Filtrele..."
                                   @bind="aciklamaArama" @bind:event="oninput" />
                            <div class="d-flex justify-content-between mb-1 small">
                                <button type="button" class="btn btn-link btn-sm p-0" @onclick="AciklamaTumunuSec">Tümünü Seç</button>
                                <button type="button" class="btn btn-link btn-sm p-0 text-danger" @onclick="AciklamaTumunuKaldir">Temizle</button>
                            </div>
                            @foreach (var a in TumAciklamalar.Where(x => string.IsNullOrEmpty(aciklamaArama) || x.Contains(aciklamaArama, StringComparison.OrdinalIgnoreCase)))
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="acik_@a.GetHashCode()"
                                           checked="@seciliAciklamalar.Contains(a)"
                                           @onchange="(e) => AciklamaToggle(a, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label small" for="acik_@a.GetHashCode()">@a</label>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="col-md-2 d-flex gap-2 justify-content-end">
                    <button class="btn btn-primary btn-sm" @onclick="@(async () => await LoadDataAsync())">
                        <i class="bi bi-search me-1"></i>Ara
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="@(async () => await FiltreTemizle())" title="Filtreleri Temizle">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <span class="badge bg-secondary align-self-center">@filtrelenmisOdemeler.Count</span>
                </div>
            </div>
            <div class="row g-2 mt-1">
                <div class="col-12 d-flex flex-wrap gap-2 align-items-center">
                    <small class="text-muted">Hızlı Filtre:</small>
                    <button type="button"
                            class="btn btn-sm @(filtreMasrafKalemi == TasimaTedarikciHakedisKalemi ? "btn-warning" : "btn-outline-warning")"
                            @onclick="TasimaTedarikciHakedisFiltresiToggle">
                        <i class="bi bi-truck me-1"></i>Taşıma Tedarikçi Hakediş
                        @if (filtreMasrafKalemi == TasimaTedarikciHakedisKalemi)
                        {
                            <span class="badge bg-light text-dark ms-1">@filtrelenmisOdemeler.Count</span>
                        }
                    </button>
                    <a href="/rapor/tasima-tedarikci" class="btn btn-sm btn-outline-info" title="Taşıma Tedarikçi Raporuna git">
                        <i class="bi bi-graph-up me-1"></i>Tedarikçi Raporu
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Ozet Kartlar -->
    <div class="row mb-3 g-2">
        <div class="col-6 col-md-2">
            <div class="card bg-primary text-white">
                <div class="card-body py-2 px-3">
                    <small>Toplam</small>
                    <h5 class="mb-0">@FormatPara(filtrelenmisOdemeler.Sum(o => o.Miktar))</h5>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card bg-warning text-dark">
                <div class="card-body py-2 px-3">
                    <small>Bekleyen</small>
                    <h5 class="mb-0">@FormatPara(filtrelenmisOdemeler.Where(o => o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi).Sum(GetBekleyenTutar))</h5>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card bg-info text-white">
                <div class="card-body py-2 px-3">
                    <small>Kısmi Ödenen</small>
                    <h5 class="mb-0">@FormatPara(filtrelenmisOdemeler.Where(o => o.Durum == OdemeDurum.KismiOdendi).Sum(o => o.ToplamKismiOdenen))</h5>
                    <small>@filtrelenmisOdemeler.Count(o => o.Durum == OdemeDurum.KismiOdendi) kayıt</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card bg-success text-white">
                <div class="card-body py-2 px-3">
                    <small>Odenen</small>
                    <h5 class="mb-0">@FormatPara(filtrelenmisOdemeler.Where(o => o.Durum == OdemeDurum.Odendi || o.Durum == OdemeDurum.KismiOdendi).Sum(GetOdenenTutar))</h5>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card bg-secondary text-white">
                <div class="card-body py-2 px-3">
                    <small>Kredi/Taksit</small>
                    <h5 class="mb-0">@FormatPara(filtrelenmisOdemeler.Where(o => o.TaksitliMi).Sum(o => o.Miktar))</h5>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card bg-danger text-white">
                <div class="card-body py-2 px-3">
                    <small>Kalan (Kısmi)</small>
                    <h5 class="mb-0">@FormatPara(filtrelenmisOdemeler.Where(o => o.Durum == OdemeDurum.KismiOdendi).Sum(o => o.Miktar - o.ToplamKismiOdenen))</h5>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Tarih</th>
                                <th>Masraf Kalemi</th>
                                <th>Aciklama</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">Taksit</th>
                                <th class="text-center" style="width: 180px;">Islemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var odeme in filtrelenmisOdemeler)
                            {
                                <tr id="odeme-row-@odeme.Id" class="@GetSatirClass(odeme)">
                                    <td>@odeme.OdemeTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <strong>@odeme.MasrafKalemi</strong>
                                        @if (string.Equals(odeme.MasrafKalemi, TasimaTedarikciHakedisKalemi, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-warning text-dark ms-1" title="Taşıma Tedarikçi Hakediş">
                                                <i class="bi bi-truck"></i>
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <small>@(odeme.Aciklama ?? "-")</small>
                                        @if (!string.IsNullOrWhiteSpace(odeme.HareketKaynakGorunumu))
                                        {
                                            <div class="mt-1">
                                                <small class="text-muted">İz: <strong>@odeme.HareketKaynakGorunumu</strong></small>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(odeme.HareketCariUnvani))
                                        {
                                            <div>
                                                <small class="text-muted">Cari: @odeme.HareketCariUnvani</small>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(odeme.HareketYonGorunumu))
                                        {
                                            <div>
                                                <small class="text-muted">Yön: @odeme.HareketYonGorunumu</small>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(odeme.HareketBelgeNo))
                                        {
                                            <div>
                                                <small class="text-muted">Belge No: @odeme.HareketBelgeNo</small>
                                            </div>
                                        }
                                        @if (odeme.OdemeYapildigiHesap != null)
                                        {
                                            <div>
                                                <small class="text-muted">Bağlı Hesap: @odeme.OdemeYapildigiHesap.HesapAdi</small>
                                            </div>
                                        }
                                        @if (odeme.BankaKasaHareketId.HasValue)
                                        {
                                            <div>
                                                <small class="text-muted">Hareket #: @odeme.BankaKasaHareketId</small>
                                            </div>
                                        }
                                        @if (odeme.OncekiDonemOdemeId.HasValue)
                                        {
                                            <div>
                                                <span class="badge bg-secondary"><i class="bi bi-arrow-left-circle me-1"></i>Önceki dönemden devir</span>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <strong>@FormatPara(GetGorunenTutar(odeme))</strong>
                                        @if (odeme.KismiOdemeMi && odeme.ToplamKismiOdenen > 0)
                                        {
                                            <br/>
                                            <small class="text-success">Ödenen: @FormatPara(odeme.ToplamKismiOdenen)</small>
                                            <br/>
                                            <small class="text-warning fw-bold">Kalan: @FormatPara(odeme.Miktar - odeme.ToplamKismiOdenen)</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetDurumClass(odeme)">@GetDurumAdi(odeme)</span>
                                        @if (odeme.Durum == OdemeDurum.KismiOdendi)
                                        {
                                            <div class="mt-1">
                                                <small class="text-warning">%@odeme.OdemeYuzdesi</small>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (odeme.TaksitliMi)
                                        {
                                            <span class="badge bg-info">@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => OdemeDuzenle(odeme)" title="Duzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            @if (odeme.Durum == OdemeDurum.Bekliyor || odeme.Durum == OdemeDurum.KismiOdendi)
                                            {
                                                <button class="btn btn-success" @onclick="() => OdemeYapModalAc(odeme)" title="Odeme Yap">
                                                    <i class="bi bi-cash"></i>
                                                </button>
                                            }
                                            @if (odeme.Durum == OdemeDurum.Odendi)
                                            {
                                                <button class="btn btn-outline-warning" @onclick="() => OdemeGeriAl(odeme)" title="Odeme Geri Al">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger" @onclick="() => OdemeSilOnay(odeme)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Odeme Yap Modal -->
@if (showOdemeYapModal && odemeYapilacak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Odeme Yap</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@odemeYapilacak.MasrafKalemi</strong><br />
                                <small>@odemeYapilacak.Aciklama</small>
                            </div>
                            <div class="text-end">
                                <small class="text-muted">Tutar:</small><br/>
                                <strong class="text-danger fs-5">@FormatPara(odemeYapilacak.Miktar)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Odeme Sekli *</label>
                            <div class="btn-group w-100 flex-wrap">
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == BudgetOdemeTipi.Kasa ? "btn-success" : "btn-outline-success")" 
                                        @onclick="() => OdemeTipiDegisti(MKFiloServis.Shared.Entities.BudgetOdemeTipi.Kasa)">
                                    <i class="bi bi-cash-stack me-1"></i>Kasa
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == BudgetOdemeTipi.Banka ? "btn-primary" : "btn-outline-primary")" 
                                        @onclick="() => OdemeTipiDegisti(MKFiloServis.Shared.Entities.BudgetOdemeTipi.Banka)">
                                    <i class="bi bi-bank me-1"></i>Banka
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == BudgetOdemeTipi.KrediKarti ? "btn-danger" : "btn-outline-danger")" 
                                        @onclick="() => OdemeTipiDegisti(MKFiloServis.Shared.Entities.BudgetOdemeTipi.KrediKarti)">
                                    <i class="bi bi-credit-card me-1"></i>Kredi Karti
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == BudgetOdemeTipi.Mahsup ? "btn-secondary" : "btn-outline-secondary")" 
                                        @onclick="() => OdemeTipiDegisti(MKFiloServis.Shared.Entities.BudgetOdemeTipi.Mahsup)">
                                    <i class="bi bi-arrow-left-right me-1"></i>Hesap Mahsup
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == BudgetOdemeTipi.CariMahsup ? "btn-warning" : "btn-outline-warning")" 
                                        @onclick="() => OdemeTipiDegisti(MKFiloServis.Shared.Entities.BudgetOdemeTipi.CariMahsup)">
                                    <i class="bi bi-person-lines-fill me-1"></i>Cari Mahsup
                                </button>
                            </div>
                        </div>

                        @if (odemeYapRequest.OdemeTipi == BudgetOdemeTipi.CariMahsup)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Cari Hesap *</label>
                                <select class="form-select" @bind="odemeYapRequest.CariId">
                                    <option value="">Secin...</option>
                                    @if (cariler != null)
                                    {
                                        @foreach (var cari in cariler)
                                        {
                                            <option value="@cari.Id">@cari.CariKodu - @cari.Unvan</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Hesap *</label>
                                <select class="form-select" @bind="odemeYapRequest.BankaHesapId" @bind:after="CariMahsupHesapDegisti">
                                    <option value="">Secin...</option>
                                    @foreach (var hesap in GetCariMahsupHesaplar())
                                    {
                                        var bakiye = hesapBakiyeleri.GetValueOrDefault(hesap.Id, 0);
                                        <option value="@hesap.Id">@hesap.HesapAdi (@FormatPara(bakiye))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Islem Yonu</label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="cariMahsupYon" id="cariOdemeYon" checked="@(!odemeYapRequest.CaridenTahsilat)" @onchange="() => odemeYapRequest.CaridenTahsilat = false" />
                                    <label class="btn btn-outline-danger" for="cariOdemeYon">
                                        <i class="bi bi-arrow-up-circle me-1"></i>Odeme (Hesap → Cari)
                                    </label>
                                    <input type="radio" class="btn-check" name="cariMahsupYon" id="cariTahsilatYon" checked="@odemeYapRequest.CaridenTahsilat" @onchange="() => odemeYapRequest.CaridenTahsilat = true" />
                                    <label class="btn btn-outline-success" for="cariTahsilatYon">
                                        <i class="bi bi-arrow-down-circle me-1"></i>Tahsilat (Cari → Hesap)
                                    </label>
                                </div>
                                <div class="alert alert-light border mt-2 mb-0 py-2 small">
                                    <i class="bi bi-info-circle me-1 text-primary"></i>
                                    @(odemeYapRequest.CaridenTahsilat
                                        ? "Cari hesaptan secilen kasa/banka hesabina tahsilat kaydi olusur."
                                        : "Secilen kasa/banka hesabindan cari hesaba odeme kaydi olusur.")
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Odeme Tarihi *</label>
                                <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                            </div>
                            <div class="col-12">
                                <div class="card bg-light border">
                                    <div class="card-header py-2">
                                        <i class="bi bi-journal-code me-1"></i>Muhasebe Eslestirme
                                    </div>
                                    <div class="card-body py-2">
                                        <div class="row g-2">
                                            <div class="col-md-4">
                                                <label class="form-label small">Muhasebe Hesap Kodu</label>
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.MuhasebeHesapKodu" placeholder="Orn: 320" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Kost Merkezi</label>
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.KostMerkeziKodu" placeholder="Masraf merkezi" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Proje Kodu</label>
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.ProjeKodu" placeholder="Proje" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (odemeYapRequest.OdemeTipi != BudgetOdemeTipi.Mahsup)
                        {
                            <div class="col-md-6">
                                <label class="form-label">@GetHesapLabel() *</label>
                                <select class="form-select" @bind="odemeYapRequest.BankaHesapId">
                                    <option value="">Secin...</option>
                                    @foreach (var hesap in GetFiltrelenmisHesaplar())
                                    {
                                        var bakiye = hesapBakiyeleri.GetValueOrDefault(hesap.Id, 0);
                                        <option value="@hesap.Id">@hesap.HesapAdi (@FormatPara(bakiye))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Odeme Tarihi *</label>
                                <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <label class="form-label">Odeme Tarihi *</label>
                                <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                            </div>
                        }

                        <div class="col-12">
                            <div class="card bg-light">
                                <div class="card-header py-2">
                                    <i class="bi bi-plus-circle me-1"></i>Ek Masraflar (Tutara Eklenir)
                                </div>
                                <div class="card-body py-2">
                                    <div class="row g-2">
                                        <div class="col-md-4">
                                            <label class="form-label small">Masraf/Komisyon</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control" @bind="odemeYapRequest.MasrafKesintisi" step="0.01" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small">Ceza/Faiz</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control" @bind="odemeYapRequest.CezaKesintisi" step="0.01" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small">Diger Ek Masraf</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control" @bind="odemeYapRequest.DigerKesinti" step="0.01" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                        </div>
                                        @if (ToplamEkMasraf != 0)
                                        {
                                            <div class="col-12">
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.KesintiAciklamasi" placeholder="Ek masraf aciklamasi..." />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Not</label>
                            <input type="text" class="form-control" @bind="odemeYapRequest.OdemeNotu" placeholder="Odeme notu..." />
                        </div>
                    </div>

                    <div class="card mt-3 @(ToplamEkMasraf != 0 ? "border-warning" : "border-success")">
                        <div class="card-body py-2">
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Tutar:</small>
                                    <div class="fs-5">@FormatPara(odemeYapilacak.Miktar)</div>
                                </div>
                                @if (ToplamEkMasraf != 0)
                                {
                                    <div class="col-3 text-center">
                                        <small class="text-muted">Ek Masraf:</small>
                                        <div class="text-primary">+@FormatPara(ToplamEkMasraf)</div>
                                    </div>
                                }
                                <div class="col text-end">
                                    <small class="text-muted">Net Odeme:</small>
                                    <div class="fs-4 fw-bold text-success">@FormatPara(NetOdemeTutari)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-success" @onclick="OdemeYapAsync" disabled="@isKaydediliyor">
                        @if (isKaydediliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Odemeyi Tamamla (@FormatPara(NetOdemeTutari))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni/Duzenle Odeme Modal -->
@if (showOdemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editOdeme.Id > 0 ? "Odeme Duzenle" : "Yeni Odeme")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
