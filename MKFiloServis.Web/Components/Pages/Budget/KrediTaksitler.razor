                                <label class="form-label">Taksit Durumu</label>
                                <div class="d-flex gap-2">
                                    <span class="badge bg-success fs-6">@secilenKrediDuzenleme.OdenenTaksitSayisi Ödendi</span>
                                    <span class="badge bg-warning text-dark fs-6">@(secilenKrediDuzenleme.ToplamTaksitSayisi - secilenKrediDuzenleme.OdenenTaksitSayisi) Bekliyor</span>
                                </div>
                                <div class="progress mt-2" style="height: 20px;">
                                    <div class="progress-bar bg-success" style="width: @secilenKrediDuzenleme.TamamlanmaYuzdesi%">
                                        %@secilenKrediDuzenleme.TamamlanmaYuzdesi.ToString("0")
                                    </div>
                                </div>
                            </div>
                            <div class="alert alert-info py-2 small mb-0">
                                <i class="bi bi-calendar me-1"></i>
                                @secilenKrediDuzenleme.BaslangicTarihi.ToString("dd.MM.yyyy") - @secilenKrediDuzenleme.BitisTarihi.ToString("dd.MM.yyyy")
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-danger">
                                <div class="card-header bg-danger text-white py-2">
                                    <i class="bi bi-exclamation-triangle me-2"></i>Silme İşlemleri
                                </div>
                                <div class="card-body">
                                    @if (secilenKrediDuzenleme.OdenenTaksitSayisi == 0)
                                    {
                                        <div class="alert alert-warning py-2 small">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Hiç ödeme yapılmamış. Tüm krediyi silebilirsiniz.
                                        </div>
                                        <button type="button" class="btn btn-danger w-100" @onclick="TumKrediSilOnay" disabled="@isSaving">
                                            <i class="bi bi-trash me-1"></i>Tüm Krediyi Sil (@secilenKrediDuzenleme.ToplamTaksitSayisi taksit)
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="alert alert-info py-2 small">
                                            <i class="bi bi-info-circle me-1"></i>
                                            @secilenKrediDuzenleme.OdenenTaksitSayisi taksit ödenmiş. Sadece bekleyen taksitleri silebilirsiniz.
                                        </div>
                                        <button type="button" class="btn btn-outline-danger w-100 mb-2" @onclick="BekleyenTaksitlariSilOnay" disabled="@isSaving">
                                            <i class="bi bi-trash me-1"></i>Bekleyen Taksitleri Sil (@(secilenKrediDuzenleme.ToplamTaksitSayisi - secilenKrediDuzenleme.OdenenTaksitSayisi) adet)
                                        </button>
                                        <small class="text-muted d-block text-center">Ödenen taksitler silinmez</small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

