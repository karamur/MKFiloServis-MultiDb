    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            tumKrediler = await BudgetService.GetKrediOzetleriAsync(secilenYil > 0 ? secilenYil : null);
            krediler = await FiltrelenmisKredileriGetirAsync(tumKrediler);
            // Tekrarlayan ödemeler pasif edildi
            // tekrarlayanOdemeler = await BudgetService.GetTekrarlayanOdemelerAsync(null);
            tekrarlayanOdemeler = new List<TekrarlayanOdeme>();

            if (krediler.Any() && (secilenKredi == null || !krediler.Any(k => k.TaksitGrupId == secilenKredi.TaksitGrupId)))
            {
                await KrediSec(krediler.First());
            }
            else if (secilenKredi != null)
            {
                var guncel = krediler.FirstOrDefault(k => k.TaksitGrupId == secilenKredi.TaksitGrupId);
                if (guncel != null)
                {
                    await KrediSec(guncel);
                }
                else
                {
                    secilenKredi = null;
                    secilenKrediTaksitler = new();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<List<KrediOzet>> FiltrelenmisKredileriGetirAsync(IEnumerable<KrediOzet> kaynakKrediler)
    {
        var filtrelenmisKrediler = kaynakKrediler;

        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            filtrelenmisKrediler = filtrelenmisKrediler.Where(k =>
                k.MasrafKalemi.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(k.Aciklama) && k.Aciklama.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)));
        }

        if (filtreAy == 0 && string.IsNullOrWhiteSpace(filtreDurum))
        {
            return filtrelenmisKrediler.OrderBy(k => k.MasrafKalemi).ToList();
        }

        var sonuc = new List<KrediOzet>();
        foreach (var kredi in filtrelenmisKrediler)
        {
            var taksitler = await BudgetService.GetKrediTaksitDetaylariAsync(kredi.TaksitGrupId);
            if (FiltreleTaksitler(taksitler).Any())
            {
                sonuc.Add(kredi);
            }
        }

        return sonuc.OrderBy(k => k.MasrafKalemi).ToList();
    }

    private async Task KrediSec(KrediOzet kredi)
    {
        secilenTekrarlayanOdemeRapor = null;
        tekrarlayanProjeksiyonListesi = new();
        secilenKredi = kredi;
        var tumTaksitler = await BudgetService.GetKrediTaksitDetaylariAsync(kredi.TaksitGrupId);
        secilenKrediTaksitler = FiltreleTaksitler(tumTaksitler);
    }
    
    private void TekrarlayanOdemeSec(TekrarlayanOdeme odeme)
    {
        secilenKredi = null;
        secilenKrediTaksitler = new();
        secilenTekrarlayanOdemeRapor = odeme;
        
        tekrarlayanProjeksiyonListesi = new();
        
        DateTime baslangic = odeme.BaslangicTarihi > DateTime.Today ? odeme.BaslangicTarihi : DateTime.Today;
        int artisAyi = GetAyCarpani(odeme.Periyod);
        
        DateTime siradakiTarih = new DateTime(baslangic.Year, baslangic.Month, Math.Min(odeme.OdemeGunu, DateTime.DaysInMonth(baslangic.Year, baslangic.Month)));
        
        if (siradakiTarih < DateTime.Today)
        {
            var nextMonth = DateTime.Today.AddMonths(1);
            siradakiTarih = new DateTime(nextMonth.Year, nextMonth.Month, Math.Min(odeme.OdemeGunu, DateTime.DaysInMonth(nextMonth.Year, nextMonth.Month)));
        }
        
        for (int i = 1; i <= 12; i++)
        {
            tekrarlayanProjeksiyonListesi.Add(new TekrarlayanProjeksiyon
            {
                Sira = i,
                Tarih = siradakiTarih,
                Tutar = odeme.Tutar
            });
            
            var nextDate = siradakiTarih.AddMonths(artisAyi);
            siradakiTarih = new DateTime(nextDate.Year, nextDate.Month, Math.Min(odeme.OdemeGunu, DateTime.DaysInMonth(nextDate.Year, nextDate.Month)));
        }
    }
    
    private int GetAyCarpani(TekrarPeriyodu periyod)
    {
        return periyod switch
        {
            TekrarPeriyodu.Aylik => 1,
            TekrarPeriyodu.IkiAylik => 2,
            TekrarPeriyodu.UcAylik => 3,
            TekrarPeriyodu.AltiAylik => 6,
            TekrarPeriyodu.Yillik => 12,
            _ => 1
        };
    }

    private List<KrediTaksitDetay> FiltreleTaksitler(IEnumerable<KrediTaksitDetay> taksitler)
    {
        var query = taksitler;

        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            query = query.Where(t =>
                t.MasrafKalemi.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(t.Aciklama) && t.Aciklama.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)));
        }

        if (secilenYil > 0)
        {
            query = query.Where(t => t.OdemeTarihi.Year == secilenYil);
        }

        if (filtreAy > 0)
        {
            query = query.Where(t => t.OdemeTarihi.Month == filtreAy);
        }

        if (!string.IsNullOrWhiteSpace(filtreDurum))
        {
            query = query.Where(DurumFiltresineUyuyor);
        }

        return query.ToList();
    }

    private bool DurumFiltresineUyuyor(KrediTaksitDetay taksit)
    {
        return filtreDurum switch
        {
            "Odendi" => taksit.Durum == OdemeDurum.Odendi,
            "Bekliyor" => taksit.Durum == OdemeDurum.Bekliyor || taksit.Durum == OdemeDurum.KismiOdendi,
            "Gecikmis" => (taksit.Durum == OdemeDurum.Bekliyor || taksit.Durum == OdemeDurum.KismiOdendi) && taksit.OdemeTarihi.Date < DateTime.Today,
            _ => true
        };
    }

    private decimal GetBuAyOdenecek()
    {
        var buAy = DateTime.Today.Month;
        var buYil = DateTime.Today.Year;
        return secilenKrediTaksitler
            .Where(t => t.OdemeTarihi.Month == buAy && t.OdemeTarihi.Year == buYil && (t.Durum == OdemeDurum.Bekliyor || t.Durum == OdemeDurum.KismiOdendi))
            .Sum(t => t.Durum == OdemeDurum.KismiOdendi ? t.KalanTutar : t.Tutar);
    }

    private decimal GetGorunenTaksitTutari(KrediTaksitDetay taksit)
        => taksit.Durum == OdemeDurum.KismiOdendi ? taksit.KalanTutar : taksit.Tutar;

