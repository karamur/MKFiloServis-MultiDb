    private async Task TekTaksitSilOnay(KrediTaksitDetay taksit)
    {
        if (secilenKredi == null) return;

        var result = await JS.InvokeAsync<bool>("confirm", $"Taksit {taksit.KacinciTaksit} ({FormatPara(taksit.Tutar)}) silmek istediğinizden emin misiniz?"

);
        if (!result) return;

        isSaving = true;
        try
        {
            var odeme = await BudgetService.GetTaksitOdemeAsync(secilenKredi.TaksitGrupId, taksit.KacinciTaksit);
            if (odeme != null)
            {
                await BudgetService.HardDeleteOdemeAsync(odeme.Id);
                ToastService.ShowSuccess($"Taksit {taksit.KacinciTaksit} silindi");
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task TumKrediSilOnay()
    {
        if (secilenKrediDuzenleme == null) return;

        var result = await JS.InvokeAsync<bool>("confirm", $"'{secilenKrediDuzenleme.MasrafKalemi}' kredisini ve TÜM {secilenKrediDuzenleme.ToplamTaksitSayisi} taksitini silmek istediğinizden emin misiniz?\n\nBu işlem geri alınamaz!");
        if (!result) return;

        isSaving = true;
        try
        {
            // Taksit grubundaki tüm ödemeleri kalıcı sil
            var taksitler = await BudgetService.GetTaksitGrubuAsync(secilenKrediDuzenleme.TaksitGrupId);
            foreach (var taksit in taksitler)
            {
                await BudgetService.HardDeleteOdemeAsync(taksit.Id);
            }
            
            ToastService.ShowSuccess($"Kredi ve {taksitler.Count} taksit silindi");
            secilenKredi = null;
            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task BekleyenTaksitlariSilOnay()
    {
        if (secilenKrediDuzenleme == null) return;

        var bekleyenSayisi = secilenKrediDuzenleme.ToplamTaksitSayisi - secilenKrediDuzenleme.OdenenTaksitSayisi;
        var result = await JS.InvokeAsync<bool>("confirm", $"{bekleyenSayisi} adet bekleyen taksiti silmek istediğinizden emin misiniz?\n\nÖdenen taksitler silinmeyecek.");
        if (!result) return;

        isSaving = true;
        try
        {
            // Taksit grubundaki bekleyen ödemeleri kalıcı sil
            var taksitler = await BudgetService.GetTaksitGrubuAsync(secilenKrediDuzenleme.TaksitGrupId);
            var bekleyenler = taksitler.Where(t => t.Durum == OdemeDurum.Bekliyor).ToList();

            foreach (var taksit in bekleyenler)
            {
                await BudgetService.HardDeleteOdemeAsync(taksit.Id);
            }

            ToastService.ShowSuccess($"{bekleyenler.Count} bekleyen taksit silindi");
            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

