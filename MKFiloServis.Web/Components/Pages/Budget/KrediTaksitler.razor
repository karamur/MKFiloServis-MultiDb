    private async Task TaksitliOdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi))
        {
            ToastService.ShowWarning("Masraf kalemi giriniz");
            return;
        }
        if (taksitRequest.TaksitSayisi < 1)
        {
            ToastService.ShowWarning("Taksit sayısı en az 1 olmalıdır");
            return;
        }
        if (taksitRequest.ToplamTutar <= 0)
        {
            ToastService.ShowWarning("Toplam tutar giriniz");

                    if (onizlemeTaksitler.Any())
                    {
                        var toplamOnizleme = onizlemeTaksitler.Sum(t => t.Tutar);
                        if (Math.Abs(toplamOnizleme - taksitRequest.ToplamTutar) >= 0.01m)
                        {
                            ToastService.ShowWarning($"Taksit tutarları toplamı ({FormatPara(toplamOnizleme)}) girilen toplam tutardan ({FormatPara(taksitRequest.ToplamTutar)}) farklı. Lütfen düzeltin.");
                            return;
                        }
                    }
            return;
        }

        isSaving = true;
        try
        {
            var request = new TaksitliOdemeRequest
            {
                MasrafKalemi = taksitRequest.MasrafKalemi,
                Aciklama = taksitRequest.Aciklama,
                BaslangicTarihi = taksitRequest.BaslangicTarihi,
                TaksitSayisi = taksitRequest.TaksitSayisi,
                ToplamTutar = taksitRequest.ToplamTutar,
                TaksitPlani = onizlemeTaksitler.Any() ? onizlemeTaksitler : new()
            };
            await BudgetService.CreateTaksitliOdemeAsync(request);
            ToastService.ShowSuccess($"{taksitRequest.TaksitSayisi} taksitli ödeme oluşturuldu");
            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

