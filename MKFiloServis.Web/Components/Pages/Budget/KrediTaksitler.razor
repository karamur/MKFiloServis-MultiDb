            </div>

            <!-- Sağ Taraf: Seçilen Kredinin/Tekrarlayanın Taksitleri -->
            <div class="col-md-7">
                @if (secilenKredi != null)
                {
                    <div class="card">
                        <div class="card-header py-2 bg-primary text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">
                                        <i class="bi bi-calendar3 me-2"></i>@secilenKredi.MasrafKalemi
                                        @if (!string.IsNullOrEmpty(secilenKredi.Aciklama))
                                        {
                                            <small class="text-white-50">- @secilenKredi.Aciklama</small>
                                        }
                                    </h6>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-light" @onclick="ExcelExport" title="Excel">
                                        <i class="bi bi-file-earmark-excel"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-light" @onclick="Yazdir" title="Yazdır">
                                        <i class="bi bi-printer"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <!-- Özet Bilgiler -->
                            <div class="row g-0 border-bottom p-2 bg-light">
                                <div class="col-3 text-center border-end">
                                    <small class="text-muted d-block">Toplam</small>
                                    <strong>@FormatPara(secilenKredi.ToplamTutar)</strong>
                                </div>
                                <div class="col-3 text-center border-end">
                                    <small class="text-muted d-block">Ödenen</small>
                                    <strong class="text-success">@FormatPara(secilenKredi.OdenenTutar)</strong>
                                </div>
                                <div class="col-3 text-center border-end">
                                    <small class="text-muted d-block">Kalan</small>
                                    <strong class="text-danger">@FormatPara(secilenKredi.KalanTutar)</strong>
                                </div>
                                <div class="col-3 text-center">
                                    <small class="text-muted d-block">İlerleme</small>
                                    <strong>%@secilenKredi.TamamlanmaYuzdesi.ToString("0")</strong><div class="progress mt-1 mx-2" style="height: 5px;"><div class="progress-bar bg-success" style="width: @secilenKredi.TamamlanmaYuzdesi%"></div></div>
                                </div>
                            </div>

                            <!-- Taksit Listesi -->
                            <div class="table-responsive" style="max-height: 450px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th style="width: 50px;">#</th>
                                            <th>Tarih</th>
                                            <th class="text-end">Tutar</th>
                                            <th class="text-center">Durum</th>
                                            <th class="text-center" style="width: 180px;">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var taksit in secilenKrediTaksitler)
                                        {
                                            var gecikmisMi = (taksit.Durum == OdemeDurum.Bekliyor || taksit.Durum == OdemeDurum.KismiOdendi) && taksit.OdemeTarihi < DateTime.Today;
                                            <tr class="@(taksit.Durum == OdemeDurum.Odendi ? "table-success" : taksit.Durum == OdemeDurum.KismiOdendi ? "table-info" : gecikmisMi ? "table-danger" : "")" style="@(taksit.Durum == OdemeDurum.Odendi ? "border-left: 3px solid #198754;" : taksit.Durum == OdemeDurum.KismiOdendi ? "border-left: 3px solid #0dcaf0;" : gecikmisMi ? "border-left: 3px solid #dc3545;" : "border-left: 3px solid #ffc107;")">
                                                <td>
                                                    <span class="badge @(taksit.Durum == OdemeDurum.Odendi ? "bg-success" : gecikmisMi ? "bg-danger" : "bg-secondary")">
                                                        @taksit.KacinciTaksit
                                                    </span>
                                                </td>
                                                <td>
                                                    @taksit.OdemeTarihi.ToString("dd.MM.yyyy")
                                                    @if (gecikmisMi)
                                                    {
                                                        <br /><small class="text-danger">@((DateTime.Today - taksit.OdemeTarihi).Days) gün gecikmiş</small>
                                                    }
                                                </td>
                                                <td class="text-end">
                                                    <strong>@FormatPara(GetGorunenTaksitTutari(taksit))</strong>
                                                    @if (taksit.Durum == OdemeDurum.KismiOdendi)
                                                    {
                                                        <br /><small class="text-success">Ödenen: @FormatPara(taksit.OdenenTutar)</small>
                                                        <br /><small class="text-warning fw-bold">Kalan: @FormatPara(taksit.KalanTutar)</small>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    @if (taksit.Durum == OdemeDurum.Odendi)
                                                    {
                                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Ödendi</span>
                                                    }
                                                    else if (taksit.Durum == OdemeDurum.KismiOdendi)
                                                    {
                                                        <span class="badge bg-info text-white"><i class="bi bi-pie-chart-fill me-1"></i>Kısmi %@taksit.OdemeYuzdesi</span>
                                                    }
                                                    else if (gecikmisMi)
                                                    {
                                                        <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Gecikmiş</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Bekliyor</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    @if (taksit.Durum != OdemeDurum.Odendi)
                                                    {
                                                        <div class="btn-group btn-group-sm">
                                                            <button class="btn btn-outline-primary" @onclick="() => TaksitDuzenleAc(taksit)" title="Düzenle">
                                                                <i class="bi bi-pencil"></i>
                                                            </button>
                                                            <button class="btn btn-success" @onclick="() => OdemeYapModalAc(taksit)" title="Ödeme Yap">
                                                                <i class="bi bi-cash-coin"></i>
                                                            </button>
                                                            <button class="btn btn-outline-danger" @onclick="() => TekTaksitSilOnay(taksit)" title="Taksiti Sil">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success px-3 py-2">
                                                            <i class="bi bi-check-lg me-1"></i>Ödendi
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
                @* Tekrarlayan Ödeme Rapor Görünümü - Pasif edildi
                else if (secilenTekrarlayanOdemeRapor != null)
                {
                    <div class="card border-info">
                        <div class="card-header py-2 bg-info text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">
                                        <i class="bi bi-arrow-repeat me-2"></i>@secilenTekrarlayanOdemeRapor.OdemeAdi
                                        @if (!string.IsNullOrEmpty(secilenTekrarlayanOdemeRapor.Aciklama))
                                        {
                                            <small class="text-white-50">- @secilenTekrarlayanOdemeRapor.Aciklama</small>
                                        }
                                    </h6>
                                </div>
                                <div class="d-flex gap-2">
                                    <span class="badge bg-light text-info align-self-center">Projeksiyon</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="row g-0 border-bottom p-2 bg-light">
                                <div class="col-4 text-center border-end">
                                    <small class="text-muted d-block">Tutar</small>
                                    <strong>@FormatPara(secilenTekrarlayanOdemeRapor.Tutar)</strong>
                                </div>
                                <div class="col-4 text-center border-end">
                                    <small class="text-muted d-block">Periyod</small>
                                    <strong>Her @GetPeriyodText(secilenTekrarlayanOdemeRapor.Periyod)</strong>
                                </div>
                                <div class="col-4 text-center">
                                    <small class="text-muted d-block">Gelecek 1 Yıl Toplamı</small>
                                    <strong class="text-danger">@FormatPara(tekrarlayanProjeksiyonListesi.Sum(x => x.Tutar))</strong>
                                </div>
                            </div>
                            <div class="table-responsive" style="max-height: 450px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th style="width: 50px;">#</th>
                                            <th>Öngörülen Tarih</th>
                                            <th class="text-end">Tutar</th>
                                            <th class="text-center">Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var projeksiyon in tekrarlayanProjeksiyonListesi)
                                        {
                                            <tr>
                                                <td>
                                                    <span class="badge bg-secondary">
                                                        @projeksiyon.Sira
                                                    </span>
                                                </td>
                                                <td>
                                                    <i class="bi bi-calendar-event me-2 text-muted"></i>
                                                    @projeksiyon.Tarih.ToString("dd.MM.yyyy")
                                                </td>
                                                <td class="text-end">
                                                    <strong>@FormatPara(projeksiyon.Tutar)</strong>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-light text-muted border"><i class="bi bi-eye text-info me-1"></i>Beklenen</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
                *@
                else
                {
                    <div class="card">
                        <div class="card-body text-center py-5 text-muted">
                            <i class="bi bi-arrow-left-circle" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">Detayları görmek için sol taraftan bir kayıt seçin</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Taksitli Ödeme Modal -->
@if (showTaksitModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Yeni Taksitli Ödeme</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Masraf Kalemi *</label>
                                <input type="text" class="form-control" @bind="taksitRequest.MasrafKalemi" placeholder="Örn: Kredi Kartı, Araç Kredisi" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Açıklama</label>
                                <input type="text" class="form-control" @bind="taksitRequest.Aciklama" placeholder="Örn: X Bankası, 12 ay vadeli" />
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Başlangıç Tarihi *</label>
                                        <input type="date" class="form-control" @bind="taksitRequest.BaslangicTarihi" @bind:after="OnizlemeOlustur" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Sayısı *</label>
                                        <input type="number" class="form-control" @bind="taksitRequest.TaksitSayisi" @bind:after="OnizlemeOlustur" min="1" max="120" />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Toplam Tutar *</label>
                                        <div class="input-group">
                                            <input type="number" class="form-control" @bind="taksitRequest.ToplamTutar" @bind:after="OnizlemeOlustur" step="0.01" />
                                            <span class="input-group-text">₺</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Tutarı</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control fw-bold text-primary" 
                                                   value="@(taksitRequest.TaksitSayisi > 0 ? FormatPara(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi) : "0 ₺")" readonly />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-info py-2">
                                @{
                                    var _toplam = onizlemeTaksitler.Any() ? onizlemeTaksitler.Sum(t => t.Tutar) : 0m;
                                    var _fark   = taksitRequest.ToplamTutar - _toplam;
                                    var _tamam  = Math.Abs(_fark) < 0.01m;
                                }
                                <i class="bi bi-info-circle me-1"></i>
                                @if (onizlemeTaksitler.Any())
                                {
                                    <text><strong>@taksitRequest.TaksitSayisi taksit</strong> &mdash; Toplam: <strong class="@(_tamam ? "text-success" : "text-danger fw-bold")">@FormatPara(_toplam)</strong></text>
                                    @if (!_tamam)
                                    {
                                        <span class="ms-1 text-danger small">(fark: @FormatPara(_fark))</span>
                                    }
                                }
                                else
                                {
                                    <text><strong>@taksitRequest.TaksitSayisi taksit</strong> oluşturulacak, her biri <strong>@FormatPara(taksitRequest.TaksitSayisi > 0 ? taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi : 0)</strong></text>
                                }
                            </div>
                            @if (taksitRequest.TaksitSayisi > 0 && taksitRequest.ToplamTutar > 0)
                            {
                                @if (!onizlemeTaksitler.Any())
                                {
                                    <div class="text-center py-3">
                                        <button class="btn btn-outline-success btn-sm" @onclick="OnizlemeOlustur">
                                            <i class="bi bi-list-ol me-1"></i>Taksit Listesini Oluştur
                                        </button>
                                        <div class="text-muted small mt-1">Tarihleri ve tutarları özelleştirebilirsiniz</div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-muted fw-bold">Taksit Planı <span class="text-info">(düzenlenebilir)</span></small>
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="OnizlemeOlustur" title="Eşit dağılıma sıfırla">
                                            <i class="bi bi-arrow-counterclockwise"></i> Sıfırla
                                        </button>
                                    </div>
                                    <div class="border rounded" style="max-height: 230px; overflow-y: auto;">
                                        @for (int idx = 0; idx < onizlemeTaksitler.Count; idx++)
                                        {
                                            var i = idx;
                                            <div class="d-flex gap-1 align-items-center border-bottom px-1 py-1">
                                                <span class="badge bg-secondary" style="min-width:24px;font-size:0.7rem;">@onizlemeTaksitler[i].Sira</span>
                                                <input type="date" class="form-control form-control-sm p-1" style="width:128px;font-size:0.8rem;"
                                                       value="@onizlemeTaksitler[i].Tarih.ToString("yyyy-MM-dd")"
                                                       @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) onizlemeTaksitler[i].Tarih = d; }" />
                                                <input type="number" class="form-control form-control-sm text-end p-1" style="width:100px;font-size:0.8rem;"
                                                       value="@onizlemeTaksitler[i].Tutar"
                                                       step="0.01"
                                                       @onchange="e => { if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v)) onizlemeTaksitler[i].Tutar = v; }" />
                                                <small class="text-muted">₺</small>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-success" @onclick="TaksitliOdemeKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Ödeme Yap Modal -->
@if (showOdemeModal && secilenTaksit != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
