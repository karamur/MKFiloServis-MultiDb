@page "/butce/kredi-taksitler"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using System.Globalization
@inject IBudgetService BudgetService
@inject IBankaHesapService BankaHesapService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Kredi / Taksitler</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-credit-card me-2"></i>Kredi / Taksitler</h3>
            <small class="text-muted">Tüm kredi ve taksitli ödemeleri yönetin</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <button class="btn btn-success" @onclick="TaksitliOdemeAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Taksitli Ödeme
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="secilenYil">
                        <option value="0">Tüm Yıllar</option>
                        @for (int y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreAy">
                        <option value="0">Tüm Aylar</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tüm Durumlar</option>
                        <option value="Bekliyor">Bekliyor</option>
                        <option value="Odendi">Ödendi</option>
                        <option value="Gecikmis">Gecikmiş</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input type="text" class="form-control form-control-sm" placeholder="Masraf Kalemi veya Açıklama Ara..." 
                           @bind="aramaMetni" />
                </div>
                <div class="col-md-2 d-flex gap-2 justify-content-end">
                    <button class="btn btn-primary btn-sm" @onclick="LoadDataAsync" title="Ara">
                        <i class="bi bi-search me-1"></i>Ara
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreTemizle" title="Filtreleri Temizle">
                        <i class="bi bi-x-lg"></i> Temizle
                    </button>
                    <span class="badge bg-secondary align-self-center">@krediler.Count</span>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Yükleniyor...</p>
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        <div class="row mb-3 g-2">
            <div class="col-6 col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2 px-3">
                        <small>Toplam Kredi</small>
                        <h5 class="mb-0">@krediler.Count adet</h5>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body py-2 px-3">
                        <small>Kalan Borç</small>
                        <h5 class="mb-0">@FormatPara(krediler.Sum(k => k.KalanTutar))</h5>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body py-2 px-3">
                        <small>Ödenen</small>
                        <h5 class="mb-0">@FormatPara(krediler.Sum(k => k.OdenenTutar))</h5>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2 px-3">
                        <small>Bu Ay Ödenecek</small>
                        <h5 class="mb-0">@FormatPara(GetBuAyOdenecek())</h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Sol Taraf: Kredi Listesi ve Tekrarlayan Ödemeler -->
            <div class="col-md-5">
                <!-- Kredi Listesi -->
                <div class="card mb-3">
                    <div class="card-header py-2 bg-primary text-white d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-credit-card me-2"></i>Kredi / Taksitler (@krediler.Count)</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 300px, overflow-y: auto;">
                            @if (krediler.Any())
                            {
                                @foreach (var kredi in krediler)
                                {
                                    <div class="list-group-item list-group-item-action p-2 @(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "active" : "")" 
                                         style="cursor: pointer;" 
                                         @onclick="() => KrediSec(kredi)"
                                         @ondblclick="() => KrediDuzenleAc(kredi)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-credit-card-2-front me-2 @(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "text-white" : "text-danger")"></i>
                                                    <strong class="@(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "" : "text-dark")">@kredi.MasrafKalemi</strong>
                                                    <button class="btn btn-sm ms-2 py-0 px-1 @(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "btn-light" : "btn-outline-secondary")" 
                                                            @onclick:stopPropagation="true"
                                                            @onclick="() => KrediDuzenleAc(kredi)" title="Detay/Sil">
                                                        <i class="bi bi-three-dots" style="font-size: 0.7rem;"></i>
                                                    </button>
                                                </div>
                                                @if (!string.IsNullOrEmpty(kredi.Aciklama))
                                                {
                                                    <small class="@(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "text-white-50" : "text-muted") d-block ms-4">@kredi.Aciklama</small>
                                                }
                                                <div class="ms-4 mt-1">
                                                    <small class="@(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "text-white-50" : "text-muted")">
                                                        @kredi.BaslangicTarihi.ToString("MMM yyyy") - @kredi.BitisTarihi.ToString("MMM yyyy")
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge @(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "bg-light text-primary" : "bg-danger")">
                                                    @FormatPara(kredi.KalanTutar)
                                                </span>
                                                <br />
                                                <small class="@(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "text-white-50" : "text-muted")">
                                                    @kredi.OdenenTaksitSayisi/@kredi.ToplamTaksitSayisi taksit
                                                </small>
                                            </div>
                                        </div>
                                        <div class="progress mt-2" style="height: 5px;">
                                            <div class="progress-bar @(secilenKredi?.TaksitGrupId == kredi.TaksitGrupId ? "bg-light" : "bg-success")" 
                                                 style="width: @kredi.TamamlanmaYuzdesi%"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-center text-muted py-4">
                                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Kredi/taksit bulunamadı</p>
                                    <button class="btn btn-outline-success btn-sm mt-2" @onclick="TaksitliOdemeAc">
                                        <i class="bi bi-plus-lg me-1"></i>Yeni Ekle
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Tekrarlayan Ödemeler - Pasif edildi, görünmez -->
                @* 
                <div class="card">
                    <div class="card-header py-2 bg-info text-white d-flex justify-content-between align-items-center">
