    private void OnizlemeOlustur()
    {
        if (taksitRequest.TaksitSayisi <= 0 || taksitRequest.ToplamTutar <= 0)
        {
            onizlemeTaksitler = new();
            return;
        }
        var taksitTutari = Math.Round(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi, 2);
        var fark = taksitRequest.ToplamTutar - taksitTutari * taksitRequest.TaksitSayisi;
        onizlemeTaksitler = Enumerable.Range(0, taksitRequest.TaksitSayisi)
            .Select(i => new TaksitDetayRequest
            {
                Sira = i + 1,
                Tarih = taksitRequest.BaslangicTarihi.AddMonths(i),
                Tutar = i == taksitRequest.TaksitSayisi - 1 ? taksitTutari + fark : taksitTutari
            }).ToList();
    }

