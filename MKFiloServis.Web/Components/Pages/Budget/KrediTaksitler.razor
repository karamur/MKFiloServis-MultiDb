    private async Task TaksitGuncelle()
    {
        if (duzenlenenTaksit == null || secilenKredi == null) return;

        // Tutar kontrolü kaldırıldı - kullanıcı ne yazdıysa o kaydedilsin (0 veya negatif dahil)

        isSaving = true;
        try
        {
            // Ödeme kaydını bul ve güncelle
            var odeme = await BudgetService.GetTaksitOdemeAsync(secilenKredi.TaksitGrupId, duzenlenenTaksit.KacinciTaksit);
            if (odeme != null)
            {
                // Doğrudan mevcut entity'nin özelliklerini güncelle
                odeme.OdemeTarihi = duzenlenenTaksitTarihi;
                odeme.OdemeAy = duzenlenenTaksitTarihi.Month;
                odeme.OdemeYil = duzenlenenTaksitTarihi.Year;
                odeme.Miktar = duzenlenenTaksitTutar;
                
                await BudgetService.UpdateOdemeAsync(odeme);
                ToastService.ShowSuccess($"Taksit {duzenlenenTaksit.KacinciTaksit} güncellendi - Tarih: {duzenlenenTaksitTarihi:dd.MM.yyyy}, Tutar: {duzenlenenTaksitTutar:N2} ₺");
                ModalKapat();
                await LoadDataAsync();
            }
            else
            {
                ToastService.ShowError("Taksit bulunamadı!");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

