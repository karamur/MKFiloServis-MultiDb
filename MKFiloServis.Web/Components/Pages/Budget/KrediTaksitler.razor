                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Toplam Tutar</label>
                                        <input type="text" class="form-control fw-bold" value="@FormatPara(secilenKrediDuzenleme.ToplamTutar)" readonly />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Kalan Tutar</label>
                                        <input type="text" class="form-control fw-bold text-danger" value="@FormatPara(secilenKrediDuzenleme.KalanTutar)" readonly />
                                    </div>
                                </div>
