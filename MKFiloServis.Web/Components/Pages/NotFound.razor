@page "/not-found"
@layout MainLayout
@inject NavigationManager Nav

<PageTitle>Ters giden bir şey var</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-sm border-0" style="max-width: 560px; width: 100%;">
        <div class="card-body text-center p-5">
            <i class="bi bi-emoji-frown text-warning" style="font-size: 4rem;"></i>
            <h3 class="mt-3 mb-2">Ters giden bir şey var</h3>
            <p class="text-muted mb-4">
                Aradığınız sayfa bulunamadı veya geçici olarak erişilemiyor.
                Adresi kontrol edip tekrar deneyebilir ya da aşağıdaki bağlantılardan devam edebilirsiniz.
            </p>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <button class="btn btn-outline-secondary" @onclick="@(() => Nav.NavigateTo("javascript:history.back()"))">
                    <i class="bi bi-arrow-left me-1"></i>Geri Dön
                </button>
                <a href="/dashboard" class="btn btn-primary">
                    <i class="bi bi-house-door me-1"></i>Ana Sayfa
                </a>
                <a href="/personel/ozluk-evrak" class="btn btn-outline-info">
                    <i class="bi bi-clipboard-check me-1"></i>Özlük Evrak
                </a>
            </div>
        </div>
    </div>
</div>
