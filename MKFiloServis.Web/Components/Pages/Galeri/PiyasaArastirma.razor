@page "/satis/arastirma"
@page "/piyasa-arastirma"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using ClosedXML.Excel
@inject IAracPiyasaArastirmaService PiyasaService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Arac Piyasa Arastirma</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1"><i class="bi bi-graph-up-arrow me-2"></i>Arac Piyasa Arastirma</h3>
            <small class="text-muted">Yapay zeka destekli piyasa analizi ve arac fiyat arastirmasi</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="KayitliAramalarModalAc">
                <i class="bi bi-clock-history me-1"></i>Kayitli Aramalar
            </button>
            @if (sonuclar.Any())
            {
                <button class="btn btn-success" @onclick="AramaKaydet" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-save me-1"></i>
                    }
                    Kaydet
                </button>
                <button class="btn btn-outline-success" @onclick="ExcelAktar">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
            }
        </div>
    </div>

    <div class="row">
        <!-- Sol Panel - Arama Kriterleri -->
        <div class="col-lg-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-search me-2"></i>Arama Kriterleri</h6>
                </div>
                <div class="card-body">
                    <!-- Vasita Turu -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vasita Turu</label>
                        <select class="form-select" @bind="selectedVasitaTuru" @bind:after="VasitaTuruSecildi">
                            @foreach (var vt in vasitaTurleri)
                            {
                                <option value="@vt.Kod">@vt.Ad</option>
                            }
                        </select>
                    </div>

                    <!-- Marka -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Marka *</label>
                        <select class="form-select" @bind="selectedMarka" @bind:after="MarkaSecildi">
                            <option value="">-- Marka Secin --</option>
                            @foreach (var marka in markalar)
                            {
                                <option value="@marka.Marka">@marka.Marka</option>
                            }
                        </select>
                    </div>

                    <!-- Model -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Model *</label>
                        <select class="form-select" @bind="selectedModel" disabled="@(string.IsNullOrEmpty(selectedMarka))">
                            <option value="">-- Model Secin --</option>
                            @foreach (var model in modeller)
                            {
                                <option value="@model">@model</option>
                            }
                        </select>
                    </div>

                    <!-- Yil Araligi -->
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Min Yil</label>
                            <select class="form-select form-select-sm" @bind="request.YilBaslangic">
                                <option value="">Tumu</option>
                                @for (int y = DateTime.Now.Year; y >= 2000; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Max Yil</label>
                            <select class="form-select form-select-sm" @bind="request.YilBitis">
                                <option value="">Tumu</option>
                                @for (int y = DateTime.Now.Year + 1; y >= 2000; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Yakit ve Vites -->
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Yakit</label>
                            <select class="form-select form-select-sm" @bind="request.YakitTipi">
                                <option value="">Tumu</option>
                                <option value="Benzin">Benzin</option>
                                <option value="Dizel">Dizel</option>
                                <option value="Benzin & LPG">Benzin & LPG</option>
                                <option value="Hibrit">Hibrit</option>
                                <option value="Elektrik">Elektrik</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Vites</label>
                            <select class="form-select form-select-sm" @bind="request.VitesTipi">
                                <option value="">Tumu</option>
                                <option value="Manuel">Manuel</option>
                                <option value="Otomatik">Otomatik</option>
                                <option value="Yari Otomatik">Yari Otomatik</option>
                            </select>
                        </div>
                    </div>

                    <!-- Tasima Kapasitesi / Koltuk Sayisi -->
                    <div class="mb-3">
                        <label class="form-label">
                            @if (selectedVasitaTuru == "ticari-arac" || selectedVasitaTuru == "minivan-panelvan")
                            {
                                <span>Koltuk Sayisi</span>
                            }
                            else
                            {
                                <span>Tasima Kapasitesi</span>
                            }
                        </label>
                        <select class="form-select form-select-sm" @bind="request.TasimaKapasitesi">
                            <option value="">Tumu</option>
                            @if (selectedVasitaTuru == "ticari-arac" || selectedVasitaTuru == "minivan-panelvan")
                            {
                                <option value="2">2 Koltuk</option>
                                <option value="3">3 Koltuk</option>
                                <option value="5">5 Koltuk</option>
                                <option value="7">7 Koltuk</option>
                                <option value="8">8 Koltuk</option>
                                <option value="9">9 Koltuk</option>
                                <option value="10+">10+ Koltuk</option>
                                <option value="14+">14+ Koltuk (Minibus)</option>
                            }
                            else
                            {
                                <option value="2">2 Kisi</option>
                                <option value="4">4 Kisi</option>
                                <option value="5">5 Kisi</option>
                                <option value="7">7 Kisi</option>
                                <option value="8+">8+ Kisi</option>
                            }
                        </select>
                    </div>

                    <!-- Ilan Tarihi Filtresi -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-event me-1"></i>Ilan Tarihi (Son)
                        </label>
                        <select class="form-select" @bind="ilanTarihGun">
                            <option value="1">Son 1 Gun (Bugun)</option>
                            <option value="2">Son 2 Gun</option>
                            <option value="3">Son 3 Gun</option>
                            <option value="7">Son 1 Hafta</option>
                            <option value="14">Son 2 Hafta</option>
                            <option value="30">Son 1 Ay</option>
                            <option value="0">Tum Ilanlar</option>
                        </select>
                        <small class="text-muted">Sadece secilen gun icinde girilen satistaki ilanlar</small>
                    </div>

                    <!-- Arama Butonu -->
                    @if (isSearching)
                    {
                        <div class="d-grid gap-2">
                            <button class="btn btn-danger" @onclick="TaramayiDurdur">
                                <i class="bi bi-stop-circle me-2"></i>Taramayi Durdur
                            </button>
                            <div class="text-center mt-2">
                                <small class="text-muted">@progressMessage</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-primary w-100" @onclick="ArastirmaBaslat"
                                disabled="@(string.IsNullOrEmpty(selectedMarka) || string.IsNullOrEmpty(selectedModel))">
                            <i class="bi bi-search me-2"></i>
                            <span>Piyasa Arastir</span>
                        </button>
                    }
                    
                    <!-- Desteklenen Kaynaklar -->
                    <div class="mt-3">
                        <small class="text-muted d-block mb-2">
                            <i class="bi bi-info-circle me-1"></i>Taranan Kaynaklar:
                        </small>
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-danger">Sahibinden</span>
                            <span class="badge bg-primary">Arabam</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sag Panel - Sonuclar -->
        <div class="col-lg-9">
            @if (isSearching)
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;"></div>
                        <h5 class="mb-2">Piyasa Taraniyor...</h5>
                        <p class="text-muted mb-2">@selectedMarka @selectedModel icin son @ilanTarihGun gun icindeki ilanlar taraniyor</p>
                        @if (!string.IsNullOrEmpty(progressMessage))
                        {
                            <div class="alert alert-info py-2 px-3 d-inline-block">
                                @progressMessage
                            </div>
                        }
                        @if (sonuclar.Any())
                        {
                            <div class="mt-3">
                                <span class="badge bg-success fs-6">@sonuclar.Count ilan cekildi</span>
                            </div>
                        }
                        <div class="mt-3">
                            <button class="btn btn-outline-danger btn-sm" @onclick="TaramayiDurdur">
                                <i class="bi bi-stop-circle me-1"></i>Durdur ve Sonuclari Goster
                            </button>
                        </div>
                    </div>
                </div>
            }
            else if (arastirma != null && sonuclar.Any())
            {
                <!-- Ozet Kartlari -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white h-100">
                            <div class="card-body py-3">
                                <h6 class="mb-1 opacity-75">Toplam Ilan</h6>
                                <h3 class="mb-0">@arastirma.ToplamIlanSayisi</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success text-white h-100">
                            <div class="card-body py-3">
                                <h6 class="mb-1 opacity-75">Ortalama Fiyat</h6>
                                <h3 class="mb-0">@FormatPara(arastirma.OrtalamaFiyat)</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-info text-white h-100">
                            <div class="card-body py-3">
                                <h6 class="mb-1 opacity-75">En Dusuk</h6>
                                <h3 class="mb-0">@FormatPara(arastirma.EnDusukFiyat)</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning text-dark h-100">
                            <div class="card-body py-3">
                                <h6 class="mb-1 opacity-75">En Yuksek</h6>
                                <h3 class="mb-0">@FormatPara(arastirma.EnYuksekFiyat)</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab Menu -->
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "ilanlar" ? "active" : "")" @onclick='() => activeTab = "ilanlar"'>
                            <i class="bi bi-table me-1"></i>Ilanlar (@filtrelenmisIlanlar.Count / @sonuclar.Count)
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "analiz" ? "active" : "")" @onclick="AnalizTabAc">
                            <i class="bi bi-graph-up me-1"></i>AI Analiz
                        </button>
                    </li>
                </ul>

                @if (activeTab == "ilanlar")
                {
                    <div class="card shadow-sm">
                        <div class="card-header bg-light">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span><i class="bi bi-list-ul me-2"></i>Ilan Listesi</span>
                                <!-- Kaynak Filtresi -->
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted">Kaynak:</small>
                                    <select class="form-select form-select-sm" style="width: auto;" @bind="seciliKaynak">
                                        <option value="">Tumu</option>
                                        @foreach (var kaynak in sonuclar.Select(x => x.Kaynak).Distinct().OrderBy(x => x))
                                        {
                                            <option value="@kaynak">@kaynak (@sonuclar.Count(x => x.Kaynak == kaynak))</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                            <table class="table table-hover table-sm mb-0" style="font-size: 11px;">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th style="width: 25px;"></th>
                                        <th style="min-width: 140px;">Arac</th>
                                        <th class="text-center" style="width: 45px;">Yil</th>
                                        <th class="text-end" style="width: 70px;">KM</th>
                                        <th class="text-end" style="width: 90px;">Fiyat</th>
                                        <th class="text-center" style="width: 40px;">Koltuk</th>
                                        <th class="text-center" style="width: 60px;">Durum</th>
                                        <th style="width: 70px;">Konum</th>
                                        <th style="width: 80px;">Kaynak</th>
                                        <th style="width: 100px;">Islem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ilan in filtrelenmisIlanlar)
                                    {
                                        var firsatMi = arastirma != null && ilan.Fiyat < arastirma.OrtalamaFiyat * 0.9m && !ilan.HasarKayitli;
                                        <tr class="@(firsatMi ? "table-success" : "")">
                                            <td class="text-center">
                                                @if (firsatMi)
                                                {
                                                    <i class="bi bi-star-fill text-warning" title="Firsat!"></i>
                                                }
                                            </td>
                                            <td>
                                                <div class="fw-semibold text-truncate" style="max-width: 140px;" title="@ilan.IlanBasligi">@ilan.IlanBasligi
                                                </div>
                                                <small class="text-muted">@ilan.YakitTipi / @ilan.VitesTipi</small>
                                            </td>
                                            <td class="text-center">@ilan.ModelYili</td>
                                            <td class="text-end">@ilan.Kilometre.ToString("N0")</td>
                                            <td class="text-end fw-bold text-success">@FormatPara(ilan.Fiyat)</td>
                                            <td class="text-center">
                                                @if (!string.IsNullOrEmpty(ilan.TasimaKapasitesi))
                                                {
                                                    <span class="badge bg-secondary">@ilan.TasimaKapasitesi</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (ilan.HasarKayitli)
                                                {
                                                    <span class="badge bg-danger" style="font-size: 9px;">Hasarli</span>
                                                }
                                                else if ((ilan.BoyaliParcaSayisi ?? 0) > 0)
                                                {
                                                    <span class="badge bg-warning text-dark" style="font-size: 9px;">Boyali</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success" style="font-size: 9px;">Temiz</span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-truncate d-block" style="max-width: 70px;" title="@ilan.Sehir">@ilan.Sehir
                                                </small>
                                            </td>
                                            <td>
                                                <span class="badge @GetKaynakClass(ilan.Kaynak)" style="font-size: 9px;">@ilan.Kaynak</span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(ilan.IlanUrl))
                                                {
                                                    <a href="@ilan.IlanUrl" target="_blank" class="btn btn-sm btn-outline-primary" 
                                                       title="@ilan.IlanUrl">
                                                        <i class="bi bi-box-arrow-up-right me-1"></i>Ilana Git
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (activeTab == "analiz")
                {
                    <div class="row g-4">
                        <!-- Sol Kolon - Grafikler -->
                        <div class="col-lg-8">
                            <!-- Fiyat Dagilimi Grafigi -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0"><i class="bi bi-bar-chart-fill me-2"></i>Fiyat Dagilimi</h6>
                                </div>
                                <div class="card-body">
                                    <canvas id="fiyatDagilimiChart" height="200"></canvas>
                                </div>
                            </div>

                            <!-- Yil ve Kaynak Grafikleri -->
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="card shadow-sm h-100">
                                        <div class="card-header bg-success text-white">
                                            <h6 class="mb-0"><i class="bi bi-calendar3 me-2"></i>Yillara Gore Dagilim</h6>
                                        </div>
                                        <div class="card-body">
                                            <canvas id="yilDagilimiChart" height="180"></canvas>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card shadow-sm h-100">
                                        <div class="card-header bg-info text-white">
                                            <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Kaynak Dagilimi</h6>
                                        </div>
                                        <div class="card-body">
                                            <canvas id="kaynakDagilimiChart" height="180"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sag Kolon - Ozet -->
                        <div class="col-lg-4">
                            <!-- Hizli Istatistikler -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-dark text-white">
                                    <h6 class="mb-0"><i class="bi bi-lightning-fill me-2"></i>Hizli Istatistikler</h6>
                                </div>
                                <div class="card-body p-0">
                                    <ul class="list-group list-group-flush">
                                        <li class="list-group-item d-flex justify-content-between">
                                            <span><i class="bi bi-hash text-primary me-2"></i>Toplam Ilan</span>
                                            <span class="badge bg-primary rounded-pill fs-6">@sonuclar.Count</span>
                                        </li>
                                        <li class="list-group-item d-flex justify-content-between">
                                            <span><i class="bi bi-currency-lira text-success me-2"></i>Ortalama</span>
                                            <span class="badge bg-success rounded-pill">@FormatPara(arastirma.OrtalamaFiyat)</span>
                                        </li>
                                        <li class="list-group-item d-flex justify-content-between">
                                            <span><i class="bi bi-speedometer text-secondary me-2"></i>Ort. KM</span>
                                            <span class="badge bg-secondary rounded-pill">@arastirma.OrtalamaKilometre.ToString("N0")</span>
                                        </li>
                                        <li class="list-group-item d-flex justify-content-between">
                                            <span><i class="bi bi-star-fill text-warning me-2"></i>Firsat</span>
                                            <span class="badge bg-success rounded-pill">@sonuclar.Count(x => x.Fiyat < arastirma.OrtalamaFiyat * 0.9m && !x.HasarKayitli)</span>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Alim-Satim Onerileri -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-success text-white">
                                    <h6 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Alim-Satim Onerileri</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <small class="text-muted">Onerilen Alis</small>
                                        <h4 class="text-success mb-0">@FormatPara(arastirma.OrtalamaFiyat * 0.85m)</h4>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-muted">Piyasa Ort.</small>
                                        <h4 class="text-primary mb-0">@FormatPara(arastirma.OrtalamaFiyat)</h4>
                                    </div>
                                    <div>
                                        <small class="text-muted">Onerilen Satis</small>
                                        <h4 class="text-warning mb-0">@FormatPara(arastirma.OrtalamaFiyat * 1.05m)</h4>
                                    </div>
                                </div>
                            </div>

                            <!-- Sehir Dagilimi -->
                            <div class="card shadow-sm">
                                <div class="card-header text-white" style="background: #6f42c1;">
                                    <h6 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Sehir Dagilimi</h6>
                                </div>
                                <div class="card-body p-0">
                                    <ul class="list-group list-group-flush">
                                        @foreach (var sehir in sonuclar.GroupBy(x => x.Sehir).OrderByDescending(g => g.Count()).Take(5))
                                        {
                                            var yuzde = (sehir.Count() * 100.0 / sonuclar.Count);
                                            <li class="list-group-item">
                                                <div class="d-flex justify-content-between mb-1">
                                                    <span>@sehir.Key</span>
                                                    <span class="text-muted">@sehir.Count()</span>
                                                </div>
                                                <div class="progress" style="height: 5px;">
                                                    <div class="progress-bar" style="width: @yuzde.ToString("F0")%; background: #6f42c1;"></div>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- AI Analiz -->
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-header text-white" style="background: linear-gradient(135deg, #0d6efd, #6610f2);">
                                    <h6 class="mb-0"><i class="bi bi-robot me-2"></i>Yapay Zeka Analizi</h6>
                                </div>
                                <div class="card-body">
                                    @if (!string.IsNullOrEmpty(arastirma.AIAnalizi))
                                    {
                                        <div class="ai-analiz-content">
                                            @((MarkupString)FormatAnaliz(arastirma.AIAnalizi))
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-search display-1 text-muted mb-3"></i>
                        <h5>Piyasa Arastirmasi Baslatin</h5>
                        <p class="text-muted">Sol panelden vasita turu, marka ve model secerek arastirma yapabilirsiniz.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Kayitli Aramalar Modal -->
@if (showKayitliAramalar)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Kayitli Aramalar</h5>
                    <button type="button" class="btn-close" @onclick="() => showKayitliAramalar = false"></button>
                </div>
                <div class="modal-body">
                    @if (isLoadingKayitliAramalar)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                        </div>
                    }
                    else if (!kayitliAramalar.Any())
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-inbox display-4 text-muted"></i>
                            <p class="mt-2 text-muted">Henuz kayitli arama yok.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Marka / Model</th>
                                        <th class="text-center">Ilan</th>
                                        <th class="text-end">Ort. Fiyat</th>
                                        <th class="text-center">Islem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var arama in kayitliAramalar)
                                    {
                                        <tr>
                                            <td>@arama.ArastirmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td><strong>@arama.Marka @arama.Model</strong></td>
                                            <td class="text-center">@arama.ToplamIlanSayisi</td>
                                            <td class="text-end">@FormatPara(arama.OrtalamaFiyat)</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-primary me-1" @onclick="() => AramaYukle(arama)">
                                                    <i class="bi bi-arrow-up-circle"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => AramaSil(arama.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showKayitliAramalar = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Resim Onizleme Modal -->
@if (showResimModal && secilenIlan != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.85);" tabindex="-1" @onclick="ResimModalKapat">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white" @onclick:stopPropagation>
                <div class="modal-header border-0">
                    <h6 class="modal-title">@secilenIlan.IlanBasligi</h6>
                    <button type="button" class="btn-close btn-close-white" @onclick="ResimModalKapat"></button>
                </div>
                <div class="modal-body text-center p-0">
                    @if (!string.IsNullOrEmpty(secilenIlan.ResimUrl))
                    {
                        <img src="@secilenIlan.ResimUrl" alt="@secilenIlan.IlanBasligi" 
                             class="img-fluid" style="max-height: 70vh;" />
                    }
                </div>
                <div class="modal-footer border-0 justify-content-between">
                    <div>
                        <span class="badge bg-secondary me-2">@secilenIlan.ModelYili</span>
                        <span class="badge bg-info me-2">@secilenIlan.Kilometre.ToString("N0") km</span>
                        @if (!string.IsNullOrEmpty(secilenIlan.TasimaKapasitesi))
                        {
                            <span class="badge bg-warning text-dark me-2">
                                <i class="bi bi-people-fill me-1"></i>@secilenIlan.TasimaKapasitesi
                            </span>
                        }
                        <span class="badge bg-success">@FormatPara(secilenIlan.Fiyat)</span>
                    </div>
                    <a href="@secilenIlan.IlanUrl" target="_blank" class="btn btn-primary btn-sm">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Ilana Git
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .ai-analiz-content h2 { font-size: 1.25rem; color: #0d6efd; margin-top: 1rem; }
    .ai-analiz-content h3 { font-size: 1.1rem; color: #198754; margin-top: 0.8rem; }
    .cursor-pointer { cursor: pointer; transition: transform 0.2s; }
    .cursor-pointer:hover { transform: scale(1.05); box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
</style>

@code {
    private AracPiyasaArastirmaRequest request = new();
    private AracPiyasaArastirma? arastirma;
    private List<PiyasaArastirmaIlan> sonuclar = new();
    private List<VasitaTuru> vasitaTurleri = new();
    private List<VasitaMarkaModel> markalar = new();
    private List<string> modeller = new();
    private List<AracPiyasaArastirma> kayitliAramalar = new();

    private string selectedVasitaTuru = "otomobil";
    private string selectedMarka = "";
    private string selectedModel = "";

#pragma warning disable CS0169, CS0414 // Field is never used / assigned but never used
    private bool isLoadingMarkalar;
    private bool isLoadingModeller;
    private bool isUpdatingMarkaModel;
#pragma warning restore CS0169, CS0414
    private bool isSearching;
    private bool isSaving;
    private bool showKayitliAramalar;
    private bool isLoadingKayitliAramalar;
    private bool showResimModal;

    private string activeTab = "ilanlar";
    private string resimBoyutu = "orta"; // kucuk, orta, buyuk, gizle
    private PiyasaArastirmaIlan? secilenIlan;
    
    // Kaynak filtresi
    private string seciliKaynak = "";
    
    // Ilan tarihi filtresi (gun cinsinden) - Default 2 gun
    private int ilanTarihGun = 2;
    
    // Progress mesaji
    private string progressMessage = "";
    
    // Tarama iptal icin
    private CancellationTokenSource? _cancellationTokenSource;

    // Filtrelenmis ilanlar
    private List<PiyasaArastirmaIlan> filtrelenmisIlanlar => 
        string.IsNullOrEmpty(seciliKaynak) 
            ? sonuclar 
            : sonuclar.Where(x => x.Kaynak == seciliKaynak).ToList();

    protected override void OnInitialized()
    {
        vasitaTurleri = PiyasaService.VasitaTurleriniGetir();
        MarkalariYukle();
    }
    
    public void Dispose()
    {
        _cancellationTokenSource?.Cancel();
        _cancellationTokenSource?.Dispose();
    }

    private void VasitaTuruSecildi()
    {
        selectedMarka = "";
        selectedModel = "";
        modeller.Clear();
        MarkalariYukle();
    }

    private void MarkalariYukle()
    {
        markalar = PiyasaService.MarkalariGetir(selectedVasitaTuru);
    }

    private void MarkaSecildi()
    {
        selectedModel = "";
        if (!string.IsNullOrEmpty(selectedMarka))
        {
            modeller = PiyasaService.ModelleriGetir(selectedVasitaTuru, selectedMarka);
        }
        else
        {
            modeller.Clear();
        }
    }

    private async Task MarkaModelGuncelle()
    {
        isUpdatingMarkaModel = true;
        StateHasChanged();

        try
        {
            await PiyasaService.MarkaModelGuncelleAsync();
            MarkalariYukle();
            ToastService.ShowSuccess("Guncellendi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isUpdatingMarkaModel = false;
        }
    }

    private async Task ArastirmaBaslat()
    {
        if (string.IsNullOrEmpty(selectedMarka) || string.IsNullOrEmpty(selectedModel))
        {
            ToastService.ShowWarning("Marka ve model secin.");
            return;
        }

        isSearching = true;
        progressMessage = "Baslatiliyor...";
        sonuclar.Clear();
        arastirma = null;
        
        // Yeni CancellationTokenSource olustur
        _cancellationTokenSource?.Cancel();
        _cancellationTokenSource?.Dispose();
        _cancellationTokenSource = new CancellationTokenSource();
        
        StateHasChanged();

        try
        {
            request.VasitaTuru = selectedVasitaTuru;
            request.Marka = selectedMarka;
            request.Model = selectedModel;
            request.IlanTarihGun = ilanTarihGun; // Ilan tarihi filtresi

            // Progress callback olustur
            var progress = new Progress<string>(message =>
            {
                progressMessage = message;
                InvokeAsync(StateHasChanged);
            });

            arastirma = await PiyasaService.ArastirmaBaslatAsync(request, progress, _cancellationTokenSource.Token);
            sonuclar = arastirma.Ilanlar.ToList();
            
            if (sonuclar.Any())
            {
                var kaynakGruplari = sonuclar.GroupBy(x => x.Kaynak).Select(g => $"g.Key: {g.Count()}").ToList();
                ToastService.ShowSuccess($"{sonuclar.Count} ilan bulundu! ({string.Join(", ", kaynakGruplari)})");
            }
            else if (!_cancellationTokenSource.IsCancellationRequested)
            {
                ToastService.ShowWarning("Ilan bulunamadi.");
            }
        }
        catch (OperationCanceledException)
        {
            // Durdurulsa bile cekilen verileri goster
            if (arastirma != null && arastirma.Ilanlar.Any())
            {
                sonuclar = arastirma.Ilanlar.ToList();
                ToastService.ShowInfo($"Tarama durduruldu. {sonuclar.Count} ilan cekildi.");
            }
            else if (sonuclar.Any())
            {
                ToastService.ShowInfo($"Tarama durduruldu. {sonuclar.Count} ilan cekildi.");
            }
            else
            {
                ToastService.ShowInfo("Tarama durduruldu.");
            }
        }
        catch (Exception ex)
        {
            // Hata olsa bile cekilen verileri goster
            if (sonuclar.Any())
            {
                ToastService.ShowWarning($"Hata olustu ama {sonuclar.Count} ilan cekildi.");
            }
            else
            {
                ToastService.ShowError($"Hata: {ex.Message}");
            }
        }
        finally
        {
            isSearching = false;
            progressMessage = "";
            StateHasChanged();
        }
    }
    
    private void TaramayiDurdur()
    {
        progressMessage = "Tarama durduruluyor...";
        StateHasChanged();
        
        _cancellationTokenSource?.Cancel();
        PiyasaService.TaramayiDurdur();
    }

    private async Task AnalizTabAc()
    {
        activeTab = "analiz";
        StateHasChanged();
        await Task.Delay(100);
        await GrafikleriCiz();
    }

    private async Task GrafikleriCiz()
    {
        if (arastirma == null || !sonuclar.Any()) return;

        try
        {
            // Fiyat dagilimi
            var fiyatGruplari = sonuclar
                .GroupBy(x => ((int)(x.Fiyat / 250000)) * 250000)
                .OrderBy(g => g.Key)
                .Select(g => new { Fiyat = $"{g.Key / 1000}K-{(g.Key + 250000) / 1000}K", Adet = g.Count() })
                .ToList();

            var fiyatLabels = string.Join(",", fiyatGruplari.Select(x => $"'{x.Fiyat}'"));
            var fiyatData = string.Join(",", fiyatGruplari.Select(x => x.Adet));

            await JS.InvokeVoidAsync("eval", $@"
                if(window.fiyatChart) window.fiyatChart.destroy();
                var ctx = document.getElementById('fiyatDagilimiChart');
                if(ctx) {{
                    window.fiyatChart = new Chart(ctx, {{
                        type: 'bar',
                        data: {{
                            labels: [{fiyatLabels}],
                            datasets: [{{ label: 'Ilan', data: [{fiyatData}], backgroundColor: 'rgba(13,110,253,0.7)' }}]
                        }},
                        options: {{ responsive: true, plugins: {{ legend: {{ display: false }} }} }}
                    }});
                }}
            ");

            // Yil dagilimi
            var yilGruplari = sonuclar.GroupBy(x => x.ModelYili).OrderBy(g => g.Key).ToList();
            var yilLabels = string.Join(",", yilGruplari.Select(x => x.Key));
            var yilData = string.Join(",", yilGruplari.Select(x => x.Count()));

            await JS.InvokeVoidAsync("eval", $@"
                if(window.yilChart) window.yilChart.destroy();
                var ctx = document.getElementById('yilDagilimiChart');
                if(ctx) {{
                    window.yilChart = new Chart(ctx, {{
                        type: 'line',
                        data: {{
                            labels: [{yilLabels}],
                            datasets: [{{ label: 'Ilan', data: [{yilData}], fill: true, backgroundColor: 'rgba(25,135,84,0.2)', borderColor: 'rgba(25,135,84,1)' }}]
                        }},
                        options: {{ responsive: true, plugins: {{ legend: {{ display: false }} }} }}
                    }});
                }}
            ");

            // Kaynak dagilimi
            var kaynakGruplari = sonuclar.GroupBy(x => x.Kaynak).ToList();
            var kaynakLabels = string.Join(",", kaynakGruplari.Select(x => $"'{x.Key}'"));
            var kaynakData = string.Join(",", kaynakGruplari.Select(x => x.Count()));

            await JS.InvokeVoidAsync("eval", $@"
                if(window.kaynakChart) window.kaynakChart.destroy();
                var ctx = document.getElementById('kaynakDagilimiChart');
                if(ctx) {{
                    window.kaynakChart = new Chart(ctx, {{
                        type: 'doughnut',
                        data: {{
                            labels: [{kaynakLabels}],
                            datasets: [{{ data: [{kaynakData}], backgroundColor: ['#dc3545', '#0d6efd'] }}]
                        }},
                        options: {{ responsive: true }}
                    }});
                }}
            ");
        }
        catch { }
    }

    private async Task AramaKaydet()
    {
        if (arastirma == null) return;

        isSaving = true;
        try
        {
            await PiyasaService.ArastirmaKaydetAsync(arastirma);
            ToastService.ShowSuccess("Kaydedildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task KayitliAramalarModalAc()
    {
        showKayitliAramalar = true;
        isLoadingKayitliAramalar = true;
        StateHasChanged();

        try
        {
            kayitliAramalar = await PiyasaService.KayitliArastirmalariGetirAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isLoadingKayitliAramalar = false;
        }
    }

    private void AramaYukle(AracPiyasaArastirma kayitliArama)
    {
        arastirma = kayitliArama;
        sonuclar = kayitliArama.Ilanlar.ToList();
        selectedMarka = kayitliArama.Marka;
        selectedModel = kayitliArama.Model;
        showKayitliAramalar = false;
        ToastService.ShowInfo($"{kayitliArama.Marka} {kayitliArama.Model} yuklendi.");
    }

    private async Task AramaSil(int id)
    {
        try
        {
            await PiyasaService.ArastirmaSilAsync(id);
            kayitliAramalar.RemoveAll(x => x.Id == id);
            ToastService.ShowSuccess("Silindi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task ExcelAktar()
    {
        if (!sonuclar.Any()) return;

        try
        {
            using var workbook = new XLWorkbook();
            var ws = workbook.Worksheets.Add("Piyasa");

            var kapasiteBaslik = (selectedVasitaTuru == "ticari-arac" || selectedVasitaTuru == "minivan-panelvan") 
                ? "Koltuk" : "Kapasite";
            var headers = new[] { "Yil", "Marka", "Model", "Versiyon", "KM", kapasiteBaslik, "Fiyat", "Yakit", "Vites", "Durum", "Sehir", "Kaynak", "URL" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.LightBlue;
            }

            int row = 2;
            foreach (var ilan in sonuclar)
            {
                var durum = ilan.HasarKayitli ? "Hasarli" : ((ilan.BoyaliParcaSayisi ?? 0) > 0 ? "Boyali" : "Temiz");
                var kapasite = !string.IsNullOrEmpty(ilan.TasimaKapasitesi) ? ilan.TasimaKapasitesi : 
                               (!string.IsNullOrEmpty(ilan.Kapasite) ? ilan.Kapasite : "");
                ws.Cell(row, 1).Value = ilan.ModelYili;
                ws.Cell(row, 2).Value = ilan.Marka;
                ws.Cell(row, 3).Value = ilan.Model;
                ws.Cell(row, 4).Value = ilan.Versiyon ?? "";
                ws.Cell(row, 5).Value = ilan.Kilometre;
                ws.Cell(row, 6).Value = kapasite;
                ws.Cell(row, 7).Value = (double)ilan.Fiyat;
                ws.Cell(row, 8).Value = ilan.YakitTipi ?? "";
                ws.Cell(row, 9).Value = ilan.VitesTipi ?? "";
                ws.Cell(row, 10).Value = durum;
                ws.Cell(row, 11).Value = ilan.Sehir ?? "";
                ws.Cell(row, 12).Value = ilan.Kaynak;
                if (!string.IsNullOrEmpty(ilan.IlanUrl))
                {
                    ws.Cell(row, 13).Value = "Git";
                    ws.Cell(row, 13).SetHyperlink(new XLHyperlink(ilan.IlanUrl));
                    ws.Cell(row, 13).Style.Font.FontColor = XLColor.Blue;
                }
                row++;
            }

            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());
            var fileName = $"Piyasa_{selectedMarka}_{selectedModel}_{DateTime.Now:yyyyMMdd}.xlsx";

            await JS.InvokeVoidAsync("eval", $@"
                var b = atob('{base64}');
                var arr = new Uint8Array(b.length);
                for(var i=0;i<b.length;i++) arr[i]=b.charCodeAt(i);
                var blob = new Blob([arr], {{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'}});
                var a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = '{fileName}';
                a.click();
            ");

            ToastService.ShowSuccess("Excel indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private string FormatPara(decimal tutar) => tutar.ToString("N0") + " TL";
    private string GetKaynakClass(String k) => k == "Sahibinden" ? "bg-danger" : "bg-primary";

    private string FormatAnaliz(string analiz)
    {
        if (string.IsNullOrEmpty(analiz)) return "";
        analiz = System.Text.RegularExpressions.Regex.Replace(analiz, @"^### (.+)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        analiz = System.Text.RegularExpressions.Regex.Replace(analiz, @"^## (.+)$", "<h2>$1</h2>", System.Text.RegularExpressions.RegexOptions.Multiline);
        analiz = System.Text.RegularExpressions.Regex.Replace(analiz, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        analiz = analiz.Replace("\n\n", "</p><p>").Replace("\n", "<br>");
        return $"<p>{analiz}</p>";
    }

    private string GetResimGenislik() => resimBoyutu switch
    {
        "kucuk" => "60px",
        "orta" => "100px",
        "buyuk" => "150px",
        _ => "0px"
    };

    private string GetResimBoyut() => resimBoyutu switch
    {
        "kucuk" => "50px",
        "orta" => "80px",
        "buyuk" => "120px",
        _ => "0px"
    };

    private void ResimBuyut(PiyasaArastirmaIlan ilan)
    {
        secilenIlan = ilan;
        showResimModal = true;
    }

    private void ResimModalKapat()
    {
        showResimModal = false;
        secilenIlan = null;
    }
}

