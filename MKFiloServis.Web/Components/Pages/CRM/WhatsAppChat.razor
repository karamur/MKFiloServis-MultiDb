@page "/crm/whatsapp-chat"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using MKFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IWhatsAppService WhatsAppService
@inject ICariService CariService
@inject ApplicationDbContext DbContext
@inject AppAuthenticationStateProvider AuthProvider
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>WhatsApp Chat - CRM</PageTitle>

<div class="container-fluid h-100 py-3" style="min-height: 80vh;">
    <div class="row h-100 g-0 border rounded bg-white shadow-sm" style="min-height: 700px;">

        <!-- Sol Panel: Kişiler ve Gruplar -->
        <div class="col-md-4 border-end d-flex flex-column h-100">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center" style="background-color: #f0f2f5;">
                <h5 class="mb-0 text-dark"><i class="bi bi-whatsapp text-success me-2"></i>Sohbetler</h5>
                <div class="dropdown">
                    <button class="btn btn-sm btn-light rounded-circle" style="width: 35px; height: 35px;" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                        <li><button class="dropdown-item py-2" @onclick="() => showYeniKisiModal = true"><i class="bi bi-person-plus me-3 text-muted"></i>Yeni Kişi</button></li>
                        <li><button class="dropdown-item py-2" @onclick="() => showYeniGrupModal = true"><i class="bi bi-people me-3 text-muted"></i>Yeni Grup</button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item py-2" @onclick='() => RehberdenAktar("cari")'><i class="bi bi-building me-3 text-muted"></i>Carilerden Aktar</button></li>
                        <li><button class="dropdown-item py-2" @onclick='() => RehberdenAktar("personel")'><i class="bi bi-person-badge me-3 text-muted"></i>Personellerden Aktar</button></li>
                        <li><button class="dropdown-item py-2" @onclick='() => RehberdenAktar("kullanici")'><i class="bi bi-person-lines-fill me-3 text-muted"></i>Kullanıcılardan Aktar</button></li>
                        <li><button class="dropdown-item py-2" @onclick='() => RehberdenAktar("tum")'><i class="bi bi-collection me-3 text-muted"></i>Tümünü Aktar</button></li>
                    </ul>
                </div>
            </div>
            
            <div class="p-2 border-bottom bg-white">
                <div class="input-group bg-light rounded-3 px-2 py-1">
                    <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control bg-transparent border-0 shadow-none" placeholder="Aratın veya yeni sohbet başlatın" @bind="aramaMetni" @bind:event="oninput" style="font-size: 0.9rem;" />
                </div>
            </div>

            <ul class="nav nav-tabs nav-fill border-bottom-0 pt-2 px-2">
                <li class="nav-item">
                    <button class="nav-link w-100 py-1 @(aktifTab == "kisiler" ? "active border-bottom-0 bg-white" : "bg-light")" @onclick='() => aktifTab = "kisiler"'>Kişiler</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link w-100 py-1 @(aktifTab == "gruplar" ? "active border-bottom-0 bg-white" : "bg-light")" @onclick='() => aktifTab = "gruplar"'>Gruplar</button>
                </li>
            </ul>

            <div class="flex-grow-1 overflow-auto bg-white">
                @if (isLoading)
                {
                    <div class="d-flex justify-content-center p-4">
                        <div class="spinner-border text-success" role="status"></div>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @if (aktifTab == "kisiler")
                        {
                            @foreach (var kisi in FiltreliKisiler())
                            {
                                <button class="list-group-item list-group-item-action d-flex align-items-center py-2 border-0 @(seciliKisi?.Id == kisi.Id && !grupModu ? "bg-light" : "")"
                                        @onclick="() => KisiSec(kisi)" style="border-bottom: 1px solid #f2f2f2 !important;">
                                    <div class="text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 48px; height: 48px; font-size: 1.2rem; background-color: @GetAvatarColor(kisi.AdSoyad);">
                                        @(kisi.AdSoyad.FirstOrDefault().ToString().ToUpper())
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <strong class="text-truncate fw-normal text-dark" style="font-size: 1.05rem;">@kisi.AdSoyad</strong>
                                        </div>
                                        <div class="text-muted text-truncate d-flex align-items-center" style="font-size: 0.85rem;">
                                            <i class="bi bi-telephone-fill me-1 small"></i> @kisi.Telefon
                                        </div>
                                    </div>
                                </button>
                            }
                        }
                        else
                        {
                            @foreach (var grup in FiltreliGruplar())
                            {
                                <button class="list-group-item list-group-item-action d-flex align-items-center py-3 border-0 @(seciliGrup?.Id == grup.Id && grupModu ? "bg-light" : "")"
                                        @onclick="() => GrupSec(grup)" style="border-bottom: 1px solid #f2f2f2 !important;">
                                    <div class="bg-secondary bg-opacity-25 text-secondary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 48px; height: 48px; font-size: 1.5rem;">
                                        <i class="bi bi-people-fill"></i>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <strong class="text-truncate fw-normal text-dark" style="font-size: 1.05rem;">@grup.GrupAdi</strong>
                                            <span class="badge bg-success rounded-pill" style="font-size: 0.7rem;">@grup.Uyeler.Count</span>
                                        </div>
                                        <div class="text-muted text-truncate" style="font-size: 0.85rem;">@(grup.Aciklama ?? "Grup Mesajı")</div>
                                    </div>
                                </button>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Sağ Panel: Sohbet Ekranı -->
        <div class="col-md-8 d-flex flex-column h-100" style="background-color: #efeae2; position: relative;">
            <!-- Wallpaper / background image simulation -->
            <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.08; background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23000000\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); z-index: 0; pointer-events: none;"></div>
            
            @if (grupModu ? seciliGrup != null : seciliKisi != null)
            {
                <!-- Sohbet Başlığı -->
                <div class="d-flex align-items-center p-2 border-bottom" style="z-index: 1; background-color: #f0f2f5;">
                    @if (grupModu)
                    {
                        <div class="bg-secondary bg-opacity-25 text-secondary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 ms-2" style="width: 40px; height: 40px;">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div class="flex-grow-1" style="cursor: pointer;" @onclick="() => showGrupUyeleriModal = true">
                            <h6 class="mb-0 text-dark">@seciliGrup!.GrupAdi</h6>
                            <small class="text-muted" style="font-size: 0.8rem;">@string.Join(", ", seciliGrup.Uyeler.Take(3).Select(u => u.Kisi?.AdSoyad)) @(seciliGrup.Uyeler.Count > 3 ? "..." : "")</small>
                        </div>
                        <div class="d-flex gap-3 me-3 text-muted" style="font-size: 1.2rem;">
                            <i class="bi bi-search" style="cursor: pointer;"></i>
                            <i class="bi bi-three-dots-vertical" style="cursor: pointer;" @onclick="() => showGrupUyeleriModal = true"></i>
                        </div>
                    }
                    else
                    {
                        <div class="text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 ms-2" style="width: 40px; height: 40px; background-color: @GetAvatarColor(seciliKisi!.AdSoyad);">
                            @(seciliKisi!.AdSoyad.FirstOrDefault().ToString().ToUpper())
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 text-dark">@seciliKisi.AdSoyad</h6>
                            <small class="text-muted" style="font-size: 0.8rem;">İçeride</small>
                        </div>
                        <div class="d-flex gap-3 me-3 text-muted" style="font-size: 1.2rem;">
                            <i class="bi bi-search" style="cursor: pointer;"></i>
                            <i class="bi bi-telephone" style="cursor: pointer;"></i>
                            <i class="bi bi-three-dots-vertical" style="cursor: pointer;"></i>
                        </div>
                    }
                </div>

                <!-- Mesajlar -->
                <div class="flex-grow-1 p-4 overflow-auto" id="chatContainer" style="z-index: 1;">
                    @if (isMessagesLoading)
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-success" role="status"></div>
                        </div>
                    }
                    else if (!aktifMesajlar.Any())
                    {
                        <div class="text-center d-flex justify-content-center align-items-center h-100">
                            <div class="bg-info bg-opacity-10 text-dark px-4 py-2 rounded-pill small shadow-sm">
                                Buraya gönderilen mesajlar uçtan uca şifrelenmiştir.
                            </div>
                        </div>
                    }
                    else
                    {
                        var groupedMessages = aktifMesajlar.GroupBy(m => m.MesajTarihi.ToLocalTime().Date);
                        foreach (var dayGroup in groupedMessages)
                        {
                            <div class="text-center mb-4 mt-2">
                                <span class="badge text-dark shadow-sm px-3 py-2 rounded-3" style="background-color: #fffaca; font-weight: normal; font-size: 0.8rem;">
                                    @(dayGroup.Key == DateTime.Today ? "BUGÜN" : (dayGroup.Key == DateTime.Today.AddDays(-1) ? "DÜN" : dayGroup.Key.ToString("dd MMMM yyyy").ToUpper()))
                                </span>
                            </div>

                            foreach (var msg in dayGroup)
                            {
                                var isGiden = msg.Tipi == WhatsAppMesaj.Yon.Giden;
                                <div class="d-flex mb-2 @(isGiden ? "justify-content-end" : "justify-content-start")">
                                    <div class="shadow-sm position-relative chat-bubble" 
                                         style="max-width: 65%; padding: 6px 7px 8px 9px; 
                                                border-radius: 7.5px; 
                                                @(isGiden ? "background-color: #d9fdd3; border-top-right-radius: 0;" : "background-color: #ffffff; border-top-left-radius: 0;")">
                                        
                                        <!-- Baloncuk kuyrukları CSS -->
                                        @if (isGiden)
                                        {
                                            <div style="position: absolute; right: -8px; top: 0; width: 0; height: 0; border-top: 0px solid transparent; border-left: 10px solid #d9fdd3; border-bottom: 10px solid transparent;"></div>
                                        }
                                        else
                                        {
                                            <div style="position: absolute; left: -8px; top: 0; width: 0; height: 0; border-top: 0px solid transparent; border-right: 10px solid #ffffff; border-bottom: 10px solid transparent;"></div>
                                        }

                                        <div class="text-break" style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.3; color: #111b21;">@msg.Icerik</div>
                                        <div class="d-flex justify-content-end align-items-center mt-1 float-end ms-3" style="font-size: 0.7rem; margin-bottom: -4px;">
                                            <span class="text-muted me-1" style="font-size: 0.65rem;">@msg.MesajTarihi.ToLocalTime().ToString("HH:mm")</span>
                                            @if (isGiden)
                                            {
                                                <i class="bi bi-check-all" style="font-size: 1rem; color: #53bdeb; margin-top: -2px;"></i>
                                            }
                                        </div>
                                        <div class="clearfix"></div>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>

                <!-- Hızlı Şablonlar -->
                @if (sablonlar.Any())
                {
                    <div class="px-3 py-2 bg-white" style="z-index: 1;">
                        <small class="text-muted d-block mb-1">Hızlı Şablonlar:</small>
                        <div class="d-flex flex-nowrap overflow-auto gap-2 pb-1" style="-ms-overflow-style: none; scrollbar-width: none;">
                            @foreach (var s in sablonlar)
                            {
                                <button class="btn btn-outline-secondary btn-sm text-nowrap rounded-pill" @onclick="() => yazilanMesaj = s.Icerik">@s.Baslik</button>
                            }
                        </div>
                    </div>
                }

                <!-- Mesaj Yazma Alanı -->
                <div class="p-2 d-flex align-items-end gap-2" style="z-index: 1; background-color: #f0f2f5;">
                    <div class="d-flex text-muted mb-2 ms-2 gap-3" style="font-size: 1.4rem;">
                        <i class="bi bi-emoji-smile" style="cursor: pointer;"></i>
                        <i class="bi bi-paperclip" style="cursor: pointer;" title="Dosya Ekle (Yakında)"></i>
                        <i class="bi bi-journal-text" style="cursor: pointer;" @onclick="() => showSablonYonetimModal = true" title="Şablonlar"></i>
                    </div>
                    
                    <div class="flex-grow-1 bg-white rounded-3 shadow-sm d-flex align-items-center mx-2 mb-1">
                        <textarea class="form-control border-0 bg-transparent shadow-none px-3 py-2" 
                                  placeholder="Bir mesaj yazın" 
                                  style="resize: none; overflow-y: auto; max-height: 150px; min-height: 42px;"
                                  rows="@Math.Min(5, Math.Max(1, yazilanMesaj.Split('\n').Length))"
                                  @bind="yazilanMesaj" @bind:event="oninput" @onkeydown="KlavyeGonder" id="chatInput"></textarea>
                    </div>
                    
                    <div class="me-2 mb-2">
                        @if (string.IsNullOrWhiteSpace(yazilanMesaj))
                        {
                            <button class="btn btn-link text-muted p-0 shadow-none border-0" disabled>
                                <i class="bi bi-mic-fill" style="font-size: 1.4rem;"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-link text-muted p-0 shadow-none border-0" @onclick="MesajGonder" disabled="@isSending">
                                @if (isSending)
                                {
                                    <span class="spinner-border spinner-border-sm text-success"></span>
                                }
                                else
                                {
                                    <i class="bi bi-send-fill" style="font-size: 1.4rem;"></i>
                                }
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Seçimsiz Boş Durum -->
                <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted" style="z-index: 1;">
                    <i class="bi bi-whatsapp opacity-25" style="font-size: 8rem;"></i>
                    <h4 class="mt-4 fw-light text-dark">Filo CRM WhatsApp</h4>
                    <p>Sohbet başlatmak için sol taraftan bir kişi veya grup seçin.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ================= MODALS ================= -->

<!-- Yeni Kişi Modal -->
@if (showYeniKisiModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Yeni Kişi Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showYeniKisiModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Ad Soyad</label>
                        <input type="text" class="form-control" @bind="yeniKisi.AdSoyad" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telefon (Örn: 905XXXXXXXXX)</label>
                        <input type="text" class="form-control" @bind="yeniKisi.Telefon" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notlar</label>
                        <textarea class="form-control" @bind="yeniKisi.Notlar"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showYeniKisiModal = false">İptal</button>
                    <button type="button" class="btn btn-success" @onclick="KisiKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni Grup Modal -->
@if (showYeniGrupModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Yeni Grup Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showYeniGrupModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Grup Adı</label>
                        <input type="text" class="form-control" @bind="yeniGrup.GrupAdi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <input type="text" class="form-control" @bind="yeniGrup.Aciklama" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showYeniGrupModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="GrupKaydet">Oluştur</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Grup Üyeleri Yönetim Modal -->
@if (showGrupUyeleriModal && seciliGrup != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">@seciliGrup.GrupAdi - Üyeler</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showGrupUyeleriModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="p-3 border-bottom bg-light">
                        <label class="form-label small fw-bold">Yeni Üye Ekle</label>
                        <div class="input-group">
                            <select class="form-select" @bind="eklenecekKisiId">
                                <option value="0">Kişi Seçin...</option>
                                @foreach (var k in kisiler.Where(k => !seciliGrup.Uyeler.Any(u => u.KisiId == k.Id)))
                                {
                                    <option value="@k.Id">@k.AdSoyad</option>
                                }
                            </select>
                            <button class="btn btn-success" @onclick="GrubaKisiEkle"><i class="bi bi-plus-lg"></i> Ekle</button>
                        </div>
                    </div>
                    <ul class="list-group list-group-flush">
                        @if (!seciliGrup.Uyeler.Any())
                        {
                            <li class="list-group-item text-center text-muted py-4">Grupta henüz üye yok.</li>
                        }
                        @foreach (var uye in seciliGrup.Uyeler)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">@uye.Kisi?.AdSoyad</h6>
                                    <small class="text-muted">@uye.Kisi?.Telefon</small>
                                </div>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => GruptanKisiCikar(uye.KisiId)">
                                    Çıkar
                                </button>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showGrupUyeleriModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Şablon Seçim Modal -->
@if (showSablonYonetimModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title">Mesaj Şablonları</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="SablonModalKapat"></button>
                </div>
                <div class="modal-body p-0">
                    @if (!sablonlar.Any())
                    {
                        <div class="p-4 text-center text-muted">Kayıtlı şablon bulunamadı.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var sablon in sablonlar)
                            {
                                <button type="button" class="list-group-item list-group-item-action text-start" @onclick="() => SablonSec(sablon)">
                                    <div class="fw-semibold">@sablon.Baslik</div>
                                    <small class="text-muted d-block mt-1">@sablon.Icerik</small>
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="SablonModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    // Scroll chat to bottom
    window.scrollToBottom = (elementId) => {
        var element = document.getElementById(elementId);
        if (element) {
            element.scrollTop = element.scrollHeight;
        }
    }
</script>

@code {
    private List<WhatsAppKisi> kisiler = new();
    private List<WhatsAppGrup> gruplar = new();
    private List<WhatsAppSablon> sablonlar = new();
    private List<WhatsAppMesaj> aktifMesajlar = new();

    private bool isLoading = true;
    private bool isMessagesLoading = false;
    private bool isSending = false;

    private string aktifTab = "kisiler";
    private string aramaMetni = "";
    private string yazilanMesaj = "";

    private bool grupModu => aktifTab == "gruplar";
    private WhatsAppKisi? seciliKisi;
    private WhatsAppGrup? seciliGrup;

    // Modals
    private bool showYeniKisiModal = false;
    private WhatsAppKisi yeniKisi = new();

    private bool showYeniGrupModal = false;
    private WhatsAppGrup yeniGrup = new();

    private bool showGrupUyeleriModal = false;
    private int eklenecekKisiId = 0;

    private bool showSablonYonetimModal = false;
    private int? aktifKullaniciId;

    protected override async Task OnInitializedAsync()
    {
        var kullanici = AuthProvider.GetAktifKullanici();
        aktifKullaniciId = kullanici?.Id;

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            kisiler = await WhatsAppService.GetKisilerAsync();
            gruplar = await WhatsAppService.GetGruplarAsync();
            sablonlar = await WhatsAppService.GetSablonlarAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Veriler yüklenemedi: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<WhatsAppKisi> FiltreliKisiler()
    {
        if (string.IsNullOrWhiteSpace(aramaMetni)) return kisiler;
        return kisiler.Where(k => 
            k.AdSoyad.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) || 
            (k.Telefon != null && k.Telefon.Contains(aramaMetni)));
    }

    private IEnumerable<WhatsAppGrup> FiltreliGruplar()
    {
        if (string.IsNullOrWhiteSpace(aramaMetni)) return gruplar;
        return gruplar.Where(g => g.GrupAdi.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase));
    }

    private async Task KisiSec(WhatsAppKisi kisi)
    {
        seciliKisi = kisi;
        seciliGrup = null;
        await MesajlariYukle();
    }

    private async Task GrupSec(WhatsAppGrup grup)
    {
        seciliGrup = grup;
        seciliKisi = null;
        await MesajlariYukle();
    }

    private async Task MesajlariYukle()
    {
        isMessagesLoading = true;
        try
        {
            if (seciliKisi != null)
            {
                aktifMesajlar = await WhatsAppService.GetMesajlarByKisiAsync(seciliKisi.Id);
                await WhatsAppService.MesajlariOkunduIsaretleAsync(kisiId: seciliKisi.Id);
            }
            else if (seciliGrup != null)
            {
                aktifMesajlar = await WhatsAppService.GetMesajlarByGrupAsync(seciliGrup.Id);
                await WhatsAppService.MesajlariOkunduIsaretleAsync(grupId: seciliGrup.Id);
            }
        }
        finally
        {
            isMessagesLoading = false;
            // ScrollToBottom is handled via JS
        }
    }

    private async Task MesajGonder()
    {
        if (string.IsNullOrWhiteSpace(yazilanMesaj)) return;

        isSending = true;
        try
        {
            if (seciliKisi != null)
            {
                var yeni = await WhatsAppService.SendMesajToKisiAsync(seciliKisi.Id, yazilanMesaj, aktifKullaniciId);
                aktifMesajlar.Add(yeni);
            }
            else if (seciliGrup != null)
            {
                var yeni = await WhatsAppService.SendMesajToGrupAsync(seciliGrup.Id, yazilanMesaj, aktifKullaniciId);
                aktifMesajlar.Add(yeni);
            }
            yazilanMesaj = "";
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task KlavyeGonder(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await MesajGonder();
        }
    }

