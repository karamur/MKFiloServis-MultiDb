    private async Task CariAktar()
    {
        try
        {
            var cariler = await CariService.GetAllAsync();
            var telefonluCariler = cariler.Where(c => !string.IsNullOrWhiteSpace(c.Telefon)).Select(c => c.Id).ToList();

            if (!telefonluCariler.Any())
            {
                ToastService.ShowWarning("Telefon numarası kayıtlı cari bulunamadı.");
                return;
            }

            await WhatsAppService.SeciliCarilerdenKisiOlustur(telefonluCariler);
            await LoadDataAsync(); // Listeyi yenile
            ToastService.ShowSuccess($"{telefonluCariler.Count} cari WhatsApp kişilerine aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Aktarım sırasında hata oluştu: " + ex.Message);
        }
    }

    private async Task RehberdenAktar(string kaynak)
    {
        try
        {
            var eklenecekKisiler = await WhatsAppAktarilacakKisileriOlustur(kaynak);
            if (!eklenecekKisiler.Any())
            {
                ToastService.ShowWarning("Aktarılacak uygun telefon kaydı bulunamadı.");
                return;
            }

            var eklenenSayi = await WhatsAppService.KisileriSenkronizeEtAsync(eklenecekKisiler);
            await LoadDataAsync();

            if (eklenenSayi == 0)
            {
                ToastService.ShowInfo("Tüm kayıtlar zaten WhatsApp rehberinde mevcut.");
                return;
            }

            ToastService.ShowSuccess($"{eklenenSayi} kişi WhatsApp rehberine aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Aktarım sırasında hata oluştu: " + ex.Message);
        }
    }

    private async Task<List<WhatsAppKisi>> WhatsAppAktarilacakKisileriOlustur(string kaynak)
    {
        var cariler = await DbContext.Cariler
            .Where(c => c.Aktif && !string.IsNullOrWhiteSpace(c.Telefon))
            .ToListAsync();

        var kullanicilar = await DbContext.Kullanicilar
            .Include(k => k.Sofor)
            .Where(k => k.Aktif)
            .ToListAsync();

        var personeller = await DbContext.Soforler
            .Where(s => s.Aktif && !string.IsNullOrWhiteSpace(s.Telefon))
            .ToListAsync();

        var eslestirmeler = await DbContext.KullaniciCariler
            .Include(x => x.Cari)
            .Where(x => x.Cari.Aktif)
            .ToListAsync();

        var sonuc = new List<WhatsAppKisi>();
        var cariBagliKullanicilar = eslestirmeler.Select(x => x.KullaniciId).ToHashSet();
        var personelBagliKullanicilar = kullanicilar.Where(k => k.SoforId.HasValue).Select(k => k.Id).ToHashSet();
        var eslenmisPersonelIdleri = kullanicilar
            .Where(k => k.SoforId.HasValue && cariBagliKullanicilar.Contains(k.Id))
            .Select(k => k.SoforId!.Value)
            .ToHashSet();

        if (kaynak is "cari" or "tum")
        {
            sonuc.AddRange(cariler.Select(cari => new WhatsAppKisi
            {
                AdSoyad = cari.Unvan,
                Telefon = cari.Telefon!.Trim(),
                CariId = cari.Id,
                Notlar = "Cari rehber aktarımı"
            }));
        }

        if (kaynak is "personel" or "tum")
        {
            sonuc.AddRange(personeller
                .Where(p => !eslenmisPersonelIdleri.Contains(p.Id))
                .Select(personel => new WhatsAppKisi
                {
                    AdSoyad = personel.TamAd,
                    Telefon = personel.Telefon!.Trim(),
                    Notlar = "Personel rehber aktarımı"
                }));
        }

        if (kaynak is "kullanici" or "tum")
        {
            sonuc.AddRange(kullanicilar
                .Where(k => !cariBagliKullanicilar.Contains(k.Id) && !personelBagliKullanicilar.Contains(k.Id))
                .Where(k => !string.IsNullOrWhiteSpace(k.Telefon))
                .Select(kullanici => new WhatsAppKisi
                {
                    AdSoyad = kullanici.AdSoyad,
                    Telefon = kullanici.Telefon!.Trim(),
                    Notlar = "Kullanıcı rehber aktarımı"
                }));
        }

        return sonuc;
    }

    private string GetAvatarColor(string name)
    {
        var colors = new[] { "#ff7a59", "#3bc14a", "#6a5acd", "#d33a2c", "#00bfa5", "#ff4500", "#1e90ff", "#ff1493" };
        int sum = 0;
        foreach (char c in name ?? "A") sum += c;
        return colors[sum % colors.Length];
    }
