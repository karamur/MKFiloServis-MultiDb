@page "/crm/whatsapp"
@page "/crm/email"
@using System.Text.Json
@using MKFiloServis.Web.Services
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ICRMService CRMService
@inject ICariService CariService
@inject ApplicationDbContext DbContext
@inject AppAuthenticationStateProvider AuthProvider
@inject IToastService ToastService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

@{
    var isWhatsApp = NavigationManager.Uri.Contains("/whatsapp");
    var pageTitle = isWhatsApp ? "WhatsApp" : "E-Posta";
    var pageIcon = isWhatsApp ? "bi-whatsapp" : "bi-envelope-fill";
    var iconColor = isWhatsApp ? "text-success" : "text-info";
}

<PageTitle>@pageTitle - CRM</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0"><i class="bi @pageIcon me-2 @iconColor"></i>@pageTitle</h3>
            <small class="text-muted">@(isWhatsApp ? "WhatsApp mesajları gönderin" : "E-posta gönderin")</small>
        </div>
        <button class="btn btn-outline-secondary" @onclick="AyarlariAc">
            <i class="bi bi-gear me-1"></i>Ayarlar
        </button>
    </div>

    <div class="row">
        <!-- Sol Panel - Hızlı Gönderim -->
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-send me-2"></i>Yeni @pageTitle Gönder</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Alıcı</label>

                        @if (isWhatsApp)
                        {
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="topluGonderimCheck" @bind="topluGonderim" />
                                <label class="form-check-label" for="topluGonderimCheck">Kişilere toplu gönderim</label>
                            </div>
                        }

                        @if (isWhatsApp && topluGonderim)
                        {
                            <div class="border rounded p-2 bg-light">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">İletişim bilgisi olan kayıtlar arasından seçim yapın</small>
                                    <div class="d-flex gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="TumKisileriSec">Tümünü Seç</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SecimleriTemizle">Temizle</button>
                                    </div>
                                </div>
                                <div style="max-height: 220px; overflow-y: auto;">
                                    @foreach (var alici in TopluAliciSecenekleri.OrderBy(c => c.SiralamaAd))
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="alici_@alici.Anahtar"
                                                   checked="@secilenAliciAnahtarlari.Contains(alici.Anahtar)"
                                                   @onchange="(e => AliciSecimDegisti(alici.Anahtar, e.Value))" />
                                            <label class="form-check-label d-flex justify-content-between w-100" for="alici_@alici.Anahtar">
                                                <span>@alici.Etiket</span>
                                                <small class="text-muted">@alici.Adres</small>
                                            </label>
                                        </div>
                                    }
                                </div>
                                <div class="mt-2 small text-muted">Seçilen kişi: @secilenAliciAnahtarlari.Count</div>
                            </div>
                        }
                        else
                        {
                            <div class="input-group">
                                <select class="form-select" @bind="secilenAliciAnahtari" @bind:after="AliciSecildi">
                                    <option value="">Alıcı seçin...</option>
                                    @foreach (var alici in TekilAliciSecenekleri.OrderBy(c => c.SiralamaAd))
                                    {
                                        <option value="@alici.Anahtar">@alici.Etiket</option>
                                    }
                                </select>
                            </div>
                            <small class="text-muted">Cari ve kullanıcı eşleşmişse yalnız cari hesap listelenir.</small>
                            <input type="text" class="form-control mt-1" 
                                   @bind="aliciAdres" 
                                   placeholder="@(isWhatsApp ? "Telefon numarası (5XX XXX XX XX)" : "E-posta adresi")" />
                        }
                    </div>

                    @if (!isWhatsApp)
                    {
                        <div class="mb-3">
                            <label class="form-label">Konu</label>
                            <input type="text" class="form-control" @bind="konu" placeholder="E-posta konusu" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Mesaj</label>
                        <textarea class="form-control" rows="5" @bind="mesajIcerik" placeholder="Mesajınızı yazın..."></textarea>
                    </div>

                    <!-- Hızlı Şablonlar -->
                    <div class="mb-3">
                        <label class="form-label small text-muted">Hızlı Şablonlar</label>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SablonUygula("Merhaba, siparişiniz hazırlanmıştır.")'>
                                Sipariş Hazır
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SablonUygula("Ödeme hatırlatması: Vadesi geçmiş faturanız bulunmaktadır.")'>
                                Ödeme Hatırlatma
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SablonUygula("Randevunuz için teşekkür ederiz. Görüşmek üzere.")'>
                                Randevu Onay
                            </button>
                        </div>

                        @if (isWhatsApp)
                        {
                            <div class="row g-2 mb-2">
                                <div class="col-md-4">
                                    <input type="text" class="form-control form-control-sm" @bind="yeniSablonBaslik" placeholder="Şablon adı" />
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control form-control-sm" @bind="yeniSablonIcerik" placeholder="Şablon metni" />
                                </div>
                                <div class="col-md-2 d-grid">
                                    <button type="button" class="btn btn-sm btn-success" @onclick="HizliSablonKaydet">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                            </div>

                            @if (hizliSablonlar.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var sablon in hizliSablonlar)
                                    {
                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="btn btn-outline-success" @onclick="() => SablonUygula(sablon.Icerik)">@sablon.Baslik</button>
                                            <button type="button" class="btn btn-outline-danger" title="Sil" @onclick="() => HizliSablonSil(sablon)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="text-end">
                        <button class="btn btn-primary" @onclick="MesajGonder" disabled="@isSending">
                            @if (isSending)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-send me-1"></i>Gönder
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ Panel - Gönderim Geçmişi -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>@(isWhatsApp ? "Gönderim Geçmişi" : "E-Posta Listesi")</h6>
                    @if (!isWhatsApp)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="EmailListeleriniYenile">
                            <i class="bi bi-arrow-clockwise me-1"></i>Yenile
                        </button>
                    }
                </div>
                @if (!isWhatsApp)
                {
                    <div class="card-header bg-light p-0">
                        <ul class="nav nav-tabs card-header-tabs ms-2 mt-2">
                            <li class="nav-item">
                                <button class="nav-link @(emailListeTab == "gonderilen" ? "active" : "")" @onclick='() => emailListeTab = "gonderilen"'>Gönderilen</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link @(emailListeTab == "gelen" ? "active" : "")" @onclick='() => emailListeTab = "gelen"'>Gelen</button>
                            </li>
                        </ul>
                    </div>
                }
                <div class="card-body p-0">
                    @if (isLoading)
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary"></div>
                        </div>
                    }
                    else if (isWhatsApp && !gonderilenMesajlar.Any())
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="bi @pageIcon" style="font-size: 3rem;"></i>
                            <p class="mt-2">Henüz @pageTitle mesajı gönderilmemiş</p>
                        </div>
                    }
                    else if (!isWhatsApp && !AktifEmailListesi.Any())
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="bi bi-envelope" style="font-size: 3rem;"></i>
                            <p class="mt-2">@(emailListeTab == "gelen" ? "Gelen e-posta bulunamadı" : "Gönderilen e-posta bulunamadı")</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            @if (isWhatsApp)
                            {
                                <table class="table table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Alıcı</th>
                                            <th>Durum</th>
                                            <th>Mesaj</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var mesaj in gonderilenMesajlar)
                                        {
                                            <tr>
                                                <td><small>@mesaj.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small></td>
                                                <td><strong>@mesaj.DisAlici</strong></td>
                                                <td>
                                                    <span class="badge @GetDurumBadge(mesaj.Durum)">@GetDurumAdi(mesaj.Durum)</span>
                                                </td>
                                                <td><small class="text-muted">@(mesaj.Icerik.Length > 50 ? mesaj.Icerik[..50] + "..." : mesaj.Icerik)</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <table class="table table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>@(emailListeTab == "gelen" ? "Kimden" : "Kime")</th>
                                            <th>Konu</th>
                                            <th>Durum</th>
                                            <th>Özet</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var mail in AktifEmailListesi)
                                        {
                                            <tr class="@(!mail.Okundu && emailListeTab == "gelen" ? "table-light" : "")">
                                                <td><small>@mail.Tarih.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small></td>
                                                <td><strong>@(emailListeTab == "gelen" ? mail.Kimden : mail.Kime)</strong></td>
                                                <td>@mail.Baslik</td>
                                                <td>
                                                    <span class="badge @(mail.GelenMi ? (mail.Okundu ? "bg-success" : "bg-warning text-dark") : GetDurumBadge(mail.Durum))">
                                                        @(mail.GelenMi ? (mail.Okundu ? "Okundu" : "Yeni") : GetDurumAdi(mail.Durum))
                                                    </span>
                                                </td>
                                                <td><small class="text-muted">@mail.Ozet</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ayarlar Modal -->
@if (showAyarModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi @pageIcon me-2"></i>@pageTitle Ayarları
                    </h5>
                    <button type="button" class="btn-close" @onclick="AyarModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (isWhatsApp)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            WhatsApp Business API entegrasyonu için API anahtarı gereklidir.
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telefon Numarası</label>
                            <input type="text" class="form-control" @bind="whatsappAyar!.Telefon" placeholder="5XXXXXXXXX" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">API Anahtarı</label>
                            <input type="password" class="form-control" @bind="whatsappAyar.ApiKey" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Webhook URL (Opsiyonel)</label>
                            <input type="text" class="form-control" @bind="whatsappAyar.WebhookUrl" />
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="whatsappAyar.Aktif" />
                            <label class="form-check-label">Aktif</label>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">SMTP Sunucu</label>
                            <input type="text" class="form-control" @bind="emailAyar!.SmtpSunucu" placeholder="smtp.gmail.com" />
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">SMTP Port</label>
                                    <input type="number" class="form-control" @bind="emailAyar.SmtpPort" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">SMTP SSL</label>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" @bind="emailAyar.SslKullan" />
                                        <label class="form-check-label">SSL Kullan</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">IMAP Sunucu</label>
                                    <input type="text" class="form-control" @bind="emailAyar.ImapSunucu" placeholder="imap.gmail.com" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">IMAP Port</label>
                                    <input type="number" class="form-control" @bind="emailAyar.ImapPort" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Gelen Klasörü</label>
                                    <input type="text" class="form-control" @bind="emailAyar.GelenKlasoru" placeholder="INBOX" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">IMAP SSL</label>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" @bind="emailAyar.ImapSslKullan" />
                                        <label class="form-check-label">SSL Kullan</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-Posta Adresi</label>
                            <input type="email" class="form-control" @bind="emailAyar.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Şifre / Uygulama Şifresi</label>
                            <input type="password" class="form-control" @bind="emailAyar.Sifre" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Gönderen Adı</label>
                            <input type="text" class="form-control" @bind="emailAyar.GonderenAdi" placeholder="CRM Filo Servis" />
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="emailAyar.GelenKutusuAktif" />
                            <label class="form-check-label">Gelen kutusu senkronizasyonu aktif</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="emailAyar.Aktif" />
                            <label class="form-check-label">Aktif</label>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="AyarModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="AyarlariKaydet" disabled="@isSavingAyar">
                        @if (isSavingAyar)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isSending = false;
    private bool isSavingAyar = false;
    private bool showAyarModal = false;
    private bool topluGonderim = false;
    private List<Cari> cariler = new();
    private List<Mesaj> gonderilenMesajlar = new();
    private List<EmailListeItem> gonderilenEmailListesi = new();
    private List<EmailListeItem> gelenEmailListesi = new();
    private List<IletisimAliciSecenegi> aliciSecenekleri = new();
    private List<string> secilenAliciAnahtarlari = new();
    private List<HizliSablonModel> hizliSablonlar = new();
    private int? aktifKullaniciId;
    private string emailListeTab = "gonderilen";

    // Gönderim
    private string secilenAliciAnahtari = "";
    private string aliciAdres = "";
    private string konu = "";
    private string mesajIcerik = "";
    private string yeniSablonBaslik = "";
    private string yeniSablonIcerik = "";

    // Ayarlar
    private EmailAyar? emailAyar;
    private WhatsAppAyar? whatsappAyar;

    private bool IsWhatsApp => NavigationManager.Uri.Contains("/whatsapp");
    private List<EmailListeItem> AktifEmailListesi => emailListeTab == "gelen" ? gelenEmailListesi : gonderilenEmailListesi;
    private IEnumerable<IletisimAliciSecenegi> TekilAliciSecenekleri => aliciSecenekleri.Where(x => !string.IsNullOrWhiteSpace(IsWhatsApp ? x.Telefon : x.Email));
    private IEnumerable<IletisimAliciSecenegi> TopluAliciSecenekleri => aliciSecenekleri.Where(x => !string.IsNullOrWhiteSpace(x.Telefon));

    protected override async Task OnInitializedAsync()
    {
        var kullanici = AuthProvider.GetAktifKullanici();
        if (kullanici != null)
        {
            aktifKullaniciId = kullanici.Id;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            cariler = await CariService.GetAllAsync();
            await AliciSecenekleriniYukle();

            if (aktifKullaniciId.HasValue)
            {
                if (IsWhatsApp)
                {
                    var tumMesajlar = await CRMService.GetGonderilenMesajlarAsync(aktifKullaniciId.Value);
                    gonderilenMesajlar = tumMesajlar
                        .Where(m => m.Tip == MesajTipi.WhatsApp)
                        .OrderByDescending(m => m.CreatedAt)
                        .Take(50)
                        .ToList();

                    whatsappAyar = await CRMService.GetWhatsAppAyarAsync(aktifKullaniciId) ?? new WhatsAppAyar
                    {
                        KullaniciId = aktifKullaniciId,
                        Aktif = false
                    };
                    HizliSablonlariYukle();
                }
                else
                {
                    emailAyar = await CRMService.GetEmailAyarAsync(aktifKullaniciId) ?? new EmailAyar
                    {
                        KullaniciId = aktifKullaniciId,
                        SmtpPort = 587,
                        SslKullan = true,
                        ImapPort = 993,
                        ImapSslKullan = true,
                        GelenKlasoru = "INBOX",
                        Aktif = false
                    };

                    await EmailListeleriniYenile();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Veriler yüklenirken hata: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task EmailListeleriniYenile()
    {
        if (!aktifKullaniciId.HasValue)
        {
            return;
        }

        gonderilenEmailListesi = await CRMService.GetGonderilenEmailListAsync(aktifKullaniciId.Value);
        gelenEmailListesi = await CRMService.GetGelenEmailListAsync(aktifKullaniciId.Value);
    }

    private async Task AliciSecenekleriniYukle()
    {
        var kullanicilar = await DbContext.Kullanicilar
            .Include(k => k.Sofor)
            .Where(k => k.Aktif)
            .ToListAsync();

        var personeller = await DbContext.Soforler
            .Where(s => s.Aktif)
            .ToListAsync();

        var eslestirmeler = await DbContext.KullaniciCariler
            .Include(x => x.Cari)
            .Where(x => x.Cari.Aktif)
            .ToListAsync();

        var secenekler = new List<IletisimAliciSecenegi>();
        var cariBagliKullanicilar = eslestirmeler
            .Select(x => x.KullaniciId)
            .ToHashSet();

        var personelBagliKullanicilar = kullanicilar
            .Where(k => k.SoforId.HasValue)
            .Select(k => k.Id)
            .ToHashSet();

        foreach (var cari in cariler.Where(c => c.Aktif))
        {
            secenekler.Add(new IletisimAliciSecenegi
            {
                Anahtar = $"cari:{cari.Id}",
                Etiket = $"{cari.Unvan} (Cari)",
                SiralamaAd = cari.Unvan,
                Telefon = cari.Telefon,
                Email = cari.Email,
                Adres = IsWhatsApp ? (cari.Telefon ?? string.Empty) : (cari.Email ?? string.Empty)
            });
        }

        var eslenmisPersonelIdleri = kullanicilar
            .Where(k => k.SoforId.HasValue && cariBagliKullanicilar.Contains(k.Id))
            .Select(k => k.SoforId!.Value)
            .ToHashSet();

        foreach (var personel in personeller.Where(s => !eslenmisPersonelIdleri.Contains(s.Id)))
        {
            secenekler.Add(new IletisimAliciSecenegi
            {
                Anahtar = $"personel:{personel.Id}",
                Etiket = $"{personel.TamAd} (Personel)",
                SiralamaAd = personel.TamAd,
                Telefon = personel.Telefon,
                Email = personel.Email,
                Adres = IsWhatsApp ? (personel.Telefon ?? string.Empty) : (personel.Email ?? string.Empty)
            });
        }

        foreach (var kullanici in kullanicilar.Where(k => !cariBagliKullanicilar.Contains(k.Id) && !personelBagliKullanicilar.Contains(k.Id)))
        {
            secenekler.Add(new IletisimAliciSecenegi
            {
                Anahtar = $"kullanici:{kullanici.Id}",
                Etiket = $"{kullanici.AdSoyad} (Kullanıcı)",
                SiralamaAd = kullanici.AdSoyad,
                Telefon = kullanici.Telefon,
                Email = kullanici.Email,
                Adres = IsWhatsApp ? (kullanici.Telefon ?? string.Empty) : (kullanici.Email ?? string.Empty)
            });
        }

        aliciSecenekleri = secenekler;
    }

    private void AliciSecildi()
    {
        var secenek = TekilAliciSecenekleri.FirstOrDefault(c => c.Anahtar == secilenAliciAnahtari);
        if (secenek != null)
        {
            aliciAdres = IsWhatsApp ? (secenek.Telefon ?? string.Empty) : (secenek.Email ?? string.Empty);
        }
    }

    private void AliciSecimDegisti(string aliciAnahtari, object? value)
    {
        var secili = value as bool? == true;
        if (secili)
        {
            if (!secilenAliciAnahtarlari.Contains(aliciAnahtari))
            {
                secilenAliciAnahtarlari.Add(aliciAnahtari);
            }
        }
        else
        {
            secilenAliciAnahtarlari.Remove(aliciAnahtari);
        }
    }

    private void TumKisileriSec()
    {
        secilenAliciAnahtarlari = TopluAliciSecenekleri
            .Select(c => c.Anahtar)
            .ToList();
    }

    private void SecimleriTemizle()
    {
        secilenAliciAnahtarlari.Clear();
    }

    private void SablonUygula(string sablon)
    {
        mesajIcerik = sablon;
    }

    private void HizliSablonlariYukle()
    {
        if (string.IsNullOrWhiteSpace(whatsappAyar?.HizliSablonlarJson))
        {
            hizliSablonlar = new();
            return;
        }

        try
        {
            hizliSablonlar = JsonSerializer.Deserialize<List<HizliSablonModel>>(whatsappAyar.HizliSablonlarJson) ?? new();
        }
        catch
        {
            hizliSablonlar = new();
        }
    }

    private async Task HizliSablonKaydet()
    {
        if (!IsWhatsApp)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(yeniSablonBaslik) || string.IsNullOrWhiteSpace(yeniSablonIcerik))
        {
            ToastService.ShowWarning("Şablon adı ve içeriği zorunludur.");
            return;
        }

        whatsappAyar ??= await CRMService.GetWhatsAppAyarAsync(aktifKullaniciId) ?? new WhatsAppAyar
        {
            KullaniciId = aktifKullaniciId,
            Aktif = false
        };

        hizliSablonlar.Add(new HizliSablonModel
        {
            Baslik = yeniSablonBaslik.Trim(),
            Icerik = yeniSablonIcerik.Trim()
        });

        whatsappAyar.HizliSablonlarJson = JsonSerializer.Serialize(hizliSablonlar);
        await CRMService.SaveWhatsAppAyarAsync(whatsappAyar);

        yeniSablonBaslik = "";
        yeniSablonIcerik = "";
        ToastService.ShowSuccess("Hızlı şablon kaydedildi.");
    }

    private async Task HizliSablonSil(HizliSablonModel sablon)
    {
        if (whatsappAyar == null)
        {
            return;
        }

        hizliSablonlar.Remove(sablon);
        whatsappAyar.HizliSablonlarJson = JsonSerializer.Serialize(hizliSablonlar);
        await CRMService.SaveWhatsAppAyarAsync(whatsappAyar);
        ToastService.ShowSuccess("Hızlı şablon silindi.");
    }

    private async Task MesajGonder()
    {
        if (string.IsNullOrWhiteSpace(mesajIcerik))
        {
            ToastService.ShowWarning("Mesaj içeriği zorunludur.");
            return;
        }

        isSending = true;
        try
        {
            if (IsWhatsApp && topluGonderim)
            {
                var alicilar = TopluAliciSecenekleri
                    .Where(c => secilenAliciAnahtarlari.Contains(c.Anahtar) && !string.IsNullOrWhiteSpace(c.Telefon))
                    .Select(c => c.Telefon!.Trim())
                    .Distinct()
                    .ToList();

                if (!alicilar.Any())
                {
                    ToastService.ShowWarning("En az bir kişi seçiniz.");
                    return;
                }

                var basariliSayisi = 0;
                foreach (var telefon in alicilar)
                {
                    if (await CRMService.SendWhatsAppAsync(aktifKullaniciId ?? 0, telefon, mesajIcerik))
                    {
                        basariliSayisi++;
                    }
                }

                if (basariliSayisi == alicilar.Count)
                {
                    ToastService.ShowSuccess($"WhatsApp mesajı {basariliSayisi} kişiye gönderildi.");
                }
                else
                {
                    ToastService.ShowWarning($"{basariliSayisi}/{alicilar.Count} kişiye gönderim başarılı oldu.");
                }

                mesajIcerik = "";
                secilenAliciAnahtarlari.Clear();
                await LoadData();
                return;
            }

            if (string.IsNullOrWhiteSpace(aliciAdres))
            {
                ToastService.ShowWarning("Alıcı bilgisi zorunludur.");
                return;
            }

            bool basarili;
            if (IsWhatsApp)
            {
                basarili = await CRMService.SendWhatsAppAsync(aktifKullaniciId ?? 0, aliciAdres, mesajIcerik);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(konu))
                {
                    ToastService.ShowWarning("E-posta konusu zorunludur.");
                    return;
                }
                basarili = await CRMService.SendEmailAsync(aktifKullaniciId ?? 0, aliciAdres, konu, mesajIcerik);
            }

            if (basarili)
            {
                ToastService.ShowSuccess($"{(IsWhatsApp ? "WhatsApp" : "E-posta")} gönderildi.");
                aliciAdres = "";
                konu = "";
                mesajIcerik = "";
                secilenAliciAnahtari = "";
                await LoadData();
            }
            else
            {
                ToastService.ShowError("Gönderim başarısız. Ayarları kontrol edin.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task AyarlariAc()
    {
        if (IsWhatsApp)
        {
            whatsappAyar = await CRMService.GetWhatsAppAyarAsync(aktifKullaniciId) ?? new WhatsAppAyar
            {
                KullaniciId = aktifKullaniciId,
                Aktif = false
            };
        }
        else
        {
            emailAyar = await CRMService.GetEmailAyarAsync(aktifKullaniciId) ?? new EmailAyar
            {
                KullaniciId = aktifKullaniciId,
                SmtpPort = 587,
                SslKullan = true,
                ImapPort = 993,
                ImapSslKullan = true,
                GelenKlasoru = "INBOX",
                Aktif = false
            };
        }
        showAyarModal = true;
    }

    private void AyarModalKapat()
    {
        showAyarModal = false;
    }

    private async Task AyarlariKaydet()
    {
        isSavingAyar = true;
        try
        {
            if (IsWhatsApp && whatsappAyar != null)
            {
                whatsappAyar.HizliSablonlarJson = JsonSerializer.Serialize(hizliSablonlar);
                await CRMService.SaveWhatsAppAyarAsync(whatsappAyar);
            }
            else if (!IsWhatsApp && emailAyar != null)
            {
                await CRMService.SaveEmailAyarAsync(emailAyar);
                await EmailListeleriniYenile();
            }

            ToastService.ShowSuccess("Ayarlar kaydedildi.");
            AyarModalKapat();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSavingAyar = false;
        }
    }

    private string GetDurumAdi(MesajDurum durum) => durum switch
    {
        MesajDurum.Taslak => "Taslak",
        MesajDurum.Gonderildi => "Gönderildi",
        MesajDurum.Iletildi => "İletildi",
        MesajDurum.Okundu => "Okundu",
        MesajDurum.Hata => "Hata",
        _ => "Bilinmiyor"
    };

    private string GetDurumBadge(MesajDurum durum) => durum switch
    {
        MesajDurum.Taslak => "bg-secondary",
        MesajDurum.Gonderildi => "bg-primary",
        MesajDurum.Iletildi => "bg-info",
        MesajDurum.Okundu => "bg-success",
        MesajDurum.Hata => "bg-danger",
        _ => "bg-light text-dark"
    };

