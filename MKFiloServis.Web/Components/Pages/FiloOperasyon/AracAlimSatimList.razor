@page "/filo-operasyon/alim-satim"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IFiloOperasyonService FiloOperasyonService
@inject IAracService AracService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<PageTitle>Araç Alım/Satım | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/filo-operasyon">Filo Operasyon</a></li>
                    <li class="breadcrumb-item active">Araç Alım/Satım</li>
                </ol>
            </nav>
            <h3 class="mb-0">
                <i class="bi bi-cart-plus me-2"></i>Araç Alım/Satım Yönetimi
            </h3>
        </div>
        <div class="btn-group">
            <button class="btn btn-success" @onclick="() => YeniIslem(AracIslemTipiDetay.Alis)">
                <i class="bi bi-box-arrow-in-down me-1"></i> Araç Al
            </button>
            <button class="btn btn-warning" @onclick="() => YeniIslem(AracIslemTipiDetay.Satis)">
                <i class="bi bi-box-arrow-up me-1"></i> Araç Sat
            </button>
        </div>
    </div>

    <!-- Özet Kartları -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6>Toplam Alım</h6>
                    <h4 class="mb-0">@_islemler.Count(i => i.IslemTipi == AracIslemTipiDetay.Alis)</h4>
                    <small>@_islemler.Where(i => i.IslemTipi == AracIslemTipiDetay.Alis).Sum(i => i.ToplamTutar).ToString("N0") ₺</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning">
                <div class="card-body text-center">
                    <h6>Toplam Satış</h6>
                    <h4 class="mb-0">@_islemler.Count(i => i.IslemTipi == AracIslemTipiDetay.Satis)</h4>
                    <small>@_islemler.Where(i => i.IslemTipi == AracIslemTipiDetay.Satis).Sum(i => i.ToplamTutar).ToString("N0") ₺</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6>Noter Bekleyen</h6>
                    <h4 class="mb-0">@_islemler.Count(i => !i.NoterIslemTamam)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h6>Fatura Bekleyen</h6>
                    <h4 class="mb-0">@_islemler.Count(i => i.NoterIslemTamam && !i.FaturaKesildi)</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">İşlem Tipi</label>
                    <select class="form-select" @bind="_filtreIslemTipi">
                        <option value="">Tümü</option>
                        <option value="@AracIslemTipiDetay.Alis">Alış</option>
                        <option value="@AracIslemTipiDetay.Satis">Satış</option>
                        <option value="@AracIslemTipiDetay.Takas">Takas</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Noter Durumu</label>
                    <select class="form-select" @bind="_filtreNoterDurum">
                        <option value="">Tümü</option>
                        <option value="true">Tamamlandı</option>
                        <option value="false">Bekliyor</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fatura Durumu</label>
                    <select class="form-select" @bind="_filtreFaturaDurum">
                        <option value="">Tümü</option>
                        <option value="true">Kesildi</option>
                        <option value="false">Bekliyor</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Başlangıç</label>
                    <input type="date" class="form-control" @bind="_filtreBaslangic" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bitiş</label>
                    <input type="date" class="form-control" @bind="_filtreBitis" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="FiltreTemizle">
                        <i class="bi bi-x-circle me-1"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!_filtrelenmisIslemler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Kayıtlı araç alım/satım işlemi bulunamadı.
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>İşlem</th>
                            <th>Araç</th>
                            <th>Karşı Taraf</th>
                            <th class="text-end">Tutar</th>
                            <th>Noter</th>
                            <th>Fatura</th>
                            <th>Ödeme</th>
                            <th>Belgeler</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var islem in _filtrelenmisIslemler)
                        {
                            <tr>
                                <td>@islem.IslemTarihi.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span class="badge @GetIslemTipiBadge(islem.IslemTipi)">
                                        @GetIslemTipiText(islem.IslemTipi)
                                    </span>
                                </td>
                                <td>
                                    <strong>@(islem.Arac?.AktifPlaka ?? "-")</strong>
                                    <br/>
                                    <small class="text-muted">@islem.Arac?.Marka @islem.Arac?.Model</small>
                                </td>
                                <td>
                                    @(islem.KarsiTarafCari?.Unvan ?? islem.KarsiTarafAdSoyad ?? "-")
                                    @if (!string.IsNullOrEmpty(islem.KarsiTarafTcKimlik))
                                    {
                                        <br/><small class="text-muted">TC: @islem.KarsiTarafTcKimlik</small>
                                    }
                                </td>
                                <td class="text-end fw-bold">
                                    @islem.ToplamTutar.ToString("N2") ₺
                                    @if (islem.KDVTutari > 0)
                                    {
                                        <br/><small class="text-muted">KDV: @islem.KDVTutari.ToString("N2") ₺</small>
                                    }
                                </td>
                                <td>
                                    @if (islem.NoterIslemTamam)
                                    {
                                        <i class="bi bi-check-circle-fill text-success" title="Noter tamamlandı"></i>
                                        <small class="d-block text-muted">@islem.NoterTarihi?.ToString("dd.MM")</small>
                                    }
                                    else
                                    {
                                        <i class="bi bi-clock text-warning" title="Noter bekliyor"></i>
                                    }
                                </td>
                                <td>
                                    @if (islem.FaturaKesildi)
                                    {
                                        <span class="badge @GetFaturaUyumBadge(islem.FaturaUyumu)">
                                            @GetFaturaUyumText(islem.FaturaUyumu)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Kesilmedi</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @GetOdemeDurumBadge(islem.OdemeDurum)">
                                        @GetOdemeDurumText(islem.OdemeDurum)
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var eksikBelgeSayisi = GetEksikBelgeSayisi(islem);
                                    }
                                    @if (eksikBelgeSayisi == 0)
                                    {
                                        <i class="bi bi-check-all text-success" title="Tüm belgeler tamam"></i>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">@eksikBelgeSayisi eksik</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/filo-operasyon/alim-satim/@islem.Id" class="btn btn-outline-primary" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/filo-operasyon/alim-satim/@islem.Id/duzenle" class="btn btn-outline-secondary" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<AracAlimSatim> _islemler = new();

    // Filtreler
    private AracIslemTipiDetay? _filtreIslemTipi;
    private bool? _filtreNoterDurum;
    private bool? _filtreFaturaDurum;
    private DateTime? _filtreBaslangic;
    private DateTime? _filtreBitis;

    private List<AracAlimSatim> _filtrelenmisIslemler => _islemler
        .Where(i => !_filtreIslemTipi.HasValue || i.IslemTipi == _filtreIslemTipi.Value)
        .Where(i => !_filtreNoterDurum.HasValue || i.NoterIslemTamam == _filtreNoterDurum.Value)
        .Where(i => !_filtreFaturaDurum.HasValue || i.FaturaKesildi == _filtreFaturaDurum.Value)
        .Where(i => !_filtreBaslangic.HasValue || i.IslemTarihi >= _filtreBaslangic.Value)
        .Where(i => !_filtreBitis.HasValue || i.IslemTarihi <= _filtreBitis.Value)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _islemler = await FiloOperasyonService.GetAracAlimSatimlarAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void YeniIslem(AracIslemTipiDetay tip)
    {
        NavigationManager.NavigateTo($"/filo-operasyon/alim-satim/yeni?tip={tip.ToString().ToLower()}");
    }

    private void FiltreTemizle()
    {
        _filtreIslemTipi = null;
        _filtreNoterDurum = null;
        _filtreFaturaDurum = null;
        _filtreBaslangic = null;
        _filtreBitis = null;
    }

    private int GetEksikBelgeSayisi(AracAlimSatim islem)
    {
        var eksik = 0;
        if (!islem.RuhsatTeslimAlindi) eksik++;
        if (!islem.SigortaTeslimAlindi) eksik++;
        if (!islem.MuayeneBelgesiTeslimAlindi) eksik++;
        if (!islem.AnahtarTeslimAlindi) eksik++;
        return eksik;
    }

    private string GetIslemTipiText(AracIslemTipiDetay tip) => tip switch
    {
        AracIslemTipiDetay.Alis => "Alış",
        AracIslemTipiDetay.Satis => "Satış",
        AracIslemTipiDetay.Takas => "Takas",
        AracIslemTipiDetay.SatisYerineAlim => "Satış+Alım",
        _ => tip.ToString()
    };

    private string GetIslemTipiBadge(AracIslemTipiDetay tip) => tip switch
    {
        AracIslemTipiDetay.Alis => "bg-success",
        AracIslemTipiDetay.Satis => "bg-warning text-dark",
        AracIslemTipiDetay.Takas => "bg-info",
        AracIslemTipiDetay.SatisYerineAlim => "bg-primary",
        _ => "bg-secondary"
    };

    private string GetFaturaUyumText(FaturaUyumsuzlukDurum durum) => durum switch
    {
        FaturaUyumsuzlukDurum.Uyumlu => "Uyumlu",
        FaturaUyumsuzlukDurum.Beklemede => "Beklemede",
        FaturaUyumsuzlukDurum.TutarFarkli => "Tutar Farklı",
        FaturaUyumsuzlukDurum.KdvFarkli => "KDV Farklı",
        FaturaUyumsuzlukDurum.BelgeEksik => "Belge Eksik",
        _ => "Kontrol Gerekli"
    };

    private string GetFaturaUyumBadge(FaturaUyumsuzlukDurum durum) => durum switch
    {
        FaturaUyumsuzlukDurum.Uyumlu => "bg-success",
        FaturaUyumsuzlukDurum.Beklemede => "bg-warning text-dark",
        _ => "bg-danger"
    };

    private string GetOdemeDurumText(AracIslemOdemeDurum durum) => durum switch
    {
        AracIslemOdemeDurum.TamOdendi => "Ödendi",
        AracIslemOdemeDurum.KismiOdendi => "Kısmi",
        AracIslemOdemeDurum.Beklemede => "Beklemede",
        AracIslemOdemeDurum.Vadeli => "Vadeli",
        AracIslemOdemeDurum.IptalEdildi => "İptal",
        _ => durum.ToString()
    };

    private string GetOdemeDurumBadge(AracIslemOdemeDurum durum) => durum switch
    {
        AracIslemOdemeDurum.TamOdendi => "bg-success",
        AracIslemOdemeDurum.KismiOdendi => "bg-warning text-dark",
        AracIslemOdemeDurum.Beklemede => "bg-secondary",
        AracIslemOdemeDurum.Vadeli => "bg-info",
        _ => "bg-secondary"
    };
}

