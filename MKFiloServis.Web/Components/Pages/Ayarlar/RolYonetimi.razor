@page "/ayarlar/roller"
@using MKFiloServis.Web.Services
@using MKFiloServis.Shared.Entities
@using YetkilerClass = MKFiloServis.Shared.Entities.Yetkiler
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Rol Yonetimi - CRM Filo Servis</PageTitle>

<MKFiloServis.Web.Components.Shared.YetkiKontrol Yetki="@YetkilerClass.RolYonetimiOku" GerekliYetkiAdi="Rol Yönetimi">
    <Yetkili>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0"><i class="bi bi-shield-check me-2"></i>Rol Yonetimi</h3>
            <small class="text-muted">Sistem rollerini ve menu yetkilerini yonetin</small>
        </div>
        <button class="btn btn-primary" @onclick="YeniRolEkle">
            <i class="bi bi-plus-lg me-1"></i>Yeni Rol
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yukleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Rol Listesi -->
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-list me-2"></i>Roller</h6>
                    </div>
                    <div class="list-group list-group-flush" style="max-height: 700px; overflow-y: auto;">
                        @foreach (var rol in roller)
                        {
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(seciliRol?.Id == rol.Id ? "active" : "")"
                                    @onclick="() => RolSec(rol)">
                                <div>
                                    <i class="bi bi-shield-fill me-2" style="color: @(seciliRol?.Id == rol.Id ? "white" : rol.Renk ?? "#6c757d")"></i>
                                    <strong>@rol.RolAdi</strong>
                                    @if (rol.SistemRolu)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Sistem</span>
                                    }
                                </div>
                                <span class="badge @(seciliRol?.Id == rol.Id ? "bg-light text-dark" : "bg-secondary")">
                                    @(rol.Kullanicilar?.Count ?? 0)
                                </span>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Yetki Duzenleyici -->
            <div class="col-md-9">
                @if (seciliRol != null)
                {
                    <div class="card shadow-sm">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">
                                    <i class="bi bi-shield-fill me-2" style="color: @(seciliRol.Renk ?? "#6c757d")"></i>
                                    @seciliRol.RolAdi - Menu Yetkileri
                                </h5>
                                <small class="text-muted">@seciliRol.Aciklama</small>
                            </div>
                            <div>
                                @if (seciliRol.RolAdi != "Admin")
                                {
                                    <button class="btn btn-outline-success btn-sm me-2" @onclick="TumYetkileriSec">
                                        <i class="bi bi-check-all me-1"></i>Tumu Sec
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm me-2" @onclick="TumYetkileriKaldir">
                                        <i class="bi bi-x-lg me-1"></i>Tumu Kaldir
                                    </button>
                                }
                                <button class="btn btn-primary btn-sm" @onclick="YetkileriKaydet" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-check-lg me-1"></i>Kaydet
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-2" style="max-height: 650px; overflow-y: auto;">
                            @if (seciliRol.RolAdi == "Admin")
                            {
                                <div class="alert alert-info m-2">
                                    <i class="bi bi-info-circle me-2"></i>
                                    Admin rolu tum yetkilere sahiptir ve degistirilemez.
                                </div>
                            }
                            else
                            {
                                @foreach (var menuGrup in menuYapisi)
                                {
                                    var anaMenuSecili = seciliYetkiler.Contains(menuGrup.YetkiKodu);
                                    var altMenuSayisi = menuGrup.AltMenuler.Count;
                                    var seciliAltMenuSayisi = menuGrup.AltMenuler.Count(m => 
                                        m.Yetkiler.Any(y => seciliYetkiler.Contains(y.Kod)));
                                    
                                    <div class="card mb-2 @(anaMenuSecili ? "border-primary" : "")">
                                        <div class="card-header py-2 @(anaMenuSecili ? "bg-primary text-white" : "bg-light")">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" 
                                                           id="menu_@menuGrup.YetkiKodu"
                                                           checked="@anaMenuSecili"
                                                           @onchange="(e) => AnaMenuDegistir(menuGrup, (bool)e.Value!)" />
                                                    <label class="form-check-label fw-bold" for="menu_@menuGrup.YetkiKodu">
                                                        <i class="bi @menuGrup.Icon me-2"></i>@menuGrup.MenuAdi
                                                    </label>
                                                </div>
                                                <div>
                                                    <span class="badge @(anaMenuSecili ? "bg-light text-primary" : "bg-secondary")">
                                                        @seciliAltMenuSayisi / @altMenuSayisi alt menu
                                                    </span>
                                                    <button class="btn btn-sm @(anaMenuSecili ? "btn-light" : "btn-outline-secondary") ms-2 py-0"
                                                            @onclick="() => ToggleMenu(menuGrup.YetkiKodu)">
                                                        <i class="bi @(acikMenuler.Contains(menuGrup.YetkiKodu) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        @if (acikMenuler.Contains(menuGrup.YetkiKodu))
                                        {
                                            <div class="card-body p-2">
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th style="width: 30%;">Alt Menu</th>
                                                                <th class="text-center" style="width: 14%;">
                                                                    <i class="bi bi-eye text-info"></i> Okuma
                                                                </th>
                                                                <th class="text-center" style="width: 14%;">
                                                                    <i class="bi bi-plus text-success"></i> Yazma
                                                                </th>
                                                                <th class="text-center" style="width: 14%;">
                                                                    <i class="bi bi-pencil text-warning"></i> Duzenleme
                                                                </th>
                                                                <th class="text-center" style="width: 14%;">
                                                                    <i class="bi bi-trash text-danger"></i> Silme
                                                                </th>
                                                                <th class="text-center" style="width: 14%;">Islemler</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var altMenu in menuGrup.AltMenuler)
                                                            {
                                                                var okumaYetki = altMenu.Yetkiler.FirstOrDefault(y => y.Adi.Contains("Okuma") || y.Adi.Contains("Goruntuleme"));
                                                                var yazmaYetki = altMenu.Yetkiler.FirstOrDefault(y => y.Adi.Contains("Yazma") || y.Adi.Contains("Olusturma"));
                                                                var duzenleYetki = altMenu.Yetkiler.FirstOrDefault(y => y.Adi.Contains("Duzenleme") || y.Adi.Contains("Uygulama"));
                                                                var silmeYetki = altMenu.Yetkiler.FirstOrDefault(y => y.Adi.Contains("Silme"));
                                                                var digerYetkiler = altMenu.Yetkiler.Where(y => 
                                                                    !y.Adi.Contains("Okuma") && !y.Adi.Contains("Goruntuleme") &&
                                                                    !y.Adi.Contains("Yazma") && !y.Adi.Contains("Olusturma") &&
                                                                    !y.Adi.Contains("Duzenleme") && !y.Adi.Contains("Uygulama") &&
                                                                    !y.Adi.Contains("Silme")).ToList();
                                                                
                                                                <tr>
                                                                    <td>
                                                                        <i class="bi @altMenu.Icon me-2 text-secondary"></i>
                                                                        <span class="small">@altMenu.MenuAdi</span>
                                                                    </td>
                                                                    <td class="text-center">
                                                                        @if (okumaYetki != null)
                                                                        {
                                                                            <input type="checkbox" class="form-check-input"
                                                                                   checked="@seciliYetkiler.Contains(okumaYetki.Kod)"
                                                                                   @onchange="(e) => YetkiDegistir(okumaYetki.Kod, (bool)e.Value!)" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center">
                                                                        @if (yazmaYetki != null)
                                                                        {
                                                                            <input type="checkbox" class="form-check-input"
                                                                                   checked="@seciliYetkiler.Contains(yazmaYetki.Kod)"
                                                                                   @onchange="(e) => YetkiDegistir(yazmaYetki.Kod, (bool)e.Value!)" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center">
                                                                        @if (duzenleYetki != null)
                                                                        {
                                                                            <input type="checkbox" class="form-check-input"
                                                                                   checked="@seciliYetkiler.Contains(duzenleYetki.Kod)"
                                                                                   @onchange="(e) => YetkiDegistir(duzenleYetki.Kod, (bool)e.Value!)" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center">
                                                                        @if (silmeYetki != null)
                                                                        {
                                                                            <input type="checkbox" class="form-check-input"
                                                                                   checked="@seciliYetkiler.Contains(silmeYetki.Kod)"
                                                                                   @onchange="(e) => YetkiDegistir(silmeYetki.Kod, (bool)e.Value!)" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center">
                                                                        <button class="btn btn-outline-success btn-sm py-0 px-1" 
                                                                                title="Tum Yetkileri Ver"
                                                                                @onclick="() => AltMenuTumYetki(altMenu, true)">
                                                                            <i class="bi bi-check-all"></i>
                                                                        </button>
                                                                        <button class="btn btn-outline-danger btn-sm py-0 px-1 ms-1" 
                                                                                title="Tum Yetkileri Kaldir"
                                                                                @onclick="() => AltMenuTumYetki(altMenu, false)">
                                                                            <i class="bi bi-x"></i>
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                                @if (digerYetkiler.Any())
                                                                {
                                                                    <tr class="table-light">
                                                                        <td colspan="6" class="py-1 ps-4">
                                                                            <small class="text-muted">Diger yetkiler: </small>
                                                                            @foreach (var diger in digerYetkiler)
                                                                            {
                                                                                <span class="badge bg-secondary me-1">
                                                                                    <input type="checkbox" class="form-check-input me-1" style="margin-top: 0;"
                                                                                           checked="@seciliYetkiler.Contains(diger.Kod)"
                                                                                           @onchange="(e) => YetkiDegistir(diger.Kod, (bool)e.Value!)" />
                                                                                    @diger.Adi
                                                                                </span>
                                                                            }
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <div class="mt-2 text-end">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => AnaMenuTumAltMenuYetki(menuGrup, true)">
                                                        <i class="bi bi-check-all me-1"></i>Tum Alt Menulere Yetki Ver
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => AnaMenuTumAltMenuYetki(menuGrup, false)">
                                                        <i class="bi bi-x me-1"></i>Tum Yetkileri Kaldir
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-shield-exclamation text-muted" style="font-size: 4rem;"></i>
                            <h5 class="mt-3 text-muted">Rol Secin</h5>
                            <p class="text-muted">Yetkileri duzenlemek icin sol taraftan bir rol secin.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Yeni Rol Modal -->
@if (showRolModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-shield-plus me-2"></i>
                        @(editingRol?.Id > 0 ? "Rol Duzenle" : "Yeni Rol")
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Rol Adi *</label>
                        <input type="text" class="form-control" @bind="editingRol!.RolAdi" placeholder="Ornek: Muhasebeci" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <textarea class="form-control" rows="2" @bind="editingRol.Aciklama" placeholder="Rol hakkinda kisa aciklama"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Renk</label>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var renk in renkSecenekleri)
                            {
                                <button type="button" 
                                        class="btn btn-sm @(editingRol.Renk == renk ? "border-3 border-dark" : "")" 
                                        style="background-color: @renk; width: 35px; height: 35px;"
                                        @onclick="() => editingRol.Renk = renk">
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="RolKaydet">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

