    private async Task LoadRoller()
    {
        isLoading = true;
        try
        {
            roller = await KullaniciService.GetRollerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Roller yuklenirken hata: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RolSec(Rol rol)
    {
        seciliRol = rol;
        seciliYetkiler.Clear();
        acikMenuler.Clear();
        
        if (rol.RolAdi == "Admin")
        {
            // Admin tum yetkilere sahip
            foreach (var menu in menuYapisi)
            {
                seciliYetkiler.Add(menu.YetkiKodu);
                foreach (var altMenu in menu.AltMenuler)
                {
                    foreach (var yetki in altMenu.Yetkiler)
                    {
                        seciliYetkiler.Add(yetki.Kod);
                    }
                }
            }
        }
        else if (rol.Yetkiler != null)
        {
            foreach (var yetki in rol.Yetkiler.Where(y => y.Izin))
            {
                seciliYetkiler.Add(yetki.YetkiKodu);
            }
        }
    }

    private void ToggleMenu(string menuKodu)
    {
        if (acikMenuler.Contains(menuKodu))
            acikMenuler.Remove(menuKodu);
        else
            acikMenuler.Add(menuKodu);
    }

    private void YetkiDegistir(string yetkiKodu, bool secili)
    {
        if (secili)
            seciliYetkiler.Add(yetkiKodu);
        else
            seciliYetkiler.Remove(yetkiKodu);
    }

    private void AnaMenuDegistir(MenuYapiGrup menu, bool secili)
    {
        if (secili)
        {
            seciliYetkiler.Add(menu.YetkiKodu);
            // Tum alt menulerin okuma yetkisini ac
            foreach (var altMenu in menu.AltMenuler)
            {
                var okumaYetki = altMenu.Yetkiler.FirstOrDefault(y => y.Adi.Contains("Okuma") || y.Adi.Contains("Goruntuleme"));
                if (okumaYetki != null)
                    seciliYetkiler.Add(okumaYetki.Kod);
            }
            // Menuyu ac
            acikMenuler.Add(menu.YetkiKodu);
        }
        else
        {
            seciliYetkiler.Remove(menu.YetkiKodu);
            // Tum alt menu yetkilerini kapat
            foreach (var altMenu in menu.AltMenuler)
            {
                foreach (var yetki in altMenu.Yetkiler)
                {
                    seciliYetkiler.Remove(yetki.Kod);
                }
            }
        }
    }

    private void AltMenuTumYetki(AltMenuYapisi altMenu, bool ver)
    {
        foreach (var yetki in altMenu.Yetkiler)
        {
            if (ver)
                seciliYetkiler.Add(yetki.Kod);
            else
                seciliYetkiler.Remove(yetki.Kod);
        }
    }

    private void AnaMenuTumAltMenuYetki(MenuYapiGrup menu, bool ver)
    {
        if (ver)
            seciliYetkiler.Add(menu.YetkiKodu);
        else
            seciliYetkiler.Remove(menu.YetkiKodu);
            
        foreach (var altMenu in menu.AltMenuler)
        {
            foreach (var yetki in altMenu.Yetkiler)
            {
                if (ver)
                    seciliYetkiler.Add(yetki.Kod);
                else
                    seciliYetkiler.Remove(yetki.Kod);
            }
        }
    }

    private void TumYetkileriSec()
    {
        foreach (var menu in menuYapisi)
        {
            seciliYetkiler.Add(menu.YetkiKodu);
            foreach (var altMenu in menu.AltMenuler)
            {
                foreach (var yetki in altMenu.Yetkiler)
                {
                    seciliYetkiler.Add(yetki.Kod);
                }
            }
        }
    }

    private void TumYetkileriKaldir()
    {
        seciliYetkiler.Clear();
    }

    private async Task YetkileriKaydet()
    {
        if (seciliRol == null) return;
        
        isSaving = true;
        try
        {
            await KullaniciService.SetRolYetkileriAsync(seciliRol.Id, seciliYetkiler.ToList());
            ToastService.ShowSuccess($"{seciliRol.RolAdi} yetkileri kaydedildi.");
            await LoadRoller();
            
            // Secili rolu guncelle
            var guncelRol = roller.FirstOrDefault(r => r.Id == seciliRol.Id);
            if (guncelRol != null)
                RolSec(guncelRol);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Yetkiler kaydedilirken hata: " + ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void YeniRolEkle()
    {
        editingRol = new Rol
        {
            Renk = "#0d6efd"
        };
        showRolModal = true;
    }

    private void ModalKapat()
    {
        showRolModal = false;
        editingRol = null;
    }

    private async Task RolKaydet()
    {
        if (editingRol == null || string.IsNullOrWhiteSpace(editingRol.RolAdi))
        {
            ToastService.ShowWarning("Rol adi zorunludur.");
            return;
        }

        try
        {
            if (editingRol.Id == 0)
            {
                await KullaniciService.CreateRolAsync(editingRol);
                ToastService.ShowSuccess("Rol olusturuldu.");
            }
            else
            {
                await KullaniciService.UpdateRolAsync(editingRol);
                ToastService.ShowSuccess("Rol guncellendi.");
            }
            
            ModalKapat();
            await LoadRoller();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    // Yardimci siniflar
    private class MenuYapiGrup
    {
        public string MenuAdi { get; set; }
        public string Icon { get; set; }
        public string YetkiKodu { get; set; }
        public List<AltMenuYapisi> AltMenuler { get; set; }

        public MenuYapiGrup(string menuAdi, string icon, string yetkiKodu, List<AltMenuYapisi> altMenuler)
        {
            MenuAdi = menuAdi;
            Icon = icon;
            YetkiKodu = yetkiKodu;
            AltMenuler = altMenuler;
        }
    }

    private class AltMenuYapisi
    {
        public string MenuAdi { get; set; }
        public string Icon { get; set; }
        public List<YetkiItem> Yetkiler { get; set; }

        public AltMenuYapisi(string menuAdi, string icon, List<YetkiItem> yetkiler)
        {
            MenuAdi = menuAdi;
            Icon = icon;
            Yetkiler = yetkiler;
        }
    }

    private class YetkiItem
    {
        public string Kod { get; set; }
        public string Adi { get; set; }

        public YetkiItem(string kod, string adi)
        {
            Kod = kod;
            Adi = adi;
        }
    }
