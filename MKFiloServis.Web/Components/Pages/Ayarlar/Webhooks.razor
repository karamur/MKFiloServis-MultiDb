@page "/ayarlar/webhooks"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services.Interfaces
@inject IWebhookService WebhookService
@inject IJSRuntime JS

<PageTitle>Webhook Yönetimi - Koa Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-broadcast text-primary me-2"></i>Webhook Yönetimi
                    </h2>
                    <small class="text-muted">Dış sistemlere otomatik olay bildirimleri</small>
                </div>
                <div>
                    <button class="btn btn-primary" @onclick="YeniEndpoint">
                        <i class="bi bi-plus-lg me-1"></i>Yeni Webhook
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <!-- İstatistik Kartları -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-primary bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-broadcast fs-4 text-primary"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Toplam Endpoint</h6>
                                <h3 class="mb-0">@endpoints.Count</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-success bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-check-circle fs-4 text-success"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Aktif</h6>
                                <h3 class="mb-0">@endpoints.Count(x => x.Aktif)</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-info bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-send fs-4 text-info"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Toplam Gönderim</h6>
                                <h3 class="mb-0">@istatistik.ToplamGonderim</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-warning bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-percent fs-4 text-warning"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Başarı Oranı</h6>
                                <h3 class="mb-0">%@istatistik.BasariOrani.ToString("F1")</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Endpoint Listesi -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white">
                <ul class="nav nav-tabs card-header-tabs">
                    <li class="nav-item">
                        <button class="nav-link @(aktifTab == "endpoints" ? "active" : "")" @onclick="TabEndpoints">
                            <i class="bi bi-broadcast me-1"></i>Endpointler
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(aktifTab == "loglar" ? "active" : "")" @onclick="LoglariYukle">
                            <i class="bi bi-journal-text me-1"></i>Loglar
                            @if (bekleyenLogSayisi > 0)
                            {
                                <span class="badge bg-warning ms-1">@bekleyenLogSayisi</span>
                            }
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                @if (aktifTab == "endpoints")
                {
                    @if (!endpoints.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-broadcast display-1 text-muted"></i>
                            <p class="text-muted mt-3">Henüz webhook endpoint tanımlanmamış.</p>
                            <button class="btn btn-primary" @onclick="YeniEndpoint">
                                <i class="bi bi-plus-lg me-1"></i>İlk Webhook'u Oluştur
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Durum</th>
                                        <th>Ad</th>
                                        <th>URL</th>
                                        <th>Olaylar</th>
                                        <th>İstatistik</th>
                                        <th>Son Gönderim</th>
                                        <th class="text-end">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var endpoint in endpoints)
                                    {
                                        <tr>
                                            <td>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" checked="@endpoint.Aktif"
                                                           @onchange="() => DurumDegistir(endpoint)" />
                                                </div>
                                            </td>
                                            <td>
                                                <strong>@endpoint.Ad</strong>
                                                @if (!string.IsNullOrEmpty(endpoint.Aciklama))
                                                {
                                                    <br /><small class="text-muted">@endpoint.Aciklama</small>
                                                }
                                            </td>
                                            <td>
                                                <code class="small">@TruncateUrl(endpoint.Url)</code>
                                            </td>
                                            <td>
                                                @{
                                                    var olaylar = GetOlayListesi(endpoint);
                                                }
                                                @if (olaylar.Any())
                                                {
                                                    <span class="badge bg-secondary">@olaylar.Count olay</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">Tümü</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="text-success">@endpoint.BasariliGonderim ✓</span> /
                                                <span class="text-danger">@endpoint.BasarisizGonderim ✗</span>
                                            </td>
                                            <td>
                                                @if (endpoint.SonGonderimTarihi.HasValue)
                                                {
                                                    <small>@endpoint.SonGonderimTarihi.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">-</small>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-info" @onclick="() => TestEt(endpoint)" title="Test Et" disabled="@testEdiliyor">
                                                        @if (testEdiliyor && testEdilenId == endpoint.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-lightning"></i>
                                                        }
                                                    </button>
                                                    <button class="btn btn-outline-primary" @onclick="() => Duzenle(endpoint)" title="Düzenle">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => SilOnay(endpoint)" title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else if (aktifTab == "loglar")
                {
                    <div class="mb-3">
                        <select class="form-select form-select-sm w-auto d-inline-block" @bind="seciliEndpointId" @bind:after="LoglariYukle">
                            <option value="0">Tüm Endpointler</option>
                            @foreach (var ep in endpoints)
                            {
                                <option value="@ep.Id">@ep.Ad</option>
                            }
                        </select>
                    </div>

                    @if (!loglar.Any())
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-journal-text display-4 text-muted"></i>
                            <p class="text-muted mt-2">Henüz log kaydı yok.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Endpoint</th>
                                        <th>Olay</th>
                                        <th>Durum</th>
                                        <th>HTTP</th>
                                        <th>Süre</th>
                                        <th>Retry</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in loglar)
                                    {
                                        <tr class="@GetLogRowClass(log)">
                                            <td><small>@log.CreatedAt.ToString("dd.MM HH:mm:ss")</small></td>
                                            <td><small>@log.WebhookEndpoint?.Ad</small></td>
                                            <td><code class="small">@log.OlayTipi</code></td>
                                            <td>
                                                <span class="badge @GetDurumBadgeClass(log.Durum)">
                                                    @GetDurumText(log.Durum)
                                                </span>
                                            </td>
                                            <td>
                                                @if (log.HttpStatusCode > 0)
                                                {
                                                    <span class="badge @GetHttpBadgeClass(log.HttpStatusCode)">@log.HttpStatusCode</span>
                                                }
                                            </td>
                                            <td><small>@log.SureMilisaniye ms</small></td>
                                            <td><small>@log.RetryCount</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<!-- Endpoint Form Modal -->
@if (formGoster)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-broadcast me-2"></i>
                        @(seciliEndpoint.Id == 0 ? "Yeni Webhook" : "Webhook Düzenle")
                    </h5>
                    <button type="button" class="btn-close" @onclick="FormKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ad <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="seciliEndpoint.Ad" placeholder="Webhook adı" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">HTTP Metodu</label>
                            <select class="form-select" @bind="seciliEndpoint.HttpMethod">
                                <option value="POST">POST</option>
                                <option value="PUT">PUT</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">URL <span class="text-danger">*</span></label>
                            <input type="url" class="form-control" @bind="seciliEndpoint.Url" placeholder="https://api.example.com/webhook" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" rows="2" @bind="seciliEndpoint.Aciklama" placeholder="Opsiyonel açıklama"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Secret (HMAC İmza)</label>
                            <div class="input-group">
                                <input type="@(secretGoster ? "text" : "password")" class="form-control" @bind="seciliEndpoint.Secret" />
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => secretGoster = !secretGoster">
                                    <i class="bi @(secretGoster ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                                <button class="btn btn-outline-primary" type="button" @onclick="YeniSecretOlustur" title="Yeni Secret Oluştur">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </div>
                            <small class="text-muted">Boş bırakılırsa otomatik oluşturulur</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Max Retry</label>
                            <input type="number" class="form-control" @bind="seciliEndpoint.MaxRetry" min="0" max="10" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Retry Aralığı (sn)</label>
                            <input type="number" class="form-control" @bind="seciliEndpoint.RetryDelaySaniye" min="5" max="300" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Dinlenecek Olaylar</label>
                            <div class="row g-2">
                                @foreach (var olay in WebhookOlayTipleri.TumOlaylar)
                                {
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" 
                                                   checked="@seciliOlaylar.Contains(olay)"
                                                   @onchange="e => OlayToggle(olay, (bool)(e.Value ?? false))" />
                                            <label class="form-check-label small">@olay</label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <small class="text-muted">Hiçbiri seçilmezse tüm olaylar dinlenir</small>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" @bind="seciliEndpoint.Aktif" />
                                <label class="form-check-label">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="FormKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="Kaydet" disabled="@kaydediliyor">
                        @if (kaydediliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (silOnayGoster)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => silOnayGoster = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekEndpoint?.Ad</strong> webhook'unu silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => silOnayGoster = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WebhookEndpoint> endpoints = new();
    private List<WebhookLog> loglar = new();
    private WebhookIstatistik istatistik = new();
    private WebhookEndpoint seciliEndpoint = new();
    private WebhookEndpoint? silinecekEndpoint;
    private HashSet<string> seciliOlaylar = new();

    private bool yukleniyor = true;
    private bool formGoster = false;
    private bool silOnayGoster = false;
    private bool kaydediliyor = false;
    private bool testEdiliyor = false;
    private int testEdilenId = 0;
    private bool secretGoster = false;
    private string aktifTab = "endpoints";
    private int seciliEndpointId = 0;
    private int bekleyenLogSayisi = 0;

    protected override async Task OnInitializedAsync()
    {
        await Yukle();
    }

    private async Task Yukle()
    {
        yukleniyor = true;
        try
        {
            endpoints = await WebhookService.GetAllEndpointsAsync();
            istatistik = await WebhookService.GetIstatistiklerAsync();
            bekleyenLogSayisi = await WebhookService.GetPendingLogCountAsync();
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void TabEndpoints()
    {
        aktifTab = "endpoints";
    }

    private async Task LoglariYukle()
    {
        aktifTab = "loglar";
        loglar = await WebhookService.GetLogsAsync(seciliEndpointId > 0 ? seciliEndpointId : null);
    }

    private void YeniEndpoint()
    {
        seciliEndpoint = new WebhookEndpoint
        {
            Aktif = true,
            MaxRetry = 3,
            RetryDelaySaniye = 30,
            HttpMethod = "POST"
        };
        seciliOlaylar.Clear();
        formGoster = true;
    }

    private void Duzenle(WebhookEndpoint endpoint)
    {
        seciliEndpoint = new WebhookEndpoint
        {
            Id = endpoint.Id,
            Ad = endpoint.Ad,
            Aciklama = endpoint.Aciklama,
            Url = endpoint.Url,
            Secret = endpoint.Secret,
            Aktif = endpoint.Aktif,
            MaxRetry = endpoint.MaxRetry,
            RetryDelaySaniye = endpoint.RetryDelaySaniye,
            HttpMethod = endpoint.HttpMethod,
            OlayFiltresi = endpoint.OlayFiltresi
        };
        seciliOlaylar = GetOlayListesi(endpoint);
        formGoster = true;
    }

    private async Task Kaydet()
    {
        if (string.IsNullOrWhiteSpace(seciliEndpoint.Ad) || string.IsNullOrWhiteSpace(seciliEndpoint.Url))
        {
            await JS.InvokeVoidAsync("alert", "Ad ve URL zorunludur.");
            return;
        }

        kaydediliyor = true;
        try
        {
            seciliEndpoint.OlayFiltresi = seciliOlaylar.Any()
                ? System.Text.Json.JsonSerializer.Serialize(seciliOlaylar.ToArray())
                : null;

            if (seciliEndpoint.Id == 0)
                await WebhookService.CreateEndpointAsync(seciliEndpoint);
            else
                await WebhookService.UpdateEndpointAsync(seciliEndpoint);

            formGoster = false;
            await Yukle();
        }
        finally
        {
            kaydediliyor = false;
        }
    }

    private void FormKapat()
    {
        formGoster = false;
    }

    private async Task DurumDegistir(WebhookEndpoint endpoint)
    {
        endpoint.Aktif = !endpoint.Aktif;
        await WebhookService.UpdateEndpointAsync(endpoint);
    }

    private async Task TestEt(WebhookEndpoint endpoint)
    {
        testEdiliyor = true;
        testEdilenId = endpoint.Id;
        StateHasChanged();

        try
        {
            var sonuc = await WebhookService.TestEndpointAsync(endpoint.Id);
            await JS.InvokeVoidAsync("alert", sonuc ? "Test başarılı!" : "Test başarısız!");
            await Yukle();
        }
        finally
        {
            testEdiliyor = false;
            testEdilenId = 0;
        }
    }

    private void SilOnay(WebhookEndpoint endpoint)
    {
        silinecekEndpoint = endpoint;
        silOnayGoster = true;
    }

    private async Task Sil()
    {
        if (silinecekEndpoint != null)
        {
            await WebhookService.DeleteEndpointAsync(silinecekEndpoint.Id);
            silOnayGoster = false;
            silinecekEndpoint = null;
            await Yukle();
        }
    }

    private void OlayToggle(string olay, bool secili)
    {
        if (secili)
            seciliOlaylar.Add(olay);
        else
            seciliOlaylar.Remove(olay);
    }

    private void YeniSecretOlustur()
    {
        var bytes = new byte[32];
        using var rng = System.Security.Cryptography.RandomNumberGenerator.Create();
        rng.GetBytes(bytes);
        seciliEndpoint.Secret = Convert.ToBase64String(bytes);
    }

    private HashSet<string> GetOlayListesi(WebhookEndpoint endpoint)
    {
        if (string.IsNullOrEmpty(endpoint.OlayFiltresi))
            return new HashSet<string>();

        try
        {
            var olaylar = System.Text.Json.JsonSerializer.Deserialize<string[]>(endpoint.OlayFiltresi);
            return olaylar != null ? new HashSet<string>(olaylar) : new HashSet<string>();
        }
        catch
        {
            return new HashSet<string>();
        }
    }

    private string TruncateUrl(string url)
    {
        return url.Length > 50 ? url.Substring(0, 47) + "..." : url;
    }

    private string GetLogRowClass(WebhookLog log)
    {
        return log.Durum switch
        {
            WebhookLogDurum.Basarisiz => "table-danger",
            WebhookLogDurum.Basarili => "",
            WebhookLogDurum.Bekliyor or WebhookLogDurum.YenidenDeneniyor => "table-warning",
            _ => ""
        };
    }

    private string GetDurumBadgeClass(WebhookLogDurum durum)
    {
        return durum switch
        {
            WebhookLogDurum.Basarili => "bg-success",
            WebhookLogDurum.Basarisiz => "bg-danger",
            WebhookLogDurum.Bekliyor => "bg-warning",
            WebhookLogDurum.Gonderiliyor => "bg-info",
            WebhookLogDurum.YenidenDeneniyor => "bg-warning",
            WebhookLogDurum.Iptal => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    private string GetDurumText(WebhookLogDurum durum)
    {
        return durum switch
        {
            WebhookLogDurum.Basarili => "Başarılı",
            WebhookLogDurum.Basarisiz => "Başarısız",
            WebhookLogDurum.Bekliyor => "Bekliyor",
            WebhookLogDurum.Gonderiliyor => "Gönderiliyor",
            WebhookLogDurum.YenidenDeneniyor => "Yeniden Deneniyor",
            WebhookLogDurum.Iptal => "İptal",
            _ => durum.ToString()
        };
    }

    private string GetHttpBadgeClass(int statusCode)
    {
        return statusCode switch
        {
            >= 200 and < 300 => "bg-success",
            >= 400 and < 500 => "bg-warning",
            >= 500 => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

