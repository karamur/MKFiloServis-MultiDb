    }
    
    private async Task CleanupLogs()
    {
        isLoading = true;
        try
        {
            var count = await AuditLogService.CleanupOldLogsAsync(cleanupDays);
            showCleanupModal = false;
            await LoadData();
            await LoadDashboard();
            await JS.InvokeVoidAsync("alert", $"{count} adet eski log silindi.");
        }
        finally
        {
            isLoading = false;
        }
    }
    
