@page "/ayarlar/audit-log"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services.Interfaces
@inject IAuditLogService AuditLogService
@inject IJSRuntime JS

<PageTitle>Audit Log - İşlem Geçmişi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0"><i class="bi bi-clock-history me-2"></i>Audit Log - İşlem Geçmişi</h3>
            <small class="text-muted">Tüm sistem işlemlerinin detaylı kaydı</small>
        </div>
        <div>
            <button class="btn btn-outline-primary me-2" @onclick="ToggleDashboard">
                <i class="bi bi-graph-up me-1"></i>@(showDashboard ? "Listeye Dön" : "Dashboard")
            </button>
            <button class="btn btn-outline-secondary me-2" @onclick="ExportToExcel" disabled="@isLoading">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-danger" @onclick="ShowCleanupModal" disabled="@isLoading">
                <i class="bi bi-trash me-1"></i>Temizle
            </button>
        </div>
    </div>

    @if (showDashboard)
    {
        <!-- Dashboard View -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title opacity-75">Toplam Log</h6>
                                <h2 class="mb-0">@dashboard?.ToplamLog.ToString("N0")</h2>
                            </div>
                            <i class="bi bi-journal-text fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title opacity-75">Bugünkü İşlem</h6>
                                <h2 class="mb-0">@dashboard?.BugunkuLog.ToString("N0")</h2>
                            </div>
                            <i class="bi bi-calendar-check fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title opacity-75">Başarısız İşlem</h6>
                                <h2 class="mb-0">@dashboard?.BasarisizIslem.ToString("N0")</h2>
                            </div>
                            <i class="bi bi-exclamation-triangle fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title opacity-75">Aktif Kullanıcı</h6>
                                <h2 class="mb-0">@dashboard?.AktifKullanici.ToString("N0")</h2>
                            </div>
                            <i class="bi bi-people fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-pie-chart me-2"></i>İşlem Tipi Dağılımı
                    </div>
                    <div class="card-body">
                        @if (dashboard?.IslemDagilimi != null)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>İşlem Tipi</th>
                                            <th class="text-end">Sayı</th>
                                            <th class="text-end">Oran</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in dashboard.IslemDagilimi.Take(8))
                                        {
                                            <tr>
                                                <td>
                                                    <span class="badge @GetIslemTipiBadgeClass(item.IslemTipi) me-1">
                                                        <i class="bi @GetIslemTipiIcon(item.IslemTipi)"></i>
                                                    </span>
                                                    @item.IslemTipi
                                                </td>
                                                <td class="text-end">@item.Sayi.ToString("N0")</td>
                                                <td class="text-end">%@item.Yuzde</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-folder me-2"></i>Kategori Dağılımı
                    </div>
                    <div class="card-body">
                        @if (dashboard?.KategoriDagilimi != null)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Kategori</th>
                                            <th class="text-end">Sayı</th>
                                            <th class="text-end">Oran</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in dashboard.KategoriDagilimi.Take(8))
                                        {
                                            <tr>
                                                <td>
                                                    <span class="badge bg-secondary me-1">
                                                        <i class="bi @GetKategoriIcon(item.Kategori)"></i>
                                                    </span>
                                                    @item.Kategori
                                                </td>
                                                <td class="text-end">@item.Sayi.ToString("N0")</td>
                                                <td class="text-end">%@item.Yuzde</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-clock me-2"></i>Son 10 İşlem
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>İşlem</th>
                                <th>Entity</th>
                                <th>Kullanıcı</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (dashboard?.SonIslemler != null)
                            {
                                @foreach (var log in dashboard.SonIslemler)
                                {
                                    <tr>
                                        <td class="text-nowrap small">@log.IslemTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge @GetIslemTipiBadgeClass(log.IslemTipi)">
                                                <i class="bi @GetIslemTipiIcon(log.IslemTipi) me-1"></i>@log.IslemTipi
                                            </span>
                                        </td>
                                        <td>@log.EntityAdi</td>
                                        <td>@(log.KullaniciAdi ?? "-")</td>
                                        <td class="text-truncate" style="max-width: 300px;">@(log.Aciklama ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- List View -->
        <!-- Filtre Kartı -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label small">Başlangıç Tarihi</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtre.BaslangicTarihi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Bitiş Tarihi</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtre.BitisTarihi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">İşlem Tipi</label>
                        <select class="form-select form-select-sm" @bind="filtre.IslemTipi">
                            <option value="">Tümü</option>
                            <option value="Create">Create</option>
                            <option value="Update">Update</option>
                            <option value="Delete">Delete</option>
                            <option value="SoftDelete">SoftDelete</option>
                            <option value="Login">Login</option>
                            <option value="LoginFailed">LoginFailed</option>
                            <option value="Logout">Logout</option>
                            <option value="Export">Export</option>
                            <option value="Import">Import</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Kategori</label>
                        <select class="form-select form-select-sm" @bind="filtre.Kategori">
                            <option value="">Tümü</option>
                            <option value="Sistem">Sistem</option>
                            <option value="Kullanici">Kullanıcı</option>
                            <option value="Finans">Finans</option>
                            <option value="Fatura">Fatura</option>
                            <option value="Cari">Cari</option>
                            <option value="Arac">Araç</option>
                            <option value="Sofor">Şoför</option>
                            <option value="Personel">Personel</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Seviye</label>
                        <select class="form-select form-select-sm" @bind="filtre.Seviye">
                            <option value="">Tümü</option>
                            <option value="Info">Info</option>
                            <option value="Warning">Warning</option>
                            <option value="Error">Error</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Durum</label>
                        <select class="form-select form-select-sm" @bind="filtreBasarili">
                            <option value="">Tümü</option>
                            <option value="true">Başarılı</option>
                            <option value="false">Başarısız</option>
                        </select>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <label class="form-label small">Arama</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Açıklama, kullanıcı veya entity ara..."
                               @bind="filtre.AramaMetni" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Entity</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Entity adı" @bind="filtre.EntityAdi" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Sayfa Boyutu</label>
                        <select class="form-select form-select-sm" @bind="filtre.SayfaBoyutu" @bind:after="LoadData">
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="250">250</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-primary btn-sm me-2" @onclick="LoadData" disabled="@isLoading">
                            <i class="bi bi-search me-1"></i>Filtrele
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ResetFilters">
                            <i class="bi bi-x-circle me-1"></i>Temizle
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sonuç Tablosu -->
        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Yükleniyor...</p>
            </div>
        }
        else if (result == null || !result.Items.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-list me-2"></i>@result.ToplamKayit.ToString("N0") kayıt bulundu</span>
                    <span class="badge bg-secondary">Sayfa @result.MevcutSayfa / @result.ToplamSayfa</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 140px;">Tarih</th>
                                    <th style="width: 100px;">İşlem</th>
                                    <th style="width: 100px;">Entity</th>
                                    <th style="width: 60px;">ID</th>
                                    <th style="width: 120px;">Kullanıcı</th>
                                    <th>Açıklama</th>
                                    <th style="width: 80px;">Durum</th>
                                    <th style="width: 60px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in result.Items)
                                {
                                    <tr class="@(!log.Basarili ? "table-danger" : (log.Seviye == "Warning" ? "table-warning" : ""))">
                                        <td class="text-nowrap small">
                                            @log.IslemTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")
                                        </td>
                                        <td>
                                            <span class="badge @GetIslemTipiBadgeClass(log.IslemTipi)">
                                                <i class="bi @GetIslemTipiIcon(log.IslemTipi) me-1"></i>@log.IslemTipi
                                            </span>
                                        </td>
                                        <td class="small">@log.EntityAdi</td>
                                        <td class="small text-muted">@(log.EntityId?.ToString() ?? "-")</td>
                                        <td class="small">@(log.KullaniciAdi ?? "-")</td>
                                        <td class="small text-truncate" style="max-width: 300px;" title="@log.Aciklama">
                                            @(log.Aciklama ?? "-")
                                        </td>
                                        <td>
                                            @if (log.Basarili)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check"></i></span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-x"></i></span>
                                            }
                                            @if (log.IslemSuresiMs.HasValue)
                                            {
                                                <small class="text-muted ms-1">@(log.IslemSuresiMs)ms</small>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-info" @onclick="() => ShowLogDetail(log)" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                @if (result.ToplamSayfa > 1)
                {
                    <div class="card-footer">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                <li class="page-item @(filtre.Sayfa <= 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(1)">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </button>
                                </li>
                                <li class="page-item @(filtre.Sayfa <= 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(filtre.Sayfa - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                </li>
                                @for (int i = Math.Max(1, filtre.Sayfa - 2); i <= Math.Min(result.ToplamSayfa, filtre.Sayfa + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(pageNum == filtre.Sayfa ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(filtre.Sayfa >= result.ToplamSayfa ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(filtre.Sayfa + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </li>
                                <li class="page-item @(filtre.Sayfa >= result.ToplamSayfa ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(result.ToplamSayfa)">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- Log Detay Modal -->
@if (selectedLog != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-info-circle me-2"></i>Log Detayı #@selectedLog.Id
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseLogDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr><th>Tarih:</th><td>@selectedLog.IslemTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td></tr>
                                <tr><th>İşlem Tipi:</th><td><span class="badge @GetIslemTipiBadgeClass(selectedLog.IslemTipi)">@selectedLog.IslemTipi</span></td></tr>
                                <tr><th>Entity:</th><td>@selectedLog.EntityAdi</td></tr>
                                <tr><th>Entity ID:</th><td>@(selectedLog.EntityId?.ToString() ?? "-")</td></tr>
                                <tr><th>Kategori:</th><td>@(selectedLog.Kategori ?? "-")</td></tr>
                                <tr><th>Seviye:</th><td><span class="badge @GetSeviyeBadgeClass(selectedLog.Seviye)">@selectedLog.Seviye</span></td></tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr><th>Kullanıcı:</th><td>@(selectedLog.KullaniciAdi ?? "-")</td></tr>
                                <tr><th>IP Adresi:</th><td>@(selectedLog.IpAdresi ?? "-")</td></tr>
                                <tr><th>İşlem Süresi:</th><td>@(selectedLog.IslemSuresiMs.HasValue ? $"{selectedLog.IslemSuresiMs}ms" : "-")</td></tr>
                                <tr><th>Durum:</th><td>@(selectedLog.Basarili ? "✅ Başarılı" : "❌ Başarısız")</td></tr>
                                <tr><th>Request Path:</th><td class="small">@(selectedLog.RequestPath ?? "-")</td></tr>
                            </table>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama:</label>
                        <div class="border rounded p-2 bg-light">@(selectedLog.Aciklama ?? "-")</div>
                    </div>

                    @if (!string.IsNullOrEmpty(selectedLog.HataMesaji))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold text-danger">Hata Mesajı:</label>
                            <div class="border rounded p-2 bg-danger bg-opacity-10 text-danger">@selectedLog.HataMesaji</div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedLog.DegisenAlanlar))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Değişen Alanlar:</label>
                            <div class="border rounded p-2 bg-warning bg-opacity-10">
                                <code>@selectedLog.DegisenAlanlar</code>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedLog.EskiDeger))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Eski Değer (JSON):</label>
                            <pre class="border rounded p-2 bg-light small" style="max-height: 200px; overflow: auto;">@FormatJson(selectedLog.EskiDeger)</pre>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedLog.YeniDeger))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Yeni Değer (JSON):</label>
                            <pre class="border rounded p-2 bg-light small" style="max-height: 200px; overflow: auto;">@FormatJson(selectedLog.YeniDeger)</pre>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedLog.UserAgent))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">User Agent:</label>
                            <div class="border rounded p-2 bg-light small">@selectedLog.UserAgent</div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseLogDetail">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Temizleme Modal -->
@if (showCleanupModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Eski Logları Temizle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCleanupModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Bu işlem geri alınamaz! Kritik seviyedeki loglar silinmeyecektir.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kaç günden eski loglar silinsin?</label>
                        <select class="form-select" @bind="cleanupDays">
                            <option value="30">30 gün</option>
                            <option value="60">60 gün</option>
                            <option value="90">90 gün</option>
                            <option value="180">180 gün</option>
                            <option value="365">365 gün</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showCleanupModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="CleanupLogs" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-trash me-1"></i>Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = false;
    private bool showDashboard = false;
    private bool showCleanupModal = false;
    private int cleanupDays = 90;
    private string filtreBasarili = "";
    
    private AuditLogFiltre filtre = new()
    {
        Sayfa = 1,
        SayfaBoyutu = 50,
        BaslangicTarihi = DateTime.Today.AddDays(-30),
        BitisTarihi = DateTime.Today.AddDays(1)
    };
    
    private AuditLogPagedResult? result;
    private AuditLogDashboard? dashboard;
    private MKFiloServis.Shared.Entities.AuditLog? selectedLog;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await LoadDashboard();
    }
    
    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            filtre.Basarili = string.IsNullOrEmpty(filtreBasarili) ? null : bool.Parse(filtreBasarili);
            result = await AuditLogService.GetPagedAsync(filtre);
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task LoadDashboard()
    {
        dashboard = await AuditLogService.GetDashboardAsync(
            DateTime.Today.AddDays(-30),
            DateTime.Today.AddDays(1));
    }
    
    private async Task GoToPage(int page)
