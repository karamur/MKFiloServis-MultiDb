@page "/ayarlar/profil"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Profilim - Koa Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="row">
        <!-- Sol Panel - Profil Özeti -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <div class="avatar-container mb-3">
                        <div class="avatar-circle bg-primary text-white">
                            <i class="bi bi-person-fill" style="font-size: 3rem;"></i>
                        </div>
                    </div>

                    @if (aktifKullanici != null)
                    {
                        <h4 class="mb-1">@aktifKullanici.AdSoyad</h4>
                        <p class="text-muted mb-2">@@@aktifKullanici.KullaniciAdi</p>

                        <span class="badge bg-primary fs-6">
                            <i class="bi bi-shield-check me-1"></i>
                            @aktifKullanici.Rol?.RolAdi
                        </span>

                        <hr class="my-3" />

                        <div class="text-start">
                            @if (!string.IsNullOrEmpty(aktifKullanici.Email))
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-envelope text-muted me-2"></i>
                                    <span>@aktifKullanici.Email</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(aktifKullanici.Telefon))
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-telephone text-muted me-2"></i>
                                    <span>@aktifKullanici.Telefon</span>
                                </div>
                            }
                            @if (aktifKullanici.SonGirisTarihi.HasValue)
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-clock-history text-muted me-2"></i>
                                    <span>Son Giriş: @aktifKullanici.SonGirisTarihi.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            }
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-calendar-check text-muted me-2"></i>
                                <span>Kayıt: @aktifKullanici.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Yükleniyor...</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Tema ve Tercihler -->
            <div class="card shadow-sm mt-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-palette me-2"></i>Görünüm Tercihleri</h6>
                </div>
                <div class="card-body">
                    @if (aktifKullanici != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Tema</label>
                            <select class="form-select" @bind="temaTercihi" @bind:after="TercihKaydetAsync">
                                <option value="Default">Varsayılan</option>
                                <option value="Dark">Koyu</option>
                                <option value="Light">Açık</option>
                            </select>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="kompaktMod"
                                   checked="@kompaktMod" @onchange="KompaktModDegistirAsync" />
                            <label class="form-check-label" for="kompaktMod">Kompakt Mod</label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sağ Panel - Bilgi Düzenleme -->
        <div class="col-md-8">
            <!-- Kişisel Bilgiler -->
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-person-vcard me-2"></i>Kişisel Bilgiler</h5>
                    @if (!bilgiDuzenlemeModu)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="BilgiDuzenlemeBasla">
                            <i class="bi bi-pencil me-1"></i>Düzenle
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (bilgiDuzenlemeModu && aktifKullanici != null)
                    {
                        <EditForm Model="@bilgiModel" OnValidSubmit="BilgiKaydetAsync">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Ad Soyad</label>
                                    <InputText class="form-control" @bind-Value="bilgiModel.AdSoyad" />
                                    <ValidationMessage For="@(() => bilgiModel.AdSoyad)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Kullanıcı Adı</label>
                                    <input type="text" class="form-control" value="@aktifKullanici.KullaniciAdi" readonly disabled />
                                    <small class="text-muted">Kullanıcı adı değiştirilemez</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">E-posta</label>
                                    <InputText class="form-control" @bind-Value="bilgiModel.Email" />
                                    <ValidationMessage For="@(() => bilgiModel.Email)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Telefon</label>
                                    <InputText class="form-control" @bind-Value="bilgiModel.Telefon" />
                                    <ValidationMessage For="@(() => bilgiModel.Telefon)" />
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-success" disabled="@bilgiKaydediliyor">
                                    @if (bilgiKaydediliyor)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-check-lg me-1"></i>Kaydet
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="BilgiDuzenlemeIptal">
                                    <i class="bi bi-x-lg me-1"></i>İptal
                                </button>
                            </div>
                        </EditForm>
                    }
                    else if (aktifKullanici != null)
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted small">Ad Soyad</label>
                                <p class="mb-0 fw-semibold">@aktifKullanici.AdSoyad</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted small">Kullanıcı Adı</label>
                                <p class="mb-0 fw-semibold">@aktifKullanici.KullaniciAdi</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted small">E-posta</label>
                                <p class="mb-0">@(string.IsNullOrEmpty(aktifKullanici.Email) ? "-" : aktifKullanici.Email)</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted small">Telefon</label>
                                <p class="mb-0">@(string.IsNullOrEmpty(aktifKullanici.Telefon) ? "-" : aktifKullanici.Telefon)</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Şifre Değiştirme -->
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-key me-2"></i>Şifre Değiştir</h5>
                    @if (!sifreDuzenlemeModu)
                    {
                        <button class="btn btn-outline-warning btn-sm" @onclick="() => sifreDuzenlemeModu = true">
                            <i class="bi bi-pencil me-1"></i>Şifre Değiştir
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (sifreDuzenlemeModu)
                    {
                        <EditForm Model="@sifreModel" OnValidSubmit="SifreDegistirAsync">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Mevcut Şifre</label>
                                    <div class="input-group">
                                        <InputText type="@(mevcutSifreGoster ? "text" : "password")" class="form-control" @bind-Value="sifreModel.MevcutSifre" />
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => mevcutSifreGoster = !mevcutSifreGoster">
                                            <i class="bi @(mevcutSifreGoster ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => sifreModel.MevcutSifre)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Yeni Şifre</label>
                                    <div class="input-group">
                                        <InputText type="@(yeniSifreGoster ? "text" : "password")" class="form-control" @bind-Value="sifreModel.YeniSifre" />
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => yeniSifreGoster = !yeniSifreGoster">
                                            <i class="bi @(yeniSifreGoster ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => sifreModel.YeniSifre)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Yeni Şifre (Tekrar)</label>
                                    <div class="input-group">
                                        <InputText type="@(yeniSifreTekrarGoster ? "text" : "password")" class="form-control" @bind-Value="sifreModel.YeniSifreTekrar" />
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => yeniSifreTekrarGoster = !yeniSifreTekrarGoster">
                                            <i class="bi @(yeniSifreTekrarGoster ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => sifreModel.YeniSifreTekrar)" />
                                </div>
                            </div>

                            @if (sifreModel.YeniSifre != sifreModel.YeniSifreTekrar && !string.IsNullOrEmpty(sifreModel.YeniSifreTekrar))
                            {
                                <div class="alert alert-danger mt-3 py-2">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Şifreler eşleşmiyor!
                                </div>
                            }

                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-warning" disabled="@(sifreKaydediliyor || sifreModel.YeniSifre != sifreModel.YeniSifreTekrar)">
                                    @if (sifreKaydediliyor)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-check-lg me-1"></i>Şifreyi Değiştir
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="SifreDuzenlemeIptal">
                                    <i class="bi bi-x-lg me-1"></i>İptal
                                </button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            Güvenliğiniz için şifrenizi düzenli olarak değiştirmenizi öneririz.
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>İki Faktörlü Doğrulama</h5>
                    @if (aktifKullanici != null)
                    {
                        <span class="badge @(aktifKullanici.IkiFaktorAktif ? "bg-success" : "bg-secondary")">
                            @(aktifKullanici.IkiFaktorAktif ? "Aktif" : "Kapalı")
                        </span>
                    }
                </div>
                <div class="card-body">
                    @if (aktifKullanici != null)
                    {
                        @if (!aktifKullanici.IkiFaktorAktif)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-1"></i>
                                Microsoft Authenticator veya Google Authenticator ile giriş güvenliğini artırabilirsiniz.
                            </div>

                            @if (ikiFaktorKurulum is null)
                            {
                                <button class="btn btn-outline-primary" @onclick="IkiFaktorKurulumBaslatAsync" disabled="@ikiFaktorIslemde">
                                    <i class="bi bi-shield-plus me-1"></i>Kurulumu Başlat
                                </button>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <label class="form-label">Manuel Kurulum Anahtarı</label>
                                    <input class="form-control font-monospace" value="@ikiFaktorKurulum.ManuelAnahtar" readonly />
                                    <small class="text-muted">Authenticator uygulamasına bu anahtarı manuel olarak ekleyin.</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Kurulum URI</label>
                                    <textarea class="form-control font-monospace" rows="3" readonly>@ikiFaktorKurulum.KurulumUri</textarea>
                                </div>
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-6">
                                        <label class="form-label">Doğrulama Kodu</label>
                                        <InputText class="form-control" @bind-Value="ikiFaktorDogrulamaKodu" />
                                    </div>
                                    <div class="col-md-6 d-flex gap-2">
                                        <button class="btn btn-success" @onclick="IkiFaktorEtkinlestirAsync" disabled="@ikiFaktorIslemde">
                                            <i class="bi bi-check-lg me-1"></i>Etkinleştir
                                        </button>
                                        <button class="btn btn-outline-secondary" @onclick="IkiFaktorKurulumIptal">
                                            <i class="bi bi-x-lg me-1"></i>İptal
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success">
                                <i class="bi bi-shield-check me-1"></i>
                                İki faktörlü doğrulama aktif.
                                @if (aktifKullanici.IkiFaktorEtkinlestirmeTarihi.HasValue)
                                {
                                    <span class="ms-1 small">(@aktifKullanici.IkiFaktorEtkinlestirmeTarihi.Value.ToString("dd.MM.yyyy HH:mm"))</span>
                                }
                            </div>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label">Kapatmak için doğrulama kodu</label>
                                    <InputText class="form-control" @bind-Value="ikiFaktorKapatmaKodu" />
                                </div>
                                <div class="col-md-6">
                                    <button class="btn btn-outline-danger" @onclick="IkiFaktorDevreDisiBirakAsync" disabled="@ikiFaktorIslemde">
                                        <i class="bi bi-shield-x me-1"></i>2FA Kapat
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Hesap Aktivitesi -->
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-activity me-2"></i>Hesap Bilgileri</h5>
                </div>
                <div class="card-body">
                    @if (aktifKullanici != null)
                    {
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="border rounded p-3 text-center">
                                    <i class="bi bi-shield-check text-success" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2 mb-1">Hesap Durumu</h6>
                                    <span class="badge bg-success">Aktif</span>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="border rounded p-3 text-center">
                                    <i class="bi bi-person-badge text-primary" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2 mb-1">Rol</h6>
                                    <span class="badge bg-primary">@aktifKullanici.Rol?.RolAdi</span>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="border rounded p-3 text-center">
                                    <i class="bi bi-calendar3 text-info" style="font-size: 2rem;"></i>
                                    <h6 class="mt-2 mb-1">Üyelik Süresi</h6>
                                    <span class="text-muted">@((DateTime.UtcNow - aktifKullanici.CreatedAt).Days) gün</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-container {
        display: flex;
        justify-content: center;
    }

    .avatar-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    }
</style>

@code {
    private Kullanici? aktifKullanici;

    // Bilgi düzenleme
    private bool bilgiDuzenlemeModu = false;
    private bool bilgiKaydediliyor = false;
    private BilgiModel bilgiModel = new();

    // Şifre değiştirme
    private bool sifreDuzenlemeModu = false;
    private bool sifreKaydediliyor = false;
    private SifreModel sifreModel = new();
    private bool mevcutSifreGoster = false;
    private bool yeniSifreGoster = false;
    private bool yeniSifreTekrarGoster = false;

    private IkiFaktorKurulumBilgisi? ikiFaktorKurulum;
    private string ikiFaktorDogrulamaKodu = string.Empty;
    private string ikiFaktorKapatmaKodu = string.Empty;
    private bool ikiFaktorIslemde = false;

    // Tercihler
    private string temaTercihi = "Default";
    private bool kompaktMod = false;

    protected override async Task OnInitializedAsync()
    {
        await YukleAsync();
    }

    private async Task YukleAsync()
    {
        aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();
        if (aktifKullanici == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        temaTercihi = aktifKullanici.Tema ?? "Default";
        kompaktMod = aktifKullanici.KompaktMod;
    }

    // Bilgi Düzenleme
    private void BilgiDuzenlemeBasla()
    {
        if (aktifKullanici == null) return;

        bilgiModel = new BilgiModel
        {
            AdSoyad = aktifKullanici.AdSoyad,
            Email = aktifKullanici.Email,
            Telefon = aktifKullanici.Telefon
        };
        bilgiDuzenlemeModu = true;
    }

    private void BilgiDuzenlemeIptal()
    {
        bilgiDuzenlemeModu = false;
        bilgiModel = new();
    }

    private async Task BilgiKaydetAsync()
    {
        if (aktifKullanici == null) return;

        try
        {
            bilgiKaydediliyor = true;

            aktifKullanici.AdSoyad = bilgiModel.AdSoyad;
            aktifKullanici.Email = bilgiModel.Email;
            aktifKullanici.Telefon = bilgiModel.Telefon;

            await KullaniciService.UpdateAsync(aktifKullanici);
            ToastService.ShowSuccess("Bilgileriniz güncellendi.");

            bilgiDuzenlemeModu = false;
            await YukleAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            bilgiKaydediliyor = false;
        }
    }

    private async Task IkiFaktorKurulumBaslatAsync()
    {
        if (aktifKullanici == null) return;

        try
        {
            ikiFaktorIslemde = true;
            ikiFaktorKurulum = await KullaniciService.IkiFaktorKurulumBaslatAsync(aktifKullanici.Id);
            ikiFaktorDogrulamaKodu = string.Empty;
            ToastService.ShowInfo("Kurulum anahtarı oluşturuldu. Authenticator uygulamanıza ekleyip doğrulama kodunu girin.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            ikiFaktorIslemde = false;
        }
    }

    private void IkiFaktorKurulumIptal()
    {
        ikiFaktorKurulum = null;
        ikiFaktorDogrulamaKodu = string.Empty;
    }

    private async Task IkiFaktorEtkinlestirAsync()
    {
        if (aktifKullanici == null) return;

        if (string.IsNullOrWhiteSpace(ikiFaktorDogrulamaKodu))
        {
            ToastService.ShowError("Doğrulama kodu zorunludur.");
            return;
        }

        try
        {
            ikiFaktorIslemde = true;
            await KullaniciService.IkiFaktorEtkinlestirAsync(aktifKullanici.Id, ikiFaktorDogrulamaKodu);
            ToastService.ShowSuccess("İki faktörlü doğrulama etkinleştirildi.");
            IkiFaktorKurulumIptal();
            await YukleAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            ikiFaktorIslemde = false;
        }
    }

    private async Task IkiFaktorDevreDisiBirakAsync()
    {
        if (aktifKullanici == null) return;

        if (string.IsNullOrWhiteSpace(ikiFaktorKapatmaKodu))
        {
            ToastService.ShowError("Doğrulama kodu zorunludur.");
            return;
        }

        try
        {
            ikiFaktorIslemde = true;
            await KullaniciService.IkiFaktorDevreDisiBirakAsync(aktifKullanici.Id, ikiFaktorKapatmaKodu);
            ikiFaktorKapatmaKodu = string.Empty;
            ToastService.ShowSuccess("İki faktörlü doğrulama kapatıldı.");
            await YukleAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            ikiFaktorIslemde = false;
        }
    }

    // Şifre Değiştirme
    private void SifreDuzenlemeIptal()
    {
        sifreDuzenlemeModu = false;
        sifreModel = new();
        mevcutSifreGoster = false;
        yeniSifreGoster = false;
        yeniSifreTekrarGoster = false;
    }

    private async Task SifreDegistirAsync()
    {
        if (aktifKullanici == null) return;

        if (sifreModel.YeniSifre != sifreModel.YeniSifreTekrar)
        {
            ToastService.ShowError("Şifreler eşleşmiyor!");
            return;
        }

        if (string.IsNullOrEmpty(sifreModel.YeniSifre) || sifreModel.YeniSifre.Length < 6)
        {
            ToastService.ShowError("Yeni şifre en az 6 karakter olmalıdır!");
            return;
        }

        try
        {
            sifreKaydediliyor = true;

            await KullaniciService.SifreDegistirAsync(aktifKullanici.Id, sifreModel.MevcutSifre, sifreModel.YeniSifre);
            ToastService.ShowSuccess("Şifreniz başarıyla değiştirildi.");

            SifreDuzenlemeIptal();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            sifreKaydediliyor = false;
        }
    }

    // Tercih Kaydetme
    private async Task TercihKaydetAsync()
    {
        if (aktifKullanici == null) return;

        try
        {
            aktifKullanici.Tema = temaTercihi;
            await KullaniciService.UpdateAsync(aktifKullanici);
            ToastService.ShowInfo("Tema tercihiniz kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task KompaktModDegistirAsync(ChangeEventArgs e)
    {
        if (aktifKullanici == null) return;

        try
        {
            kompaktMod = (bool)(e.Value ?? false);
            aktifKullanici.KompaktMod = kompaktMod;
            await KullaniciService.UpdateAsync(aktifKullanici);
            ToastService.ShowInfo("Tercihleriniz kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

