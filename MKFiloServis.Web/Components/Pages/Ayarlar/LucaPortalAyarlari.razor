@page "/ayarlar/luca-portal"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject ILucaPortalService LucaService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Luca Portal Ayarlari</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3><i class="bi bi-cloud-arrow-down me-2"></i>Luca Portal Entegrasyonu</h3>
            <small class="text-muted">E-Fatura ve E-Arsiv belgelerini Luca Portal'dan cekin</small>
        </div>
        <div>
            @if (baglantiDurumu)
            {
                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Bagli</span>
            }
            else
            {
                <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Bagli Degil</span>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Yukleniyor...</p>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Giris Bilgileri -->
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-key me-2"></i>Giris Bilgileri</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Portal URL</label>
                            <input type="text" class="form-control" @bind="ayarlar.PortalUrl" placeholder="https://edonusum.lfrms.com.tr" />
                            <small class="text-muted">Luca E-Donusum portal adresi</small>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Kullanici Adi</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" class="form-control" @bind="ayarlar.KullaniciAdi" placeholder="Portal kullanici adiniz" />
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Sifre</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="@(showPassword ? "text" : "password")" class="form-control" @bind="ayarlar.Sifre" placeholder="Portal sifreniz" />
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => showPassword = !showPassword">
                                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(hataMesaji))
                        {
                            <div class="alert alert-danger py-2">
                                <i class="bi bi-exclamation-triangle me-2"></i>@hataMesaji
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(basariMesaji))
                        {
                            <div class="alert alert-success py-2">
                                <i class="bi bi-check-circle me-2"></i>@basariMesaji
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" @onclick="BaglantiTest" disabled="@isConnecting">
                                @if (isConnecting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-plug me-1"></i>
                                }
                                Baglanti Test Et
                            </button>
                            <button class="btn btn-success" @onclick="AyarlariKaydet" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i>
                                }
                                Kaydet
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Senkron Ayarlari -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i>Senkronizasyon Ayarlari</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="otomatikSenkron" @bind="ayarlar.OtomatikSenkron">
                            <label class="form-check-label" for="otomatikSenkron">
                                Otomatik Senkronizasyon
                            </label>
                        </div>
                        
                        @if (ayarlar.OtomatikSenkron)
                        {
                            <div class="mb-3">
                                <label class="form-label">Senkron Araligi (Saat)</label>
                                <select class="form-select" @bind="ayarlar.SenkronAralikSaat">
                                    <option value="1">Her saat</option>
                                    <option value="6">6 saatte bir</option>
                                    <option value="12">12 saatte bir</option>
                                    <option value="24">Gunluk</option>
                                </select>
                            </div>
                        }
                        
                        @if (ayarlar.SonSenkronTarihi.HasValue)
                        {
                            <div class="alert alert-info py-2 mb-0">
                                <i class="bi bi-info-circle me-2"></i>
                                Son Senkron: @ayarlar.SonSenkronTarihi.Value.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Hizli Islemler ve Bilgi -->
            <div class="col-md-6">
                <!-- Baglanti Durumu -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Baglanti Durumu</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless mb-0">
                            <tbody>
                                <tr>
                                    <td class="text-muted">Durum:</td>
                                    <td>
                                        @if (baglantiDurumu)
                                        {
                                            <span class="text-success"><i class="bi bi-check-circle me-1"></i>Bagli</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger"><i class="bi bi-x-circle me-1"></i>Bagli Degil</span>
                                        }
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(ayarlar.LucaFirmaKodu))
                                {
                                    <tr>
                                        <td class="text-muted">Firma Kodu:</td>
                                        <td>@ayarlar.LucaFirmaKodu</td>
                                    </tr>
                                }
                                @if (ayarlar.TokenGecerlilikTarihi.HasValue)
                                {
                                    <tr>
                                        <td class="text-muted">Oturum:</td>
                                        <td>
                                            @if (ayarlar.TokenGecerliMi)
                                            {
                                                <span class="text-success">Gecerli (@ayarlar.TokenGecerlilikTarihi.Value.ToString("HH:mm")'e kadar)</span>
                                            }
                                            else
                                            {
                                                <span class="text-warning">Suresi Dolmus</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Hizli Islemler -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Hizli Islemler</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/faturalar/luca-portal")'>
                                <i class="bi bi-file-earmark-arrow-down me-2"></i>Belgeleri Listele ve Indir
                            </button>
                            <button class="btn btn-outline-success" @onclick="ManuelSenkron" disabled="@(!baglantiDurumu || isSyncing)">
                                @if (isSyncing)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Senkronize Ediliyor...</span>
                                }
                                else
                                {
                                    <i class="bi bi-arrow-repeat me-2"></i>
                                    <span>Simdi Senkronize Et</span>
                                }
                            </button>
                            <button class="btn btn-outline-danger" @onclick="OturumuKapat" disabled="@(!baglantiDurumu)">
                                <i class="bi bi-box-arrow-right me-2"></i>Oturumu Kapat
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Yardim -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-question-circle me-2"></i>Yardim</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                Luca Portal hesabiniza giris yapin
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                E-Fatura ve E-Arsiv belgelerinizi gorun
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                XML ve PDF dosyalarini indirin
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                Belgeleri sisteme aktarin
                            </li>
                        </ul>
                        <hr />
                        <small class="text-muted">
                            <i class="bi bi-shield-check me-1"></i>
                            Giris bilgileriniz guvenli bir sekilde saklanir.
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Senkron Log -->
        @if (senkronLog.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-terminal me-2"></i>Senkronizasyon Logu</h5>
                </div>
                <div class="card-body">
                    <div class="bg-dark text-light p-3 rounded" style="max-height: 200px; overflow-y: auto; font-family: monospace; font-size: 0.85rem;">
                        @foreach (var log in senkronLog)
                        {
                            <div>@log</div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private LucaPortalSettings ayarlar = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isConnecting = false;
    private bool isSyncing = false;
    private bool showPassword = false;
    private bool baglantiDurumu = false;
    private string? hataMesaji;
    private string? basariMesaji;
    private List<string> senkronLog = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAyarlar();
    }

    private async Task LoadAyarlar()
    {
        isLoading = true;
        
        try
        {
            var mevcutAyarlar = await LucaService.GetAyarlarAsync();
            if (mevcutAyarlar != null)
            {
                ayarlar = mevcutAyarlar;
            }
            
            // Baglanti durumunu kontrol et
            if (!string.IsNullOrEmpty(ayarlar.KullaniciAdi))
            {
                baglantiDurumu = ayarlar.TokenGecerliMi;
            }
        }
        catch (Exception ex)
        {
            hataMesaji = $"Ayarlar yuklenemedi: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task BaglantiTest()
    {
        if (string.IsNullOrWhiteSpace(ayarlar.KullaniciAdi) || string.IsNullOrWhiteSpace(ayarlar.Sifre))
        {
            hataMesaji = "Kullanici adi ve sifre giriniz";
            basariMesaji = null;
            return;
        }

        isConnecting = true;
        hataMesaji = null;
        basariMesaji = null;
        
        try
        {
            var sonuc = await LucaService.GirisYapAsync(ayarlar.KullaniciAdi, ayarlar.Sifre);
            
            if (sonuc.Basarili)
            {
                baglantiDurumu = true;
                basariMesaji = $"Baglanti basarili! Firma: {sonuc.FirmaUnvan ?? sonuc.FirmaKodu}";
                
                // Ayarlari guncelle
                ayarlar.AccessToken = sonuc.AccessToken;
                ayarlar.TokenGecerlilikTarihi = sonuc.TokenGecerlilikTarihi;
                ayarlar.LucaFirmaKodu = sonuc.FirmaKodu;
                
                ToastService.ShowSuccess("Luca Portal baglantisi basarili!");
            }
            else
            {
                baglantiDurumu = false;
                hataMesaji = sonuc.HataMesaji ?? "Baglanti basarisiz";
                ToastService.ShowError(hataMesaji);
            }
        }
        catch (Exception ex)
        {
            hataMesaji = $"Baglanti hatasi: {ex.Message}";
            baglantiDurumu = false;
        }
        finally
        {
            isConnecting = false;
        }
    }

    private async Task AyarlariKaydet()
    {
        isSaving = true;
        hataMesaji = null;
        
        try
        {
            var sonuc = await LucaService.AyarKaydetAsync(ayarlar);
            
            if (sonuc)
            {
                ToastService.ShowSuccess("Ayarlar kaydedildi!");
                basariMesaji = "Ayarlar basariyla kaydedildi";
            }
            else
            {
                hataMesaji = "Ayarlar kaydedilemedi";
                ToastService.ShowError(hataMesaji);
            }
        }
        catch (Exception ex)
        {
            hataMesaji = $"Kayit hatasi: {ex.Message}";
            ToastService.ShowError(hataMesaji);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ManuelSenkron()
    {
        if (!baglantiDurumu)
        {
            hataMesaji = "Once baglanti kurun";
            return;
        }

        isSyncing = true;
        senkronLog.Clear();
        hataMesaji = null;
        
        try
        {
            var progress = new Progress<string>(mesaj =>
            {
                senkronLog.Add($"[{DateTime.Now:HH:mm:ss}] {mesaj}");
                InvokeAsync(StateHasChanged);
            });
            
            var baslangic = DateTime.Today.AddMonths(-1);
            var bitis = DateTime.Today;
            
            var aktarilanSayi = await LucaService.TumBelgeleriSenkronizeEtAsync(baslangic, bitis, progress);
            
            senkronLog.Add($"[{DateTime.Now:HH:mm:ss}] Tamamlandi. {aktarilanSayi} belge aktarildi.");
            ToastService.ShowSuccess($"Senkronizasyon tamamlandi! {aktarilanSayi} belge aktarildi.");
        }
        catch (Exception ex)
        {
            hataMesaji = $"Senkron hatasi: {ex.Message}";
            senkronLog.Add($"[{DateTime.Now:HH:mm:ss}] HATA: {ex.Message}");
        }
        finally
        {
            isSyncing = false;
        }
    }

    private async Task OturumuKapat()
    {
        try
        {
            await LucaService.CikisYapAsync();
            baglantiDurumu = false;
            ayarlar.AccessToken = null;
            ayarlar.TokenGecerlilikTarihi = null;
            ToastService.ShowInfo("Oturum kapatildi");
        }
        catch (Exception ex)
        {
            hataMesaji = $"Cikis hatasi: {ex.Message}";
        }
    }
}

