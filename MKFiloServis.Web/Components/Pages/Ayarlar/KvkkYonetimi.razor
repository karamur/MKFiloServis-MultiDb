@page "/ayarlar/kvkk"
@using MKFiloServis.Web.Data
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> ContextFactory
@inject IDataExportService ExportService
@inject IJSRuntime JS
@inject IToastService Toast
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>KVKK / Kişisel Veri Yönetimi</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
            <i class="bi bi-shield-lock-fill text-primary fs-4"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-bold">KVKK / Kişisel Veri Yönetimi</h4>
            <small class="text-muted">6698 sayılı Kişisel Verilerin Korunması Kanunu uyumluluk araçları</small>
        </div>
    </div>

    <div class="row g-4">

        <!-- Veri Dışa Aktarım -->
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-download me-2 text-primary"></i>Kişisel Veri Dışa Aktarımı
                </div>
                <div class="card-body">
                    <p class="text-muted small">Bir kişiye ait tüm kişisel veriyi KVKK madde 11 kapsamında dışa aktarın.</p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Veri Sahibi Türü</label>
                        <select class="form-select" @bind="seciliTur">
                            <option value="personel">Personel</option>
                            <option value="sofor">Şoför</option>
                            <option value="kullanici">Kullanıcı</option>
                            <option value="cari">Cari</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">ID veya Ad</label>
                        <input class="form-control" @bind="aramaMetni" placeholder="Ad soyad veya ID girin..." />
                    </div>
                    <button class="btn btn-primary" @onclick="VeriAktar" disabled="@islem">
                        <i class="bi bi-download me-2"></i>JSON Olarak İndir
                    </button>
                </div>
            </div>
        </div>

        <!-- Anonimleştirme / Silme -->
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-eraser me-2 text-danger"></i>Kişisel Veri Silme / Anonimleştirme
                </div>
                <div class="card-body">
                    <p class="text-muted small">KVKK madde 7 kapsamında kişisel verileri silin veya anonimleştirin.</p>
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Bu işlem geri alınamaz. Silinen veriler audit log'da kayıt altına alınır.
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Kullanıcı Adı veya E-posta</label>
                        <input class="form-control" @bind="silmeHedefi" placeholder="Kullanıcı adı veya e-posta..." />
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="onayCheck" @bind="silmeOnay" />
                        <label class="form-check-label text-danger" for="onayCheck">
                            Bu işlemin geri alınamaz olduğunu onaylıyorum.
                        </label>
                    </div>
                    <button class="btn btn-outline-danger" @onclick="VeriSil"
                            disabled="@(!silmeOnay || islem || string.IsNullOrWhiteSpace(silmeHedefi))">
                        <i class="bi bi-trash me-2"></i>Veriyi Sil / Anonimleştir
                    </button>
                </div>
            </div>
        </div>

        <!-- KVKK Aydınlatma Metni -->
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-file-text me-2 text-success"></i>Veri İşleme Özeti
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var kategori in veriKategorileri)
                        {
                            <div class="col-6 col-md-3">
                                <div class="border rounded-3 p-3 text-center">
                                    <i class="bi @kategori.Ikon fs-3 text-primary mb-2 d-block"></i>
                                    <div class="fw-bold">@kategori.Ad</div>
                                    <small class="text-muted">@kategori.Aciklama</small>
                                </div>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-12 col-md-6">
                            <h6 class="fw-bold">İşlenen Kişisel Veri Kategorileri</h6>
                            <ul class="small text-muted">
                                <li>Kimlik bilgileri (ad, soyad, T.C. Kimlik No)</li>
                                <li>İletişim bilgileri (telefon, e-posta, adres)</li>
                                <li>Çalışma bilgileri (pozisyon, departman, maaş)</li>
                                <li>Mali bilgiler (banka hesabı, IBAN)</li>
                                <li>Sürücü bilgileri (ehliyet, plaka, sefer kayıtları)</li>
                            </ul>
                        </div>
                        <div class="col-12 col-md-6">
                            <h6 class="fw-bold">Veri Saklama Süreleri</h6>
                            <ul class="small text-muted">
                                <li>Personel kayıtları: İş ilişkisi + 10 yıl</li>
                                <li>Fatura kayıtları: 10 yıl (VUK)</li>
                                <li>Sürücü kayıtları: 5 yıl</li>
                                <li>Audit log: 2 yıl</li>
                                <li>Sistem logları: 1 yıl</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit Log Kısa Özet -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span><i class="bi bi-clock-history me-2"></i>Son Veri Erişim Kayıtları</span>
                    <a href="/ayarlar/auditlog" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
                </div>
                <div class="card-body p-0">
                    @if (auditLoglar.Count == 0)
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-check-circle fs-4 d-block mb-2"></i>
                            Kayıt bulunamadı.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead><tr>
                                    <th>Tarih</th><th>Kullanıcı</th><th>İşlem</th><th>Tablo</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var log in auditLoglar)
                                    {
                                        <tr>
                                            <td><small>@log.Tarih.ToString("dd.MM HH:mm")</small></td>
                                            <td><small>@log.KullaniciAdi</small></td>
                                            <td><span class="badge @IslemRenk(log.IslemTipi)">@log.IslemTipi</span></td>
                                            <td><small class="text-muted">@log.TabloAdi</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string seciliTur = "personel";
    private string aramaMetni = string.Empty;
    private string silmeHedefi = string.Empty;
    private bool silmeOnay = false;
    private bool islem = false;
    private List<AuditLogSatir> auditLoglar = new();

    private record AuditLogSatir(DateTime Tarih, string KullaniciAdi, string IslemTipi, string TabloAdi);

    private readonly List<(string Ad, string Ikon, string Aciklama)> veriKategorileri = new()
    {
        ("Personel", "bi-person-badge", "Ad, SGK, maaş"),
        ("Araç & Şoför", "bi-truck", "Plaka, sürücü, konum"),
        ("Cari", "bi-building", "Firma, iletişim"),
        ("Finans", "bi-bank", "Fatura, ödeme")
    };

    protected override async Task OnInitializedAsync()
    {
        await YukleAuditLogAsync();
    }

    private async Task YukleAuditLogAsync()
    {
        try
        {
            await using var ctx = await ContextFactory.CreateDbContextAsync();
            var kayitlar = await ctx.AuditLoglar
                .OrderByDescending(a => a.IslemTarihi)
                .Take(20)
                .ToListAsync();
            auditLoglar = kayitlar.Select(a => new AuditLogSatir(
                a.IslemTarihi, a.KullaniciAdi ?? "Sistem", a.IslemTipi ?? "-", a.EntityAdi ?? "-")).ToList();
        }
        catch { auditLoglar = new(); }
    }

    private async Task VeriAktar()
    {
        if (string.IsNullOrWhiteSpace(aramaMetni)) return;
        islem = true;
        try
        {
            await using var ctx = await ContextFactory.CreateDbContextAsync();
            object? veri = seciliTur switch
            {
                "personel" => await ctx.Soforler
                    .Where(s => !s.IsDeleted && ((s.Ad + " " + s.Soyad).Contains(aramaMetni) || s.Id.ToString() == aramaMetni))
                    .Select(s => new { s.Id, Ad = s.Ad + " " + s.Soyad, s.Email, s.Telefon, s.Departman, s.Pozisyon })
                    .ToListAsync(),
                "sofor" => await ctx.Soforler
                    .Where(s => !s.IsDeleted && ((s.Ad + " " + s.Soyad).Contains(aramaMetni) || s.Id.ToString() == aramaMetni))
                    .Select(s => new { s.Id, AdSoyad = s.Ad + " " + s.Soyad, s.Telefon, s.EhliyetNo })
                    .ToListAsync(),
                "kullanici" => await ctx.Kullanicilar
                    .Where(k => !k.IsDeleted && (k.KullaniciAdi.Contains(aramaMetni) || (k.Email != null && k.Email.Contains(aramaMetni))))
                    .Select(k => new { k.Id, k.KullaniciAdi, k.Email, k.AdSoyad })
                    .ToListAsync(),
                _ => await ctx.Cariler
                    .Where(c => !c.IsDeleted && (c.Unvan.Contains(aramaMetni) || c.Id.ToString() == aramaMetni))
                    .Select(c => new { c.Id, FirmaAdi = c.Unvan, c.Email, c.Telefon, c.Adres })
                    .ToListAsync()
            };

            if (veri == null)
            {
                Toast.ShowWarning("Veri bulunamadı.");
                return;
            }

            var json = System.Text.Json.JsonSerializer.SerializeToUtf8Bytes(veri,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var b64 = Convert.ToBase64String(json);
            await JS.InvokeVoidAsync("downloadBase64File", b64, $"kvkk-veri-{seciliTur}-{DateTime.Now:yyyyMMddHHmm}.json", "application/json");
            Toast.ShowSuccess("Veri başarıyla dışa aktarıldı.");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Hata: {ex.Message}");
        }
        finally { islem = false; }
    }

    private async Task VeriSil()
    {
        if (!silmeOnay || string.IsNullOrWhiteSpace(silmeHedefi)) return;
        islem = true;
        try
        {
            await using var ctx = await ContextFactory.CreateDbContextAsync();
            var kullanici = await ctx.Kullanicilar
                .FirstOrDefaultAsync(k => k.KullaniciAdi == silmeHedefi || k.Email == silmeHedefi);

            if (kullanici == null)
            {
                Toast.ShowWarning("Kullanıcı bulunamadı.");
                return;
            }

            // Anonimleştir - soft delete + kişisel bilgileri sil
            kullanici.AdSoyad = $"[SİLİNDİ-{kullanici.Id}]";
            kullanici.Email = $"deleted_{kullanici.Id}@kvkk.local";
            kullanici.IsDeleted = true;
            await ctx.SaveChangesAsync();

            Toast.ShowSuccess($"Kullanıcı verileri anonimleştirildi (ID: {kullanici.Id}).");
            silmeHedefi = string.Empty;
            silmeOnay = false;
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Hata: {ex.Message}");
        }
        finally { islem = false; }
    }

    private static string IslemRenk(string tip) => tip switch
    {
        "Insert" or "Create" => "bg-success",
        "Update" or "Edit" => "bg-warning text-dark",
        "Delete" => "bg-danger",
        _ => "bg-secondary"
    };
}

