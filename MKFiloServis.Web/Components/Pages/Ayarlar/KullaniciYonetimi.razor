@page "/ayarlar/kullanicilar"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.WebUtilities
@using YetkilerClass = MKFiloServis.Shared.Entities.Yetkiler
@inject IKullaniciService KullaniciService
@inject MKFiloServis.Web.Services.LicenseService LicenseService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Kullanici ve Rol Yonetimi</PageTitle>

<MKFiloServis.Web.Components.Shared.YetkiKontrol Yetki="@YetkilerClass.KullaniciYonetimiOku" GerekliYetkiAdi="Kullanıcı Yönetimi">
    <Yetkili>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-people me-2"></i>Kullanici ve Rol Yonetimi</h3>
        <div class="btn-group">
            <button class="btn @(aktifSekme == "kullanicilar" ? "btn-primary" : "btn-outline-primary")" @onclick='() => aktifSekme = "kullanicilar"'>
                <i class="bi bi-person-lines-fill me-1"></i>Kullanicilar
            </button>
            <button class="btn @(aktifSekme == "roller" ? "btn-primary" : "btn-outline-primary")" @onclick='() => aktifSekme = "roller"'>
                <i class="bi bi-shield-check me-1"></i>Roller ve Yetkiler
            </button>
        </div>
    </div>

    @if (!kullaniciEklenebilir)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Lisans limitine ulasildi. Maksimum @(lisans?.IsDemo == true ? "5" : "sınırsız") kullanici ekleyebilirsiniz.
        </div>
    }

    @if (aktifSekme == "kullanicilar")
    {
        <!-- KULLANICILAR SEKMESI -->
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-person-lines-fill me-2"></i>Kullanicilar (@FiltrelenmisKullanicilar.Count)</h5>
                <button class="btn btn-primary btn-sm" @onclick="YeniKullaniciAc" disabled="@(!kullaniciEklenebilir)">
                    <i class="bi bi-plus-lg me-1"></i>Yeni Kullanici
                </button>
            </div>
            <div class="card-body p-0">
                <div class="p-3 border-bottom bg-light-subtle">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label mb-1">Durum Filtresi</label>
                            <select class="form-select form-select-sm" @bind="durumFiltresi">
                                <option value="tum">Tum Kullanıcılar</option>
                                <option value="aktif">Sadece Aktif</option>
                                <option value="pasif">Sadece Pasif</option>
                                <option value="kilitli">Sadece Kilitli</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label mb-1">Rol Filtresi</label>
                            <select class="form-select form-select-sm" @bind="rolFiltresi">
                                <option value="tum">Tum Roller</option>
                                @foreach (var rol in roller)
                                {
                                    <option value="@rol.Id">@rol.RolAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label mb-1">Arama</label>
                            <input type="text" class="form-control form-control-sm" @bind="aramaMetni" placeholder="Kullanici adi / ad soyad" />
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Kullanici Adi</th>
                                <th>Ad Soyad</th>
                                <th>Rol</th>
                                <th>Son Giris</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kullanici in FiltrelenmisKullanicilar)
                            {
                                var rolTanim = SistemRolleri.GetAllRoles().FirstOrDefault(r => r.Name == kullanici.Rol?.RolAdi);
                                <tr>
                                    <td>
                                        <i class="bi bi-person-circle me-2 text-primary"></i>
                                        <strong>@kullanici.KullaniciAdi</strong>
                                    </td>
                                    <td>@kullanici.AdSoyad</td>
                                    <td>
                                        <span class="badge" style="background-color: @(rolTanim?.Color ?? kullanici.Rol?.Renk ?? "#6c757d")">
                                            @if (rolTanim != null)
                                            {
                                                <i class="@rolTanim.Icon me-1"></i>
                                            }
                                            @kullanici.Rol?.RolAdi
                                        </span>
                                    </td>
                                    <td>
                                        @if (kullanici.SonGirisTarihi.HasValue)
                                        {
                                            <small>@kullanici.SonGirisTarihi.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (kullanici.Kilitli)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-lock me-1"></i>Kilitli</span>
                                        }
                                        else if (kullanici.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pasif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => DuzenleAc(kullanici)" title="Duzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn @(kullanici.Aktif ? "btn-outline-warning" : "btn-outline-success")" @onclick="() => AktiflikDegistirAsync(kullanici)" title="@(kullanici.Aktif ? "Pasife Al" : "Aktife Al")">
                                                <i class="bi @(kullanici.Aktif ? "bi-pause-circle" : "bi-play-circle")"></i>
                                            </button>
                                            @if (kullanici.Kilitli)
                                            {
                                                <button class="btn btn-outline-warning" @onclick="() => KilidiKaldirAsync(kullanici)" title="Kilidi Kaldir">
                                                    <i class="bi bi-unlock"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-secondary" @onclick="() => SifreSifirlaAc(kullanici)" title="Sifre Sifirla">
                                                <i class="bi bi-key"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- ROLLER VE YETKILER SEKMESI -->
        <div class="row g-3">
            <!-- Roller Listesi -->
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-shield-check me-2"></i>Roller</h5>
                        <button class="btn btn-primary btn-sm" @onclick="YeniRolAc">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var rol in roller)
                            {
                                var rolTanim = SistemRolleri.GetAllRoles().FirstOrDefault(r => r.Name == rol.RolAdi);
                                var secilenMi = secilenRol?.Id == rol.Id;
                                <button class="list-group-item list-group-item-action @(secilenMi ? "active" : "")" @onclick="() => RolSec(rol)">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <span class="rounded-circle d-inline-flex align-items-center justify-content-center me-2"
                                                  style="width: 32px; height: 32px; background-color: @(rolTanim?.Color ?? rol.Renk ?? "#6c757d"); color: white; font-size: 0.8rem;">
                                                <i class="@(rolTanim?.Icon ?? "bi-shield")"></i>
                                            </span>
                                            <div>
                                                <strong>@(rolTanim?.DisplayName ?? rol.RolAdi)</strong>
                                                @if (rol.SistemRolu)
                                                {
                                                    <i class="bi bi-lock-fill text-muted ms-1" style="font-size: 0.7rem;" title="Sistem Rolu"></i>
                                                }
                                                <br />
                                                <small class="@(secilenMi ? "text-white-50" : "text-muted")">
                                                    @(rol.Yetkiler?.Count(y => y.Izin) ?? 0) yetki | @(rol.Kullanicilar?.Count ?? 0) kullanici
                                                </small>
                                            </div>
                                        </div>
                                        @if (!rol.SistemRolu || rol.RolAdi != SistemRolleri.Admin)
                                        {
                                            <i class="bi bi-chevron-right"></i>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Yetki Yonetimi -->
            <div class="col-md-8">
                @if (secilenRol != null)
                {
                    var secilenRolTanim = SistemRolleri.GetAllRoles().FirstOrDefault(r => r.Name == secilenRol.RolAdi);
                    <div class="card shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <span class="rounded-circle d-inline-flex align-items-center justify-content-center me-2"
                                      style="width: 36px; height: 36px; background-color: @(secilenRolTanim?.Color ?? secilenRol.Renk ?? "#6c757d"); color: white;">
                                    <i class="@(secilenRolTanim?.Icon ?? "bi-shield")"></i>
                                </span>
                                <div>
                                    <h5 class="mb-0">@(secilenRolTanim?.DisplayName ?? secilenRol.RolAdi) Yetkileri</h5>
                                    <small class="text-muted">@(secilenRolTanim?.Description ?? secilenRol.Aciklama ?? "")</small>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                @if (secilenRol.RolAdi != SistemRolleri.Admin)
                                {
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="VarsayilanlariUygula" title="Varsayilan yetkilere sifirla">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>Sifirla
                                    </button>
                                    <button class="btn btn-success btn-sm" @onclick="YetkileriKaydet" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-check-lg me-1"></i>Kaydet
                                    </button>
                                }
                                @if (!secilenRol.SistemRolu)
                                {
                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => RolDuzenleAc(secilenRol)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RolSilOnay(secilenRol)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            @if (secilenRol.RolAdi == SistemRolleri.Admin)
                            {
                                <div class="alert alert-info mb-3">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <strong>Admin</strong> rolu tum sistem yetkilerine varsayilan olarak sahiptir ve yetkileri degistirilemez.
                                </div>
                                <div class="row g-2">
                                    @foreach (var group in YetkilerClass.GetGrouped())
                                    {
                                        <div class="col-md-4 col-lg-3">
                                            <div class="border rounded p-2 bg-success bg-opacity-10 h-100">
                                                <strong class="text-success"><i class="bi bi-check-circle-fill me-1"></i>@group.Key</strong>
                                                <div class="mt-1">
                                                    <span class="badge bg-success">Tam Yetki</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="row g-3">
                                    @foreach (var group in YetkilerClass.GetGrouped())
                                    {
                                        <div class="col-md-6 col-lg-4">
                                            <div class="border rounded p-2 h-100">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <strong>@group.Key</strong>
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox"
                                                               checked="@GrupTumSeciliMi(group.Value)"
                                                               @onchange="(e) => GrupToggle(group.Value, (bool)(e.Value ?? false))" />
                                                    </div>
                                                </div>
                                                @foreach (var yetki in group.Value)
                                                {
                                                    <div class="form-check mb-1">
                                                        <input class="form-check-input" type="checkbox" id="@($"perm_{yetki.Kod}")"
                                                               checked="@secilenYetkiler.Contains(yetki.Kod)"
                                                               @onchange="(e) => YetkiToggle(yetki.Kod, (bool)(e.Value ?? false))" />
                                                        <label class="form-check-label" for="@($"perm_{yetki.Kod}")">
                                                            <i class="bi @yetki.Icon me-1 text-muted" style="font-size: 0.8rem;"></i>
                                                            <small>@yetki.Adi</small>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow-sm">
                        <div class="card-body text-center py-5 text-muted">
                            <i class="bi bi-shield-check" style="font-size: 3rem;"></i>
                            <p class="mt-2">Yetkileri goruntulemek icin soldan bir rol secin</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Kullanici Ekle/Duzenle Modal -->
@if (showKullaniciModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(editKullanici.Id > 0 ? "Kullanici Duzenle" : "Yeni Kullanici")
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kullanici Adi *</label>
                            <input type="text" class="form-control" @bind="editKullanici.KullaniciAdi"
                                   disabled="@(editKullanici.Id > 0)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ad Soyad *</label>
                            <input type="text" class="form-control" @bind="editKullanici.AdSoyad" />
                        </div>
                        @if (editKullanici.Id == 0)
                        {
                            <div class="col-12">
                                <label class="form-label">Sifre *</label>
                                <input type="password" class="form-control" @bind="yeniSifre" />
                            </div>
                        }
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="editKullanici.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" @bind="editKullanici.Telefon" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Rol *</label>
                            <select class="form-select" @bind="editKullanici.RolId">
                                @foreach (var rol in roller)
                                {
                                    var rt = SistemRolleri.GetAllRoles().FirstOrDefault(r => r.Name == rol.RolAdi);
                                    <option value="@rol.Id">@(rt?.DisplayName ?? rol.RolAdi)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" @bind="editKullanici.Aktif" />
                                <label class="form-check-label">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button class="btn btn-primary" @onclick="KullaniciKaydetAsync">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Sifre Sifirlama Modal -->
@if (showSifreModal && secilenKullanici != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Sifre Sifirla</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <p>@secilenKullanici.AdSoyad icin yeni sifre:</p>
                    <input type="password" class="form-control" @bind="yeniSifre" placeholder="Yeni Sifre" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button class="btn btn-warning" @onclick="SifreSifirlaAsync">
                        <i class="bi bi-key me-1"></i>Sifirla
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Rol Ekle/Duzenle Modal -->
@if (showRolModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editRol.Id > 0 ? "Rol Duzenle" : "Yeni Rol")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Rol Adi *</label>
                        <input type="text" class="form-control" @bind="editRol.RolAdi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="editRol.Aciklama" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Renk</label>
                        <input type="color" class="form-control form-control-color" @bind="editRol.Renk" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button class="btn btn-primary" @onclick="RolKaydetAsync">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string aktifSekme = "kullanicilar";
    private List<Kullanici> kullanicilar = new();
    private List<Rol> roller = new();
    private LicenseInfo? lisans;
    private bool kullaniciEklenebilir = true;
    private static readonly HashSet<string> GecerliDurumFiltreleri = new(StringComparer.OrdinalIgnoreCase) { "tum", "aktif", "pasif", "kilitli" };
    private bool querydenYukleniyor = false;
    private string _durumFiltresi = "tum";
    private string durumFiltresi
    {
        get => _durumFiltresi;
        set
        {
            if (_durumFiltresi == value) return;
            _durumFiltresi = value;
            QueryStringFiltreleriniGuncelle();
        }
    }
    private string _rolFiltresi = "tum";
    private string rolFiltresi
    {
        get => _rolFiltresi;
        set
        {
            if (_rolFiltresi == value) return;
            _rolFiltresi = value;
            QueryStringFiltreleriniGuncelle();
        }
    }
    private string _aramaMetni = "";
    private string aramaMetni
    {
        get => _aramaMetni;
        set
        {
            if (_aramaMetni == value) return;
            _aramaMetni = value;
            QueryStringFiltreleriniGuncelle();
        }
    }

    private List<Kullanici> FiltrelenmisKullanicilar => kullanicilar
        .Where(DurumFiltresineUygun)
        .Where(RolFiltresineUygun)
        .Where(AramayaUygun)
        .ToList();

    // Kullanici modal
    private bool showKullaniciModal = false;
    private bool showSifreModal = false;
    private Kullanici editKullanici = new();
    private Kullanici? secilenKullanici;
    private string yeniSifre = "";

    // Rol/Yetki
    private bool showRolModal = false;
    private Rol editRol = new();
    private Rol? secilenRol;
    private HashSet<string> secilenYetkiler = new();
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        FiltreleriQuerydenYukle();
    }

    private async Task LoadDataAsync()
    {
        kullanicilar = await KullaniciService.GetAllAsync();
        roller = await KullaniciService.GetRollerAsync();
        lisans = await LicenseService.GetCurrentLicenseAsync();
        kullaniciEklenebilir = await LicenseService.CheckUserLimitAsync(kullanicilar.Count);
    }

    private bool DurumFiltresineUygun(Kullanici kullanici) => durumFiltresi switch
    {
        "aktif" => kullanici.Aktif && !kullanici.Kilitli,
        "pasif" => !kullanici.Aktif && !kullanici.Kilitli,
        "kilitli" => kullanici.Kilitli,
        _ => true
    };

    private bool RolFiltresineUygun(Kullanici kullanici)
    {
        if (rolFiltresi == "tum")
            return true;

        return int.TryParse(rolFiltresi, out var rolId) && kullanici.RolId == rolId;
    }

    private bool AramayaUygun(Kullanici kullanici)
    {
        if (string.IsNullOrWhiteSpace(aramaMetni))
            return true;

        return (kullanici.KullaniciAdi?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false)
            || (kullanici.AdSoyad?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void FiltreleriQuerydenYukle()
    {
        querydenYukleniyor = true;
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        var durum = query.TryGetValue("durum", out var d) ? d.ToString() : "tum";
        _durumFiltresi = GecerliDurumFiltreleri.Contains(durum) ? durum : "tum";

        var rol = query.TryGetValue("rol", out var r) ? r.ToString() : "tum";
        _rolFiltresi = rol == "tum" || int.TryParse(rol, out _) ? rol : "tum";

        _aramaMetni = query.TryGetValue("arama", out var a) ? a.ToString() : string.Empty;
        querydenYukleniyor = false;
    }

    private void QueryStringFiltreleriniGuncelle()
    {
        if (querydenYukleniyor)
            return;

        var mevcutUri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var basePath = mevcutUri.GetLeftPart(UriPartial.Path);
        var query = new Dictionary<string, string?>();

        if (_durumFiltresi != "tum") query["durum"] = _durumFiltresi;
        if (_rolFiltresi != "tum") query["rol"] = _rolFiltresi;
        if (!string.IsNullOrWhiteSpace(_aramaMetni)) query["arama"] = _aramaMetni;

        var yeniUri = query.Count > 0 ? QueryHelpers.AddQueryString(basePath, query) : basePath;
        if (!string.Equals(Navigation.Uri, yeniUri, StringComparison.Ordinal))
            Navigation.NavigateTo(yeniUri, replace: true);
    }

    #region Kullanici Islemleri

    private void YeniKullaniciAc()
    {
        editKullanici = new Kullanici { Aktif = true, RolId = roller.FirstOrDefault()?.Id ?? 0 };
        yeniSifre = "";
        showKullaniciModal = true;
    }

    private void DuzenleAc(Kullanici kullanici)
    {
        editKullanici = new Kullanici
        {
            Id = kullanici.Id,
            KullaniciAdi = kullanici.KullaniciAdi,
            AdSoyad = kullanici.AdSoyad,
            Email = kullanici.Email,
            Telefon = kullanici.Telefon,
            RolId = kullanici.RolId,
            Aktif = kullanici.Aktif
        };
        showKullaniciModal = true;
    }

    private void SifreSifirlaAc(Kullanici kullanici)
    {
        secilenKullanici = kullanici;
        yeniSifre = "";
        showSifreModal = true;
    }

    private async Task KullaniciKaydetAsync()
    {
        if (string.IsNullOrWhiteSpace(editKullanici.KullaniciAdi) || string.IsNullOrWhiteSpace(editKullanici.AdSoyad))
        {
            ToastService.ShowWarning("Kullanici adi ve ad soyad zorunlu!");
            return;
        }

        try
        {
            if (editKullanici.Id > 0)
            {
                await KullaniciService.UpdateAsync(editKullanici);
                ToastService.ShowSuccess("Kullanici guncellendi!");
            }
            else
            {
                if (string.IsNullOrWhiteSpace(yeniSifre))
                {
                    ToastService.ShowWarning("Sifre zorunlu!");
                    return;
                }
                await KullaniciService.CreateAsync(editKullanici, yeniSifre);
                ToastService.ShowSuccess("Kullanici eklendi!");
            }
            ModalKapat();
            await LoadDataAsync();
        FiltreleriQuerydenYukle();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task SifreSifirlaAsync()
    {
        if (secilenKullanici == null || string.IsNullOrWhiteSpace(yeniSifre))
        {
            ToastService.ShowWarning("Sifre bos olamaz!");
            return;
        }

        try
        {
            await KullaniciService.SifreSifirlaAsync(secilenKullanici.Id, yeniSifre);
            ToastService.ShowSuccess("Sifre sifirlandi!");
            ModalKapat();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task KilidiKaldirAsync(Kullanici kullanici)
    {
        try
        {
            await KullaniciService.SifreSifirlaAsync(kullanici.Id, "123456");
            ToastService.ShowSuccess("Kilit kaldirildi, yeni sifre: 123456");
            await LoadDataAsync();
        FiltreleriQuerydenYukle();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task AktiflikDegistirAsync(Kullanici kullanici)
    {
        var aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();
        if (aktifKullanici?.Id == kullanici.Id && kullanici.Aktif)
        {
            ToastService.ShowWarning("Aktif oturumdaki kullanıcı pasife alınamaz.");
            return;
        }

        try
        {
            var guncel = await KullaniciService.ToggleAktifAsync(kullanici.Id);
            ToastService.ShowSuccess($"{guncel.AdSoyad} için durum {(guncel.Aktif ? "aktif" : "pasif")} yapıldı.");
            await LoadDataAsync();
        FiltreleriQuerydenYukle();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    #endregion

    #region Rol Islemleri

    private void YeniRolAc()
    {
        editRol = new Rol { Renk = "#0d6efd" };
        showRolModal = true;
    }

    private void RolDuzenleAc(Rol rol)
    {
        editRol = new Rol
        {
            Id = rol.Id,
            RolAdi = rol.RolAdi,
            Aciklama = rol.Aciklama,
            Renk = rol.Renk ?? "#6c757d"
        };
        showRolModal = true;
    }

    private async Task RolKaydetAsync()
    {
        if (string.IsNullOrWhiteSpace(editRol.RolAdi))
        {
            ToastService.ShowWarning("Rol adi zorunlu!");
            return;
        }

        try
        {
            if (editRol.Id > 0)
            {
                await KullaniciService.UpdateRolAsync(editRol);
                ToastService.ShowSuccess("Rol guncellendi!");
            }
            else
            {
                await KullaniciService.CreateRolAsync(editRol);
                ToastService.ShowSuccess("Rol eklendi!");
            }
            ModalKapat();
            await LoadDataAsync();
        FiltreleriQuerydenYukle();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task RolSilOnay(Rol rol)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{rol.RolAdi}' rolunu silmek istediginize emin misiniz?");
        if (confirmed)
        {
            try
            {
                await KullaniciService.DeleteRolAsync(rol.Id);
                ToastService.ShowSuccess("Rol silindi!");
                secilenRol = null;
                await LoadDataAsync();
        FiltreleriQuerydenYukle();
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Hata: " + ex.Message);
            }
        }
    }

    private void RolSec(Rol rol)
    {
        secilenRol = rol;
        // Mevcut yetkileri yukle
        secilenYetkiler = new HashSet<string>(
            rol.Yetkiler?.Where(y => y.Izin).Select(y => y.YetkiKodu) ?? Enumerable.Empty<string>()
        );
    }

    #endregion

    #region Yetki Islemleri

    private void YetkiToggle(string yetkiKodu, bool izin)
    {
        if (izin)
            secilenYetkiler.Add(yetkiKodu);
        else
            secilenYetkiler.Remove(yetkiKodu);
    }

    private bool GrupTumSeciliMi(List<YetkiTanim> yetkiler)
    {
        return yetkiler.All(y => secilenYetkiler.Contains(y.Kod));
    }

    private void GrupToggle(List<YetkiTanim> yetkiler, bool izin)
    {
        foreach (var yetki in yetkiler)
        {
            if (izin)
                secilenYetkiler.Add(yetki.Kod);
            else
                secilenYetkiler.Remove(yetki.Kod);
        }
    }

    private async Task VarsayilanlariUygula()
    {
        if (secilenRol == null) return;
        var defaults = SistemRolleri.GetDefaultPermissions(secilenRol.RolAdi);
        secilenYetkiler = new HashSet<string>(defaults);
        StateHasChanged();
        ToastService.ShowInfo("Varsayilan yetkiler yuklendi. Kaydetmeyi unutmayin.");
    }

    private async Task YetkileriKaydet()
    {
        if (secilenRol == null) return;
        isSaving = true;
        StateHasChanged();

        try
        {
            await KullaniciService.SetRolYetkileriAsync(secilenRol.Id, secilenYetkiler.ToList());
            ToastService.ShowSuccess($"'{secilenRol.RolAdi}' yetkileri kaydedildi! ({secilenYetkiler.Count} yetki)");
            await LoadDataAsync();
        FiltreleriQuerydenYukle();

            // Secili rolu guncelle
            secilenRol = roller.FirstOrDefault(r => r.Id == secilenRol.Id);
            if (secilenRol != null)
                RolSec(secilenRol);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    #endregion

    private void ModalKapat()
    {
        showKullaniciModal = false;
        showSifreModal = false;
        showRolModal = false;
        secilenKullanici = null;
    }
}

