@page "/ayarlar/veritabani"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject IDatabaseSettingsService DbSettingsService
@inject IBackupService BackupService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Veritabani Ayarlari</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-database-gear me-2"></i>Veritabani Baglanti Ayarlari</h3>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-plug me-2"></i>Baglanti Bilgileri</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-12">
                                <label class="form-label fw-bold">Calisma Veritabani</label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="dbProvider" id="btnPostgreSQL"
                                           checked="@(settings.Provider == DatabaseProvider.PostgreSQL)"
                                           @onchange="() => ProviderDegistir(DatabaseProvider.PostgreSQL)">
                                    <label class="btn btn-outline-primary" for="btnPostgreSQL">
                                        <i class="bi bi-database me-1"></i>PostgreSQL
                                    </label>

                                    <input type="radio" class="btn-check" name="dbProvider" id="btnSQLServer"
                                           checked="@(settings.Provider == DatabaseProvider.SQLServer)"
                                           @onchange="() => ProviderDegistir(DatabaseProvider.SQLServer)">
                                    <label class="btn btn-outline-secondary" for="btnSQLServer">
                                        <i class="bi bi-server me-1"></i>SQL Server
                                    </label>

                                    <input type="radio" class="btn-check" name="dbProvider" id="btnMySQL"
                                           checked="@(settings.Provider == DatabaseProvider.MySQL)"
                                           @onchange="() => ProviderDegistir(DatabaseProvider.MySQL)">
                                    <label class="btn btn-outline-warning" for="btnMySQL">
                                        <i class="bi bi-hdd-network me-1"></i>MySQL
                                    </label>

                                    <input type="radio" class="btn-check" name="dbProvider" id="btnSQLite"
                                           checked="@(settings.Provider == DatabaseProvider.SQLite)"
                                           @onchange="() => ProviderDegistir(DatabaseProvider.SQLite)">
                                    <label class="btn btn-outline-info" for="btnSQLite">
                                        <i class="bi bi-file-earmark-binary me-1"></i>SQLite
                                    </label>
                                </div>
                                <small class="text-muted d-block mt-2">Kanonik migration ve veri modeli kaynagi her zaman PostgreSQL olarak korunur.</small>
                            </div>
                        </div>

                        <div class="alert alert-secondary py-2">
                            <strong>Kanonik Veritabani:</strong> PostgreSQL
                            <br />
                            <small>SQLite secildiginde dahi migration replay yerine gecis manifesti ve veri donusum akisi kullanilir.</small>
                        </div>

                        @if (settings.Provider != DatabaseProvider.SQLite)
                        {
                            <div class="row mb-3">
                                <div class="col-md-8">
                                    <label class="form-label">Sunucu Adresi (Host)</label>
                                    <input type="text" class="form-control" @bind="settings.Host" placeholder="localhost veya IP adresi" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Port</label>
                                    <input type="number" class="form-control" @bind="settings.Port" />
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Veritabani Adi</label>
                            @if (settings.Provider == DatabaseProvider.SQLite)
                            {
                                <input type="text" class="form-control" @bind="settings.DatabaseName" placeholder="MKFiloServis.db" />
                                <small class="text-muted">SQLite icin dosya adi girin. Manifest ve sonraki gecis bilgileri App_Data/db-transitions altinda saklanir.</small>
                            }
                            else
                            {
                                <input type="text" class="form-control" @bind="settings.DatabaseName" placeholder="MKFiloServis" />
                            }
                        </div>

                        @if (settings.Provider != DatabaseProvider.SQLite)
                        {
                            @if (settings.Provider == DatabaseProvider.SQLServer)
                            {
                                <div class="mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" @bind="settings.UseIntegratedSecurity" id="useIntegratedSecurity" />
                                        <label class="form-check-label" for="useIntegratedSecurity">
                                            Windows Authentication kullan
                                        </label>
                                    </div>
                                </div>
                            }

                            @if (settings.Provider != DatabaseProvider.SQLServer || !settings.UseIntegratedSecurity)
                            {
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Kullanici Adi</label>
                                        <input type="text" class="form-control" @bind="settings.Username" placeholder="@(settings.Provider == DatabaseProvider.MySQL ? "root" : settings.Provider == DatabaseProvider.SQLServer ? "sa" : "postgres")" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Sifre</label>
                                        <div class="input-group">
                                            <input type="@(showPassword ? "text" : "password")" class="form-control" @bind="settings.Password" />
                                            <button class="btn btn-outline-secondary" type="button" @onclick="() => showPassword = !showPassword">
                                                <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }

                        <!-- Baglanti Dizesi Onizleme -->
                        <div class="mb-3">
                            <label class="form-label">Baglanti Dizesi (Connection String)</label>
                            <div class="input-group">
                                <input type="text" class="form-control font-monospace" value="@settings.GetConnectionString()" readonly />
                                <button class="btn btn-outline-secondary" type="button" @onclick="CopyConnectionString" title="Kopyala">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(testMessage))
                        {
                            <div class="alert @(testSuccess ? "alert-success" : "alert-danger") py-2">
                                <i class="bi @(testSuccess ? "bi-check-circle" : "bi-x-circle") me-2"></i>@testMessage
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button class="btn btn-info" @onclick="TestConnection" disabled="@isTesting">
                                @if (isTesting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-plug me-1"></i>
                                }
                                Baglanti Test Et
                            </button>
                            <button class="btn btn-success" @onclick="SaveAndApply" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i>
                                }
                                Kaydet ve Uygula
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-lightning me-2"></i>Hizli Ayarlar</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary" @onclick="() => HizliAyar(DatabaseProvider.PostgreSQL)">
                                <i class="bi bi-database me-2"></i>PostgreSQL (Kanonik)
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="() => HizliAyar(DatabaseProvider.SQLServer)">
                                <i class="bi bi-server me-2"></i>SQL Server
                            </button>
                            <button class="btn btn-outline-warning" @onclick="() => HizliAyar(DatabaseProvider.MySQL)">
                                <i class="bi bi-hdd-network me-2"></i>MySQL
                            </button>
                            <button class="btn btn-outline-info" @onclick="() => HizliAyar(DatabaseProvider.SQLite)">
                                <i class="bi bi-file-earmark-binary me-2"></i>SQLite (Yerel Calisma)
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-arrow-left-right me-2"></i>Gecis Kurali</h6>
                    </div>
                    <div class="card-body">
                        <small class="text-muted">
                            Saglayici degisikliklerinde dogrudan migration replay yapilmaz.
                            Sistem once gecis manifesti olusturur; veri snapshot/export akisi bunun uzerinden yonetilir.
                        </small>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-box-arrow-in-down me-2"></i>PostgreSQL Yedegini SQLite'a Aktar</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <label class="form-label">Yedek Dosyasi</label>
                            <select class="form-select" @bind="selectedPostgreSqlBackupFile">
                                <option value="">Yedek secin</option>
                                @foreach (var backup in postgreSqlBackups)
                                {
                                    <option value="@backup.FileName">@backup.FileName</option>
                                }
                            </select>
                            <small class="text-muted">.backup veya .sql PostgreSQL yedekleri listelenir ve aktif SQLite veritabanina aktarilir.</small>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="sqliteImportConfirm" @bind="sqliteImportConfirm" />
                            <label class="form-check-label" for="sqliteImportConfirm">
                                Mevcut SQLite verisinin silinip secilen yedekten yeniden olusturulacagini onayliyorum.
                            </label>
                        </div>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-info" @onclick="LoadPostgreSqlBackups" disabled="@isImportingBackup">
                                <i class="bi bi-arrow-clockwise me-1"></i>Yedekleri Yenile
                            </button>
                            <button class="btn btn-primary" @onclick="ImportPostgreSqlBackupToSqlite" disabled="@(!CanImportPostgreSqlBackup)">
                                @if (isImportingBackup)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-database-down me-1"></i>
                                }
                                SQLite'a Aktar
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Bilgi</h6>
                    </div>
                    <div class="card-body">
                        <h6>Desteklenen Runtime Sağlayıcılar:</h6>
                        <ul class="list-unstyled mb-3">
                            <li><strong>PostgreSQL:</strong> Kanonik ve önerilen</li>
                            <li><strong>SQL Server:</strong> Sunucu tabanlı çalışma modu</li>
                            <li><strong>MySQL:</strong> Sunucu tabanlı çalışma modu</li>
                            <li><strong>SQLite:</strong> Yerel/tek dosya çalışma modu</li>
                        </ul>
                        @if (!string.IsNullOrWhiteSpace(settings.TransitionManifestPath))
                        {
                            <div class="alert alert-info py-2">
                                <small><i class="bi bi-file-earmark-code me-1"></i>Son gecis manifesti: @settings.TransitionManifestPath</small>
                            </div>
                        }
                        <div class="alert alert-warning py-2 mb-0">
                            <small><i class="bi bi-exclamation-triangle me-1"></i>Ayarlar kaydedildikten sonra uygulamayi yeniden baslatmaniz gerekir.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DatabaseSettings settings = new();
    private bool isLoading = true;
    private bool isTesting = false;
    private bool isSaving = false;
    private bool showPassword = false;
    private string testMessage = "";
    private bool testSuccess = false;
    private bool isImportingBackup = false;
    private bool sqliteImportConfirm = false;
    private string selectedPostgreSqlBackupFile = string.Empty;
    private List<BackupInfo> postgreSqlBackups = new();
    private bool CanImportPostgreSqlBackup =>
        settings.Provider == DatabaseProvider.SQLite &&
        !string.IsNullOrWhiteSpace(selectedPostgreSqlBackupFile) &&
        sqliteImportConfirm &&
        !isImportingBackup;

    protected override async Task OnInitializedAsync()
    {
        settings = await DbSettingsService.GetSettingsAsync();
        await LoadPostgreSqlBackups();
        isLoading = false;
    }

    private void ProviderDegistir(DatabaseProvider provider)
    {
        settings.Provider = DatabaseSettings.NormalizeRuntimeProvider(provider);
        settings.CanonicalProvider = DatabaseProvider.PostgreSQL;
        settings.Port = settings.GetDefaultPort();
        testMessage = "";

        switch (settings.Provider)
        {
            case DatabaseProvider.PostgreSQL:
                settings.Host = "localhost";
                settings.DatabaseName = string.IsNullOrWhiteSpace(settings.DatabaseName) || settings.DatabaseName.EndsWith(".db", StringComparison.OrdinalIgnoreCase)
                    ? "MKFiloServis"
                    : settings.DatabaseName;
                settings.Username = "postgres";
                settings.UseIntegratedSecurity = false;
                break;
            case DatabaseProvider.SQLServer:
                settings.Host = "localhost";
                settings.DatabaseName = "MKFiloServis";
                settings.Username = "sa";
                settings.UseIntegratedSecurity = false;
                break;
            case DatabaseProvider.MySQL:
                settings.Host = "localhost";
                settings.DatabaseName = "MKFiloServis";
                settings.Username = "root";
                settings.UseIntegratedSecurity = false;
                break;
            case DatabaseProvider.SQLite:
                settings.DatabaseName = "MKFiloServis.db";
                break;
        }
    }

    private void HizliAyar(DatabaseProvider provider)
    {
        settings.Provider = DatabaseSettings.NormalizeRuntimeProvider(provider);
        settings.CanonicalProvider = DatabaseProvider.PostgreSQL;
        settings.Port = settings.GetDefaultPort();
        testMessage = "";

        switch (settings.Provider)
        {
            case DatabaseProvider.PostgreSQL:
                settings.Host = "localhost";
                settings.DatabaseName = "MKFiloServis";
                settings.Username = "postgres";
                settings.Password = "";
                settings.UseIntegratedSecurity = false;
                break;
            case DatabaseProvider.SQLServer:
                settings.Host = "localhost";
                settings.DatabaseName = "MKFiloServis";
                settings.Username = "sa";
                settings.Password = "";
                settings.UseIntegratedSecurity = true;
                break;
            case DatabaseProvider.MySQL:
                settings.Host = "localhost";
                settings.DatabaseName = "MKFiloServis";
                settings.Username = "root";
                settings.Password = "";
                settings.UseIntegratedSecurity = false;
                break;
            case DatabaseProvider.SQLite:
                settings.DatabaseName = "MKFiloServis.db";
                break;
        }
    }

    private async Task TestConnection()
    {
        isTesting = true;
        testMessage = "";
        StateHasChanged();

        try
        {
            var result = await DbSettingsService.TestConnectionAsync(settings);
            testSuccess = result.Success;
            testMessage = result.Message;
        }
        finally
        {
            isTesting = false;
            StateHasChanged();
        }
    }

    private async Task SaveAndApply()
    {
        isSaving = true;
        StateHasChanged();

        try
        {
            var result = await DbSettingsService.ApplyConnectionAsync(settings);

            if (result.Success)
            {
                ToastService.ShowSuccess(result.Message);
                testSuccess = true;
                testMessage = result.Message;
            }
            else
            {
                ToastService.ShowError(result.Message);
                testSuccess = false;
                testMessage = result.Message;
            }
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task LoadPostgreSqlBackups()
    {
        var backups = await BackupService.GetBackupListAsync();
        postgreSqlBackups = backups
            .Where(x => x.FileName.Contains("PostgreSQL", StringComparison.OrdinalIgnoreCase)
                || x.FileName.EndsWith(".backup", StringComparison.OrdinalIgnoreCase)
                || x.FileName.EndsWith(".sql", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.CreatedAt)
            .ToList();
    }

    private async Task ImportPostgreSqlBackupToSqlite()
    {
        if (!CanImportPostgreSqlBackup)
        {
            return;
        }

        isImportingBackup = true;
        StateHasChanged();

        try
        {
            await DbSettingsService.SaveSettingsAsync(settings);
            var result = await BackupService.ConvertAndRestoreAsync(selectedPostgreSqlBackupFile, "PostgreSQL", "SQLite");
            if (result.Success)
            {
                sqliteImportConfirm = false;
                ToastService.ShowSuccess($"{result.Message}. Uygulamayi yeniden baslatin veya baglantiyi tekrar test edin.");
            }
            else
            {
                ToastService.ShowError($"PostgreSQL yedegi SQLite veritabanina aktarilamadi: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Aktarim hatasi: {ex.Message}");
        }
        finally
        {
            isImportingBackup = false;
            StateHasChanged();
        }
    }

    private async Task CopyConnectionString()
    {
        // JavaScript ile panoya kopyala
        ToastService.ShowInfo("Baglanti dizesi kopyalandi.");
    }
}

