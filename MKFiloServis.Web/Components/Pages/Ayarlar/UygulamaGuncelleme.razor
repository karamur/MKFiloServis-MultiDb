@page "/ayarlar/uygulama-guncelleme"
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IToastService ToastService
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@rendermode InteractiveServer

<PageTitle>Uygulama Guncelleme</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3><i class="bi bi-cloud-arrow-down me-2"></i>Uygulama Guncelleme</h3>
            <p class="text-muted mb-0">Uygulama dosyalarini yukleyerek guncelleme yapin</p>
        </div>
    </div>

    <!-- Mevcut Surum Bilgisi -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Mevcut Surum Bilgisi</h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tr>
                            <td class="text-muted">Uygulama Dizini:</td>
                            <td><code>@appPath</code></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Son Guncelleme:</td>
                            <td>@sonGuncelleme</td>
                        </tr>
                        <tr>
                            <td class="text-muted">.NET Surum:</td>
                            <td>@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Ortam:</td>
                            <td><span class="badge @(Env.IsDevelopment() ? "bg-warning" : "bg-success")">@(Env.IsDevelopment() ? "Development" : "Production")</span></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Guncelleme Oncesi</h6>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li>Guncelleme oncesi <strong>veritabani yedegi</strong> alin</li>
                        <li>Guncelleme dosyasi <code>.zip</code> formatinda olmalidir</li>
                        <li>ZIP icinde <code>publish</code> klasoru veya dogrudan dosyalar olmalidir</li>
                        <li>Guncelleme sonrasi uygulama <strong>otomatik yeniden baslar</strong></li>
                        <li class="text-danger"><strong>appsettings.json dosyaniz korunur, uzerine yazilmaz</strong></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Guncelleme Yukleme -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h6 class="mb-0"><i class="bi bi-upload me-2"></i>Guncelleme Dosyasi Yukle</h6>
        </div>
        <div class="card-body">
            @if (isUpdating)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;"></div>
                    <h5>Guncelleme uygulanıyor...</h5>
                    <p class="text-muted">@guncellemeDurumu</p>
                    <div class="progress mx-auto" style="max-width: 400px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" style="width: @ilerlemeYuzde%">@ilerlemeYuzde%</div>
                    </div>
                </div>
            }
            else
            {
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Guncelleme ZIP dosyasini secin:</label>
                            <InputFile class="form-control form-control-lg" OnChange="DosyaSecildi" accept=".zip" />
                            <small class="text-muted">Maks. dosya boyutu: 200 MB</small>
                        </div>
                        @if (secilenDosya != null)
                        {
                            <div class="alert alert-info py-2">
                                <i class="bi bi-file-earmark-zip me-2"></i>
                                <strong>@secilenDosya.Name</strong> - @FormatDosyaBoyutu(secilenDosya.Size)
                            </div>
                        }
                    </div>
                    <div class="col-md-4 text-end">
                        <button class="btn btn-success btn-lg" @onclick="GuncellemeBaslat" disabled="@(secilenDosya == null)">
                            <i class="bi bi-cloud-arrow-down me-2"></i>Guncellemeyi Baslat
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Guncelleme Gecmisi -->
    <div class="card">
        <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Guncelleme Gecmisi</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Dosya</th>
                            <th>Boyut</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (guncellemeLoglari.Any())
                        {
                            @foreach (var log in guncellemeLoglari)
                            {
                                <tr>
                                    <td>@log.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@log.DosyaAdi</td>
                                    <td>@log.Boyut</td>
                                    <td><span class="badge @(log.Basarili ? "bg-success" : "bg-danger")">@(log.Basarili ? "Basarili" : "Hata")</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Henuz guncelleme yapilmamis</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private IBrowserFile? secilenDosya;
    private bool isUpdating = false;
    private string guncellemeDurumu = "";
    private int ilerlemeYuzde = 0;
    private string appPath = "";
    private string sonGuncelleme = "";
    private List<GuncellemeLog> guncellemeLoglari = new();

    protected override void OnInitialized()
    {
        appPath = AppDomain.CurrentDomain.BaseDirectory;
        var exeFile = Path.Combine(appPath, "MKFiloServis.Web.exe");
        if (File.Exists(exeFile))
            sonGuncelleme = new FileInfo(exeFile).LastWriteTime.ToString("dd.MM.yyyy HH:mm");
        else
            sonGuncelleme = "Bilinmiyor";

        // Log dosyasini oku
        LoadGuncellemeLoglari();
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        secilenDosya = e.File;
    }

    private async Task GuncellemeBaslat()
    {
        if (secilenDosya == null) return;

        var onay = await JS.InvokeAsync<bool>("confirm",
            "UYARI: Guncelleme sonrasi uygulama yeniden baslatilacak!\n\n" +
            "Veritabani yedeginizi aldiginizdan emin olun.\n\n" +
            "Devam etmek istiyor musunuz?");

        if (!onay) return;

        isUpdating = true;
        guncellemeDurumu = "Dosya yukleniyor...";
        ilerlemeYuzde = 10;
        StateHasChanged();

        try
        {
            // 1. Gecici klasore ZIP yukle
            var tempDir = Path.Combine(Path.GetTempPath(), "MKFiloServis_Update_" + Guid.NewGuid().ToString("N")[..8]);
            Directory.CreateDirectory(tempDir);
            var zipPath = Path.Combine(tempDir, secilenDosya.Name);

            guncellemeDurumu = "ZIP dosyasi kaydediliyor...";
            ilerlemeYuzde = 20;
            StateHasChanged();
            await Task.Delay(100);

            using (var stream = secilenDosya.OpenReadStream(maxAllowedSize: 200 * 1024 * 1024))
            using (var fileStream = new FileStream(zipPath, FileMode.Create))
            {
                await stream.CopyToAsync(fileStream);
            }

            guncellemeDurumu = "ZIP aciliyor...";
            ilerlemeYuzde = 40;
            StateHasChanged();
            await Task.Delay(100);

            // 2. ZIP'i cikart
            var extractDir = Path.Combine(tempDir, "extracted");
            System.IO.Compression.ZipFile.ExtractToDirectory(zipPath, extractDir, overwriteFiles: true);

            // publish alt klasoru varsa onu kullan
            var sourceDir = extractDir;
            var publishSubDir = Path.Combine(extractDir, "publish");
            if (Directory.Exists(publishSubDir))
                sourceDir = publishSubDir;

            guncellemeDurumu = "Mevcut dosyalar yedekleniyor...";
            ilerlemeYuzde = 55;
            StateHasChanged();
            await Task.Delay(100);

            // 3. Mevcut appsettings.json'u koru
            var appSettingsPath = Path.Combine(appPath, "appsettings.json");
            var appSettingsBackup = "";
            if (File.Exists(appSettingsPath))
            {
                appSettingsBackup = await File.ReadAllTextAsync(appSettingsPath);
            }

            guncellemeDurumu = "Dosyalar guncelleniyor...";
            ilerlemeYuzde = 70;
            StateHasChanged();
            await Task.Delay(100);

            // 4. Dosyalari kopyala (appsettings.json haric)
            var dosyalar = Directory.GetFiles(sourceDir, "*", SearchOption.AllDirectories);
            var kopyalanan = 0;
            foreach (var dosya in dosyalar)
            {
                var relativePath = Path.GetRelativePath(sourceDir, dosya);

                // appsettings.json'u atla - kullanicinin ayarlari korunsun
                if (relativePath.Equals("appsettings.json", StringComparison.OrdinalIgnoreCase))
                    continue;

                var hedefYol = Path.Combine(appPath, relativePath);
                var hedefDir = Path.GetDirectoryName(hedefYol);
                if (hedefDir != null && !Directory.Exists(hedefDir))
                    Directory.CreateDirectory(hedefDir);

                try
                {
                    File.Copy(dosya, hedefYol, overwrite: true);
                    kopyalanan++;
                }
                catch
                {
                    // Kilitli dosyalar icin (exe vb.) - restart sonrasi guncellenecek
                }
            }

            guncellemeDurumu = $"{kopyalanan} dosya guncellendi. appsettings.json korundu.";
            ilerlemeYuzde = 90;
            StateHasChanged();
            await Task.Delay(100);

            // 5. appsettings.json'u geri yaz (korunmus halini)
            if (!string.IsNullOrEmpty(appSettingsBackup))
            {
                await File.WriteAllTextAsync(appSettingsPath, appSettingsBackup);
            }

            // 6. Guncelleme logunu kaydet
            var log = new GuncellemeLog
            {
                Tarih = DateTime.Now,
                DosyaAdi = secilenDosya.Name,
                Boyut = FormatDosyaBoyutu(secilenDosya.Size),
                Basarili = true
            };
            SaveGuncellemeLog(log);

            // 7. Temizle
            try { Directory.Delete(tempDir, true); } catch { }

            guncellemeDurumu = "Guncelleme tamamlandi! Uygulama yeniden baslatiliyor...";
            ilerlemeYuzde = 100;
            StateHasChanged();

            ToastService.ShowSuccess($"Guncelleme basarili! {kopyalanan} dosya guncellendi.");

            // 8. Uygulamayi yeniden baslat (3 sn sonra)
            await Task.Delay(3000);
            Environment.Exit(0); // Servis olarak calisiyor ise otomatik yeniden baslar
        }
        catch (Exception ex)
        {
            guncellemeDurumu = $"Hata: {ex.Message}";
            ToastService.ShowError("Guncelleme hatasi: " + ex.Message);

            var log = new GuncellemeLog
            {
                Tarih = DateTime.Now,
                DosyaAdi = secilenDosya?.Name ?? "Bilinmiyor",
                Boyut = secilenDosya != null ? FormatDosyaBoyutu(secilenDosya.Size) : "-",
                Basarili = false
            };
            SaveGuncellemeLog(log);
        }
        finally
        {
            isUpdating = false;
            StateHasChanged();
        }
    }

    private string FormatDosyaBoyutu(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824.0:N1} GB";
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:N1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:N1} KB";
        return $"{bytes} B";
    }

    private void LoadGuncellemeLoglari()
    {
        try
        {
            var logPath = Path.Combine(appPath, "Data", "guncelleme_log.txt");
            if (File.Exists(logPath))
            {
                var lines = File.ReadAllLines(logPath);
                foreach (var line in lines.Reverse().Take(20))
                {
                    var parts = line.Split('|');
                    if (parts.Length >= 4)
                    {
                        guncellemeLoglari.Add(new GuncellemeLog
                        {
                            Tarih = DateTime.TryParse(parts[0], out var t) ? t : DateTime.MinValue,
                            DosyaAdi = parts[1],
                            Boyut = parts[2],
                            Basarili = parts[3] == "OK"
                        });
                    }
                }
            }
        }
        catch { }
    }

    private void SaveGuncellemeLog(GuncellemeLog log)
    {
        try
        {
            var dataDir = Path.Combine(appPath, "Data");
            if (!Directory.Exists(dataDir)) Directory.CreateDirectory(dataDir);
            var logPath = Path.Combine(dataDir, "guncelleme_log.txt");
            var line = $"{log.Tarih:yyyy-MM-dd HH:mm:ss}|{log.DosyaAdi}|{log.Boyut}|{(log.Basarili ? "OK" : "HATA")}";
            File.AppendAllLines(logPath, [line]);
        }
        catch { }
    }

    private class GuncellemeLog
    {
        public DateTime Tarih { get; set; }
        public string DosyaAdi { get; set; } = "";
        public string Boyut { get; set; } = "";
        public bool Basarili { get; set; }
    }
}

