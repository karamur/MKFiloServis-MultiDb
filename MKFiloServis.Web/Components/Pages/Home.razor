                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Öncelik</th>
                                        <th>Evrak No</th>
                                        <th>Konu</th>
                                        <th>Atayan</th>
                                        <th>Atama Tarihi</th>
                                        <th>Teslim Tarihi</th>
                                        <th class="text-center">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var atama in atananEvraklar)
                                    {
                                        var oncelik = atama.Evrak?.Oncelik ?? EvrakOncelik.Normal;
                                        var oncelikBadge = oncelik switch
                                        {
                                            EvrakOncelik.Acil => "bg-danger",
                                            EvrakOncelik.Yuksek => "bg-warning text-dark",
                                            EvrakOncelik.Dusuk => "bg-secondary",
                                            _ => "bg-info"
                                        };
                                        var gecikmis = atama.TeslimTarihi.HasValue && atama.TeslimTarihi.Value.Date < DateTime.Today;
                                        <tr>
                                            <td><span class="badge @oncelikBadge">@oncelik</span></td>
                                            <td><code>@(atama.Evrak?.EvrakNo ?? "-")</code></td>
                                            <td><strong>@(atama.Evrak?.Konu ?? "-")</strong></td>
                                            <td>@(atama.AtayanKullanici?.AdSoyad ?? "-")</td>
                                            <td>@atama.AtamaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>
                                                @if (atama.TeslimTarihi.HasValue)
                                                {
                                                    <span class="@(gecikmis ? "text-danger fw-bold" : "")">
                                                        @atama.TeslimTarihi.Value.ToString("dd.MM.yyyy")
                                                        @if (gecikmis)
                                                        {
                                                            <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                                        }
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <a href="/ebys/evrak/@atama.EvrakId" class="btn btn-sm btn-outline-primary" title="Detay">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-success py-4">
                            <i class="bi bi-check-circle" style="font-size: 3rem;"></i>
                            <p class="mb-0 mt-2">Bekleyen atanmış evrak yok!</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <a href="/ebys/takip" class="btn btn-primary">
                        <i class="bi bi-list-ul me-1"></i>Tüm Evrakları Görüntüle
                    </a>
                    <button type="button" class="btn btn-secondary" @onclick="() => showAtananEvraklarModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}
}

@code {
    private int cariSayisi = 0;
    private int aracSayisi = 0;
    private int soforSayisi = 0;
    private int bekleyenFaturaSayisi = 0;

    private decimal buAyGelir = 0;
    private decimal buAyGider = 0;
    private decimal toplamKasa = 0;
    private decimal toplamBanka = 0;

    private List<ServisCalisma>? sonCalismalar;
    private List<FaturaEntity> vadeGecmisFaturalar = new();
    private List<FaturaEntity> vadeYaklasanFaturalar = new();
    private List<BankaKasaHareket>? sonHareketler;
    private List<BudgetOdeme> gecmisOdenmemisBorclar = new();
    
    private BelgeUyariOzet? belgeUyarilar;
    private EvrakExpiryOzet? _evrakExpiryOzet;
    private List<EbysEvrakAtama>? atananEvraklar;
    private BudgetOzet? butceOzet;
    private BudgetOdeme? seciliGecmisBorc;
    private bool showBelgeModal = false;
    private bool showAtananEvraklarModal = false;
    private bool showGecmisBorcModal = false;
    private bool isLoading = true;

    // Widget ayarları
    private bool widgetAyarGoster = false;
    private Dictionary<string, (string Ad, string Ikon, bool Gorünür)> widgetler = new()
    {
        ["hizli-islemler"] = ("Hızlı İşlemler", "bi-lightning-charge", true),
        ["ozet-kartlar"] = ("Özet Kartlar", "bi-grid-3x3-gap", true),
        ["finansal-ozet"] = ("Finansal Özet", "bi-cash-stack", true),
        ["grafikler"] = ("Grafikler", "bi-bar-chart", true),
        ["vade-faturalar"] = ("Vade / Fatura Uyarıları", "bi-exclamation-triangle", true),
        ["son-islemler"] = ("Son İşlemler", "bi-clock-history", true),
    };

    private List<string> widgetSira = new()
    {
        "hizli-islemler", "ozet-kartlar", "finansal-ozet", "grafikler", "vade-faturalar", "son-islemler"
    };

    private bool WidgetGorünür(string key) => widgetler.TryGetValue(key, out var w) && w.Gorünür;
    private int GetWidgetOrder(string key) => widgetSira.IndexOf(key);

    private async Task WidgetToggle(string key, bool visible)
    {
        if (widgetler.TryGetValue(key, out var w))
            widgetler[key] = (w.Ad, w.Ikon, visible);
        await JSRuntime.InvokeVoidAsync("dashboardWidgets.set", key, visible);
    }

    private async Task WidgetYukariTasi(string key)
    {
        var idx = widgetSira.IndexOf(key);
        if (idx > 0)
        {
            widgetSira.RemoveAt(idx);
            widgetSira.Insert(idx - 1, key);
            await JSRuntime.InvokeVoidAsync("dashboardWidgets.setOrder", widgetSira.ToArray());
        }
    }

    private async Task WidgetAsagiTasi(string key)
    {
        var idx = widgetSira.IndexOf(key);
        if (idx >= 0 && idx < widgetSira.Count - 1)
        {
            widgetSira.RemoveAt(idx);
            widgetSira.Insert(idx + 1, key);
            await JSRuntime.InvokeVoidAsync("dashboardWidgets.setOrder", widgetSira.ToArray());
        }
    }

    private async Task WidgetSifirla()
    {
        var keys = widgetler.Keys.ToList();
        foreach (var k in keys)
        {
            var w = widgetler[k];
            widgetler[k] = (w.Ad, w.Ikon, true);
        }
        widgetSira = new List<string> { "hizli-islemler", "ozet-kartlar", "finansal-ozet", "grafikler", "vade-faturalar", "son-islemler" };
        await JSRuntime.InvokeVoidAsync("dashboardWidgets.reset");
    }
    private bool dashboardLoadInProgress;
    private readonly List<string> dashboardHatalari = new();

    // Grafik verileri
    private AylikGrafikData? gelirGiderData;
    private List<MasrafKategoriDagilimi>? masrafDagilimi;
    private List<CariTipDagilimi>? cariDagilimi;
    private List<AylikButceVeri>? aylikButce;
    private bool chartsRendered = false;
    
    // Yetki kontrolleri - Shared.Entities.Yetkiler sabitlerini kullanıyoruz
    private HashSet<string> kullaniciYetkileri = new();
    private bool HasDashboardPermission => kullaniciYetkileri.Contains(Yetkiler.Dashboard) || kullaniciYetkileri.Contains("*");
    private bool CanViewCariler => kullaniciYetkileri.Contains(Yetkiler.CarilerOku) || kullaniciYetkileri.Contains("*");
    private bool CanViewAraclar => kullaniciYetkileri.Contains(Yetkiler.AraclarOku) || kullaniciYetkileri.Contains("*");
    private bool CanViewSoforler => kullaniciYetkileri.Contains(Yetkiler.PersonelOku) || kullaniciYetkileri.Contains("*");
    private bool CanViewFaturalar =>
        kullaniciYetkileri.Contains(Yetkiler.FaturalarOku) ||
        kullaniciYetkileri.Contains(Yetkiler.KesilenFaturalarOku) ||
        kullaniciYetkileri.Contains(Yetkiler.GelenFaturalarOku) ||
        kullaniciYetkileri.Contains("*");
    private bool CanViewFinans =>
        kullaniciYetkileri.Contains(Yetkiler.BankaHesaplariOku) ||
        kullaniciYetkileri.Contains(Yetkiler.BankaHareketleriOku) ||
        kullaniciYetkileri.Contains(Yetkiler.ButceAnalizOku) ||
        kullaniciYetkileri.Contains(Yetkiler.OdemeYonetimiOku) ||
        kullaniciYetkileri.Contains("*");
    private bool CanViewServisler =>
        kullaniciYetkileri.Contains(Yetkiler.ServisCalismalariOku) ||
        kullaniciYetkileri.Contains(Yetkiler.TopluCalismaOku) ||
        kullaniciYetkileri.Contains("*");
    private bool CanViewBelgeUyarilari => kullaniciYetkileri.Contains(Yetkiler.BelgeUyarilariOku) || kullaniciYetkileri.Contains("*");
    private bool CanViewEbys => kullaniciYetkileri.Contains("menu.ebys") || kullaniciYetkileri.Contains("*");

    protected override async Task OnInitializedAsync()
    {
        await LoadYetkilerAsync();
        
        if (HasDashboardPermission)
        {
            await LoadDashboardDataAsync();
        }
        else
        {
            isLoading = false;
        }
    }
    
    private async Task LoadYetkilerAsync()
    {
        try
        {
            kullaniciYetkileri = await KullaniciService.GetCurrentUserYetkilerAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Yetki yükleme hatası");
            kullaniciYetkileri = new HashSet<string>();
        }
    }

    private bool HasYetki(string yetkiKodu)
    {
        return kullaniciYetkileri.Contains(yetkiKodu) || kullaniciYetkileri.Contains("*");
    }

    private async Task TryLoadDashboardSectionAsync(Func<IServiceProvider, Task> action, string sectionName)
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            await action(scope.ServiceProvider);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Dashboard bölüm yükleme hatası: {SectionName}", sectionName);
            dashboardHatalari.Add($"{sectionName}: {ex.Message}");
        }
    }

    private void ResetDashboardData()
    {
        cariSayisi = 0;
        aracSayisi = 0;
        soforSayisi = 0;
        bekleyenFaturaSayisi = 0;
        buAyGelir = 0;
        buAyGider = 0;
        toplamKasa = 0;
        toplamBanka = 0;
        sonCalismalar = null;
        vadeGecmisFaturalar = new();
        vadeYaklasanFaturalar = new();
        sonHareketler = null;
        gecmisOdenmemisBorclar = new();
        belgeUyarilar = null;
        atananEvraklar = null;
        butceOzet = null;
    }

    private async Task LoadDashboardDataAsync()
    {
        if (dashboardLoadInProgress)
            return;

        try
        {
            dashboardLoadInProgress = true;
            isLoading = true;
            dashboardHatalari.Clear();
            ResetDashboardData();
            StateHasChanged();

            // Tum bolumler paralel yuklenir (IDbContextFactory sayesinde guvenli)
            var tasks = new List<Task>();

            if (CanViewCariler)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<ICariService>();
                    cariSayisi = await svc.GetCountAsync();
                }, "Cari verileri"));

            if (CanViewAraclar)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<IAracService>();
                    aracSayisi = await svc.GetActiveCountAsync();
                }, "Arac verileri"));

            if (CanViewSoforler)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<ISoforService>();
                    soforSayisi = await svc.GetActiveByGorevCountAsync(PersonelGorev.Sofor);
                }, "Sofor verileri"));

            if (CanViewFaturalar)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<IFaturaService>();
                    var stats = await svc.GetDashboardStatsAsync();
                    bekleyenFaturaSayisi = stats.BekleyenFaturaSayisi;
                    buAyGelir = stats.BuAyGelir;
                    buAyGider = stats.BuAyGider;
                    vadeGecmisFaturalar = stats.VadeGecmisFaturalar;
                    vadeYaklasanFaturalar = stats.VadeYaklasanFaturalar;
                }, "Fatura verileri"));

            if (CanViewFinans)
            {
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var bankaSvc = sp.GetRequiredService<IBankaKasaHareketService>();
                    var budgetSvc = sp.GetRequiredService<IBudgetService>();
                    var stats = await bankaSvc.GetDashboardStatsAsync();
                    toplamKasa = stats.ToplamKasa;
                    toplamBanka = stats.ToplamBanka;
                    sonHareketler = await bankaSvc.GetRecentAsync(5);
                    butceOzet = await budgetSvc.GetAylikOzetAsync(DateTime.Today.Year, DateTime.Today.Month);
                    var aktifFirma = FirmaService.GetAktifFirma();
                    gecmisOdenmemisBorclar = await budgetSvc.GetDevirBekleyenOdemelerAsync(
                        new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
                        (aktifFirma.TumFirmalar || aktifFirma.FirmaId <= 0) ? null : aktifFirma.FirmaId);
                }, "Finans verileri"));

                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<IDashboardGrafikService>();
                    var yil = DateTime.Today.Year;
                    gelirGiderData = await svc.GetAylikGelirGiderAsync(yil);
                    masrafDagilimi = await svc.GetMasrafKategoriDagilimiAsync(6);
                    cariDagilimi = await svc.GetCariTipDagilimiAsync();
                    aylikButce = await svc.GetAylikButceAsync(6);
                }, "Grafik verileri"));
            }

            if (CanViewServisler)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<IServisCalismaService>();
                    sonCalismalar = await svc.GetRecentAsync(5);
                }, "Servis verileri"));

            if (CanViewBelgeUyarilari)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var svc = sp.GetRequiredService<IBelgeUyariService>();
                    belgeUyarilar = await svc.GetBelgeUyarilarAsync(30);
                }, "Belge uyarilari"));

            // PART 6-7: EvrakDosya tabanlı geçerlilik takibi
            tasks.Add(TryLoadDashboardSectionAsync(async sp =>
            {
                var svc = sp.GetRequiredService<EvrakExpiryService>();
                _evrakExpiryOzet = await svc.GetExpiryOzetAsync();
            }, "Evrak geçerlilik kontrolü"));

            if (CanViewEbys)
                tasks.Add(TryLoadDashboardSectionAsync(async sp =>
                {
                    var kulSvc = sp.GetRequiredService<IKullaniciService>();
                    var aktifKullanici = await kulSvc.GetAktifKullaniciAsync();
                    if (aktifKullanici != null)
                    {
                        var ebysSvc = sp.GetRequiredService<IEbysEvrakService>();
                        atananEvraklar = await ebysSvc.GetKullaniciAtamalariAsync(aktifKullanici.Id);
                    }
                }, "EBYS atanan evraklar"));

            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Dashboard yukleme hatasi");
        }
        finally
        {
            dashboardLoadInProgress = false;
            isLoading = false;
            StateHasChanged();
        }
    }

    private static string GetAyAdi(int ay) => ay >= 1 && ay <= 12
        ? new DateTime(2000, ay, 1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR"))
        : "-";

    private static int GetGecikmeGun(DateTime odemeTarihi) => Math.Max(0, (DateTime.Today - odemeTarihi.Date).Days);

    private static int GetDevirAySayisi(DateTime odemeTarihi)
    {
        var bugun = DateTime.Today;
        var ayFarki = ((bugun.Year - odemeTarihi.Year) * 12) + bugun.Month - odemeTarihi.Month;
        return Math.Max(1, ayFarki + 1);
    }

    private static string GetGecikmeBadgeClass(int gecikmeGun) => gecikmeGun switch
    {
        >= 90 => "bg-danger",
        >= 30 => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string GetGecikmeSinifi(int gecikmeGun) => gecikmeGun switch
    {
        >= 180 => "Kritik",
        >= 90 => "Yüksek",
        >= 30 => "Orta",
        _ => "Yeni"
    };

    private static string GetGecikmeSinifBadgeClass(int gecikmeGun) => gecikmeGun switch
    {
        >= 180 => "bg-dark",
        >= 90 => "bg-danger",
        >= 30 => "bg-warning text-dark",
        _ => "bg-info text-dark"
    };

    private List<FirmaDevirBorcOzet> GetFirmaGrupOzetleri() => gecmisOdenmemisBorclar
        .GroupBy(x => x.Firma?.FirmaAdi ?? "Tüm Firmalar")
        .Select(g => new FirmaDevirBorcOzet
        {
            FirmaAdi = g.Key,
            KayitSayisi = g.Count(),
            ToplamTutar = g.Sum(x => x.Miktar),
            KritikKayitSayisi = g.Count(x => GetGecikmeGun(x.OdemeTarihi) >= 180)
        })
        .OrderByDescending(x => x.ToplamTutar)
        .ToList();

    private List<BudgetOdeme> GetEnKritikBorclar() => gecmisOdenmemisBorclar
        .OrderByDescending(x => GetGecikmeGun(x.OdemeTarihi))
        .ThenByDescending(x => x.Miktar)
        .Take(10)
        .ToList();

    private void GecmisBorcOnizlemeAc(BudgetOdeme odeme)
    {
        seciliGecmisBorc = odeme;
        showGecmisBorcModal = true;
    }

    private void GecmisBorcOnizlemeKapat()
    {
        showGecmisBorcModal = false;
        seciliGecmisBorc = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedWidgets = await JSRuntime.InvokeAsync<Dictionary<string, bool>>("dashboardWidgets.getAll");
                if (savedWidgets != null)
                {
                    var keys = widgetler.Keys.ToList();
                    foreach (var k in keys)
                    {
                        if (savedWidgets.TryGetValue(k, out var vis))
                        {
                            var w = widgetler[k];
                            widgetler[k] = (w.Ad, w.Ikon, vis);
                        }
                    }
                }
                var savedOrder = await JSRuntime.InvokeAsync<string[]?>("dashboardWidgets.getOrder");
                if (savedOrder != null && savedOrder.Length == widgetSira.Count && savedOrder.All(widgetSira.Contains))
                {
                    widgetSira = savedOrder.ToList();
                }
                StateHasChanged();
            }
            catch { }
        }

        if (!firstRender && !isLoading && !chartsRendered && HasDashboardPermission && CanViewFinans)
        {
            chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task RenderChartsAsync()
    {
        try
        {
            // Aylık Gelir/Gider Bar Chart
            if (gelirGiderData != null && gelirGiderData.Aylar.Any())
            {
                await JSRuntime.InvokeVoidAsync("createBarChart",
                    "gelirGiderChart",
                    gelirGiderData.Aylar.ToArray(),
                    gelirGiderData.Veri1.Select(v => (double)v).ToArray(),
                    gelirGiderData.Veri2.Select(v => (double)v).ToArray(),
                    gelirGiderData.Veri1Label,
                    gelirGiderData.Veri2Label);
            }

            // Masraf Kategori Doughnut Chart
            if (masrafDagilimi != null && masrafDagilimi.Any())
            {
                var colors = new[] { "#0d6efd", "#6610f2", "#6f42c1", "#d63384", "#dc3545", "#fd7e14", "#ffc107", "#198754" };
                await JSRuntime.InvokeVoidAsync("createDoughnutChart",
                    "masrafDagilimiChart",
                    masrafDagilimi.Select(m => m.KategoriAdi).ToArray(),
                    masrafDagilimi.Select(m => (double)m.Tutar).ToArray(),
                    colors.Take(masrafDagilimi.Count).ToArray());
            }

            // Aylık Bütçe Line Chart
            if (aylikButce != null && aylikButce.Any())
            {
                await JSRuntime.InvokeVoidAsync("createLineChart",
                    "butceChart",
                    aylikButce.Select(b => b.AyAdi).ToArray(),
                    aylikButce.Select(b => (double)b.PlanlananOdeme).ToArray(),
                    aylikButce.Select(b => (double)b.GerceklesenOdeme).ToArray());
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Grafik render hatası");
        }
    }

    private sealed class FirmaDevirBorcOzet
    {
        public string FirmaAdi { get; set; } = string.Empty;
        public int KayitSayisi { get; set; }
        public decimal ToplamTutar { get; set; }
        public int KritikKayitSayisi { get; set; }
    }
}

