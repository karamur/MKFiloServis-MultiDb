@page "/dashboard"
@attribute [Authorize]
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@using Microsoft.AspNetCore.Authorization
@using FaturaEntity = MKFiloServis.Shared.Entities.Fatura
@inject ICariService CariService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IFaturaService FaturaService
@inject IServisCalismaService ServisCalismaService
@inject IBankaKasaHareketService BankaKasaService
@inject IBelgeUyariService BelgeUyariService
@inject IEbysEvrakService EbysEvrakService
@inject IBudgetService BudgetService
@inject IFirmaService FirmaService
@inject IAktifFirmaProvider AktifFirmaProvider
@inject IKullaniciService KullaniciService
@inject NavigationManager Navigation
@inject ILogger<Home> Logger
@inject IDashboardGrafikService GrafikService
@inject IJSRuntime JSRuntime
@inject EvrakExpiryService EvrakExpiryService
@rendermode InteractiveServer
@using MKFiloServis.Web.Data
@inject IServiceScopeFactory ScopeFactory

<PageTitle>CRM Filo Servis - Ana Sayfa</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else if (!HasDashboardPermission)
{
    <div class="container-fluid">
        <div class="alert alert-warning">
            <i class="bi bi-shield-lock me-2"></i>
            <strong>Dashboard görüntüleme yetkiniz bulunmuyor.</strong>
            <p class="mb-0 mt-2">Lütfen sistem yöneticinizle iletişime geçin.</p>
        </div>
    </div>
}
else
{
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </h3>
        <div class="d-flex align-items-center gap-2">
            <small class="text-muted d-none d-md-inline">Son güncelleme: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</small>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => widgetAyarGoster = true" title="Widget ayarları">
                <i class="bi bi-layout-wtf me-1"></i><span class="d-none d-md-inline">Düzenle</span>
            </button>
        </div>
    </div>

    @if (!AktifFirmaProvider.Mevcut.TumFirmalar)
    {
        <div class="alert alert-info d-flex align-items-center py-2 mb-3">
            <i class="bi bi-building me-2 fs-4"></i>
            <div>
                <strong>@AktifFirmaProvider.Mevcut.FirmaAdi</strong>
                <small class="text-muted ms-2">(@AktifFirmaProvider.Mevcut.FirmaKodu)</small>
                <br />
                <small>Donem: @AktifFirmaProvider.Mevcut.AktifDonemAy.ToString("D2")/@AktifFirmaProvider.Mevcut.AktifDonemYil</small>
            </div>
        </div>
    }

    <MKFiloServis.Web.Components.Shared.OperasyonelOzetBandi />

    @if (widgetAyarGoster)
    {
        <div class="modal show d-block" style="background:rgba(0,0,0,.5);" @onclick="() => widgetAyarGoster = false">
            <div class="modal-dialog" @onclick:stopPropagation>
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-layout-wtf me-2"></i>Dashboard Widget Ayarları</h5>
                        <button class="btn-close" @onclick="() => widgetAyarGoster = false"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-3">Görmek istediğiniz bölümleri seçin ve sırayı düzenleyin. Ayarlar tarayıcınıza kaydedilir.</p>
                        @foreach (var key in widgetSira)
                        {
                            if (!widgetler.TryGetValue(key, out var w)) continue;
                            var idx = widgetSira.IndexOf(key);
                            <div class="d-flex align-items-center border rounded px-2 py-1 mb-2 bg-body-tertiary">
                                <div class="d-flex flex-column me-2">
                                    <button class="btn btn-sm p-0 lh-1 text-muted" style="font-size:0.7rem;"
                                            @onclick="() => WidgetYukariTasi(key)"
                                            disabled="@(idx == 0)" title="Yukarı taşı">
                                        <i class="bi bi-chevron-up"></i>
                                    </button>
                                    <button class="btn btn-sm p-0 lh-1 text-muted" style="font-size:0.7rem;"
                                            @onclick="() => WidgetAsagiTasi(key)"
                                            disabled="@(idx == widgetSira.Count - 1)" title="Aşağı taşı">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                                <div class="form-check form-switch flex-grow-1 mb-0">
                                    <input class="form-check-input" type="checkbox" id="w_@key"
                                           checked="@w.Gorünür"
                                           @onchange="@(e => WidgetToggle(key, (bool)(e.Value ?? true)))" />
                                    <label class="form-check-label" for="w_@key">
                                        <i class="bi @w.Ikon me-2 text-muted"></i>@w.Ad
                                    </label>
                                </div>
                                <span class="badge bg-secondary ms-2" style="font-size:0.65rem;">@(idx + 1)</span>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="WidgetSifirla">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Varsayılanları Geri Yükle
                        </button>
                        <button class="btn btn-primary" @onclick="() => widgetAyarGoster = false">Kapat</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (dashboardHatalari.Any())
    {
        <div class="alert alert-warning mb-4">
            <strong>Bazı dashboard verileri yüklenemedi:</strong>
            <ul class="mb-0 mt-2">
                @foreach (var hata in dashboardHatalari)
                {
                    <li>@hata</li>
                }
            </ul>
        </div>
    }

    <!-- Kritik Uyarılar Banner -->
    @if (CanViewBelgeUyarilari && belgeUyarilar != null && belgeUyarilar.ToplamKritikUyari > 0)
    {
        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
            <div class="flex-grow-1">
                <strong>@belgeUyarilar.ToplamKritikUyari kritik belge uyarısı var!</strong>
                Süresi geçmiş veya 7 gün içinde dolacak belgeler bulunuyor.
            </div>
            <button class="btn btn-outline-danger btn-sm" @onclick="() => showBelgeModal = true">
                <i class="bi bi-eye me-1"></i>Görüntüle
            </button>
        </div>
    }

    <!-- EvrakDosya Geçerlilik Uyarıları (YENİ SİSTEM) -->
    @if (_evrakExpiryOzet != null && (_evrakExpiryOzet.ExpiredCount > 0 || _evrakExpiryOzet.WarningCount > 0))
    {
        <div class="alert @(_evrakExpiryOzet.ExpiredCount > 0 ? "alert-danger" : "alert-warning") d-flex align-items-center mb-4" role="alert">
            <i class="bi @(_evrakExpiryOzet.ExpiredCount > 0 ? "bi-x-circle-fill" : "bi-exclamation-triangle-fill") me-2" style="font-size: 1.5rem;"></i>
            <div class="flex-grow-1">
                @if (_evrakExpiryOzet.ExpiredCount > 0)
                {
                    <strong><i class="bi bi-x-circle me-1"></i>@_evrakExpiryOzet.ExpiredCount evrak süresi dolmuş!</strong>
                }
                @if (_evrakExpiryOzet.WarningCount > 0)
                {
                    <span class="ms-3"><i class="bi bi-clock me-1"></i>@_evrakExpiryOzet.WarningCount evrak süresi yaklaşıyor (7 gün)</span>
                }
            </div>
        </div>
    }

    <!-- Bana Atanan EBYS Evrakları Banner -->
    @if (CanViewEbys && atananEvraklar != null && atananEvraklar.Count > 0)
    {
        var acilSayisi = atananEvraklar.Count(a => a.Evrak != null && a.Evrak.Oncelik == EvrakOncelik.Acil);
        var gecikmisSayisi = atananEvraklar.Count(a => a.TeslimTarihi.HasValue && a.TeslimTarihi.Value.Date < DateTime.Today);
        var alertClass = (acilSayisi > 0 || gecikmisSayisi > 0) ? "alert-danger" : "alert-info";
        var btnClass = (acilSayisi > 0 || gecikmisSayisi > 0) ? "btn-outline-danger" : "btn-outline-primary";
        <div class="alert @alertClass d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-inbox-fill me-2" style="font-size: 1.5rem;"></i>
            <div class="flex-grow-1">
                <strong>Size atanmış @atananEvraklar.Count bekleyen evrak var!</strong>
                @if (acilSayisi > 0)
                {
                    <span class="badge bg-danger ms-2">@acilSayisi acil</span>
                }
                @if (gecikmisSayisi > 0)
                {
                    <span class="badge bg-warning text-dark ms-2">@gecikmisSayisi gecikmiş</span>
                }
            </div>
            <button class="btn @btnClass btn-sm me-2" @onclick="() => showAtananEvraklarModal = true">
                <i class="bi bi-eye me-1"></i>Görüntüle
            </button>
            <a href="/ebys/takip" class="btn @btnClass btn-sm">
                <i class="bi bi-arrow-right me-1"></i>Evrak Takip
            </a>
        </div>
    }

    <div class="dashboard-flex-widgets" style="display:flex;flex-direction:column;">
    <!-- Hızlı İşlemler Paneli -->
    @if (WidgetGorünür("hizli-islemler"))
    {
    <div class="card mb-4 border-0 shadow-sm" style='order: @GetWidgetOrder("hizli-islemler")'>
        <div class="card-header bg-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <h6 class="mb-0 text-white"><i class="bi bi-lightning-charge-fill me-2"></i>Hızlı İşlemler</h6>
        </div>
        <div class="card-body py-3">
            <div class="row g-2">
                @if (HasYetki("servis.ekle"))
                {
                    <div class="col-6 col-md-2">
                        <a href="/servis-calismalari/yeni" class="btn btn-outline-primary w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3">
                            <i class="bi bi-plus-circle fs-4 mb-1"></i>
                            <small>Yeni Sefer</small>
                        </a>
                    </div>
                }
                @if (HasYetki("aracmasraf.ekle"))
                {
                    <div class="col-6 col-md-2">
                        <a href="/arac-masraflari/yeni" class="btn btn-outline-warning w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3">
                            <i class="bi bi-fuel-pump fs-4 mb-1"></i>
                            <small>Yakıt/Masraf</small>
                        </a>
                    </div>
                }
                @if (HasYetki("kesilenfatura.ekle"))
                {
                    <div class="col-6 col-md-2">
                        <a href="/faturalar/yeni" class="btn btn-outline-success w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3">
                            <i class="bi bi-receipt fs-4 mb-1"></i>
                            <small>Fatura Kes</small>
                        </a>
                    </div>
                }
                @if (HasYetki("tahsilat.ekle"))
                {
                    <div class="col-6 col-md-2">
                        <a href="/banka-hareketleri/yeni?tur=tahsilat" class="btn btn-outline-info w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3">
                            <i class="bi bi-cash-stack fs-4 mb-1"></i>
                            <small>Tahsilat</small>
                        </a>
                    </div>
                }
                @if (HasYetki("odeme.ekle"))
                {
                    <div class="col-6 col-md-2">
                        <a href="/banka-hareketleri/yeni?tur=odeme" class="btn btn-outline-danger w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3">
                            <i class="bi bi-credit-card fs-4 mb-1"></i>
                            <small>Ödeme</small>
                        </a>
                    </div>
                }
                @if (HasYetki("cariler.ekle"))
                {
                    <div class="col-6 col-md-2">
                        <a href="/cariler/yeni" class="btn btn-outline-secondary w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3">
                            <i class="bi bi-person-plus fs-4 mb-1"></i>
                            <small>Yeni Cari</small>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
    }

    <!-- Özet Kartlar -->
    @if (WidgetGorünür("ozet-kartlar"))
    {
    <div class="row mb-4" style='order: @GetWidgetOrder("ozet-kartlar")'>
        @if (CanViewCariler)
        {
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Toplam Cari</h6>
                            <h2>@cariSayisi</h2>
                        </div>
                        <i class="bi bi-people-fill" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/cariler" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }

        @if (CanViewAraclar)
        {
        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Aktif Araç</h6>
                            <h2>@aracSayisi</h2>
                        </div>
                        <i class="bi bi-truck" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/araclar" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }

        @if (CanViewSoforler)
        {
        <div class="col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Aktif Şoför</h6>
                            <h2>@soforSayisi</h2>
                        </div>
                        <i class="bi bi-person-badge" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/soforler" class="text-dark text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }

        @if (CanViewFaturalar)
        {
        <div class="col-md-3">
            <div class="card bg-danger text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Bekleyen Fatura</h6>
                            <h2>@bekleyenFaturaSayisi</h2>
                        </div>
                        <i class="bi bi-receipt" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/faturalar" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }
    </div>
    }

    <!-- Finansal Özet -->
    @if (WidgetGorünür("finansal-ozet") && CanViewFinans)
    {
    <div class="row mb-4" style='order: @GetWidgetOrder("finansal-ozet")'>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Bu Ay Özet</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <small class="text-muted d-block">Toplam Gelir</small>
                            <h5 class="text-success mb-0">@FormatKisa(buAyGelir)</h5>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Toplam Gider</small>
                            <h5 class="text-danger mb-0">@FormatKisa(buAyGider)</h5>
                        </div>
                    </div>
                    <hr />
                    <div class="text-center">
                        <small class="text-muted d-block">Net Kar/Zarar</small>
                        <h4 class="@(buAyGelir - buAyGider >= 0 ? "text-success" : "text-danger") mb-0">
                            @FormatKisa(buAyGelir - buAyGider)
                        </h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-bank me-2"></i>Kasa/Banka Durumu</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Toplam Kasa:</span>
                        <strong class="text-primary">@Format(toplamKasa)</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Toplam Banka:</span>
                        <strong class="text-primary">@Format(toplamBanka)</strong>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span><strong>Genel Toplam:</strong></span>
                        <strong class="h5 text-success mb-0">@Format(toplamKasa + toplamBanka)</strong>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/banka-hareketleri" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right me-1"></i>Detay Görüntüle
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Bu Ay Bütçe</h6>
                </div>
                <div class="card-body">
                    @if (butceOzet != null)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Planlanan Ödeme:</span>
                            <strong class="text-danger">@FormatKisa(butceOzet.ToplamOdeme)</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Ödenen:</span>
                            <strong class="text-success">@FormatKisa(butceOzet.OdenenToplam)</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Bekleyen:</span>
                            <strong class="text-warning">@FormatKisa(butceOzet.BekleyenToplam)</strong>
                        </div>
                        <hr />
                        <div class="progress" style="height: 20px;">
                            @{
                                var odemeYuzdesi = butceOzet.ToplamOdeme > 0 
                                    ? (int)((butceOzet.OdenenToplam / butceOzet.ToplamOdeme) * 100) 
                                    : 0;
                            }
                            <div class="progress-bar bg-success" role="progressbar" 
                                 style="width: @odemeYuzdesi%" 
                                 aria-valuenow="@odemeYuzdesi" aria-valuemin="0" aria-valuemax="100">
                                @odemeYuzdesi%
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Bütçe verisi yok</p>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/butce" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right me-1"></i>Detay Görüntüle
                    </a>
                </div>
            </div>
        </div>
    </div>
    }

    <!-- Grafikler Bölümü -->
    @if (WidgetGorünür("grafikler"))
    {
    <div class="row mb-4" style='order: @GetWidgetOrder("grafikler")'>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-bar-chart-fill me-2"></i>Aylık Gelir/Gider (@DateTime.Today.Year)</h6>
                </div>
                <div class="card-body">
                    <div style="height: 280px;">
                        <canvas id="gelirGiderChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-pie-chart-fill me-2"></i>Masraf Dağılımı (6 Ay)</h6>
                </div>
                <div class="card-body">
                    <div style="height: 200px;">
                        <canvas id="masrafDagilimiChart"></canvas>
                    </div>
                    @if (masrafDagilimi != null && masrafDagilimi.Any())
                    {
                        <div class="mt-2" style="max-height: 60px; overflow-y: auto; font-size: 0.75rem;">
                            @{
                                var colors = new[] { "#0d6efd", "#6610f2", "#6f42c1", "#d63384", "#dc3545", "#fd7e14", "#ffc107", "#198754" };
                                var i = 0;
                            }
                            @foreach (var item in masrafDagilimi.Take(8))
                            {
                                <span class="me-2">
                                    <span style="display:inline-block;width:10px;height:10px;background:@colors[i++ % colors.Length];border-radius:2px;"></span>
                                    @item.KategoriAdi
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4" style='order: @GetWidgetOrder("grafikler")'>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>Bütçe Takibi (6 Ay)</h6>
                </div>
                <div class="card-body">
                    <div style="height: 200px;">
                        <canvas id="butceChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-people-fill me-2"></i>Cari Dağılımı</h6>
                </div>
                <div class="card-body" style="max-height: 250px; overflow-y: auto;">
                    @if (cariDagilimi != null && cariDagilimi.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Cari Tipi</th>
                                        <th class="text-center">Adet</th>
