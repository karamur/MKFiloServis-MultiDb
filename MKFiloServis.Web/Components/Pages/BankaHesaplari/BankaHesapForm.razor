@page "/banka-hesaplari/yeni"
@page "/banka-hesaplari/{Id:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IBankaHesapService BankaHesapService
@inject IBudgetService BudgetService
@inject IFirmaService FirmaService
@inject IAktifFirmaProvider AktifFirmaProvider
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Hesap Düzenle" : "Yeni Banka/Kasa Hesabı")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-bank me-2"></i>@(IsEdit ? "Hesap Düzenle" : "Yeni Banka/Kasa Hesabı")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            @if (!string.IsNullOrWhiteSpace(saveErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-octagon me-2"></i>@saveErrorMessage
                </div>
            }

            <EditForm Model="hesap" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Hesap Kodu *</label>
                            <InputText @bind-Value="hesap.HesapKodu" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Hesap Adı *</label>
                            <InputText @bind-Value="hesap.HesapAdi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Hesap Tipi *</label>
                            <InputSelect @bind-Value="hesap.HesapTipi" class="form-select"
                                @bind-Value:after="OnHesapTipiChanged">
                                @foreach (HesapTipi tip in Enum.GetValues(typeof(HesapTipi)))
                                {
                                    <option value="@tip">@GetTipText(tip)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Bağlı Firma *</label>
                            <InputSelect @bind-Value="hesap.FirmaId" class="form-select">
                                <option value="">-- Firma seçin --</option>
                                @if (firmalar != null)
                                {
                                    @foreach (var f in firmalar)
                                    {
                                        <option value="@f.Id">@f.FirmaAdi</option>
                                    }
                                }
                            </InputSelect>
                            <div class="form-text">Bu hesap, seçilen firmanın kasa/banka listesinde görünür.</div>
                        </div>
                    </div>
                </div>

                @if (hesap.HesapTipi == HesapTipi.KrediKarti)
                {
                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label class="form-label">İlişkili Kredi/Taksit</label>
                                <select class="form-select" @bind="secilenKrediGrupId">
                                    <option value="">-- Seçiniz (Opsiyonel) --</option>
                                    @if (krediOzetleri != null)
                                    {
                                        @foreach (var kredi in krediOzetleri)
                                        {
                                            <option value="@kredi.TaksitGrupId">@kredi.MasrafKalemi - @kredi.Aciklama (@FormatPara(kredi.KalanTutar)
                                                kalan)
                                            </option>
                                        }
                                    }
                                </select>
                                <small class="text-muted">Bu kredi kartı ile yapılan ödemeler seçilen kredi/taksitle
                                    ilişkilendirilir</small>
                            </div>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Banka Adı</label>
                            <InputText @bind-Value="hesap.BankaAdi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Şube Adı</label>
                            <InputText @bind-Value="hesap.SubeAdi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Şube Kodu</label>
                            <InputText @bind-Value="hesap.SubeKodu" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Hesap No / Kart No</label>
                            <InputText @bind-Value="hesap.HesapNo" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">IBAN</label>
                            <InputText @bind-Value="hesap.Iban" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Para Birimi</label>
                            <InputText @bind-Value="hesap.ParaBirimi" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">@(hesap.HesapTipi == HesapTipi.KrediKarti ? "Kredi Limiti" :
                            "Açılış Bakiyesi") (₺)</label>
                            <InputNumber @bind-Value="hesap.AcilisBakiye" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3 pt-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="hesap.Aktif" class="form-check-input" id="aktif" />
                                <label class="form-check-label" for="aktif">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notlar</label>
                    <InputTextArea @bind-Value="hesap.Notlar" class="form-control" rows="2" />
                </div>

                <div class="card border-light-subtle mb-3">
                    <div class="card-header bg-light">
                        <strong><i class="bi bi-journal-code me-2"></i>Muhasebe Eşleştirme</strong>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3 mb-md-0">
                                    <label class="form-label">Varsayılan Muhasebe Kodu</label>
                                    <InputText @bind-Value="hesap.VarsayilanMuhasebeKodu" class="form-control" />
                                    <div class="form-text">Örn: Kasa için `100`, banka için `102`, kredi için `300`.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div>
                                    <label class="form-label">Varsayılan Kost Merkezi</label>
                                    <InputText @bind-Value="hesap.VarsayilanKostMerkezi" class="form-control" />
                                    <div class="form-text">Bu hesaptan açılan hareketlere otomatik önerilir.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg me-1"></i>
                        }
                        Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri" disabled="@isSaving">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private BankaHesap hesap = new();
    private List<KrediOzet>? krediOzetleri;
    private List<Firma>? firmalar;
    private string secilenKrediGrupId = "";
    private bool IsEdit => Id.HasValue;
    private bool isSaving;
    private string? saveErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Kredi/Taksit listesini yükle
        krediOzetleri = await BudgetService.GetKrediOzetleriAsync();
        firmalar = await FirmaService.GetAktifFirmalarAsync();

        if (IsEdit)
        {
            var existing = await BankaHesapService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                hesap = existing;
                if (hesap.KrediTaksitGrupId.HasValue)
                {
                    secilenKrediGrupId = hesap.KrediTaksitGrupId.Value.ToString();
                }
            }
            else
            {
                Navigation.NavigateTo("/banka-hesaplari");
            }
        }
        else
        {
            hesap.HesapKodu = await BankaHesapService.GenerateNextKodAsync();
            hesap.HesapTipi = HesapTipi.VadesizHesap;
            hesap.ParaBirimi = "TRY";
            hesap.Aktif = true;
            // Varsayılan: aktif firma
            if (AktifFirmaProvider.AktifFirmaId.HasValue && AktifFirmaProvider.AktifFirmaId.Value > 0)
            {
                hesap.FirmaId = AktifFirmaProvider.AktifFirmaId.Value;
            }
            ApplyVarsayilanMuhasebeAlanlari(force: true);
        }
    }

    private async Task OnHesapTipiChanged()
    {
        if (hesap.HesapTipi != HesapTipi.KrediKarti)
        {
            secilenKrediGrupId = "";
            hesap.KrediTaksitGrupId = null;
        }

        ApplyVarsayilanMuhasebeAlanlari();
    }

    private async Task Kaydet()
    {
        if (isSaving)
            return;

        if (string.IsNullOrWhiteSpace(hesap.HesapAdi))
        {
            ToastService.ShowWarning("Hesap adı zorunludur.");
            return;
        }

        if (!hesap.FirmaId.HasValue || hesap.FirmaId.Value <= 0)
        {
            ToastService.ShowWarning("Bağlı firma seçimi zorunludur.");
            return;
        }

        // Kredi kartı için ilişkili kredi ayarla
        if (hesap.HesapTipi == HesapTipi.KrediKarti && !string.IsNullOrEmpty(secilenKrediGrupId))
        {
            hesap.KrediTaksitGrupId = Guid.Parse(secilenKrediGrupId);
        }
        else
        {
            hesap.KrediTaksitGrupId = null;
        }

        saveErrorMessage = null;
        isSaving = true;

        try
        {
            if (IsEdit)
            {
                await BankaHesapService.UpdateAsync(hesap);
                ToastService.ShowSuccess("Banka hesabı güncellendi.");
            }
            else
            {
                await BankaHesapService.CreateAsync(hesap);
                ToastService.ShowSuccess("Banka hesabı kaydedildi.");
            }

            Navigation.NavigateTo("/banka-hesaplari");
        }
        catch (InvalidOperationException ex)
        {
            saveErrorMessage = ex.Message;
            ToastService.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            saveErrorMessage = "Kayıt sırasında beklenmeyen bir hata oluştu.";
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Geri()
    {
        Navigation.NavigateTo("/banka-hesaplari");
    }

    private string GetTipText(HesapTipi tip) => tip switch
    {
        HesapTipi.Kasa => "Kasa",
        HesapTipi.VadesizHesap => "Vadesiz Hesap",
        HesapTipi.VadeliHesap => "Vadeli Hesap",
        HesapTipi.KrediHesabi => "Kredi Hesabı",
        HesapTipi.KrediKarti => "Kredi Kartı",
        _ => tip.ToString()
    };

    private string FormatPara(decimal tutar)
    {
        return tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " ₺";
    }

    private void ApplyVarsayilanMuhasebeAlanlari(bool force = false)
    {
        if (force || string.IsNullOrWhiteSpace(hesap.VarsayilanMuhasebeKodu))
        {
            hesap.VarsayilanMuhasebeKodu = GetVarsayilanMuhasebeKodu(hesap.HesapTipi);
        }
    }

    private string GetVarsayilanMuhasebeKodu(HesapTipi tip) => tip switch
    {
        HesapTipi.Kasa => "100",
        HesapTipi.VadesizHesap => "102",
        HesapTipi.VadeliHesap => "102",
        HesapTipi.KrediHesabi => "300",
        HesapTipi.KrediKarti => "300",
        _ => string.Empty
    };
}

