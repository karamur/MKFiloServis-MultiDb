@page "/kullanici-tercihleri"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IIlanYayinService IlanYayinService
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>Kullanıcı Tercihleri</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-gear me-2"></i>Kullanıcı Tercihleri</h4>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Yükleniyor...</span>
                            </div>
                        </div>
                    }
                    else if (tercih != null)
                    {
                        <EditForm Model="tercih" OnValidSubmit="KaydetTercihler">
                            <!-- Anasayfa Tercihleri -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0"><i class="bi bi-house me-2"></i>Anasayfa Tercihleri</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Varsayılan Anasayfa</label>
                                        <select class="form-select" @bind="tercih.VarsayilanAnasayfa">
                                            <option value="">Dashboard (Genel Bakış)</option>
                                            @foreach (var sayfa in anasayfaSecenekleri)
                                            {
                                                <option value="@sayfa.Value">@sayfa.Text</option>
                                            }
                                        </select>
                                        <small class="text-muted">Sisteme giriş yaptığınızda açılacak sayfa</small>
                                    </div>
                                    <div class="form-check form-switch mb-3">
                                        <InputCheckbox @bind-Value="tercih.AnasayfaWidgetGoster" class="form-check-input" id="chkWidget" />
                                        <label class="form-check-label" for="chkWidget">Dashboard'da widget'ları göster</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Tema Tercihleri -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0"><i class="bi bi-palette me-2"></i>Tema Tercihleri</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Tema</label>
                                            <select class="form-select" @bind="tercih.Tema">
                                                <option value="">Varsayılan</option>
                                                <option value="light">Açık</option>
                                                <option value="dark">Koyu</option>
                                                <option value="auto">Otomatik (Sistem)</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Sidebar Durumu</label>
                                            <select class="form-select" @bind="tercih.SidebarDurum">
                                                <option value="">Varsayılan</option>
                                                <option value="expanded">Açık</option>
                                                <option value="collapsed">Kapalı</option>
                                                <option value="auto">Otomatik</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Bildirim Tercihleri -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0"><i class="bi bi-bell me-2"></i>Bildirim Tercihleri</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-check form-switch mb-3">
                                        <InputCheckbox @bind-Value="tercih.EmailBildirimAktif" class="form-check-input" id="chkEmail" />
                                        <label class="form-check-label" for="chkEmail">E-posta bildirimleri</label>
                                    </div>
                                    <div class="form-check form-switch mb-3">
                                        <InputCheckbox @bind-Value="tercih.TarayiciBildirimAktif" class="form-check-input" id="chkBrowser" />
                                        <label class="form-check-label" for="chkBrowser">Tarayıcı bildirimleri</label>
                                    </div>
                                    <div class="form-check form-switch mb-3">
                                        <InputCheckbox @bind-Value="tercih.SesBildirimAktif" class="form-check-input" id="chkSes" />
                                        <label class="form-check-label" for="chkSes">Ses bildirimleri</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Liste Tercihleri -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0"><i class="bi bi-list me-2"></i>Liste Tercihleri</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Varsayılan Sayfa Boyutu</label>
                                        <select class="form-select" @bind="tercih.VarsayilanSayfaBoyutu">
                                            <option value="10">10 kayıt</option>
                                            <option value="25">25 kayıt</option>
                                            <option value="50">50 kayıt</option>
                                            <option value="100">100 kayıt</option>
                                        </select>
                                        <small class="text-muted">Listelerde sayfa başına gösterilecek kayıt sayısı</small>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-check-lg me-1"></i> Tercihleri Kaydet
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>

            <!-- Son Erişilen Sayfalar -->
            @if (sonIslemler.Any())
            {
                <div class="card mt-4 shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Son Erişilen Sayfalar</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            @foreach (var islem in sonIslemler)
                            {
                                <a href="@islem.SayfaYolu" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi @(islem.Icon ?? "bi-file-earmark") me-2"></i>
                                        @(islem.SayfaBasligi ?? islem.SayfaYolu)
                                    </div>
                                    <div>
                                        <span class="badge bg-secondary me-2">@islem.ErisimSayisi kez</span>
                                        <small class="text-muted">@islem.ErisimZamani.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private KullaniciTercihi? tercih;
    private List<KullaniciSonIslem> sonIslemler = new();
    private int kullaniciId;
    private bool isLoading = true;
    private bool isSaving = false;

    private List<(string Value, string Text)> anasayfaSecenekleri = new()
    {
        ("araclar", "Araçlar"),
        ("cariler", "Cariler"),
        ("soforler", "Personeller"),
        ("guzergahlar", "Güzergahlar"),
        ("faturalar", "Faturalar"),
        ("servis-calismalar", "Servis Çalışmaları"),
        ("arac-masraflar", "Araç Masrafları"),
        ("filo-operasyon", "Filo Operasyon"),
        ("arac-ilan-yayinlari", "Araç İlan Yayınları"),
        ("muhasebe", "Muhasebe"),
        ("bordro", "Bordro"),
        ("stok", "Stok/Envanter"),
        ("butce-odeme", "Bütçe & Ödeme"),
        ("raporlar", "Raporlar")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                var kullaniciIdClaim = user.FindFirst("KullaniciId")?.Value;
                if (int.TryParse(kullaniciIdClaim, out kullaniciId))
                {
                    tercih = await IlanYayinService.GetKullaniciTercihiAsync(kullaniciId);
                    if (tercih == null)
                    {
                        tercih = new KullaniciTercihi
                        {
                            KullaniciId = kullaniciId,
                            VarsayilanSayfaBoyutu = 25,
                            EmailBildirimAktif = true,
                            TarayiciBildirimAktif = true,
                            AnasayfaWidgetGoster = true
                        };
                    }

                    sonIslemler = await IlanYayinService.GetSonIslemlerAsync(kullaniciId, 10);
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task KaydetTercihler()
    {
        if (tercih == null) return;

        isSaving = true;
        try
        {
            tercih.KullaniciId = kullaniciId;
            await IlanYayinService.CreateOrUpdateTercihAsync(tercih);
            ToastService.ShowSuccess("Tercihler kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }
}

