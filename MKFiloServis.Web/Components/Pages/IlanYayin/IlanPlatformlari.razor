@page "/ilan-platformlari"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IIlanYayinService IlanYayinService
@inject IToastService ToastService
@attribute [Authorize]

<PageTitle>İlan Platformları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-broadcast me-2"></i>İlan Platformları</h2>
            <p class="text-muted mb-0">Araç ilanlarınızı yayınlayacağınız platformları yönetin</p>
        </div>
        <button class="btn btn-primary" @onclick="YeniPlatform">
            <i class="bi bi-plus-lg me-1"></i> Yeni Platform
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var platform in platformlar)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 @(platform.Aktif ? "" : "border-secondary opacity-75")">
                        <div class="card-header d-flex justify-content-between align-items-center @(platform.Aktif ? "bg-success text-white" : "bg-secondary text-white")">
                            <div>
                                <i class="bi @(platform.Icon ?? "bi-globe") me-2"></i>
                                @platform.PlatformAdi
                            </div>
                            <span class="badge @(platform.Aktif ? "bg-light text-success" : "bg-dark")">
                                @(platform.Aktif ? "Aktif" : "Pasif")
                            </span>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(platform.WebSiteUrl))
                            {
                                <p class="mb-2">
                                    <small class="text-muted">Web:</small>
                                    <a href="@platform.WebSiteUrl" target="_blank" class="ms-1">
                                        @platform.WebSiteUrl
                                    </a>
                                </p>
                            }
                            <p class="mb-2">
                                <small class="text-muted">Tip:</small>
                                <span class="ms-1">@GetPlatformTipiText(platform.PlatformTipi)</span>
                            </p>
                            <p class="mb-2">
                                <small class="text-muted">Otomatik Yayın:</small>
                                <span class="ms-1">
                                    @if (platform.OtomatikYayinDestegi)
                                    {
                                        <i class="bi bi-check-circle text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle text-muted"></i>
                                    }
                                </span>
                            </p>
                            @if (!string.IsNullOrEmpty(platform.Notlar))
                            {
                                <p class="mb-0 small text-muted">
                                    @platform.Notlar
                                </p>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => DuzenleDialog(platform)">
                                    <i class="bi bi-pencil"></i> Düzenle
                                </button>
                                <button class="btn btn-outline-@(platform.Aktif ? "secondary" : "success") btn-sm" @onclick="() => ToggleAktif(platform)">
                                    @if (platform.Aktif)
                                    {
                                        <i class="bi bi-pause"></i>
                                        <span>Durdur</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-play"></i>
                                        <span>Aktif Et</span>
                                    }
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => SilOnay(platform)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!platformlar.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Henüz platform tanımlanmamış. "Yeni Platform" butonuna tıklayarak başlayın.
            </div>
        }
    }
</div>

<!-- Platform Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi @(editPlatform.Id == 0 ? "bi-plus-circle" : "bi-pencil") me-2"></i>
                        @(editPlatform.Id == 0 ? "Yeni Platform" : "Platform Düzenle")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editPlatform" OnValidSubmit="KaydetPlatform">
                        <DataAnnotationsValidator />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Platform Adı *</label>
                                <InputText @bind-Value="editPlatform.PlatformAdi" class="form-control" placeholder="Örn: Sahibinden" />
                                <ValidationMessage For="@(() => editPlatform.PlatformAdi)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Platform Tipi</label>
                                <InputSelect @bind-Value="editPlatform.PlatformTipi" class="form-select">
                                    @foreach (var tip in Enum.GetValues<PlatformTipi>())
                                    {
                                        <option value="@tip">@GetPlatformTipiText(tip)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Web Site URL</label>
                                <InputText @bind-Value="editPlatform.WebSiteUrl" class="form-control" placeholder="https://www.sahibinden.com" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Icon</label>
                                <InputText @bind-Value="editPlatform.Icon" class="form-control" placeholder="bi-globe" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Sıra No</label>
                                <InputNumber @bind-Value="editPlatform.SiraNo" class="form-control" />
                            </div>
                        </div>

                        <hr />
                        <h6 class="mb-3"><i class="bi bi-key me-1"></i> API Ayarları (Opsiyonel)</h6>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">API URL</label>
                                <InputText @bind-Value="editPlatform.ApiUrl" class="form-control" placeholder="https://api.sahibinden.com" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">API Key</label>
                                <InputText @bind-Value="editPlatform.ApiKey" class="form-control" type="password" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Kullanıcı Adı</label>
                                <InputText @bind-Value="editPlatform.KullaniciAdi" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Şifre</label>
                                <InputText @bind-Value="editPlatform.Sifre" class="form-control" type="password" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="editPlatform.Notlar" class="form-control" rows="2" />
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <InputCheckbox @bind-Value="editPlatform.Aktif" class="form-check-input" id="chkAktif" />
                                    <label class="form-check-label" for="chkAktif">Platform Aktif</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <InputCheckbox @bind-Value="editPlatform.OtomatikYayinDestegi" class="form-check-input" id="chkOtomatik" />
                                    <label class="form-check-label" for="chkOtomatik">Otomatik Yayın Desteği</label>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i> Kaydet
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Platform Silme</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@deletePlatform?.PlatformAdi</strong> platformunu silmek istediğinize emin misiniz?</p>
                    <p class="text-muted small">Bu işlem geri alınamaz. Platforma ait tüm yayın kayıtları da silinecektir.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button class="btn btn-danger" @onclick="SilPlatform" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-trash me-1"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<IlanPlatformu> platformlar = new();
    private IlanPlatformu editPlatform = new();
    private IlanPlatformu? deletePlatform;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showModal = false;
    private bool showDeleteModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            platformlar = await IlanYayinService.GetPlatformlarAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void YeniPlatform()
    {
        editPlatform = new IlanPlatformu
        {
            Aktif = true,
            SiraNo = platformlar.Count + 1,
            Icon = "bi-globe"
        };
        showModal = true;
    }

    private void DuzenleDialog(IlanPlatformu platform)
    {
        editPlatform = new IlanPlatformu
        {
            Id = platform.Id,
            PlatformAdi = platform.PlatformAdi,
            WebSiteUrl = platform.WebSiteUrl,
            ApiUrl = platform.ApiUrl,
            ApiKey = platform.ApiKey,
            ApiSecret = platform.ApiSecret,
            KullaniciAdi = platform.KullaniciAdi,
            Sifre = platform.Sifre,
            PlatformTipi = platform.PlatformTipi,
            Aktif = platform.Aktif,
            SiraNo = platform.SiraNo,
            Icon = platform.Icon,
            Renk = platform.Renk,
            OtomatikYayinDestegi = platform.OtomatikYayinDestegi,
            Notlar = platform.Notlar
        };
        showModal = true;
    }

    private async Task KaydetPlatform()
    {
        if (string.IsNullOrWhiteSpace(editPlatform.PlatformAdi))
        {
            ToastService.ShowError("Platform adı zorunludur.");
            return;
        }

        isSaving = true;
        try
        {
            if (editPlatform.Id == 0)
            {
                await IlanYayinService.CreatePlatformAsync(editPlatform);
                ToastService.ShowSuccess("Platform eklendi.");
            }
            else
            {
                await IlanYayinService.UpdatePlatformAsync(editPlatform);
                ToastService.ShowSuccess("Platform güncellendi.");
            }
            await LoadData();
            showModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleAktif(IlanPlatformu platform)
    {
        platform.Aktif = !platform.Aktif;
        await IlanYayinService.UpdatePlatformAsync(platform);
        ToastService.ShowInfo(platform.Aktif ? "Platform aktif edildi." : "Platform pasif edildi.");
        await LoadData();
    }

    private void SilOnay(IlanPlatformu platform)
    {
        deletePlatform = platform;
        showDeleteModal = true;
    }

    private async Task SilPlatform()
    {
        if (deletePlatform == null) return;

        isSaving = true;
        try
        {
            await IlanYayinService.DeletePlatformAsync(deletePlatform.Id);
            ToastService.ShowSuccess("Platform silindi.");
            await LoadData();
            showDeleteModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private string GetPlatformTipiText(PlatformTipi tip)
    {
        return tip switch
        {
            PlatformTipi.WebSitesi => "Web Sitesi",
            PlatformTipi.MobilUygulama => "Mobil Uygulama",
            PlatformTipi.SosyalMedya => "Sosyal Medya",
            PlatformTipi.Marketplace => "Marketplace",
            _ => "Diğer"
        };
    }
}

