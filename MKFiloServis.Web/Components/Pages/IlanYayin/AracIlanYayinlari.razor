@page "/arac-ilan-yayinlari"
@page "/arac-ilan-yayinlari/{AracId:int}"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IIlanYayinService IlanYayinService
@inject IAracService AracService
@inject IToastService ToastService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<PageTitle>Araç İlan Yayınları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-megaphone me-2"></i>Araç İlan Yayınları</h2>
            <p class="text-muted mb-0">Araçlarınızı çeşitli platformlarda yayınlayın (Sahibinden, Arabam vb.)</p>
        </div>
        <button class="btn btn-primary" @onclick="YeniYayin">
            <i class="bi bi-plus-lg me-1"></i> Yeni Yayın
        </button>
    </div>

    <!-- Filtreler -->
    <div class="card mb-4">
        <div class="card-body py-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small">Platform</label>
                    <select class="form-select form-select-sm" @bind="filterPlatformId" @bind:after="ApplyFilter">
                        <option value="">Tümü</option>
                        @foreach (var platform in platformlar)
                        {
                            <option value="@platform.Id">@platform.PlatformAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Durum</label>
                    <select class="form-select form-select-sm" @bind="filterDurum" @bind:after="ApplyFilter">
                        <option value="">Tümü</option>
                        <option value="Taslak">Taslak</option>
                        <option value="Aktif">Aktif</option>
                        <option value="Durduruldu">Durduruldu</option>
                        <option value="Satildi">Satıldı</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Araç Ara</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Plaka veya araç adı..." 
                           @bind="searchText" @bind:event="oninput" @bind:after="ApplyFilter" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilter">
                        <i class="bi bi-x-lg me-1"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- İstatistikler -->
    @if (istatistikler != null)
    {
        <div class="row mb-4">
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamYayin</h4>
                        <small>Toplam Yayın</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.AktifYayin</h4>
                        <small>Aktif</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.TaslakYayin</h4>
                        <small>Taslak</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamGoruntulenme</h4>
                        <small>Görüntülenme</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamTiklama</h4>
                        <small>Tıklama</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamMesaj</h4>
                        <small>Mesaj</small>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Araç</th>
                        <th>Platform</th>
                        <th>Durum</th>
                        <th>Fiyat</th>
                        <th>İstatistik</th>
                        <th>Son Güncelleme</th>
                        <th width="150">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var yayin in filteredYayinlar)
                    {
                        <tr>
                            <td>
                                <strong>@yayin.Arac?.AktifPlaka</strong>
                                <br />
                                <small class="text-muted">@yayin.Arac?.Marka @yayin.Arac?.Model</small>
                            </td>
                            <td>
                                <span class="badge bg-primary">
                                    <i class="bi @(yayin.Platform?.Icon ?? "bi-globe") me-1"></i>
                                    @yayin.Platform?.PlatformAdi
                                </span>
                                @if (!string.IsNullOrEmpty(yayin.PlatformIlanUrl))
                                {
                                    <a href="@yayin.PlatformIlanUrl" target="_blank" class="ms-1">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                }
                            </td>
                            <td>
                                <span class="badge @GetDurumBadgeClass(yayin.Durum)">
                                    @GetDurumText(yayin.Durum)
                                </span>
                            </td>
                            <td>
                                @if (yayin.FiyatGizli)
                                {
                                    <span class="text-muted">Gizli</span>
                                }
                                else
                                {
                                    <strong>@yayin.YayinFiyati.ToString("N0") ₺</strong>
                                }
                                @if (!string.IsNullOrEmpty(yayin.FiyatAciklama))
                                {
                                    <br />
                                    <small class="text-info">@yayin.FiyatAciklama</small>
                                }
                            </td>
                            <td>
                                <small>
                                    <i class="bi bi-eye text-primary"></i> @yayin.GoruntulenmeSayisi
                                    <i class="bi bi-cursor ms-2 text-success"></i> @yayin.TiklamaSayisi
                                    <i class="bi bi-heart ms-2 text-danger"></i> @yayin.FavorilenmeSayisi
                                    <i class="bi bi-chat ms-2 text-warning"></i> @yayin.MesajSayisi
                                </small>
                            </td>
                            <td>
                                @if (yayin.SonGuncelleme.HasValue)
                                {
                                    @yayin.SonGuncelleme.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary" @onclick="() => DuzenleYayin(yayin)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (yayin.Durum == IlanYayinDurum.Taslak || yayin.Durum == IlanYayinDurum.Durduruldu)
                                    {
                                        <button class="btn btn-outline-success" @onclick="() => AktifEt(yayin)" title="Yayına Al">
                                            <i class="bi bi-play"></i>
                                        </button>
                                    }
                                    @if (yayin.Durum == IlanYayinDurum.Aktif)
                                    {
                                        <button class="btn btn-outline-warning" @onclick="() => Durdur(yayin)" title="Durdur">
                                            <i class="bi bi-pause"></i>
                                        </button>
                                    }
                                    @if (yayin.Durum != IlanYayinDurum.Satildi)
                                    {
                                        <button class="btn btn-outline-info" @onclick="() => SatildiIsaretle(yayin)" title="Satıldı">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    }
                                    <button class="btn btn-outline-danger" @onclick="() => SilOnay(yayin)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!filteredYayinlar.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Yayın bulunamadı. "Yeni Yayın" butonuna tıklayarak araçlarınızı platformlarda yayınlayın.
            </div>
        }
    }
</div>

<!-- Yayın Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi @(editYayin.Id == 0 ? "bi-plus-circle" : "bi-pencil") me-2"></i>
                        @(editYayin.Id == 0 ? "Yeni Yayın" : "Yayın Düzenle")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editYayin" OnValidSubmit="KaydetYayin">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Araç *</label>
                                <select class="form-select" @bind="editYayin.AracId">
                                    <option value="0">-- Araç Seçin --</option>
                                    @foreach (var arac in araclar)
                                    {
                                        <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Platform *</label>
                                <select class="form-select" @bind="editYayin.PlatformId">
                                    <option value="0">-- Platform Seçin --</option>
                                    @foreach (var platform in platformlar.Where(p => p.Aktif))
                                    {
                                        <option value="@platform.Id">@platform.PlatformAdi</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Yayın Fiyatı</label>
                                <InputNumber @bind-Value="editYayin.YayinFiyati" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Fiyat Açıklaması</label>
                                <InputText @bind-Value="editYayin.FiyatAciklama" class="form-control" placeholder="Pazarlık olur, Takas olur" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Durum</label>
                                <InputSelect @bind-Value="editYayin.Durum" class="form-select">
                                    @foreach (var durum in Enum.GetValues<IlanYayinDurum>())
                                    {
                                        <option value="@durum">@GetDurumText(durum)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Platform İlan No</label>
                                <InputText @bind-Value="editYayin.PlatformIlanNo" class="form-control" placeholder="Platformdaki ilan numarası" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Platform İlan URL</label>
                                <InputText @bind-Value="editYayin.PlatformIlanUrl" class="form-control" placeholder="https://..." />
                            </div>
                        </div>

                        <hr />
                        <h6 class="mb-3"><i class="bi bi-bar-chart me-1"></i> İstatistikler</h6>
                        <div class="row">
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Görüntülenme</label>
                                <InputNumber @bind-Value="editYayin.GoruntulenmeSayisi" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Tıklama</label>
                                <InputNumber @bind-Value="editYayin.TiklamaSayisi" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Favorileme</label>
                                <InputNumber @bind-Value="editYayin.FavorilenmeSayisi" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Mesaj</label>
                                <InputNumber @bind-Value="editYayin.MesajSayisi" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="editYayin.Notlar" class="form-control" rows="2" />
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="editYayin.FiyatGizli" class="form-check-input" id="chkFiyatGizli" />
                                    <label class="form-check-label" for="chkFiyatGizli">Fiyat Gizli</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="editYayin.OneCikarildiMi" class="form-check-input" id="chkOneCikart" />
                                    <label class="form-check-label" for="chkOneCikart">Öne Çıkarıldı</label>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer px-0 pb-0 mt-3">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i> Kaydet
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Yayın Silme</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Bu yayını silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button class="btn btn-danger" @onclick="SilYayin" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-trash me-1"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? AracId { get; set; }

    private List<AracIlanYayin> yayinlar = new();
    private List<AracIlanYayin> filteredYayinlar = new();
    private List<IlanPlatformu> platformlar = new();
    private List<Arac> araclar = new();
    private YayinIstatistikleri? istatistikler;
    private AracIlanYayin editYayin = new();
    private AracIlanYayin? deleteYayin;
    
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showModal = false;
    private bool showDeleteModal = false;

    private string filterPlatformId = "";
    private string filterDurum = "";
    private string searchText = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            platformlar = await IlanYayinService.GetPlatformlarAsync();
            araclar = await AracService.GetAllAsync();
            yayinlar = await IlanYayinService.GetYayinlarAsync(AracId);
            istatistikler = await IlanYayinService.GetYayinIstatistikleriAsync(AracId);
            ApplyFilter();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        var query = yayinlar.AsEnumerable();

        if (!string.IsNullOrEmpty(filterPlatformId) && int.TryParse(filterPlatformId, out var platformId))
            query = query.Where(y => y.PlatformId == platformId);

        if (!string.IsNullOrEmpty(filterDurum) && Enum.TryParse<IlanYayinDurum>(filterDurum, out var durum))
            query = query.Where(y => y.Durum == durum);

        if (!string.IsNullOrEmpty(searchText))
        {
            var search = searchText.ToLowerInvariant();
            query = query.Where(y => 
                (y.Arac != null && y.Arac.AktifPlaka != null && y.Arac.AktifPlaka.ToLowerInvariant().Contains(search)) ||
                (y.Arac != null && y.Arac.Marka != null && y.Arac.Marka.ToLowerInvariant().Contains(search)) ||
                (y.Arac != null && y.Arac.Model != null && y.Arac.Model.ToLowerInvariant().Contains(search)));
        }

        filteredYayinlar = query.ToList();
    }

    private void ClearFilter()
    {
        filterPlatformId = "";
        filterDurum = "";
        searchText = "";
        ApplyFilter();
    }

    private void YeniYayin()
    {
        editYayin = new AracIlanYayin
        {
            Durum = IlanYayinDurum.Taslak,
            AracId = AracId ?? 0
        };
        showModal = true;
    }

    private void DuzenleYayin(AracIlanYayin yayin)
    {
        editYayin = new AracIlanYayin
        {
            Id = yayin.Id,
            AracId = yayin.AracId,
            PlatformId = yayin.PlatformId,
            Durum = yayin.Durum,
            YayinFiyati = yayin.YayinFiyati,
            FiyatGizli = yayin.FiyatGizli,
            FiyatAciklama = yayin.FiyatAciklama,
            GoruntulenmeSayisi = yayin.GoruntulenmeSayisi,
            TiklamaSayisi = yayin.TiklamaSayisi,
            FavorilenmeSayisi = yayin.FavorilenmeSayisi,
            MesajSayisi = yayin.MesajSayisi,
            PlatformIlanNo = yayin.PlatformIlanNo,
            PlatformIlanUrl = yayin.PlatformIlanUrl,
            OneCikarildiMi = yayin.OneCikarildiMi,
            Notlar = yayin.Notlar
        };
        showModal = true;
    }

    private async Task KaydetYayin()
    {
        if (editYayin.AracId == 0)
        {
            ToastService.ShowError("Araç seçimi zorunludur.");
            return;
        }
        if (editYayin.PlatformId == 0)
        {
            ToastService.ShowError("Platform seçimi zorunludur.");
            return;
        }

        isSaving = true;
        try
        {
            if (editYayin.Id == 0)
            {
                await IlanYayinService.CreateYayinAsync(editYayin);
                ToastService.ShowSuccess("Yayın eklendi.");
            }
            else
            {
                await IlanYayinService.UpdateYayinAsync(editYayin);
                ToastService.ShowSuccess("Yayın güncellendi.");
            }
            await LoadData();
            showModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task AktifEt(AracIlanYayin yayin)
    {
        await IlanYayinService.YayinAktifEtAsync(yayin.Id);
        ToastService.ShowSuccess("Yayın aktif edildi.");
        await LoadData();
    }

    private async Task Durdur(AracIlanYayin yayin)
    {
        await IlanYayinService.YayinDurdurAsync(yayin.Id);
        ToastService.ShowWarning("Yayın durduruldu.");
        await LoadData();
    }

    private async Task SatildiIsaretle(AracIlanYayin yayin)
    {
        await IlanYayinService.YayinSatildiIsaretle(yayin.Id);
        ToastService.ShowInfo("Araç satıldı olarak işaretlendi.");
        await LoadData();
    }

    private void SilOnay(AracIlanYayin yayin)
    {
        deleteYayin = yayin;
        showDeleteModal = true;
    }

    private async Task SilYayin()
    {
        if (deleteYayin == null) return;

        isSaving = true;
        try
        {
            await IlanYayinService.DeleteYayinAsync(deleteYayin.Id);
            ToastService.ShowSuccess("Yayın silindi.");
            await LoadData();
            showDeleteModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private string GetDurumBadgeClass(IlanYayinDurum durum)
    {
        return durum switch
        {
            IlanYayinDurum.Taslak => "bg-secondary",
            IlanYayinDurum.OnayBekliyor => "bg-warning text-dark",
            IlanYayinDurum.Aktif => "bg-success",
            IlanYayinDurum.Durduruldu => "bg-dark",
            IlanYayinDurum.SuresiDoldu => "bg-danger",
            IlanYayinDurum.Satildi => "bg-info",
            IlanYayinDurum.Silindi => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetDurumText(IlanYayinDurum durum)
    {
        return durum switch
        {
            IlanYayinDurum.Taslak => "Taslak",
            IlanYayinDurum.OnayBekliyor => "Onay Bekliyor",
            IlanYayinDurum.Aktif => "Aktif",
            IlanYayinDurum.Durduruldu => "Durduruldu",
            IlanYayinDurum.SuresiDoldu => "Süresi Doldu",
            IlanYayinDurum.Satildi => "Satıldı",
            IlanYayinDurum.Silindi => "Silindi",
            _ => "Bilinmiyor"
        };
    }
}

