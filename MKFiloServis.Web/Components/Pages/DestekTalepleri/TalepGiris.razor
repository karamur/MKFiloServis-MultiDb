@page "/destek-talepleri/talep-giris"
@page "/destek-talepleri/talep-giris/{TalepId:int}"
@rendermode InteractiveServer
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@inject IDestekTalebiService DestekService
@inject IKullaniciService KullaniciService
@inject AppAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(TalepId > 0 ? "Talep Düzenle" : "Yeni Destek Talebi")</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h3>
                    <i class="bi bi-ticket-detailed-fill text-primary me-2"></i>
                    @(TalepId > 0 ? "Talep Düzenle" : "Yeni Destek Talebi Oluştur")
                </h3>
                <div class="d-flex gap-2">
                    <a href="destek-talepleri/taleplerim" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Taleplerime Dön
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-2 text-muted">Veriler yükleniyor...</p>
        </div>
    }
    else
    {
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Talep Bilgileri</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="talep" OnValidSubmit="KaydetAsync">
                        <DataAnnotationsValidator />
                        
                        @if (TalepId > 0 && talep != null)
                        {
                            <div class="mb-3 p-3 bg-light rounded">
                                <div class="row">
                                    <div class="col-md-4">
                                        <small class="text-muted">Talep No</small>
                                        <div class="fw-bold">@talep.TalepNo</div>
                                    </div>
                                    <div class="col-md-4">
                                        <small class="text-muted">Durum</small>
                                        <div>
                                            <span class="badge @GetDurumBadgeClass(talep.Durum)">@GetDurumText(talep.Durum)</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <small class="text-muted">Oluşturulma</small>
                                        <div class="fw-bold">@talep.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Departman <span class="text-danger">*</span></label>
                                <select class="form-select" @bind="talep!.DepartmanId" disabled="@(!CanEdit)">
                                    <option value="0">-- Seçiniz --</option>
                                    @foreach (var dept in departmanlar)
                                    {
                                        <option value="@dept.Id">@dept.Ad</option>
                                    }
                                </select>
                                <ValidationMessage For="() => talep.DepartmanId" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Kategori</label>
                                <select class="form-select" @bind="talep.KategoriId" disabled="@(!CanEdit)">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var kat in kategoriler.Where(k => talep.DepartmanId == 0 || k.DepartmanId == talep.DepartmanId || k.DepartmanId == null))
                                    {
                                        <option value="@kat.Id">@kat.Ad</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Konu <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="talep.Konu" placeholder="Talebin konusunu kısaca yazın" disabled="@(!CanEdit)" />
                            <ValidationMessage For="() => talep.Konu" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Açıklama <span class="text-danger">*</span></label>
                            <textarea class="form-control" rows="6" @bind="talep.Aciklama" 
                                placeholder="Sorununuzu veya talebinizi detaylı olarak açıklayın..." disabled="@(!CanEdit)"></textarea>
                            <ValidationMessage For="() => talep.Aciklama" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Öncelik</label>
                                <select class="form-select" @bind="talep.Oncelik" disabled="@(!CanEdit)">
                                    @foreach (DestekOncelik oncelik in Enum.GetValues(typeof(DestekOncelik)))
                                    {
                                        <option value="@oncelik">@GetOncelikText(oncelik)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">İletişim E-posta</label>
                                <input type="email" class="form-control" @bind="talep.MusteriEmail" placeholder="E-posta adresiniz" disabled="@(!CanEdit)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">İletişim Telefon</label>
                            <input type="tel" class="form-control" @bind="talep.MusteriTelefon" placeholder="Telefon numaranız" disabled="@(!CanEdit)" />
                        </div>

                        @if (CanEdit)
                        {
                            <hr />
                            <div class="d-flex justify-content-between">
                                <div>
                                    @if (TalepId == 0 || talep.Durum == DestekDurum.Taslak)
                                    {
                                        <button type="button" class="btn btn-outline-secondary me-2" @onclick="TaslakKaydet" disabled="@isSaving">
                                            <i class="bi bi-file-earmark me-1"></i>Taslak Kaydet
                                        </button>
                                    }
                                </div>
                                <div>
                                    <a href="destek-talepleri/taleplerim" class="btn btn-outline-secondary me-2">
                                        <i class="bi bi-x-lg me-1"></i>İptal
                                    </a>
                                    @if (TalepId == 0 || talep.Durum == DestekDurum.Taslak)
                                    {
                                        <button type="submit" class="btn btn-success" disabled="@isSaving">
                                            @if (isSaving)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            <i class="bi bi-send me-1"></i>Gönder
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                Bu talep gönderildiği için düzenlenemez. Durum: <strong>@GetDurumText(talep.Durum)</strong>
                            </div>
                        }
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Yardım Kartı -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Yardım</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Taslak:</strong> Henüz gönderilmedi, düzenleyebilirsiniz
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-send text-primary me-2"></i>
                            <strong>Gönderildi:</strong> Yetkili atama bekliyor
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-gear text-warning me-2"></i>
                            <strong>İşlemde:</strong> Yetkili üzerinde çalışıyor
                        </li>
                        <li>
                            <i class="bi bi-check2-all text-success me-2"></i>
                            <strong>Bitti:</strong> Tamamlandı, onayınız bekleniyor
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Talep Geçmişi (Düzenleme modunda) -->
            @if (TalepId > 0 && aktiviteler.Any())
            {
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Son Aktiviteler</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var aktivite in aktiviteler.Take(5))
                            {
                                <li class="list-group-item">
                                    <small class="text-muted">@aktivite.CreatedAt.ToString("dd.MM HH:mm")</small>
                                    <div>@aktivite.Aciklama</div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
    }
</div>

@code {
    [Parameter] public int TalepId { get; set; }

    private DestekTalebi talep = new();
    private List<DestekDepartman> departmanlar = new();
    private List<DestekKategori> kategoriler = new();
    private List<DestekTalebiAktivite> aktiviteler = new();
    
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isSaving = false;
    private bool isLoading = true;
    private int? aktifKullaniciId;

    private bool CanEdit => talep.Durum == DestekDurum.Taslak || TalepId == 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var aktifKullanici = AuthProvider.GetAktifKullanici();
            aktifKullaniciId = aktifKullanici?.Id;

            departmanlar = await DestekService.GetDepartmanlarAsync();
            kategoriler = await DestekService.GetKategorilerAsync();

            if (TalepId > 0)
            {
                var existingTalep = await DestekService.GetByIdWithDetailsAsync(TalepId);
                if (existingTalep != null)
                {
                    // Sadece kendi talebini düzenleyebilir
                    if (existingTalep.OlusturanKullaniciId != aktifKullaniciId)
                    {
                        errorMessage = "Bu talebi düzenleme yetkiniz yok.";
                        Navigation.NavigateTo("destek-talepleri/taleplerim");
                        return;
                    }
                    talep = existingTalep;
                    aktiviteler = await DestekService.GetAktivitelerAsync(TalepId);
                }
                else
                {
                    errorMessage = "Talep bulunamadı.";
                }
            }
            else
            {
                // Yeni talep - varsayılan değerler
                talep = new DestekTalebi
                {
                    Durum = DestekDurum.Taslak,
                    Oncelik = DestekOncelik.Normal,
                    Kaynak = DestekKaynak.Web,
                    OlusturanKullaniciId = aktifKullaniciId,
                    MusteriAdi = aktifKullanici?.AdSoyad ?? string.Empty,
                    MusteriEmail = aktifKullanici?.Email ?? string.Empty
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Veriler yüklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task TaslakKaydet()
    {
        await KaydetInternalAsync(taslak: true);
    }

    private async Task KaydetAsync()
    {
        await KaydetInternalAsync(taslak: false);
    }

    private async Task KaydetInternalAsync(bool taslak)
    {
        if (string.IsNullOrWhiteSpace(talep.Konu))
        {
            errorMessage = "Konu alanı zorunludur.";
            return;
        }

        if (string.IsNullOrWhiteSpace(talep.Aciklama))
        {
            errorMessage = "Açıklama alanı zorunludur.";
            return;
        }

        if (talep.DepartmanId == 0)
        {
            errorMessage = "Departman seçimi zorunludur.";
            return;
        }

        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            talep.Durum = taslak ? DestekDurum.Taslak : DestekDurum.Gonderildi;
            talep.OlusturanKullaniciId = aktifKullaniciId;
            talep.SonAktiviteTarihi = DateTime.UtcNow;

            if (TalepId == 0)
            {
                var created = await DestekService.CreateAsync(talep);
                successMessage = taslak 
                    ? "Talep taslak olarak kaydedildi." 
                    : $"Talep başarıyla gönderildi. Talep No: {created.TalepNo}";
                
                if (!taslak)
                {
                    await Task.Delay(1500);
                    Navigation.NavigateTo("destek-talepleri/taleplerim");
                }
                else
                {
                    Navigation.NavigateTo($"destek-talepleri/talep-giris/{created.Id}");
                }
            }
            else
            {
                await DestekService.UpdateAsync(talep);
                successMessage = taslak 
                    ? "Taslak güncellendi." 
                    : "Talep başarıyla gönderildi.";
                
                if (!taslak)
                {
                    await Task.Delay(1500);
                    Navigation.NavigateTo("destek-talepleri/taleplerim");
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kayıt sırasında hata: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetDurumText(DestekDurum durum) => durum switch
    {
        DestekDurum.Taslak => "Taslak",
        DestekDurum.Gonderildi => "Gönderildi",
        DestekDurum.Islemde => "İşlemde",
        DestekDurum.Bitti => "Bitti",
        DestekDurum.Onaylandi => "Onaylandı",
        DestekDurum.Yeni => "Yeni",
        DestekDurum.Acik => "Açık",
        DestekDurum.Beklemede => "Beklemede",
        DestekDurum.YanitBekleniyor => "Yanıt Bekleniyor",
        DestekDurum.Cozuldu => "Çözüldü",
        DestekDurum.Kapali => "Kapalı",
        _ => durum.ToString()
    };

    private string GetDurumBadgeClass(DestekDurum durum) => durum switch
    {
        DestekDurum.Taslak => "bg-secondary",
        DestekDurum.Gonderildi => "bg-info",
        DestekDurum.Islemde => "bg-warning text-dark",
        DestekDurum.Bitti => "bg-success",
        DestekDurum.Onaylandi => "bg-primary",
        DestekDurum.Yeni => "bg-primary",
        DestekDurum.Acik => "bg-warning text-dark",
        DestekDurum.Beklemede => "bg-secondary",
        DestekDurum.YanitBekleniyor => "bg-info",
        DestekDurum.Cozuldu => "bg-success",
        DestekDurum.Kapali => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetOncelikText(DestekOncelik oncelik) => oncelik switch
    {
        DestekOncelik.Dusuk => "Düşük",
        DestekOncelik.Normal => "Normal",
        DestekOncelik.Yuksek => "Yüksek",
        DestekOncelik.Acil => "Acil",
        DestekOncelik.Kritik => "Kritik",
        _ => oncelik.ToString()
    };
}

