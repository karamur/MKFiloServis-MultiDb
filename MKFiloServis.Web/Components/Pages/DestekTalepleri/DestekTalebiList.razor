@page "/destek-talepleri"
@rendermode InteractiveServer
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Models
@inject IDestekTalebiService DestekService
@inject IKullaniciService KullaniciService
@inject ICariService CariService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Destek Talepleri</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h3><i class="bi bi-ticket-detailed-fill text-primary me-2"></i>Destek Talepleri</h3>
                <div class="d-flex gap-2">
                    <a href="destek-talepleri/bilgi-bankasi" class="btn btn-outline-info">
                        <i class="bi bi-book me-1"></i>Bilgi Bankası
                    </a>
                    <a href="destek-talepleri/ayarlar" class="btn btn-outline-secondary">
                        <i class="bi bi-gear me-1"></i>Ayarlar
                    </a>
                    <button class="btn btn-outline-secondary me-2" @onclick="LoadDashboardStats">
                        <i class="bi bi-graph-up me-1"></i>İstatistikler
                    </button>
                    <button class="btn btn-primary" @onclick="YeniTalepOlustur">
                        <i class="bi bi-plus-lg me-1"></i>Yeni Talep
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-start mb-3">
            <div>
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Destek modülü verileri yüklenirken sorun oluştu.</strong>
                <div class="small mt-1">@loadError</div>
            </div>
            <button class="btn btn-outline-warning btn-sm" @onclick="SayfayiYenile">
                <i class="bi bi-arrow-clockwise me-1"></i>Tekrar Dene
            </button>
        </div>
    }

    <!-- Dashboard Kartları -->
    @if (stats != null)
    {
        <div class="row mb-3">
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@stats.ToplamTalepSayisi</h5>
                        <small>Toplam</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@stats.AcikTalepSayisi</h5>
                        <small>Açık</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success text-white">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@stats.BugunAcilanTalepSayisi</h5>
                        <small>Bugün Açılan</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@stats.BugunKapatilanTalepSayisi</h5>
                        <small>Bugün Kapanan</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@stats.SlaAsildiSayisi</h5>
                        <small>SLA Aşımı</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body text-center py-2">
                        <h5 class="mb-0">@(stats.OrtalamaCozumSuresiSaat.ToString("F1"))s</h5>
                        <small>Ort. Çözüm</small>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Arama</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Talep No, Konu, Müşteri..." 
                           @bind="filter.AramaMetni" @bind:event="oninput" @onkeyup="OnAramaKeyUp" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" @bind="filter.Durum" @bind:after="LoadTalepler">
                        <option value="">Tümü</option>
                        @foreach (var durum in Enum.GetValues<DestekDurum>())
                        {
                            <option value="@durum">@GetDurumText(durum)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Öncelik</label>
                    <select class="form-select form-select-sm" @bind="filter.Oncelik" @bind:after="LoadTalepler">
                        <option value="">Tümü</option>
                        @foreach (var oncelik in Enum.GetValues<DestekOncelik>())
                        {
                            <option value="@oncelik">@GetOncelikText(oncelik)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Departman</label>
                    <select class="form-select form-select-sm" @bind="filter.DepartmanId" @bind:after="LoadTalepler">
                        <option value="">Tümü</option>
                        @foreach (var dept in departmanlar)
                        {
                            <option value="@dept.Id">@dept.Ad</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Atanan</label>
                    <select class="form-select form-select-sm" @bind="filter.AtananKullaniciId" @bind:after="LoadTalepler">
                        <option value="">Tümü</option>
                        <option value="0">Atanmamış</option>
                        @foreach (var user in kullanicilar)
                        {
                            <option value="@user.Id">@user.AdSoyad</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="sadeceAcik" @bind="filter.SadeceAcik" @bind:after="LoadTalepler" />
                        <label class="form-check-label small" for="sadeceAcik">Sadece Açık</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="slaAsildi" @bind="filter.SlaAsildi" @bind:after="LoadTalepler" />
                        <label class="form-check-label small" for="slaAsildi">SLA Aşımı</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tablo -->
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Yükleniyor...</p>
        </div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Hiç destek talebi bulunamadı.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm">
                <thead class="table-light">
                    <tr>
                        <th style="width:120px;">Talep No</th>
                        <th>Konu</th>
                        <th style="width:120px;">Müşteri</th>
                        <th style="width:100px;">Departman</th>
                        <th style="width:90px;">Öncelik</th>
                        <th style="width:90px;">Durum</th>
                        <th style="width:100px;">Atanan</th>
                        <th style="width:80px;">SLA</th>
                        <th style="width:100px;">Son Aktivite</th>
                        <th style="width:80px;">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var talep in pagedResult.Items)
                    {
                        <tr class="@(talep.SlaAsildi ? "table-danger" : "")">
                            <td>
                                <a href="destek-talepleri/@talep.Id" class="text-decoration-none fw-bold">
                                    @talep.TalepNo
                                </a>
                            </td>
                            <td>
                                <span class="text-truncate d-inline-block" style="max-width:250px;" title="@talep.Konu">
                                    @talep.Konu
                                </span>
                                @if (!string.IsNullOrEmpty(talep.Etiketler))
                                {
                                    <br />
                                    @foreach (var etiket in talep.Etiketler.Split(',').Take(3))
                                    {
                                        <span class="badge bg-light text-dark me-1">@etiket.Trim()</span>
                                    }
                                }
                            </td>
                            <td>
                                <small>@talep.MusteriAdi</small>
                                <br />
                                <small class="text-muted">@talep.MusteriEmail</small>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@talep.Departman?.Ad</span>
                            </td>
                            <td>
                                <span class="badge @GetOncelikBadgeClass(talep.Oncelik)">
                                    @GetOncelikText(talep.Oncelik)
                                </span>
                            </td>
                            <td>
                                <span class="badge @GetDurumBadgeClass(talep.Durum)">
                                    @GetDurumText(talep.Durum)
                                </span>
                            </td>
                            <td>
                                @if (talep.AtananKullanici != null)
                                {
                                    <small>@talep.AtananKullanici.AdSoyad</small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (talep.SlaBitisTarihi.HasValue)
                                {
                                    var kalan = talep.SlaBitisTarihi.Value - DateTime.UtcNow;
                                    @if (talep.SlaAsildi)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-exclamation-triangle"></i> Aşıldı
                                        </span>
                                    }
                                    else if (kalan.TotalHours < 4)
                                    {
                                        <span class="badge bg-warning text-dark">@kalan.Hours s @kalan.Minutes dk</span>
                                    }
                                    else
                                    {
                                        <span class="text-success small">@kalan.Hours s</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <small title="@talep.SonAktiviteTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")">
                                    @GetRelativeTime(talep.SonAktiviteTarihi)
                                </small>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="destek-talepleri/@talep.Id" class="btn btn-outline-primary btn-sm" title="Detay">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" title="İşlemler">
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="#" @onclick="() => AtamaModalAc(talep)" @onclick:preventDefault><i class="bi bi-person-plus me-2"></i>Ata</a></li>
                                        <li><a class="dropdown-item" href="#" @onclick="() => DurumDegistirModalAc(talep)" @onclick:preventDefault><i class="bi bi-arrow-repeat me-2"></i>Durum Değiştir</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item text-danger" href="#" @onclick="() => TalepSil(talep.Id)" @onclick:preventDefault><i class="bi bi-trash me-2"></i>Sil</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Sayfalama -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <small class="text-muted">Toplam @pagedResult.TotalCount kayıt</small>
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(filter.Page <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(filter.Page - 1)">Önceki</button>
                    </li>
                    @for (int i = Math.Max(1, filter.Page - 2); i <= Math.Min(pagedResult.TotalPages, filter.Page + 2); i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(pageNum == filter.Page ? "active" : "")">
                            <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(filter.Page >= pagedResult.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(filter.Page + 1)">Sonraki</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Yeni Talep Modal -->
@if (showYeniTalepModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Yeni Destek Talebi</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Müşteri Adı <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="yeniTalep.MusteriAdi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-posta <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" @bind="yeniTalep.MusteriEmail" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" @bind="yeniTalep.MusteriTelefon" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">İlişkili Cari</label>
                            <select class="form-select" @bind="yeniTalep.CariId" @bind:after="CariSecildi">
                                <option value="">Seçiniz...</option>
                                @foreach (var cari in cariler)
                                {
                                    <option value="@cari.Id">@cari.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Departman <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="yeniTalep.DepartmanId">
                                @foreach (var dept in departmanlar)
                                {
                                    <option value="@dept.Id">@dept.Ad</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kategori</label>
                            <select class="form-select" @bind="yeniTalep.KategoriId">
                                <option value="">Seçiniz...</option>
                                @foreach (var kat in kategoriler.Where(k => k.DepartmanId == yeniTalep.DepartmanId || k.DepartmanId == null))
                                {
                                    <option value="@kat.Id">@kat.Ad</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Öncelik</label>
                            <select class="form-select" @bind="yeniTalep.Oncelik">
                                @foreach (var oncelik in Enum.GetValues<DestekOncelik>())
                                {
                                    <option value="@oncelik">@GetOncelikText(oncelik)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kaynak</label>
                            <select class="form-select" @bind="yeniTalep.Kaynak">
                                @foreach (var kaynak in Enum.GetValues<DestekKaynak>())
                                {
                                    <option value="@kaynak">@kaynak</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Konu <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="yeniTalep.Konu" maxlength="500" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama <span class="text-danger">*</span></label>
                            <textarea class="form-control" rows="5" @bind="yeniTalep.Aciklama"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Etiketler</label>
                            <input type="text" class="form-control" @bind="yeniTalep.Etiketler" placeholder="Virgülle ayırın: hata, acil, yazılım" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TalepKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Atama Modal -->
@if (showAtamaModal && seciliTalep != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Talep Ata</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Talep:</strong> @seciliTalep.TalepNo - @seciliTalep.Konu</p>
                    <div class="mb-3">
                        <label class="form-label">Atanacak Kullanıcı</label>
                        <select class="form-select" @bind="secilenKullaniciId">
                            <option value="">Seçiniz...</option>
                            @foreach (var user in kullanicilar)
                            {
                                <option value="@user.Id">@user.AdSoyad</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TalepAta" disabled="@(secilenKullaniciId == null)">
                        <i class="bi bi-check-lg me-1"></i>Ata
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Durum Değiştir Modal -->
@if (showDurumModal && seciliTalep != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Durum Değiştir</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Talep:</strong> @seciliTalep.TalepNo - @seciliTalep.Konu</p>
                    <p><strong>Mevcut Durum:</strong> <span class="badge @GetDurumBadgeClass(seciliTalep.Durum)">@GetDurumText(seciliTalep.Durum)</span></p>
                    <div class="mb-3">
                        <label class="form-label">Yeni Durum</label>
                        <select class="form-select" @bind="secilenDurum">
                            @foreach (var durum in Enum.GetValues<DestekDurum>())
                            {
                                <option value="@durum">@GetDurumText(durum)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="DurumDegistir">
                        <i class="bi bi-check-lg me-1"></i>Değiştir
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DestekTalebiFilterParams filter = new() { Page = 1, PageSize = 20 };
    private PagedResult<DestekTalebi>? pagedResult;
    private DestekDashboardStats? stats;
    private List<DestekDepartman> departmanlar = new();
    private List<DestekKategori> kategoriler = new();
    private List<Kullanici> kullanicilar = new();
    private List<Cari> cariler = new();
    
    private bool isLoading = true;
    private bool isSaving = false;
    private string? loadError;
    
    // Modal kontrolleri
    private bool showYeniTalepModal = false;
    private bool showAtamaModal = false;
    private bool showDurumModal = false;
    private DestekTalebi yeniTalep = new();
    private DestekTalebi? seciliTalep;
    private int? secilenKullaniciId;
    private DestekDurum secilenDurum;

    protected override async Task OnInitializedAsync()
    {
        await SayfayiYenile();
    }

    private async Task SayfayiYenile()
    {
        loadError = null;
        await LoadReferansVeriler();
        await LoadTalepler();
        await LoadDashboardStats();
    }

    private async Task LoadReferansVeriler()
    {
        try
        {
            departmanlar = await DestekService.GetDepartmanlarAsync();
            kategoriler = await DestekService.GetKategorilerAsync();
            kullanicilar = (await KullaniciService.GetAllAsync()).Where(k => k.Aktif).ToList();
            cariler = (await CariService.GetAllAsync()).Where(c => c.Aktif).OrderBy(c => c.Unvan).ToList();
        }
        catch (Exception ex)
        {
            departmanlar = new();
            kategoriler = new();
            kullanicilar = new();
            cariler = new();
            loadError = ex.Message;
        }
    }

    private async Task LoadTalepler()
    {
        isLoading = true;
        try
        {
            pagedResult = await DestekService.GetPagedAsync(filter);
        }
        catch (Exception ex)
        {
            pagedResult = new PagedResult<DestekTalebi>
            {
                Items = new List<DestekTalebi>(),
                TotalCount = 0,
                PageNumber = filter.Page,
                PageSize = filter.PageSize
            };
            loadError ??= ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task CariSecildi()
    {
        if (!yeniTalep.CariId.HasValue)
        {
            return Task.CompletedTask;
        }

        var seciliCari = cariler.FirstOrDefault(c => c.Id == yeniTalep.CariId.Value);
        if (seciliCari == null)
        {
            return Task.CompletedTask;
        }

        yeniTalep.MusteriAdi = seciliCari.Unvan;
        yeniTalep.MusteriEmail = seciliCari.Email ?? string.Empty;
        yeniTalep.MusteriTelefon = seciliCari.Telefon;

        return Task.CompletedTask;
    }

    private async Task LoadDashboardStats()
    {
        try
        {
            stats = await DestekService.GetDashboardStatsAsync();
        }
        catch (Exception ex)
        {
            stats = null;
            loadError ??= ex.Message;
        }
    }

    private async Task OnAramaKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            filter.Page = 1;
            await LoadTalepler();
        }
    }

    private async Task ChangePage(int page)
    {
        filter.Page = page;
        await LoadTalepler();
    }

    private void YeniTalepOlustur()
    {
        yeniTalep = new DestekTalebi
        {
            Oncelik = DestekOncelik.Normal,
            Kaynak = DestekKaynak.Web,
            DepartmanId = departmanlar.FirstOrDefault()?.Id ?? 0
        };
        showYeniTalepModal = true;
    }

    private async Task TalepKaydet()
    {
        if (string.IsNullOrWhiteSpace(yeniTalep.MusteriAdi) ||
            string.IsNullOrWhiteSpace(yeniTalep.MusteriEmail) ||
            string.IsNullOrWhiteSpace(yeniTalep.Konu) ||
            string.IsNullOrWhiteSpace(yeniTalep.Aciklama))
        {
            await JS.InvokeVoidAsync("alert", "Lütfen zorunlu alanları doldurun.");
            return;
        }

        isSaving = true;
        try
        {
            await DestekService.CreateAsync(yeniTalep);
            CloseModals();
            await LoadTalepler();
            await LoadDashboardStats();
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AtamaModalAc(DestekTalebi talep)
    {
        seciliTalep = talep;
        secilenKullaniciId = talep.AtananKullaniciId;
        showAtamaModal = true;
    }

    private async Task TalepAta()
    {
        if (seciliTalep == null || !secilenKullaniciId.HasValue) return;
        
        await DestekService.AtaAsync(seciliTalep.Id, secilenKullaniciId.Value);
        CloseModals();
        await LoadTalepler();
    }

    private void DurumDegistirModalAc(DestekTalebi talep)
    {
        seciliTalep = talep;
        secilenDurum = talep.Durum;
        showDurumModal = true;
    }

    private async Task DurumDegistir()
    {
        if (seciliTalep == null) return;
        
        await DestekService.UpdateDurumAsync(seciliTalep.Id, secilenDurum);
        CloseModals();
        await LoadTalepler();
        await LoadDashboardStats();
    }

    private async Task TalepSil(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bu talebi silmek istediğinize emin misiniz?");
        if (!confirmed) return;
        
        await DestekService.DeleteAsync(id);
        await LoadTalepler();
        await LoadDashboardStats();
    }

    private void CloseModals()
    {
        showYeniTalepModal = false;
        showAtamaModal = false;
        showDurumModal = false;
        seciliTalep = null;
    }

