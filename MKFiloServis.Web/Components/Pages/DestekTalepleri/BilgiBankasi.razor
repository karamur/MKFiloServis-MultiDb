@page "/destek-talepleri/bilgi-bankasi"
@rendermode InteractiveServer
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Models
@using MKFiloServis.Web.Services
@using MKFiloServis.Web.Services.Interfaces
@inject IDestekTalebiService DestekService
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@inject IJSRuntime JS

<PageTitle>Bilgi Bankası - Koa Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-book me-2"></i>Bilgi Bankası</h4>
        <div class="d-flex gap-2">
            <a href="/destek-talepleri" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-ticket-detailed me-1"></i>Talepler
            </a>
            <a href="/destek-talepleri/ayarlar" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-gear me-1"></i>Ayarlar
            </a>
            <button class="btn btn-primary btn-sm" @onclick="YeniMakale">
                <i class="bi bi-plus-lg me-1"></i>Yeni Makale
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-start mb-3">
            <div>
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Bilgi bankası verileri yüklenirken sorun oluştu.</strong>
                <div class="small mt-1">@loadError</div>
            </div>
            <button class="btn btn-outline-warning btn-sm" @onclick="SayfayiYenile">
                <i class="bi bi-arrow-clockwise me-1"></i>Tekrar Dene
            </button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Arama</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" @bind="filter.AramaMetni" @bind:event="oninput" @bind:after="OnFilterChanged" placeholder="Makale ara..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filter.KategoriId" @bind:after="OnFilterChanged">
                        <option value="">Tüm Kategoriler</option>
                        @foreach (var kategori in kategoriler)
                        {
                            <option value="@kategori.Id">@kategori.Ad</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" value="@durumFilterValue" @onchange="DurumDegisti">
                        <option value="">Tüm Durumlar</option>
                        <option value="Taslak">Taslak</option>
                        <option value="IncelemeBekliyor">İnceleme Bekliyor</option>
                        <option value="Yayinda">Yayında</option>
                        <option value="Arsiv">Arşiv</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="FiltreleriTemizle">
                        <i class="bi bi-x-circle me-1"></i>Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-2">
                    <h5 class="mb-0">@toplamMakale</h5>
                    <small>Toplam Makale</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center py-2">
                    <h5 class="mb-0">@yayindaMakale</h5>
                    <small>Yayında</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center py-2">
                    <h5 class="mb-0">@taslakMakale</h5>
                    <small>Taslak</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center py-2">
                    <h5 class="mb-0">@toplamGoruntuleme</h5>
                    <small>Toplam Görüntülenme</small>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Yükleniyor...</p>
        </div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle me-2"></i>
            Henüz bilgi bankası makalesi bulunmuyor. Yeni makale ekleyerek başlayabilirsiniz.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var makale in pagedResult!.Items)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100 @(makale.Durum == BilgiBankasiDurum.Yayinda ? string.Empty : "border-warning")">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <span class="badge" style="background-color: @(makale.Kategori?.Renk ?? "#6c757d")">
                                @(makale.Kategori?.Ad ?? "Genel")
                            </span>
                            <span class="badge @GetDurumBadgeClass(makale.Durum)">@GetDurumText(makale.Durum)</span>
                        </div>
                        <div class="card-body">
                            <h6 class="card-title">
                                <i class="bi @(makale.Kategori?.Simge ?? "bi-file-text") me-1"></i>
                                @makale.Baslik
                            </h6>
                            <p class="card-text text-muted small">
                                @(makale.Ozet?.Length > 120 ? makale.Ozet[..120] + "..." : makale.Ozet)
                            </p>
                            @if (!string.IsNullOrWhiteSpace(makale.Etiketler))
                            {
                                <div class="mt-2">
                                    @foreach (var etiket in makale.Etiketler.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(3))
                                    {
                                        <span class="badge bg-light text-dark me-1">@etiket</span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center py-2">
                            <small class="text-muted">
                                <i class="bi bi-eye me-1"></i>@makale.GoruntulemeSayisi
                                <i class="bi bi-hand-thumbs-up ms-2 me-1"></i>@makale.YararliBulmaSayisi
                            </small>
                            <div>
                                <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => MakaleDuzenle(makale)" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => MakaleSil(makale)" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (pagedResult!.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <small class="text-muted">Toplam @pagedResult.TotalCount kayıt</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(filter.Page <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => ChangePage(filter.Page - 1)">Önceki</button>
                        </li>
                        @for (int i = Math.Max(1, filter.Page - 2); i <= Math.Min(pagedResult.TotalPages, filter.Page + 2); i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(pageNumber == filter.Page ? "active" : "")">
                                <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                            </li>
                        }
                        <li class="page-item @(filter.Page >= pagedResult.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => ChangePage(filter.Page + 1)">Sonraki</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@if (showMakaleModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-file-text me-2"></i>@(editMakale.Id > 0 ? "Makale Düzenle" : "Yeni Makale")
                    </h5>
                    <button type="button" class="btn-close" @onclick="MakaleModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Başlık <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="editMakale.Baslik" placeholder="Makale başlığı" />
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Kategori</label>
                                <select class="form-select" @bind="editMakale.KategoriId">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var kategori in kategoriler)
                                    {
                                        <option value="@kategori.Id">@kategori.Ad</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Durum</label>
                                <select class="form-select" @bind="editMakale.Durum">
                                    @foreach (var durum in Enum.GetValues<BilgiBankasiDurum>())
                                    {
                                        <option value="@durum">@GetDurumText(durum)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Özet</label>
                        <textarea class="form-control" rows="2" @bind="editMakale.Ozet" placeholder="Kısa açıklama..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">İçerik <span class="text-danger">*</span></label>
                        <textarea class="form-control" rows="10" @bind="editMakale.Icerik" placeholder="Makale içeriği"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Etiketler</label>
                        <input type="text" class="form-control" @bind="editMakale.Etiketler" placeholder="anahtar1, anahtar2, anahtar3" />
                        <small class="text-muted">Virgülle ayırarak yazın</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="MakaleModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="MakaleKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private BilgiBankasiFilterParams filter = new() { Page = 1, PageSize = 12, SortBy = "CreatedAt", SortDesc = true };
    private PagedResult<DestekBilgiBankasi>? pagedResult;
    private List<DestekKategori> kategoriler = new();
    private DestekBilgiBankasi editMakale = new() { Durum = BilgiBankasiDurum.Taslak };
    private bool isLoading = true;
    private bool isSaving;
    private bool showMakaleModal;
    private string durumFilterValue = string.Empty;
    private int toplamMakale;
    private int yayindaMakale;
    private int taslakMakale;
    private int toplamGoruntuleme;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await SayfayiYenile();
    }

    private async Task SayfayiYenile()
    {
        loadError = null;

        try
        {
            kategoriler = await DestekService.GetKategorilerAsync();
        }
        catch (Exception ex)
        {
            kategoriler = new();
            loadError = ex.GetBaseException().Message;
        }

        await LoadMakaleler();
    }

    private async Task LoadMakaleler()
    {
        isLoading = true;
        try
        {
            pagedResult = await DestekService.GetBilgiBankasiPagedAsync(filter);
            await LoadStats();
        }
        catch (Exception ex)
        {
            pagedResult = new PagedResult<DestekBilgiBankasi>
            {
                Items = new List<DestekBilgiBankasi>(),
                TotalCount = 0,
                PageNumber = filter.Page,
                PageSize = filter.PageSize
            };
            loadError ??= ex.GetBaseException().Message;
            ToastService.ShowError($"Bilgi bankası yüklenemedi: {ex.GetBaseException().Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadStats()
    {
        try
        {
            var tumMakaleler = await DestekService.GetBilgiBankasiPagedAsync(new BilgiBankasiFilterParams
            {
                Page = 1,
                PageSize = 500,
                SortBy = "CreatedAt",
                SortDesc = true
            });

            toplamMakale = tumMakaleler.TotalCount;
            yayindaMakale = tumMakaleler.Items.Count(x => x.Durum == BilgiBankasiDurum.Yayinda);
            taslakMakale = tumMakaleler.Items.Count(x => x.Durum == BilgiBankasiDurum.Taslak);
            toplamGoruntuleme = tumMakaleler.Items.Sum(x => x.GoruntulemeSayisi);
        }
        catch (Exception ex)
        {
            toplamMakale = 0;
            yayindaMakale = 0;
            taslakMakale = 0;
            toplamGoruntuleme = 0;
            loadError ??= ex.GetBaseException().Message;
        }
    }

    private async Task OnFilterChanged()
    {
        filter.Page = 1;
        await LoadMakaleler();
    }

    private async Task DurumDegisti(ChangeEventArgs e)
    {
        durumFilterValue = e.Value?.ToString() ?? string.Empty;
        filter.Durum = Enum.TryParse<BilgiBankasiDurum>(durumFilterValue, out var durum)
            ? durum
            : null;
        filter.Page = 1;
        await LoadMakaleler();
    }

    private async Task FiltreleriTemizle()
    {
        filter = new BilgiBankasiFilterParams { Page = 1, PageSize = 12, SortBy = "CreatedAt", SortDesc = true };
        durumFilterValue = string.Empty;
        await LoadMakaleler();
    }

    private void YeniMakale()
    {
        editMakale = new DestekBilgiBankasi { Durum = BilgiBankasiDurum.Taslak };
        showMakaleModal = true;
    }

    private void MakaleDuzenle(DestekBilgiBankasi makale)
    {
        editMakale = new DestekBilgiBankasi
        {
            Id = makale.Id,
            Baslik = makale.Baslik,
            Ozet = makale.Ozet,
            Icerik = makale.Icerik,
            KategoriId = makale.KategoriId,
            Etiketler = makale.Etiketler,
            Durum = makale.Durum,
            Slug = makale.Slug,
            SeoBaslik = makale.SeoBaslik,
            SeoAciklama = makale.SeoAciklama,
            GoruntulemeSayisi = makale.GoruntulemeSayisi,
            YararliBulmaSayisi = makale.YararliBulmaSayisi,
            YararsizBulmaSayisi = makale.YararsizBulmaSayisi,
            YayinlanmaTarihi = makale.YayinlanmaTarihi,
            CreatedAt = makale.CreatedAt,
            YazarKullaniciId = makale.YazarKullaniciId
        };
        showMakaleModal = true;
    }

    private async Task MakaleKaydet()
    {
        if (string.IsNullOrWhiteSpace(editMakale.Baslik) || string.IsNullOrWhiteSpace(editMakale.Icerik))
        {
            ToastService.ShowWarning("Başlık ve içerik alanları zorunludur.");
            return;
        }

        isSaving = true;
        try
        {
            var aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();
            editMakale.YazarKullaniciId ??= aktifKullanici?.Id;

            if (editMakale.Id > 0)
            {
                await DestekService.UpdateBilgiBankasiAsync(editMakale);
                ToastService.ShowSuccess("Makale güncellendi.");
            }
            else
            {
                await DestekService.CreateBilgiBankasiAsync(editMakale);
                ToastService.ShowSuccess("Makale oluşturuldu.");
            }

            showMakaleModal = false;
            await LoadMakaleler();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Makale kaydedilemedi: {ex.GetBaseException().Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task MakaleSil(DestekBilgiBankasi makale)
    {
        var onay = await JS.InvokeAsync<bool>("confirm", $"'{makale.Baslik}' makalesini silmek istediğinize emin misiniz?");
        if (!onay)
        {
            return;
        }

        try
        {
            await DestekService.DeleteBilgiBankasiAsync(makale.Id);
            ToastService.ShowSuccess("Makale silindi.");
            await LoadMakaleler();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Makale silinemedi: {ex.GetBaseException().Message}");
        }
    }

    private async Task ChangePage(int page)
    {
        filter.Page = page;
        await LoadMakaleler();
    }

    private void MakaleModalKapat()
    {
        showMakaleModal = false;
    }

    private static string GetDurumText(BilgiBankasiDurum durum) => durum switch
    {
        BilgiBankasiDurum.Taslak => "Taslak",
        BilgiBankasiDurum.IncelemeBekliyor => "İnceleme Bekliyor",
        BilgiBankasiDurum.Yayinda => "Yayında",
        BilgiBankasiDurum.Arsiv => "Arşiv",
        _ => durum.ToString()
    };

    private static string GetDurumBadgeClass(BilgiBankasiDurum durum) => durum switch
    {
        BilgiBankasiDurum.Taslak => "bg-warning text-dark",
        BilgiBankasiDurum.IncelemeBekliyor => "bg-info text-dark",
        BilgiBankasiDurum.Yayinda => "bg-success",
        BilgiBankasiDurum.Arsiv => "bg-secondary",
        _ => "bg-secondary"
    };
}

