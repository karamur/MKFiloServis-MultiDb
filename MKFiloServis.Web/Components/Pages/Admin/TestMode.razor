@page "/admin/test"
@using Microsoft.AspNetCore.Authorization
@using MKFiloServis.Shared.Entities
@using Microsoft.EntityFrameworkCore
@inject MKFiloServis.Web.Services.TestSessionService TestService
@inject MKFiloServis.Web.Data.DemoDataService DemoService
@inject IDbContextFactory<MKFiloServis.Web.Data.ApplicationDbContext> DbFactory
@inject ILogger<TestMode> Logger
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Guvenli Test Modu</PageTitle>

<div class="container-fluid px-3">
    <h4 class="mb-3">Guvenli Test Modu</h4>

    <div class="alert @(_testAktif ? "alert-warning" : "alert-info") py-2">
        @if (_testAktif)
        {
            <strong>TEST AKTIF!</strong>
            <span>Tum islemler test oturumuna kaydediliyor. Test sonunda geri alinacak.</span>
        }
        else
        {
            <span>Test modu kapali. Canli veri korunuyor.</span>
        }
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success bg-opacity-10 py-2">
                    <strong>Test Baslat</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">5 kritik tablonun SQL backupini alir ve test moduna gecer.</p>
                    <div class="mb-2">
                        <label class="form-label small">Test Etiketi</label>
                        <input type="text" class="form-control form-control-sm" @bind="_testTag" placeholder="TEST_001" />
                    </div>
                    <button class="btn btn-success w-100" @onclick="TestBaslat" disabled="@(_calisiyor || _testAktif)">
                        @if (_calisiyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Backup Al + Test Baslat
                    </button>
                    @if (_baslatSonuc != null)
                    {
                        <div class="mt-2 small @(_baslatSonuc.Basarili ? "text-success" : "text-danger")">
                            @_baslatSonuc.Mesaj
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger bg-opacity-10 py-2">
                    <strong>Testi Geri Al</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Tum tablolari backuptan geri yukler.</p>
                    <p class="small text-danger fw-bold">DIKKAT: Test sirasinda yapilan TUM degisiklikler SILINIR.</p>
                    <button class="btn btn-danger w-100" @onclick="TestGeriAl" disabled="@(_calisiyor || !_testAktif)">
                        @if (_calisiyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        SQL Restore + Testi Kapat
                    </button>
                    @if (_rollbackSonuc != null)
                    {
                        <div class="mt-2 small @(_rollbackSonuc.Basarili ? "text-success" : "text-danger")">
                            @_rollbackSonuc.Mesaj
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-md-6">
            <div class="card border-primary">
                <div class="card-header bg-primary bg-opacity-10 py-2">
                    <strong>Demo Veriler Ekle</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Veri tabanini sifrla ve demo veriler ekle.</p>
                    <p class="small text-warning fw-bold">DIKKAT: Tum tablolar temizlenecek ve demo veriler eklenecek.</p>
                    <button class="btn btn-primary w-100" @onclick="DemoVerilerEkle" disabled="@_calisiyor">
                        @if (_calisiyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Veri Tabanini Sifirla + Demo Ekle
                    </button>
                    @if (_demoEkleSonuc != null)
                    {
                        <div class="mt-2 small @(_demoEkleSonuc.Basarili ? "text-success" : "text-danger")">
                            @_demoEkleSonuc.Mesaj
                            @if (_demoEkleSonuc.SeedCount > 0)
                            {
                                <div class="small mt-1">@_demoEkleSonuc.SeedCount adet kayit eklendi</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-warning">
                <div class="card-header bg-warning bg-opacity-10 py-2">
                    <strong>Demo Veriler Kaldır</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Sadece [TEST] markerli demo verileri kaldır.</p>
                    <p class="small text-info fw-bold">Not: Sadece ozel olarak isaretlenen test verileri silinir.</p>
                    <button class="btn btn-warning w-100" @onclick="DemoVerilerKaldir" disabled="@_calisiyor">
                        @if (_calisiyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Demo Veriler Kaldir
                    </button>
                    @if (_demoKaldirSonuc != null)
                    {
                        <div class="mt-2 small @(_demoKaldirSonuc.Basarili ? "text-success" : "text-danger")">
                            @_demoKaldirSonuc.Mesaj
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-md-12">
            <div class="card border-secondary">
                <div class="card-header bg-secondary bg-opacity-10 py-2">
                    <strong>Firma Verilerini Temizle</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Seçilen firmanın TÜM verilerini sil (Cariler, Araçlar, Soförler, Faturalar, vb).</p>
                    <p class="small text-danger fw-bold">DİKKAT: Bu işlem kalıcıdır ve geri alınamaz!</p>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small">Firma Seç</label>
                            <select class="form-select form-select-sm" @bind="_secilenFirmaId">
                                @foreach (var firma in _firmalar)
                                {
                                    <option value="@firma.Id">@firma.FirmaAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <button class="btn btn-danger w-100" @onclick="FirmaVerileriniTemizle" disabled="@(_calisiyor || _secilenFirmaId <= 0)">
                                @if (_calisiyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Firma Verilerini Temizle
                            </button>
                        </div>
                    </div>
                    @if (_firmaTemizlenmeSonuc != null)
                    {
                        <div class="mt-2 small @(_firmaTemizlenmeSonuc.Basarili ? "text-success" : "text-danger")">
                            @_firmaTemizlenmeSonuc.Mesaj
                            @if (_firmaTemizlenmeSonuc.TruncatedTables.Count > 0)
                            {
                                <div class="small mt-2">
                                    <strong>Silinen tablolar:</strong>
                                    <ul class="mb-0 mt-1">
                                        @foreach (var table in _firmaTemizlenmeSonuc.TruncatedTables.Take(10))
                                        {
                                            <li>@table</li>
                                        }
                                        @if (_firmaTemizlenmeSonuc.TruncatedTables.Count > 10)
                                        {
                                            <li>... ve @(_firmaTemizlenmeSonuc.TruncatedTables.Count - 10) tablo daha</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header py-2"><strong>Test Akisi</strong></div>
        <div class="card-body py-2">
            <ol class="small mb-0">
                <li><strong>Test Baslat</strong> - 5 tablo backup alinir</li>
                <li>Gridde degisiklik yap - Kaydet</li>
                <li>IsleAsync calistir - Fatura/Muhasebe olussun</li>
                <li>Dashboard kontrol et</li>
                <li>Denetim calistir</li>
                <li>Rebuild test et</li>
                <li><strong>Testi Geri Al</strong> - SQL restore, sistem eski haline doner</li>
                <li><strong>Alternatif:</strong> Demo Veriler Ekle - Tum veri tabanini sifrla</li>
                <li><strong>Alternatif:</strong> Demo Veriler Kaldir - Sadece test verilerini sil</li>
                <li><strong>Firma Yönetimi:</strong> Firma Verilerini Temizle - Seçilen firmanın TÜM verilerini sil</li>
            </ol>
        </div>
    </div>
</div>

