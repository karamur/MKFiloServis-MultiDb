@page "/admin/recovery"
@using MKFiloServis.Shared.Entities
@using MKFiloServis.Web.Data
@using MKFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject RebuildService RebuildService
@attribute [Authorize(Roles = "Admin,HoldingYoneticisi")]
@rendermode InteractiveServer

<PageTitle>Recovery — Sistem Kurtarma</PageTitle>

<div class="container-fluid px-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="bi bi-tools me-2 text-warning"></i>Sistem Kurtarma</h4>
            <small class="text-muted">Snapshot geri alma, dönem rebuild, eksik zincir tamamlama</small>
        </div>
    </div>

    @* Filtreler *@
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="_firmaId">
                        @foreach (var f in _firmalar)
                        {
                            <option value="@f.Id">@f.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Yıl</label>
                    <select class="form-select form-select-sm" @bind="_yil">
                        @for (int y = DateTime.Today.Year - 1; y <= DateTime.Today.Year + 1; y++)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Ay</label>
                    <select class="form-select form-select-sm" @bind="_ay">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")))</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-primary btn-sm" @onclick="OnizlemeYap" disabled="@_calisiyor">
                        <i class="bi bi-eye me-1"></i>Önizleme
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_calisiyor)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-warning"></div>
            <p class="text-muted mt-2">@_durumMesaji</p>
        </div>
    }

    @* Önizleme *@
    @if (_onizleme != null)
    {
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Hakediş Sayısı</small>
                        <div class="fs-4 fw-bold">@_onizleme.HakedisSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(_onizleme.IslenmemisHakedisSayisi > 0 ? "border-danger" : "border-success")">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">İşlenmemiş</small>
                        <div class="fs-4 fw-bold">@_onizleme.IslenmemisHakedisSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(_onizleme.Tutarli ? "border-success" : "border-danger")">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Snapshot Uyumu</small>
                        <div class="fs-5 fw-bold">
                            @if (_onizleme.Tutarli) { <span class="text-success">✅ Tutarlı</span> }
                            else { <span class="text-danger">❌ Fark: @((_onizleme.HakedisGelirToplam - _onizleme.SnapshotHakedisGelir).ToString("N2")) ₺</span> }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 d-flex align-items-center">
                <button class="btn @(_rebuildOnay ? "btn-danger" : "btn-warning") w-100" @onclick="RebuildCalistir" disabled="@_calisiyor">
                    <i class="bi @(_rebuildOnay ? "bi-exclamation-triangle" : "bi-arrow-repeat") me-2"></i>
                    @(_rebuildOnay ? "Onaylamak için tekrar tıkla" : "Rebuild Başlat")
                </button>
            </div>
        </div>
    }

    @* Sonuç *@
    @if (_sonuc != null)
    {
        <div class="card @(_sonuc.TamBasarili ? "border-success" : "border-warning")">
            <div class="card-header py-2 @(_sonuc.TamBasarili ? "bg-success bg-opacity-10" : "bg-warning bg-opacity-10")">
                <strong>
                    @if (_sonuc.TamBasarili) { <i class="bi bi-check-circle me-1 text-success"></i> }
                    else { <i class="bi bi-exclamation-triangle me-1 text-warning"></i> }
                    Rebuild Tamamlandı
                </strong>
            </div>
            <div class="card-body py-2">
                <div class="row g-2 small">
                    <div class="col-3"><strong>@_sonuc.ToplamHakedis</strong> hakediş</div>
                    <div class="col-3 text-success"><strong>@_sonuc.BasariliIslem</strong> başarılı</div>
                    <div class="col-3 text-warning"><strong>@_sonuc.AtlananIslem</strong> atlandı</div>
                    <div class="col-3 text-danger"><strong>@_sonuc.Hata</strong> hata</div>
                </div>
                @if (_sonuc.Hatalar.Any())
                {
                    <div class="mt-2">
                        <small class="fw-bold text-danger">Hatalar:</small>
                        <ul class="small text-danger mb-0">
                            @foreach (var h in _sonuc.Hatalar)
                            {
                                <li>@h</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    }
</div>

