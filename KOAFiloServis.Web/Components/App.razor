@using KOAFiloServis.Web.Services
@inject LicenseService LicenseService
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <!-- iOS ve Android icin PWA/mobile ayarlar -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#1e3c72" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <!-- Leaflet.js Harita Kütüphanesi -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["KOAFiloServis.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script>(function(){var t=localStorage.getItem('crm-theme')||'light';document.documentElement.setAttribute('data-theme',t);})()</script>
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <KOAFiloServis.Web.Components.Shared.AppRouteTracker />
    @* 🔥 PART 5: Router-level license gate — Singleton cache ile root seviyede karar *@
    @if (LicenseService.HasValidLicense())
    {
        <KOAFiloServis.Web.Components.Shared.AppErrorBoundary>
            <ChildContent>
                <Routes @rendermode="InteractiveServer" />
            </ChildContent>
        </KOAFiloServis.Web.Components.Shared.AppErrorBoundary>
    }
    else
    {
        <KOAFiloServis.Web.Components.Pages.LicenseBlock />
    }
    <ReconnectModal />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="js/dashboard.js"></script>
    <script src="js/file-interop.js"></script>
    <script src="js/app.js"></script>
    <script>
        // Fallback: file-interop.js yüklenemezse veya cache nedeniyle eski shell sunulursa
        // downloadFile vb. fonksiyonların window scope'unda mutlaka bulunmasını garanti eder.
        (function () {
            function _b64ToBytes(b64) {
                var clean = String(b64).replace(/[\r\n\s]/g, '');
                var pad = clean.length % 4;
                if (pad === 2) clean += '==';
                else if (pad === 3) clean += '=';
                else if (pad === 1) throw new Error('Gecersiz base64 uzunlugu');
                var bin = atob(clean);
                var arr = new Uint8Array(bin.length);
                for (var i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
                return arr;
            }
            if (typeof window.downloadFile !== 'function') {
                window.downloadFile = function (filename, base64Content, contentType) {
                    try {
                        var byteNumbers = _b64ToBytes(base64Content);
                        var blob = new Blob([byteNumbers], { type: contentType || 'application/octet-stream' });
                        var url = URL.createObjectURL(blob);
                        var link = document.createElement('a');
                        link.href = url;
                        link.download = filename;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        setTimeout(function () { URL.revokeObjectURL(url); }, 10000);
                    } catch (e) {
                        console.error('downloadFile fallback hatası:', e);
                        throw e;
                    }
                };
            }
            if (typeof window.downloadFileFromBase64 !== 'function') {
                window.downloadFileFromBase64 = function (filename, base64Content) {
                    return window.downloadFile(filename, base64Content, 'application/octet-stream');
                };
            }
            if (typeof window.downloadFileFromStream !== 'function') {
                window.downloadFileFromStream = function (filename, base64Content) {
                    return window.downloadFile(filename, base64Content, 'application/octet-stream');
                };
            }
            if (typeof window.downloadFileFromBytes !== 'function') {
                window.downloadFileFromBytes = function (filename, contentType, bytes) {
                    try {
                        var byteArray;
                        if (typeof bytes === 'string') {
                            byteArray = _b64ToBytes(bytes);
                        } else if (bytes instanceof Uint8Array) {
                            byteArray = bytes;
                        } else if (Array.isArray(bytes)) {
                            byteArray = new Uint8Array(bytes);
                        } else if (bytes && Array.isArray(bytes.data)) {
                            byteArray = new Uint8Array(bytes.data);
                        } else {
                            throw new Error('Gecersiz byte dizisi');
                        }
                        var blob = new Blob([byteArray], { type: contentType || 'application/octet-stream' });
                        var url = URL.createObjectURL(blob);
                        var link = document.createElement('a');
                        link.href = url;
                        link.download = filename;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        setTimeout(function () { URL.revokeObjectURL(url); }, 10000);
                    } catch (e) {
                        console.error('downloadFileFromBytes fallback hatası:', e);
                        throw e;
                    }
                };
            }
        })();
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="js/dashboard-charts.js"></script>
    <script src="js/karlilik-charts.js"></script>
    <script src="js/filo-kpi-charts.js"></script>
    <!-- Leaflet.js Harita Kütüphanesi -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="js/leaflet-interop.js"></script>
    <!-- SignalR Client Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="js/signalr-interop.js"></script>
    <!-- Bootstrap JS for dropdowns -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
