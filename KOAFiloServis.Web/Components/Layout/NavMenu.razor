@code {
    private enum NavSection
    {
        Cari,
        FiloServis,
        Fatura,
        BankaKasa,
        Raporlar,
        Personel,
        Ayarlar,
        Muhasebe,
        Checklist,
        Butce,
        Satis,
        Stok,
        Ihale,
        Ebys,
        Araclar,
        TedarikciOperasyon,
        LastikTakip,
        PuantajIslemleri
    }

    private HashSet<NavSection> expandedSections = new();
    private HashSet<string> kullaniciYetkileri = new();
    private HashSet<string> kullaniciYetkiPrefixleri = new();
    private bool yetkilerYuklendi = false;
    private bool isAdmin = false;
    private bool isSuperAdmin = false;
    private readonly SemaphoreSlim yetkiYukleGate = new(1, 1);

    protected override async Task OnInitializedAsync()
    {
        // Once subscribe ol, sonra ilk yuklemeyi yap. Aksi halde yukleme sirasinda
        // gerceklesen AuthenticationStateChanged olaylari kacirilir.
        AuthProvider.AuthenticationStateChanged += OnAuthStateChanged;
        await YetkileriYukle();
    }

    private void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        _ = HandleAuthStateChangedAsync();
    }

    private async Task HandleAuthStateChangedAsync()
    {
        try
        {
            await YetkileriYukle();
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            // Circuit kapanırken beklenen durum, sessizce yut
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "NavMenu auth state degisikligi islenirken hata olustu");
        }
    }

    public void Dispose()
    {
        AuthProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        yetkiYukleGate.Dispose();
    }

    private async Task YetkileriYukle()
    {
        // Es zamanli auth state degisikliklerinde koleksiyonlarda race olusmamasi icin serialize et
        await yetkiYukleGate.WaitAsync();
        try
        {
            var aktifKullanici = AuthProvider.GetAktifKullanici();
            if (aktifKullanici != null)
            {
                // Admin / SuperAdmin kontrolu
                var rolAdi = aktifKullanici.Rol?.RolAdi;
                isAdmin = rolAdi == "Admin";
                isSuperAdmin = rolAdi == "SuperAdmin" || rolAdi == "Admin";

                if (!isAdmin)
                {
                    // Kullanici yetkilerini yukle
                    var yetkiler = await KullaniciService.GetKullaniciYetkileriAsync(aktifKullanici.Id);
                    var yetkiSet = yetkiler.ToHashSet();
                    var prefixSet = yetkiSet
                        .Select(y =>
                        {
                            var idx = y.IndexOf('.');
                            return idx > 0 ? y.Substring(0, idx) : y;
                        })
                        .ToHashSet();

                    // Yeni referanslari atomik olarak ata (render sirasinda yarim doldurulmus
                    // koleksiyon gorunmesin)
                    kullaniciYetkileri = yetkiSet;
                    kullaniciYetkiPrefixleri = prefixSet;
                }
                else
                {
                    kullaniciYetkileri = new HashSet<string>();
                    kullaniciYetkiPrefixleri = new HashSet<string>();
                }

                yetkilerYuklendi = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "NavMenu kullanici yetkileri yuklenirken hata olustu");
            // Hata durumunda bos yetkiler
            kullaniciYetkileri = new HashSet<string>();
            kullaniciYetkiPrefixleri = new HashSet<string>();
        }
        finally
        {
            yetkiYukleGate.Release();
        }
    }

    private bool HasYetki(string yetkiKodu)
    {
        // Admin her seyi gorebilir
        if (isAdmin) return true;

        // Yetkiler henuz yuklenmediyse gosterme
        if (!yetkilerYuklendi) return false;

        return kullaniciYetkileri.Contains(yetkiKodu);
    }

    private bool HasAnyYetki(params string[] yetkiKodlari)
    {
        if (isAdmin) return true;
        if (!yetkilerYuklendi) return false;

        foreach (var kod in yetkiKodlari)
        {
            if (kullaniciYetkileri.Contains(kod)) return true;
        }
        return false;
    }

    private bool IsSuperAdmin() => isSuperAdmin;

    private bool HasMenuYetki(string menuKodu)
    {
        // Admin her seyi gorebilir
        if (isAdmin) return true;
        
        // Yetkiler henuz yuklenmediyse gosterme
        if (!yetkilerYuklendi) return false;

        if (kullaniciYetkileri.Contains(menuKodu)) return true;

        if (MenuRelatedYetkiler.TryGetValue(menuKodu, out var menuYetkileri))
        {
            // Kullanici yetkileri genelde menuYetkileri'nden buyuk oldugu icin kucuk seti gez
            foreach (var y in menuYetkileri)
            {
                if (kullaniciYetkileri.Contains(y)) return true;
            }
        }

        if (MenuPrefixleri.TryGetValue(menuKodu, out var menuPrefixleri))
        {
            foreach (var prefix in menuPrefixleri)
            {
                if (kullaniciYetkiPrefixleri.Contains(prefix))
                    return true;
            }
        }

        return false;
    }

    private static readonly Dictionary<string, HashSet<string>> MenuPrefixleri = new()
    {
        ["menu.crm"] = new() { "bildirim", "mesaj", "email", "hatirlatici" },
        ["menu.cari"] = new() { "cari", "cariler", "kesilenfatura", "gelenfatura" },
        ["menu.filoservis"] = new() { "arac", "araclar", "guzergah", "guzergahlar", "serviscalisma", "toplucalisma", "aracmasraf", "filo", "hakedis", "operasyonel-hakedis", "arac-maliyet-snapshot", "filo-gunluk-puantaj", "tedarikciservis", "tedarikciarac", "tedarikcipersonel", "tedarikciaracevrak" },
        ["menu.muhasebe"] = new() { "muhasebe", "hesapplani", "muhasebefis", "muhaseberapor" },
        ["menu.personel"] = new() { "personel", "maas", "izin" },
        ["menu.fatura"] = new() { "fatura", "faturalar", "faturahazirlik", "kesilenfatura", "gelenfatura" },
        ["menu.bankakasa"] = new() { "banka", "bankahesap", "bankahareket" },
        ["menu.butce"] = new() { "butce", "odemeyonetim", "tekrarlayanodem" },
        ["menu.checklist"] = new() { "checklist", "checklistmali" },
        ["menu.raporlar"] = new() { "rapor", "raporlar", "raporozmal", "raporkirala", "raporkomisyon", "raporservis", "raporfatura", "rapormasraf", "raporekstre" },
        ["menu.satis"] = new() { "satis", "piyasa", "ilan" },
        ["menu.ayarlar"] = new() { "firma", "ayarlar", "kullanici", "rol", "veritabani", "sistemdurumu", "aktivitelog", "yedekleme", "guncelleme", "destektalebi", "piyasakaynak", "masrafkalem" },
        ["menu.ebys"] = new() { "ebys", "evrak", "belgeuyari" },
        ["menu.stok"] = new() { "stok" },
    };

    private static readonly Dictionary<string, HashSet<string>> MenuRelatedYetkiler = new()
    {
        ["menu.filoservis"] = new() { "raporlar.oku", "serviscalisma.oku", "tedarikciservis.oku", "tedarikciarac.oku", "tedarikcipersonel.oku", "tedarikciaracevrak.oku" },
        ["menu.satis"] = new() { "satis.oku", "piyasa.oku", "raporlar.oku" },
    };

    private void ToggleSection(NavSection section)
    {
        if (!expandedSections.Add(section))
        {
            expandedSections.Remove(section);
        }
    }

    private bool IsExpanded(NavSection section) => expandedSections.Contains(section);
}


















