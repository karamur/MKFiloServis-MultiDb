@page "/kasa-banka/gelir-gider-islem"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@inject IBankaKasaHareketService HareketService
@inject IBankaHesapService BankaHesapService
@inject ICariService CariService
@inject ISoforService SoforService
@inject IAracService AracService
@inject IMuhasebeService MuhasebeService
@inject IBudgetService BudgetService
@inject IPersonelFinansService PersonelFinansService
@inject IStokService StokService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Gelir/Gider İşlem</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-lightning-charge text-warning me-2"></i>Gelir/Gider İşlem</h3>
            <small class="text-muted">Kasa, Banka veya Personel Cebinden gelir/gider kaydı</small>
        </div>
        <div class="d-flex gap-2">
            <a href="/finans/personel-odenecekler" class="btn btn-outline-info btn-sm">
                <i class="bi bi-person-check me-1"></i>Personele Ödenecekler (@personeleOdenecekSayisi)
            </a>
            <a href="/banka-hareketleri" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-list-ul me-1"></i>Tüm Hareketler
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Sol Panel - Hızlı Giriş -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header bg-primary text-white py-2">
                    <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Yeni İşlem</h6>
                </div>
                <div class="card-body">
                    <!-- İşlem Türü -->
                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">İşlem Türü</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <button type="button" class="btn w-100 @(hareket.HareketTipi == HareketTipi.Cikis ? "btn-danger" : "btn-outline-danger")"
                                        @onclick="() => hareket.HareketTipi = HareketTipi.Cikis">
                                    <i class="bi bi-arrow-up-circle me-1"></i>Gider / Masraf
                                </button>
                            </div>
                            <div class="col-6">
                                <button type="button" class="btn w-100 @(hareket.HareketTipi == HareketTipi.Giris ? "btn-success" : "btn-outline-success")"
                                        @onclick="() => hareket.HareketTipi = HareketTipi.Giris">
                                    <i class="bi bi-arrow-down-circle me-1"></i>Gelir / Tahsilat
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Ödeme Kaynağı Seçimi -->
                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">Ödeme Kaynağı</label>
                        <div class="row g-2 mb-2">
                            <div class="col-4">
                                <button type="button" 
                                        class="btn btn-sm w-100 @(odemeKaynagi == OdemeKaynakTipi.Kasa ? "btn-warning" : "btn-outline-warning")"
                                        @onclick="() => OdemeKaynagiSec(OdemeKaynakTipi.Kasa)">
                                    <i class="bi bi-cash-coin me-1"></i>Kasa
                                </button>
                            </div>
                            <div class="col-4">
                                <button type="button" 
                                        class="btn btn-sm w-100 @(odemeKaynagi == OdemeKaynakTipi.Banka ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => OdemeKaynagiSec(OdemeKaynakTipi.Banka)">
                                    <i class="bi bi-bank me-1"></i>Banka
                                </button>
                            </div>
                            <div class="col-4">
                                <button type="button" 
                                        class="btn btn-sm w-100 @(odemeKaynagi == OdemeKaynakTipi.PersonelCebinden ? "btn-info" : "btn-outline-info")"
                                        @onclick="() => OdemeKaynagiSec(OdemeKaynakTipi.PersonelCebinden)">
                                    <i class="bi bi-person-badge me-1"></i>Personel Cebinden
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Kasa/Banka Hesap Seçimi -->
                    @if (odemeKaynagi != OdemeKaynakTipi.PersonelCebinden)
                    {
                        <div class="mb-3">
                            <label class="form-label small text-muted mb-1">Hesap Seçimi</label>
                            <div class="row g-2 mb-2">
                                @foreach (var hesap in filtreliHesaplar.Take(4))
                                {
                                    <div class="col-6">
                                        <button type="button" 
                                                class="btn btn-sm w-100 @(hareket.BankaHesapId == hesap.Id ? "btn-dark" : "btn-outline-dark")"
                                                @onclick="() => HesapSec(hesap)">
                                            <i class="bi @GetHesapIcon(hesap.HesapTipi) me-1"></i>
                                            <small>@TruncateText(hesap.HesapAdi, 12)</small>
                                        </button>
                                    </div>
                                }
                            </div>
                            @if (filtreliHesaplar.Count > 4)
                            {
                                <select class="form-select form-select-sm" @bind="hareket.BankaHesapId">
                                    <option value="0">Diğer hesaplar...</option>
                                    @foreach (var hesap in filtreliHesaplar.Skip(4))
                                    {
                                        <option value="@hesap.Id">@hesap.HesapAdi (@hesap.BankaAdi)</option>
                                    }
                                </select>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Personel Seçimi -->
                        <div class="mb-3">
                            <label class="form-label small text-muted mb-1">Harcamayı Yapan Personel *</label>
                            <select class="form-select" @bind="hareket.PersonelCebindenId">
                                <option value="">Personel Seçiniz...</option>
                                @foreach (var p in personeller.Where(x => x.Aktif))
                                {
                                    <option value="@p.Id">@p.TamAd (@p.SoforKodu)</option>
                                }
                            </select>
                            <small class="text-info">
                                <i class="bi bi-info-circle me-1"></i>
                                Bu tutar personele geri ödenecekler listesine eklenecektir.
                            </small>
                        </div>
                        <!-- Araç (Opsiyonel) -->
                        <div class="mb-3">
                            <label class="form-label small text-muted mb-1">Araç (Plaka) <span class="text-muted">(opsiyonel)</span></label>
                            <select class="form-select" @bind="hareket.AracId">
                                <option value="">-- Araç Seçiniz --</option>
                                @foreach (var a in araclar)
                                {
                                    <option value="@a.Id">@a.AktifPlaka — @a.Marka @a.Model</option>
                                }
                            </select>
                            <small class="text-muted">
                                <i class="bi bi-truck me-1"></i>
                                Araç masrafı ise plaka seçin; bakım-onarım kayıtlarında listelenecektir.
                            </small>
                        </div>
                    }

                    <!-- Tutar ve Tarih -->
                    <div class="row g-2 mb-3">
                        <div class="col-7">
                            <label class="form-label small text-muted mb-1">Tutar *</label>
                            <div class="input-group">
                                <input type="number" class="form-control form-control-lg" @bind="hareket.Tutar" step="0.01" min="0" placeholder="0,00" />
                                <span class="input-group-text">₺</span>
                            </div>
                        </div>
                        <div class="col-5">
                            <label class="form-label small text-muted mb-1">Tarih</label>
                            <input type="date" class="form-control" @bind="hareket.IslemTarihi" />
                        </div>
                    </div>

                    <!-- Açıklama -->
                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">Açıklama</label>
                        <input type="text" class="form-control" @bind="hareket.Aciklama" placeholder="Masraf açıklaması..." />
                    </div>

                    <!-- Stok Kart Detay -->
                    <div class="mb-2">
                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="() => stokDetayGoster = !stokDetayGoster">
                            <i class="bi @(stokDetayGoster ? "bi-chevron-up" : "bi-boxes") me-1"></i>
                            @(stokDetayGoster ? "Stok Kalemlerini Gizle" : "Stok Kalemleri Ekle")
                            @if (masrafKalemleri.Any())
                            {
                                <span class="badge bg-primary ms-1">@masrafKalemleri.Count kalem</span>
                            }
                        </button>
                    </div>

                    @if (stokDetayGoster)
                    {
                        <div class="border rounded p-2 mb-3 bg-light">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="fw-bold text-muted"><i class="bi bi-boxes me-1"></i>Stok Kalemleri</small>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="KalemEkle">
                                    <i class="bi bi-plus"></i> Kalem Ekle
                                </button>
                            </div>
                            @if (!masrafKalemleri.Any())
                            {
                                <div class="text-center text-muted py-2">
                                    <small>Kalem eklemek için "Kalem Ekle" butonuna tıklayın</small>
                                </div>
                            }
                            @foreach (var kalem in masrafKalemleri)
                            {
                                <div class="row g-1 mb-1 align-items-center">
                                    <div class="col-5">
                                        <select class="form-select form-select-sm" @bind="kalem.StokKartiId">
                                            <option value="0">Stok seçin...</option>
                                            @foreach (var stok in stokKartlari)
                                            {
                                                <option value="@stok.Id">@stok.StokAdi</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-2">
                                        <input type="number" class="form-control form-control-sm" @bind="kalem.Miktar"
                                               step="0.01" min="0.01" placeholder="Miktar"
                                               @oninput="() => ToplamHesapla()" />
                                    </div>
                                    <div class="col-2">
                                        <input type="number" class="form-control form-control-sm" @bind="kalem.BirimFiyat"
                                               step="0.01" min="0" placeholder="B.Fiyat"
                                               @oninput="() => ToplamHesapla()" />
                                    </div>
                                    <div class="col-2">
                                        <input type="text" class="form-control form-control-sm" @bind="kalem.Aciklama" placeholder="Not" />
                                    </div>
                                    <div class="col-1">
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => KalemSil(kalem)">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                            @if (masrafKalemleri.Any())
                            {
                                <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                    <small class="text-muted">Kalem Toplamı: <strong>@FormatPara(masrafKalemleri.Sum(k => k.Miktar * k.BirimFiyat))</strong></small>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToplamTutaraAktar">
                                        <i class="bi bi-arrow-up-circle me-1"></i>Tutara Aktar
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    <!-- Opsiyonel Alanlar -->
                    <div class="mb-3">
                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="() => detayGoster = !detayGoster">
                            <i class="bi @(detayGoster ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>
                            @(detayGoster ? "Detayları Gizle" : "Daha Fazla Seçenek")
                        </button>
                    </div>

                    @if (detayGoster)
                    {
                        <div class="border rounded p-2 mb-3 bg-light">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label small text-muted mb-1">Cari (Opsiyonel)</label>
                                    <select class="form-select form-select-sm" @bind="hareket.CariId">
                                        <option value="">Seçilmedi</option>
                                        @foreach (var cari in cariler.Take(50))
                                        {
                                            <option value="@cari.Id">@cari.Unvan</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted mb-1">Belge No</label>
                                    <input type="text" class="form-control form-select-sm" @bind="hareket.BelgeNo" placeholder="Fiş, fatura no" />
                                </div>
                            </div>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="muhasebeFisi" @bind="muhasebeFisiOlustur" />
                                <label class="form-check-label small" for="muhasebeFisi">
                                    Muhasebe fişi oluştur
                                </label>
                            </div>
                        </div>
                    }

                    <!-- Kaydet Butonu -->
                    <div class="d-grid">
                        <button class="btn btn-lg @GetKaydetButtonClass()" 
                                @onclick="KaydetAsync" disabled="@(!CanSave())">
                            @if (isKaydediliyor)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-check-lg me-1"></i>
                            @GetKaydetButtonText()
                        </button>
                    </div>
                </div>
            </div>

            <!-- Bütçe ve Personel Ödenecek Bağlantıları -->
            <div class="card mt-3">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small"><i class="bi bi-link-45deg me-1"></i>Planlı ödeme mi?</span>
                        <a href="/butce" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-wallet2 me-1"></i>Bütçe Yönetimi
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ Panel - Son İşlemler + Personele Ödenecekler -->
        <div class="col-lg-7">
            <!-- Personele Ödenecekler Özet -->
            @if (personeleOdenecekler.Any())
            {
                <div class="card mb-3 border-info">
                    <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-person-check me-2"></i>Personele Ödenecekler</h6>
                        <a href="/finans/personel-odenecekler" class="btn btn-sm btn-light">
                            Tümünü Gör (@personeleOdenecekler.Count)
                        </a>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var item in personeleOdenecekler.Take(5))
                            {
                                <div class="list-group-item py-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>@item.PersonelCebinden?.TamAd</strong>
                                            <small class="text-muted d-block">@item.IslemTarihi.ToString("dd.MM.yy") - @TruncateText(item.Aciklama, 30)</small>
                                        </div>
                                        <div class="text-end">
                                             <span class="badge bg-warning text-dark">@FormatPara(item.Tutar)</span>
                                             <button class="btn btn-sm btn-success ms-1" @onclick="() => PersoneleOdeAsync(item)" title="Ödendi İşaretle">
                                                 <i class="bi bi-check2"></i>
                                             </button>
                                             <button class="btn btn-sm btn-outline-primary ms-1" @onclick="() => HareketDuzenleAc(item)" title="Düzenle">
                                                 <i class="bi bi-pencil"></i>
                                             </button>
                                             <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => SilAsync(item)" title="Sil">
                                                 <i class="bi bi-trash"></i>
                                             </button>
                                         </div>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (personeleOdenecekler.Any())
                        {
                            <div class="card-footer bg-warning-subtle py-2">
                                <div class="d-flex justify-content-between">
                                    <span><strong>Toplam Ödenecek:</strong></span>
                                    <strong class="text-danger">@FormatPara(personeleOdenecekler.Sum(x => x.Tutar))</strong>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Son İşlemler -->
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Son İşlemler</h6>
                    <select class="form-select form-select-sm" style="width: 150px;" @bind="filtreHesapId" @bind:after="FiltreleAsync">
                        <option value="0">Tüm Hesaplar</option>
                        @foreach (var hesap in tumHesaplar)
                        {
                            <option value="@hesap.Id">@hesap.HesapAdi</option>
                        }
                    </select>
                </div>
                <div class="card-body p-0">
                    @if (sonHareketler == null || !sonHareketler.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-2">Henüz işlem bulunmuyor</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                            @foreach (var h in sonHareketler)
                            {
                                <div class="list-group-item list-group-item-action py-2">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge @(h.HareketTipi == HareketTipi.Giris ? "bg-success" : "bg-danger")">
                                                    <i class="bi @(h.HareketTipi == HareketTipi.Giris ? "bi-arrow-down" : "bi-arrow-up")"></i>
                                                </span>
                                                <strong class="@(h.HareketTipi == HareketTipi.Giris ? "text-success" : "text-danger")">
                                                    @(h.HareketTipi == HareketTipi.Giris ? "+" : "-")@FormatPara(h.Tutar)
                                                </strong>
                                                <small class="text-muted">@h.IslemTarihi.ToString("dd.MM.yy")</small>
                                                @if (h.IsPersonelCebinden)
                                                {
                                                    <span class="badge bg-info" title="Personel Cebinden">
                                                        <i class="bi bi-person"></i> @h.PersonelCebinden?.TamAd
                                                    </span>
                                                    @if (!h.PersoneleOdendi)
                                                    {
                                                        <span class="badge bg-warning text-dark">Ödenmedi</span>
                                                    }
                                                }
                                            </div>
                                            <small class="text-muted d-block">
                                                @(h.IsPersonelCebinden ? "Personel Cebinden" : h.BankaHesap?.HesapAdi) - @TruncateText(h.Aciklama, 35)
                                            </small>
                                        </div>
                                        @if (h.IslemKaynak == IslemKaynak.Manuel || h.IslemKaynak == IslemKaynak.PersonelCebinden)
                                        {
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => HareketDuzenleAc(h)" title="Düzenle">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => SilAsync(h)" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary" title="@GetKaynakAciklama(h.IslemKaynak)">@GetKaynakKisaAd(h.IslemKaynak)</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hareket Düzenleme Modal -->
@if (duzenleModalGoster && duzenleHareket != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Hareketi Düzenle</h5>
                    <button type="button" class="btn-close" @onclick="() => duzenleModalGoster = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small text-muted">Tutar *</label>
                        <div class="input-group">
                            <input type="number" class="form-control" @bind="duzenleHareket.Tutar" step="0.01" min="0.01" />
                            <span class="input-group-text">₺</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Tarih</label>
                        <input type="date" class="form-control" @bind="duzenleHareket.IslemTarihi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Açıklama</label>
                        <input type="text" class="form-control" @bind="duzenleHareket.Aciklama" placeholder="Açıklama..." />
                    </div>
                    @if (duzenleHareket.PersonelCebindenId.HasValue)
                    {
                        <div class="mb-3">
                            <label class="form-label small text-muted">Personel</label>
                            <select class="form-select" @bind="duzenleHareket.PersonelCebindenId">
                                <option value="">Seçiniz...</option>
                                @foreach (var p in personeller.Where(x => x.Aktif))
                                {
                                    <option value="@p.Id">@p.TamAd (@p.SoforKodu)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Araç (Plaka) <span class="text-muted">(opsiyonel)</span></label>
                            <select class="form-select" @bind="duzenleHareket.AracId">
                                <option value="">-- Araç Seçiniz --</option>
                                @foreach (var a in araclar)
                                {
                                    <option value="@a.Id">@a.AktifPlaka — @a.Marka @a.Model</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => duzenleModalGoster = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="HareketGuncelleAsync">
                        @if (isDuzenleniyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private BankaKasaHareket hareket = new()
    {
        IslemTarihi = DateTime.Today,
        HareketTipi = HareketTipi.Cikis
    };

    private List<BankaHesap> tumHesaplar = new();
    private List<BankaHesap> filtreliHesaplar = new();
    private List<Cari> cariler = new();
    private List<Sofor> personeller = new();
    private List<BankaKasaHareket> sonHareketler = new();
    private List<BankaKasaHareket> personeleOdenecekler = new();
    private List<StokKarti> stokKartlari = new();
    private List<MasrafKalem> masrafKalemleri = new();
    private List<Arac> araclar = new();

    private int filtreHesapId = 0;
    private bool muhasebeFisiOlustur = false;
    private bool isKaydediliyor = false;
    private bool isDuzenleniyor = false;
    private bool detayGoster = false;
    private bool stokDetayGoster = false;
    private bool duzenleModalGoster = false;
    private BankaKasaHareket? duzenleHareket = null;
    private OdemeKaynakTipi odemeKaynagi = OdemeKaynakTipi.Kasa;
    private int personeleOdenecekSayisi = 0;

    private enum OdemeKaynakTipi { Kasa, Banka, PersonelCebinden }

    private class MasrafKalem
    {
        public int StokKartiId { get; set; }
        public decimal Miktar { get; set; } = 1;
        public decimal BirimFiyat { get; set; }
        public string? Aciklama { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        tumHesaplar = (await BankaHesapService.GetAllAsync()).Where(h => h.Aktif).ToList();
        cariler = await CariService.GetAllAsync();
        personeller = await SoforService.GetAllAsync();
        araclar = (await AracService.GetActiveAsync()).OrderBy(a => a.AktifPlaka).ToList();
        stokKartlari = await StokService.GetStokKartlariAsync(aktif: true);

        await FiltreleHesaplariAsync();
        await FiltreleAsync();
        await LoadPersoneleOdeneceklerAsync();

        // Varsayılan kasa hesabı
        var kasaHesap = filtreliHesaplar.FirstOrDefault(h => h.HesapTipi == HesapTipi.Kasa);
        if (kasaHesap != null)
        {
            hareket.BankaHesapId = kasaHesap.Id;
        }
    }

    private async Task FiltreleHesaplariAsync()
    {
        filtreliHesaplar = odemeKaynagi switch
        {
            OdemeKaynakTipi.Kasa => tumHesaplar.Where(h => h.HesapTipi == HesapTipi.Kasa).ToList(),
            OdemeKaynakTipi.Banka => tumHesaplar.Where(h => h.HesapTipi == HesapTipi.VadesizHesap || h.HesapTipi == HesapTipi.KrediKarti).ToList(),
            _ => tumHesaplar.ToList()
        };

        if (!filtreliHesaplar.Any(h => h.Id == hareket.BankaHesapId))
        {
            hareket.BankaHesapId = filtreliHesaplar.FirstOrDefault()?.Id ?? 0;
        }
    }

    private async Task OdemeKaynagiSec(OdemeKaynakTipi kaynak)
    {
        odemeKaynagi = kaynak;

        if (kaynak == OdemeKaynakTipi.PersonelCebinden)
        {
            hareket.BankaHesapId = 0;
            hareket.PersonelCebindenId = null;
        }
        else
        {
            hareket.PersonelCebindenId = null;
            await FiltreleHesaplariAsync();
        }
    }

    private void HesapSec(BankaHesap hesap)
    {
        hareket.BankaHesapId = hesap.Id;
    }

    private async Task LoadPersoneleOdeneceklerAsync()
    {
        var tumHareketler = await HareketService.GetAllAsync();
        personeleOdenecekler = tumHareketler
            .Where(h => h.PersonelCebindenId.HasValue && !h.PersoneleOdendi)
            .OrderByDescending(h => h.IslemTarihi)
            .ToList();
        personeleOdenecekSayisi = personeleOdenecekler.Count;
    }

    private async Task FiltreleAsync()
    {
        sonHareketler = await HareketService.GetAllAsync();

        if (filtreHesapId > 0)
        {
            sonHareketler = sonHareketler.Where(h => h.BankaHesapId == filtreHesapId).ToList();
        }

        sonHareketler = sonHareketler
            .OrderByDescending(h => h.IslemTarihi)
            .ThenByDescending(h => h.CreatedAt)
            .Take(30)
            .ToList();
    }

    private bool CanSave()
    {
        if (isKaydediliyor) return false;
        if (hareket.Tutar <= 0) return false;

        if (odemeKaynagi == OdemeKaynakTipi.PersonelCebinden)
        {
            return hareket.PersonelCebindenId.HasValue;
        }
        else
        {
            return hareket.BankaHesapId > 0;
        }
    }

    private async Task KaydetAsync()
    {
        if (!CanSave()) return;

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            hareket.IslemNo = await HareketService.GenerateNextIslemNoAsync();

            if (odemeKaynagi == OdemeKaynakTipi.PersonelCebinden)
            {
                hareket.IslemKaynak = IslemKaynak.PersonelCebinden;
                hareket.PersoneleOdendi = false;
                // Personel cebinden için geçici bir hesap ata (sistem kasası)
                var sistemKasa = tumHesaplar.FirstOrDefault(h => h.HesapTipi == HesapTipi.Kasa);
                hareket.BankaHesapId = sistemKasa?.Id ?? tumHesaplar.First().Id;
            }
            else
            {
                hareket.IslemKaynak = IslemKaynak.Manuel;
            }

            await HareketService.CreateAsync(hareket);

            // Stok hareketleri oluştur
            foreach (var kalem in masrafKalemleri.Where(k => k.StokKartiId > 0 && k.Miktar > 0))
            {
                try
                {
                    await StokService.CreateStokHareketAsync(new StokHareket
                    {
                        StokKartiId = kalem.StokKartiId,
                        IslemTarihi = hareket.IslemTarihi,
                        HareketTipi = StokHareketTipi.Cikis,
                        Miktar = kalem.Miktar,
                        BirimFiyat = kalem.BirimFiyat,
                        BelgeNo = hareket.BelgeNo,
                        Aciklama = kalem.Aciklama ?? hareket.Aciklama
                    });
                }
                catch { /* Stok hatası ana işlemi engellemez */ }
            }

            if (muhasebeFisiOlustur)
            {
                await OlusturMuhasebeFisiAsync();
            }

            var islemTipi = hareket.HareketTipi == HareketTipi.Cikis ? "Masraf" : "Gelir";
            var kaynakMetni = odemeKaynagi == OdemeKaynakTipi.PersonelCebinden 
                ? " (Personel cebinden - personel borclarına eklendi)" 
                : "";
            ToastService.ShowSuccess($"{islemTipi} kaydedildi: {FormatPara(hareket.Tutar)}{kaynakMetni}");

            // Formu sıfırla
            var eskiHesapId = hareket.BankaHesapId;
            var eskiKaynak = odemeKaynagi;
            hareket = new BankaKasaHareket
            {
                IslemTarihi = DateTime.Today,
                HareketTipi = HareketTipi.Cikis,
                BankaHesapId = eskiKaynak != OdemeKaynakTipi.PersonelCebinden ? eskiHesapId : 0
            };
            masrafKalemleri.Clear();

            await FiltreleAsync();
            await LoadPersoneleOdeneceklerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

    private async Task PersoneleOdeAsync(BankaKasaHareket item)
    {
        var result = await JS.InvokeAsync<bool>("confirm", 
            $"{item.PersonelCebinden?.TamAd} kişisine {FormatPara(item.Tutar)} tutarı ödendi olarak işaretlensin mi?");
        if (!result) return;

        try
        {
            item.PersoneleOdendi = true;
            item.PersonelOdemeTarihi = DateTime.Today;
            await HareketService.UpdateAsync(item);

            ToastService.ShowSuccess($"Ödeme kaydedildi: {item.PersonelCebinden?.TamAd} - {FormatPara(item.Tutar)}");
            await LoadPersoneleOdeneceklerAsync();
            await FiltreleAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task OlusturMuhasebeFisiAsync()
    {
        try
        {
            var hesap = tumHesaplar.FirstOrDefault(h => h.Id == hareket.BankaHesapId);
            if (hesap == null) return;

            var fisTipi = hareket.HareketTipi == HareketTipi.Cikis ? FisTipi.Tediye : FisTipi.Tahsilat;
            var fisNo = await MuhasebeService.GenerateNextFisNoAsync(fisTipi);

            var fis = new MuhasebeFis
            {
                FisNo = fisNo,
                FisTarihi = hareket.IslemTarihi,
                FisTipi = fisTipi,
                Aciklama = hareket.Aciklama ?? $"{hesap.HesapAdi} - {(hareket.HareketTipi == HareketTipi.Cikis ? "Ödeme" : "Tahsilat")}",
                ToplamBorc = hareket.Tutar,
                ToplamAlacak = hareket.Tutar,
                Durum = FisDurum.Taslak,
                Kaynak = FisKaynak.BankaHareket
            };

            await MuhasebeService.CreateFisAsync(fis);
        }
        catch { }
    }

    private void HareketDuzenleAc(BankaKasaHareket h)
    {
        duzenleHareket = new BankaKasaHareket
        {
            Id = h.Id,
            IslemNo = h.IslemNo,
            BelgeNo = h.BelgeNo,
            Tutar = h.Tutar,
            IslemTarihi = h.IslemTarihi,
            Aciklama = h.Aciklama,
            PersonelCebindenId = h.PersonelCebindenId,
            HareketTipi = h.HareketTipi,
            BankaHesapId = h.BankaHesapId,
            IslemKaynak = h.IslemKaynak,
            CariId = h.CariId,
            AracId = h.AracId,
            MuhasebeFisId = h.MuhasebeFisId,
            PersoneleOdendi = h.PersoneleOdendi,
            PersonelOdemeTarihi = h.PersonelOdemeTarihi
        };
        duzenleModalGoster = true;
    }

    private async Task HareketGuncelleAsync()
    {
        if (duzenleHareket == null || duzenleHareket.Tutar <= 0) return;
        isDuzenleniyor = true;
        try
        {
            await HareketService.UpdateAsync(duzenleHareket);
            ToastService.ShowSuccess("Hareket güncellendi.");
            duzenleModalGoster = false;
            await FiltreleAsync();
            await LoadPersoneleOdeneceklerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isDuzenleniyor = false;
        }
    }

    private async Task SilAsync(BankaKasaHareket h)
    {
        var result = await JS.InvokeAsync<bool>("confirm", "Bu işlemi silmek istediğinizden emin misiniz?");
        if (!result) return;

        try
        {
            await HareketService.DeleteAsync(h.Id);
            ToastService.ShowSuccess("İşlem silindi.");
            await FiltreleAsync();
            await LoadPersoneleOdeneceklerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private string GetHesapIcon(HesapTipi tip) => tip switch
    {
        HesapTipi.Kasa => "bi-cash-coin",
        HesapTipi.VadesizHesap => "bi-bank",
        HesapTipi.KrediKarti => "bi-credit-card",
        _ => "bi-wallet"
    };

    private string GetKaydetButtonClass() => odemeKaynagi switch
    {
        OdemeKaynakTipi.PersonelCebinden => "btn-info",
        _ => hareket.HareketTipi == HareketTipi.Cikis ? "btn-danger" : "btn-success"
    };

    private string GetKaydetButtonText()
    {
        var tip = hareket.HareketTipi == HareketTipi.Cikis ? "Masraf" : "Gelir";
        return odemeKaynagi == OdemeKaynakTipi.PersonelCebinden 
            ? $"{tip} Kaydet (Personele Ödenecek)" 
            : $"{tip} Kaydet";
    }

    private string FormatPara(decimal tutar) => tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " ₺";
    private string TruncateText(string? text, int maxLength) => 
        string.IsNullOrEmpty(text) ? "" : text.Length > maxLength ? text[..maxLength] + "..." : text;

    private string GetKaynakKisaAd(IslemKaynak kaynak) => kaynak switch
    {
        IslemKaynak.Manuel => "M",
        IslemKaynak.FaturaOdeme => "FÖ",
        IslemKaynak.FaturaTahsilat => "FT",
        IslemKaynak.Butce => "B",
        IslemKaynak.Mahsup => "MH",
        IslemKaynak.PersonelCebinden => "PC",
        _ => "?"
    };

    private string GetKaynakAciklama(IslemKaynak kaynak) => kaynak switch
    {
        IslemKaynak.Manuel => "Manuel giriş",
        IslemKaynak.FaturaOdeme => "Fatura ödemesi",
        IslemKaynak.FaturaTahsilat => "Fatura tahsilatı",
        IslemKaynak.Butce => "Bütçe modülünden",
        IslemKaynak.Mahsup => "Mahsup işlemi",
        IslemKaynak.PersonelCebinden => "Personel cebinden harcama",
        _ => "Diğer"
    };

    private void KalemEkle() => masrafKalemleri.Add(new MasrafKalem());
    private void KalemSil(MasrafKalem kalem) => masrafKalemleri.Remove(kalem);
    private void ToplamHesapla() { } // StateHasChanged tetiklenir
    private void ToplamTutaraAktar()
    {
        if (masrafKalemleri.Any())
            hareket.Tutar = masrafKalemleri.Sum(k => k.Miktar * k.BirimFiyat);
    }
}

