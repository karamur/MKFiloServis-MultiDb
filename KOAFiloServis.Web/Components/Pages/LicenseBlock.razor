@page "/license-block"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject KOAFiloServis.Web.Services.LicenseService LicenseService
@inject NavigationManager Nav

<PageTitle>Lisans Gerekli</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="text-center" style="max-width:500px;">
        <div class="mb-4">
            <i class="bi bi-shield-lock text-danger" style="font-size:4rem;"></i>
        </div>

        @if (_isDemoExpired)
        {
            <h3 class="text-danger mb-3">Demo Suresi Doldu</h3>
            <p class="text-muted mb-4">
                Bu yazilimin deneme suresi sona ermistir.<br />
                Lisans alarak kullanmaya devam edebilirsiniz.
            </p>
        }
        else
        {
            <h3 class="text-danger mb-3">Lisans Gerekli</h3>
            <p class="text-muted mb-4">
                Sistemi kullanmak icin gecerli bir lisans dosyasi yuklenmelidir.<br />
                Lutfen sistem yoneticiniz veya yazilim saglayiciniz ile iletisime geciniz.
            </p>
        }

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert alert-warning py-2 small mb-3">@_message</div>
        }

        <div class="card">
            <div class="card-body">
                <h6>Lisans Dosyasi Yukle</h6>
                <InputFile OnChange="OnLicenseFileSelected" class="form-control form-control-sm mb-2"
                           accept=".json,.txt" />
                @if (_uploadError != null)
                {
                    <div class="alert alert-danger py-1 small mb-2">@_uploadError</div>
                }
                <button class="btn btn-primary btn-sm w-100" @onclick="LisansYukle" disabled="@(_licenseJson == null)">
                    <i class="bi bi-upload me-1"></i> Lisans Yukle
                </button>
            </div>
        </div>

        <div class="mt-3">
            <a href="/" class="btn btn-outline-secondary btn-sm">Sayfayi Yenile</a>
        </div>
    </div>
</div>
