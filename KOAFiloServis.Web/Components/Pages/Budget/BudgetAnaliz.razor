    private List<TaksitBilgisi> taksitListesi = new();

    private void TaksitListesiHesapla()
    {
        taksitListesi.Clear();

        if (taksitRequest.TaksitSayisi <= 1 || taksitRequest.ToplamTutar <= 0)
            return;

        var ilkOdemeTarihi = taksitRequest.BaslangicTarihi;
        var taksitTutari = Math.Round(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi, 2);

        for (int i = 0; i < taksitRequest.TaksitSayisi; i++)
        {
            taksitListesi.Add(new TaksitBilgisi
            {
                Sira = i + 1,
                Tarih = ilkOdemeTarihi.AddMonths(i),
                Tutar = taksitTutari
            });
        }

        // Son taksitte yuvarlama farkini duzelt (toplam tam tutsin)
        var fark = taksitRequest.ToplamTutar - taksitListesi.Sum(t => t.Tutar);
        if (fark != 0 && taksitListesi.Any())
        {
            taksitListesi.Last().Tutar += fark;
        }
    }

    private void TaksitListesiSifirla()
    {
        taksitListesi.Clear();
        TaksitListesiHesapla();
        StateHasChanged();
    }

    private void TaksitTarihDegistir(TaksitBilgisi taksit, ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var yeniTarih))
        {
            taksit.Tarih = yeniTarih;
            StateHasChanged();
        }
    }

    private void TaksitTutarDegistir(TaksitBilgisi taksit, ChangeEventArgs e)
    {
        var valueStr = e.Value?.ToString() ?? "0";
        if (decimal.TryParse(valueStr, System.Globalization.NumberStyles.Any, 
            new System.Globalization.CultureInfo("tr-TR"), out var yeniTutar) && yeniTutar >= 0)
        {
            taksit.Tutar = yeniTutar;
            StateHasChanged();
        }
    }

    private bool TaksitKaydetmeGecerliMi()
    {
        if (taksitRequest.TaksitSayisi < 1 || taksitRequest.ToplamTutar <= 0)
            return false;

        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi))
            return false;

        if (!taksitListesi.Any())
            return false;

        // Fark kontrolu - 0.01 TL tolerans
        var taksitToplam = taksitListesi.Sum(t => t.Tutar);
        var fark = Math.Abs(taksitRequest.ToplamTutar - taksitToplam);
        
        return fark < 0.01m;
    }

