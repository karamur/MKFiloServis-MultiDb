<!-- Tekrarlayan Odeme Yeni/Duzenle Modal -->
@if (showTekrarlayanModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>@(editTekrarlayan.Id > 0 ? "Tekrarlayan Odeme Duzenle" : "Yeni Tekrarlayan Odeme")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                <div class="row">
                <div class="col-md-7">
                    <div class="alert alert-info py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Tekrarlayan odemeler, belirlediginiz periyotta otomatik olarak takvime eklenir.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Odeme Adi *</label>
                        <input type="text" class="form-control" @bind="editTekrarlayan.OdemeAdi" placeholder="Ornek: Ofis Kirasi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Masraf Kalemi *</label>
                        <input type="text" class="form-control" @bind="editTekrarlayan.MasrafKalemi" list="masrafListTekrar" />
                        <datalist id="masrafListTekrar">
                            @if (masrafKalemleri != null)
                            {
                                @foreach (var k in masrafKalemleri)
                                {
                                    <option value="@k.KalemAdi" />
                                }
                            }
                        </datalist>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Tutar *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editTekrarlayan.Tutar" step="0.01" />
                                    <span class="input-group-text">TL</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Odeme Gunu *</label>
                                <input type="number" class="form-control" @bind="editTekrarlayan.OdemeGunu" min="1" max="31" />
                                <small class="text-muted">Ayin kacinci gunu</small>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tekrar Periyodu *</label>
                        <select class="form-select" @bind="editTekrarlayan.Periyod">
                            <option value="@TekrarPeriyodu.Aylik">Her Ay</option>
                            <option value="@TekrarPeriyodu.IkiAylik">2 Ayda Bir</option>
                            <option value="@TekrarPeriyodu.UcAylik">3 Ayda Bir</option>
                            <option value="@TekrarPeriyodu.AltiAylik">6 Ayda Bir</option>
                            <option value="@TekrarPeriyodu.Yillik">Yillik</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Baslangic Tarihi *</label>
                                <input type="date" class="form-control" @bind="editTekrarlayan.BaslangicTarihi" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Bitis Tarihi</label>
                                <input type="date" class="form-control" @bind="editTekrarlayan.BitisTarihi" />
                                <small class="text-muted">Bos birakilirsa suresiz</small>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Firma</label>
                        <select class="form-select" @bind="editTekrarlayan.FirmaId">
                            <option value="">Firma Secin...</option>
                            @if (firmalar != null)
                            {
                                @foreach (var f in firmalar)
                                {
                                    <option value="@f.Id">@f.FirmaAdi</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Hatirlatma (gun once)</label>
                                <input type="number" class="form-control" @bind="editTekrarlayan.HatirlatmaGunSayisi" min="0" max="30" />
