    // AI Ollama Analiz
    private async Task AiAnalizBaslat()
    {
        if (!ollamaBagli) return;

        aiYukleniyor = true;
        aiSonuc = "";
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            var prompt = OlusturAiPrompt();
            aiSonuc = await OllamaService.RaporYorumlaAsync(prompt);
        }
        catch (Exception ex)
        {
            aiSonuc = $"AI analiz hatası: {ex.Message}";
        }
        finally
        {
            sw.Stop();
            aiAnalizSuresi = sw.Elapsed.TotalSeconds < 60
                ? $"{sw.Elapsed.TotalSeconds:N1} saniye"
                : $"{sw.Elapsed.TotalMinutes:N1} dakika";
            aiYukleniyor = false;
            StateHasChanged();
        }
    }

