    private async Task OdemeYap()
    {
        if (odemeYapilacak == null) return;

        // Validasyon
        if (odemeYapRequest.OdemeTipi == Services.OdemeTipi.CariMahsup)
        {
            if (!odemeYapRequest.CariId.HasValue || odemeYapRequest.CariId == 0)
            {
                ToastService.ShowWarning("Lütfen cari hesap seçin!");
                return;
            }

            if (!odemeYapRequest.BankaHesapId.HasValue || odemeYapRequest.BankaHesapId == 0)
            {
                ToastService.ShowWarning("Lütfen işlem yapılacak hesabı seçin!");
                return;
            }
        }
        else if (odemeYapRequest.OdemeTipi != Services.OdemeTipi.Mahsup && !odemeYapRequest.BankaHesapId.HasValue)
        {
            ToastService.ShowWarning("Lütfen hesap seçin!");
            return;
        }

        // Kısmi ödeme validasyonu
        if (kismiOdemeAktif)
        {
            var kalanTutar = odemeYapilacak.Miktar - odemeYapilacak.ToplamKismiOdenen;
            if (kismiOdemeTutari <= 0)
            {
                ToastService.ShowWarning("Kısmi ödeme tutarı 0'dan büyük olmalıdır!");
                return;
            }
            if (kismiOdemeTutari > kalanTutar)
            {
                ToastService.ShowWarning($"Kısmi ödeme tutarı kalan tutardan ({FormatPara(kalanTutar)}) fazla olamaz!");
                return;
            }
        }

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            var odenenId = odemeYapilacak.Id;
            string mesaj;

            if (kismiOdemeAktif)
            {
                // Kısmi ödeme işlemi
                var kismiRequest = new KismiOdemeRequest
                {
                    OdenecekTutar = kismiOdemeTutari,
                    OdemeTarihi = odemeYapRequest.OdemeTarihi,
                    BankaHesapId = odemeYapRequest.BankaHesapId,
                    OdemeTipi = odemeYapRequest.OdemeTipi,
                    Aciklama = odemeYapRequest.OdemeNotu,
                    KalanSonrakiDonemeAktarilsin = kalanSonrakiDonemeAktarilsin,
                    HedefAy = kalanSonrakiDonemeAktarilsin ? hedefAktarimAyi : null,
                    HedefYil = kalanSonrakiDonemeAktarilsin ? hedefAktarimYili : null,
                    CariId = odemeYapRequest.CariId,
                    MasrafKesintisi = odemeYapRequest.MasrafKesintisi,
                    CezaKesintisi = odemeYapRequest.CezaKesintisi,
                    DigerKesinti = odemeYapRequest.DigerKesinti,
                    KesintiAciklamasi = odemeYapRequest.KesintiAciklamasi
                };

                var sonuc = await BudgetService.KismiOdemeYapAsync(odenenId, kismiRequest);

                var kalanTutar = odemeYapilacak.Miktar - odemeYapilacak.ToplamKismiOdenen - kismiOdemeTutari;
                mesaj = $"Kısmi ödeme kaydedildi! ({FormatPara(kismiOdemeTutari)})";

                if (kalanTutar > 0)
                {
                    mesaj += $" - Kalan: {FormatPara(kalanTutar)}";
                    if (kalanSonrakiDonemeAktarilsin && sonuc.SonrakiDonemOdemeId.HasValue)
                    {
                        mesaj += " (Sonraki döneme aktarıldı)";
                    }
                }
                else
                {
                    mesaj = $"{odemeYapilacak.MasrafKalemi} tamamen ödendi! ({FormatPara(odemeYapilacak.Miktar)})";
                }
            }
            else
            {
                // Normal ödeme işlemi
                await BudgetService.OdemeYapAsync(odenenId, odemeYapRequest);

                mesaj = odemeYapRequest.OdemeTipi == Services.OdemeTipi.CariMahsup
                    ? $"{odemeYapRequest.CaridenTahsilat switch { true => "Cari mahsup tahsilat", false => "Cari mahsup ödeme" }} kaydedildi! ({FormatPara(NetOdemeTutari)})"
                    : $"{odemeYapilacak.MasrafKalemi} ödendi! ({FormatPara(NetOdemeTutari)})";
                if (ToplamEkMasraf > 0)
                    mesaj += $" - Ek Masraf: {FormatPara(ToplamEkMasraf)}";

                // Ödenen kaydı seçili gün listesinden kaldır (tam ödeme için)
                secilenGunOdemeleri.RemoveAll(o => o.Id == odenenId);
                bekleyenOdemeler.RemoveAll(o => o.Id == odenenId);
            }

            ToastService.ShowSuccess(mesaj);
            ModalKapat();

            // Hesap bakiyelerini güncelle
            hesapBakiyeleri = await BankaHesapService.GetTumHesapBakiyeleriAsync();

            // Tum veriyi yenile (gun secimi korunacak)
            await YenileDataAsync();

            // Seçili günü de güncelle (eğer gün seçiliyse)
            if (secilenGun.HasValue)
            {
                var gunData = takvimData?.FirstOrDefault(t => t.Gun == secilenGun.Value);
                secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi).ToList() ?? new List<BudgetOdeme>();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

