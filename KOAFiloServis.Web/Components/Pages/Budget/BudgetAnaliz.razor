@page "/butce"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IBudgetService BudgetService
@inject IBankaHesapService BankaHesapService
@inject ICariService CariService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject IOllamaService OllamaService
@rendermode InteractiveServer

<PageTitle>Butce Analiz</PageTitle>

<div class="container-fluid">
    <!-- Ust Bar -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            @if (secilenGun.HasValue)
            {
                <button class="btn btn-outline-secondary" @onclick="GeriDon">
                    <i class="bi bi-arrow-left me-1"></i>Geri
                </button>
                <h4 class="mb-0"><i class="bi bi-calendar-day me-2"></i>@secilenGunTarih.ToString("dd MMMM yyyy")</h4>
            }
            else
            {
                <h3 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Butce Analiz</h3>
            }
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <!-- Firma Filtresi -->
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenFirmaId" @bind:after="YenileDataAsync">
                <option value="0">Tum Firmalar</option>
                @if (firmalar != null)
                {
                    @foreach (var firma in firmalar)
                    {
                        <option value="@firma.Id">@firma.FirmaAdi</option>
                    }
                }
            </select>
            <!-- Periyod Secimi -->
            <div class="btn-group btn-group-sm">
                <button class="btn @(secilenPeriyod == "aylik" ? "btn-primary" : "btn-outline-primary")" @onclick="PeriyodAylikSec">Aylik</button>
                <button class="btn @(secilenPeriyod == "yillik" ? "btn-primary" : "btn-outline-primary")" @onclick="PeriyodYillikSec">Yillik</button>
            </div>
            <select class="form-select form-select-sm" style="width: 90px;" @bind="secilenYil" @bind:after="YenileDataAsync">
                @for (int y = DateTime.Today.Year + 2; y >= DateTime.Today.Year - 5; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 110px;" @bind="secilenAy" @bind:after="YenileDataAsync">
                <option value="0">Tum Yil</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@GetAyAdi(m)</option>
                }
            </select>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-primary" @onclick="YeniOdemeAc" title="Yeni Odeme"><i class="bi bi-plus-lg"></i></button>
                <button class="btn btn-success" @onclick="TaksitliOdemeAc" title="Taksitli Odeme"><i class="bi bi-calendar-plus"></i></button>
                <button class="btn btn-danger" @onclick="TekrarlayanOdemeListeAc" title="Tekrarlayan Odemeler"><i class="bi bi-arrow-repeat"></i></button>
                <button class="btn btn-info" @onclick="SablonIndir" title="Excel Sablon Indir"><i class="bi bi-download"></i></button>
                <button class="btn btn-warning" @onclick="ExcelYukleModalAc" title="Excel Yukle"><i class="bi bi-upload"></i></button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Ozet Kartlari -->
        <div class="row mb-3 g-2">
            <div class="col-6 col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body py-2 px-3">
                        <small>Toplam</small>
                        <h4 class="mb-0">@FormatPara(ozet?.ToplamOdeme ?? 0)</h4>
                        <small class="opacity-75">@(ozet?.ToplamKayit ?? 0) kayit</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body py-2 px-3">
                        <small>Odenen</small>
                        <h4 class="mb-0">@FormatPara(ozet?.OdenenToplam ?? 0)</h4>
                        <small class="opacity-75">@(ozet?.OdenenKayit ?? 0) kayit</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body py-2 px-3">
                        <small>Bekleyen</small>
                        <h4 class="mb-0">@FormatPara(ozet?.BekleyenToplam ?? 0)</h4>
                        <small>@(ozet?.BekleyenKayit ?? 0) kayit</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body py-2 px-3">
                        <small>Kredi/Taksit</small>
                        <h4 class="mb-0">@FormatPara(krediTaksitToplam)</h4>
                        <small class="opacity-75">@krediTaksitAdet adet</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- Sol: Takvim -->
            <div class="col-md-5">
                <!-- Takvim -->
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <h6 class="mb-0"><i class="bi bi-calendar3 me-2"></i>@GetAyAdi(aktifTakvimAy) @secilenYil</h6>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary btn-sm" @onclick="OncekiAy" disabled="@(aktifTakvimAy <= 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button class="btn btn-outline-primary btn-sm" @onclick="SonrakiAy" disabled="@(aktifTakvimAy >= 12)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-2">
                        <table class="table table-bordered table-sm mb-0" style="table-layout: fixed;">
                            <thead>
                                <tr class="text-center bg-light">
                                    <th>Pzt</th><th>Sal</th><th>Car</th><th>Per</th><th>Cum</th><th>Cmt</th><th>Paz</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var ilkGun = new DateTime(secilenYil, aktifTakvimAy, 1);
                                    var ilkGunHafta = ((int)ilkGun.DayOfWeek + 6) % 7;
                                    var gunSayisi = DateTime.DaysInMonth(secilenYil, aktifTakvimAy);
                                    var satirSayisi = (int)Math.Ceiling((ilkGunHafta + gunSayisi) / 7.0);
                                    var gun = 1;
                                }
                                @for (int satir = 0; satir < satirSayisi; satir++)
                                {
                                    <tr>
                                        @for (int sutun = 0; sutun < 7; sutun++)
                                        {
                                            var hucreIndex = satir * 7 + sutun;
                                            if (hucreIndex < ilkGunHafta || gun > gunSayisi)
                                            {
                                                <td class="bg-light"></td>
                                            }
                                            else
                                            {
                                                var currentGun = gun;
                                                var gunData = takvimData?.FirstOrDefault(t => t.Gun == currentGun);
                                                var bugun = DateTime.Today.Day == currentGun && DateTime.Today.Month == aktifTakvimAy && DateTime.Today.Year == secilenYil;
                                                var seciliMi = secilenGun == currentGun;
                                                var gunTarihi = new DateTime(secilenYil, aktifTakvimAy, currentGun);
                                                var gunRenk = GetGunVadeRenk(gunTarihi);
                                                <td class="@(seciliMi ? "bg-primary text-white" : bugun ? "bg-info bg-opacity-25" : "") p-1" 
                                                    style="height: 55px; vertical-align: top; cursor: pointer; @(gunData != null && gunData.BekleyenOdemeSayisi > 0 && !seciliMi ? $"border-left: 3px solid {gunRenk};" : "")" 
                                                    @onclick="() => GunSec(currentGun)">
                                                    <div class="d-flex justify-content-between">
                                                        <strong>@currentGun</strong>
                                                        @if (gunData != null && gunData.BekleyenOdemeSayisi > 0)
                                                        {
                                                            <span class="badge rounded-pill" style="font-size: 0.6rem; background-color: @(seciliMi ? "white" : gunRenk); color: @(seciliMi ? "#0d6efd" : "white");">@gunData.BekleyenOdemeSayisi</span>
                                                        }
                                                    </div>
                                                    @if (gunData != null && gunData.BekleyenToplamOdeme > 0)
                                                    {
                                                        <div style="font-size: 0.65rem; color: @(seciliMi ? "white" : gunRenk);">
                                                            @FormatPara(gunData.BekleyenToplamOdeme)
                                                        </div>
                                                    }
                                                </td>
                                                gun++;
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Kredi Taksit Listesi -->
                <div class="card">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-credit-card me-2"></i>Kredi/Taksitler</h6>
                        <a href="/butce/kredi-taksitler" class="btn btn-outline-info btn-sm py-0">Tümü</a>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                            @if (aktifKrediler != null && aktifKrediler.Any())
                            {
                                @foreach (var kredi in aktifKrediler)
                                {
                                    <div class="list-group-item list-group-item-action p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small><strong>@kredi.MasrafKalemi</strong></small>
                                                @if (!string.IsNullOrEmpty(kredi.Aciklama))
                                                {
                                                    <small class="text-muted d-block">@kredi.Aciklama</small>
                                                }
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-danger">@FormatPara(kredi.KalanTutar)</span>
                                                <br /><small>@kredi.KalanTaksitSayisi/@kredi.ToplamTaksitSayisi</small>
                                            </div>
                                        </div>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar bg-success" style="width: @kredi.TamamlanmaYuzdesi%"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-center text-muted py-3">
                                    <small>Aktif kredi yok</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Tekrarlayan Odemeler -->
                <div class="card mt-3">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-arrow-repeat me-2 text-danger"></i>Tekrarlayan Odemeler</h6>
                        <button class="btn btn-outline-danger btn-sm py-0" @onclick="YeniTekrarlayanOdemeAc" title="Yeni Ekle">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                            @if (tekrarlayanOdemeler != null && tekrarlayanOdemeler.Any())
                            {
                                @foreach (var plan in tekrarlayanOdemeler)
                                {
                                    <div class="list-group-item list-group-item-action p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small><i class="@(plan.Icon ?? "bi-arrow-repeat") me-1" style="color: @(plan.Renk ?? "#dc3545")"></i><strong>@plan.OdemeAdi</strong></small>
                                                <br /><small class="text-muted">Her @(GetPeriyodAdi(plan.Periyod)) - @plan.OdemeGunu. gun</small>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-danger">@FormatPara(plan.Tutar)</span>
                                                <br />
                                                <div class="btn-group btn-group-sm mt-1">
                                                    <button class="btn btn-outline-primary py-0 px-1" @onclick="() => TekrarlayanOdemeDuzenle(plan)" title="Duzenle">
                                                        <i class="bi bi-pencil" style="font-size: 0.65rem;"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger py-0 px-1" @onclick="() => TekrarlayanOdemeSilOnay(plan)" title="Sil">
                                                        <i class="bi bi-trash" style="font-size: 0.65rem;"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-center text-muted py-3">
                                    <i class="bi bi-arrow-repeat" style="font-size: 1.5rem;"></i>
                                    <p class="mb-0 mt-1"><small>Tekrarlayan odeme yok</small></p>
                                    <button class="btn btn-outline-danger btn-sm mt-1" @onclick="YeniTekrarlayanOdemeAc">
                                        <i class="bi bi-plus-lg me-1"></i>Ekle
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sag: Odeme Listesi -->
            <div class="col-md-7">
                @if (secilenGun.HasValue)
                {
                    <!-- Gun Detay -->
                    <div class="card">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center bg-primary text-white">
                            <h6 class="mb-0"><i class="bi bi-calendar-day me-2"></i>@secilenGunTarih.ToString("dd MMMM yyyy dddd")</h6>
                            <span class="badge bg-light text-primary">@FormatPara(secilenGunOdemeleri.Sum(GetBekleyenTutar))</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                                @foreach (var odeme in secilenGunOdemeleri)
                                {
                                    <div class="list-group-item p-2">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@odeme.MasrafKalemi</strong>
                                                @if (odeme.TaksitliMi)
                                                {
                                                    <span class="badge bg-info ms-1">@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                }
                                                <br /><small class="text-muted">@GetGorunenAciklama(odeme)</small>
                                            </div>
                                            <div class="text-end">
                                                <strong class="text-danger">@FormatPara(GetBekleyenTutar(odeme))</strong>
                                                <br />
                                                <span class="badge @GetDurumClass(odeme.Durum)">@GetDurumAdi(odeme.Durum)</span>
                                            </div>
                                        </div>
                                        <div class="mt-2 d-flex gap-1">
                                            @if (odeme.Durum == OdemeDurum.Bekliyor || odeme.Durum == OdemeDurum.KismiOdendi)
                                            {
                                                <button class="btn btn-success btn-sm py-0" @onclick="() => OdemeYapModalAc(odeme)">
                                                    <i class="bi bi-cash me-1"></i>Ode
                                                </button>
                                            }
                                            <button class="btn btn-outline-primary btn-sm py-0" @onclick="() => OdemeDuzenle(odeme)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm py-0" @onclick="() => OdemeSilOnay(odeme)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (!secilenGunOdemeleri.Any())
                                {
                                    <div class="list-group-item text-center text-muted py-4">
                                        <i class="bi bi-calendar-x" style="font-size: 2rem;"></i>
                                        <p class="mb-0 mt-2">Bu gunde odeme yok</p>
                                        <button class="btn btn-primary btn-sm mt-2" @onclick="YeniOdemeAc">
                                            <i class="bi bi-plus-lg me-1"></i>Odeme Ekle
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Bekleyen Odeme Listesi -->
                    <div class="card mb-3">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Bekleyen Odemeler - @GetAyAdi(aktifTakvimAy) @secilenYil</h6>
                            <div class="d-flex gap-1 align-items-center">
                                <span class="badge bg-warning text-dark me-2">@bekleyenOdemeler.Count kayit | @FormatPara(bekleyenOdemeler.Sum(GetBekleyenTutar))</span>
                                <button class="btn btn-outline-primary btn-sm py-0" @onclick='() => AylikListeOnIzleme("bekleyen")' title="On Izleme">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn btn-outline-success btn-sm py-0" @onclick='() => AylikListeYazdir("bekleyen")' title="Yazdir">
                                    <i class="bi bi-printer"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Masraf</th>
                                            <th class="text-end">Tutar</th>
                                            <th class="text-center">Taksit</th>
                                            <th class="text-center">Islem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            // ─── DİAG-RENDER: foreach öncesi render kontrolü ───
                                            if (_diagnostikSonOdemeId > 0)
                                            {
                                                var renderKaydi = bekleyenOdemeler.FirstOrDefault(x => x.Id == _diagnostikSonOdemeId);
                                                Console.WriteLine($"[DİAG-RENDER] Render anı: bekleyenOdemeler.Count={bekleyenOdemeler.Count}, Id={_diagnostikSonOdemeId} render koleksiyonunda mı? {renderKaydi != null}");
                                            }
                                        }
                                        @foreach (var odeme in bekleyenOdemeler)
                                        {
                                            var vadeRenk = GetOdemeVadeRenk(odeme);
                                            <tr style="border-left: 3px solid @vadeRenk;">
                                                <td>
                                                    <small>@odeme.OdemeTarihi.ToString("dd.MM")</small>
                                                    <br />
                                                    @{
                                                        var kalanGun = (odeme.OdemeTarihi.Date - DateTime.Today).Days;
                                                    }
                                                    <span class="badge" style="font-size: 0.6rem; background-color: @vadeRenk; color: white;">
                                                        @if (kalanGun < 0)
                                                        {
                                                            @($"{Math.Abs(kalanGun)}g gecikti")
                                                        }
                                                        else if (kalanGun == 0)
                                                        {
                                                            @("Bugun")
                                                        }
                                                        else
                                                        {
                                                            @($"{kalanGun}g kaldi")
                                                        }
                                                    </span>
                                                </td>
                                                <td>
                                                    @odeme.MasrafKalemi
                                                    @if (!string.IsNullOrEmpty(odeme.Aciklama))
                                                    {
                                                        <br /><small class="text-muted">@GetGorunenAciklama(odeme)</small>
                                                    }
                                                </td>
                                                <td class="text-end">
                                                        <strong>@FormatPara(GetBekleyenTutar(odeme))</strong>
                                                        @if (odeme.KismiOdemeMi && odeme.ToplamKismiOdenen > 0)
                                                        {
                                                            <br/>
                                                            <small class="text-success">Ödenen: @FormatPara(odeme.ToplamKismiOdenen)</small>
                                                            <br/>
                                                            <small class="text-warning fw-bold">Kalan: @FormatPara(odeme.Miktar - odeme.ToplamKismiOdenen)</small>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (odeme.TaksitliMi)
                                                        {
                                                            <span class="badge bg-info">@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                        }
                                                        @if (odeme.Durum == OdemeDurum.KismiOdendi)
                                                        {
                                                            <span class="badge bg-warning text-dark" title="Kısmi ödenmiş">
                                                                <i class="bi bi-pie-chart-fill"></i> %@odeme.OdemeYuzdesi
                                                            </span>
                                                        }
                                                        @if (odeme.OncekiDonemOdemeId.HasValue)
                                                        {
                                                            <span class="badge bg-secondary" title="Önceki dönemden devir">
                                                                <i class="bi bi-arrow-left-circle"></i>
                                                            </span>
                                                        }
                                                    </td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-success py-0 px-1" @onclick="() => OdemeYapModalAc(odeme)" title="Ode">
                                                            <i class="bi bi-cash" style="font-size: 0.7rem;"></i>
                                                        </button>
                                                        <button class="btn btn-outline-primary py-0 px-1" @onclick="() => OdemeDuzenle(odeme)" title="Duzenle">
                                                            <i class="bi bi-pencil" style="font-size: 0.7rem;"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger py-0 px-1" @onclick="() => OdemeSilOnay(odeme)" title="Sil">
                                                            <i class="bi bi-trash" style="font-size: 0.7rem;"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    @if (devirBekleyenOdemeler.Any())
                    {
                        <div class="card">
                            <div class="card-header py-2 d-flex justify-content-between align-items-center bg-light">
                                <h6 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i>Önceki Aylardan Devir Ödenmeyenler</h6>
                                <div class="d-flex gap-1 align-items-center">
                                    <span class="badge bg-danger">@devirBekleyenOdemeler.Count kayıt | @FormatPara(devirBekleyenOdemeler.Sum(GetBekleyenTutar))</span>
                                    <button class="btn btn-outline-primary btn-sm py-0" @onclick='() => AylikListeOnIzleme("devir")' title="Ön İzleme">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-outline-success btn-sm py-0" @onclick='() => AylikListeYazdir("devir")' title="Yazdır">
                                        <i class="bi bi-printer"></i>
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm py-0" @onclick='() => AylikListeExcelAktar("devir")' title="Excel Aktar">
                                        <i class="bi bi-file-earmark-excel"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
                                    <table class="table table-hover table-sm mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>Dönem</th>
                                                <th>Tarih</th>
                                                <th>Masraf</th>
                                                <th class="text-end">Tutar</th>
                                                <th>Açıklama</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var odeme in devirBekleyenOdemeler)
                                            {
                                                <tr class="table-warning">
                                                    <td><small>@GetAyAdi(odeme.OdemeAy) @odeme.OdemeYil</small></td>
                                                    <td><small>@odeme.OdemeTarihi.ToString("dd.MM.yyyy")</small></td>
                                                    <td>@odeme.MasrafKalemi</td>
                                                    <td class="text-end"><strong>@FormatPara(GetBekleyenTutar(odeme))</strong></td>
                                                    <td><small class="text-muted">@GetGorunenAciklama(odeme)</small></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Kategori Bazlı Analiz -->
        <div class="row g-3 mt-1">
            <div class="col-md-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-pie-chart me-2 text-primary"></i>Kategori Dağılımı</h6>
                        <button class="btn btn-outline-primary btn-sm py-0" @onclick="KategoriAnalizYukle" title="Yenile">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                    <div class="card-body p-2">
                        @if (kategoriOzetleri.Count > 0)
                        {
                            @foreach (var kat in kategoriOzetleri.Take(10))
                            {
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-truncate" style="max-width: 55%;">
                                            <i class="bi bi-circle-fill me-1" style="color: @(kat.Renk ?? "#6c757d"); font-size: 0.5rem;"></i>
                                            @kat.MasrafKalemi
                                        </small>
                                        <small class="text-end">
                                            <strong>@FormatPara(kat.Toplam)</strong>
                                            <span class="text-muted ms-1">(%@kat.Yuzde.ToString("N1"))</span>
                                        </small>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar" style="width: @kat.Yuzde.ToString("N1", System.Globalization.CultureInfo.InvariantCulture)%; background-color: @(kat.Renk ?? "#0d6efd");" role="progressbar"></div>
                                    </div>
                                </div>
                            }
                            <hr class="my-2" />
                            <div class="d-flex justify-content-between">
                                <small class="text-muted">Toplam @kategoriOzetleri.Count kategori</small>
                                <strong class="text-primary">@FormatPara(kategoriOzetleri.Sum(k => k.Toplam))</strong>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-pie-chart" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-1"><small>Kategori verisi yok</small></p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-graph-up me-2 text-success"></i>Aylık Harcama Trendi</h6>
                        <button class="btn btn-outline-success btn-sm py-0" @onclick="TrendAnalizYukle" title="Yenile">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                    <div class="card-body p-2">
                        @if (trendData.Count > 0)
                        {
                            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Dönem</th>
                                            <th class="text-end">Toplam</th>
                                            <th class="text-end">Ödenen</th>
                                            <th class="text-end">Bekleyen</th>
                                            <th style="width: 30%;">Oran</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var maxToplam = trendData.Max(t => t.Toplam); }
                                        @foreach (var trend in trendData)
                                        {
                                            var odenmeOrani = trend.Toplam > 0 ? (trend.Odenen / trend.Toplam * 100) : 0;
                                            var barWidth = maxToplam > 0 ? (trend.Toplam / maxToplam * 100) : 0;
                                            <tr>
                                                <td><small class="fw-bold">@trend.Etiket</small></td>
                                                <td class="text-end"><small>@FormatPara(trend.Toplam)</small></td>
                                                <td class="text-end"><small class="text-success">@FormatPara(trend.Odenen)</small></td>
                                                <td class="text-end"><small class="text-warning">@FormatPara(trend.Bekleyen)</small></td>
                                                <td>
                                                    <div class="progress" style="height: 12px;">
                                                        <div class="progress-bar bg-success" style="width: @odenmeOrani.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)%;"
                                                             title="Ödenen: %@odenmeOrani.ToString("N0")">
                                                        </div>
                                                        <div class="progress-bar bg-warning" style="width: @((100 - odenmeOrani).ToString("N0", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <hr class="my-2" />
                            <div class="row g-1 text-center">
                                <div class="col-4">
                                    <small class="text-muted d-block">Ortalama</small>
                                    <small class="fw-bold text-primary">@FormatPara(trendData.Average(t => t.Toplam))</small>
                                </div>
                                <div class="col-4">
                                    <small class="text-muted d-block">En Yüksek</small>
                                    <small class="fw-bold text-danger">@trendData.OrderByDescending(t => t.Toplam).First().Etiket</small>
                                </div>
                                <div class="col-4">
                                    <small class="text-muted d-block">En Düşük</small>
                                    <small class="fw-bold text-success">@trendData.OrderBy(t => t.Toplam).First().Etiket</small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-graph-up" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-1"><small>Trend verisi yok</small></p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Rapor Yorumlama -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card shadow-sm border-info">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center bg-info bg-opacity-10">
                        <h6 class="mb-0">
                            <i class="bi bi-robot me-2 text-info"></i>AI Bütçe Analizi
                            <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;">Ollama - @ollamaModelAdi</span>
                            @if (ollamaBagli)
                            {
                                <span class="badge bg-success ms-1" style="font-size: 0.6rem;">● Bağlı</span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-1" style="font-size: 0.6rem;">● Bağlantı Yok</span>
                            }
                        </h6>
                        <div class="d-flex gap-1">
                            <select class="form-select form-select-sm" style="width: 160px;" @bind="aiAnalizTuru">
                                <option value="genel">Genel Bütçe Analizi</option>
                                <option value="kategori">Kategori Analizi</option>
                                <option value="trend">Trend Analizi</option>
                                <option value="tasarruf">Tasarruf Önerileri</option>
                                <option value="anomali">Anomali Tespiti</option>
                            </select>
                            <button class="btn btn-info btn-sm" @onclick="AiAnalizBaslat" disabled="@(aiYukleniyor || !ollamaBagli)">
                                @if (aiYukleniyor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Analiz ediliyor...</span>
                                }
                                else
                                {
                                    <i class="bi bi-lightning-charge me-1"></i>
                                    <span>Analiz Et</span>
                                }
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (!ollamaBagli)
                        {
                            <div class="alert alert-warning mb-0">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                <strong>Ollama bağlantısı kurulamadı.</strong>
                                <br /><small>
                                    AI analiz için Ollama'nın bilgisayarınızda çalışıyor olması gerekir.
                                    <br />Kurulum: <code>curl -fsSL https://ollama.com/install.sh | sh</code>
                                    <br />Model indirme: <code>ollama pull @ollamaModelAdi</code>
                                    <br />Başlatma: <code>ollama serve</code>
                                </small>
                            </div>
                        }
                        else if (string.IsNullOrEmpty(aiSonuc))
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-robot" style="font-size: 2.5rem;"></i>
                                <p class="mb-0 mt-2">Analiz türünü seçip <strong>"Analiz Et"</strong> butonuna tıklayın.</p>
                                <small>Verileriniz cihazınızda işlenir, internete gönderilmez.</small>
                            </div>
                        }
                        else
                        {
                            <div class="ai-sonuc">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">
                                        <i class="bi bi-clock me-1"></i>@aiAnalizSuresi
                                    </small>
                                    <button class="btn btn-outline-secondary btn-sm py-0" @onclick="AiSonucTemizle">
                                        <i class="bi bi-x-lg me-1"></i>Temizle
                                    </button>
                                </div>
                                <div class="border rounded p-3 bg-light" style="white-space: pre-wrap; font-size: 0.9rem; line-height: 1.6; max-height: 400px; overflow-y: auto;">@aiSonuc</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Odeme Yap Modal -->
@if (showOdemeYapModal && odemeYapilacak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Ödeme Yap</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@odemeYapilacak.MasrafKalemi</strong><br />
                                <small>@GetGorunenAciklama(odemeYapilacak)</small>
                            </div>
                            <div class="text-end">
                                <small class="text-muted">Tutar:</small><br/>
                                <strong class="text-danger fs-5">@FormatPara(odemeYapilacak.Miktar)</strong>
                                @if (odemeYapilacak.KismiOdemeMi && odemeYapilacak.ToplamKismiOdenen > 0)
                                {
                                    <br/>
                                    <small class="text-success">Ödenen: @FormatPara(odemeYapilacak.ToplamKismiOdenen)</small>
                                    <br/>
                                    <small class="text-warning fw-bold">Kalan: @FormatPara(odemeYapilacak.Miktar - odemeYapilacak.ToplamKismiOdenen)</small>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Kısmi Ödeme Seçeneği -->
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="kismiOdemeSwitch" @bind="kismiOdemeAktif">
                            <label class="form-check-label" for="kismiOdemeSwitch">
                                <i class="bi bi-pie-chart me-1"></i>Kısmi Ödeme Yap
                            </label>
                        </div>
                        @if (kismiOdemeAktif)
                        {
                            <div class="card border-warning mt-2">
                                <div class="card-body py-2">
                                    <div class="row g-2 align-items-center">
                                        <div class="col-md-6">
                                            <label class="form-label small mb-1">Ödenecek Tutar *</label>
                                            <div class="input-group">
                                                <input type="number" class="form-control" @bind="kismiOdemeTutari" step="0.01" 
                                                       max="@(odemeYapilacak.Miktar - odemeYapilacak.ToplamKismiOdenen)" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                            <small class="text-muted">Kalan: @FormatPara(odemeYapilacak.Miktar - odemeYapilacak.ToplamKismiOdenen)</small>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-check mt-3">
                                                <input class="form-check-input" type="checkbox" id="sonrakiDonemeAktar" @bind="kalanSonrakiDonemeAktarilsin">
                                                <label class="form-check-label" for="sonrakiDonemeAktar">
                                                    <i class="bi bi-arrow-right-circle me-1"></i>Kalan tutarı sonraki döneme aktar
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    @if (kalanSonrakiDonemeAktarilsin && kismiOdemeTutari > 0)
                                    {
                                        var kalanTutar = (odemeYapilacak.Miktar - odemeYapilacak.ToplamKismiOdenen) - kismiOdemeTutari;
                                        if (kalanTutar > 0)
                                        {
                                            var sonrakiAy = hedefAktarimAyi;
                                            var sonrakiYil = hedefAktarimYili;
                                            <div class="row g-2 mt-1">
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-1">Hangi Aya Aktarılsın?</label>
                                                    <select class="form-select form-select-sm" @bind="hedefAktarimAyi">
                                                        @foreach (var aySecenek in GetAktarimAySecenekleri())
                                                        {
                                                            <option value="@aySecenek">@GetAyAdi(aySecenek)</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small mb-1">Yıl</label>
                                                    <select class="form-select form-select-sm" @bind="hedefAktarimYili" @bind:after="HedefAktarimYiliDegisti">
                                                        @for (int y = odemeYapilacak.OdemeYil; y <= odemeYapilacak.OdemeYil + 2; y++)
                                                        {
                                                            <option value="@y">@y</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="alert alert-light border-warning mb-0 mt-2 py-1 small">
                                                <i class="bi bi-info-circle me-1 text-warning"></i>
                                                Kalan <strong>@FormatPara(kalanTutar)</strong>, <strong>@GetAyAdi(sonrakiAy) @sonrakiYil</strong> dönemine aktarılacak.
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="row g-3">
                        <!-- Ödeme Tipi -->
                        <div class="col-12">
                            <label class="form-label">Ödeme Şekli *</label>
                            <div class="btn-group w-100 flex-wrap">
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == Services.OdemeTipi.Kasa ? "btn-success" : "btn-outline-success")" 
                                        @onclick="() => OdemeTipiDegisti(Services.OdemeTipi.Kasa)">
                                    <i class="bi bi-cash-stack me-1"></i>Kasa
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == Services.OdemeTipi.Banka ? "btn-primary" : "btn-outline-primary")" 
                                        @onclick="() => OdemeTipiDegisti(Services.OdemeTipi.Banka)">
                                    <i class="bi bi-bank me-1"></i>Banka
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == Services.OdemeTipi.KrediKarti ? "btn-danger" : "btn-outline-danger")" 
                                        @onclick="() => OdemeTipiDegisti(Services.OdemeTipi.KrediKarti)">
                                    <i class="bi bi-credit-card me-1"></i>Kredi Kartı
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == Services.OdemeTipi.Mahsup ? "btn-secondary" : "btn-outline-secondary")" 
                                        @onclick="() => OdemeTipiDegisti(Services.OdemeTipi.Mahsup)">
                                    <i class="bi bi-arrow-left-right me-1"></i>Hesap Mahsup
                                </button>
                                <button type="button" class="btn @(odemeYapRequest.OdemeTipi == Services.OdemeTipi.CariMahsup ? "btn-warning" : "btn-outline-warning")" 
                                        @onclick="() => OdemeTipiDegisti(Services.OdemeTipi.CariMahsup)">
                                    <i class="bi bi-person-lines-fill me-1"></i>Cari Mahsup
                                </button>
                            </div>
                        </div>

                        <!-- Cari Seçimi (Cari Mahsup için) -->
                        @if (odemeYapRequest.OdemeTipi == Services.OdemeTipi.CariMahsup)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Cari Hesap *</label>
                                <select class="form-select" @bind="odemeYapRequest.CariId">
                                    <option value="">Seçin...</option>
                                    @if (cariler != null)
                                    {
                                        @foreach (var cari in cariler)
                                        {
                                            <option value="@cari.Id">@cari.CariKodu - @cari.Unvan</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Hesap *</label>
                                <select class="form-select" @bind="odemeYapRequest.BankaHesapId" @bind:after="CariMahsupHesapDegisti">
                                    <option value="">Seçin...</option>
                                    @if (bankaHesaplari != null)
                                    {
                                        @foreach (var hesap in GetCariMahsupHesaplar())
                                        {
                                            var bakiye = hesapBakiyeleri.GetValueOrDefault(hesap.Id, 0);
                                            <option value="@hesap.Id">@hesap.HesapAdi (@FormatPara(bakiye))</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">İşlem Yönü</label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="cariMahsupYon" id="cariOdeme" 
                                           checked="@(!odemeYapRequest.CaridenTahsilat)" @onchange="() => odemeYapRequest.CaridenTahsilat = false" />
                                    <label class="btn btn-outline-danger" for="cariOdeme">
                                        <i class="bi bi-arrow-up-circle me-1"></i>Ödeme (Hesap → Cari)
                                    </label>
                                    <input type="radio" class="btn-check" name="cariMahsupYon" id="cariTahsilat" 
                                           checked="@odemeYapRequest.CaridenTahsilat" @onchange="() => odemeYapRequest.CaridenTahsilat = true" />
                                    <label class="btn btn-outline-success" for="cariTahsilat">
                                        <i class="bi bi-arrow-down-circle me-1"></i>Tahsilat (Cari → Hesap)
                                    </label>
                                </div>
                                <div class="alert alert-light border mt-2 mb-0 py-2 small">
                                    <i class="bi bi-info-circle me-1 text-primary"></i>
                                    @(odemeYapRequest.CaridenTahsilat
                                        ? "Cari hesaptan seçilen kasa/banka hesabına tahsilat kaydı oluşur."
                                        : "Seçilen kasa/banka hesabından cari hesaba ödeme kaydı oluşur.")
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ödeme Tarihi *</label>
                                <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                            </div>
                            <div class="col-12">
                                <div class="card bg-light border">
                                    <div class="card-header py-2">
                                        <i class="bi bi-journal-code me-1"></i>Muhasebe Eşleştirme
                                    </div>
                                    <div class="card-body py-2">
                                        <div class="row g-2">
                                            <div class="col-md-4">
                                                <label class="form-label small">Muhasebe Hesap Kodu</label>
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.MuhasebeHesapKodu" placeholder="Örn: 320" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Kost Merkezi</label>
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.KostMerkeziKodu" placeholder="Masraf merkezi" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Proje Kodu</label>
                                                <input type="text" class="form-control form-control-sm" @bind="odemeYapRequest.ProjeKodu" placeholder="Proje" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (odemeYapRequest.OdemeTipi != Services.OdemeTipi.Mahsup && bankaHesaplari != null)
                        {
                            <div class="col-md-6">
                                <label class="form-label">@GetHesapLabel() *</label>
                                <select class="form-select" @bind="odemeYapRequest.BankaHesapId">
                                    <option value="">Seçin...</option>
                                    @foreach (var hesap in GetFiltrelenmisHesaplar())
                                    {
                                        var bakiye = hesapBakiyeleri.GetValueOrDefault(hesap.Id, 0);
                                        <option value="@hesap.Id">@hesap.HesapAdi (@FormatPara(bakiye))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ödeme Tarihi *</label>
                                <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <label class="form-label">Ödeme Tarihi *</label>
                                <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                            </div>
                        }

                        <!-- Ek Masraflar (Tutara eklenir) -->
                        <div class="col-12">
                            <div class="card bg-light">
                                <div class="card-header py-2">
                                    <i class="bi bi-plus-circle me-1"></i>Ek Masraflar (Tutara Eklenir)
                                </div>
                                <div class="card-body py-2">
                                    <div class="row g-2">
                                        <div class="col-md-4">
                                            <label class="form-label small">Masraf/Komisyon</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control" @bind="odemeYapRequest.MasrafKesintisi" step="0.01" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small">Ceza/Faiz</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control" @bind="odemeYapRequest.CezaKesintisi" step="0.01" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small">Diğer Ek Masraf</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control" @bind="odemeYapRequest.DigerKesinti" step="0.01" />
                                                <span class="input-group-text">₺</span>
                                            </div>
                                        </div>
                                        @if (ToplamEkMasraf != 0)
                                        {
                                            <div class="col-12">
                                                <input type="text" class="form-control form-control-sm" 
                                                       @bind="odemeYapRequest.KesintiAciklamasi" 
                                                       placeholder="Ek masraf açıklaması..." />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Ödeme Notu -->
                        <div class="col-12">
                            <label class="form-label">Not</label>
                            <input type="text" class="form-control" @bind="odemeYapRequest.OdemeNotu" placeholder="Ödeme notu..." />
                        </div>
                    </div>

                    <!-- Özet -->
                    <div class="card mt-3 @(ToplamEkMasraf != 0 ? "border-warning" : "border-success")">
                        <div class="card-body py-2">
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Tutar:</small>
                                <div class="fs-5">@FormatPara(kismiOdemeAktif ? kismiOdemeTutari : GetBekleyenTutar(odemeYapilacak))</div>
                                </div>
                                @if (ToplamEkMasraf != 0)
                                {
                                    <div class="col-3 text-center">
                                        <small class="text-muted">Ek Masraf:</small>
                                        <div class="text-primary">+@FormatPara(ToplamEkMasraf)</div>
                                    </div>
                                }
                                <div class="col text-end">
                                    <small class="text-muted">Net Ödeme:</small>
                                    <div class="fs-4 fw-bold text-success">@FormatPara(NetOdemeTutari)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-success" @onclick="OdemeYap" disabled="@isKaydediliyor">
                        @if (isKaydediliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Ödemeyi Tamamla (@FormatPara(NetOdemeTutari))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni/Duzenle Odeme Modal -->
@if (showOdemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header @(editOdeme.TaksitliMi ? "bg-warning text-dark" : "")">
                    <h5 class="modal-title">
                        @if (editOdeme.TaksitliMi && editOdeme.Id > 0)
                        {
                            <i class="bi bi-credit-card me-2"></i>
                            <text>Taksit Duzenle</text>
                        }
                        else
                        {
                            @(editOdeme.Id > 0 ? "Odeme Duzenle" : "Yeni Odeme")
                        }
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (editOdeme.TaksitliMi && editOdeme.Id > 0)
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>Kredi/Taksit:</strong> @editOdeme.MasrafKalemi
                            <br/><small>Taksit @editOdeme.KacinciTaksit / @editOdeme.ToplamTaksitSayisi</small>
                        </div>
                        <div class="alert alert-warning py-2 mb-3 small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Yapacaginiz degisiklikler <strong>tum raporlara</strong> (Butce Analiz, Kredi/Taksitler, Fatura Odeme vb.) otomatik olarak yansiyacaktir.
                        </div>
                    }
                    @if (editOdeme.Durum == OdemeDurum.Odendi)
                    {
                        <div class="alert alert-success py-2 mb-3">
                            <div><strong><i class="bi bi-check-circle me-1"></i>Ödeme İzi</strong></div>
                            @if (editOdeme.GercekOdemeTarihi.HasValue)
                            {
                                <div><small>Gerçek Ödeme Tarihi: @editOdeme.GercekOdemeTarihi.Value.ToString("dd.MM.yyyy")</small></div>
                            }
                            <div><small>Ödenen Tutar: @FormatPara(editOdeme.OdenenTutar ?? editOdeme.Miktar)</small></div>
                            @if (!string.IsNullOrWhiteSpace(GetOdemeHesapAdi(editOdeme.OdemeYapildigiHesapId)))
                            {
                                <div><small>Hesap: @GetOdemeHesapAdi(editOdeme.OdemeYapildigiHesapId)</small></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(editOdeme.HareketKaynakGorunumu))
                            {
                                <div><small>İz: @editOdeme.HareketKaynakGorunumu</small></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(editOdeme.HareketCariUnvani))
                            {
                                <div><small>Cari: @editOdeme.HareketCariUnvani</small></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(editOdeme.HareketYonGorunumu))
                            {
                                <div><small>Yön: @editOdeme.HareketYonGorunumu</small></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(editOdeme.HareketBelgeNo))
                            {
                                <div><small>Belge No: @editOdeme.HareketBelgeNo</small></div>
                            }
                            @if (editOdeme.BankaKasaHareketId.HasValue)
                            {
                                <div><small>Hareket #: @editOdeme.BankaKasaHareketId</small></div>
                            }
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Firma</label>
                        <select class="form-select" @bind="editOdeme.FirmaId">
                            <option value="">Firma Secin...</option>
                            @if (firmalar != null)
                            {
                                @foreach (var f in firmalar)
                                {
                                    <option value="@f.Id">@f.FirmaAdi</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Odeme Tarihi *</label>
                        <input type="date" class="form-control" @bind="editOdeme.OdemeTarihi" />
                    </div>
                    @if (!editOdeme.TaksitliMi || editOdeme.Id == 0)
                    {
                        <div class="mb-3">
                            <label class="form-label">Masraf Kalemi *</label>
                            <input type="text" class="form-control" @bind="editOdeme.MasrafKalemi" list="masrafList" />
                            <datalist id="masrafList">
                                @if (masrafKalemleri != null)
                                {
                                    @foreach (var k in masrafKalemleri)
                                    {
                                        <option value="@k.KalemAdi" />
                                    }
                                }
                            </datalist>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="editOdeme.Aciklama" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Miktar * @(editOdeme.TaksitliMi ? "(Taksit Tutari)" : "")</label>
                        <div class="input-group">
                            <input type="number" class="form-control @(editOdeme.TaksitliMi ? "border-warning" : "")" @bind="editOdeme.Miktar" step="0.01" />
                            <span class="input-group-text">TL</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select class="form-select" @bind="editOdeme.Durum">
                            <option value="@OdemeDurum.Bekliyor">Bekliyor</option>
                            <option value="@OdemeDurum.KismiOdendi">Kısmi Ödendi</option>
                            <option value="@OdemeDurum.Odendi">Odendi</option>
                            <option value="@OdemeDurum.Ertelendi">Ertelendi</option>
                            <option value="@OdemeDurum.Iptal">Iptal</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn @(editOdeme.TaksitliMi ? "btn-warning" : "btn-primary")" @onclick="OdemeKaydet">
                        @if (editOdeme.TaksitliMi)
                        {
                            <i class="bi bi-check-lg me-1"></i>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Taksitli Odeme Modal -->
@if (showTaksitModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Taksitli Odeme / Kredi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Firma</label>
                                <select class="form-select" @bind="taksitRequest.FirmaId">
                                    <option value="">Firma Secin...</option>
                                    @if (firmalar != null)
                                    {
                                        @foreach (var f in firmalar)
                                        {
                                            <option value="@f.Id">@f.FirmaAdi</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Masraf Kalemi *</label>
                                <input type="text" class="form-control" @bind="taksitRequest.MasrafKalemi" list="masrafList2" />
                                <datalist id="masrafList2">
                                    @if (masrafKalemleri != null)
                                    {
                                        @foreach (var k in masrafKalemleri)
                                        {
                                            <option value="@k.KalemAdi" />
                                        }
                                    }
                                </datalist>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Aciklama</label>
                                <input type="text" class="form-control" @bind="taksitRequest.Aciklama" />
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Baslangic Tarihi *</label>
                                        <input type="date" class="form-control" @bind="taksitRequest.BaslangicTarihi" @bind:after="TaksitListesiHesapla" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Sayisi *</label>
                                        <input type="number" class="form-control" @bind="taksitRequest.TaksitSayisi" min="1" max="120" @bind:after="TaksitListesiHesapla" />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Toplam Tutar *</label>
                                        <div class="input-group">
                                            <input type="number" class="form-control" @bind="taksitRequest.ToplamTutar" step="0.01" @bind:after="TaksitListesiHesapla" />
                                            <span class="input-group-text">TL</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Tutari</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control fw-bold text-primary" value="@(taksitRequest.TaksitSayisi > 0 ? FormatPara(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi) : "0 TL")" readonly />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            @if (taksitRequest.TaksitSayisi > 1 && taksitListesi.Any())
                            {
                                var taksitToplam = taksitListesi.Sum(t => t.Tutar);
                                var fark = taksitRequest.ToplamTutar - taksitToplam;
                                var farkSifir = Math.Abs(fark) < 0.01m;
                                
                                <div class="card">
                                    <div class="card-header py-2 bg-info text-white d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0"><i class="bi bi-list-ol me-2"></i>Taksit Plani (@taksitListesi.Count Taksit)</h6>
                                        <button type="button" class="btn btn-sm btn-light" @onclick="TaksitListesiSifirla" title="Taksitleri Sifirla">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </div>
                                    <div class="card-body p-0" style="max-height: 280px; overflow-y: auto;">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th width="40">#</th>
                                                    <th>Tarih</th>
                                                    <th class="text-end">Tutar (TL)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var taksit in taksitListesi)
                                                {
                                                    <tr>
                                                        <td><span class="badge bg-secondary">@taksit.Sira</span></td>
                                                        <td>
                                                            <input type="date" class="form-control form-control-sm" 
                                                                   value="@taksit.Tarih.ToString("yyyy-MM-dd")" 
                                                                   @onchange="@(e => TaksitTarihDegistir(taksit, e))" />
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm text-end" 
                                                                   value="@taksit.Tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))"
                                                                   @onchange="@(e => TaksitTutarDegistir(taksit, e))" 
                                                                   style="width: 120px;" />
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="card-footer p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small class="text-muted">Taksit Toplami:</small>
                                                <strong class="ms-1">@taksitToplam.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) TL</strong>
                                            </div>
                                            <div>
                                                <small class="text-muted">Fark:</small>
                                                <strong class="ms-1 @(farkSifir ? "text-success" : "text-danger")">
                                                    @fark.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) TL
                                                    @if (farkSifir)
                                                    {
                                                        <i class="bi bi-check-circle-fill ms-1"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                                    }
                                                </strong>
                                            </div>
                                        </div>
                                        @if (!farkSifir)
                                        {
                                            <div class="alert alert-warning py-1 px-2 mt-2 mb-0" style="font-size: 11px;">
                                                <i class="bi bi-info-circle me-1"></i>
                                                Taksit toplamı ile toplam tutar eşit olmalı!
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info text-center mt-5">
                                    <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Taksit sayisi 2 veya daha fazla olduğunda taksit plani burada gorunecek</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TaksitliOdemeKaydet" 
                            disabled="@(!TaksitKaydetmeGecerliMi())">
                        <i class="bi bi-check-lg me-1"></i>@(taksitRequest.TaksitSayisi > 1 ? $"{taksitRequest.TaksitSayisi} Taksit Olustur" : "Kaydet")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Excel Yukle Modal -->
@if (showExcelModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Excel'den Yukle</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
