    private decimal NetOdemeTutari => (odemeYapilacak?.Miktar ?? 0) + ToplamEkMasraf;
    private IEnumerable<int> GetAktarimAySecenekleri()
    {
        if (odemeYapilacak == null)
            return Enumerable.Range(1, 12);

        return hedefAktarimYili > odemeYapilacak.OdemeYil
            ? Enumerable.Range(1, 12)
            : Enumerable.Range(odemeYapilacak.OdemeAy + 1, 12 - odemeYapilacak.OdemeAy);
    }

    private void HedefAktarimYiliDegisti()
    {
        var ilkGecerliAy = GetAktarimAySecenekleri().FirstOrDefault();
        if (ilkGecerliAy > 0 && !GetAktarimAySecenekleri().Contains(hedefAktarimAyi))
        {
            hedefAktarimAyi = ilkGecerliAy;
        }
    }

