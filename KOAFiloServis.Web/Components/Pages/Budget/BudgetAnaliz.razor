                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Durum</label>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" @bind="editTekrarlayan.Aktif" />
                                    <label class="form-check-label">@(editTekrarlayan.Aktif ? "Aktif" : "Pasif")</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="editTekrarlayan.Aciklama" />
                    </div>
                </div> <!-- col-md-7 -->
                <!-- Sağ: Önizleme paneli -->
                <div class="col-md-5 border-start">
                    <div class="fw-bold text-danger mb-2"><i class="bi bi-calendar3 me-1"></i>Gelecek Ödemeler</div>
                    @{
                        var onizlemeSayisi = 8;
                        var periyodAy = editTekrarlayan.Periyod switch {
                            TekrarPeriyodu.IkiAylik => 2,
                            TekrarPeriyodu.UcAylik => 3,
                            TekrarPeriyodu.AltiAylik => 6,
                            TekrarPeriyodu.Yillik => 12,
                            _ => 1
                        };
                        var bas = editTekrarlayan.BaslangicTarihi == default ? DateTime.Today : editTekrarlayan.BaslangicTarihi;
                        var gun = editTekrarlayan.OdemeGunu > 0 ? editTekrarlayan.OdemeGunu : bas.Day;
                    }
                    @if (editTekrarlayan.Tutar > 0)
                    {
                        <div class="border rounded" style="max-height: 300px; overflow-y: auto;">
                            @for (int i = 0; i < onizlemeSayisi; i++)
                            {
                                var odemeAy = bas.AddMonths(i * periyodAy);
                                var maxGun = DateTime.DaysInMonth(odemeAy.Year, odemeAy.Month);
                                var odemeTarih = new DateTime(odemeAy.Year, odemeAy.Month, Math.Min(gun, maxGun));
                                if (editTekrarlayan.BitisTarihi.HasValue && odemeTarih > editTekrarlayan.BitisTarihi.Value)
                                    break;
                                <div class="d-flex justify-content-between align-items-center border-bottom px-2 py-1">
                                    <span>
                                        <span class="badge bg-secondary me-1" style="font-size:0.7rem;">@(i + 1)</span>
                                        <small>@odemeTarih.ToString("dd.MM.yyyy")</small>
                                    </span>
                                    <strong class="text-success">@editTekrarlayan.Tutar.ToString("N2") ₺</strong>
                                </div>
                            }
                        </div>
                        @if (editTekrarlayan.BitisTarihi == null)
                        {
                            <small class="text-muted d-block mt-1"><i class="bi bi-infinity me-1"></i>Süresiz devam eder</small>
                        }
                    }
                    else
                    {
                        <div class="text-muted small py-3 text-center">
                            <i class="bi bi-cash-coin d-block mb-1" style="font-size:1.5rem;"></i>
                            Tutar ve başlangıç tarihi girilince önizleme görünür
                        </div>
                    }
                </div> <!-- col-md-5 -->
                </div> <!-- row -->
                </div> <!-- modal-body -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-danger" @onclick="TekrarlayanOdemeKaydet">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Aylik Liste On Izleme/Yazdir Modal -->
@if (showAylikListeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-printer me-2"></i>@AktifRaporBaslik</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body p-0" style="max-height: 70vh; overflow-y: auto;">
                    <div id="printArea" class="p-4 bg-white text-dark">
                        @if (aktifListeRaporTuru == "bekleyen")
                        {
                        <!-- 1. SAYFA: TAKVİM -->
                        <div class="print-page print-calendar print-calendar-page">
                            <div class="text-center mb-4">
                                <h4>Bütçe Takvim Önizlemesi</h4>
                                <p class="text-muted">Dönem: @GetAyAdi(aktifTakvimAy) @secilenYil</p>
                            </div>
                            
                            <table class="table table-bordered table-sm mb-0 print-table print-calendar-table" style="table-layout: fixed; width: 100%;">
                                <thead>
                                    <tr class="text-center bg-light">
                                        <th style="width: 14.28%;">Pzt</th>
                                        <th style="width: 14.28%;">Sal</th>
                                        <th style="width: 14.28%;">Çar</th>
                                        <th style="width: 14.28%;">Per</th>
                                        <th style="width: 14.28%;">Cum</th>
                                        <th style="width: 14.28%;">Cmt</th>
                                        <th style="width: 14.28%;">Paz</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var pIlkGun = new DateTime(secilenYil, aktifTakvimAy, 1);
                                        var pIlkGunHafta = ((int)pIlkGun.DayOfWeek + 6) % 7;
                                        var pGunSayisi = DateTime.DaysInMonth(secilenYil, aktifTakvimAy);
                                        var pSatirSayisi = (int)Math.Ceiling((pIlkGunHafta + pGunSayisi) / 7.0);
                                        var pGun = 1;
                                    }
                                    @for (int satir = 0; satir < pSatirSayisi; satir++)
                                    {
                                        <tr>
                                            @for (int sutun = 0; sutun < 7; sutun++)
                                            {
                                                var hucreIndex = satir * 7 + sutun;
                                                if (hucreIndex < pIlkGunHafta || pGun > pGunSayisi)
                                                {
                                                    <td class="bg-light p-1" style="height: 120px;"></td>
                                                }
                                                else
                                                {
                                                    var currentGun = pGun;
                                                    var gunData = takvimData?.FirstOrDefault(t => t.Gun == currentGun);
                                                    <td class="p-0" style="height: 14vh; vertical-align: top; font-size: 0.70rem; overflow: hidden;">
                                                        <div class="d-flex justify-content-between mb-1 bg-light px-1" style="border-bottom: 1px solid #ccc; padding-top: 2px; padding-bottom: 2px;">
                                                            <strong style="font-size: 0.85rem;">@currentGun</strong>
                                                            @if (gunData != null && gunData.BekleyenToplamOdeme > 0)
                                                            {
                                                                <strong class="text-danger" style="font-size: 0.80rem;">@gunData.BekleyenToplamOdeme.ToString("N0") TL</strong>
                                                            }
                                                        </div>
                                                        <div class="px-1" style="overflow: hidden; max-height: calc(14vh - 22px);">
                                                           @if (gunData != null && gunData.Odemeler != null)
                                                           {
                                                               foreach(var o in gunData.Odemeler.Where(x => x.Durum == OdemeDurum.Bekliyor || x.Durum == OdemeDurum.Ertelendi).OrderBy(x => x.Durum))
                                                               {
                                                                   int kalanGun = (o.OdemeTarihi.Date - DateTime.Today).Days;
                                                                   string blockClass = "";
                                                                   string timeText = "";

                                                                   if (kalanGun < 0) {
                                                                       blockClass = "bg-danger text-white"; 
                                                                       timeText = $"{Math.Abs(kalanGun)}g Gecikti";
                                                                   } else if (kalanGun == 0) {
                                                                       blockClass = "bg-warning text-dark fw-bold"; 
                                                                       timeText = "Bugün";
                                                                   } else {
                                                                       blockClass = "bg-success text-white"; 
                                                                       timeText = $"{kalanGun}g Kaldı";
                                                                   }

                                                                   string stringAciklama = string.IsNullOrWhiteSpace(o.Aciklama) ? o.MasrafKalemi : o.Aciklama;
                                                                   stringAciklama = stringAciklama.Replace("[Tekrarlayan]", "").Replace("[tekrarlayan]", "").Trim();

                                                                   <div class="mb-1 px-1 py-1 rounded border-bottom border-light @blockClass" style="line-height: 1.1; font-size: 0.65rem;">
                                                                       <div class="text-truncate" style="max-width: 100%;" title="@stringAciklama">@stringAciklama</div>
                                                                       <div class="d-flex justify-content-between">
                                                                           <span class="fw-bold">@o.Miktar.ToString("N0") TL</span>
                                                                           <span style="font-size: 0.55rem; opacity: 0.9;">@timeText</span>
                                                                       </div>
                                                                   </div>
                                                               }
                                                           }
                                                        </div>
                                                    </td>
                                                    pGun++;
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- 2. SAYFA ZORUNLU KESME -->
                        <div style="page-break-before: always; border-top: 2px dashed #ccc; margin: 30px 0;" class="print-page-break d-print-none text-center text-muted">
                            <small><i class="bi bi-scissors me-1"></i> Sayfa Kesimi (Yazdırırken aktif olur) <i class="bi bi-scissors ms-1"></i></small>
                        </div>
                        <div style="page-break-before: always;" class="d-none d-print-block"></div>
                        }

                        <!-- 2. SAYFA: LİSTE -->
                        <div class="print-page print-list-page">
                            <div class="text-center mb-4">
                                <h4>@AktifRaporBaslik</h4>
                                <p class="text-muted">@AktifRaporAltBaslik</p>
                            </div>
                            <table class="table table-bordered table-sm w-100 print-table print-list-table" style="font-size: 0.9rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Masraf Kalemi</th>
                                        <th class="print-aciklama-col">Açıklama</th>
                                        <th class="text-center">Taksit</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var odeme in AktifRaporOdemeleri)
                                    {
                                        int kGun2 = (odeme.OdemeTarihi.Date - DateTime.Today).Days;
                                        string trColorClass = "";
                                        string timeText2 = "";
                                        
                                        if (kGun2 < 0) { 
                                            trColorClass = "table-danger text-danger"; 
                                            timeText2 = $"{Math.Abs(kGun2)}g Gecikti";
                                        } 
                                        else if (kGun2 == 0) { 
                                            trColorClass = "table-warning text-dark fw-bold"; 
                                            timeText2 = "Bugün";
                                        } 
                                        else { 
                                            trColorClass = "table-success text-success"; 
                                            timeText2 = $"{kGun2}g Kaldı";
                                        }

                                        <tr class="@($"{trColorClass} print-list-row")">
                                            <td>
                                                @odeme.OdemeTarihi.ToString("dd.MM.yyyy")
                                                <br />
                                                <small class="fw-bold">@timeText2</small>
                                            </td>
                                            <td><strong>@odeme.MasrafKalemi</strong></td>
                                            <td class="print-aciklama-col">@(odeme.Aciklama?.Replace("[Tekrarlayan]", "")?.Replace("[tekrarlayan]", "")?.Trim())</td>
                                            <td class="text-center">
                                                @if (odeme.TaksitliMi)
                                                {
                                                    <span class="badge bg-info">@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                }
                                                else
                                                {
                                                    <span>-</span>
                                                }
                                            </td>
                                        <td class="text-end fw-bold">@GetBekleyenTutar(odeme).ToString("N2") TL</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light fw-bold">
                                    <tr>
                                        <td colspan="4" class="text-end">TOPLAM:</td>
                                        <td class="text-end">@AktifRaporOdemeleri.Sum(GetBekleyenTutar).ToString("N2") TL</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                    <button type="button" class="btn btn-primary" @onclick='() => AylikListeExcelAktar(aktifListeRaporTuru)'>
                        <i class="bi bi-file-excel me-1"></i>Excel İndir
                    </button>
                    <button type="button" class="btn btn-success" @onclick='() => AylikListeYazdir(aktifListeRaporTuru)'>
                        <i class="bi bi-printer me-1"></i>Yazdır
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    #printArea .print-list-page {
        display: flex;
        flex-direction: column;
    }

    #printArea .print-list-table {
        table-layout: fixed;
    }

    #printArea .print-list-table th,
    #printArea .print-list-table td {
        padding: 0.2rem 0.35rem !important;
        line-height: 1.15;
        vertical-align: top;
        height: auto;
        white-space: normal;
    }

    #printArea .print-list-table tbody tr {
        page-break-inside: avoid;
    }

    #printArea .print-list-table small {
        line-height: 1.05;
    }

    #printArea .print-list-table .print-aciklama-col {
        font-size: 0.78rem;
        line-height: 1.05;
        word-break: break-word;
    }
</style>

@code {
    // DİAGNOSTİK: Son oluşturulan/güncellenen ödeme Id'si (sadece log için)
    private int _diagnostikSonOdemeId;
    private int secilenYil;
    private int secilenAy;
    private int aktifTakvimAy;
    private int secilenFirmaId = 0;
    private string secilenPeriyod = "aylik";

    private int? secilenGun = null;
    private DateTime secilenGunTarih;
    private List<BudgetOdeme> secilenGunOdemeleri = new();
    private List<BudgetOdeme> bekleyenOdemeler = new();
    private List<BudgetOdeme> devirBekleyenOdemeler = new();
    private string aktifListeRaporTuru = "bekleyen";

    private bool isLoading = true;
    private bool isKaydediliyor = false;
    private BudgetOzet? ozet;
    private List<BudgetOdeme> odemeler = new();
    private List<BudgetGunlukOzet>? takvimData;
    private List<BudgetMasrafKalemi>? masrafKalemleri;
    private List<BankaHesap>? bankaHesaplari;
    private Dictionary<int, decimal> hesapBakiyeleri = new();
    private List<Firma>? firmalar;
    private List<Cari>? cariler;
    private List<KrediOzet>? aktifKrediler;
    private decimal krediTaksitToplam = 0;
    private int krediTaksitAdet = 0;

    private bool showOdemeModal = false;
    private bool showOdemeYapModal = false;
    private bool showTaksitModal = false;
    private bool showExcelModal = false;
    private bool showAylikListeModal = false;
    private bool showTekrarlayanModal = false;
    private bool showTekrarlayanListeModal = false;

    private BudgetOdeme editOdeme = new();
    private BudgetOdeme? odemeYapilacak;
    private OdemeYapRequest odemeYapRequest = new();
    private TaksitliOdemeRequest taksitRequest = new();
    private IBrowserFile? excelDosya;
    private List<TekrarlayanOdeme>? tekrarlayanOdemeler;
    private TekrarlayanOdeme editTekrarlayan = new();

    // Kısmi Ödeme
    private bool kismiOdemeAktif = false;
    private decimal kismiOdemeTutari = 0;
    private bool kalanSonrakiDonemeAktarilsin = false;
    private int hedefAktarimAyi;
    private int hedefAktarimYili;

    // Kategori & Trend Analiz
    private List<BudgetKategoriOzet> kategoriOzetleri = new();
    private List<BudgetTrendData> trendData = new();
    private HedefGerceklesenOzet hedefGerceklesen = new();

    // AI Ollama
    private bool ollamaBagli = false;
    private string ollamaModelAdi = "";
    private string aiAnalizTuru = "genel";
    private string aiSonuc = "";
    private string aiAnalizSuresi = "";
    private bool aiYukleniyor = false;

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    private List<BudgetOdeme> AktifRaporOdemeleri => aktifListeRaporTuru == "devir" ? devirBekleyenOdemeler : bekleyenOdemeler;
    private string AktifRaporBaslik => aktifListeRaporTuru == "devir"
        ? "Önceki Aylardan Devir Ödenmeyenler"
        : "Aylık Bekleyen Ödeme Listesi";
    private string AktifRaporAltBaslik => aktifListeRaporTuru == "devir"
        ? $"{GetAyAdi(aktifTakvimAy)} {secilenYil} öncesi devreden ödenmeyen kayıtlar"
        : $"Dönem: {GetAyAdi(aktifTakvimAy)} {secilenYil}";

    protected override async Task OnInitializedAsync()
    {
        secilenYil = DateTime.Today.Year;
        secilenAy = DateTime.Today.Month;
        aktifTakvimAy = secilenAy;

        firmalar = await FirmaService.GetAktifFirmalarAsync();
        var aktifFirma = FirmaService.GetAktifFirma();
        if (!aktifFirma.TumFirmalar && aktifFirma.FirmaId > 0)
            secilenFirmaId = aktifFirma.FirmaId;

        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
        bankaHesaplari = await BankaHesapService.GetAllAsync();
        hesapBakiyeleri = await BankaHesapService.GetTumHesapBakiyeleriAsync();
        cariler = await CariService.GetAllAsync();
        tekrarlayanOdemeler = await BudgetService.GetTekrarlayanOdemelerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);
        await YenileDataAsync();

        // Kategori ve trend verilerini yükle
        await KategoriAnalizYukle();
        await TrendAnalizYukle();

        // Ollama bağlantı kontrolü (arka planda)
        ollamaModelAdi = OllamaService.ModelAdi;
        _ = Task.Run(async () =>
        {
            ollamaBagli = await OllamaService.BaglantiKontrolAsync();
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task YenileDataAsync()
    {
        isLoading = true;
        var oncekiSecilenGun = secilenGun; // Onceki secimi sakla

        // ─── DİAGNOSTİK LOG 3: YenileDataAsync GİRİŞ ───
        Console.WriteLine($"[DİAG-3] YenileDataAsync GİRİŞ: secilenYil={secilenYil}, secilenAy={secilenAy}, aktifTakvimAy={aktifTakvimAy}, secilenFirmaId={secilenFirmaId}");

        StateHasChanged();

        try
        {
            // Bozuk kısmi ödeme/devir/mükerrer kayıtları otomatik düzelt
            await BudgetService.TemizleMukerrerKrediKartiBorclariAsync();

            // Önce seçilen dönem için veya tüm yıl için tekrarlayan ödemeleri oluştur
            if (secilenAy > 0)
            {
                await BudgetService.TekrarlayanOdemelerdenKayitOlusturAsync(secilenYil, secilenAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            }
            else
            {
                for (int m = 1; m <= 12; m++)
                {
                    await BudgetService.TekrarlayanOdemelerdenKayitOlusturAsync(secilenYil, m, secilenFirmaId > 0 ? secilenFirmaId : null);
                }
            }

            // Firma filtresine göre odemeler
            odemeler = await BudgetService.GetOdemelerAsync(secilenYil, secilenAy > 0 ? secilenAy : null, secilenFirmaId > 0 ? secilenFirmaId : null);

            // ─── DİAG-KAYIP ID=552 ───
            var kayip552 = odemeler.FirstOrDefault(x => x.Id == 552);
            if (kayip552 == null)
            {
                Console.WriteLine($"[DİAG-KAYIP-552] GetOdemelerAsync dönüşünde ID=552 YOK. secilenYil={secilenYil}, secilenAy={secilenAy}, secilenFirmaId={secilenFirmaId}");
            }
            else
            {
                Console.WriteLine($"[DİAG-KAYIP-552] GetOdemelerAsync dönüşünde ID=552 VAR: OdemeAy={kayip552.OdemeAy}, OdemeYil={kayip552.OdemeYil}, Durum={kayip552.Durum}, FirmaId={kayip552.FirmaId}, OdemeTarihi={kayip552.OdemeTarihi:yyyy-MM-dd}");
            }

            // ─── DİAGNOSTİK LOG 4: GetOdemelerAsync dönüşü ───
            Console.WriteLine($"[DİAG-4] GetOdemelerAsync dönüş: odemeler.Count={odemeler.Count}");
            if (_diagnostikSonOdemeId > 0)
                Console.WriteLine($"[DİAG-4] odemeler içinde Id={_diagnostikSonOdemeId} var mı? {odemeler.Any(x => x.Id == _diagnostikSonOdemeId)}");

            if (secilenAy > 0)
            {
                ozet = await BudgetService.GetAylikOzetAsync(secilenYil, secilenAy, secilenFirmaId > 0 ? secilenFirmaId : null);
                aktifTakvimAy = secilenAy;
            }
            else
            {
                var yillikOzet = await BudgetService.GetYillikOzetAsync(secilenYil, secilenFirmaId > 0 ? secilenFirmaId : null);
                ozet = new BudgetOzet
                {
                    Yil = secilenYil,
                    ToplamOdeme = yillikOzet.ToplamOdeme,
                    OdenenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Odendi).Sum(o => o.Miktar),
                    BekleyenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).Sum(o => o.Miktar),
                    ToplamKayit = odemeler.Count,
                    OdenenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Odendi),
                    BekleyenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Bekliyor)
                };
            }

            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            aktifKrediler = await BudgetService.GetAktifKredilerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);
            devirBekleyenOdemeler = await BudgetService.GetDevirBekleyenOdemelerAsync(
                new DateTime(secilenYil, aktifTakvimAy, 1),
                secilenFirmaId > 0 ? secilenFirmaId : null);

            // Bekleyen ödemeler - aktif takvim ayına göre filtrele (Bekliyor + KismiOdendi)
            bekleyenOdemeler = odemeler
                .Where(o => (o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi) && o.OdemeAy == aktifTakvimAy)
                .OrderBy(o => o.OdemeTarihi)
                .ToList();

            // ─── DİAG-KAYIP ID=552 bekleyen filtresi ───
            var kayip552Full = odemeler.FirstOrDefault(x => x.Id == 552);
            if (kayip552Full != null)
            {
                var durumUygun = kayip552Full.Durum == OdemeDurum.Bekliyor || kayip552Full.Durum == OdemeDurum.KismiOdendi;
                var ayUygun = kayip552Full.OdemeAy == aktifTakvimAy;
                Console.WriteLine($"[DİAG-KAYIP-552] bekleyen filtresi: Durum uygun mu? {durumUygun} (Durum={kayip552Full.Durum}), Ay uygun mu? {ayUygun} (OdemeAy={kayip552Full.OdemeAy}, aktifTakvimAy={aktifTakvimAy})");
                if (!durumUygun) Console.WriteLine($"[DİAG-KAYIP-552] ⚠ DURUM FİLTRESİNDE ELENDİ. Kaydın Durum={kayip552Full.Durum}, beklenen: Bekliyor(1) veya KismiOdendi(5)");
                if (!ayUygun) Console.WriteLine($"[DİAG-KAYIP-552] ⚠ AY FİLTRESİNDE ELENDİ. Kaydın OdemeAy={kayip552Full.OdemeAy}, aktifTakvimAy={aktifTakvimAy}");
            }

            // ─── DİAGNOSTİK LOG 5: bekleyenOdemeler filtresi sonrası ───
            Console.WriteLine($"[DİAG-5] bekleyenOdemeler oluşturuldu: Count={bekleyenOdemeler.Count}, aktifTakvimAy={aktifTakvimAy}");
            if (_diagnostikSonOdemeId > 0)
            {
                var kayitVarMi = bekleyenOdemeler.Any(x => x.Id == _diagnostikSonOdemeId);
                Console.WriteLine($"[DİAG-5] bekleyenOdemeler içinde Id={_diagnostikSonOdemeId} var mı? {kayitVarMi}");
                if (!kayitVarMi)
                {
                    // Kayıt neden yok? Detaylı kontrol
                    var odemeKaydi = odemeler.FirstOrDefault(x => x.Id == _diagnostikSonOdemeId);
                    if (odemeKaydi == null)
                        Console.WriteLine($"[DİAG-5] ⚠ KAYIP: Id={_diagnostikSonOdemeId} odemeler listesinde hiç yok! GetOdemelerAsync filtresinde elendi.");
                    else
                        Console.WriteLine($"[DİAG-5] ⚠ KAYIP: Id={_diagnostikSonOdemeId} odemeler'de VAR ama bekleyenOdemeler filtresinde elendi. Kaydın Durum={odemeKaydi.Durum}, OdemeAy={odemeKaydi.OdemeAy}, aktifTakvimAy={aktifTakvimAy}");
                }
            }
            Console.WriteLine("═══════════════════════════════════════════");

            var krediOdemeler = odemeler.Where(o => o.TaksitliMi && (o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi)).ToList();
            krediTaksitToplam = krediOdemeler.Sum(o => o.Miktar);
            krediTaksitAdet = krediOdemeler.Count;

            // Onceki gun seciliyse, gun verilerini de guncelle
            if (oncekiSecilenGun.HasValue)
            {
                secilenGun = oncekiSecilenGun;
                var maxGun = DateTime.DaysInMonth(secilenYil, aktifTakvimAy);
                var gecerliGun = Math.Min(oncekiSecilenGun.Value, maxGun);
                secilenGun = gecerliGun;
                secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, gecerliGun);
                var gunData = takvimData?.FirstOrDefault(t => t.Gun == gecerliGun);
                secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor).ToList() ?? new List<BudgetOdeme>();
            }
            else
            {
                secilenGun = null;
                secilenGunOdemeleri.Clear();
            }

            // Kategori ve trend verilerini de güncelle
            await KategoriAnalizYukle();
            await TrendAnalizYukle();
            await HedefGerceklesenYukle();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HedefGerceklesenYukle()
    {
        var referans = GetReferansDonemBilgisi();
        if (referans is null)
        {
            hedefGerceklesen = new HedefGerceklesenOzet();
            return;
        }

        int? firmaId = secilenFirmaId > 0 ? secilenFirmaId : null;
        var referansOdemeler = await BudgetService.GetOdemelerAsync(referans.Value.Yil, referans.Value.Ay, firmaId);

        var gerceklesenToplam = ozet?.ToplamOdeme ?? odemeler.Sum(o => o.Miktar);
        var hedefToplam = referansOdemeler.Sum(o => o.Miktar);

        var gerceklesenKategori = odemeler
            .GroupBy(o => o.MasrafKalemi)
            .ToDictionary(g => g.Key, g => g.Sum(x => x.Miktar));

        var referansKategori = referansOdemeler
            .GroupBy(o => o.MasrafKalemi)
            .ToDictionary(g => g.Key, g => g.Sum(x => x.Miktar));

        var kategoriRenkleri = masrafKalemleri?
            .GroupBy(m => m.KalemAdi)
            .ToDictionary(g => g.Key, g => g.First().Renk) ?? new Dictionary<string, string?>();

        var satirlar = gerceklesenKategori.Keys
            .Union(referansKategori.Keys)
            .Select(k =>
            {
                var hedef = referansKategori.GetValueOrDefault(k, 0);
                var gerceklesen = gerceklesenKategori.GetValueOrDefault(k, 0);
                return new HedefGerceklesenKategoriSatir
                {
                    MasrafKalemi = k,
                    Renk = kategoriRenkleri.GetValueOrDefault(k),
                    HedefTutar = hedef,
                    GerceklesenTutar = gerceklesen
                };
            })
            .OrderByDescending(x => Math.Max(x.HedefTutar, x.GerceklesenTutar))
            .Take(8)
            .ToList();

        hedefGerceklesen = new HedefGerceklesenOzet
        {
            ReferansEtiketi = referans.Value.Etiket,
            HedefTutar = hedefToplam,
            GerceklesenTutar = gerceklesenToplam,
            Kategoriler = satirlar
        };
    }

    private (int Yil, int? Ay, string Etiket)? GetReferansDonemBilgisi()
