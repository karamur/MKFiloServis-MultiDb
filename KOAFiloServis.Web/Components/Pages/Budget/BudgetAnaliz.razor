        aiAnalizSuresi = "";
    }

    private string OlusturAiPrompt()
    {
        var sb = new System.Text.StringBuilder();

        // Dönem bilgisi
        var donem = secilenAy > 0
            ? $"{GetAyAdi(secilenAy)} {secilenYil}"
            : $"{secilenYil} Yılı";

        sb.AppendLine($"DÖNEM: {donem}");
        sb.AppendLine();

        // Özet bilgiler
        if (ozet != null)
        {
            sb.AppendLine("BÜTÇE ÖZETİ:");
            sb.AppendLine($"- Toplam Harcama: {ozet.ToplamOdeme:N2} TL ({ozet.ToplamKayit} kayıt)");
            sb.AppendLine($"- Ödenen: {ozet.OdenenToplam:N2} TL ({ozet.OdenenKayit} kayıt)");
            sb.AppendLine($"- Bekleyen: {ozet.BekleyenToplam:N2} TL ({ozet.BekleyenKayit} kayıt)");
            if (ozet.ToplamOdeme > 0)
                sb.AppendLine($"- Ödeme Oranı: %{(ozet.OdenenToplam / ozet.ToplamOdeme * 100):N1}");
            sb.AppendLine();
        }

        // Kategori verileri
        if (kategoriOzetleri.Count > 0)
        {
            sb.AppendLine("KATEGORİ DAĞILIMI:");
            foreach (var kat in kategoriOzetleri.OrderByDescending(k => k.Toplam).Take(15))
            {
                sb.AppendLine($"- {kat.MasrafKalemi}: {kat.Toplam:N2} TL (%{kat.Yuzde:N1}, {kat.Adet} adet)");
            }
            sb.AppendLine();
        }

        // Trend verileri
        if (trendData.Count > 0)
        {
            sb.AppendLine("AYLIK TREND:");
            foreach (var trend in trendData)
            {
                sb.AppendLine($"- {trend.Etiket}: Toplam {trend.Toplam:N2} TL, Ödenen {trend.Odenen:N2} TL, Bekleyen {trend.Bekleyen:N2} TL ({trend.OdemeSayisi} adet)");
            }
            sb.AppendLine();
        }

        // Kredi/taksit bilgisi
        if (krediTaksitAdet > 0)
        {
            sb.AppendLine($"KREDİ/TAKSİT: {krediTaksitAdet} adet bekleyen taksit, toplam {krediTaksitToplam:N2} TL");
            sb.AppendLine();
        }

        // Devir ödenmeyenler
        if (devirBekleyenOdemeler.Count > 0)
        {
            sb.AppendLine($"GECİKMİŞ ÖDEMELER: {devirBekleyenOdemeler.Count} adet önceki dönemlerden devir, toplam {devirBekleyenOdemeler.Sum(GetBekleyenTutar):N2} TL");
            sb.AppendLine();
        }

        // Analiz türüne göre talimat
        sb.AppendLine("---");
        sb.AppendLine(aiAnalizTuru switch
        {
