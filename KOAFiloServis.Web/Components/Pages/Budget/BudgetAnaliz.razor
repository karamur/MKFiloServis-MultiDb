    private string GetGorunenAciklama(BudgetOdeme? odeme)
    {
        if (odeme == null || string.IsNullOrWhiteSpace(odeme.Aciklama))
            return string.Empty;

        var aciklama = odeme.Aciklama.Trim();

        // OncekiDonemOdemeId olsun olmasın, [Devir] ve suffix'i temizle
        while (aciklama.StartsWith("[Devir]", StringComparison.OrdinalIgnoreCase))
        {
            aciklama = aciklama.Substring(7).TrimStart();
        }

        const string suffix = "Önceki dönemden kalan";
        if (aciklama.EndsWith(suffix, StringComparison.OrdinalIgnoreCase))
        {
            aciklama = aciklama[..^suffix.Length].TrimEnd().TrimEnd('-', ' ', ':');
        }

        return aciklama;
    }

    private void CariMahsupHesapDegisti()
    {
        if (!odemeYapRequest.BankaHesapId.HasValue || bankaHesaplari == null)
            return;

        var seciliHesap = bankaHesaplari.FirstOrDefault(h => h.Id == odemeYapRequest.BankaHesapId.Value);
        if (seciliHesap == null)
            return;

        odemeYapRequest.MuhasebeHesapKodu = seciliHesap.VarsayilanMuhasebeKodu ?? string.Empty;
        odemeYapRequest.KostMerkeziKodu = seciliHesap.VarsayilanKostMerkezi ?? string.Empty;
    }

