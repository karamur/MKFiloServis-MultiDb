@page "/operasyon-giris"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer

<PageTitle>Operasyon Girişi</PageTitle>

<style>
    .ops-table { font-size: .82rem; }
    .ops-table th { font-size: .78rem; padding: 6px 8px; background: #f0f4f8; white-space: nowrap; }
    .ops-table td { padding: 4px 8px; vertical-align: middle; }
    .ops-table input.form-select, .ops-table select.form-select { font-size: .80rem; padding: 2px 6px; }
    .ops-table input[type=number] { width: 56px; text-align: center; font-size: .80rem; }
    .satir-degisik { background: #e8f5e9 !important; }
    .satir-yeni-eklendi { background: #d4edda !important; transition: background 2s ease; }
    @@keyframes highlight-fade { from { background-color: #b7e4c7; } to { background-color: transparent; } }
    .satir-yeni-eklendi { animation: highlight-fade 2s ease forwards; }
    .autocomplete-dropdown { z-index: 1050; max-height: 200px; overflow: auto; }
    .slot-btn { min-width: 60px; font-size: .78rem; padding: 2px 8px; }
    .slot-btn.active { box-shadow: 0 0 0 2px #0d6efd; }
</style>

<div class="container-fluid px-3">

    @* ── Başlık ────────────────────────────────────────────────────────────── *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="bi bi-journal-text me-2 text-primary"></i>Operasyon Girişi</h4>
            <p class="text-muted small mb-0">Günlük araç / şoför sefer operasyon kaydı</p>
        </div>
        <div class="d-flex gap-2">
            @if (degisiklikVar)
            {
                <button class="btn btn-success" @onclick="TopluKaydet" disabled="@kaydediliyor">
                    @if (kaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    else { <i class="bi bi-floppy me-1"></i> }
                    Tümünü Kaydet (@degisikSatirlar.Count)
                </button>
            }
        </div>
    </div>

    @* ── Hata Mesajı ───────────────────────────────────────────────────────── *@
    @if (!string.IsNullOrEmpty(hataMesaji))
    {
        <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> @hataMesaji
            <button type="button" class="btn-close" @onclick="() => hataMesaji = null"></button>
        </div>
    }

    @* ── Filtre Barı ───────────────────────────────────────────────────────── *@
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                @* Tarih *@
                <div class="col-auto">
                    <label class="form-label small mb-1">Tarih</label>
                    <div class="input-group input-group-sm">
                        <button class="btn btn-outline-secondary" @onclick="OncekiGun"><i class="bi bi-chevron-left"></i></button>
                        <input type="date" class="form-control" style="width:150px"
                               value="@seciliTarih.ToString("yyyy-MM-dd")"
                               @onchange="TarihDegisti" />
                        <button class="btn btn-outline-secondary" @onclick="SonrakiGun"><i class="bi bi-chevron-right"></i></button>
                        <button class="btn btn-outline-primary" @onclick="BuguneGit">Bugün</button>
                    </div>
                </div>

                @* Kurum Autocomplete *@
                <div class="col">
                    <label class="form-label small mb-1">Kurum</label>
                    <div class="position-relative">
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" placeholder="Kurum adı yazın..."
                                   value="@kurumArama" @oninput="KurumAramaGuncelle" autocomplete="off" />
                            @if (seciliKurumId.HasValue)
                            {
                                <button class="btn btn-outline-secondary" @onclick="KurumTemizle"><i class="bi bi-x"></i></button>
                            }
                        </div>
                        @if (kurumOnerileri.Any() && !seciliKurumId.HasValue)
                        {
                            <div class="list-group position-absolute w-100 shadow-sm autocomplete-dropdown">
                                @foreach (var k in kurumOnerileri)
                                {
                                    <button type="button" class="list-group-item list-group-item-action py-1 px-2 small"
                                            @onclick="() => KurumSec(k)">
                                        <strong>@k.KurumAdi</strong>
                                        @if (!string.IsNullOrEmpty(k.UnvanTam) && k.UnvanTam != k.KurumAdi)
                                        {
                                            <span class="text-muted ms-1">@k.UnvanTam</span>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>

                @* Güzergah Dropdown *@
                <div class="col-auto">
                    <label class="form-label small mb-1">Güzergah</label>
                    <select class="form-select form-select-sm" style="min-width:200px"
                            @onchange="GuzergahDegisti">
                        <option value="">Tümü</option>
                        @foreach (var g in guzergahListesi.OrderBy(g => g.GuzergahAdi))
                        {
                            <option value="@g.Id" selected="@(seciliGuzergahId == g.Id)">@g.GuzergahAdi</option>
                        }
                    </select>
                </div>

                @* Bilgi *@
                <div class="col-auto ms-auto">
                    <div class="text-end">
                        <small class="text-muted">@tarihGoster</small><br />
                        <span class="badge bg-info">@operasyonlar.Count operasyon</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Toolbar ───────────────────────────────────────────────────────────── *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <button class="btn btn-primary btn-sm" @onclick="YeniKayitFormAc" disabled="@yukleniyor">
            <i class="bi bi-plus-lg me-1"></i> Yeni Operasyon Ekle
        </button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="OncekiGunKopyala" disabled="@yukleniyor">
            <i class="bi bi-clipboard me-1"></i> Önceki Gün Kopyala
        </button>
        <small class="text-muted">
            @if (degisikSatirlar.Count > 0)
            {
                <span class="text-success"><i class="bi bi-pencil-square me-1"></i>@degisikSatirlar.Count değişiklik</span>
            }
        </small>
    </div>

    @* ── Yeni Kayıt Formu (inline) ─────────────────────────────────────────── *@
    @if (yeniKayitFormAcik)
    {
        <div class="card border-primary mb-3">
            <div class="card-header py-2 bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                <strong class="small"><i class="bi bi-plus-circle me-1"></i>Yeni Operasyon</strong>
                <button class="btn-close btn-sm" @onclick="YeniKayitIptal"></button>
            </div>
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    @* Güzergah Dropdown *@
                    <div class="col-auto">
                        <label class="form-label small mb-1">Güzergah *</label>
                        <select class="form-select form-select-sm" style="min-width:180px"
                                value="@yeniKayit.GuzergahId"
                                @onchange="YeniGuzergahDegisti">
                            <option value="0">— Seçiniz —</option>
                            @foreach (var g in guzergahListesi.OrderBy(g => g.GuzergahAdi))
                            {
                                <option value="@g.Id" selected="@(yeniKayit.GuzergahId == g.Id)">@g.GuzergahAdi</option>
                            }
                        </select>
                    </div>

                    @* Araç Autocomplete *@
                    <div class="col">
                        <label class="form-label small mb-1">Araç *</label>
                        <div class="position-relative">
                            <input type="text" class="form-control form-control-sm" placeholder="Plaka yazın..."
                                   value="@yeniAracArama" @oninput="YeniAracAramaGuncelle" autocomplete="off" />
                            @if (yeniAracOnerileri.Any())
                            {
                                <div class="list-group position-absolute w-100 shadow-sm autocomplete-dropdown">
                                    @foreach (var a in yeniAracOnerileri)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action py-1 px-2 small"
                                                @onclick="() => YeniAracSec(a)">
                                            <strong>@(a.AktifPlaka ?? a.Plaka)</strong>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* Şoför Autocomplete *@
                    <div class="col">
                        <label class="form-label small mb-1">Şoför</label>
                        <div class="position-relative">
                            <input type="text" class="form-control form-control-sm" placeholder="Şoför adı yazın..."
                                   value="@yeniSoforArama" @oninput="YeniSoforAramaGuncelle" autocomplete="off" />
                            @if (yeniSoforOnerileri.Any())
                            {
                                <div class="list-group position-absolute w-100 shadow-sm autocomplete-dropdown">
                                    @foreach (var s in yeniSoforOnerileri)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action py-1 px-2 small"
                                                @onclick="() => YeniSoforSec(s)">
                                            <strong>@s.Ad @s.Soyad</strong>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* Slot Seçimi *@
                    <div class="col-auto">
                        <label class="form-label small mb-1">Slot</label>
                        <div class="btn-group btn-group-sm">
                            @foreach (var sl in new[] { SeferSlot.Sabah, SeferSlot.Aksam, SeferSlot.Mesai })
                            {
                                <button type="button"
                                        class="btn slot-btn @(yeniKayit.Slot == sl ? "btn-primary active" : "btn-outline-primary")"
                                        @onclick="() => YeniSlotSec(sl)">
                                    @SlotAd(sl)
                                </button>
                            }
                        </div>
                    </div>

                    @* Sefer Sayısı *@
                    <div class="col-auto">
                        <label class="form-label small mb-1">Sefer</label>
                        <input type="number" class="form-control form-control-sm" style="width:70px"
                               min="0" max="10" value="@yeniKayit.SeferSayisi"
                               @onchange="e => { if(int.TryParse(e?.Value?.ToString(), out var v)) yeniKayit.SeferSayisi = v; }" />
                    </div>

                    @* Puantaj Çarpanı *@
                    <div class="col-auto">
                        <label class="form-label small mb-1">Çarpan</label>
                        <input type="number" class="form-control form-control-sm" style="width:70px"
                               min="0.1" max="10" step="0.1" value="@yeniKayit.PuantajCarpani"
                               @onchange="e => { if(decimal.TryParse(e?.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v) && v > 0 && v <= 10) yeniKayit.PuantajCarpani = v; }" />
                    </div>

                    @* Ekle Butonu *@
                    <div class="col-auto">
                        <button class="btn btn-primary btn-sm" @onclick="YeniKayitEkle">
                            <i class="bi bi-plus-lg me-1"></i> Ekle
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Operasyon Grid ───────────────────────────────────────────────────── *@
    @if (yukleniyor)
    {
        <div class="text-center py-5 text-muted">
            <span class="spinner-border spinner-border-sm me-2"></span>Yükleniyor...
        </div>
    }
    else if (!operasyonlar.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox display-4 d-block mb-2"></i>
            Bu tarihte operasyon kaydı bulunamadı.
        </div>
    }
    else
    {
        <div class="table-responsive" style="max-height:60vh; overflow-y:auto;">
            <table class="table table-sm table-hover ops-table align-middle mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="width:40px">#</th>
                        <th style="width:85px">Tarih</th>
                        <th>Kurum</th>
                        <th>Güzergah</th>
                        <th style="width:75px">Slot</th>
                        <th>Araç</th>
                        <th>Şoför</th>
                        <th style="width:60px">Sefer</th>
                        <th style="width:65px">Çarpan</th>
                        <th style="width:90px">Durum</th>
                        <th style="width:45px">Kaynak</th>
                        <th style="width:50px"></th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int sira = 0;
                    }
                    @foreach (var o in operasyonlar.OrderByDescending(o => o.CreatedAt).ThenBy(o => o.GuzergahId).ThenBy(o => o.Slot))
                    {
                        sira++;
                        <tr class="@RowClass(o)">
                            <td class="text-muted small">@sira</td>

                            @* Tarih *@
                            <td><span class="fw-medium small">@o.Tarih.ToString("dd.MM.yyyy HH:mm")</span></td>

                            @* Kurum *@
                            <td><span class="small">@KurumAdi(o)</span></td>

                            @* Güzergah *@
                            <td><span class="small">@GuzergahAdi(o)</span></td>

                            @* Slot (inline edit) *@
                            <td>
                                <select class="form-select form-select-sm py-0" style="font-size:.76rem"
                                        @onchange="e => SlotDegisti(o, e)">
                                    @foreach (var sl in Enum.GetValues<SeferSlot>())
                                    {
                                        <option value="@sl" selected="@(o.Slot == sl)">@SlotAd(sl)</option>
                                    }
                                </select>
                            </td>

                            @* Araç *@
                            <td><span class="fw-medium small">@AracPlaka(o)</span></td>

                            @* Şoför *@
                            <td><span class="small">@SoforAdi(o)</span></td>

                            @* Sefer Sayısı (inline edit) *@
                            <td>
                                <input type="number" class="form-control form-control-sm py-0" style="width:48px;font-size:.78rem"
                                       min="0" max="10"
                                       value="@o.SeferSayisi"
                                       @onchange="e => SeferSayisiDegisti(o, e)" />
                            </td>

                            @* Puantaj Çarpanı (inline edit) *@
                            <td>
                                <input type="number" class="form-control form-control-sm py-0" style="width:55px;font-size:.78rem"
                                       min="0.1" max="10" step="0.1"
                                       value="@o.PuantajCarpani"
                                       @onchange="e => PuantajCarpaniDegisti(o, e)" />
                            </td>

                            @* Durum (inline edit) *@
                            <td>
                                <select class="form-select form-select-sm py-0" style="font-size:.76rem"
                                        @onchange="e => DurumDegisti(o, e)">
                                    @foreach (var d in Enum.GetValues<OperasyonDurumu>())
                                    {
                                        <option value="@d" selected="@(o.OperasyonDurumu == d)">@DurumAd(d)</option>
                                    }
                                </select>
                            </td>

                            @* Kaynak *@
                            <td class="text-center">
                                @if (o.Kaynak == PuantajKaynak.Puantaj)
                                { <span class="badge bg-info" title="Puantajdan oluşturuldu">P</span> }
                                else if (o.Kaynak == PuantajKaynak.ExcelImport)
                                { <span class="badge bg-success" title="Excel import">E</span> }
                                else
                                { <span class="badge bg-secondary" title="Manuel">M</span> }
                                @if (o.KullaniciKilitliMi)
                                { <i class="bi bi-lock-fill text-warning small ms-1" title="Kullanıcı tarafından kilitlendi"></i> }
                            </td>

                            @* Kilit *@
                            <td class="text-center">
                                @if (o.Kaynak == PuantajKaynak.Puantaj)
                                {
                                    @if (o.KullaniciKilitliMi)
                                    {
                                        <button class="btn btn-outline-warning btn-sm py-0 px-1" title="Kilit Aç"
                                                @onclick="() => KilitToggle(o)">
                                            <i class="bi bi-unlock-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Kilitle"
                                                @onclick="() => KilitToggle(o)">
                                            <i class="bi bi-lock"></i>
                                        </button>
                                    }
                                }
                            </td>

                            @* Sil *@
                            <td>
                                <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Sil"
                                        @onclick="() => SatirSil(o)">
                                    <i class="bi bi-trash small"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-secondary fw-bold" style="font-size:.80rem">
                    <tr>
                        <td colspan="2" class="text-end">Toplam: @operasyonlar.Count kayıt</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td class="text-center">@operasyonlar.Sum(o => o.SeferSayisi)</td>
                        <td class="text-center">@operasyonlar.Sum(o => o.SeferSayisi * o.PuantajCarpani).ToString("0.##")</td>
                        <td></td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>
