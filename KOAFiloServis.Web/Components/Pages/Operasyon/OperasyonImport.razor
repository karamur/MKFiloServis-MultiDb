@page "/operasyon/import"
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer

<PageTitle>Operasyon Excel Import | KOA Filo Servis</PageTitle>

<div class="container-fluid px-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Operasyon Excel Import</h4>
            <p class="text-muted small mb-0">Excel ile toplu operasyon kaydı girişi</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-info btn-sm" @onclick="SablonIndir">
                <i class="bi bi-download me-1"></i>Şablon İndir
            </button>
            <a href="/operasyon-giris" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Operasyon Girişi
            </a>
        </div>
    </div>

    <div class="row g-4">
        @* ── Sol Panel: Upload ────────────────────────────────────── *@
        <div class="col-md-5">
            <div class="card">
                <div class="card-header"><strong><i class="bi bi-upload me-1"></i>1. Excel Yükle</strong></div>
                <div class="card-body">
                    <div class="alert alert-info py-2 small">
                        <i class="bi bi-info-circle me-1"></i>
                        Şablonu indirip doldurun. <strong>Plaka</strong>, <strong>Güzergah</strong> ve <strong>Tarih</strong> zorunludur.
                    </div>

                    <div class="mb-3">
                        <label class="form-label small">Excel Dosyası (.xlsx)</label>
                        <InputFile class="form-control form-control-sm" OnChange="DosyaSecildi" accept=".xlsx,.xls" />
                        @if (importFile != null)
                        {
                            <small class="text-muted">@importFile.Name (@(importFile.Size / 1024) KB)</small>
                        }
                    </div>

                    <button class="btn btn-success w-100" @onclick="VeriOnizle" disabled="@(importFile == null || isliyor)">
                        @if (isliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-search me-1"></i>Veriyi Önizle
                    </button>
                </div>
            </div>

            @* ── Özet Kartları ────────────────────────────────────── *@
            @if (sonuclar.Any())
            {
                <div class="card mt-3">
                    <div class="card-header"><strong><i class="bi bi-bar-chart me-1"></i>Özet</strong></div>
                    <div class="card-body py-2">
                        <div class="row g-2 text-center">
                            <div class="col-4">
                                <div class="border rounded p-2 bg-success bg-opacity-10">
                                    <h5 class="mb-0 text-success">@gecerliSayi</h5>
                                    <small class="text-muted">Geçerli</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-2 bg-danger bg-opacity-10">
                                    <h5 class="mb-0 text-danger">@hataliSayi</h5>
                                    <small class="text-muted">Hatalı</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-2 bg-warning bg-opacity-10">
                                    <h5 class="mb-0 text-warning">@atlananSayi</h5>
                                    <small class="text-muted">Atlandı</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Sağ Panel: Preview ──────────────────────────────────── *@
        <div class="col-md-7">
            @if (isliyor)
            {
                <div class="text-center py-5 text-muted">
                    <span class="spinner-border spinner-border-sm me-2"></span>Excel okunuyor, lookup'lar çözülüyor...
                </div>
            }
            else if (!string.IsNullOrEmpty(hataMesaji))
            {
                <div class="alert alert-danger py-2">
                    <i class="bi bi-exclamation-triangle me-1"></i> @hataMesaji
                </div>
            }
            else if (sonuclar.Any())
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <strong><i class="bi bi-table me-1"></i>2. Önizleme (@sonuclar.Count satır)</strong>
                        @if (!kaydedildi)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="TopluKaydet"
                                    disabled="@(isliyor || gecerliSayi == 0)">
                                @if (isliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-save me-1"></i>
                                Kaydet (@gecerliSayi geçerli)
                            </button>
                        }
                        else
                        {
                            <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>Kaydedildi</span>
                        }
                    </div>
                    <div class="card-body p-0" style="max-height:60vh;overflow-y:auto">
                        <table class="table table-sm table-striped small mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>#</th><th>Plaka</th><th>Güzergah</th><th>Tarih</th><th>Sonuç</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < sonuclar.Count; i++)
                                {
                                    var s = sonuclar[i];
                                    <tr class="@(s.Atlandi ? "table-warning" : !s.Basarili ? "table-danger" : "")">
                                        <td>@s.SatirNo</td>
                                        <td><strong>@s.Plaka</strong></td>
                                        <td>@s.GuzergahAdi</td>
                                        <td>—</td>
                                        <td>
                                            @if (s.Atlandi)
                                            { <span class="badge bg-warning text-dark">Atlandı (duplicate)</span> }
                                            else if (s.Basarili)
                                            { <span class="badge bg-success">Geçerli</span> }
                                            else
                                            { <span class="badge bg-danger" title="@s.HataMesaji">Hata</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else if (!isliyor && importFile == null)
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-arrow-up-circle display-4 d-block mb-2"></i>
                    Excel dosyası seçip <strong>Veriyi Önizle</strong> butonuna tıklayın.
                </div>
            }
        </div>
    </div>
</div>
