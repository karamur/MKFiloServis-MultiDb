@page "/operasyonlar/hakedis-puantaj"
@page "/operasyon/hakedis-puantaj"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IHakedisPuantajService HakedisService
@inject IFirmaService FirmaService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject IAracService AracService
@inject ICariService CariService
@inject IHakedisMuhasebeService HakedisMuhasebeService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Hakedis Puantajlari</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-calculator me-2 text-success"></i>Hakedis Puantajlari</h4>
        <div class="btn-group">
            <button class="btn btn-success" @onclick="YeniHakedis"><i class="bi bi-plus-lg me-1"></i>Yeni Hakedis</button>
            <button class="btn btn-outline-secondary" @onclick="LoadData"><i class="bi bi-arrow-clockwise me-1"></i>Yenile</button>
        </div>
    </div>
    <div class="card mb-3"><div class="card-body py-2"><div class="row g-2">
        <div class="col-md-2"><select class="form-select form-select-sm" @bind="filtreYil"><option value="0">-- Yil --</option>
            @for (int y = DateTime.Now.Year - 1; y <= DateTime.Now.Year + 1; y++) { <option value="@y">@y</option> }</select></div>
        <div class="col-md-2"><select class="form-select form-select-sm" @bind="filtreAy"><option value="0">-- Ay --</option>
            @for (int m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2024,m,1).ToString("MMMM"))</option> }</select></div>
        <div class="col-md-2"><button class="btn btn-sm btn-primary" @onclick="LoadData"><i class="bi bi-search me-1"></i>Filtrele</button></div>
    </div></div></div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (hakedisler != null)
    {
        <div class="card"><div class="card-body p-0" style="overflow-x: auto;">
        <table class="table table-sm table-bordered mb-0" style="font-size:12px;white-space:nowrap;">
        <thead class="table-dark"><tr>
            <th>S.No</th><th style="min-width:140px;">Guzergah</th><th>Gelir</th><th>Gider</th><th>Yon</th>
            <th>Plaka</th><th>Sofor</th><th>Tedarikci</th>
            @for (int g = 1; g <= gunSayisi; g++) { <th style="width:34px;text-align:center;">@g</th> }
            <th>Gun</th><th>Toplam</th><th>KDV%</th><th>Kesinti</th><th>Odenecek</th><th>Durum</th><th>Islemler</th>
        </tr></thead>
        <tbody>
        @{ int sira = 0; }
        @foreach (var h in hakedisler)
        {
            sira++;
            var detayDict = h.Detaylar?.ToDictionary(d => d.Gun) ?? new();
            <tr>
                <td class="text-center">@sira</td>
                <td>@(h.Guzergah?.GuzergahAdi ?? h.GuzergahId.ToString())</td>
                <td class="text-end">@h.GelirBirimFiyat.ToString("N0")</td>
                <td class="text-end">@h.GiderBirimFiyat.ToString("N0")</td>
                <td class="text-center"><span class="badge @(h.YonTipi == YonTipi.SabahAksam ? "bg-primary" : "bg-info")">@(h.YonTipi.ToString())</span></td>
                <td>@(h.Arac?.Plaka ?? "")</td>
                <td>@(h.Sofor?.TamAd ?? "")</td>
                <td>@(h.Cari?.Unvan ?? "")</td>
                @for (int g = 1; g <= gunSayisi; g++)
                {
                    var d = detayDict.GetValueOrDefault(g);
                    var sf = d?.SeferSayisi ?? 0;
                    var bg = d?.EkSeferMi == true ? "bg-warning text-dark" : d?.MesaiMi == true ? "bg-info text-dark" : sf > 0 ? "bg-success" : "";
                    <td class="text-center @bg" style="cursor:pointer;" @onclick="() => GunTikla(h, g)">@(sf > 0 ? sf.ToString() : "")</td>
                }
                <td class="text-center fw-bold">@h.ToplamSefer</td>
                <td class="text-end fw-bold">@h.GiderToplam.ToString("N0")</td>
                <td class="text-center">%@h.KdvOrani</td>
                <td class="text-end text-danger">@h.ToplamKesinti.ToString("N0")</td>
                <td class="text-end fw-bold text-success">@h.OdenecekTutar.ToString("N0")</td>
                <td class="text-center">
                    @switch (h.Durum)
                    {
                        case HakedisDurumu.Taslak:
                            <span class="badge bg-secondary">Taslak</span>
                            break;
                        case HakedisDurumu.OnayBekliyor:
                            <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                            break;
                        case HakedisDurumu.Onaylandi:
                            <span class="badge bg-success">Onaylandı</span>
                            break;
                        default:
                            <span class="badge bg-info">@h.Durum</span>
                            break;
                    }
                </td>
                <td>
                    <div class="btn-group btn-group-sm">
                        @if (h.Durum == HakedisDurumu.Taslak)
                        {
                            <button class="btn btn-outline-warning" @onclick="() => OnayaGonder(h)" title="Onaya Gönder">
                                <i class="bi bi-send"></i>
                            </button>
                        }
                        @if (h.Durum == HakedisDurumu.OnayBekliyor)
                        {
                            <button class="btn btn-outline-success" @onclick="() => Onayla(h)" title="Onayla">
                                <i class="bi bi-check2-circle"></i>
                            </button>
                        }
                        @if (h.Durum == HakedisDurumu.Onaylandi && !h.MuhasebeyeAktarildiMi)
                        {
                            <button class="btn btn-outline-primary" @onclick="() => MuhasebeyeAktar(h)" title="Muhasebeye Aktar">
                                <i class="bi bi-journal-arrow-up"></i>
                            </button>
                        }
                        <button class="btn btn-outline-danger" @onclick="() => Sil(h)" title="Sil">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        }
        </tbody></table></div></div>
    } else { <div class="text-center py-5"><div class="spinner-border text-primary"></div></div> }
</div>

@if (showModal && model != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header bg-success text-white"><h5 class="modal-title">Yeni Hakedis</h5><button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button></div>
    <div class="modal-body">
        @* Modal içinde errorMessage göster *@
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger py-2 mb-3">
                <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
            </div>
        }
        <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Yil <span class="text-danger">*</span></label>
            <InputNumber @bind-Value="model.Yil" class="@YilInputClass" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Ay <span class="text-danger">*</span></label>
            <InputNumber @bind-Value="model.Ay" class="@AyInputClass" min="1" max="12" />
        </div>
        <div class="col-md-3"><label class="form-label">KDV %</label><InputNumber @bind-Value="model.KdvOrani" class="form-control form-control-sm" /></div>
        <div class="col-md-3"><label class="form-label">Yon</label>
            <select class="form-select form-select-sm" value="@((int)model.YonTipi)" @onchange="YonDegisti">
                <option value="@((int)YonTipi.Sabah)">Sabah (1 sefer)</option>
                <option value="@((int)YonTipi.Aksam)">Aksam (1 sefer)</option>
                <option value="@((int)YonTipi.SabahAksam)">Sabah+Aksam (2 sefer)</option>
            </select></div>
    </div><div class="row g-2 mt-2">
        <div class="col-md-4">
            <label class="form-label">Guzergah <span class="text-danger">*</span></label>
            <select class="form-select form-select-sm @(triedSubmit && model.GuzergahId <= 0 ? "border-danger" : "")" value="@model.GuzergahId" @onchange="GuzergahSecildi"><option value="0">-- Secin --</option>
                @foreach (var g in guzergahlar) { <option value="@g.Id">@g.GuzergahAdi</option> }</select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Gelir Fiyat <span class="text-danger">*</span></label>
            <InputNumber @bind-Value="model.GelirBirimFiyat" class="@GelirInputClass" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Gider Fiyat <span class="text-danger">*</span></label>
            <InputNumber @bind-Value="model.GiderBirimFiyat" class="@GiderInputClass" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Tedarikci <span class="text-danger">*</span></label>
            <select class="form-select form-select-sm @(triedSubmit && model.CariId <= 0 ? "border-danger" : "")" @bind="model.CariId"><option value="0">-- Secin --</option>
                @foreach (var c in cariler) { <option value="@c.Id">@c.Unvan</option> }</select>
        </div>
    </div><div class="row g-2 mt-2">
        <div class="col-md-3">
            <label class="form-label">Arac <span class="text-danger">*</span></label>
            <select class="form-select form-select-sm @(triedSubmit && model.AracId <= 0 ? "border-danger" : "")" @bind="model.AracId"><option value="0">-- Secin --</option>
            @foreach (var a in araclar) { <option value="@a.Id">@a.Plaka</option> }</select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Sofor <span class="text-danger">*</span></label>
            <select class="form-select form-select-sm @(triedSubmit && model.SoforId <= 0 ? "border-danger" : "")" @bind="model.SoforId"><option value="0">-- Secin --</option>
            @foreach (var s in soforler) { <option value="@s.Id">@s.TamAd</option> }</select>
        </div>
        <div class="col-md-6"><label class="form-label">Aciklama</label><input class="form-control form-control-sm" @bind="model.Aciklama" /></div>
    </div></div>
    <div class="modal-footer">
        <button class="btn btn-primary" @onclick="Kaydet" disabled="@kaydediyor">
            @if (kaydediyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-check-lg me-1"></i>Olustur
        </button>
        <button class="btn btn-danger" @onclick="ModalKapat" disabled="@kaydediyor">Iptal</button>
    </div>
    </div></div></div>
}

@if (showGunModal && model != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-sm"><div class="modal-content">
    <div class="modal-header bg-info text-white"><h5 class="modal-title">Gun @seciliGun</h5><button type="button" class="btn-close btn-close-white" @onclick="() => showGunModal = false"></button></div>
    <div class="modal-body"><div class="mb-2"><label class="form-label">Sefer Turu</label>
        <select class="form-select form-select-sm" @bind="gunSeferTuruId" @bind:event="oninput" @onchange="SeferTuruDegisti">
            <option value="0">-- Standart --</option>
            @foreach (var st in seferTurleri) { <option value="@st.Id">@st.Kod - @st.Ad</option> }</select></div>
        <div class="mb-2"><label class="form-label">Sefer Sayisi</label><InputNumber @bind-Value="gunSeferSayisi" class="form-control form-control-sm" min="0" /></div>
        <div class="mb-2"><label class="form-label">Aciklama</label><input class="form-control form-control-sm" @bind="gunAciklama" /></div>
    </div><div class="modal-footer"><button class="btn btn-primary" @onclick="GunKaydet"><i class="bi bi-check-lg me-1"></i>Kaydet</button>
    <button class="btn btn-secondary" @onclick="() => showGunModal = false">Kapat</button></div>
    </div></div></div>
}

@code {
    private List<KOAFiloServis.Shared.Entities.HakedisPuantaj>? hakedisler;
    private KOAFiloServis.Shared.Entities.HakedisPuantaj? model;
    private List<Guzergah> guzergahlar = new();
    private List<Arac> araclar = new();
    private List<Sofor> soforler = new();
    private List<Cari> cariler = new();
    private List<HakedisSeferTuru> seferTurleri = new();
    private bool showModal, showGunModal;
    private int seciliGun, gunSeferSayisi, gunSeferTuruId;
    private string? gunAciklama;
    private int filtreYil, filtreAy;
    private string? errorMessage;
    private string? successMessage;
    private bool kaydediyor;
    // Client-side validation tracking
    private bool triedSubmit;
    private int gunSayisi => model != null ? DateTime.DaysInMonth(model.Yil, model.Ay) : 30;

    // InputNumber helper CSS classes (component attributes can't use inline @(ternary) expressions)
    private string YilInputClass => triedSubmit && (model != null && (model.Yil < 2020 || model.Yil > 2100))
        ? "form-control form-control-sm border-danger"
        : "form-control form-control-sm";
    private string AyInputClass => triedSubmit && (model != null && (model.Ay < 1 || model.Ay > 12))
        ? "form-control form-control-sm border-danger"
        : "form-control form-control-sm";
    private string GelirInputClass => triedSubmit && (model != null && model.GelirBirimFiyat < 0)
        ? "form-control form-control-sm border-danger"
        : "form-control form-control-sm";
    private string GiderInputClass => triedSubmit && (model != null && model.GiderBirimFiyat < 0)
        ? "form-control form-control-sm border-danger"
        : "form-control form-control-sm";

    protected override async Task OnInitializedAsync()
    {
        filtreYil = DateTime.Now.Year;
        filtreAy = DateTime.Now.Month;
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            errorMessage = null;
            hakedisler = await HakedisService.GetAllAsync(yil: filtreYil == 0 ? null : filtreYil, ay: filtreAy == 0 ? null : filtreAy);
            guzergahlar = await GuzergahService.GetAllAsync();
            araclar = (await AracService.GetAllAsync()).Where(a => a.Aktif).ToList();
            soforler = await SoforService.GetActiveAsync();
            cariler = await CariService.GetAllAsync();
            seferTurleri = hakedisler?
                .SelectMany(h => h.Detaylar ?? new List<HakedisPuantajDetay>())
                .Where(d => d.SeferTuru != null)
                .Select(d => d.SeferTuru!)
                .DistinctBy(s => s.Id)
                .OrderBy(s => s.Kod)
                .ToList() ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine(ex);
            ToastService.ShowError(ex.Message);
        }
    }

    /// <summary>
    /// Aktif firma kontrolü yaparak yeni hakediş formunu açar.
    /// </summary>
    private void YeniHakedis()
    {
        errorMessage = null;
        successMessage = null;
        triedSubmit = false;

        var aktifFirma = FirmaService.GetAktifFirma();
        if (aktifFirma.FirmaId <= 0)
        {
            errorMessage = "Önce aktif firma seçmelisiniz. Lütfen üst menüden çalışacağınız firmayı seçin.";
            ToastService.ShowWarning("Aktif firma seçilmeden hakediş oluşturulamaz.");
            return;
        }

        model = new KOAFiloServis.Shared.Entities.HakedisPuantaj
        {
            Yil = filtreYil,
            Ay = filtreAy,
            YonTipi = YonTipi.SabahAksam,
            GunlukSeferSayisi = 2,
            KdvOrani = 20
        };
        Console.WriteLine($"[HakedisUI] Yeni hakediş formu açıldı. AktifFirmaId={aktifFirma.FirmaId}, Yil={filtreYil}, Ay={filtreAy}");
        showModal = true;
    }

    private void ModalKapat()
    {
        showModal = false;
        model = null;
        triedSubmit = false;
        errorMessage = null;
    }

    private void YonDegisti(ChangeEventArgs e)
    {
        if (model == null) return;

        if (int.TryParse(e.Value?.ToString(), out var yonInt) && Enum.IsDefined(typeof(YonTipi), yonInt))
            model.YonTipi = (YonTipi)yonInt;

        model.GunlukSeferSayisi = model.YonTipi switch { YonTipi.Sabah => 1, YonTipi.Aksam => 1, _ => 2 };
    }

    private async Task GuzergahSecildi(ChangeEventArgs e) {
        if (model == null) return;
        model.GuzergahId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        if (model.GuzergahId == 0) return;
        var g = guzergahlar.FirstOrDefault(x => x.Id == model.GuzergahId);
        if (g != null) {
            if (model.GelirBirimFiyat == 0 && g.BirimFiyat > 0) model.GelirBirimFiyat = g.BirimFiyat;
            if (model.GiderBirimFiyat == 0 && g.GiderFiyat > 0) model.GiderBirimFiyat = g.GiderFiyat;
            if (model.AracId == 0 && g.VarsayilanAracId.HasValue) model.AracId = g.VarsayilanAracId.Value;
            if (model.SoforId == 0 && g.VarsayilanSoforId.HasValue) model.SoforId = g.VarsayilanSoforId.Value;
            model.YonTipi = g.SeferTipi switch { SeferTipi.Sabah => YonTipi.Sabah, SeferTipi.Aksam => YonTipi.Aksam, SeferTipi.SabahAksam => YonTipi.SabahAksam, _ => YonTipi.SabahAksam };
            model.GunlukSeferSayisi = model.YonTipi switch { YonTipi.Sabah => 1, YonTipi.Aksam => 1, _ => 2 };
        }
    }

    /// <summary>
    /// İstemci tarafı zorunlu alan kontrolü. Service'e gitmeden önce kullanıcıya net mesaj verir.
    /// </summary>
    private string? ValidateModel()
    {
        if (model == null) return "Form verisi bulunamadı.";

        if (model.GuzergahId <= 0)
            return "Güzergah seçimi zorunludur. Lütfen bir güzergah seçin.";
        if (model.AracId <= 0)
            return "Araç seçimi zorunludur. Lütfen bir araç seçin.";
        if (model.SoforId <= 0)
            return "Şoför seçimi zorunludur. Lütfen bir şoför seçin.";
        if (model.CariId <= 0)
            return "Tedarikçi seçimi zorunludur. Lütfen bir tedarikçi (cari) seçin.";
        if (model.Yil < 2020 || model.Yil > 2100)
            return "Geçersiz yıl. Lütfen 2020-2100 arası bir yıl girin.";
        if (model.Ay < 1 || model.Ay > 12)
            return "Geçersiz ay. Lütfen 1-12 arası bir ay girin.";
        if (model.GelirBirimFiyat < 0)
            return "Gelir birim fiyat negatif olamaz.";
        if (model.GiderBirimFiyat < 0)
            return "Gider birim fiyat negatif olamaz.";
        if (model.KdvOrani < 0 || model.KdvOrani > 100)
            return "KDV oranı 0-100 arası olmalıdır.";

        return null; // Geçerli
    }

    private async Task Kaydet()
    {
        if (model == null) return;
        triedSubmit = true;

        // ADIM 1: İstemci validasyonu
        var validationError = ValidateModel();
        if (validationError != null)
        {
            errorMessage = validationError;
            ToastService.ShowWarning(validationError);
            Console.WriteLine($"[HakedisUI] İstemci validasyon hatası: {validationError}");
            return;
        }

        // ADIM 2: Kaydet
        kaydediyor = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var aktifFirma = FirmaService.GetAktifFirma();
            Console.WriteLine($"[HakedisUI] Kaydet başladı. FirmaId={aktifFirma.FirmaId}, Yil={model.Yil}, Ay={model.Ay}, GuzergahId={model.GuzergahId}, AracId={model.AracId}, SoforId={model.SoforId}, CariId={model.CariId}");

            var sonuc = await HakedisService.CreateAsync(model);

            Console.WriteLine($"[HakedisUI] Kaydedildi. Id={sonuc.Id}");
            successMessage = $"Hakediş başarıyla kaydedildi. Kayıt No: {sonuc.Id}";
            ToastService.ShowSuccess(successMessage);

            showModal = false;
            model = null;
            triedSubmit = false;
            kaydediyor = false;

            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            kaydediyor = false;
            errorMessage = ex.Message;
            Console.WriteLine($"[HakedisUI] Kaydet HATA: {ex.Message}");
            Console.WriteLine(ex);
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task Sil(KOAFiloServis.Shared.Entities.HakedisPuantaj h)
    {
        try
        {
            errorMessage = null;
            await HakedisService.DeleteAsync(h.Id);
            await LoadData();
            ToastService.ShowSuccess($"Hakediş silindi (ID: {h.Id}).");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine(ex);
            ToastService.ShowError(ex.Message);
        }
    }

    private void GunTikla(KOAFiloServis.Shared.Entities.HakedisPuantaj h, int gun)
    {
        errorMessage = null;
        model = h;
        seciliGun = gun;
        showGunModal = true;
        var d = h.Detaylar?.FirstOrDefault(x => x.Gun == gun);
        gunSeferSayisi = d?.SeferSayisi ?? 0;
        gunSeferTuruId = d?.SeferTuruId ?? 0;
        gunAciklama = d?.Aciklama;
    }

    private void SeferTuruDegisti(ChangeEventArgs e)
    {
        if (gunSeferTuruId > 0)
        {
            var s = seferTurleri.FirstOrDefault(x => x.Id == gunSeferTuruId);
            if (s != null)
                gunSeferSayisi = (int)s.VarsayilanSeferSayisi;
        }
    }

    private async Task GunKaydet()
    {
        if (model == null) return;

        decimal carpan = 1;
        bool mesai = false;
        bool ek = false;

        if (gunSeferTuruId > 0)
        {
            var s = seferTurleri.FirstOrDefault(x => x.Id == gunSeferTuruId);
            if (s != null)
            {
                carpan = s.FiyatCarpani;
                mesai = s.MesaiMi;
                ek = s.EkSeferMi;
            }
        }

        try
        {
            errorMessage = null;
            Console.WriteLine($"[HakedisUI] GunKaydet: HakedisId={model.Id}, Gun={seciliGun}, SeferSayisi={gunSeferSayisi}, SeferTuruId={gunSeferTuruId}");
            await HakedisService.GunlukSeferGuncelleAsync(model.Id, seciliGun, gunSeferSayisi, gunSeferTuruId > 0 ? gunSeferTuruId : null, carpan, mesai, ek, gunAciklama);
            Console.WriteLine($"[HakedisUI] GunKaydet başarılı: HakedisId={model.Id}, Gun={seciliGun}");
            showGunModal = false;
            await LoadData();
            ToastService.ShowSuccess($"Gün {seciliGun} güncellendi. Sefer sayısı: {gunSeferSayisi}");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"[HakedisUI] GunKaydet HATA: {ex.Message}");
            Console.WriteLine(ex);
            ToastService.ShowError(ex.Message);
        }
    }

