@page "/araclar/plaka-takip/{Id:int}/duzenle"
@page "/filo-operasyon/kiralik-c-plaka-takip/{Id:int}/duzenle"
@page "/filo-operasyon/kiralık-c-plaka-takip/{Id:int}/duzenle"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services.Interfaces
@inject IAracService AracService
@inject IKiralikPlakaTakipService TakipService
@inject NavigationManager NavManager
@using KOAFiloServis.Web.Services
@inject IToastService ToastService

@using System.Globalization

<PageTitle>@(_isEdit ? "Düzenle" : "Yeni") | Kiralık C Plaka</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/araclar">Araçlar</a></li>
                    <li class="breadcrumb-item"><a href="/araclar/plaka-takip">Plaka Takip</a></li>
                    <li class="breadcrumb-item active">@(_isEdit ? "Düzenle" : "Yeni")</li>
                </ol>
            </nav>
            <h3 class="mb-0"><i class="bi bi-card-text me-2"></i>@(_isEdit ? "Düzenle" : "Yeni Kayıt")</h3>
        </div>
    </div>

    @if(_loading) { <div class="text-center py-5"><div class="spinner-border"></div></div> }
    else {
        <EditForm Model="_model" OnSubmit="Kaydet">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Plaka</label>
                            <input class="form-control" @bind="_model.Plaka" @onblur="PlakadanAracEslestir" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Eşleşen Araç</label>
                            <select class="form-select" value="@(_model.AracId?.ToString() ?? "")"
                                    @onchange="OnAracSecildi">
                                <option value="">-- Eşleşme yok --</option>
                                @foreach (var a in _araclar)
                                {
                                    <option value="@a.Id">@a.AktifPlaka - @a.Marka @a.Model (@a.SaseNo)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">İsim Soyisim</label>
                            <input class="form-control" @bind="_model.IsimSoyisim" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Başlama Tarihi</label>
                            <input type="date" class="form-control" @bind="_model.BaslamaTarihi" @bind:after="OnTarihAraligiDegisti" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bitiş Tarihi</label>
                            <input type="date" class="form-control" @bind="_model.BitisTarihi" @bind:after="OnTarihAraligiDegisti" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Durum</label>
                            <input class="form-control" @bind="_model.Durum" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kasa Durumu</label>
                            <input class="form-control" @bind="_model.KasaDurumu" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fatura</label>
                            <input type="number" step="0.01" class="form-control" @bind="_model.FaturaOdemesi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Periyot (Aylık/Yıllık)</label>
                            <select class="form-select" @bind="_model.Periyot" @bind:after="OnPeriyotDegisti">
                                <option value="AYLIK">AYLIK</option>
                                <option value="YILLIK">YILLIK</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Periyot Tutarı</label>
                            <input type="number" step="0.01" class="form-control" @bind="_model.AylikVeyaYillikTutar" @bind:after="OnPlanParametreDegisti" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Sayısı</label>
                            <input type="number" min="1" class="form-control" @bind="_model.OdemeSayisi" @bind:after="OnOdemeSayisiDegisti" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Toplam (Fatura + Ek Tutar)</label>
                            <input type="text" class="form-control bg-light fw-bold" value="@GosterilenToplam.ToString("N2")" readonly />
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-table me-2"></i>Tek Birleşik Takip Listesi</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="BirlesikTakipPlaniniElleYenile">
                            <i class="bi bi-arrow-repeat me-1"></i>Planı Yenile
                        </button>
                    </h5>

                    <div class="card border-0 bg-light mb-3">
                        <div class="card-body py-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Ek Ödeme Girişleri</h6>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="EkOdemeSatiriEkle">
                                    <i class="bi bi-plus-lg me-1"></i>Ek Ödeme Ekle
                                </button>
                            </div>

                            @if (_ekOdemeSatirlari.Count == 0)
                            {
                                <div class="text-muted small">Ek ödeme yok. Gerekirse ilgili ay için ek satır ekleyin.</div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered mb-0 align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width:220px;">Dönem</th>
                                                <th style="width:180px;" class="text-end">Ek Ödeme Tutarı</th>
                                                <th>Açıklama</th>
                                                <th style="width:90px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < _ekOdemeSatirlari.Count; i++)
                                            {
                                                var satir = _ekOdemeSatirlari[i];
                                                <tr>
                                                    <td>
                                                        <select class="form-select form-select-sm" @bind="satir.DonemAnahtari" @bind:after="OnPlanParametreDegisti">
                                                            @foreach (var donem in GetPlanDonemSecenekleri())
                                                            {
                                                                <option value="@donem.Key">@donem.Label</option>
                                                            }
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="satir.Tutar" @bind:after="OnPlanParametreDegisti" />
                                                    </td>
                                                    <td>
                                                        <input class="form-control form-control-sm" @bind="satir.Aciklama" />
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EkOdemeSatiriSil(i)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th width="40">#</th>
                                    <th>Ay</th>
                                    <th class="text-end">Baz Plan</th>
                                    <th class="text-end">Ek Ödeme</th>
                                    <th class="text-end">Plan Tutarı</th>
                                    <th style="min-width:180px;">Fatura No</th>
                                    <th style="min-width:170px;">Fatura Tarihi</th>
                                    <th class="text-end" style="min-width:140px;">Fatura Tutarı</th>
                                    <th class="text-end" style="min-width:140px;">Bu Ay Ödenen</th>
                                    <th class="text-end" style="min-width:140px;">Bu Ay Kalan</th>
                                    <th class="text-end">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _aylikTakipSatirlari.Count; i++)
                                {
                                    var satir = _aylikTakipSatirlari[i];
                                    <tr>
                                        <td><span class="badge bg-secondary">@satir.Sira</span></td>
                                        <td>@satir.AyAdi @satir.Yil</td>
                                        <td class="text-end">@satir.BazPlanTutari.ToString("N2")</td>
                                        <td class="text-end text-warning fw-semibold">@satir.EkOdemeTutari.ToString("N2")</td>
                                        <td class="text-end fw-semibold">@satir.PlanTutari.ToString("N2")</td>
                                        <td><input class="form-control form-control-sm" @bind="satir.FaturaNo" @bind:event="oninput" placeholder="Fatura no" /></td>
                                        <td><input type="date" class="form-control form-control-sm" @bind="satir.FaturaTarihi" /></td>
                                        <td><input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="satir.FaturaTutari" @bind:event="oninput" /></td>
                                        <td><input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="satir.BuAyOdenen" /></td>
                                        <td class="text-end text-danger fw-semibold">@Math.Max(0, satir.PlanTutari - satir.BuAyOdenen).ToString("N2")</td>
                                        <td class="text-end">
                                            @if (satir.BuAyOdenen >= satir.PlanTutari && satir.PlanTutari > 0)
                                            { <span class="badge bg-success">Ödeme Yapıldı</span> }
                                            else if (satir.BuAyOdenen > 0)
                                            { <span class="badge bg-warning text-dark">Kısmi</span> }
                                            else
                                            { <span class="badge bg-danger">Yapılmadı</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th colspan="2">Toplam</th>
                                    <th class="text-end">@_aylikTakipSatirlari.Sum(x => x.BazPlanTutari).ToString("N2")</th>
                                    <th class="text-end">@_aylikTakipSatirlari.Sum(x => x.EkOdemeTutari).ToString("N2")</th>
                                    <th class="text-end">@_aylikTakipSatirlari.Sum(x => x.PlanTutari).ToString("N2")</th>
                                    <th></th>
                                    <th></th>
                                    <th class="text-end">@_aylikTakipSatirlari.Sum(x => x.FaturaTutari).ToString("N2")</th>
                                    <th class="text-end">@_aylikTakipSatirlari.Sum(x => x.BuAyOdenen).ToString("N2")</th>
                                    <th class="text-end">@_aylikTakipSatirlari.Sum(x => Math.Max(0, x.PlanTutari - x.BuAyOdenen)).ToString("N2")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-2">
                            <label class="form-label">Tamamı (Plan Toplamı)</label>
                            <input type="text" class="form-control bg-light fw-bold" value="@_aylikTakipSatirlari.Sum(x => x.PlanTutari).ToString("N2")" readonly />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ek Ödeme Toplamı</label>
                            <input type="text" class="form-control bg-light fw-bold text-warning" value="@_aylikTakipSatirlari.Sum(x => x.EkOdemeTutari).ToString("N2")" readonly />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Kesilen Toplam Fatura</label>
                            <input type="text" class="form-control bg-light fw-bold" value="@_aylikTakipSatirlari.Sum(x => x.FaturaTutari).ToString("N2")" readonly />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ödenen Toplam Fatura</label>
                            <input type="text" class="form-control bg-light fw-bold text-success" value="@_aylikTakipSatirlari.Sum(x => x.BuAyOdenen).ToString("N2")" readonly />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Kalan Fatura</label>
                            <input type="text" class="form-control bg-light fw-bold text-danger" value="@Math.Max(0, _aylikTakipSatirlari.Sum(x => x.PlanTutari) - _aylikTakipSatirlari.Sum(x => x.BuAyOdenen)).ToString("N2")" readonly />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ödenmesi Gereken Miktar</label>
                            <input type="text" class="form-control bg-light fw-bold text-warning" value="@Math.Max(0, _aylikTakipSatirlari.Sum(x => x.FaturaTutari) - _aylikTakipSatirlari.Sum(x => x.BuAyOdenen)).ToString("N2")" readonly />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Son Ödeme Tarihi</label>
                            <input type="date" class="form-control" @bind="_model.SonOdemeTarihi" />
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <a href="/araclar/plaka-takip" class="btn btn-secondary">Geri</a>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-info" @onclick="() => _showOnizlemeModal = true">
                            <i class="bi bi-eye me-1"></i>Önizleme
                        </button>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@if (_showOnizlemeModal)
{
    var aylar = OdemePlaniHesapla();
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Birleşik Takip Önizleme - @_model.Plaka</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _showOnizlemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-3"><div class="card bg-info text-white text-center py-2"><small>Toplam Ödeme</small><h6 class="mb-0">@_model.ToplamOdeme.ToString("N2")</h6></div></div>
                        <div class="col-md-3"><div class="card bg-success text-white text-center py-2"><small>Ödenen</small><h6 class="mb-0">@_model.OdenenTutar.ToString("N2")</h6></div></div>
                        <div class="col-md-3"><div class="card bg-warning text-dark text-center py-2"><small>Kesilen Fatura</small><h6 class="mb-0">@_model.KesilenFaturaTutar.ToString("N2")</h6></div></div>
                        <div class="col-md-3"><div class="card bg-danger text-white text-center py-2"><small>Kalan</small><h6 class="mb-0">@_model.KalanOdeme.ToString("N2")</h6></div></div>
                    </div>

                    <div class="table-responsive" style="max-height: 420px; overflow-y: auto;">
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>#</th>
                                    <th>Ay</th>
                                    <th class="text-end">Plan</th>
                                    <th>Fatura No</th>
                                    <th>Tarih</th>
                                    <th class="text-end">Fatura</th>
                                    <th class="text-end">Ödenen</th>
                                    <th class="text-end">Kalan</th>
                                    <th class="text-end">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ay in aylar)
                                {
                                    <tr>
                                        <td>@ay.Sira</td>
                                        <td>@ay.AyAdi @ay.Yil</td>
                                        <td class="text-end">@ay.OdemeTutari.ToString("N2")</td>
                                        <td>@(ay.EslesenFaturaNoListesi.Any() ? string.Join(", ", ay.EslesenFaturaNoListesi) : "-")</td>
                                        <td>@(ay.EslesenFaturaDetaylari.FirstOrDefault()?.FaturaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td class="text-end">@ay.EslesenFaturaTutari.ToString("N2")</td>
                                        <td class="text-end">@ay.BuAyOdenen.ToString("N2")</td>
                                        <td class="text-end">@ay.BuAyKalan.ToString("N2")</td>
                                        <td class="text-end">
                                            @if (ay.OdemeDurumu == "YAPILDI")
                                            { <span class="badge bg-success">Ödeme Yapıldı</span> }
                                            else if (ay.OdemeDurumu == "KISMI")
                                            { <span class="badge bg-warning text-dark">Kısmi</span> }
                                            else
                                            { <span class="badge bg-danger">Yapılmadı</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showOnizlemeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool _isEdit => Id.HasValue;
    private bool _loading = true;
    private KiralikPlakaTakip _model = new();
    private List<Arac> _araclar = new();
    private readonly List<FaturaSatiri> _faturaSatirlari = new();
    private readonly List<AylikTakipSatiri> _aylikTakipSatirlari = new();
    private readonly List<EkOdemeSatiri> _ekOdemeSatirlari = new();
    private string _odemeDurumuSecimi = "YAPILMADI";
    private bool _showOnizlemeModal;
    private decimal FaturaToplami => _faturaSatirlari.Sum(x => x.Tutar);
    private decimal GosterilenToplam => _aylikTakipSatirlari.Sum(x => x.PlanTutari);

    protected override async Task OnInitializedAsync() {
        _araclar = await AracService.GetActiveAsync();
        if (Id is int editId) {
            var e = await TakipService.GetByIdAsync(editId);
            if(e != null) _model = e;
            else NavManager.NavigateTo("/araclar/plaka-takip");
        }
        FaturaSatirlariniModeldenYukle();
        _model.OdemeSayisi = _model.OdemeSayisi <= 0 ? DonemSayisiniHesapla(_model.BaslamaTarihi, _model.BitisTarihi, _model.Periyot) : _model.OdemeSayisi;
        BirlesikTakipPlaniniYenile(false);
        SenkronizeOdemeDurumuModelden();
        _loading = false;
    }

    private void PlakadanAracEslestir(FocusEventArgs _) {
        if (string.IsNullOrWhiteSpace(_model.Plaka)) return;
        var p = NormalizePlaka(_model.Plaka);
        var arac = _araclar.FirstOrDefault(a => NormalizePlaka(a.AktifPlaka) == p)
            ?? _araclar.FirstOrDefault(a => a.PlakaGecmisi != null && a.PlakaGecmisi.Any(pg => !pg.IsDeleted && NormalizePlaka(pg.Plaka) == p));
        if (arac != null) _model.AracId = arac.Id;
    }

    private static string NormalizePlaka(string? plaka)
    {
        if (string.IsNullOrWhiteSpace(plaka)) return string.Empty;
        return new string(plaka.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();
    }

    private void OnAracSecildi(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(v)) _model.AracId = null;
        else if (int.TryParse(v, out var id)) _model.AracId = id;
    }

    private void FaturaSatirlariniModeldenYukle()
    {
        _faturaSatirlari.Clear();

        var detaylar = _model.FaturaDetaylari?
            .Where(x => !x.IsDeleted)
            .OrderBy(x => x.Yil)
            .ThenBy(x => x.Ay)
            .ThenBy(x => x.Sira)
            .ToList() ?? new List<KiralikPlakaTakipFatura>();

        if (detaylar.Count > 0)
        {
            _faturaSatirlari.AddRange(detaylar.Select(x => new FaturaSatiri
            {
                Sira = x.Sira,
                Yil = x.Yil,
                Ay = x.Ay,
                BazPlanTutari = x.BazPlanTutari > 0 ? x.BazPlanTutari : entityFallbackBazPlan(x),
                EkOdemeTutari = x.EkOdemeTutari,
                PlanTutari = x.PlanTutari > 0 ? x.PlanTutari : ((x.BazPlanTutari > 0 ? x.BazPlanTutari : entityFallbackBazPlan(x)) + x.EkOdemeTutari),
                FaturaNo = x.FaturaNo,
                FaturaTarihi = x.FaturaTarihi,
                Tutar = x.FaturaTutari,
                BuAyOdenen = x.BuAyOdenen
            }));

            _ekOdemeSatirlari.Clear();
            _ekOdemeSatirlari.AddRange(detaylar
                .Where(x => x.EkOdemeTutari > 0)
                .Select(x => new EkOdemeSatiri
                {
                    DonemAnahtari = $"{x.Yil:D4}-{x.Ay:D2}",
                    Tutar = x.EkOdemeTutari
                }));
            return;
        }

        var noParcalari = (_model.KesilenFaturaNo ?? string.Empty)
            .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (noParcalari.Length > 1)
        {
            var parcaTutari = noParcalari.Length > 0 ? (_model.KesilenFaturaTutar / noParcalari.Length) : 0;
            foreach (var no in noParcalari)
            {
                _faturaSatirlari.Add(new FaturaSatiri
                {
                    FaturaNo = no,
                    FaturaTarihi = null,
                    Tutar = parcaTutari
                });
            }
        }
        else
        {
            _faturaSatirlari.Add(new FaturaSatiri
            {
                FaturaNo = _model.KesilenFaturaNo,
                FaturaTarihi = _model.KesilenFaturaTarih,
                Tutar = _model.KesilenFaturaTutar
            });
        }

        if (_faturaSatirlari.Count == 0)
            _faturaSatirlari.Add(new FaturaSatiri());
    }

    private void FaturaSatiriEkle()
    {
        _faturaSatirlari.Add(new FaturaSatiri { FaturaTarihi = DateTime.Today });
    }

    private void FaturaSatiriSil(int index)
    {
        if (index < 0 || index >= _faturaSatirlari.Count) return;
        _faturaSatirlari.RemoveAt(index);
        if (_faturaSatirlari.Count == 0)
            _faturaSatirlari.Add(new FaturaSatiri());
    }

    private void EkOdemeSatiriEkle()
    {
        var ilkDonem = GetPlanDonemSecenekleri().FirstOrDefault();
        if (ilkDonem == null)
        {
            ToastService.ShowWarning("Önce başlangıç tarihi ve ödeme planını oluşturun.");
            return;
        }

        _ekOdemeSatirlari.Add(new EkOdemeSatiri
        {
            DonemAnahtari = ilkDonem.Key,
            Tutar = 0
        });
    }

    private void EkOdemeSatiriSil(int index)
    {
        if (index < 0 || index >= _ekOdemeSatirlari.Count)
            return;

        _ekOdemeSatirlari.RemoveAt(index);
        OnPlanParametreDegisti();
    }

    private List<DonemSecenegi> GetPlanDonemSecenekleri()
    {
        var liste = new List<DonemSecenegi>();
        if (_model.BaslamaTarihi == default || _model.OdemeSayisi <= 0)
            return liste;

        var tarih = new DateTime(_model.BaslamaTarihi.Year, _model.BaslamaTarihi.Month, 1);
        for (int i = 0; i < _model.OdemeSayisi; i++)
        {
            liste.Add(new DonemSecenegi
            {
                Key = $"{tarih.Year:D4}-{tarih.Month:D2}",
                Label = $"{CultureInfo.GetCultureInfo("tr-TR").TextInfo.ToTitleCase(tarih.ToString("MMMM yyyy", CultureInfo.GetCultureInfo("tr-TR")))}"
            });

            tarih = _model.Periyot == "YILLIK" ? tarih.AddYears(1) : tarih.AddMonths(1);
        }

        return liste;
    }

    private Dictionary<(int Yil, int Ay), decimal> GetEkOdemeSozlugu()
    {
        var sozluk = new Dictionary<(int Yil, int Ay), decimal>();
        foreach (var satir in _ekOdemeSatirlari)
        {
            if (string.IsNullOrWhiteSpace(satir.DonemAnahtari) || satir.Tutar == 0)
                continue;

            var parcali = satir.DonemAnahtari.Split('-');
            if (parcali.Length != 2 || !int.TryParse(parcali[0], out var yil) || !int.TryParse(parcali[1], out var ay))
                continue;

            var anahtar = (yil, ay);
            sozluk[anahtar] = sozluk.GetValueOrDefault(anahtar) + satir.Tutar;
        }

        return sozluk;
    }

    private static int DonemSayisiniHesapla(DateTime baslangic, DateTime bitis, string? periyot)
    {
        if (baslangic == default || bitis == default || bitis < baslangic)
            return 1;

        if (string.Equals(periyot, "YILLIK", StringComparison.OrdinalIgnoreCase))
        {
            var yilSayisi = (bitis.Year - baslangic.Year) + 1;
            if (bitis.Month < baslangic.Month || (bitis.Month == baslangic.Month && bitis.Day < baslangic.Day))
                yilSayisi--;

            return Math.Max(1, yilSayisi);
        }

        var aySayisi = ((bitis.Year - baslangic.Year) * 12) + bitis.Month - baslangic.Month + 1;
        if (bitis.Day < baslangic.Day)
            aySayisi--;

        return Math.Max(1, aySayisi);
    }

    private static DateTime DonemBitisTarihiHesapla(DateTime baslangic, int odemeSayisi, string? periyot)
    {
        var guvenliOdemeSayisi = Math.Max(1, odemeSayisi);
        return string.Equals(periyot, "YILLIK", StringComparison.OrdinalIgnoreCase)
            ? baslangic.Date.AddYears(guvenliOdemeSayisi).AddDays(-1)
            : baslangic.Date.AddMonths(guvenliOdemeSayisi).AddDays(-1);
    }

    private void BirlesikTakipPlaniniYenile(bool bitisTarihiniYenidenHesapla = true)
    {
        var oncekiSatirlar = _aylikTakipSatirlari
            .GroupBy(x => (x.Yil, x.Ay))
            .ToDictionary(g => g.Key, g => g.First());

        _aylikTakipSatirlari.Clear();

        if (_model.BaslamaTarihi == default)
            return;

        _model.OdemeSayisi = Math.Max(1, _model.OdemeSayisi);
        var ilkDonem = new DateTime(_model.BaslamaTarihi.Year, _model.BaslamaTarihi.Month, 1);
        if (bitisTarihiniYenidenHesapla || _model.BitisTarihi == default || _model.BitisTarihi < _model.BaslamaTarihi)
            _model.BitisTarihi = DonemBitisTarihiHesapla(_model.BaslamaTarihi, _model.OdemeSayisi, _model.Periyot);

        var ekOdemeSozlugu = GetEkOdemeSozlugu();
        var faturaAyGruplari = _faturaSatirlari
            .Where(x => (x.Yil.HasValue && x.Ay.HasValue) || x.FaturaTarihi.HasValue)
            .GroupBy(x => x.Yil.HasValue && x.Ay.HasValue
                ? (x.Yil!.Value, x.Ay!.Value)
                : (x.FaturaTarihi!.Value.Year, x.FaturaTarihi!.Value.Month))
            .ToDictionary(g => g.Key, g => g.OrderBy(x => x.Sira).ToList());

        var tarih = ilkDonem;
        var toplamOdenen = Math.Max(0, _model.OdenenTutar);
        var siraliEskiSatirlar = oncekiSatirlar.Values.OrderBy(x => x.Sira).ToList();
        var kalanOdenen = toplamOdenen;

        for (int i = 0; i < _model.OdemeSayisi; i++)
        {
            var ayAnahtar = (tarih.Year, tarih.Month);
            oncekiSatirlar.TryGetValue(ayAnahtar, out var oncekiSatir);
            var kaynakSatir = oncekiSatir ?? (i < siraliEskiSatirlar.Count ? siraliEskiSatirlar[i] : null);
            var bazPlan = _model.AylikVeyaYillikTutar;
            var ekOdeme = ekOdemeSozlugu.GetValueOrDefault(ayAnahtar);
            var plan = bazPlan + ekOdeme;
            var ayFaturalari = faturaAyGruplari.TryGetValue(ayAnahtar, out var bulunanlar)
                ? bulunanlar
                : new List<FaturaSatiri>();
            var buAyOdenen = kaynakSatir?.BuAyOdenen ?? Math.Min(plan, kalanOdenen);
            kalanOdenen = Math.Max(0, kalanOdenen - buAyOdenen);

            _aylikTakipSatirlari.Add(new AylikTakipSatiri
            {
                Sira = i + 1,
                Yil = tarih.Year,
                Ay = tarih.Month,
                AyAdi = CultureInfo.GetCultureInfo("tr-TR").TextInfo.ToTitleCase(tarih.ToString("MMMM")),
                BazPlanTutari = bazPlan,
                EkOdemeTutari = ekOdeme,
                PlanTutari = plan,
                FaturaNo = kaynakSatir?.FaturaNo ?? ayFaturalari.FirstOrDefault()?.FaturaNo,
                FaturaTarihi = kaynakSatir?.FaturaTarihi ?? ayFaturalari.FirstOrDefault()?.FaturaTarihi,
                FaturaTutari = kaynakSatir?.FaturaTutari ?? ayFaturalari.Sum(x => x.Tutar),
                BuAyOdenen = buAyOdenen
            });

            tarih = string.Equals(_model.Periyot, "YILLIK", StringComparison.OrdinalIgnoreCase)
                ? tarih.AddYears(1)
                : tarih.AddMonths(1);
        }

        _model.EkTutar = _ekOdemeSatirlari.Sum(x => x.Tutar);
        _model.ToplamOdeme = _aylikTakipSatirlari.Sum(x => x.PlanTutari);
        _model.OdenenTutar = _aylikTakipSatirlari.Sum(x => x.BuAyOdenen);
        SenkronizeOdemeDurumuModelden();
    }

    private List<OdemePlanSatiri> OdemePlaniHesapla()
    {
        var liste = new List<OdemePlanSatiri>();
        var bugun = DateTime.Today;

        var faturaAyGruplari = _faturaSatirlari
            .Where(x => x.FaturaTarihi.HasValue)
            .GroupBy(x => (x.FaturaTarihi!.Value.Year, x.FaturaTarihi!.Value.Month))
            .ToDictionary(g => g.Key, g => g.ToList());

        foreach (var satir in _aylikTakipSatirlari.OrderBy(x => x.Sira))
        {
            var ayAnahtar = (satir.Yil, satir.Ay);
            var eslesenFaturalar = faturaAyGruplari.TryGetValue(ayAnahtar, out var ayFaturalari)
                ? ayFaturalari
                : new List<FaturaSatiri>();
            var eslesenFaturaToplami = eslesenFaturalar.Sum(x => x.Tutar);

            var odemeDurumu = satir.BuAyOdenen >= satir.PlanTutari && satir.PlanTutari > 0
                ? "YAPILDI"
                : (satir.BuAyOdenen > 0 ? "KISMI" : "YAPILMADI");

            liste.Add(new OdemePlanSatiri
            {
                Sira = satir.Sira,
                Yil = satir.Yil,
                AyAdi = satir.AyAdi,
                OdemeTutari = satir.PlanTutari,
                EslesenFaturaTutari = eslesenFaturaToplami,
                EslesenFaturaNoListesi = eslesenFaturalar
                    .Select(x => x.FaturaNo)
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Cast<string>()
                    .ToList(),
                EslesenFaturaDetaylari = eslesenFaturalar
                    .OrderByDescending(x => x.FaturaTarihi)
                    .ToList(),
                BuAyOdenen = satir.BuAyOdenen,
                BuAyKalan = Math.Max(0, satir.PlanTutari - satir.BuAyOdenen),
                OdemeDurumu = odemeDurumu,
                BugundenOnce = new DateTime(satir.Yil, satir.Ay, 1) < bugun
            });
        }

        return liste;
    }

    private class OdemePlanSatiri
    {
        public int Sira { get; set; }
        public int Yil { get; set; }
        public string AyAdi { get; set; } = "";
        public decimal OdemeTutari { get; set; }
        public decimal EslesenFaturaTutari { get; set; }
        public List<string> EslesenFaturaNoListesi { get; set; } = new();
        public List<FaturaSatiri> EslesenFaturaDetaylari { get; set; } = new();
        public decimal BuAyOdenen { get; set; }
        public decimal BuAyKalan { get; set; }
        public string OdemeDurumu { get; set; } = "YAPILMADI";
        public bool BugundenOnce { get; set; }
    }

    private void OnOdemeDurumuDegisti(ChangeEventArgs e)
    {
        _odemeDurumuSecimi = e.Value?.ToString() ?? "YAPILMADI";
        var hedefToplam = _model.ToplamOdeme > 0 ? _model.ToplamOdeme : _model.Toplam;

        switch (_odemeDurumuSecimi)
        {
            case "YAPILMADI":
                _model.OdenenTutar = 0;
                break;
            case "YAPILDI":
                _model.OdenenTutar = hedefToplam;
                break;
            case "KISMI":
                if (_model.OdenenTutar <= 0)
                    _model.OdenenTutar = Math.Min(hedefToplam, _model.AylikVeyaYillikTutar > 0 ? _model.AylikVeyaYillikTutar : hedefToplam / 2);
                break;
        }
    }

    private void SenkronizeOdemeDurumuModelden()
    {
        var hedefToplam = _model.ToplamOdeme > 0 ? _model.ToplamOdeme : _model.Toplam;
        if (_model.OdenenTutar <= 0)
            _odemeDurumuSecimi = "YAPILMADI";
        else if (hedefToplam > 0 && _model.OdenenTutar >= hedefToplam)
            _odemeDurumuSecimi = "YAPILDI";
        else
            _odemeDurumuSecimi = "KISMI";
    }

    private decimal entityFallbackBazPlan(KiralikPlakaTakipFatura _) => _model.AylikVeyaYillikTutar;

    private void OnTarihAraligiDegisti()
    {
        if (_model.BaslamaTarihi != default && _model.BitisTarihi != default && _model.BitisTarihi >= _model.BaslamaTarihi)
            _model.OdemeSayisi = DonemSayisiniHesapla(_model.BaslamaTarihi, _model.BitisTarihi, _model.Periyot);

        BirlesikTakipPlaniniYenile(false);
    }

    private void OnPeriyotDegisti()
    {
        if (_model.BaslamaTarihi != default && _model.BitisTarihi != default && _model.BitisTarihi >= _model.BaslamaTarihi)
            _model.OdemeSayisi = DonemSayisiniHesapla(_model.BaslamaTarihi, _model.BitisTarihi, _model.Periyot);
        else
            _model.OdemeSayisi = Math.Max(1, _model.OdemeSayisi);

        BirlesikTakipPlaniniYenile(false);
    }

    private void OnOdemeSayisiDegisti()
    {
        _model.OdemeSayisi = Math.Max(1, _model.OdemeSayisi);
        BirlesikTakipPlaniniYenile();
    }

    private void BirlesikTakipPlaniniElleYenile()
    {
        BirlesikTakipPlaniniYenile();
    }

    private void OnPlanParametreDegisti()
    {
        BirlesikTakipPlaniniYenile(false);
    }

