@page "/filo-operasyon"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IFiloOperasyonService FiloOperasyonService
@inject NavigationManager NavigationManager

<PageTitle>Filo Operasyon Yönetimi | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-truck me-2"></i>Filo Operasyon Yönetimi
        </h3>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Toplam Araç</h6>
                                <h3 class="mb-0">@_ozet.ToplamAracSayisi</h3>
                                <small class="text-muted">
                                    Özmal: @_ozet.OzmalAracSayisi | Kiralık: @_ozet.KiralikAracSayisi
                                </small>
                            </div>
                            <div class="text-primary">
                                <i class="bi bi-car-front fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Tedarikçi Araçları</h6>
                                <h3 class="mb-0">@_ozet.TedarikciAraciSayisi</h3>
                                <small class="text-muted">
                                    tedarikçiye bağlı araç
                                    @if (_ozet.AktifTedarikciIsSayisi > 0)
                                    {
                                        <span class="ms-2 badge bg-success">@_ozet.AktifTedarikciIsSayisi aktif iş</span>
                                    }
                                </small>
                            </div>
                            <div class="text-success">
                                <i class="bi bi-truck-front fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Satışa Bekleyen</h6>
                                <h3 class="mb-0">@_ozet.SatisaBekleyenAracSayisi</h3>
                                <small class="text-warning">
                                    @_ozet.NoterBekleyenSatisSayisi noter bekliyor
                                </small>
                            </div>
                            <div class="text-warning">
                                <i class="bi bi-tag fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Kiralık C Plaka Takip</h6>
                                <h3 class="mb-0">@_ozet.DevamEdenPlakaDonusumSayisi</h3>
                                <small class="text-muted">devam eden</small>
                            </div>
                            <div class="text-info">
                                <i class="bi bi-card-text fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hızlı İşlemler -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-lightning-charge me-2"></i>Hızlı İşlemler</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <button class="btn btn-outline-primary w-100 py-3" @onclick="YeniKomisyonculukIs">
                                    <i class="bi bi-plus-circle fs-4 d-block mb-2"></i>
                                    Yeni Taşıma Tedarikçisi
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-outline-success w-100 py-3" @onclick="YeniAracAlim">
                                    <i class="bi bi-box-arrow-in-down fs-4 d-block mb-2"></i>
                                    Araç Alımı
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-outline-warning w-100 py-3" @onclick="YeniAracSatis">
                                    <i class="bi bi-box-arrow-up fs-4 d-block mb-2"></i>
                                    Araç Satışı
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-outline-info w-100 py-3" @onclick="YeniPlakaDonusum">
                                    <i class="bi bi-arrow-repeat fs-4 d-block mb-2"></i>
                                    Kiralık C Plaka Takip
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modül Kartları -->
        <div class="row g-4">
            <!-- Tedarikçi Servis Operasyon -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-truck me-2"></i>Tedarikçi Servis Operasyon</h5>
                        <a href="/personel-tasima/tedarikciler" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Alt yüklenici (taşıma) firmaları ve tedarikçiye bağlı araç/personel yönetimi;
                            sözleşme, sefer ücretleri ve evrak takibi.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-success me-2"></i>Tedarikçi ve iletişim yönetimi</li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>
                                <a href="/tedarikci-servis/araclar">Tedarikçi Araçları</a> &amp;
                                <a href="/tedarikci-servis/personel">Tedarikçi Personeli</a>
                            </li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>
                                <a href="/tedarikci-servis/arac-evraklari">Araç Evrak Takibi</a>
                            </li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>
                                <a href="/tedarikci-servis/isler">Tedarikçi İşler</a> &amp; Sözleşme/Sefer ücreti takibi
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Araç Alım/Satım -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-cart-plus me-2"></i>Araç Alım/Satım</h5>
                        <a href="/filo-operasyon/alim-satim" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Özmal ve dışarıdan alınan araçların satışı, yeni araç alımı, 
                            noter evrak takibi ve fatura kontrolü.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Araç alış/satış kayıtları</li>
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Noter evrak takibi</li>
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Fatura kesim kontrolü</li>
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Belge teslim durumu</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Kiralık C Plaka Takip -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-card-text me-2"></i>Kiralık C Plaka Takip</h5>
                        <a href="/filo-operasyon/kiralik-c-plaka-takip" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Kiralık C plakalı araçların takibi, kıra sözleşmeleri, ödeme durumları ve 
                            masraf takibi.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-info me-2"></i>C plaka kiralık araç takibi</li>
                            <li><i class="bi bi-check-circle text-info me-2"></i>Kira dönemi ve ödeme takibi</li>
                            <li><i class="bi bi-check-circle text-info me-2"></i>Masraf hesaplama</li>
                            <li><i class="bi bi-check-circle text-info me-2"></i>Durum ve kasa takibi</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Operasyon Durumu -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Operasyon & Raporlar</h5>
                        <a href="/filo-operasyon/raporlar" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Araç bazlı gelir/gider takibi, kar/zarar analizi ve 
                            operasyon performans raporları.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Araç kar/zarar analizi</li>
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Taşıma tedarikçi kazanç raporu</li>
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Aylık operasyon özeti</li>
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Filo performans karşılaştırma</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private FiloOzetRaporu _ozet = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _ozet = await FiloOperasyonService.GetFiloOzetRaporuAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Filo özet yüklenirken hata: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void YeniKomisyonculukIs()
    {
        NavigationManager.NavigateTo("/personel-tasima/tedarikciler/yeni");
    }

    private void YeniAracAlim()
    {
        NavigationManager.NavigateTo("/filo-operasyon/alim-satim/yeni?tip=alim");
    }

    private void YeniAracSatis()
    {
        NavigationManager.NavigateTo("/filo-operasyon/alim-satim/yeni?tip=satis");
    }

    private void YeniPlakaDonusum()
    {
        NavigationManager.NavigateTo("/filo-operasyon/plaka-donusum/yeni");
    }
}
