    private async Task ExcelAktar()
    {
        try
        {
            var data = FiltrelenmisListe;
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            using var workbook = new XLWorkbook();

            // ───────────────── ÖZET SAYFASI ─────────────────
            var ozet = workbook.Worksheets.Add("Özet");
            ozet.Cell(1, 1).Value = "KİRALIK C PLAKA TAKİP RAPORU";
            ozet.Range(1, 1, 1, 4).Merge();
            ozet.Cell(1, 1).Style.Font.Bold = true;
            ozet.Cell(1, 1).Style.Font.FontSize = 16;
            ozet.Cell(1, 1).Style.Fill.BackgroundColor = XLColor.DarkBlue;
            ozet.Cell(1, 1).Style.Font.FontColor = XLColor.White;
            ozet.Cell(1, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ozet.Row(1).Height = 28;

            ozet.Cell(2, 1).Value = $"Oluşturma Tarihi: {DateTime.Now:dd.MM.yyyy HH:mm}";
            ozet.Range(2, 1, 2, 4).Merge();
            ozet.Cell(2, 1).Style.Font.Italic = true;
            ozet.Cell(2, 1).Style.Font.FontColor = XLColor.Gray;

            // Filtre bilgisi
            var filtreler = new List<string>();
            if (!string.IsNullOrWhiteSpace(aramaMetni)) filtreler.Add($"Arama: {aramaMetni}");
            if (!string.IsNullOrEmpty(durumFiltre)) filtreler.Add($"Durum: {durumFiltre}");
            if (!string.IsNullOrEmpty(kasaFiltre)) filtreler.Add($"Kasa: {kasaFiltre}");
            if (!string.IsNullOrEmpty(bitisFiltre)) filtreler.Add($"Bitiş: {bitisFiltre}");
            if (!string.IsNullOrEmpty(eslesmeFiltre)) filtreler.Add($"Eşleşme: {eslesmeFiltre}");
            ozet.Cell(3, 1).Value = filtreler.Any() ? "Filtreler: " + string.Join(" | ", filtreler) : "Filtre uygulanmadı";
            ozet.Range(3, 1, 3, 4).Merge();
            ozet.Cell(3, 1).Style.Font.Italic = true;
            ozet.Cell(3, 1).Style.Font.FontColor = XLColor.Gray;

            // Genel İstatistikler
            int r = 5;
            ozet.Cell(r, 1).Value = "GENEL İSTATİSTİKLER";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;

            var sureGecen = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0);
            var yedi = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; });
            var otuz = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g > 7 && g <= 30; });
            var aktif = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days > 30);

            void Stat(string label, object value, XLColor? bg = null)
            {
                ozet.Cell(r, 1).Value = label;
                ozet.Cell(r, 2).Value = XLCellValue.FromObject(value);
                ozet.Cell(r, 1).Style.Font.Bold = true;
                if (bg is not null)
                {
                    ozet.Range(r, 1, r, 2).Style.Fill.BackgroundColor = bg;
                }
                r++;
            }

            Stat("Toplam Kayıt", data.Count);
            Stat("Eşleşen Araç", data.Count(x => x.Arac != null), XLColor.LightGreen);
            Stat("Eşleşmeyen", data.Count(x => x.Arac == null), XLColor.LightPink);
            Stat("Süresi Geçen", sureGecen, XLColor.LightPink);
            Stat("7 Gün İçinde Bitecek", yedi, XLColor.LightYellow);
            Stat("30 Gün İçinde Bitecek", otuz, XLColor.LightBlue);
            Stat("31+ Gün (Aktif)", aktif, XLColor.LightGreen);
            Stat("Toplam Fatura (₺)", data.Sum(x => x.FaturaOdemesi).ToString("N2"));
            Stat("Toplam Ek Tutar (₺)", data.Sum(x => x.EkTutar).ToString("N2"));
            Stat("GENEL TOPLAM (₺)", data.Sum(x => x.Toplam).ToString("N2"), XLColor.LightYellow);

            r += 2;

            // Duruma Göre Dağılım
            ozet.Cell(r, 1).Value = "DURUMA GÖRE DAĞILIM";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;
            ozet.Cell(r, 1).Value = "Durum";
            ozet.Cell(r, 2).Value = "Adet";
            ozet.Cell(r, 3).Value = "Toplam (₺)";
            ozet.Cell(r, 4).Value = "Oran (%)";
            ozet.Range(r, 1, r, 4).Style.Font.Bold = true;
            ozet.Range(r, 1, r, 4).Style.Fill.BackgroundColor = XLColor.Gainsboro;
            r++;
            foreach (var g in data.GroupBy(x => string.IsNullOrWhiteSpace(x.Durum) ? "(Boş)" : x.Durum.Trim()).OrderByDescending(g => g.Count()))
            {
                ozet.Cell(r, 1).Value = g.Key;
                ozet.Cell(r, 2).Value = g.Count();
                ozet.Cell(r, 3).Value = g.Sum(x => x.Toplam);
                ozet.Cell(r, 3).Style.NumberFormat.Format = "#,##0.00";
                ozet.Cell(r, 4).Value = data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0;
                ozet.Cell(r, 4).Style.NumberFormat.Format = "0.0\"%\"";
                r++;
            }

            r += 2;

            // Kasa Durumuna Göre Dağılım
            ozet.Cell(r, 1).Value = "KASA DURUMUNA GÖRE DAĞILIM";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;
            ozet.Cell(r, 1).Value = "Kasa Durumu";
            ozet.Cell(r, 2).Value = "Adet";
            ozet.Cell(r, 3).Value = "Toplam (₺)";
            ozet.Cell(r, 4).Value = "Oran (%)";
            ozet.Range(r, 1, r, 4).Style.Font.Bold = true;
            ozet.Range(r, 1, r, 4).Style.Fill.BackgroundColor = XLColor.Gainsboro;
            r++;
            foreach (var g in data.GroupBy(x => string.IsNullOrWhiteSpace(x.KasaDurumu) ? "(Boş)" : x.KasaDurumu.Trim()).OrderByDescending(g => g.Count()))
            {
                ozet.Cell(r, 1).Value = g.Key;
                ozet.Cell(r, 2).Value = g.Count();
                ozet.Cell(r, 3).Value = g.Sum(x => x.Toplam);
                ozet.Cell(r, 3).Style.NumberFormat.Format = "#,##0.00";
                ozet.Cell(r, 4).Value = data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0;
                ozet.Cell(r, 4).Style.NumberFormat.Format = "0.0\"%\"";
                r++;
            }

            ozet.Columns().AdjustToContents();
            ozet.Column(1).Width = Math.Max(ozet.Column(1).Width, 28);
            ozet.SheetView.FreezeRows(3);

            // ───────────────── DETAY SAYFASI ─────────────────
            var ws = workbook.Worksheets.Add("Detay");

            var headers = new[] { "S.NO", "PLAKA", "EŞLEŞEN ARAÇ", "İSİM SOYİSİM", "BAŞLAMA TARİHİ", "BİTİŞ TARİHİ", "KALAN GÜN", "DURUM", "KASA DURUMU", "FATURA", "PERİYOT", "AYLIK/YILLIK", "EK TUTAR", "TOPLAM", "KESİLEN FATURA NO", "KESİLEN FATURA TUTAR", "KALAN FATURA", "ÖDENEN" };
            for (int i = 0; i < headers.Length; i++)
                ws.Cell(1, i + 1).Value = headers[i];

            var headerRange = ws.Range(1, 1, 1, headers.Length);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Font.FontColor = XLColor.White;
            headerRange.Style.Fill.BackgroundColor = XLColor.DarkBlue;
            headerRange.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            headerRange.Style.Border.OutsideBorder = XLBorderStyleValues.Medium;
            headerRange.Style.Border.InsideBorder = XLBorderStyleValues.Thin;
            ws.Row(1).Height = 22;

            int row = 2;
            int sira = 1;
            foreach (var item in data)
            {
                var kalan = (item.BitisTarihi.Date - DateTime.Today).Days;
                ws.Cell(row, 1).Value = sira++;
                ws.Cell(row, 2).Value = item.Plaka;
                ws.Cell(row, 3).Value = item.Arac != null ? $"{item.Arac.AktifPlaka} - {item.Arac.Marka} {item.Arac.Model}" : "Eşleşmedi";
                ws.Cell(row, 4).Value = item.IsimSoyisim;
                ws.Cell(row, 5).Value = item.BaslamaTarihi;
                ws.Cell(row, 5).Style.DateFormat.Format = "dd.MM.yyyy";
                ws.Cell(row, 6).Value = item.BitisTarihi;
                ws.Cell(row, 6).Style.DateFormat.Format = "dd.MM.yyyy";
                ws.Cell(row, 7).Value = kalan;
                ws.Cell(row, 8).Value = item.Durum;
                ws.Cell(row, 9).Value = item.KasaDurumu;
                ws.Cell(row, 10).Value = item.FaturaOdemesi;
                ws.Cell(row, 10).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 11).Value = item.Periyot;
                ws.Cell(row, 12).Value = item.AylikVeyaYillikTutar;
                ws.Cell(row, 12).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 13).Value = item.EkTutar;
                ws.Cell(row, 13).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 14).Value = item.Toplam;
                ws.Cell(row, 14).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 14).Style.Font.Bold = true;
                ws.Cell(row, 15).Value = item.KesilenFaturaNo ?? "";
                ws.Cell(row, 16).Value = item.KesilenFaturaTutar;
                ws.Cell(row, 16).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 17).Value = item.KalanFaturaTutar;
                ws.Cell(row, 17).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 18).Value = item.OdenenTutar;
                ws.Cell(row, 18).Style.NumberFormat.Format = "#,##0.00";

                // Bitiş tarihi rengi
                if (kalan < 0)
                {
                    ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightPink;
                    ws.Cell(row, 6).Style.Font.FontColor = XLColor.DarkRed;
                    ws.Cell(row, 6).Style.Font.Bold = true;
                }
                else if (kalan <= 7)
                {
                    ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightYellow;
                }
                else if (kalan <= 30)
                {
                    ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightCyan;
                }

                // Durum rengi
                ws.Cell(row, 8).Style.Fill.BackgroundColor = GetDurumXLColor(item.Durum);
                ws.Cell(row, 8).Style.Font.Bold = true;
                ws.Cell(row, 8).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

                // Kasa Durumu rengi
                ws.Cell(row, 9).Style.Fill.BackgroundColor = GetKasaXLColor(item.KasaDurumu);
                ws.Cell(row, 9).Style.Font.Bold = true;
                ws.Cell(row, 9).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

                // Eşleşmeyen vurgu
                if (item.Arac == null)
                {
                    ws.Cell(row, 3).Style.Font.FontColor = XLColor.White;
                    ws.Cell(row, 3).Style.Fill.BackgroundColor = XLColor.Red;
                    ws.Cell(row, 3).Style.Font.Bold = true;
                }

                row++;
            }

            // Toplam satırı
            ws.Cell(row, 9).Value = "TOPLAM";
            ws.Cell(row, 9).Style.Font.Bold = true;
            ws.Cell(row, 9).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Right;
            ws.Cell(row, 10).FormulaA1 = $"SUM(J2:J{row - 1})";
            ws.Cell(row, 10).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 13).FormulaA1 = $"SUM(M2:M{row - 1})";
            ws.Cell(row, 13).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 14).FormulaA1 = $"SUM(N2:N{row - 1})";
            ws.Cell(row, 14).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 16).FormulaA1 = $"SUM(P2:P{row - 1})";
            ws.Cell(row, 16).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 17).FormulaA1 = $"SUM(Q2:Q{row - 1})";
            ws.Cell(row, 17).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 18).FormulaA1 = $"SUM(R2:R{row - 1})";
            ws.Cell(row, 18).Style.NumberFormat.Format = "#,##0.00";
            ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.DarkGray;
            ws.Range(row, 1, row, headers.Length).Style.Font.FontColor = XLColor.White;
            ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
            ws.Range(row, 1, row, headers.Length).Style.Border.TopBorder = XLBorderStyleValues.Medium;

            // Tüm tabloya çerçeve
            ws.Range(1, 1, row, headers.Length).Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
            ws.Range(1, 1, row, headers.Length).Style.Border.InsideBorder = XLBorderStyleValues.Thin;

            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(1);
            ws.RangeUsed()!.SetAutoFilter();

            using var ms = new MemoryStream();
            workbook.SaveAs(ms);
            var bytes = ms.ToArray();
            var fileName = $"kiralik-c-plaka-rapor-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
            ToastService.ShowSuccess("Excel raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel aktarım hatası: {ex.Message}");
        }
    }

    private static XLColor GetDurumXLColor(string? durum)
    {
        var d = (durum ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(d)) return XLColor.LightGray;
        if (d.Contains("aktif") || d.Contains("devam") || d.Contains("açık") || d.Contains("acik") || d.Contains("geçerli") || d.Contains("gecerli"))
            return XLColor.LightGreen;
        if (d.Contains("pasif") || d.Contains("iptal") || d.Contains("kapalı") || d.Contains("kapali") || d.Contains("sona") || d.Contains("bitti") || d.Contains("bitmiş") || d.Contains("bitmis") || d.Contains("dondu"))
            return XLColor.LightPink;
        if (d.Contains("bekle") || d.Contains("askı") || d.Contains("aski") || d.Contains("onay"))
            return XLColor.LightYellow;
        return XLColor.LightCyan;
    }

    private static XLColor GetKasaXLColor(string? kasa)
    {
        var k = (kasa ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(k)) return XLColor.LightGray;
        if (k.Contains("ödendi") || k.Contains("odendi") || k.Contains("tamam") || k.Contains("kapandı") || k.Contains("kapandi") || k.Contains("tahsil"))
            return XLColor.LightGreen;
        if (k.Contains("ödenmedi") || k.Contains("odenmedi") || k.Contains("borç") || k.Contains("borc") || k.Contains("açık") || k.Contains("acik") || k.Contains("bekliyor") || k.Contains("bekleniyor"))
            return XLColor.LightPink;
        if (k.Contains("kısmi") || k.Contains("kismi") || k.Contains("parça") || k.Contains("parca") || k.Contains("eksik") || k.Contains("kısmen") || k.Contains("kismen"))
            return XLColor.LightYellow;
        return XLColor.LightCyan;
    }

    private async Task PdfAktar()
    {
        try
        {
            var data = FiltrelenmisListe;
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            QuestPDF.Settings.License = LicenseType.Community;

            var sureGecen = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0);
            var yedi = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; });
            var otuz = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g > 7 && g <= 30; });
            var aktifSayi = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days > 30);
            var eslesen = data.Count(x => x.Arac != null);
            var eslesmeyen = data.Count(x => x.Arac == null);

            var durumGruplari = data
                .GroupBy(x => string.IsNullOrWhiteSpace(x.Durum) ? "(Boş)" : x.Durum.Trim())
                .OrderByDescending(g => g.Count())
                .ToList();
            var kasaGruplari = data
                .GroupBy(x => string.IsNullOrWhiteSpace(x.KasaDurumu) ? "(Boş)" : x.KasaDurumu.Trim())
                .OrderByDescending(g => g.Count())
                .ToList();

            var filtreler = new List<string>();
            if (!string.IsNullOrWhiteSpace(aramaMetni)) filtreler.Add($"Arama: {aramaMetni}");
            if (!string.IsNullOrEmpty(durumFiltre)) filtreler.Add($"Durum: {durumFiltre}");
            if (!string.IsNullOrEmpty(kasaFiltre)) filtreler.Add($"Kasa: {kasaFiltre}");
            if (!string.IsNullOrEmpty(bitisFiltre)) filtreler.Add($"Bitiş: {bitisFiltre}");
            if (!string.IsNullOrEmpty(eslesmeFiltre)) filtreler.Add($"Eşleşme: {eslesmeFiltre}");

            var document = Document.Create(container =>
            {
                container.Page(page =>
                {
                    page.Size(PageSizes.A4.Landscape());
                    page.Margin(20);
                    page.DefaultTextStyle(x => x.FontSize(8));

                    // BAŞLIK
                    page.Header().Column(col =>
                    {
                        col.Item().Background(Colors.Blue.Darken3).Padding(10).Column(c =>
                        {
                            c.Item().Text("KİRALIK C PLAKA TAKİP RAPORU").Bold().FontSize(16).FontColor(Colors.White);
                            c.Item().Text("KOA Filo Servis").FontSize(9).FontColor(Colors.Grey.Lighten2);
                        });
                        col.Item().PaddingTop(4).Row(row =>
                        {
                            row.RelativeItem().Text($"Oluşturma: {DateTime.Now:dd.MM.yyyy HH:mm}").FontSize(8).FontColor(Colors.Grey.Darken2);
                            row.RelativeItem().AlignRight().Text($"Toplam Kayıt: {data.Count}").Bold().FontSize(9);
                        });
                        if (filtreler.Any())
                            col.Item().PaddingTop(2).Text($"Filtreler: {string.Join(" | ", filtreler)}").FontSize(7).Italic().FontColor(Colors.Grey.Darken2);
                    });

                    page.Content().PaddingVertical(8).Column(content =>
                    {
                        content.Spacing(8);

                        // ÖZET KARTLARI
                        content.Item().Row(row =>
                        {
                            row.Spacing(5);
                            void Kart(QuestPDF.Infrastructure.IContainer c, string baslik, string deger, string bg, string fg = "#FFFFFF")
                            {
                                c.Background(bg).Padding(6).Column(k =>
                                {
                                    k.Item().Text(baslik).FontSize(7).FontColor(fg);
                                    k.Item().Text(deger).Bold().FontSize(13).FontColor(fg);
                                });
                            }
                            Kart(row.RelativeItem(), "Toplam", data.Count.ToString(), Colors.Blue.Darken2);
                            Kart(row.RelativeItem(), "Eşleşen", eslesen.ToString(), Colors.Green.Darken1);
                            Kart(row.RelativeItem(), "Eşleşmeyen", eslesmeyen.ToString(), Colors.Red.Darken1);
                            Kart(row.RelativeItem(), "Süresi Geçen", sureGecen.ToString(), Colors.Red.Darken3);
                            Kart(row.RelativeItem(), "7 Gün İçinde", yedi.ToString(), Colors.Orange.Darken1, "#000000");
                            Kart(row.RelativeItem(), "30 Gün İçinde", otuz.ToString(), Colors.Cyan.Darken2);
                            Kart(row.RelativeItem(), "Aktif (31+)", aktifSayi.ToString(), Colors.Teal.Darken2);
                        });

                        content.Item().Row(row =>
                        {
                            row.Spacing(5);
                            void Mali(QuestPDF.Infrastructure.IContainer c, string baslik, decimal deger, string bg)
                            {
                                c.Background(bg).Padding(6).Column(k =>
                                {
                                    k.Item().Text(baslik).FontSize(7).FontColor(Colors.White);
                                    k.Item().Text($"{deger:N2} ₺").Bold().FontSize(12).FontColor(Colors.White);
                                });
                            }
                            Mali(row.RelativeItem(), "Toplam Fatura", data.Sum(x => x.FaturaOdemesi), Colors.Indigo.Darken1);
                            Mali(row.RelativeItem(), "Toplam Ek Tutar", data.Sum(x => x.EkTutar), Colors.Purple.Darken1);
                            Mali(row.RelativeItem(2), "GENEL TOPLAM", data.Sum(x => x.Toplam), Colors.Green.Darken3);
                        });

                        // DAĞILIM TABLOLARI
                        content.Item().Row(row =>
                        {
                            row.Spacing(8);

                            row.RelativeItem().Border(1).BorderColor(Colors.Grey.Lighten1).Column(col =>
                            {
                                col.Item().Background(Colors.Blue.Lighten4).Padding(5).Text("DURUMA GÖRE DAĞILIM").Bold().FontSize(9);
                                col.Item().Table(t =>
                                {
                                    t.ColumnsDefinition(c =>
                                    {
                                        c.RelativeColumn(3);
                                        c.RelativeColumn(1);
                                        c.RelativeColumn(2);
                                        c.RelativeColumn(1);
                                    });
                                    t.Header(h =>
                                    {
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text("Durum").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Adet").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Tutar (₺)").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("%").Bold().FontSize(8);
                                    });
                                    foreach (var g in durumGruplari)
                                    {
                                        var bg = GetDurumQpdfBg(g.Key);
                                        t.Cell().Background(bg).Padding(3).Text(g.Key).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Count().ToString()).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Sum(x => x.Toplam).ToString("N2")).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text($"{(data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0):0.0}").FontSize(8);
                                    }
                                });
                            });

                            row.RelativeItem().Border(1).BorderColor(Colors.Grey.Lighten1).Column(col =>
                            {
                                col.Item().Background(Colors.Green.Lighten4).Padding(5).Text("KASA DURUMUNA GÖRE DAĞILIM").Bold().FontSize(9);
                                col.Item().Table(t =>
                                {
                                    t.ColumnsDefinition(c =>
                                    {
                                        c.RelativeColumn(3);
                                        c.RelativeColumn(1);
                                        c.RelativeColumn(2);
                                        c.RelativeColumn(1);
                                    });
                                    t.Header(h =>
                                    {
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text("Kasa Durumu").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Adet").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Tutar (₺)").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("%").Bold().FontSize(8);
                                    });
                                    foreach (var g in kasaGruplari)
                                    {
                                        var bg = GetKasaQpdfBg(g.Key);
                                        t.Cell().Background(bg).Padding(3).Text(g.Key).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Count().ToString()).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Sum(x => x.Toplam).ToString("N2")).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text($"{(data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0):0.0}").FontSize(8);
                                    }
                                });
                            });
                        });

                        // BAŞLIK BANNERı
                        content.Item().Background(Colors.Blue.Darken3).Padding(5).Text("DETAY LİSTE").Bold().FontSize(10).FontColor(Colors.White);

                        // ANA TABLO
                        content.Item().Table(table =>
                        {
                            table.ColumnsDefinition(c =>
                            {
                                c.ConstantColumn(20);    // S.NO
                                c.RelativeColumn(2);     // Plaka
                                c.RelativeColumn(3);     // Eşleşen Araç
                                c.RelativeColumn(3);     // İsim
                                c.RelativeColumn(2);     // Başlama
                                c.RelativeColumn(2.5f);  // Bitiş
                                c.RelativeColumn(2);     // Durum
                                c.RelativeColumn(2);     // Kasa
                                c.RelativeColumn(2);     // Fatura
                                c.RelativeColumn(2);     // Ek
                                c.RelativeColumn(2);     // Toplam
                                c.RelativeColumn(2);     // Kesilen Fatura
                                c.RelativeColumn(2);     // Kalan
                                c.RelativeColumn(2);     // Ödenen
                            });

                            table.Header(h =>
                            {
                                string[] hs = { "#", "PLAKA", "EŞLEŞEN ARAÇ", "İSİM SOYİSİM", "BAŞLAMA", "BİTİŞ", "DURUM", "KASA", "FATURA", "EK TUTAR", "TOPLAM", "KESİLEN FATURA", "KALAN", "ÖDENEN" };
                                foreach (var head in hs)
                                    h.Cell().Background(Colors.Blue.Darken2).Padding(4).AlignCenter().Text(head).Bold().FontSize(8).FontColor(Colors.White);
                            });

                            int sira = 1;
                            foreach (var item in data)
                            {
                                var kalan = (item.BitisTarihi.Date - DateTime.Today).Days;
                                string rowBg = kalan < 0 ? Colors.Red.Lighten4
                                    : kalan <= 7 ? Colors.Yellow.Lighten4
                                    : kalan <= 30 ? Colors.Cyan.Lighten4
                                    : (sira % 2 == 0 ? Colors.Grey.Lighten4 : Colors.White);
                                string bitisFg = kalan < 0 ? Colors.Red.Darken3 : Colors.Black;

                                QuestPDF.Infrastructure.IContainer Cell() => table.Cell().Background(rowBg).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3);

                                Cell().AlignCenter().Text(sira++.ToString()).FontSize(7);
                                Cell().Text(item.Plaka ?? "").Bold().FontSize(7);
                                if (item.Arac != null)
                                    Cell().Text($"{item.Arac.AktifPlaka} - {item.Arac.Marka} {item.Arac.Model}").FontSize(7);
                                else
                                    table.Cell().Background(Colors.Red.Lighten2).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3).Text("Eşleşmedi").Bold().FontSize(7).FontColor(Colors.White);
                                Cell().Text(item.IsimSoyisim ?? "").FontSize(7);
                                Cell().Text(item.BaslamaTarihi.ToString("dd.MM.yyyy")).FontSize(7);
                                Cell().Text(t =>
                                {
                                    t.Span($"{item.BitisTarihi:dd.MM.yyyy}").FontSize(7).FontColor(bitisFg).Bold();
                                    t.Span(kalan < 0 ? $" ({Math.Abs(kalan)}g geçti)" : $" ({kalan}g)").FontSize(6).FontColor(bitisFg);
                                });
                                table.Cell().Background(GetDurumQpdfBg(item.Durum)).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3).AlignCenter().Text(item.Durum ?? "").Bold().FontSize(7);
                                table.Cell().Background(GetKasaQpdfBg(item.KasaDurumu)).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3).AlignCenter().Text(item.KasaDurumu ?? "").Bold().FontSize(7);
                                Cell().AlignRight().Text(item.FaturaOdemesi.ToString("N2")).FontSize(7);
                                Cell().AlignRight().Text(item.EkTutar.ToString("N2")).FontSize(7);
                                Cell().AlignRight().Text(item.Toplam.ToString("N2")).Bold().FontSize(7);
                                Cell().AlignRight().Text(item.KesilenFaturaTutar > 0 ? item.KesilenFaturaTutar.ToString("N2") : "-").FontSize(7);
                                Cell().AlignRight().Text(item.KalanFaturaTutar > 0 ? item.KalanFaturaTutar.ToString("N2") : "-").FontSize(7);
                                Cell().AlignRight().Text(item.OdenenTutar > 0 ? item.OdenenTutar.ToString("N2") : "-").FontSize(7);
                            }

                            // Toplam satırı
                            for (int i = 0; i < 8; i++)
                                table.Cell().Background(Colors.Grey.Darken1).Padding(4).Text(i == 7 ? "TOPLAM" : "").Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.FaturaOdemesi).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.EkTutar).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Green.Darken3).Padding(4).AlignRight().Text(data.Sum(x => x.Toplam).ToString("N2")).Bold().FontSize(10).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.KesilenFaturaTutar).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.KalanFaturaTutar).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.OdenenTutar).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                        });
                    });

                    page.Footer().Row(row =>
                    {
                        row.RelativeItem().Text("KOA Filo Servis - Kiralık C Plaka Takip Raporu").FontSize(7).FontColor(Colors.Grey.Darken1);
                        row.RelativeItem().AlignRight().Text(t =>
                        {
                            t.Span("Sayfa ").FontSize(7).FontColor(Colors.Grey.Darken1);
                            t.CurrentPageNumber().FontSize(7).Bold();
                            t.Span(" / ").FontSize(7).FontColor(Colors.Grey.Darken1);
                            t.TotalPages().FontSize(7).Bold();
                        });
                    });
                });
            });

            var bytes = document.GeneratePdf();
            var fileName = $"kiralik-c-plaka-rapor-{DateTime.Now:yyyyMMdd-HHmm}.pdf";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/pdf", base64);
            ToastService.ShowSuccess("PDF raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF aktarım hatası: {ex.Message}");
        }
    }

    private static string GetDurumQpdfBg(string? durum)
    {
        var d = (durum ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(d)) return Colors.Grey.Lighten3;
        if (d.Contains("aktif") || d.Contains("devam") || d.Contains("açık") || d.Contains("acik") || d.Contains("geçerli") || d.Contains("gecerli"))
            return Colors.Green.Lighten3;
        if (d.Contains("pasif") || d.Contains("iptal") || d.Contains("kapalı") || d.Contains("kapali") || d.Contains("sona") || d.Contains("bitti") || d.Contains("bitmiş") || d.Contains("bitmis") || d.Contains("dondu"))
            return Colors.Red.Lighten3;
        if (d.Contains("bekle") || d.Contains("askı") || d.Contains("aski") || d.Contains("onay"))
            return Colors.Yellow.Lighten3;
        return Colors.Cyan.Lighten3;
    }

