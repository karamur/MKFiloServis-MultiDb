@page "/araclar/plaka-takip"
@page "/filo-operasyon/kiralik-c-plaka-takip"
@page "/filo-operasyon/kiralık-c-plaka-takip"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using ClosedXML.Excel
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@inject IKiralikPlakaTakipService TakipService
@inject IFaturaSablonService FaturaSablonService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Kiralık C Plaka Takibi | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/araclar">Araçlar</a></li>
                    <li class="breadcrumb-item active">Plaka Takip</li>
                </ol>
            </nav>
            <h3 class="mb-0"><i class="bi bi-card-text me-2"></i>Kiralık C Plaka Takibi</h3>
            <small class="text-muted">Yeni kayıt yalnızca Excel ile yapılır.</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-warning" @onclick="OtomatikEslestir" disabled="@_eslestirmeCalisiyor || _faturaEslestirmeCalisiyor">
                @if (_eslestirmeCalisiyor || _faturaEslestirmeCalisiyor)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-link-45deg me-1"></i>
                }
                Araç Eşleştir
            </button>
            <button class="btn btn-outline-secondary" disabled title="Manuel fatura girişi aktif">
                <i class="bi bi-hand-index-thumb me-1"></i>
                Fatura Eşleştir (Kapalı)
            </button>
            <button class="btn btn-outline-secondary" @onclick="OnizlemeAc" disabled="@(!FiltrelenmisListe.Any())"><i class="bi bi-eye me-1"></i> Önizleme</button>
            <button class="btn btn-outline-danger" @onclick="PdfAktar" disabled="@(!FiltrelenmisListe.Any())"><i class="bi bi-file-earmark-pdf me-1"></i> PDF</button>
            <button class="btn btn-outline-success" @onclick="ExcelAktar" disabled="@(!FiltrelenmisListe.Any())"><i class="bi bi-file-earmark-excel me-1"></i> Excel</button>
            <button class="btn btn-outline-info" @onclick="SablonIndir"><i class="bi bi-download me-1"></i> Şablon</button>
            <button class="btn btn-success" @onclick="ExcelImportModalAc"><i class="bi bi-upload me-1"></i> Excel Aktar</button>
        </div>
    </div>

    @if (!_loading && _liste.Any())
    {
        <div class="card mb-3">
            <div class="card-body py-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label mb-1 small">Arama (Plaka / İsim)</label>
                        <input type="text" class="form-control form-control-sm" @bind="aramaMetni" @bind:event="oninput" placeholder="Plaka veya isim..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Durum</label>
                        <select class="form-select form-select-sm" @bind="durumFiltre">
                            <option value="">Tümü</option>
                            @foreach (var d in DurumSecenekleri)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Kasa Durumu</label>
                        <select class="form-select form-select-sm" @bind="kasaFiltre">
                            <option value="">Tümü</option>
                            @foreach (var k in KasaSecenekleri)
                            {
                                <option value="@k">@k</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Bitiş Durumu</label>
                        <select class="form-select form-select-sm" @bind="bitisFiltre">
                            <option value="">Tümü</option>
                            <option value="gecti">Süresi Geçti</option>
                            <option value="7">7 gün içinde</option>
                            <option value="30">30 gün içinde</option>
                            <option value="aktif">31+ gün</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Eşleşme</label>
                        <select class="form-select form-select-sm" @bind="eslesmeFiltre">
                            <option value="">Tümü</option>
                            <option value="eslesti">Eşleşti</option>
                            <option value="eslesmedi">Eşleşmedi</option>
                        </select>
                    </div>
                    <div class="col-md-1 d-grid">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="FiltreleriTemizle" title="Filtreleri temizle"><i class="bi bi-x-circle"></i></button>
                    </div>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-3 small text-muted">
                    <span><i class="bi bi-list-ol me-1"></i><strong>@FiltrelenmisListe.Count</strong> / @_liste.Count kayıt</span>
                    <span class="text-success"><i class="bi bi-check-circle me-1"></i>Eşleşen: <strong>@FiltrelenmisListe.Count(x => x.Arac != null && x.Arac.Aktif)</strong></span>
                    <span class="text-danger"><i class="bi bi-x-circle me-1"></i>Eşleşmeyen: <strong>@FiltrelenmisListe.Count(x => x.Arac == null || (x.Arac != null && !x.Arac.Aktif))</strong></span>
                    <span class="text-danger"><i class="bi bi-clock-history me-1"></i>Süresi Geçen: <strong>@FiltrelenmisListe.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0)</strong></span>
                    <span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>7 Gün İçinde: <strong>@FiltrelenmisListe.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; })</strong></span>
                    <span><i class="bi bi-cash-coin me-1"></i>Tamamı: <strong>@FiltrelenmisListe.Sum(x => x.ToplamOdeme > 0 ? x.ToplamOdeme : x.Toplam).ToString("N2")</strong> ₺</span>
                    <span class="text-info"><i class="bi bi-receipt me-1"></i>Kesilen Toplam Fatura: <strong>@FiltrelenmisListe.Sum(x => x.KesilenFaturaTutar).ToString("N2")</strong> ₺</span>
                    <span class="text-success"><i class="bi bi-cash-stack me-1"></i>Ödenen Toplam Fatura: <strong>@FiltrelenmisListe.Sum(x => Math.Min(x.OdenenTutar, x.KesilenFaturaTutar)).ToString("N2")</strong> ₺</span>
                    <span class="text-danger"><i class="bi bi-hourglass-split me-1"></i>Kalan Fatura: <strong>@FiltrelenmisListe.Sum(x => Math.Max(0, x.KesilenFaturaTutar - x.OdenenTutar)).ToString("N2")</strong> ₺</span>
                    <span class="text-primary"><i class="bi bi-wallet2 me-1"></i>Ödenmesi Gereken Miktar: <strong>@FiltrelenmisListe.Sum(x => Math.Max(0, (x.ToplamOdeme > 0 ? x.ToplamOdeme : x.Toplam) - x.OdenenTutar)).ToString("N2")</strong> ₺</span>
                </div>
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (!_liste.Any())
    {
        <div class="alert alert-info">Kayıt bulunamadı.</div>
    }
    else if (!FiltrelenmisListe.Any())
    {
        <div class="alert alert-warning">Filtrelere uyan kayıt bulunamadı. <button class="btn btn-link p-0 align-baseline" @onclick="FiltreleriTemizle">Filtreleri temizle</button></div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>S.NO</th>
                            <th>PLAKA</th>
                            <th>EŞLEŞEN ARAÇ</th>
                            <th>İSİM SOYİSİM</th>
                            <th>BAŞLAMA TARİHİ</th>
                            <th>BİTİŞ TARİHİ</th>
                            <th>DURUM</th>
                            <th>KASA DURUMU</th>
                            <th>FATURA</th>
                            <th>AYLIK / YILLIK</th>
                            <th>EK TUTAR</th>
                            <th>TOPLAM</th>
                            <th class="text-end">TAMAMI</th>
                            <th class="text-end">KESİLEN TOPLAM FATURA</th>
                            <th class="text-end">ÖDENEN TOPLAM FATURA</th>
                            <th class="text-end">KALAN FATURA</th>
                            <th class="text-end">ÖDENMESİ GEREKEN MİKTAR</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var liste = FiltrelenmisListe;
                        }
                        @for (int i = 0; i < liste.Count; i++)
                        {
                            var item = liste[i];
                            var pasifAracBagli = item.Arac != null && !item.Arac.Aktif;
                            var eslesmedi = item.Arac == null || pasifAracBagli;
                            var kalanGun = (item.BitisTarihi.Date - DateTime.Today).Days;
                            var bitisClass = kalanGun < 0 ? "bg-danger text-white"
                                : kalanGun <= 7 ? "bg-warning text-dark"
                                : kalanGun <= 30 ? "bg-info text-dark"
                                : "bg-success text-white";
                            var bitisText = kalanGun < 0
                                ? $"{item.BitisTarihi:dd.MM.yyyy} ({Math.Abs(kalanGun)} gün geçti)"
                                : $"{item.BitisTarihi:dd.MM.yyyy} ({kalanGun} gün)";
                            var durumClass = GetDurumClass(item.Durum);
                            var kasaClass = GetKasaClass(item.KasaDurumu);
                            <tr class="@(eslesmedi ? "table-danger" : "")">
                                <td>@(i + 1)</td>
                                <td><strong>@item.Plaka</strong></td>
                                <td>
                                    @if (!eslesmedi)
                                    {
                                        <a href="javascript:void(0)" class="text-decoration-none" @onclick="() => AracDetayGoster(item.Arac!)" title="Araç detayları için tıkla">
                                            <strong>@item.Arac!.AktifPlaka</strong>
                                            @if (!string.IsNullOrWhiteSpace(item.Arac.Marka))
                                            {
                                                <br/><small class="text-muted">@item.Arac.Marka @item.Arac.Model @item.Arac.ModelYili</small>
                                            }
                                        </a>
                                    }
                                    else if (pasifAracBagli)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-circle me-1"></i>Pasif araç</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Eşleşmedi</span>
                                    }
                                </td>
                                <td>@item.IsimSoyisim</td>
                                <td>@item.BaslamaTarihi.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge @bitisClass" title="Bitiş tarihi">@bitisText</span></td>
                                <td><span class="badge @durumClass">@item.Durum</span></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.KasaDurumu))
                                    {
                                        <span class="badge @kasaClass">@item.KasaDurumu</span>
                                    }
                                </td>
                                <td>@item.FaturaOdemesi.ToString("N2")</td>
                                <td>@item.Periyot <br /><small class="text-muted">@item.AylikVeyaYillikTutar.ToString("N2")</small></td>
                                <td>@item.EkTutar.ToString("N2")</td>
                                <td><strong>@item.Toplam.ToString("N2")</strong></td>
                                <td class="text-end fw-semibold">@((item.ToplamOdeme > 0 ? item.ToplamOdeme : item.Toplam).ToString("N2"))</td>
                                <td class="text-end">@(item.KesilenFaturaTutar > 0 ? item.KesilenFaturaTutar.ToString("N2") : "-")</td>
                                <td class="text-end">
                                    @{
                                        var kesilendenOdenenToplam = Math.Min(item.OdenenTutar, item.KesilenFaturaTutar);
                                    }
                                    @if (kesilendenOdenenToplam > 0)
                                    { <span class="text-success fw-semibold">@kesilendenOdenenToplam.ToString("N2")</span> }
                                    else { <span>-</span> }
                                </td>
                                <td class="text-end">
                                    @{
                                        var kalanFatura = Math.Max(0, item.KesilenFaturaTutar - item.OdenenTutar);
                                    }
                                    @if (kalanFatura > 0)
                                    { <span class="text-danger fw-semibold">@kalanFatura.ToString("N2")</span> }
                                    else { <span>-</span> }
                                </td>
                                <td class="text-end">
                                    @{
                                        var odenmesiGerekenMiktar = Math.Max(0, (item.ToplamOdeme > 0 ? item.ToplamOdeme : item.Toplam) - item.OdenenTutar);
                                    }
                                    @if (odenmesiGerekenMiktar > 0)
                                    { <span class="text-primary fw-semibold">@odenmesiGerekenMiktar.ToString("N2")</span> }
                                    else { <span>-</span> }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-dark" title="Hesap Pusulası" @onclick="() => HesapPusulasiGosterAsync(item)"><i class="bi bi-journal-text"></i></button>
                                        <a href="/araclar/plaka-takip/@item.Id/duzenle" class="btn btn-outline-primary" title="Düzenle"><i class="bi bi-pencil"></i></a>
                                        <button class="btn btn-outline-danger" title="Sil" @onclick="() => Sil(item)"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showImportModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Excel'den Kiralık C Plaka Aktar</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ImportModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Excel sütunları: <strong>PLAKA | İSİM SOYİSİM | BAŞLAMA TARİHİ | BİTİŞ TARİHİ | DURUM | KASA DURUMU | FATURA | AYLIK / YILLIK | TUTAR | EK TUTAR | TOPLAM</strong>
                        <br /><small class="text-muted">TOPLAM otomatik hesaplanır: <strong>FATURA + EK TUTAR</strong></small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Excel Dosyası Seç *</label>
                        <InputFile class="form-control" OnChange="DosyaSecildi" accept=".xlsx,.xls" />
                    </div>

                    @if (importResult != null)
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-md-3 col-6"><div class="card bg-success text-white text-center py-2"><h4 class="mb-0">@importResult.ImportedCount</h4><small>Eklenen</small></div></div>
                            <div class="col-md-3 col-6"><div class="card bg-warning text-dark text-center py-2"><h4 class="mb-0">@importResult.UpdatedCount</h4><small>Güncellenen</small></div></div>
                            <div class="col-md-3 col-6"><div class="card bg-secondary text-white text-center py-2"><h4 class="mb-0">@importResult.SkippedCount</h4><small>Atlanan</small></div></div>
                            <div class="col-md-3 col-6"><div class="card bg-danger text-white text-center py-2"><h4 class="mb-0">@importResult.ErrorCount</h4><small>Hata</small></div></div>
                        </div>

                        @if (importResult.SkippedRecords.Any())
                        {
                            <div class="alert alert-warning py-2" style="max-height: 160px; overflow-y: auto;">
                                @foreach (var s in importResult.SkippedRecords.Take(30))
                                {
                                    <div><small>@s</small></div>
                                }
                            </div>
                        }

                        @if (importResult.Errors.Any())
                        {
                            <div class="alert alert-danger py-2" style="max-height: 200px; overflow-y: auto;">
                                @foreach (var error in importResult.Errors.Take(30))
                                {
                                    <div><small>@error</small></div>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-info" @onclick="SablonIndir"><i class="bi bi-download me-1"></i>Şablon İndir</button>
                    <button type="button" class="btn btn-secondary" @onclick="ImportModalKapat">Kapat</button>
                    <button type="button" class="btn btn-success" @onclick="ExcelImportYap" disabled="@(isImporting || importFile == null)">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-upload me-1"></i>Aktarımı Başlat
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showOnizlemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Rapor Önizleme - Kiralık C Plaka (@FiltrelenmisListe.Count kayıt)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOnizlemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-primary">Toplam: @FiltrelenmisListe.Count</span>
                        <span class="badge bg-success">Eşleşen: @FiltrelenmisListe.Count(x => x.Arac != null && x.Arac.Aktif)</span>
                        <span class="badge bg-danger">Eşleşmeyen: @FiltrelenmisListe.Count(x => x.Arac == null || (x.Arac != null && !x.Arac.Aktif))</span>
                        <span class="badge bg-dark">Süresi Geçen: @FiltrelenmisListe.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0)</span>
                        <span class="badge bg-warning text-dark">7 Gün İçinde: @FiltrelenmisListe.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; })</span>
                        <span class="badge bg-info text-dark">Toplam Tutar: @FiltrelenmisListe.Sum(x => x.Toplam).ToString("N2") ₺</span>
                        <span class="badge bg-warning text-dark">Toplam Ödenen: @FiltrelenmisListe.Sum(x => x.OdenenTutar).ToString("N2") ₺</span>
                        <span class="badge bg-danger">Toplam Kalan: @FiltrelenmisListe.Sum(x => x.KalanFaturaTutar).ToString("N2") ₺</span>
                    </div>

                    @{
                        var kasaGruplari = FiltrelenmisListe
                            .GroupBy(x => string.IsNullOrWhiteSpace(x.KasaDurumu) ? "(Boş)" : x.KasaDurumu.Trim())
                            .OrderByDescending(g => g.Count())
                            .ToList();
                        var durumGruplari = FiltrelenmisListe
                            .GroupBy(x => string.IsNullOrWhiteSpace(x.Durum) ? "(Boş)" : x.Durum.Trim())
                            .OrderByDescending(g => g.Count())
                            .ToList();
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header py-2 bg-light"><strong><i class="bi bi-tag me-1"></i>Duruma Göre Dağılım</strong></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Durum</th><th class="text-end">Adet</th><th class="text-end">Toplam (₺)</th></tr></thead>
                                        <tbody>
                                            @foreach (var g in durumGruplari)
                                            {
                                                <tr>
                                                    <td><span class="badge @GetDurumClass(g.Key)">@g.Key</span></td>
                                                    <td class="text-end">@g.Count()</td>
                                                    <td class="text-end">@g.Sum(x => x.Toplam).ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header py-2 bg-light"><strong><i class="bi bi-cash-stack me-1"></i>Kasa Durumuna Göre Dağılım</strong></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Kasa Durumu</th><th class="text-end">Adet</th><th class="text-end">Toplam (₺)</th></tr></thead>
                                        <tbody>
                                            @foreach (var g in kasaGruplari)
                                            {
                                                <tr>
                                                    <td><span class="badge @GetKasaClass(g.Key)">@g.Key</span></td>
                                                    <td class="text-end">@g.Count()</td>
                                                    <td class="text-end">@g.Sum(x => x.Toplam).ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Plaka</th>
                                    <th>Eşleşen Araç</th>
                                    <th>İsim Soyisim</th>
                                    <th>Başlama</th>
                                    <th>Bitiş</th>
                                    <th>Durum</th>
                                    <th>Kasa Durumu</th>
                                    <th class="text-end">Fatura</th>
                                    <th class="text-end">Ek Tutar</th>
                                    <th class="text-end">Toplam</th>
                                    <th>Kesilen Fatura No</th>
                                    <th class="text-end">Kesilen Fatura</th>
                                    <th class="text-end">Kalan</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var ix = 1; }
                                @foreach (var item in FiltrelenmisListe)
                                {
                                    var pkalan = (item.BitisTarihi.Date - DateTime.Today).Days;
                                    var pBitisClass = pkalan < 0 ? "bg-danger text-white"
                                        : pkalan <= 7 ? "bg-warning text-dark"
                                        : pkalan <= 30 ? "bg-info text-dark"
                                        : "bg-success text-white";
                                    var pSatirClass = item.Arac == null ? "table-danger"
                                        : pkalan < 0 ? "table-danger"
                                        : pkalan <= 7 ? "table-warning"
                                        : pkalan <= 30 ? "table-info"
                                        : "";
                                    <tr class="@pSatirClass">
                                        <td>@(ix++)</td>
                                        <td><strong>@item.Plaka</strong></td>
                                        <td>
                                            @if (item.Arac != null && item.Arac.Aktif)
                                                        {
                                                            @($"{item.Arac.AktifPlaka} - {item.Arac.Marka} {item.Arac.Model}")
                                                        }
                                                        else if (item.Arac != null)
                                                        {
                                                            <span class="badge bg-warning text-dark">Pasif araç</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger">Eşleşmedi</span>
                                                        }
                                        </td>
                                        <td>@item.IsimSoyisim</td>
                                        <td>@item.BaslamaTarihi.ToString("dd.MM.yyyy")</td>
                                        <td><span class="badge @pBitisClass">@item.BitisTarihi.ToString("dd.MM.yyyy") (@(pkalan < 0 ? $"{Math.Abs(pkalan)}g geçti" : $"{pkalan}g"))</span></td>
                                        <td><span class="badge @GetDurumClass(item.Durum)">@(string.IsNullOrWhiteSpace(item.Durum) ? "-" : item.Durum)</span></td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.KasaDurumu))
                                            {
                                                <span class="badge @GetKasaClass(item.KasaDurumu)">@item.KasaDurumu</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-end">@item.FaturaOdemesi.ToString("N2")</td>
                                        <td class="text-end">@item.EkTutar.ToString("N2")</td>
                                        <td class="text-end"><strong>@item.Toplam.ToString("N2")</strong></td>
                                        <td>@(item.KesilenFaturaNo ?? "-")</td>
                                        <td class="text-end">@(item.KesilenFaturaTutar > 0 ? item.KesilenFaturaTutar.ToString("N2") : "-")</td>
                                        <td class="text-end">@(item.KalanFaturaTutar > 0 ? item.KalanFaturaTutar.ToString("N2") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th colspan="8" class="text-end">TOPLAM</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.FaturaOdemesi).ToString("N2")</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.EkTutar).ToString("N2")</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.Toplam).ToString("N2")</th>
                                    <th></th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.KesilenFaturaTutar).ToString("N2")</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.KalanFaturaTutar).ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger" @onclick="PdfAktar"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</button>
                    <button class="btn btn-outline-success" @onclick="ExcelAktar"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary" @onclick="() => showOnizlemeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showHesapPusulasiModal && seciliHesapItem != null)
{
    <style>
        .hesap-pusulasi-surface {
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        }

        .hesap-pusulasi-surface .modal-header {
            background: #1f2937 !important;
        }

        .hesap-pusulasi-summary-card {
            border: 0;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.12);
        }

        .hesap-pusulasi-summary-card small,
        .hesap-pusulasi-summary-card h5 {
            color: #0f172a !important;
        }

        .hesap-pusulasi-summary-card.is-primary { background: #dbeafe !important; }
        .hesap-pusulasi-summary-card.is-success { background: #dcfce7 !important; }
        .hesap-pusulasi-summary-card.is-danger { background: #fee2e2 !important; }
        .hesap-pusulasi-summary-card.is-warning { background: #fef3c7 !important; }

        .hesap-pusulasi-table thead th {
            background: #eff6ff !important;
            color: #1e3a8a !important;
            border-bottom: 1px solid #bfdbfe;
        }

        .hesap-pusulasi-table tbody td,
        .hesap-pusulasi-table tbody th,
        .hesap-pusulasi-table tfoot th,
        .hesap-pusulasi-table tfoot td {
            color: #111827;
        }

        .hesap-pusulasi-print-area {
            background: #fff;
            color: #111827;
        }

        @@media print {
            body * {
                visibility: hidden !important;
            }

            #hesapPusulasiPrintArea,
            #hesapPusulasiPrintArea * {
                visibility: visible !important;
            }

            #hesapPusulasiPrintArea {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                padding: 0 !important;
                margin: 0 !important;
                background: #fff !important;
            }

            .no-print {
                display: none !important;
            }
        }
    </style>
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content hesap-pusulasi-surface">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title"><i class="bi bi-journal-text me-2"></i>Hesap Pusulası - @seciliHesapItem.Plaka</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HesapPusulasiKapat"></button>
                </div>
                <div class="modal-body">
                    <!-- Genel Bilgiler -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="card border-primary shadow-sm">
                                <div class="card-header py-2 bg-primary text-white"><strong><i class="bi bi-person me-1"></i>@seciliHesapItem.IsimSoyisim</strong></div>
                                <div class="card-body py-2 small">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr><td class="text-muted" width="80">Plaka</td><td><strong>@seciliHesapItem.Plaka</strong></td></tr>
                                        <tr><td class="text-muted">Başlama</td><td>@seciliHesapItem.BaslamaTarihi.ToString("dd.MM.yyyy")</td></tr>
                                        <tr><td class="text-muted">Bitiş</td><td>@seciliHesapItem.BitisTarihi.ToString("dd.MM.yyyy")</td></tr>
                                        <tr><td class="text-muted">Durum</td><td><span class="badge @GetDurumClass(seciliHesapItem.Durum)">@seciliHesapItem.Durum</span></td></tr>
                                        <tr><td class="text-muted">Periyot</td><td>@seciliHesapItem.Periyot</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="card hesap-pusulasi-summary-card is-primary text-center py-2">
                                        <small>Toplam Borç</small>
                                        <h5 class="mb-0 fw-bold">@seciliHesapItem.ToplamOdeme.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card hesap-pusulasi-summary-card is-success text-center py-2">
                                        <small>Ödenen</small>
                                        <h5 class="mb-0 fw-bold">@seciliHesapItem.OdenenTutar.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card hesap-pusulasi-summary-card @(seciliHesapItem.KalanOdeme > 0 ? "is-danger" : "is-success") text-center py-2">
                                        <small>Kalan Ödeme</small>
                                        <h5 class="mb-0 fw-bold">@seciliHesapItem.KalanOdeme.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card hesap-pusulasi-summary-card @(seciliHesapItem.KalanFaturaTutar > 0 ? "is-warning" : "is-success") text-center py-2">
                                        <small>Kalan Fatura</small>
                                        <h5 class="mb-0 fw-bold">@seciliHesapItem.KalanFaturaTutar.ToString("N2")</h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fatura Bilgileri -->
                    <div class="card mb-3">
                        <div class="card-header py-2 bg-light d-flex justify-content-between align-items-center">
                            <strong><i class="bi bi-receipt me-1"></i>Fatura Bilgileri</strong>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-secondary">Adet: @seciliFaturaSatirlari.Count</span>
                                <span class="badge bg-dark">Toplam: @seciliFaturaSatirlari.Sum(x => x.Toplam).ToString("N2", CultureInfo.GetCultureInfo("tr-TR")) ₺</span>
                                @if (seciliFaturaSatirlari.Any(x => x.FaturaId.HasValue))
                                {
                                    <button class="btn btn-sm btn-outline-info" @onclick="HesapPusulasiPdfOnizle" disabled="@hesapPusulasiPdfYukleniyor">
                                        @if (hesapPusulasiPdfYukleniyor)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-eye me-1"></i>PDF Önizle
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="HesapPusulasiPdfIndir" disabled="@hesapPusulasiPdfYukleniyor">
                                        @if (hesapPusulasiPdfYukleniyor)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-file-pdf me-1"></i>PDF
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-body py-2">
                            @if (hesapPusulasiYukleniyor)
                            {
                                <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                            }
                            else if (!seciliFaturaSatirlari.Any())
                            {
                                <div class="text-muted">Kayıtta fatura detayı bulunamadı.</div>
                            }
                            else
                            {
                                <div class="table-responsive" style="max-height:280px; overflow-y:auto;">
                                    <table class="table table-sm table-striped align-middle mb-0 hesap-pusulasi-table">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>Fatura No</th>
                                                <th>Tarih</th>
                                                <th>Cari</th>
                                                <th>Açıklama</th>
                                                <th class="text-end">KDV</th>
                                                <th class="text-end">Toplam</th>
                                                <th class="text-center">Detay</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var fs in seciliFaturaSatirlari)
                                            {
                                                <tr>
                                                    <td><strong>@(string.IsNullOrWhiteSpace(fs.FaturaNo) ? "-" : fs.FaturaNo)</strong></td>
                                                    <td>@(fs.FaturaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                                    <td>@(string.IsNullOrWhiteSpace(fs.CariUnvan) ? "-" : fs.CariUnvan)</td>
                                                    <td class="small">@(string.IsNullOrWhiteSpace(fs.Aciklama) ? "-" : fs.Aciklama)</td>
                                                    <td class="text-end">@fs.Kdv.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                    <td class="text-end fw-semibold">@fs.Toplam.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                    <td class="text-center">
                                                        @if (fs.FaturaId.HasValue)
                                                        {
                                                            <a class="btn btn-sm btn-outline-primary" href="/faturalar/detay/@fs.FaturaId.Value" target="_blank">
                                                                <i class="bi bi-box-arrow-up-right"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </td>
                                                </tr>
                                                @if (fs.Kalemler.Any())
                                                {
                                                    <tr>
                                                        <td colspan="7" class="bg-light">
                                                            <div class="small fw-semibold mb-1">Kalemler</div>
                                                            <div class="table-responsive">
                                                                <table class="table table-sm table-borderless mb-0">
                                                                    <thead>
                                                                        <tr>
                                                                            <th>Açıklama</th>
                                                                            <th class="text-end">Miktar</th>
                                                                            <th>Birim</th>
                                                                            <th class="text-end">Birim Fiyat</th>
                                                                            <th class="text-end">KDV %</th>
                                                                            <th class="text-end">KDV</th>
                                                                            <th class="text-end">Toplam</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var k in fs.Kalemler)
                                                                        {
                                                                            <tr>
                                                                                <td>@k.Aciklama</td>
                                                                                <td class="text-end">@k.Miktar.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                                                <td>@k.Birim</td>
                                                                                <td class="text-end">@k.BirimFiyat.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                                                <td class="text-end">@k.KdvOrani.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                                                <td class="text-end">@k.KdvTutari.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                                                <td class="text-end fw-semibold">@k.Toplam.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <th colspan="5" class="text-end">Fatura Toplamı</th>
                                                <th class="text-end">@seciliFaturaSatirlari.Sum(x => x.Toplam).ToString("N2", CultureInfo.GetCultureInfo("tr-TR"))</th>
                                                <th></th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                <div class="mt-2 small text-muted">
                                    Kalan Fatura: <strong class="text-danger">@seciliHesapItem.KalanFaturaTutar.ToString("N2", CultureInfo.GetCultureInfo("tr-TR")) ₺</strong>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Aylık Vade Takvimi -->
                    @{
                        var vadeAylari = HesapPlaniHesapla(seciliHesapItem, seciliFaturaSatirlari);
                    }
                    @if (vadeAylari.Any())
                    {
                        <div class="card">
                            <div class="card-header py-2 bg-light d-flex justify-content-between align-items-center">
                                <strong><i class="bi bi-calendar-month me-1"></i>Vade / Ödeme Takvimi</strong>
                                <small class="text-muted">@vadeAylari.Count ay</small>
                            </div>
                            <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                                <table class="table table-sm table-striped mb-0 hesap-pusulasi-table">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th width="40">#</th>
                                            <th>Ay</th>
                                            <th class="text-end">Tutar</th>
                                            <th>Eşleşen Faturalar</th>
                                            <th class="text-end">Eşleşen Toplam</th>
                                            <th class="text-end">Bu Ay Ödenen</th>
                                            <th class="text-end">Bu Ay Kalan</th>
                                            <th class="text-end">Durum</th>
                                            <th class="text-center">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ay in vadeAylari)
                                        {
                                            <tr>
                                                <td>@ay.Sira</td>
                                                <td>@ay.AyAdi @ay.Yil</td>
                                                <td class="text-end">@ay.OdemeTutari.ToString("N2")</td>
                                                <td>
                                                    @if (ay.EslesenFaturaNoListesi.Any())
                                                    {
                                                        <div class="d-flex flex-wrap gap-1">
                                                            @foreach (var fno in ay.EslesenFaturaNoListesi)
                                                            {
                                                                <span class="badge bg-light text-dark border">@fno</span>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td class="text-end">
                                                    @if (ay.EslesenFaturaTutari > 0)
                                                    {
                                                        <span class="fw-semibold text-primary">@ay.EslesenFaturaTutari.ToString("N2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td class="text-end text-success fw-semibold">@ay.BuAyOdenen.ToString("N2")</td>
                                                <td class="text-end text-danger fw-semibold">@ay.BuAyKalan.ToString("N2")</td>
                                                <td class="text-end">
                                                    @if (ay.OdemeDurumu == "YAPILDI")
                                                    { <span class="badge bg-success">Ödeme Yapıldı</span> }
                                                    else if (ay.OdemeDurumu == "KISMI")
                                                    { <span class="badge bg-warning text-dark">Kısmi Ödeme</span> }
                                                    else if (ay.BugundenOnce)
                                                    { <span class="badge bg-danger">Ödenmedi</span> }
                                                    else
                                                    { <span class="badge bg-info text-dark">Bekliyor</span> }
                                                </td>
                                                <td class="text-center">
                                                    <a class="btn btn-sm btn-outline-primary" href="/araclar/plaka-takip/@seciliHesapItem.Id/duzenle">
                                                        <i class="bi bi-link-45deg"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            @if (ay.EslesenFaturaDetaylari.Any())
                                            {
                                                <tr>
                                                    <td></td>
                                                    <td colspan="8" class="bg-light">
                                                        <div class="small fw-semibold mb-1">Ay Detayı</div>
                                                        <div class="table-responsive">
                                                            <table class="table table-sm mb-0">
                                                                <thead>
                                                                    <tr>
                                                                        <th>Fatura No</th>
                                                                        <th>Tarih</th>
                                                                        <th>Cari</th>
                                                                        <th>Açıklama</th>
                                                                        <th class="text-end">Toplam</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var fd in ay.EslesenFaturaDetaylari)
                                                                    {
                                                                        <tr>
                                                                            <td>@fd.FaturaNo</td>
                                                                            <td>@(fd.FaturaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                                                            <td>@(fd.CariUnvan ?? "-")</td>
                                                                            <td>@(fd.Aciklama ?? "-")</td>
                                                                            <td class="text-end fw-semibold">@fd.Toplam.ToString("N2")</td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <th colspan="2">Toplam</th>
                                            <th class="text-end">@vadeAylari.Sum(a => a.OdemeTutari).ToString("N2")</th>
                                            <th></th>
                                            <th class="text-end">@vadeAylari.Sum(a => a.EslesenFaturaTutari).ToString("N2")</th>
                                            <th class="text-end">@vadeAylari.Sum(a => a.BuAyOdenen).ToString("N2")</th>
                                            <th class="text-end">@vadeAylari.Sum(a => a.BuAyKalan).ToString("N2")</th>
                                            <th></th>
                                            <th></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer no-print">
                    <button type="button" class="btn btn-outline-info" @onclick="HesapPusulasiOnizlemeAc">
                        <i class="bi bi-eye me-1"></i>Önizle
                    </button>
                    <button type="button" class="btn btn-outline-dark" @onclick="HesapPusulasiYazdir">
                        <i class="bi bi-printer me-1"></i>Yazdır
                    </button>
                    <a href="/araclar/plaka-takip/@seciliHesapItem.Id/duzenle" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Düzenle
                    </a>
                    <button type="button" class="btn btn-secondary" @onclick="HesapPusulasiKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showHesapPusulasiOnizleme && seciliHesapItem != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Hesap Pusulası Önizleme - @seciliHesapItem.Plaka</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HesapPusulasiOnizlemeKapat"></button>
                </div>
                <div class="modal-body p-0" style="height:80vh;">
                    <iframe srcdoc="@hesapPusulasiHtmlOnizleme" style="width:100%; height:100%; border:none;"></iframe>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-dark" @onclick="HesapPusulasiYazdir">
                        <i class="bi bi-printer me-1"></i>Yazdır
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="HesapPusulasiOnizlemeKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showHesapPusulasiPdfOnizleme && !string.IsNullOrWhiteSpace(hesapPusulasiPdfDataUrl))
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-file-pdf me-2"></i>PDF Önizleme - @(hesapPusulasiPdfDosyaAdi ?? "fatura")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="KapatHesapPusulasiPdfOnizleme"></button>
                </div>
                <div class="modal-body p-0" style="height:75vh;">
                    <iframe src="@hesapPusulasiPdfDataUrl" style="width:100%; height:100%; border:none;"></iframe>
                </div>
