@code {
    private bool _loading = true;
    private List<KiralikPlakaTakip> _liste = new();

    private bool showImportModal;
    private bool isImporting;
    private bool _eslestirmeCalisiyor;
    private bool _faturaEslestirmeCalisiyor;
    private bool showOnizlemeModal;
    private bool showAracDetayModal;
    private Arac? seciliArac;
    private List<GuzergahBilgisi> seciliGuzergahBilgisi = new();
    private bool showHesapPusulasiModal;
    private KiralikPlakaTakip? seciliHesapItem;
    private List<HesapPusulasiFaturaSatiri> seciliFaturaSatirlari = new();
    private bool hesapPusulasiYukleniyor;
    private bool hesapPusulasiPdfYukleniyor;
    private bool showHesapPusulasiPdfOnizleme;
    private bool showHesapPusulasiOnizleme;
    private string? hesapPusulasiHtmlOnizleme;
    private string? hesapPusulasiPdfDataUrl;
    private string? hesapPusulasiPdfDosyaAdi;
    private IBrowserFile? importFile;
    private KiralikPlakaImportResult? importResult;

    // Filtre alanları
    private string aramaMetni = string.Empty;
    private string durumFiltre = string.Empty;
    private string kasaFiltre = string.Empty;
    private string bitisFiltre = string.Empty;
    private string eslesmeFiltre = string.Empty;

    private IEnumerable<string> DurumSecenekleri => _liste
        .Select(x => (x.Durum ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrEmpty(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x);

    private IEnumerable<string> KasaSecenekleri => _liste
        .Select(x => (x.KasaDurumu ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrEmpty(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x);

    private List<KiralikPlakaTakip> FiltrelenmisListe => _liste
        .Where(x => string.IsNullOrWhiteSpace(aramaMetni)
            || (x.Plaka ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
            || (x.IsimSoyisim ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
            || (x.Arac != null && (
                (x.Arac.AktifPlaka ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
                || (x.Arac.Marka ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
                || (x.Arac.Model ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase))))
        .Where(x => string.IsNullOrEmpty(durumFiltre)
            || string.Equals((x.Durum ?? string.Empty).Trim(), durumFiltre, StringComparison.OrdinalIgnoreCase))
        .Where(x => string.IsNullOrEmpty(kasaFiltre)
            || string.Equals((x.KasaDurumu ?? string.Empty).Trim(), kasaFiltre, StringComparison.OrdinalIgnoreCase))
        .Where(x =>
        {
            if (string.IsNullOrEmpty(bitisFiltre)) return true;
            var gun = (x.BitisTarihi.Date - DateTime.Today).Days;
            return bitisFiltre switch
            {
                "gecti" => gun < 0,
                "7" => gun >= 0 && gun <= 7,
                "30" => gun >= 0 && gun <= 30,
                "aktif" => gun > 30,
                _ => true
            };
        })
        .Where(x => eslesmeFiltre switch
        {
            "eslesti" => x.Arac != null && x.Arac.Aktif,
            "eslesmedi" => x.Arac == null || (x.Arac != null && !x.Arac.Aktif),
            _ => true
        })
        .OrderBy(x => x.BitisTarihi)
        .ToList();

    private void FiltreleriTemizle()
    {
        aramaMetni = string.Empty;
        durumFiltre = string.Empty;
        kasaFiltre = string.Empty;
        bitisFiltre = string.Empty;
        eslesmeFiltre = string.Empty;
    }

    private void OnizlemeAc() => showOnizlemeModal = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task AracDetayGoster(Arac arac)
    {
        seciliArac = arac;
        seciliGuzergahBilgisi.Clear();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // GuzergahSefer'den araca bağlı güzergahları bul
            var seferler = await db.GuzergahSeferleri
                .Include(s => s.Guzergah)
                .Where(s => s.AracId == arac.Id && s.Guzergah != null && !s.Guzergah.IsDeleted)
                .OrderBy(s => s.Guzergah!.GuzergahAdi).ThenBy(s => s.Sira)
                .ToListAsync();

            foreach (var s in seferler)
            {
                var slotAdi = s.Slot switch
                {
                    SeferSlot.Sabah => "Sabah",
                    SeferSlot.Aksam => "Akşam",
                    SeferSlot.Mesai => "Mesai",
                    SeferSlot.Diger1 => "Diğer 1",
                    SeferSlot.Diger2 => "Diğer 2",
                    SeferSlot.Diger3 => "Diğer 3",
                    SeferSlot.Diger4 => "Diğer 4",
                    SeferSlot.Diger5 => "Diğer 5",
                    _ => s.Slot.ToString()
                };
                seciliGuzergahBilgisi.Add(new GuzergahBilgisi
                {
                    GuzergahId = s.GuzergahId,
                    GuzergahAdi = s.Guzergah?.GuzergahAdi ?? "?",
                    SoforAdi = s.SoforAd,
                    SlotAdi = $"Slot: {slotAdi} (Sefer {s.Sira})"
                });
            }

            // Ayrıca varsayılan araç olarak atandığı güzergahları da bul
            var guzergahlar = await db.Guzergahlar
                .Include(g => g.VarsayilanSofor)
                .Where(g => g.VarsayilanAracId == arac.Id && g.Aktif && !g.IsDeleted)
                .ToListAsync();

            foreach (var g in guzergahlar)
            {
                if (!seciliGuzergahBilgisi.Any(x => x.GuzergahId == g.Id))
                {
                    var soforAdi = g.VarsayilanSofor != null
                        ? $"{g.VarsayilanSofor.Ad} {g.VarsayilanSofor.Soyad}"
                        : null;
                    seciliGuzergahBilgisi.Add(new GuzergahBilgisi
                    {
                        GuzergahId = g.Id,
                        GuzergahAdi = g.GuzergahAdi ?? "?",
                        SoforAdi = soforAdi,
                        SlotAdi = "Varsayılan Araç"
                    });
                }
            }
        }
        catch { /* güzergah bilgisi yüklenemezse modal yine de açılsın */ }

        showAracDetayModal = true;
    }

    private void AracDetayKapat()
    {
        showAracDetayModal = false;
        seciliArac = null;
        seciliGuzergahBilgisi.Clear();
    }

    private async Task HesapPusulasiGosterAsync(KiralikPlakaTakip item)
    {
        showHesapPusulasiModal = true;
        hesapPusulasiYukleniyor = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            seciliHesapItem = await db.KiralikPlakaTakipler
                .Include(x => x.Arac)
                .Include(x => x.FaturaDetaylari.Where(fd => !fd.IsDeleted))
                .FirstOrDefaultAsync(x => !x.IsDeleted && x.Id == item.Id);

            if (seciliHesapItem == null)
            {
                ToastService.ShowWarning("Kayıt detayları bulunamadı.");
                showHesapPusulasiModal = false;
                return;
            }

            seciliHesapItem.FaturaDetaylari = seciliHesapItem.FaturaDetaylari
                .OrderBy(x => x.Yil)
                .ThenBy(x => x.Ay)
                .ThenBy(x => x.Sira)
                .ToList();

            var faturaNoSet = ParseFaturaNoListesi(seciliHesapItem.KesilenFaturaNo)
                .Select(x => x.ToUpperInvariant())
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            var linkedById = new List<Fatura>();
            if (seciliHesapItem.GelenFaturaId.HasValue && seciliHesapItem.GelenFaturaId.Value > 0)
            {
                var fatura = await db.Faturalar
                    .Include(f => f.Cari)
                    .Include(f => f.FaturaKalemleri)
                    .FirstOrDefaultAsync(f => !f.IsDeleted && f.Id == seciliHesapItem.GelenFaturaId.Value);
                if (fatura != null)
                    linkedById.Add(fatura);
            }

            var linkedByNo = await db.Faturalar
                .Include(f => f.Cari)
                .Include(f => f.FaturaKalemleri)
                .Where(f => !f.IsDeleted && faturaNoSet.Contains(f.FaturaNo.ToUpper()))
                .OrderByDescending(f => f.FaturaTarihi)
                .ToListAsync();

            var allLinked = linkedById
                .Concat(linkedByNo)
                .GroupBy(f => f.Id)
                .Select(g => g.First())
                .OrderByDescending(f => f.FaturaTarihi)
                .ToList();

            seciliFaturaSatirlari = allLinked.Select(f => new HesapPusulasiFaturaSatiri
            {
                FaturaId = f.Id,
                FaturaNo = f.FaturaNo,
                FaturaTarihi = f.FaturaTarihi,
                Aciklama = f.Aciklama,
                CariUnvan = f.Cari?.Unvan,
                Kdv = f.KdvTutar,
                Toplam = f.GenelToplam,
                Kalemler = (f.FaturaKalemleri ?? new List<FaturaKalem>())
                    .OrderBy(k => k.SiraNo)
                    .Select(k => new HesapPusulasiFaturaKalemi
                    {
                        Aciklama = k.Aciklama,
                        Miktar = k.Miktar,
                        Birim = k.Birim,
                        BirimFiyat = k.BirimFiyat,
                        KdvOrani = k.KdvOrani,
                        KdvTutari = k.KdvTutar,
                        Toplam = k.ToplamTutar
                    })
                    .ToList()
            }).ToList();

            if (!seciliFaturaSatirlari.Any() && seciliHesapItem.FaturaDetaylari.Any())
            {
                seciliFaturaSatirlari = seciliHesapItem.FaturaDetaylari
                    .Select(detay => new HesapPusulasiFaturaSatiri
                    {
                        FaturaNo = detay.FaturaNo,
                        FaturaTarihi = detay.FaturaTarihi,
                        Toplam = detay.FaturaTutari,
                        Aciklama = detay.EkOdemeTutari > 0
                            ? $"Birleşik takip satırı • Baz: {detay.BazPlanTutari:N2} + Ek: {detay.EkOdemeTutari:N2}"
                            : "Birleşik takip satırı"
                    })
                    .ToList();
            }

            if (!seciliFaturaSatirlari.Any())
            {
                var manualNos = ParseFaturaNoListesi(seciliHesapItem.KesilenFaturaNo).ToList();
                if (manualNos.Any())
                {
                    var parca = manualNos.Count > 0 ? seciliHesapItem.KesilenFaturaTutar / manualNos.Count : 0;
                    seciliFaturaSatirlari = manualNos.Select(no => new HesapPusulasiFaturaSatiri
                    {
                        FaturaNo = no,
                        FaturaTarihi = seciliHesapItem.KesilenFaturaTarih,
                        Toplam = parca,
                        Aciklama = "Manuel fatura girişi"
                    }).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowWarning($"Fatura detayları yüklenirken uyarı oluştu: {ex.Message}");
            seciliFaturaSatirlari = new();
        }
        finally
        {
            hesapPusulasiYukleniyor = false;
        }
    }

    private void HesapPusulasiKapat()
    {
        showHesapPusulasiModal = false;
        seciliHesapItem = null;
        seciliFaturaSatirlari.Clear();
        hesapPusulasiYukleniyor = false;
        hesapPusulasiPdfYukleniyor = false;
        HesapPusulasiOnizlemeKapat();
        KapatHesapPusulasiPdfOnizleme();
    }

    private static List<OdemePlanSatiri> HesapPlaniHesapla(KiralikPlakaTakip item, IReadOnlyCollection<HesapPusulasiFaturaSatiri> faturalar)
    {
        var liste = new List<OdemePlanSatiri>();
        if (item.Periyot != "AYLIK") return liste;

        var baslangic = item.BaslamaTarihi;
        var bitis = item.BitisTarihi;
        var bugun = DateTime.Today;

        var faturaAyGruplari = faturalar
            .Where(f => f.FaturaTarihi.HasValue)
            .GroupBy(f => (f.FaturaTarihi!.Value.Year, f.FaturaTarihi!.Value.Month))
            .ToDictionary(g => g.Key, g => g.ToList());

        var tarih = new DateTime(baslangic.Year, baslangic.Month, 1);
        var bitisAy = new DateTime(bitis.Year, bitis.Month, 1);
        int sira = 0;
        var kalanOdenen = item.OdenenTutar;

        while (tarih <= bitisAy)
        {
            sira++;
            var aylikTutar = item.AylikVeyaYillikTutar;
            var buAyOdenen = Math.Min(aylikTutar, Math.Max(0, kalanOdenen));
            kalanOdenen = Math.Max(0, kalanOdenen - aylikTutar);

            var ayAnahtar = (tarih.Year, tarih.Month);
            var eslesenFaturalar = faturaAyGruplari.TryGetValue(ayAnahtar, out var ayFaturalari)
                ? ayFaturalari
                : new List<HesapPusulasiFaturaSatiri>();

            var eslesenFaturaToplami = eslesenFaturalar.Sum(x => x.Toplam);
            var odemeDurumu = buAyOdenen >= aylikTutar && aylikTutar > 0
                ? "YAPILDI"
                : (buAyOdenen > 0 ? "KISMI" : "YAPILMADI");

            liste.Add(new OdemePlanSatiri
            {
                Sira = sira,
                Yil = tarih.Year,
                AyAdi = new DateTime(2024, tarih.Month, 1).ToString("MMMM"),
                OdemeTutari = aylikTutar,
                EslesenFaturaTutari = eslesenFaturaToplami,
                EslesenFaturaNoListesi = eslesenFaturalar
                    .Select(x => x.FaturaNo)
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Cast<string>()
                    .ToList(),
                EslesenFaturaDetaylari = eslesenFaturalar
                    .OrderByDescending(x => x.FaturaTarihi)
                    .ToList(),
                BuAyOdenen = buAyOdenen,
                BuAyKalan = Math.Max(0, aylikTutar - buAyOdenen),
                OdemeDurumu = odemeDurumu,
                BugundenOnce = tarih < bugun
            });

            tarih = tarih.AddMonths(1);
        }

        return liste;
    }

    private class OdemePlanSatiri
    {
        public int Sira { get; set; }
        public int Yil { get; set; }
        public string AyAdi { get; set; } = "";
        public decimal OdemeTutari { get; set; }
        public decimal EslesenFaturaTutari { get; set; }
        public List<string> EslesenFaturaNoListesi { get; set; } = new();
        public List<HesapPusulasiFaturaSatiri> EslesenFaturaDetaylari { get; set; } = new();
        public decimal BuAyOdenen { get; set; }
        public decimal BuAyKalan { get; set; }
        public string OdemeDurumu { get; set; } = "YAPILMADI";
        public bool BugundenOnce { get; set; }
    }

    private class HesapPusulasiFaturaSatiri
    {
        public int? FaturaId { get; set; }
        public string? FaturaNo { get; set; }
        public DateTime? FaturaTarihi { get; set; }
        public string? Aciklama { get; set; }
        public string? CariUnvan { get; set; }
        public decimal Kdv { get; set; }
        public decimal Toplam { get; set; }
        public List<HesapPusulasiFaturaKalemi> Kalemler { get; set; } = new();
    }

    private class HesapPusulasiFaturaKalemi
    {
        public string? Aciklama { get; set; }
        public decimal Miktar { get; set; }
        public string? Birim { get; set; }
        public decimal BirimFiyat { get; set; }
        public decimal KdvOrani { get; set; }
        public decimal KdvTutari { get; set; }
        public decimal Toplam { get; set; }
    }

    private static IEnumerable<string> ParseFaturaNoListesi(string? kesilenFaturaNo)
    {
        if (string.IsNullOrWhiteSpace(kesilenFaturaNo))
            return Enumerable.Empty<string>();

        return kesilenFaturaNo
            .Split(new[] { ';', ',', '|' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private async Task HesapPusulasiPdfIndir()
    {
        if (hesapPusulasiPdfYukleniyor || !seciliFaturaSatirlari.Any(x => x.FaturaId.HasValue))
            return;

        hesapPusulasiPdfYukleniyor = true;
        try
        {
            var result = await HesapPusulasiPdfOlustur();
            if (result?.Basarili == true && result.PdfData != null)
            {
                var dosyaAdi = string.IsNullOrWhiteSpace(result.DosyaAdi)
                    ? "fatura.pdf"
                    : result.DosyaAdi;
                var base64 = Convert.ToBase64String(result.PdfData);
                await JS.InvokeVoidAsync("downloadFile", dosyaAdi, base64, "application/pdf");
                ToastService.ShowSuccess("Fatura PDF indirildi.");
            }
            else if (result != null)
            {
                ToastService.ShowWarning(result.Mesaj ?? "Fatura PDF oluşturulamadı.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hesap pusulası PDF işlemi başarısız: {ex.Message}");
        }
        finally
        {
            hesapPusulasiPdfYukleniyor = false;
        }
    }

    private async Task HesapPusulasiPdfOnizle()
    {
        if (hesapPusulasiPdfYukleniyor || !seciliFaturaSatirlari.Any(x => x.FaturaId.HasValue))
            return;

        hesapPusulasiPdfYukleniyor = true;
        try
        {
            var result = await HesapPusulasiPdfOlustur();
            if (result?.Basarili == true && result.PdfData != null)
            {
                var base64 = Convert.ToBase64String(result.PdfData);
                hesapPusulasiPdfDataUrl = $"data:application/pdf;base64,{base64}";
                hesapPusulasiPdfDosyaAdi = string.IsNullOrWhiteSpace(result.DosyaAdi) ? "fatura.pdf" : result.DosyaAdi;
                showHesapPusulasiPdfOnizleme = true;
            }
            else if (result != null)
            {
                ToastService.ShowWarning(result.Mesaj ?? "PDF önizleme oluşturulamadı.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF önizleme hatası: {ex.Message}");
        }
        finally
        {
            hesapPusulasiPdfYukleniyor = false;
        }
    }

