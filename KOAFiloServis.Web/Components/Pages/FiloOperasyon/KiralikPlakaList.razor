    private string HesapPusulasiHtmlOlustur()
    {
        if (seciliHesapItem == null)
            return string.Empty;

        var tr = CultureInfo.GetCultureInfo("tr-TR");
        var vadeAylari = HesapPlaniHesapla(seciliHesapItem, seciliFaturaSatirlari);
        var faturaRows = string.Join(string.Empty, seciliFaturaSatirlari.Select(fs => $@"<tr>
<td><strong>{System.Net.WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(fs.FaturaNo) ? "-" : fs.FaturaNo)}</strong></td>
<td>{(fs.FaturaTarihi?.ToString("dd.MM.yyyy") ?? "-")}</td>
<td>{System.Net.WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(fs.CariUnvan) ? "-" : fs.CariUnvan)}</td>
<td>{System.Net.WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(fs.Aciklama) ? "-" : fs.Aciklama)}</td>
