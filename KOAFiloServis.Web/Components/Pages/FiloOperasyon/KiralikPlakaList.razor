</tr>"));

        return $@"<!doctype html>
<html lang='tr'>
<head>
<meta charset='utf-8' />
<title>Hesap Pusulası - {System.Net.WebUtility.HtmlEncode(seciliHesapItem.Plaka)}</title>
<style>
