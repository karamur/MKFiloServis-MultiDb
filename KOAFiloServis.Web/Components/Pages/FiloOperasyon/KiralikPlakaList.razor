        var vadeRows = string.Join(string.Empty, vadeAylari.Select(ay => $@"<tr>
<td>{ay.Sira}</td>
<td>{System.Net.WebUtility.HtmlEncode($"{ay.AyAdi} {ay.Yil}")}</td>
<td style='text-align:right'>{ay.OdemeTutari.ToString("N2", tr)}</td>
<td>{System.Net.WebUtility.HtmlEncode(ay.EslesenFaturaNoListesi.Any() ? string.Join(", ", ay.EslesenFaturaNoListesi) : "-")}</td>
<td style='text-align:right'>{(ay.EslesenFaturaTutari > 0 ? ay.EslesenFaturaTutari.ToString("N2", tr) : "-")}</td>
<td style='text-align:right; color:#047857; font-weight:700;'>{ay.BuAyOdenen.ToString("N2", tr)}</td>
<td style='text-align:right; color:#dc2626; font-weight:700;'>{ay.BuAyKalan.ToString("N2", tr)}</td>
