    private async Task OtomatikEslestir()
    {
        if (_eslestirmeCalisiyor || _faturaEslestirmeCalisiyor) return;
        _eslestirmeCalisiyor = true;
        try
        {
            var sonuc = await TakipService.EslestirmeYapAsync();
            if (sonuc.Eslesen > 0)
            {
                ToastService.ShowSuccess($"{sonuc.Eslesen} kayıt araç ile eşleştirildi.");
                await LoadData();
            }
            else
            {
                ToastService.ShowInfo("Eşleştirilecek yeni kayıt bulunamadı.");
            }

            if (sonuc.CokluAdayNedeniyleAtlanan > 0)
                ToastService.ShowWarning($"{sonuc.CokluAdayNedeniyleAtlanan} kayıt çoklu aday nedeniyle otomatik eşleştirilmedi.");

            if (sonuc.PasifAracNedeniyleAtlanan > 0)
                ToastService.ShowInfo($"{sonuc.PasifAracNedeniyleAtlanan} kayıt yalnız pasif araç adayı bulunduğu için eşleştirilmedi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Eşleştirme başarısız: {ex.Message}");
        }
        finally
        {
            _eslestirmeCalisiyor = false;
        }
    }

