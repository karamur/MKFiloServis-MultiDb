@page "/araclar/plaka-takip"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using ClosedXML.Excel
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IKiralikPlakaTakipService TakipService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Kiralık C Plaka Takibi | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/araclar">Araçlar</a></li>
                    <li class="breadcrumb-item active">Plaka Takip</li>
                </ol>
            </nav>
            <h3 class="mb-0"><i class="bi bi-card-text me-2"></i>Kiralık C Plaka Takibi</h3>
            <small class="text-muted">Yeni kayıt yalnızca Excel ile yapılır.</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-warning" @onclick="OtomatikEslestir" disabled="@_eslestirmeCalisiyor">
                @if (_eslestirmeCalisiyor)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-link-45deg me-1"></i>
                }
                Otomatik Eşleştir
            </button>
            <button class="btn btn-outline-secondary" @onclick="OnizlemeAc" disabled="@(!FiltrelenmisListe.Any())"><i class="bi bi-eye me-1"></i> Önizleme</button>
            <button class="btn btn-outline-danger" @onclick="PdfAktar" disabled="@(!FiltrelenmisListe.Any())"><i class="bi bi-file-earmark-pdf me-1"></i> PDF</button>
            <button class="btn btn-outline-success" @onclick="ExcelAktar" disabled="@(!FiltrelenmisListe.Any())"><i class="bi bi-file-earmark-excel me-1"></i> Excel</button>
            <button class="btn btn-outline-info" @onclick="SablonIndir"><i class="bi bi-download me-1"></i> Şablon</button>
            <button class="btn btn-success" @onclick="ExcelImportModalAc"><i class="bi bi-upload me-1"></i> Excel Aktar</button>
        </div>
    </div>

    @if (!_loading && _liste.Any())
    {
        <div class="card mb-3">
            <div class="card-body py-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label mb-1 small">Arama (Plaka / İsim)</label>
                        <input type="text" class="form-control form-control-sm" @bind="aramaMetni" @bind:event="oninput" placeholder="Plaka veya isim..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Durum</label>
                        <select class="form-select form-select-sm" @bind="durumFiltre">
                            <option value="">Tümü</option>
                            @foreach (var d in DurumSecenekleri)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Kasa Durumu</label>
                        <select class="form-select form-select-sm" @bind="kasaFiltre">
                            <option value="">Tümü</option>
                            @foreach (var k in KasaSecenekleri)
                            {
                                <option value="@k">@k</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Bitiş Durumu</label>
                        <select class="form-select form-select-sm" @bind="bitisFiltre">
                            <option value="">Tümü</option>
                            <option value="gecti">Süresi Geçti</option>
                            <option value="7">7 gün içinde</option>
                            <option value="30">30 gün içinde</option>
                            <option value="aktif">31+ gün</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label mb-1 small">Eşleşme</label>
                        <select class="form-select form-select-sm" @bind="eslesmeFiltre">
                            <option value="">Tümü</option>
                            <option value="eslesti">Eşleşti</option>
                            <option value="eslesmedi">Eşleşmedi</option>
                        </select>
                    </div>
                    <div class="col-md-1 d-grid">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="FiltreleriTemizle" title="Filtreleri temizle"><i class="bi bi-x-circle"></i></button>
                    </div>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-3 small text-muted">
                    <span><i class="bi bi-list-ol me-1"></i><strong>@FiltrelenmisListe.Count</strong> / @_liste.Count kayıt</span>
                    <span class="text-success"><i class="bi bi-check-circle me-1"></i>Eşleşen: <strong>@FiltrelenmisListe.Count(x => x.Arac != null)</strong></span>
                    <span class="text-danger"><i class="bi bi-x-circle me-1"></i>Eşleşmeyen: <strong>@FiltrelenmisListe.Count(x => x.Arac == null)</strong></span>
                    <span class="text-danger"><i class="bi bi-clock-history me-1"></i>Süresi Geçen: <strong>@FiltrelenmisListe.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0)</strong></span>
                    <span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>7 Gün İçinde: <strong>@FiltrelenmisListe.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; })</strong></span>
                    <span><i class="bi bi-cash-coin me-1"></i>Toplam: <strong>@FiltrelenmisListe.Sum(x => x.Toplam).ToString("N2")</strong> ₺</span>
                </div>
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (!_liste.Any())
    {
        <div class="alert alert-info">Kayıt bulunamadı.</div>
    }
    else if (!FiltrelenmisListe.Any())
    {
        <div class="alert alert-warning">Filtrelere uyan kayıt bulunamadı. <button class="btn btn-link p-0 align-baseline" @onclick="FiltreleriTemizle">Filtreleri temizle</button></div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>S.NO</th>
                            <th>PLAKA</th>
                            <th>EŞLEŞEN ARAÇ</th>
                            <th>İSİM SOYİSİM</th>
                            <th>BAŞLAMA TARİHİ</th>
                            <th>BİTİŞ TARİHİ</th>
                            <th>DURUM</th>
                            <th>KASA DURUMU</th>
                            <th>FATURA</th>
                            <th>AYLIK / YILLIK</th>
                            <th>EK TUTAR</th>
                            <th>TOPLAM</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var liste = FiltrelenmisListe;
                        }
                        @for (int i = 0; i < liste.Count; i++)
                        {
                            var item = liste[i];
                            var eslesmedi = item.Arac == null;
                            var kalanGun = (item.BitisTarihi.Date - DateTime.Today).Days;
                            var bitisClass = kalanGun < 0 ? "bg-danger text-white"
                                : kalanGun <= 7 ? "bg-warning text-dark"
                                : kalanGun <= 30 ? "bg-info text-dark"
                                : "bg-success text-white";
                            var bitisText = kalanGun < 0
                                ? $"{item.BitisTarihi:dd.MM.yyyy} ({Math.Abs(kalanGun)} gün geçti)"
                                : $"{item.BitisTarihi:dd.MM.yyyy} ({kalanGun} gün)";
                            var durumClass = GetDurumClass(item.Durum);
                            var kasaClass = GetKasaClass(item.KasaDurumu);
                            <tr class="@(eslesmedi ? "table-danger" : "")">
                                <td>@(i + 1)</td>
                                <td><strong>@item.Plaka</strong></td>
                                <td>
                                    @if (!eslesmedi)
                                    {
                                        <a href="javascript:void(0)" class="text-decoration-none" @onclick="() => AracDetayGoster(item.Arac!)" title="Araç detayları için tıkla">
                                            <strong>@item.Arac!.AktifPlaka</strong>
                                            @if (!string.IsNullOrWhiteSpace(item.Arac.Marka))
                                            {
                                                <br/><small class="text-muted">@item.Arac.Marka @item.Arac.Model @item.Arac.ModelYili</small>
                                            }
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Eşleşmedi</span>
                                    }
                                </td>
                                <td>@item.IsimSoyisim</td>
                                <td>@item.BaslamaTarihi.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge @bitisClass" title="Bitiş tarihi">@bitisText</span></td>
                                <td><span class="badge @durumClass">@item.Durum</span></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.KasaDurumu))
                                    {
                                        <span class="badge @kasaClass">@item.KasaDurumu</span>
                                    }
                                </td>
                                <td>@item.FaturaOdemesi.ToString("N2")</td>
                                <td>@item.Periyot <br /><small class="text-muted">@item.AylikVeyaYillikTutar.ToString("N2")</small></td>
                                <td>@item.EkTutar.ToString("N2")</td>
                                <td><strong>@item.Toplam.ToString("N2")</strong></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/araclar/plaka-takip/@item.Id/duzenle" class="btn btn-outline-primary" title="Düzenle"><i class="bi bi-pencil"></i></a>
                                        <button class="btn btn-outline-danger" title="Sil" @onclick="() => Sil(item)"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showImportModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Excel'den Kiralık C Plaka Aktar</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ImportModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Excel sütunları: <strong>PLAKA | İSİM SOYİSİM | BAŞLAMA TARİHİ | BİTİŞ TARİHİ | DURUM | KASA DURUMU | FATURA | AYLIK / YILLIK | TUTAR | EK TUTAR | TOPLAM</strong>
                        <br /><small class="text-muted">TOPLAM otomatik hesaplanır: <strong>FATURA + EK TUTAR</strong></small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Excel Dosyası Seç *</label>
                        <InputFile class="form-control" OnChange="DosyaSecildi" accept=".xlsx,.xls" />
                    </div>

                    @if (importResult != null)
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-md-3 col-6"><div class="card bg-success text-white text-center py-2"><h4 class="mb-0">@importResult.ImportedCount</h4><small>Eklenen</small></div></div>
                            <div class="col-md-3 col-6"><div class="card bg-warning text-dark text-center py-2"><h4 class="mb-0">@importResult.UpdatedCount</h4><small>Güncellenen</small></div></div>
                            <div class="col-md-3 col-6"><div class="card bg-secondary text-white text-center py-2"><h4 class="mb-0">@importResult.SkippedCount</h4><small>Atlanan</small></div></div>
                            <div class="col-md-3 col-6"><div class="card bg-danger text-white text-center py-2"><h4 class="mb-0">@importResult.ErrorCount</h4><small>Hata</small></div></div>
                        </div>

                        @if (importResult.SkippedRecords.Any())
                        {
                            <div class="alert alert-warning py-2" style="max-height: 160px; overflow-y: auto;">
                                @foreach (var s in importResult.SkippedRecords.Take(30))
                                {
                                    <div><small>@s</small></div>
                                }
                            </div>
                        }

                        @if (importResult.Errors.Any())
                        {
                            <div class="alert alert-danger py-2" style="max-height: 200px; overflow-y: auto;">
                                @foreach (var error in importResult.Errors.Take(30))
                                {
                                    <div><small>@error</small></div>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-info" @onclick="SablonIndir"><i class="bi bi-download me-1"></i>Şablon İndir</button>
                    <button type="button" class="btn btn-secondary" @onclick="ImportModalKapat">Kapat</button>
                    <button type="button" class="btn btn-success" @onclick="ExcelImportYap" disabled="@(isImporting || importFile == null)">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-upload me-1"></i>Aktarımı Başlat
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showOnizlemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Rapor Önizleme - Kiralık C Plaka (@FiltrelenmisListe.Count kayıt)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOnizlemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-primary">Toplam: @FiltrelenmisListe.Count</span>
                        <span class="badge bg-success">Eşleşen: @FiltrelenmisListe.Count(x => x.Arac != null)</span>
                        <span class="badge bg-danger">Eşleşmeyen: @FiltrelenmisListe.Count(x => x.Arac == null)</span>
                        <span class="badge bg-dark">Süresi Geçen: @FiltrelenmisListe.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0)</span>
                        <span class="badge bg-warning text-dark">7 Gün İçinde: @FiltrelenmisListe.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; })</span>
                        <span class="badge bg-info text-dark">Toplam Tutar: @FiltrelenmisListe.Sum(x => x.Toplam).ToString("N2") ₺</span>
                    </div>

                    @{
                        var kasaGruplari = FiltrelenmisListe
                            .GroupBy(x => string.IsNullOrWhiteSpace(x.KasaDurumu) ? "(Boş)" : x.KasaDurumu.Trim())
                            .OrderByDescending(g => g.Count())
                            .ToList();
                        var durumGruplari = FiltrelenmisListe
                            .GroupBy(x => string.IsNullOrWhiteSpace(x.Durum) ? "(Boş)" : x.Durum.Trim())
                            .OrderByDescending(g => g.Count())
                            .ToList();
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header py-2 bg-light"><strong><i class="bi bi-tag me-1"></i>Duruma Göre Dağılım</strong></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Durum</th><th class="text-end">Adet</th><th class="text-end">Toplam (₺)</th></tr></thead>
                                        <tbody>
                                            @foreach (var g in durumGruplari)
                                            {
                                                <tr>
                                                    <td><span class="badge @GetDurumClass(g.Key)">@g.Key</span></td>
                                                    <td class="text-end">@g.Count()</td>
                                                    <td class="text-end">@g.Sum(x => x.Toplam).ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header py-2 bg-light"><strong><i class="bi bi-cash-stack me-1"></i>Kasa Durumuna Göre Dağılım</strong></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Kasa Durumu</th><th class="text-end">Adet</th><th class="text-end">Toplam (₺)</th></tr></thead>
                                        <tbody>
                                            @foreach (var g in kasaGruplari)
                                            {
                                                <tr>
                                                    <td><span class="badge @GetKasaClass(g.Key)">@g.Key</span></td>
                                                    <td class="text-end">@g.Count()</td>
                                                    <td class="text-end">@g.Sum(x => x.Toplam).ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Plaka</th>
                                    <th>Eşleşen Araç</th>
                                    <th>İsim Soyisim</th>
                                    <th>Başlama</th>
                                    <th>Bitiş</th>
                                    <th>Durum</th>
                                    <th>Kasa Durumu</th>
                                    <th class="text-end">Fatura</th>
                                    <th class="text-end">Ek Tutar</th>
                                    <th class="text-end">Toplam</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var ix = 1; }
                                @foreach (var item in FiltrelenmisListe)
                                {
                                    var pkalan = (item.BitisTarihi.Date - DateTime.Today).Days;
                                    var pBitisClass = pkalan < 0 ? "bg-danger text-white"
                                        : pkalan <= 7 ? "bg-warning text-dark"
                                        : pkalan <= 30 ? "bg-info text-dark"
                                        : "bg-success text-white";
                                    var pSatirClass = item.Arac == null ? "table-danger"
                                        : pkalan < 0 ? "table-danger"
                                        : pkalan <= 7 ? "table-warning"
                                        : pkalan <= 30 ? "table-info"
                                        : "";
                                    <tr class="@pSatirClass">
                                        <td>@(ix++)</td>
                                        <td><strong>@item.Plaka</strong></td>
                                        <td>
                                            @if (item.Arac != null)
                                            {
                                                @($"{item.Arac.AktifPlaka} - {item.Arac.Marka} {item.Arac.Model}")
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Eşleşmedi</span>
                                            }
                                        </td>
                                        <td>@item.IsimSoyisim</td>
                                        <td>@item.BaslamaTarihi.ToString("dd.MM.yyyy")</td>
                                        <td><span class="badge @pBitisClass">@item.BitisTarihi.ToString("dd.MM.yyyy") (@(pkalan < 0 ? $"{Math.Abs(pkalan)}g geçti" : $"{pkalan}g"))</span></td>
                                        <td><span class="badge @GetDurumClass(item.Durum)">@(string.IsNullOrWhiteSpace(item.Durum) ? "-" : item.Durum)</span></td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.KasaDurumu))
                                            {
                                                <span class="badge @GetKasaClass(item.KasaDurumu)">@item.KasaDurumu</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-end">@item.FaturaOdemesi.ToString("N2")</td>
                                        <td class="text-end">@item.EkTutar.ToString("N2")</td>
                                        <td class="text-end"><strong>@item.Toplam.ToString("N2")</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th colspan="8" class="text-end">TOPLAM</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.FaturaOdemesi).ToString("N2")</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.EkTutar).ToString("N2")</th>
                                    <th class="text-end">@FiltrelenmisListe.Sum(x => x.Toplam).ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger" @onclick="PdfAktar"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</button>
                    <button class="btn btn-outline-success" @onclick="ExcelAktar"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary" @onclick="() => showOnizlemeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showAracDetayModal && seciliArac != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-truck me-2"></i>Araç Detay - @seciliArac.AktifPlaka</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="AracDetayKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header py-2 bg-light"><strong><i class="bi bi-info-circle me-1"></i>Temel Bilgiler</strong></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr><td class="text-muted" width="100">Marka</td><td><strong>@(seciliArac.Marka ?? "-")</strong></td></tr>
                                        <tr><td class="text-muted">Model</td><td><strong>@(seciliArac.Model ?? "-")</strong></td></tr>
                                        <tr><td class="text-muted">Model Yılı</td><td><strong>@(seciliArac.ModelYili?.ToString() ?? "-")</strong></td></tr>
                                        <tr><td class="text-muted">Şasi No</td><td><code>@(seciliArac.SaseNo ?? "-")</code></td></tr>
                                        <tr><td class="text-muted">Motor No</td><td>@(seciliArac.MotorNo ?? "-")</td></tr>
                                        <tr><td class="text-muted">Renk</td><td>@(seciliArac.Renk ?? "-")</td></tr>
                                        <tr><td class="text-muted">Km</td><td>@(seciliArac.KmDurumu?.ToString("N0") ?? "-")</td></tr>
                                        <tr><td class="text-muted">Koltuk</td><td>@seciliArac.KoltukSayisi</td></tr>
                                        <tr><td class="text-muted">Durum</td><td>
                                            @if (seciliArac.Aktif)
                                            { <span class="badge bg-success">Aktif</span> }
                                            else
                                            { <span class="badge bg-secondary">Pasif</span> }
                                            <span class="badge bg-info ms-1">@seciliArac.Durumu</span>
                                        </td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header py-2 bg-light"><strong><i class="bi bi-shield-check me-1"></i>Sigorta / Muayene</strong></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        @{
                                            var bugun = DateTime.Today;
                                            string SigortaBadge(DateTime? bitis)
                                            {
                                                if (!bitis.HasValue) return "<span class=\"badge bg-secondary\">-</span>";
                                                var gun = (bitis.Value - bugun).Days;
                                                return gun < 0 ? $"<span class=\"badge bg-danger\">{bitis:dd.MM.yyyy} (geçti)</span>"
                                                    : gun <= 30 ? $"<span class=\"badge bg-warning text-dark\">{bitis:dd.MM.yyyy} ({gun}g)</span>"
                                                    : $"<span class=\"badge bg-success\">{bitis:dd.MM.yyyy} ({gun}g)</span>";
                                            }
                                        }
                                        <tr><td class="text-muted">Trafik Sigortası</td><td>@((MarkupString)SigortaBadge(seciliArac.TrafikSigortaBitisTarihi))</td></tr>
                                        <tr><td class="text-muted">Kasko</td><td>@((MarkupString)SigortaBadge(seciliArac.KaskoBitisTarihi))</td></tr>
                                        <tr><td class="text-muted">Muayene</td><td>@((MarkupString)SigortaBadge(seciliArac.MuayeneBitisTarihi))</td></tr>
                                        <tr><td class="text-muted">Koltuk Sigortası</td><td>@((MarkupString)SigortaBadge(seciliArac.KoltukSigortasiBitisTarihi))</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        @if (seciliGuzergahBilgisi.Any())
                        {
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header py-2 bg-light"><strong><i class="bi bi-signpost me-1"></i>Bağlı Olduğu Güzergah(lar)</strong></div>
                                    <div class="card-body py-2">
                                        @foreach (var gb in seciliGuzergahBilgisi)
                                        {
                                            <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                                                <div>
                                                    <a href="/guzergahlar/@gb.GuzergahId/duzenle" target="_blank" class="fw-semibold">@gb.GuzergahAdi</a>
                                                    @if (!string.IsNullOrWhiteSpace(gb.SoforAdi))
                                                    {
                                                        <span class="text-muted ms-2"><i class="bi bi-person me-1"></i>@gb.SoforAdi</span>
                                                    }
                                                </div>
                                                <small class="text-muted">@gb.SlotAdi</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <a href="/araclar/@seciliArac.Id/evraklar" class="btn btn-outline-primary" target="_blank">
                        <i class="bi bi-folder2-open me-1"></i>Evraklar
                    </a>
                    <a href="/araclar/@seciliArac.Id/duzenle" class="btn btn-outline-secondary" target="_blank">
                        <i class="bi bi-pencil me-1"></i>Düzenle
                    </a>
                    <button type="button" class="btn btn-secondary" @onclick="AracDetayKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<KiralikPlakaTakip> _liste = new();

    private bool showImportModal;
    private bool isImporting;
    private bool _eslestirmeCalisiyor;
    private bool showOnizlemeModal;
    private bool showAracDetayModal;
    private Arac? seciliArac;
    private List<GuzergahBilgisi> seciliGuzergahBilgisi = new();
    private IBrowserFile? importFile;
    private KiralikPlakaImportResult? importResult;

    // Filtre alanları
    private string aramaMetni = string.Empty;
    private string durumFiltre = string.Empty;
    private string kasaFiltre = string.Empty;
    private string bitisFiltre = string.Empty;
    private string eslesmeFiltre = string.Empty;

    private IEnumerable<string> DurumSecenekleri => _liste
        .Select(x => (x.Durum ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrEmpty(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x);

    private IEnumerable<string> KasaSecenekleri => _liste
        .Select(x => (x.KasaDurumu ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrEmpty(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x);

    private List<KiralikPlakaTakip> FiltrelenmisListe => _liste
        .Where(x => string.IsNullOrWhiteSpace(aramaMetni)
            || (x.Plaka ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
            || (x.IsimSoyisim ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
            || (x.Arac != null && (
                (x.Arac.AktifPlaka ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
                || (x.Arac.Marka ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
                || (x.Arac.Model ?? string.Empty).Contains(aramaMetni, StringComparison.OrdinalIgnoreCase))))
        .Where(x => string.IsNullOrEmpty(durumFiltre)
            || string.Equals((x.Durum ?? string.Empty).Trim(), durumFiltre, StringComparison.OrdinalIgnoreCase))
        .Where(x => string.IsNullOrEmpty(kasaFiltre)
            || string.Equals((x.KasaDurumu ?? string.Empty).Trim(), kasaFiltre, StringComparison.OrdinalIgnoreCase))
        .Where(x =>
        {
            if (string.IsNullOrEmpty(bitisFiltre)) return true;
            var gun = (x.BitisTarihi.Date - DateTime.Today).Days;
            return bitisFiltre switch
            {
                "gecti" => gun < 0,
                "7" => gun >= 0 && gun <= 7,
                "30" => gun >= 0 && gun <= 30,
                "aktif" => gun > 30,
                _ => true
            };
        })
        .Where(x => eslesmeFiltre switch
        {
            "eslesti" => x.Arac != null,
            "eslesmedi" => x.Arac == null,
            _ => true
        })
        .OrderBy(x => x.BitisTarihi)
        .ToList();

    private void FiltreleriTemizle()
    {
        aramaMetni = string.Empty;
        durumFiltre = string.Empty;
        kasaFiltre = string.Empty;
        bitisFiltre = string.Empty;
        eslesmeFiltre = string.Empty;
    }

    private void OnizlemeAc() => showOnizlemeModal = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task AracDetayGoster(Arac arac)
    {
        seciliArac = arac;
        seciliGuzergahBilgisi.Clear();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // GuzergahSefer'den araca bağlı güzergahları bul
            var seferler = await db.GuzergahSeferleri
                .Include(s => s.Guzergah)
                .Where(s => s.AracId == arac.Id && s.Guzergah != null && !s.Guzergah.IsDeleted)
                .OrderBy(s => s.Guzergah!.GuzergahAdi).ThenBy(s => s.Sira)
                .ToListAsync();

            foreach (var s in seferler)
            {
                var slotAdi = s.Slot switch
                {
                    SeferSlot.Sabah => "Sabah",
                    SeferSlot.Aksam => "Akşam",
                    SeferSlot.Mesai => "Mesai",
                    SeferSlot.Diger1 => "Diğer 1",
                    SeferSlot.Diger2 => "Diğer 2",
                    SeferSlot.Diger3 => "Diğer 3",
                    SeferSlot.Diger4 => "Diğer 4",
                    SeferSlot.Diger5 => "Diğer 5",
                    _ => s.Slot.ToString()
                };
                seciliGuzergahBilgisi.Add(new GuzergahBilgisi
                {
                    GuzergahId = s.GuzergahId,
                    GuzergahAdi = s.Guzergah?.GuzergahAdi ?? "?",
                    SoforAdi = s.SoforAd,
                    SlotAdi = $"Slot: {slotAdi} (Sefer {s.Sira})"
                });
            }

            // Ayrıca varsayılan araç olarak atandığı güzergahları da bul
            var guzergahlar = await db.Guzergahlar
                .Include(g => g.VarsayilanSofor)
                .Where(g => g.VarsayilanAracId == arac.Id && g.Aktif && !g.IsDeleted)
                .ToListAsync();

            foreach (var g in guzergahlar)
            {
                if (!seciliGuzergahBilgisi.Any(x => x.GuzergahId == g.Id))
                {
                    var soforAdi = g.VarsayilanSofor != null
                        ? $"{g.VarsayilanSofor.Ad} {g.VarsayilanSofor.Soyad}"
                        : null;
                    seciliGuzergahBilgisi.Add(new GuzergahBilgisi
                    {
                        GuzergahId = g.Id,
                        GuzergahAdi = g.GuzergahAdi ?? "?",
                        SoforAdi = soforAdi,
                        SlotAdi = "Varsayılan Araç"
                    });
                }
            }
        }
        catch { /* güzergah bilgisi yüklenemezse modal yine de açılsın */ }

        showAracDetayModal = true;
    }

    private void AracDetayKapat()
    {
        showAracDetayModal = false;
        seciliArac = null;
        seciliGuzergahBilgisi.Clear();
    }

    private static string GetDurumClass(string? durum)
    {
        var d = (durum ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(d)) return "bg-secondary";
        if (d.Contains("aktif") || d.Contains("devam") || d.Contains("açık") || d.Contains("acik") || d.Contains("geçerli") || d.Contains("gecerli"))
            return "bg-success";
        if (d.Contains("pasif") || d.Contains("iptal") || d.Contains("kapalı") || d.Contains("kapali") || d.Contains("sona") || d.Contains("bitti") || d.Contains("bitmiş") || d.Contains("bitmis") || d.Contains("dondu"))
            return "bg-danger";
        if (d.Contains("bekle") || d.Contains("askı") || d.Contains("aski") || d.Contains("onay"))
            return "bg-warning text-dark";
        return "bg-info text-dark";
    }

    private static string GetKasaClass(string? kasa)
    {
        var k = (kasa ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(k)) return "bg-secondary";
        if (k.Contains("ödendi") || k.Contains("odendi") || k.Contains("tamam") || k.Contains("kapandı") || k.Contains("kapandi") || k.Contains("tahsil"))
            return "bg-success";
        if (k.Contains("ödenmedi") || k.Contains("odenmedi") || k.Contains("borç") || k.Contains("borc") || k.Contains("açık") || k.Contains("acik") || k.Contains("bekliyor") || k.Contains("bekleniyor"))
            return "bg-danger";
        if (k.Contains("kısmi") || k.Contains("kismi") || k.Contains("parça") || k.Contains("parca") || k.Contains("eksik") || k.Contains("kısmen") || k.Contains("kismen"))
            return "bg-warning text-dark";
        return "bg-info text-dark";
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _liste = await TakipService.GetAllAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SablonIndir()
    {
        try
        {
            var content = await TakipService.GetExcelSablonAsync();
            var fileName = $"kiralik-c-plaka-sablon-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
            var base64 = Convert.ToBase64String(content);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Şablon indirilemedi: {ex.Message}");
        }
    }

    private async Task OtomatikEslestir()
    {
        if (_eslestirmeCalisiyor) return;
        _eslestirmeCalisiyor = true;
        try
        {
            var eslesen = await TakipService.EslestirmeYapAsync();
            if (eslesen > 0)
            {
                ToastService.ShowSuccess($"{eslesen} kayıt araç ile eşleştirildi.");
                await LoadData();
            }
            else
            {
                ToastService.ShowInfo("Eşleştirilecek yeni kayıt bulunamadı.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Eşleştirme başarısız: {ex.Message}");
        }
        finally
        {
            _eslestirmeCalisiyor = false;
        }
    }

    private void ExcelImportModalAc()
    {
        showImportModal = true;
        importResult = null;
        importFile = null;
    }

    private void ImportModalKapat()
    {
        showImportModal = false;
        importResult = null;
        importFile = null;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        importFile = e.File;
        importResult = null;
    }

    private async Task ExcelImportYap()
    {
        if (importFile == null) return;

        isImporting = true;
        try
        {
            await using var stream = importFile.OpenReadStream(10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            importResult = await TakipService.ImportFromExcelAsync(ms.ToArray());
            if (importResult.Success)
                ToastService.ShowSuccess("Excel aktarımı tamamlandı.");
            else
                ToastService.ShowWarning("Excel aktarımında uyarılar/hatalar oluştu.");

            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel aktarım hatası: {ex.Message}");
        }
        finally
        {
            isImporting = false;
        }
    }

    private async Task Sil(KiralikPlakaTakip item)
    {
        try
        {
            await TakipService.DeleteAsync(item.Id);
            _liste.Remove(item);
            ToastService.ShowSuccess("Silindi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task ExcelAktar()
    {
        try
        {
            var data = FiltrelenmisListe;
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            using var workbook = new XLWorkbook();

            // ───────────────── ÖZET SAYFASI ─────────────────
            var ozet = workbook.Worksheets.Add("Özet");
            ozet.Cell(1, 1).Value = "KİRALIK C PLAKA TAKİP RAPORU";
            ozet.Range(1, 1, 1, 4).Merge();
            ozet.Cell(1, 1).Style.Font.Bold = true;
            ozet.Cell(1, 1).Style.Font.FontSize = 16;
            ozet.Cell(1, 1).Style.Fill.BackgroundColor = XLColor.DarkBlue;
            ozet.Cell(1, 1).Style.Font.FontColor = XLColor.White;
            ozet.Cell(1, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ozet.Row(1).Height = 28;

            ozet.Cell(2, 1).Value = $"Oluşturma Tarihi: {DateTime.Now:dd.MM.yyyy HH:mm}";
            ozet.Range(2, 1, 2, 4).Merge();
            ozet.Cell(2, 1).Style.Font.Italic = true;
            ozet.Cell(2, 1).Style.Font.FontColor = XLColor.Gray;

            // Filtre bilgisi
            var filtreler = new List<string>();
            if (!string.IsNullOrWhiteSpace(aramaMetni)) filtreler.Add($"Arama: {aramaMetni}");
            if (!string.IsNullOrEmpty(durumFiltre)) filtreler.Add($"Durum: {durumFiltre}");
            if (!string.IsNullOrEmpty(kasaFiltre)) filtreler.Add($"Kasa: {kasaFiltre}");
            if (!string.IsNullOrEmpty(bitisFiltre)) filtreler.Add($"Bitiş: {bitisFiltre}");
            if (!string.IsNullOrEmpty(eslesmeFiltre)) filtreler.Add($"Eşleşme: {eslesmeFiltre}");
            ozet.Cell(3, 1).Value = filtreler.Any() ? "Filtreler: " + string.Join(" | ", filtreler) : "Filtre uygulanmadı";
            ozet.Range(3, 1, 3, 4).Merge();
            ozet.Cell(3, 1).Style.Font.Italic = true;
            ozet.Cell(3, 1).Style.Font.FontColor = XLColor.Gray;

            // Genel İstatistikler
            int r = 5;
            ozet.Cell(r, 1).Value = "GENEL İSTATİSTİKLER";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;

            var sureGecen = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0);
            var yedi = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; });
            var otuz = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g > 7 && g <= 30; });
            var aktif = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days > 30);

            void Stat(string label, object value, XLColor? bg = null)
            {
                ozet.Cell(r, 1).Value = label;
                ozet.Cell(r, 2).Value = XLCellValue.FromObject(value);
                ozet.Cell(r, 1).Style.Font.Bold = true;
                if (bg is not null)
                {
                    ozet.Range(r, 1, r, 2).Style.Fill.BackgroundColor = bg;
                }
                r++;
            }

            Stat("Toplam Kayıt", data.Count);
            Stat("Eşleşen Araç", data.Count(x => x.Arac != null), XLColor.LightGreen);
            Stat("Eşleşmeyen", data.Count(x => x.Arac == null), XLColor.LightPink);
            Stat("Süresi Geçen", sureGecen, XLColor.LightPink);
            Stat("7 Gün İçinde Bitecek", yedi, XLColor.LightYellow);
            Stat("30 Gün İçinde Bitecek", otuz, XLColor.LightBlue);
            Stat("31+ Gün (Aktif)", aktif, XLColor.LightGreen);
            Stat("Toplam Fatura (₺)", data.Sum(x => x.FaturaOdemesi).ToString("N2"));
            Stat("Toplam Ek Tutar (₺)", data.Sum(x => x.EkTutar).ToString("N2"));
            Stat("GENEL TOPLAM (₺)", data.Sum(x => x.Toplam).ToString("N2"), XLColor.LightYellow);

            r += 2;

            // Duruma Göre Dağılım
            ozet.Cell(r, 1).Value = "DURUMA GÖRE DAĞILIM";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;
            ozet.Cell(r, 1).Value = "Durum";
            ozet.Cell(r, 2).Value = "Adet";
            ozet.Cell(r, 3).Value = "Toplam (₺)";
            ozet.Cell(r, 4).Value = "Oran (%)";
            ozet.Range(r, 1, r, 4).Style.Font.Bold = true;
            ozet.Range(r, 1, r, 4).Style.Fill.BackgroundColor = XLColor.Gainsboro;
            r++;
            foreach (var g in data.GroupBy(x => string.IsNullOrWhiteSpace(x.Durum) ? "(Boş)" : x.Durum.Trim()).OrderByDescending(g => g.Count()))
            {
                ozet.Cell(r, 1).Value = g.Key;
                ozet.Cell(r, 2).Value = g.Count();
                ozet.Cell(r, 3).Value = g.Sum(x => x.Toplam);
                ozet.Cell(r, 3).Style.NumberFormat.Format = "#,##0.00";
                ozet.Cell(r, 4).Value = data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0;
                ozet.Cell(r, 4).Style.NumberFormat.Format = "0.0\"%\"";
                r++;
            }

            r += 2;

            // Kasa Durumuna Göre Dağılım
            ozet.Cell(r, 1).Value = "KASA DURUMUNA GÖRE DAĞILIM";
            ozet.Range(r, 1, r, 4).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;
            ozet.Cell(r, 1).Value = "Kasa Durumu";
            ozet.Cell(r, 2).Value = "Adet";
            ozet.Cell(r, 3).Value = "Toplam (₺)";
            ozet.Cell(r, 4).Value = "Oran (%)";
            ozet.Range(r, 1, r, 4).Style.Font.Bold = true;
            ozet.Range(r, 1, r, 4).Style.Fill.BackgroundColor = XLColor.Gainsboro;
            r++;
            foreach (var g in data.GroupBy(x => string.IsNullOrWhiteSpace(x.KasaDurumu) ? "(Boş)" : x.KasaDurumu.Trim()).OrderByDescending(g => g.Count()))
            {
                ozet.Cell(r, 1).Value = g.Key;
                ozet.Cell(r, 2).Value = g.Count();
                ozet.Cell(r, 3).Value = g.Sum(x => x.Toplam);
                ozet.Cell(r, 3).Style.NumberFormat.Format = "#,##0.00";
                ozet.Cell(r, 4).Value = data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0;
                ozet.Cell(r, 4).Style.NumberFormat.Format = "0.0\"%\"";
                r++;
            }

            ozet.Columns().AdjustToContents();
            ozet.Column(1).Width = Math.Max(ozet.Column(1).Width, 28);
            ozet.SheetView.FreezeRows(3);

            // ───────────────── DETAY SAYFASI ─────────────────
            var ws = workbook.Worksheets.Add("Detay");

            var headers = new[] { "S.NO", "PLAKA", "EŞLEŞEN ARAÇ", "İSİM SOYİSİM", "BAŞLAMA TARİHİ", "BİTİŞ TARİHİ", "KALAN GÜN", "DURUM", "KASA DURUMU", "FATURA", "PERİYOT", "AYLIK/YILLIK", "EK TUTAR", "TOPLAM" };
            for (int i = 0; i < headers.Length; i++)
                ws.Cell(1, i + 1).Value = headers[i];

            var headerRange = ws.Range(1, 1, 1, headers.Length);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Font.FontColor = XLColor.White;
            headerRange.Style.Fill.BackgroundColor = XLColor.DarkBlue;
            headerRange.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            headerRange.Style.Border.OutsideBorder = XLBorderStyleValues.Medium;
            headerRange.Style.Border.InsideBorder = XLBorderStyleValues.Thin;
            ws.Row(1).Height = 22;

            int row = 2;
            int sira = 1;
            foreach (var item in data)
            {
                var kalan = (item.BitisTarihi.Date - DateTime.Today).Days;
                ws.Cell(row, 1).Value = sira++;
                ws.Cell(row, 2).Value = item.Plaka;
                ws.Cell(row, 3).Value = item.Arac != null ? $"{item.Arac.AktifPlaka} - {item.Arac.Marka} {item.Arac.Model}" : "Eşleşmedi";
                ws.Cell(row, 4).Value = item.IsimSoyisim;
                ws.Cell(row, 5).Value = item.BaslamaTarihi;
                ws.Cell(row, 5).Style.DateFormat.Format = "dd.MM.yyyy";
                ws.Cell(row, 6).Value = item.BitisTarihi;
                ws.Cell(row, 6).Style.DateFormat.Format = "dd.MM.yyyy";
                ws.Cell(row, 7).Value = kalan;
                ws.Cell(row, 8).Value = item.Durum;
                ws.Cell(row, 9).Value = item.KasaDurumu;
                ws.Cell(row, 10).Value = item.FaturaOdemesi;
                ws.Cell(row, 10).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 11).Value = item.Periyot;
                ws.Cell(row, 12).Value = item.AylikVeyaYillikTutar;
                ws.Cell(row, 12).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 13).Value = item.EkTutar;
                ws.Cell(row, 13).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 14).Value = item.Toplam;
                ws.Cell(row, 14).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 14).Style.Font.Bold = true;

                // Bitiş tarihi rengi
                if (kalan < 0)
                {
                    ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightPink;
                    ws.Cell(row, 6).Style.Font.FontColor = XLColor.DarkRed;
                    ws.Cell(row, 6).Style.Font.Bold = true;
                }
                else if (kalan <= 7)
                {
                    ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightYellow;
                }
                else if (kalan <= 30)
                {
                    ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.LightCyan;
                }

                // Durum rengi
                ws.Cell(row, 8).Style.Fill.BackgroundColor = GetDurumXLColor(item.Durum);
                ws.Cell(row, 8).Style.Font.Bold = true;
                ws.Cell(row, 8).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

                // Kasa Durumu rengi
                ws.Cell(row, 9).Style.Fill.BackgroundColor = GetKasaXLColor(item.KasaDurumu);
                ws.Cell(row, 9).Style.Font.Bold = true;
                ws.Cell(row, 9).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

                // Eşleşmeyen vurgu
                if (item.Arac == null)
                {
                    ws.Cell(row, 3).Style.Font.FontColor = XLColor.White;
                    ws.Cell(row, 3).Style.Fill.BackgroundColor = XLColor.Red;
                    ws.Cell(row, 3).Style.Font.Bold = true;
                }

                row++;
            }

            // Toplam satırı
            ws.Cell(row, 9).Value = "TOPLAM";
            ws.Cell(row, 9).Style.Font.Bold = true;
            ws.Cell(row, 9).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Right;
            ws.Cell(row, 10).FormulaA1 = $"SUM(J2:J{row - 1})";
            ws.Cell(row, 10).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 13).FormulaA1 = $"SUM(M2:M{row - 1})";
            ws.Cell(row, 13).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 14).FormulaA1 = $"SUM(N2:N{row - 1})";
            ws.Cell(row, 14).Style.NumberFormat.Format = "#,##0.00";
            ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.DarkGray;
            ws.Range(row, 1, row, headers.Length).Style.Font.FontColor = XLColor.White;
            ws.Range(row, 1, row, headers.Length).Style.Font.Bold = true;
            ws.Range(row, 1, row, headers.Length).Style.Border.TopBorder = XLBorderStyleValues.Medium;

            // Tüm tabloya çerçeve
            ws.Range(1, 1, row, headers.Length).Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
            ws.Range(1, 1, row, headers.Length).Style.Border.InsideBorder = XLBorderStyleValues.Thin;

            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(1);
            ws.RangeUsed()!.SetAutoFilter();

            using var ms = new MemoryStream();
            workbook.SaveAs(ms);
            var bytes = ms.ToArray();
            var fileName = $"kiralik-c-plaka-rapor-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
            ToastService.ShowSuccess("Excel raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel aktarım hatası: {ex.Message}");
        }
    }

    private static XLColor GetDurumXLColor(string? durum)
    {
        var d = (durum ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(d)) return XLColor.LightGray;
        if (d.Contains("aktif") || d.Contains("devam") || d.Contains("açık") || d.Contains("acik") || d.Contains("geçerli") || d.Contains("gecerli"))
            return XLColor.LightGreen;
        if (d.Contains("pasif") || d.Contains("iptal") || d.Contains("kapalı") || d.Contains("kapali") || d.Contains("sona") || d.Contains("bitti") || d.Contains("bitmiş") || d.Contains("bitmis") || d.Contains("dondu"))
            return XLColor.LightPink;
        if (d.Contains("bekle") || d.Contains("askı") || d.Contains("aski") || d.Contains("onay"))
            return XLColor.LightYellow;
        return XLColor.LightCyan;
    }

    private static XLColor GetKasaXLColor(string? kasa)
    {
        var k = (kasa ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(k)) return XLColor.LightGray;
        if (k.Contains("ödendi") || k.Contains("odendi") || k.Contains("tamam") || k.Contains("kapandı") || k.Contains("kapandi") || k.Contains("tahsil"))
            return XLColor.LightGreen;
        if (k.Contains("ödenmedi") || k.Contains("odenmedi") || k.Contains("borç") || k.Contains("borc") || k.Contains("açık") || k.Contains("acik") || k.Contains("bekliyor") || k.Contains("bekleniyor"))
            return XLColor.LightPink;
        if (k.Contains("kısmi") || k.Contains("kismi") || k.Contains("parça") || k.Contains("parca") || k.Contains("eksik") || k.Contains("kısmen") || k.Contains("kismen"))
            return XLColor.LightYellow;
        return XLColor.LightCyan;
    }

    private async Task PdfAktar()
    {
        try
        {
            var data = FiltrelenmisListe;
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            QuestPDF.Settings.License = LicenseType.Community;

            var sureGecen = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days < 0);
            var yedi = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g >= 0 && g <= 7; });
            var otuz = data.Count(x => { var g = (x.BitisTarihi.Date - DateTime.Today).Days; return g > 7 && g <= 30; });
            var aktifSayi = data.Count(x => (x.BitisTarihi.Date - DateTime.Today).Days > 30);
            var eslesen = data.Count(x => x.Arac != null);
            var eslesmeyen = data.Count(x => x.Arac == null);

            var durumGruplari = data
                .GroupBy(x => string.IsNullOrWhiteSpace(x.Durum) ? "(Boş)" : x.Durum.Trim())
                .OrderByDescending(g => g.Count())
                .ToList();
            var kasaGruplari = data
                .GroupBy(x => string.IsNullOrWhiteSpace(x.KasaDurumu) ? "(Boş)" : x.KasaDurumu.Trim())
                .OrderByDescending(g => g.Count())
                .ToList();

            var filtreler = new List<string>();
            if (!string.IsNullOrWhiteSpace(aramaMetni)) filtreler.Add($"Arama: {aramaMetni}");
            if (!string.IsNullOrEmpty(durumFiltre)) filtreler.Add($"Durum: {durumFiltre}");
            if (!string.IsNullOrEmpty(kasaFiltre)) filtreler.Add($"Kasa: {kasaFiltre}");
            if (!string.IsNullOrEmpty(bitisFiltre)) filtreler.Add($"Bitiş: {bitisFiltre}");
            if (!string.IsNullOrEmpty(eslesmeFiltre)) filtreler.Add($"Eşleşme: {eslesmeFiltre}");

            var document = Document.Create(container =>
            {
                container.Page(page =>
                {
                    page.Size(PageSizes.A4.Landscape());
                    page.Margin(20);
                    page.DefaultTextStyle(x => x.FontSize(8));

                    // BAŞLIK
                    page.Header().Column(col =>
                    {
                        col.Item().Background(Colors.Blue.Darken3).Padding(10).Column(c =>
                        {
                            c.Item().Text("KİRALIK C PLAKA TAKİP RAPORU").Bold().FontSize(16).FontColor(Colors.White);
                            c.Item().Text("KOA Filo Servis").FontSize(9).FontColor(Colors.Grey.Lighten2);
                        });
                        col.Item().PaddingTop(4).Row(row =>
                        {
                            row.RelativeItem().Text($"Oluşturma: {DateTime.Now:dd.MM.yyyy HH:mm}").FontSize(8).FontColor(Colors.Grey.Darken2);
                            row.RelativeItem().AlignRight().Text($"Toplam Kayıt: {data.Count}").Bold().FontSize(9);
                        });
                        if (filtreler.Any())
                            col.Item().PaddingTop(2).Text($"Filtreler: {string.Join(" | ", filtreler)}").FontSize(7).Italic().FontColor(Colors.Grey.Darken2);
                    });

                    page.Content().PaddingVertical(8).Column(content =>
                    {
                        content.Spacing(8);

                        // ÖZET KARTLARI
                        content.Item().Row(row =>
                        {
                            row.Spacing(5);
                            void Kart(QuestPDF.Infrastructure.IContainer c, string baslik, string deger, string bg, string fg = "#FFFFFF")
                            {
                                c.Background(bg).Padding(6).Column(k =>
                                {
                                    k.Item().Text(baslik).FontSize(7).FontColor(fg);
                                    k.Item().Text(deger).Bold().FontSize(13).FontColor(fg);
                                });
                            }
                            Kart(row.RelativeItem(), "Toplam", data.Count.ToString(), Colors.Blue.Darken2);
                            Kart(row.RelativeItem(), "Eşleşen", eslesen.ToString(), Colors.Green.Darken1);
                            Kart(row.RelativeItem(), "Eşleşmeyen", eslesmeyen.ToString(), Colors.Red.Darken1);
                            Kart(row.RelativeItem(), "Süresi Geçen", sureGecen.ToString(), Colors.Red.Darken3);
                            Kart(row.RelativeItem(), "7 Gün İçinde", yedi.ToString(), Colors.Orange.Darken1, "#000000");
                            Kart(row.RelativeItem(), "30 Gün İçinde", otuz.ToString(), Colors.Cyan.Darken2);
                            Kart(row.RelativeItem(), "Aktif (31+)", aktifSayi.ToString(), Colors.Teal.Darken2);
                        });

                        content.Item().Row(row =>
                        {
                            row.Spacing(5);
                            void Mali(QuestPDF.Infrastructure.IContainer c, string baslik, decimal deger, string bg)
                            {
                                c.Background(bg).Padding(6).Column(k =>
                                {
                                    k.Item().Text(baslik).FontSize(7).FontColor(Colors.White);
                                    k.Item().Text($"{deger:N2} ₺").Bold().FontSize(12).FontColor(Colors.White);
                                });
                            }
                            Mali(row.RelativeItem(), "Toplam Fatura", data.Sum(x => x.FaturaOdemesi), Colors.Indigo.Darken1);
                            Mali(row.RelativeItem(), "Toplam Ek Tutar", data.Sum(x => x.EkTutar), Colors.Purple.Darken1);
                            Mali(row.RelativeItem(2), "GENEL TOPLAM", data.Sum(x => x.Toplam), Colors.Green.Darken3);
                        });

                        // DAĞILIM TABLOLARI
                        content.Item().Row(row =>
                        {
                            row.Spacing(8);

                            row.RelativeItem().Border(1).BorderColor(Colors.Grey.Lighten1).Column(col =>
                            {
                                col.Item().Background(Colors.Blue.Lighten4).Padding(5).Text("DURUMA GÖRE DAĞILIM").Bold().FontSize(9);
                                col.Item().Table(t =>
                                {
                                    t.ColumnsDefinition(c =>
                                    {
                                        c.RelativeColumn(3);
                                        c.RelativeColumn(1);
                                        c.RelativeColumn(2);
                                        c.RelativeColumn(1);
                                    });
                                    t.Header(h =>
                                    {
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text("Durum").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Adet").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Tutar (₺)").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("%").Bold().FontSize(8);
                                    });
                                    foreach (var g in durumGruplari)
                                    {
                                        var bg = GetDurumQpdfBg(g.Key);
                                        t.Cell().Background(bg).Padding(3).Text(g.Key).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Count().ToString()).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Sum(x => x.Toplam).ToString("N2")).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text($"{(data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0):0.0}").FontSize(8);
                                    }
                                });
                            });

                            row.RelativeItem().Border(1).BorderColor(Colors.Grey.Lighten1).Column(col =>
                            {
                                col.Item().Background(Colors.Green.Lighten4).Padding(5).Text("KASA DURUMUNA GÖRE DAĞILIM").Bold().FontSize(9);
                                col.Item().Table(t =>
                                {
                                    t.ColumnsDefinition(c =>
                                    {
                                        c.RelativeColumn(3);
                                        c.RelativeColumn(1);
                                        c.RelativeColumn(2);
                                        c.RelativeColumn(1);
                                    });
                                    t.Header(h =>
                                    {
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text("Kasa Durumu").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Adet").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Tutar (₺)").Bold().FontSize(8);
                                        h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("%").Bold().FontSize(8);
                                    });
                                    foreach (var g in kasaGruplari)
                                    {
                                        var bg = GetKasaQpdfBg(g.Key);
                                        t.Cell().Background(bg).Padding(3).Text(g.Key).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Count().ToString()).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text(g.Sum(x => x.Toplam).ToString("N2")).FontSize(8);
                                        t.Cell().Background(bg).Padding(3).AlignRight().Text($"{(data.Count > 0 ? (double)g.Count() * 100 / data.Count : 0):0.0}").FontSize(8);
                                    }
                                });
                            });
                        });

                        // BAŞLIK BANNERı
                        content.Item().Background(Colors.Blue.Darken3).Padding(5).Text("DETAY LİSTE").Bold().FontSize(10).FontColor(Colors.White);

                        // ANA TABLO
                        content.Item().Table(table =>
                        {
                            table.ColumnsDefinition(c =>
                            {
                                c.ConstantColumn(20);    // S.NO
                                c.RelativeColumn(2);     // Plaka
                                c.RelativeColumn(3);     // Eşleşen Araç
                                c.RelativeColumn(3);     // İsim
                                c.RelativeColumn(2);     // Başlama
                                c.RelativeColumn(2.5f);  // Bitiş
                                c.RelativeColumn(2);     // Durum
                                c.RelativeColumn(2);     // Kasa
                                c.RelativeColumn(2);     // Fatura
                                c.RelativeColumn(2);     // Ek
                                c.RelativeColumn(2);     // Toplam
                            });

                            table.Header(h =>
                            {
                                string[] hs = { "#", "PLAKA", "EŞLEŞEN ARAÇ", "İSİM SOYİSİM", "BAŞLAMA", "BİTİŞ", "DURUM", "KASA", "FATURA", "EK TUTAR", "TOPLAM" };
                                foreach (var head in hs)
                                    h.Cell().Background(Colors.Blue.Darken2).Padding(4).AlignCenter().Text(head).Bold().FontSize(8).FontColor(Colors.White);
                            });

                            int sira = 1;
                            foreach (var item in data)
                            {
                                var kalan = (item.BitisTarihi.Date - DateTime.Today).Days;
                                string rowBg = kalan < 0 ? Colors.Red.Lighten4
                                    : kalan <= 7 ? Colors.Yellow.Lighten4
                                    : kalan <= 30 ? Colors.Cyan.Lighten4
                                    : (sira % 2 == 0 ? Colors.Grey.Lighten4 : Colors.White);
                                string bitisFg = kalan < 0 ? Colors.Red.Darken3 : Colors.Black;

                                QuestPDF.Infrastructure.IContainer Cell() => table.Cell().Background(rowBg).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3);

                                Cell().AlignCenter().Text(sira++.ToString()).FontSize(7);
                                Cell().Text(item.Plaka ?? "").Bold().FontSize(7);
                                if (item.Arac != null)
                                    Cell().Text($"{item.Arac.AktifPlaka} - {item.Arac.Marka} {item.Arac.Model}").FontSize(7);
                                else
                                    table.Cell().Background(Colors.Red.Lighten2).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3).Text("Eşleşmedi").Bold().FontSize(7).FontColor(Colors.White);
                                Cell().Text(item.IsimSoyisim ?? "").FontSize(7);
                                Cell().Text(item.BaslamaTarihi.ToString("dd.MM.yyyy")).FontSize(7);
                                Cell().Text(t =>
                                {
                                    t.Span($"{item.BitisTarihi:dd.MM.yyyy}").FontSize(7).FontColor(bitisFg).Bold();
                                    t.Span(kalan < 0 ? $" ({Math.Abs(kalan)}g geçti)" : $" ({kalan}g)").FontSize(6).FontColor(bitisFg);
                                });
                                table.Cell().Background(GetDurumQpdfBg(item.Durum)).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3).AlignCenter().Text(item.Durum ?? "").Bold().FontSize(7);
                                table.Cell().Background(GetKasaQpdfBg(item.KasaDurumu)).BorderBottom(0.5f).BorderColor(Colors.Grey.Lighten2).Padding(3).AlignCenter().Text(item.KasaDurumu ?? "").Bold().FontSize(7);
                                Cell().AlignRight().Text(item.FaturaOdemesi.ToString("N2")).FontSize(7);
                                Cell().AlignRight().Text(item.EkTutar.ToString("N2")).FontSize(7);
                                Cell().AlignRight().Text(item.Toplam.ToString("N2")).Bold().FontSize(7);
                            }

                            // Toplam satırı
                            for (int i = 0; i < 8; i++)
                                table.Cell().Background(Colors.Grey.Darken1).Padding(4).Text(i == 7 ? "TOPLAM" : "").Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.FaturaOdemesi).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Grey.Darken1).Padding(4).AlignRight().Text(data.Sum(x => x.EkTutar).ToString("N2")).Bold().FontSize(9).FontColor(Colors.White);
                            table.Cell().Background(Colors.Green.Darken3).Padding(4).AlignRight().Text(data.Sum(x => x.Toplam).ToString("N2")).Bold().FontSize(10).FontColor(Colors.White);
                        });
                    });

                    page.Footer().Row(row =>
                    {
                        row.RelativeItem().Text("KOA Filo Servis - Kiralık C Plaka Takip Raporu").FontSize(7).FontColor(Colors.Grey.Darken1);
                        row.RelativeItem().AlignRight().Text(t =>
                        {
                            t.Span("Sayfa ").FontSize(7).FontColor(Colors.Grey.Darken1);
                            t.CurrentPageNumber().FontSize(7).Bold();
                            t.Span(" / ").FontSize(7).FontColor(Colors.Grey.Darken1);
                            t.TotalPages().FontSize(7).Bold();
                        });
                    });
                });
            });

            var bytes = document.GeneratePdf();
            var fileName = $"kiralik-c-plaka-rapor-{DateTime.Now:yyyyMMdd-HHmm}.pdf";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/pdf", base64);
            ToastService.ShowSuccess("PDF raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF aktarım hatası: {ex.Message}");
        }
    }

    private static string GetDurumQpdfBg(string? durum)
    {
        var d = (durum ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(d)) return Colors.Grey.Lighten3;
        if (d.Contains("aktif") || d.Contains("devam") || d.Contains("açık") || d.Contains("acik") || d.Contains("geçerli") || d.Contains("gecerli"))
            return Colors.Green.Lighten3;
        if (d.Contains("pasif") || d.Contains("iptal") || d.Contains("kapalı") || d.Contains("kapali") || d.Contains("sona") || d.Contains("bitti") || d.Contains("bitmiş") || d.Contains("bitmis") || d.Contains("dondu"))
            return Colors.Red.Lighten3;
        if (d.Contains("bekle") || d.Contains("askı") || d.Contains("aski") || d.Contains("onay"))
            return Colors.Yellow.Lighten3;
        return Colors.Cyan.Lighten3;
    }

