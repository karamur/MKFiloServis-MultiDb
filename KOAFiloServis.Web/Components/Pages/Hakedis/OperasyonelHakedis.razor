@page "/operasyonel-hakedis"
@using System.IO
@using System.IO.Compression
@using ClosedXML.Excel
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IOperasyonelHakedisService HakedisService
@inject IFirmaService FirmaService
@inject ITasimaTedarikciService TedarikciService
@inject IAracService AracService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject IPdfService PdfService
@attribute [Authorize]

<PageTitle>Operasyonel Hakediş</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-receipt-cutoff me-2"></i>Operasyonel Hakediş</h2>
            <p class="text-muted mb-0">Kurum / Tedarikçi / Araç bazlı dönemsel hakediş üretimi, onayı ve faturaya dönüştürme</p>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-success" @onclick="ListeyiExceleAktar" disabled="@(!hakedisler.Any() || listeExcelCalisiyor)" title="Filtrelenmiş hakediş listesini Excel olarak indir">
                @if (listeExcelCalisiyor)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-file-earmark-excel me-1"></i>
                }
                Listeyi Excel
            </button>
            <button class="btn btn-outline-primary" @onclick="TopluModalAc" title="Dönem içindeki tüm referanslar için tek tıkla hakediş üret">
                <i class="bi bi-stack me-1"></i> Toplu Üret
            </button>
            <button class="btn btn-primary" @onclick="UretModalAc">
                <i class="bi bi-plus-lg me-1"></i> Hakediş Üret
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Yıl</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="LoadAsync">
                        @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAy" @bind:after="LoadAsync">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@AyAdi(a)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Tip</label>
                    <select class="form-select form-select-sm" @bind="filtreTip" @bind:after="OnTipChanged">
                        <option value="">Tümü</option>
                        <option value="Kurum">Kurum</option>
                        <option value="Tedarikci">Tedarikçi</option>
                        <option value="Arac">Araç</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum" @bind:after="LoadAsync">
                        <option value="">Tümü</option>
                        <option value="Taslak">Taslak</option>
                        <option value="Onaylandi">Onaylandı</option>
                        <option value="Faturalandi">Faturalandı</option>
                        <option value="TahsilEdildi">Tahsil Edildi</option>
                        <option value="Odendi">Ödendi</option>
                        <option value="Iptal">İptal</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">
                        @(filtreTip switch
                        {
                            "Kurum" => "Kurum",
                            "Tedarikci" => "Tedarikçi",
                            "Arac" => "Araç",
                            _ => "Referans"
                        })
                    </label>
                    <select class="form-select form-select-sm" @bind="filtreReferansId" @bind:after="LoadAsync" disabled="@string.IsNullOrEmpty(filtreTip)">
                        <option value="0">Tümü</option>
                        @if (filtreTip == "Kurum")
                        {
                            @foreach (var f in firmalar)
                            {
                                <option value="@f.Id">@f.FirmaAdi</option>
                            }
                        }
                        else if (filtreTip == "Tedarikci")
                        {
                            @foreach (var t in tedarikciler)
                            {
                                <option value="@t.Id">@t.Unvan</option>
                            }
                        }
                        else if (filtreTip == "Arac")
                        {
                            @foreach (var a in araclar)
                            {
                                <option value="@a.Id">@a.Plaka</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreyiTemizle">
                        <i class="bi bi-x-lg me-1"></i>Filtreyi Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste -->
    <div class="card">
        @if (!yukleniyor && hakedisler.Any())
        {
            <div class="card-header bg-light py-2 d-flex flex-wrap gap-3 align-items-center small">
                <span><i class="bi bi-list-ol me-1"></i><strong>@hakedisler.Count</strong> hakediş</span>
                <span class="text-muted">|</span>
                <span><i class="bi bi-truck me-1"></i>Toplam Sefer: <strong>@hakedisler.Sum(h => h.ToplamSeferSayisi).ToString("N2")</strong></span>
                <span class="text-muted">|</span>
                <span><i class="bi bi-cash me-1"></i>Toplam Tutar: <strong>@hakedisler.Sum(h => h.Tutar).ToString("N2") ₺</strong></span>
                <span class="text-muted">|</span>
                <span><i class="bi bi-receipt me-1"></i>Genel Toplam: <strong>@hakedisler.Sum(h => h.GenelToplam).ToString("N2") ₺</strong></span>
            </div>
        }
        @if (seciliIds.Count > 0)
        {
            <div class="card-body py-2 border-top bg-warning-subtle d-flex flex-wrap gap-2 align-items-center">
                <span class="me-2"><i class="bi bi-check2-square me-1"></i><strong>@seciliIds.Count</strong> kayıt seçili</span>
                <button class="btn btn-sm btn-success" @onclick="TopluOnayla" disabled="@topluIslemCalisiyor">
                    <i class="bi bi-check2-circle me-1"></i> Toplu Onayla
                </button>
                <button class="btn btn-sm btn-primary" @onclick="TopluFaturalaAc" disabled="@topluIslemCalisiyor">
                    <i class="bi bi-receipt me-1"></i> Toplu Faturala
                </button>
                <button class="btn btn-sm btn-outline-danger" @onclick="TopluPdfZipIndir" disabled="@topluIslemCalisiyor">
                    <i class="bi bi-file-earmark-zip me-1"></i> Toplu PDF (ZIP)
                </button>
                <button class="btn btn-sm btn-outline-success" @onclick="TopluExcelIndir" disabled="@topluIslemCalisiyor">
                    <i class="bi bi-file-earmark-excel me-1"></i> Toplu Excel
                </button>
                <button class="btn btn-sm btn-outline-danger" @onclick="TopluSil" disabled="@topluIslemCalisiyor">
                    <i class="bi bi-trash me-1"></i> Toplu Sil
                </button>
                <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="SecimiTemizle" disabled="@topluIslemCalisiyor">
                    <i class="bi bi-x-lg me-1"></i> Seçimi Temizle
                </button>
                @if (topluIslemCalisiyor)
                {
                    <span class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span> İşleniyor...</span>
                }
            </div>
        }
        <div class="card-body p-0">
            @if (yukleniyor)
            {
                <div class="p-4 text-center text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
                </div>
            }
            else if (!hakedisler.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Bu kriterlere uygun hakediş bulunamadı. Üst sağdaki "Hakediş Üret" ile yeni hakediş oluşturabilirsiniz.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:32px;" class="text-center">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@TumuSecili"
                                           @onchange="OnTumuSecChanged" />
                                </th>
                                <th class="user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Donem")'>Dönem @SiralamaIkon("Donem")</th>
                                <th class="user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Tip")'>Tip @SiralamaIkon("Tip")</th>
                                <th class="user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Referans")'>Referans @SiralamaIkon("Referans")</th>
                                <th class="text-end user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Sefer")'>Sefer @SiralamaIkon("Sefer")</th>
                                <th class="text-end user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Tutar")'>Tutar @SiralamaIkon("Tutar")</th>
                                <th class="text-end user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Kdv")'>KDV @SiralamaIkon("Kdv")</th>
                                <th class="text-end user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("GenelToplam")'>Genel Toplam @SiralamaIkon("GenelToplam")</th>
                                <th class="user-select-none" style="cursor:pointer;" @onclick='() => SiralamaDegistir("Durum")'>Durum @SiralamaIkon("Durum")</th>
                                <th class="text-center" style="width:240px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in SiraliHakedisler)
                            {
                                <tr class="@(seciliIds.Contains(h.Id) ? "table-active" : null)">
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@seciliIds.Contains(h.Id)"
                                               @onchange="(e) => OnSatirSecChanged(h.Id, (bool)e.Value!)" />
                                    </td>
                                    <td>@h.Yil/@h.Ay.ToString("D2")</td>
                                    <td><span class="badge @TipBadge(h.Tip)">@h.Tip</span></td>
                                    <td>@ReferansAdi(h)</td>
                                    <td class="text-end">@h.ToplamSeferSayisi.ToString("N2")</td>
                                    <td class="text-end">@h.Tutar.ToString("N2") ₺</td>
                                    <td class="text-end">@h.KdvTutar.ToString("N2") ₺</td>
                                    <td class="text-end fw-semibold">@h.GenelToplam.ToString("N2") ₺</td>
                                    <td><span class="badge @DurumBadge(h.Durum)">@h.Durum</span></td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-secondary" title="Detaylar" @onclick="() => DetayAc(h)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" title="PDF İndir" @onclick="() => PdfIndir(h)">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </button>
                                            @if (h.Durum == HakedisDurum.Taslak)
                                            {
                                                <button class="btn btn-outline-success" title="Onayla" @onclick="() => Onayla(h)">
                                                    <i class="bi bi-check2-circle"></i>
                                                </button>
                                                <button class="btn btn-outline-danger" title="Sil" @onclick="() => Sil(h)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            @if (h.Durum == HakedisDurum.Onaylandi && h.Tip != HakedisTipi.Arac)
                                            {
                                                <button class="btn btn-outline-primary" title="Faturaya Dönüştür" @onclick="() => FaturayaDonustur(h)">
                                                    <i class="bi bi-receipt"></i>
                                                </button>
                                            }
                                            @if (h.Durum != HakedisDurum.Faturalandi && h.Durum != HakedisDurum.Iptal)
                                            {
                                                <button class="btn btn-outline-warning" title="İptal" @onclick="() => IptalEt(h)">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                @if (acikDetayId == h.Id)
                                {
                                    <tr>
                                        <td colspan="10" class="bg-light">
                                            <div class="p-2">
                                                @{
                                                    var aktifH = detayCache.TryGetValue(h.Id, out var dh) ? dh : h;
                                                }
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <h6 class="mb-0">
                                                        Detay Satırları (@(aktifH.Detaylar?.Count ?? 0))
                                                        @if (aktifH.Detaylar != null && aktifH.Detaylar.Any())
                                                        {
                                                            <span class="text-muted small ms-2">
                                                                Toplam: @aktifH.Detaylar.Sum(x => x.SeferSayisi).ToString("N2") sefer • @aktifH.Detaylar.Sum(x => x.Tutar).ToString("N2") ₺
                                                            </span>
                                                        }
                                                    </h6>
                                                    <div>
                                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => DetayExcelIndir(aktifH)" disabled="@(aktifH.Detaylar == null || !aktifH.Detaylar.Any())">
                                                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => PdfIndir(aktifH)">
                                                            <i class="bi bi-file-earmark-pdf me-1"></i>PDF
                                                        </button>
                                                    </div>
                                                </div>
                                                @if (detayYukleniyorId == h.Id)
                                                {
                                                    <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Detaylar yükleniyor...</div>
                                                }
                                                else if (aktifH.Detaylar == null || !aktifH.Detaylar.Any())
                                                {
                                                    <div class="text-muted small">Bu hakedişe ait detay bulunamadı.</div>
                                                }
                                                else
                                                {
                                                    <table class="table table-sm table-bordered mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th>Tarih</th>
                                                                <th>Servis Türü</th>
                                                                <th>Araç</th>
                                                                <th>Şoför</th>
                                                                <th>Güzergah</th>
                                                                <th class="text-end">Sefer</th>
                                                                <th class="text-end">Birim ₺</th>
                                                                <th class="text-end">Tutar ₺</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var d in aktifH.Detaylar.OrderBy(x => x.Tarih))
                                                            {
                                                                <tr>
                                                                    <td>@d.Tarih.ToString("dd.MM.yyyy")</td>
                                                                    <td>@d.ServisTuru</td>
                                                                    <td>@(d.Arac?.Plaka ?? "-")</td>
                                                                    <td>@(d.Sofor?.TamAd ?? "-")</td>
                                                                    <td>@(d.Guzergah?.GuzergahAdi ?? "-")</td>
                                                                    <td class="text-end">@d.SeferSayisi.ToString("N2")</td>
                                                                    <td class="text-end">@d.BirimFiyat.ToString("N2")</td>
                                                                    <td class="text-end fw-semibold">@d.Tutar.ToString("N2")</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot class="table-light">
                                                            <tr class="fw-bold">
                                                                <td colspan="5" class="text-end">TOPLAM</td>
                                                                <td class="text-end">@aktifH.Detaylar.Sum(x => x.SeferSayisi).ToString("N2")</td>
                                                                <td></td>
                                                                <td class="text-end">@aktifH.Detaylar.Sum(x => x.Tutar).ToString("N2")</td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Üretim Modal -->
@if (uretModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-lg me-2"></i>Yeni Hakediş Üret</h5>
                    <button type="button" class="btn-close" @onclick="UretModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small">Yıl</label>
                            <select class="form-select form-select-sm" @bind="uretYil" @bind:after="OnizlemeYukle">
                                @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Ay</label>
                            <select class="form-select form-select-sm" @bind="uretAy" @bind:after="OnizlemeYukle">
                                @for (int a = 1; a <= 12; a++)
                                {
                                    <option value="@a">@AyAdi(a)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small">Tip</label>
                            <select class="form-select form-select-sm" @bind="uretTip" @bind:after="OnizlemeYukle">
                                <option value="Kurum">Kurum (Gelir)</option>
                                <option value="Tedarikci">Tedarikçi (Gider)</option>
                                <option value="Arac">Araç (İç Karlılık)</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small">Referans</label>
                            @if (uretTip == "Kurum")
                            {
                                <select class="form-select form-select-sm" @bind="uretReferansId" @bind:after="OnizlemeYukle">
                                    <option value="0">-- Seçiniz --</option>
                                    @foreach (var f in firmalar)
                                    {
                                        <option value="@f.Id">@f.FirmaAdi</option>
                                    }
                                </select>
                            }
                            else if (uretTip == "Tedarikci")
                            {
                                <select class="form-select form-select-sm" @bind="uretReferansId" @bind:after="OnizlemeYukle">
                                    <option value="0">-- Seçiniz --</option>
                                    @foreach (var t in tedarikciler)
                                    {
                                        <option value="@t.Id">@t.Unvan</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <select class="form-select form-select-sm" @bind="uretReferansId" @bind:after="OnizlemeYukle">
                                    <option value="0">-- Seçiniz --</option>
                                    @foreach (var a in araclar)
                                    {
                                        <option value="@a.Id">@a.Plaka</option>
                                    }
                                </select>
                            }
                        </div>
                        <div class="col-12">
                            @if (onizlemeYukleniyor)
                            {
                                <div class="alert alert-light border py-2 mb-0 small">
                                    <span class="spinner-border spinner-border-sm me-1"></span>Önizleme hesaplanıyor...
                                </div>
                            }
                            else if (onizleme != null)
                            {
                                <div class="alert @(onizleme.PuantajSayisi == 0 ? "alert-warning" : "alert-info") py-2 mb-0 small">
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-list-check me-1"></i>Puantaj Kaydı</span>
                                        <strong>@onizleme.PuantajSayisi</strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-truck me-1"></i>Toplam Sefer</span>
                                        <strong>@onizleme.ToplamSefer.ToString("N2")</strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-cash me-1"></i>Tahmini Tutar (KDV hariç)</span>
                                        <strong>@onizleme.TahminiTutar.ToString("N2") ₺</strong>
                                    </div>
                                    @if (onizleme.PuantajSayisi == 0)
                                    {
                                        <div class="mt-1 text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Bu döneme ait puantaj bulunamadı; üretim boş olacaktır.</div>
                                    }
                                    @if (onizleme.MevcutTaslakVar)
                                    {
                                        <div class="mt-1 text-warning"><i class="bi bi-info-circle me-1"></i>Bu dönem için mevcut <strong>Taslak</strong> hakediş üzerine yazılacaktır (#@onizleme.MevcutHakedisId).</div>
                                    }
                                    else if (onizleme.MevcutOnayliVar)
                                    {
                                        <div class="mt-1 text-danger"><i class="bi bi-shield-exclamation me-1"></i>Bu dönem için <strong>@onizleme.MevcutHakedisDurum</strong> durumunda mevcut hakediş var (#@onizleme.MevcutHakedisId). Yeni üretim ek kayıt oluşturur.</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="UretModalKapat">İptal</button>
                    <button class="btn btn-primary btn-sm" @onclick="UretOnayla" disabled="@(uretReferansId <= 0 || isleniyor)">
                        @if (isleniyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Üret
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Üretim Modal -->
@if (topluModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-stack me-2"></i>Toplu Hakediş Üret</h5>
                    <button type="button" class="btn-close" @onclick="TopluModalKapat" disabled="@topluIsleniyor"></button>
                </div>
                <div class="modal-body">
                    @if (topluSonuc == null)
                    {
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label small">Yıl</label>
                                <select class="form-select form-select-sm" @bind="topluYil" disabled="@topluIsleniyor">
                                    @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                                    {
                                        <option value="@y">@y</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Ay</label>
                                <select class="form-select form-select-sm" @bind="topluAy" disabled="@topluIsleniyor">
                                    @for (int a = 1; a <= 12; a++)
                                    {
                                        <option value="@a">@AyAdi(a)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Tip</label>
                                <select class="form-select form-select-sm" @bind="topluTip" disabled="@topluIsleniyor">
                                    <option value="Kurum">Kurum (Gelir)</option>
                                    <option value="Tedarikci">Tedarikçi (Gider)</option>
                                    <option value="Arac">Araç (İç Karlılık)</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-info py-2 mb-0 small">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Seçilen dönem puantajlarındaki <strong>tüm @topluTip</strong> referansları için ayrı ayrı hakediş üretilecek.
                                    Mevcut <strong>Onaylı/Faturalı</strong> hakedişler atlanır; <strong>Taslak</strong> kayıtlar üzerine yazılır.
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-md-3">
                                <div class="card border-primary text-center">
                                    <div class="card-body py-2">
                                        <div class="small text-muted">Toplam Referans</div>
                                        <div class="h4 mb-0">@topluSonuc.ToplamReferans</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card border-success text-center">
                                    <div class="card-body py-2">
                                        <div class="small text-muted">Üretilen</div>
                                        <div class="h4 mb-0 text-success">@topluSonuc.UretilenAdet</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card border-warning text-center">
                                    <div class="card-body py-2">
                                        <div class="small text-muted">Atlanan</div>
                                        <div class="h4 mb-0 text-warning">@topluSonuc.AtlananAdet</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card border-danger text-center">
                                    <div class="card-body py-2">
                                        <div class="small text-muted">Hatalı</div>
                                        <div class="h4 mb-0 text-danger">@topluSonuc.HataliAdet</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="alert alert-success py-2 small mb-2">
                            <i class="bi bi-cash-stack me-1"></i>Üretilen hakedişler toplam genel tutar:
                            <strong>@topluSonuc.ToplamTutar.ToString("N2") ₺</strong>
                        </div>
                        <div class="table-responsive" style="max-height:380px;overflow-y:auto;">
                            <table class="table table-sm table-hover table-bordered mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Referans</th>
                                        <th>Sonuç</th>
                                        <th class="text-end">Sefer</th>
                                        <th class="text-end">Tutar ₺</th>
                                        <th>Mesaj / Hakediş</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in topluSonuc.Satirlar)
                                    {
                                        <tr>
                                            <td>@s.ReferansAd <span class="text-muted small">#@s.ReferansId</span></td>
                                            <td>
                                                <span class="badge @(s.Sonuc switch {
                                                    "Üretildi" => "bg-success",
                                                    "Atlandı" => "bg-warning text-dark",
                                                    "Hata" => "bg-danger",
                                                    _ => "bg-secondary"
                                                })">@s.Sonuc</span>
                                            </td>
                                            <td class="text-end">@s.Sefer.ToString("N2")</td>
                                            <td class="text-end fw-semibold">@s.Tutar.ToString("N2")</td>
                                            <td class="small">
                                                @if (s.HakedisId.HasValue)
                                                {
                                                    <span class="text-muted">#@s.HakedisId</span>
                                                }
                                                @if (!string.IsNullOrEmpty(s.Mesaj))
                                                {
                                                    <span> @s.Mesaj</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="TopluModalKapat" disabled="@topluIsleniyor">
                        @(topluSonuc == null ? "İptal" : "Kapat")
                    </button>
                    @if (topluSonuc == null)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="TopluUret" disabled="@topluIsleniyor">
                            @if (topluIsleniyor)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-stack me-1"></i> Üret
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Faturalama Modal -->
@if (topluFaturaModalAcik)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Toplu Faturalama</h5>
                    <button type="button" class="btn-close" @onclick="TopluFaturaKapat"></button>
                </div>
                <div class="modal-body">
                    @if (topluFaturaSonuc == null)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>@seciliIds.Count</strong> seçili hakediş faturaya dönüştürülecek.
                            Sadece <strong>Onaylanmış</strong> ve <strong>Kurum/Tedarikçi</strong> tipindekiler işleme alınır;
                            <strong>Araç</strong> tipi ve diğer durumlardakiler atlanır.
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label">Fatura Tarihi</label>
                                <input type="date" class="form-control" @bind="topluFaturaTarihi" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-2 mb-3">
                            <div class="col"><div class="card border-primary"><div class="card-body py-2 text-center"><div class="small text-muted">Seçili</div><div class="h4 mb-0">@topluFaturaSonuc.ToplamSecili</div></div></div></div>
                            <div class="col"><div class="card border-success"><div class="card-body py-2 text-center"><div class="small text-muted">Faturalandı</div><div class="h4 mb-0 text-success">@topluFaturaSonuc.BasariliAdet</div></div></div></div>
                            <div class="col"><div class="card border-warning"><div class="card-body py-2 text-center"><div class="small text-muted">Atlandı</div><div class="h4 mb-0 text-warning">@topluFaturaSonuc.AtlananAdet</div></div></div></div>
                            <div class="col"><div class="card border-danger"><div class="card-body py-2 text-center"><div class="small text-muted">Hata</div><div class="h4 mb-0 text-danger">@topluFaturaSonuc.HataliAdet</div></div></div></div>
                        </div>
                        <div class="table-responsive" style="max-height:380px;overflow-y:auto;">
                            <table class="table table-sm table-hover">
                                <thead class="table-light"><tr><th>Hakediş #</th><th>Sonuç</th><th>Mesaj</th></tr></thead>
                                <tbody>
                                    @foreach (var s in topluFaturaSonuc.Satirlar)
                                    {
                                        <tr>
                                            <td>#@s.HakedisId</td>
                                            <td><span class="badge bg-@(s.Sonuc == "Tamam" ? "success" : s.Sonuc == "Atlandı" ? "warning" : "danger")">@s.Sonuc</span></td>
                                            <td class="small">@s.Mesaj</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    @if (topluFaturaSonuc == null)
                    {
                        <button class="btn btn-secondary" @onclick="TopluFaturaKapat" disabled="@topluFaturaCalisiyor">İptal</button>
                        <button class="btn btn-primary" @onclick="TopluFaturalaCalistir" disabled="@topluFaturaCalisiyor">
                            @if (topluFaturaCalisiyor)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-receipt me-1"></i> Faturaları Üret
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary" @onclick="TopluFaturaKapat">Kapat</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool yukleniyor = true;
    private bool isleniyor = false;
    private bool uretModalAcik = false;

    private int filtreYil = DateTime.Now.Year;
    private int filtreAy = DateTime.Now.Month;
    private string filtreTip = "";
    private string filtreDurum = "";
    private int filtreReferansId = 0;

    private int uretYil = DateTime.Now.Year;
    private int uretAy = DateTime.Now.Month;
    private string uretTip = "Kurum";
    private int uretReferansId = 0;

    private HakedisOnizleme? onizleme = null;
    private bool onizlemeYukleniyor = false;
    private CancellationTokenSource? onizlemeCts;

    // Toplu üretim
    private bool topluModalAcik = false;
    private bool topluIsleniyor = false;
    private int topluYil = DateTime.Now.Year;
    private int topluAy = DateTime.Now.Month;
    private string topluTip = "Kurum";
    private TopluHakedisSonuc? topluSonuc = null;

    // Toplu Onay/Silme seçimi
    private HashSet<int> seciliIds = new();
    private bool topluIslemCalisiyor = false;
    private bool TumuSecili => hakedisler.Count > 0 && hakedisler.All(h => seciliIds.Contains(h.Id));

    // Toplu Faturalama
    private bool topluFaturaModalAcik = false;
    private bool topluFaturaCalisiyor = false;
    private DateTime topluFaturaTarihi = DateTime.Today;
    private TopluIslemSonuc? topluFaturaSonuc = null;

    private int? acikDetayId = null;
    private int? detayYukleniyorId = null;
    private Dictionary<int, Hakedis> detayCache = new();

    private List<Hakedis> hakedisler = new();
    private List<Firma> firmalar = new();
    private List<TasimaTedarikci> tedarikciler = new();
    private List<Arac> araclar = new();

    // Sıralama state
    private string siralamaKolon = "Donem";
    private bool siralamaAzalan = true;

    private IEnumerable<Hakedis> SiraliHakedisler
    {
        get
        {
            IEnumerable<Hakedis> q = hakedisler;
            q = siralamaKolon switch
            {
                "Donem" => siralamaAzalan
                    ? q.OrderByDescending(h => h.Yil).ThenByDescending(h => h.Ay).ThenByDescending(h => h.Id)
                    : q.OrderBy(h => h.Yil).ThenBy(h => h.Ay).ThenBy(h => h.Id),
                "Tip" => Sirala(q, h => h.Tip.ToString()),
                "Referans" => Sirala(q, h => ReferansAdi(h)),
                "Sefer" => Sirala(q, h => h.ToplamSeferSayisi),
                "Tutar" => Sirala(q, h => h.Tutar),
                "Kdv" => Sirala(q, h => h.KdvTutar),
                "GenelToplam" => Sirala(q, h => h.GenelToplam),
                "Durum" => Sirala(q, h => h.Durum.ToString()),
                _ => q
            };
            return q;
        }
    }

    private IOrderedEnumerable<Hakedis> Sirala<TKey>(IEnumerable<Hakedis> q, Func<Hakedis, TKey> selector)
        => siralamaAzalan ? q.OrderByDescending(selector) : q.OrderBy(selector);

    private void SiralamaDegistir(string kolon)
    {
        if (siralamaKolon == kolon)
            siralamaAzalan = !siralamaAzalan;
        else
        {
            siralamaKolon = kolon;
            siralamaAzalan = false;
        }
    }

    private MarkupString SiralamaIkon(string kolon)
    {
        if (siralamaKolon != kolon)
            return new MarkupString("<i class=\"bi bi-arrow-down-up text-muted small ms-1\"></i>");
        return new MarkupString(siralamaAzalan
            ? "<i class=\"bi bi-arrow-down small ms-1\"></i>"
            : "<i class=\"bi bi-arrow-up small ms-1\"></i>");
    }

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        tedarikciler = await TedarikciService.GetAllAsync(sadeceAktif: true);
        araclar = await AracService.GetActiveAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            HakedisTipi? tip = string.IsNullOrEmpty(filtreTip) ? null : Enum.Parse<HakedisTipi>(filtreTip);
            HakedisDurum? durum = string.IsNullOrEmpty(filtreDurum) ? null : Enum.Parse<HakedisDurum>(filtreDurum);
            int? refId = filtreReferansId > 0 ? filtreReferansId : null;
            hakedisler = await HakedisService.GetHakedislerAsync(filtreYil, filtreAy, tip, refId, durum);
            detayCache.Clear();
            acikDetayId = null;
            // listede artık olmayan seçimleri temizle
            var mevcutIds = hakedisler.Select(h => h.Id).ToHashSet();
            seciliIds.RemoveWhere(id => !mevcutIds.Contains(id));
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private async Task FiltreyiTemizle()
    {
        filtreYil = DateTime.Now.Year;
        filtreAy = DateTime.Now.Month;
        filtreTip = "";
        filtreDurum = "";
        filtreReferansId = 0;
        await LoadAsync();
    }

    private void OnSatirSecChanged(int id, bool secili)
    {
        if (secili) seciliIds.Add(id);
        else seciliIds.Remove(id);
    }

    private void OnTumuSecChanged(ChangeEventArgs e)
    {
        var secili = (bool)(e.Value ?? false);
        if (secili)
        {
            foreach (var h in hakedisler) seciliIds.Add(h.Id);
        }
        else
        {
            foreach (var h in hakedisler) seciliIds.Remove(h.Id);
        }
    }

    private void SecimiTemizle() => seciliIds.Clear();

    private async Task TopluOnayla()
    {
        if (seciliIds.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"{seciliIds.Count} kayıt onaylanacak. Devam edilsin mi?"))
            return;

        topluIslemCalisiyor = true;
        try
        {
            var sonuc = await HakedisService.TopluOnaylaAsync(seciliIds.ToList(), "Sistem");
            ToastService.ShowSuccess($"Toplu onay: {sonuc.BasariliAdet} onaylandı, {sonuc.AtlananAdet} atlandı, {sonuc.HataliAdet} hata.");
            if (sonuc.HataliAdet > 0 || sonuc.AtlananAdet > 0)
            {
                var ilk = sonuc.Satirlar.FirstOrDefault(s => s.Sonuc != "Tamam");
                if (ilk != null)
                    ToastService.ShowWarning($"Örnek: #{ilk.HakedisId} → {ilk.Sonuc} {ilk.Mesaj}");
            }
            seciliIds.Clear();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu onay hatası: {ex.Message}");
        }
        finally
        {
            topluIslemCalisiyor = false;
        }
    }

    private async Task TopluSil()
    {
        if (seciliIds.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"{seciliIds.Count} kayıt silinecek. (Faturalanmış olanlar atlanır.) Devam edilsin mi?"))
            return;

        topluIslemCalisiyor = true;
        try
        {
            var sonuc = await HakedisService.TopluSilAsync(seciliIds.ToList());
            ToastService.ShowSuccess($"Toplu silme: {sonuc.BasariliAdet} silindi, {sonuc.AtlananAdet} atlandı, {sonuc.HataliAdet} hata.");
            if (sonuc.HataliAdet > 0 || sonuc.AtlananAdet > 0)
            {
                var ilk = sonuc.Satirlar.FirstOrDefault(s => s.Sonuc != "Tamam");
                if (ilk != null)
                    ToastService.ShowWarning($"Örnek: #{ilk.HakedisId} → {ilk.Sonuc} {ilk.Mesaj}");
            }
            seciliIds.Clear();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu silme hatası: {ex.Message}");
        }
        finally
        {
            topluIslemCalisiyor = false;
        }
    }

    private void TopluFaturalaAc()
    {
        if (seciliIds.Count == 0) return;
        topluFaturaTarihi = DateTime.Today;
        topluFaturaSonuc = null;
        topluFaturaCalisiyor = false;
        topluFaturaModalAcik = true;
    }

    private void TopluFaturaKapat()
    {
        topluFaturaModalAcik = false;
        if (topluFaturaSonuc != null)
        {
            // sonuç görüntülendi -> seçimi temizle ve listeyi yenile
            seciliIds.Clear();
            topluFaturaSonuc = null;
            _ = LoadAsync();
        }
    }

    private async Task TopluFaturalaCalistir()
    {
        if (seciliIds.Count == 0) return;
        topluFaturaCalisiyor = true;
        try
        {
            topluFaturaSonuc = await HakedisService.TopluFaturalaAsync(seciliIds.ToList(), topluFaturaTarihi);
            ToastService.ShowSuccess($"Toplu faturalama: {topluFaturaSonuc.BasariliAdet} fatura, {topluFaturaSonuc.AtlananAdet} atlandı, {topluFaturaSonuc.HataliAdet} hata.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu faturalama hatası: {ex.Message}");
        }
        finally
        {
            topluFaturaCalisiyor = false;
        }
    }

    private async Task OnTipChanged()
    {
        // Tip değişince referans seçimi sıfırlanmalı (yanlış id'lerle filtrelemeyi önle)
        filtreReferansId = 0;
        await LoadAsync();
    }

    private void UretModalAc()
    {
        uretYil = filtreYil;
        uretAy = filtreAy;
        uretTip = "Kurum";
        uretReferansId = 0;
        onizleme = null;
        uretModalAcik = true;
    }

    private void UretModalKapat()
    {
        uretModalAcik = false;
        onizleme = null;
        onizlemeCts?.Cancel();
    }

    private async Task OnizlemeYukle()
    {
        if (uretReferansId <= 0)
        {
            onizleme = null;
            return;
        }

        onizlemeCts?.Cancel();
        onizlemeCts = new CancellationTokenSource();
        var token = onizlemeCts.Token;

        onizlemeYukleniyor = true;
        StateHasChanged();
        try
        {
            var tip = Enum.Parse<HakedisTipi>(uretTip);
            var sonuc = await HakedisService.OnizleAsync(tip, uretReferansId, uretYil, uretAy);
            if (token.IsCancellationRequested) return;
            onizleme = sonuc;
        }
        catch (Exception ex)
        {
            if (!token.IsCancellationRequested)
                ToastService.ShowError($"Önizleme alınamadı: {ex.Message}");
        }
        finally
        {
            if (!token.IsCancellationRequested)
                onizlemeYukleniyor = false;
        }
    }

    private void TopluModalAc()
    {
        topluYil = filtreYil;
        topluAy = filtreAy;
        topluTip = string.IsNullOrEmpty(filtreTip) ? "Kurum" : filtreTip;
        topluSonuc = null;
        topluModalAcik = true;
    }

    private void TopluModalKapat()
    {
        if (topluIsleniyor) return;
        topluModalAcik = false;
        topluSonuc = null;
    }

    private async Task TopluUret()
    {
        topluIsleniyor = true;
        StateHasChanged();
        try
        {
            var tip = Enum.Parse<HakedisTipi>(topluTip);
            topluSonuc = await HakedisService.TopluUretAsync(tip, topluYil, topluAy);
            ToastService.ShowSuccess($"Toplu üretim tamamlandı: {topluSonuc.UretilenAdet} üretildi, {topluSonuc.AtlananAdet} atlandı, {topluSonuc.HataliAdet} hata.");
            filtreYil = topluYil;
            filtreAy = topluAy;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu üretim hatası: {ex.Message}");
        }
        finally
        {
            topluIsleniyor = false;
        }
    }

    private async Task UretOnayla()
    {
        if (uretReferansId <= 0) return;
        isleniyor = true;
        try
        {
            Hakedis? h = uretTip switch
            {
                "Kurum" => await HakedisService.KurumHakedisiUretAsync(uretReferansId, uretYil, uretAy),
                "Tedarikci" => await HakedisService.TedarikciHakedisiUretAsync(uretReferansId, uretYil, uretAy),
                "Arac" => await HakedisService.AracHakedisiUretAsync(uretReferansId, uretYil, uretAy),
                _ => null
            };

            if (h != null)
            {
                ToastService.ShowSuccess($"Hakediş üretildi: {h.ToplamSeferSayisi:N2} sefer / {h.GenelToplam:N2} ₺");
                uretModalAcik = false;
                filtreYil = uretYil;
                filtreAy = uretAy;
                await LoadAsync();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isleniyor = false;
        }
    }

    private async Task Onayla(Hakedis h)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"{h.Yil}/{h.Ay:D2} {h.Tip} hakedişi onaylansın mı?")) return;
        try
        {
            await HakedisService.OnaylaAsync(h.Id, "Kullanıcı");
            ToastService.ShowSuccess("Hakediş onaylandı.");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
    }

    private async Task IptalEt(Hakedis h)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Hakediş iptal edilsin mi?")) return;
        try
        {
            await HakedisService.IptalEtAsync(h.Id);
            ToastService.ShowWarning("Hakediş iptal edildi.");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
    }

    private async Task Sil(Hakedis h)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Hakediş silinsin mi?")) return;
        try
        {
            await HakedisService.SilAsync(h.Id);
            ToastService.ShowSuccess("Hakediş silindi.");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
    }

    private async Task FaturayaDonustur(Hakedis h)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Hakediş #{h.Id} faturaya dönüştürülsün mü?")) return;
        try
        {
            var f = await HakedisService.FaturayaDonustureAsync(h.Id, DateTime.Today);
            ToastService.ShowSuccess($"Fatura oluşturuldu: {f.FaturaNo}");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
    }

    private async Task DetayAc(Hakedis h)
    {
        if (acikDetayId == h.Id)
        {
            acikDetayId = null;
            return;
        }

        acikDetayId = h.Id;
        if (!detayCache.ContainsKey(h.Id))
        {
            detayYukleniyorId = h.Id;
            try
            {
                var dolu = await HakedisService.GetByIdAsync(h.Id);
                if (dolu != null) detayCache[h.Id] = dolu;
            }
            catch (Exception ex) { ToastService.ShowError($"Detay yüklenemedi: {ex.Message}"); }
            finally { detayYukleniyorId = null; }
        }
    }

    private bool listeExcelCalisiyor = false;

    private async Task ListeyiExceleAktar()
    {
        if (!hakedisler.Any()) return;
        listeExcelCalisiyor = true;
        StateHasChanged();
        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Hakedisler");

            var baslik = $"OPERASYONEL HAKEDİŞ LİSTESİ • {filtreYil}/{filtreAy:D2}"
                + (string.IsNullOrEmpty(filtreTip) ? "" : $" • {filtreTip}")
                + (string.IsNullOrEmpty(filtreDurum) ? "" : $" • {filtreDurum}");
            ws.Cell(1, 1).Value = baslik;
            ws.Cell(1, 1).Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 13;
            ws.Range(1, 1, 1, 10).Merge();

            var headers = new[] { "#", "Dönem", "Tip", "Referans", "Sefer", "Tutar ₺", "KDV %", "KDV ₺", "Genel Toplam ₺", "Durum" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(3, i + 1).Value = headers[i];
                ws.Cell(3, i + 1).Style.Font.Bold = true;
                ws.Cell(3, i + 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            }

            int r = 4;
            foreach (var h in hakedisler)
            {
                ws.Cell(r, 1).Value = h.Id;
                ws.Cell(r, 2).Value = $"{h.Yil}/{h.Ay:D2}";
                ws.Cell(r, 3).Value = h.Tip.ToString();
                ws.Cell(r, 4).Value = ReferansAdi(h);
                ws.Cell(r, 5).Value = h.ToplamSeferSayisi;
                ws.Cell(r, 6).Value = h.Tutar;
                ws.Cell(r, 7).Value = h.KdvOran;
                ws.Cell(r, 8).Value = h.KdvTutar;
                ws.Cell(r, 9).Value = h.GenelToplam;
                ws.Cell(r, 10).Value = h.Durum.ToString();
                r++;
            }

            // Toplam satırı
            ws.Cell(r, 4).Value = "TOPLAM";
            ws.Cell(r, 5).Value = hakedisler.Sum(h => h.ToplamSeferSayisi);
            ws.Cell(r, 6).Value = hakedisler.Sum(h => h.Tutar);
            ws.Cell(r, 8).Value = hakedisler.Sum(h => h.KdvTutar);
            ws.Cell(r, 9).Value = hakedisler.Sum(h => h.GenelToplam);
            ws.Range(r, 4, r, 10).Style.Font.Bold = true;
            ws.Range(r, 4, r, 10).Style.Fill.BackgroundColor = XLColor.LightYellow;

            ws.Range(4, 5, r, 9).Style.NumberFormat.Format = "#,##0.00";
            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(3);

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var fileName = $"Hakedis_Liste_{filtreYil}_{filtreAy:D2}_{DateTime.Now:yyyyMMddHHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(ms.ToArray()));
            ToastService.ShowSuccess($"Excel indirildi: {hakedisler.Count} kayıt.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel oluşturulamadı: {ex.GetBaseException().Message}");
        }
        finally
        {
            listeExcelCalisiyor = false;
        }
    }

    private async Task TopluExcelIndir()
    {
        if (seciliIds.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"{seciliIds.Count} hakediş için detay Excel (her biri ayrı sayfa) indirilsin mi?"))
            return;

        topluIslemCalisiyor = true;
        StateHasChanged();
        int basarili = 0, hata = 0;
        try
        {
            using var wb = new XLWorkbook();

            // Özet sayfası
            var ozet = wb.Worksheets.Add("Özet");
            ozet.Cell(1, 1).Value = $"SEÇİLİ HAKEDİŞLER • {DateTime.Now:dd.MM.yyyy HH:mm}";
            ozet.Cell(1, 1).Style.Font.Bold = true;
            ozet.Cell(1, 1).Style.Font.FontSize = 13;
            ozet.Range(1, 1, 1, 8).Merge();
            var oh = new[] { "#", "Dönem", "Tip", "Referans", "Sefer", "Tutar ₺", "KDV ₺", "Genel Toplam ₺" };
            for (int i = 0; i < oh.Length; i++)
            {
                ozet.Cell(3, i + 1).Value = oh[i];
                ozet.Cell(3, i + 1).Style.Font.Bold = true;
                ozet.Cell(3, i + 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            }
            int orow = 4;

            foreach (var id in seciliIds.ToList())
            {
                try
                {
                    Hakedis? full;
                    if (!detayCache.TryGetValue(id, out full!))
                    {
                        full = await HakedisService.GetByIdAsync(id);
                        if (full != null) detayCache[id] = full;
                    }
                    if (full == null) { hata++; continue; }

                    // Özet satırı
                    ozet.Cell(orow, 1).Value = full.Id;
                    ozet.Cell(orow, 2).Value = $"{full.Yil}/{full.Ay:D2}";
                    ozet.Cell(orow, 3).Value = full.Tip.ToString();
                    ozet.Cell(orow, 4).Value = ReferansAdi(full);
                    ozet.Cell(orow, 5).Value = full.ToplamSeferSayisi;
                    ozet.Cell(orow, 6).Value = full.Tutar;
                    ozet.Cell(orow, 7).Value = full.KdvTutar;
                    ozet.Cell(orow, 8).Value = full.GenelToplam;
                    orow++;

                    // Detay sayfası
                    var sheetName = $"H{full.Id}_{full.Tip}_{full.Yil}{full.Ay:D2}";
                    if (sheetName.Length > 31) sheetName = sheetName.Substring(0, 31);
                    var ws = wb.Worksheets.Add(sheetName);

                    ws.Cell(1, 1).Value = $"HAKEDİŞ #{full.Id} • {full.Yil}/{full.Ay:D2} • {full.Tip} • {ReferansAdi(full)}";
                    ws.Cell(1, 1).Style.Font.Bold = true;
                    ws.Cell(1, 1).Style.Font.FontSize = 12;
                    ws.Range(1, 1, 1, 8).Merge();

                    var dh = new[] { "Tarih", "Servis Türü", "Araç", "Şoför", "Güzergah", "Sefer", "Birim ₺", "Tutar ₺" };
                    for (int i = 0; i < dh.Length; i++)
                    {
                        ws.Cell(3, i + 1).Value = dh[i];
                        ws.Cell(3, i + 1).Style.Font.Bold = true;
                        ws.Cell(3, i + 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
                    }

                    int dr = 4;
                    if (full.Detaylar != null)
                    {
                        foreach (var d in full.Detaylar.OrderBy(x => x.Tarih))
                        {
                            ws.Cell(dr, 1).Value = d.Tarih;
                            ws.Cell(dr, 1).Style.DateFormat.Format = "dd.MM.yyyy";
                            ws.Cell(dr, 2).Value = d.ServisTuru.ToString();
                            ws.Cell(dr, 3).Value = d.Arac?.Plaka ?? "-";
                            ws.Cell(dr, 4).Value = d.Sofor?.TamAd ?? "-";
                            ws.Cell(dr, 5).Value = d.Guzergah?.GuzergahAdi ?? "-";
                            ws.Cell(dr, 6).Value = d.SeferSayisi;
                            ws.Cell(dr, 7).Value = d.BirimFiyat;
                            ws.Cell(dr, 8).Value = d.Tutar;
                            dr++;
                        }
                        ws.Cell(dr, 5).Value = "TOPLAM";
                        ws.Cell(dr, 6).Value = full.Detaylar.Sum(x => x.SeferSayisi);
                        ws.Cell(dr, 8).Value = full.Detaylar.Sum(x => x.Tutar);
                        ws.Range(dr, 5, dr, 8).Style.Font.Bold = true;
                        ws.Range(dr, 5, dr, 8).Style.Fill.BackgroundColor = XLColor.LightYellow;
                    }
                    ws.Range(4, 6, Math.Max(dr, 4), 8).Style.NumberFormat.Format = "#,##0.00";
                    ws.Columns().AdjustToContents();
                    ws.SheetView.FreezeRows(3);
                    basarili++;
                }
                catch
                {
                    hata++;
                }
            }

            // Özet toplam
            ozet.Cell(orow, 4).Value = "TOPLAM";
            ozet.Cell(orow, 5).Value = hakedisler.Where(x => seciliIds.Contains(x.Id)).Sum(x => x.ToplamSeferSayisi);
            ozet.Cell(orow, 6).Value = hakedisler.Where(x => seciliIds.Contains(x.Id)).Sum(x => x.Tutar);
            ozet.Cell(orow, 7).Value = hakedisler.Where(x => seciliIds.Contains(x.Id)).Sum(x => x.KdvTutar);
            ozet.Cell(orow, 8).Value = hakedisler.Where(x => seciliIds.Contains(x.Id)).Sum(x => x.GenelToplam);
            ozet.Range(orow, 4, orow, 8).Style.Font.Bold = true;
            ozet.Range(orow, 4, orow, 8).Style.Fill.BackgroundColor = XLColor.LightYellow;
            ozet.Range(4, 5, orow, 8).Style.NumberFormat.Format = "#,##0.00";
            ozet.Columns().AdjustToContents();
            ozet.SheetView.FreezeRows(3);

            if (basarili == 0)
            {
                ToastService.ShowWarning("Excel üretilemedi.");
                return;
            }

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var fileName = $"Hakedisler_Detay_{filtreYil}_{filtreAy:D2}_{DateTime.Now:yyyyMMddHHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(ms.ToArray()));
            ToastService.ShowSuccess($"Excel indirildi: {basarili} hakediş" + (hata > 0 ? $", {hata} hata" : "") + ".");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu Excel hatası: {ex.GetBaseException().Message}");
        }
        finally
        {
            topluIslemCalisiyor = false;
        }
    }

    private async Task TopluPdfZipIndir()
    {
        if (seciliIds.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"{seciliIds.Count} hakediş için PDF üretilip ZIP olarak indirilsin mi?"))
            return;

        topluIslemCalisiyor = true;
        StateHasChanged();
        int basarili = 0, hata = 0;
        try
        {
            byte[] zipBytes;
            using (var ms = new MemoryStream())
            {
                using (var zip = new ZipArchive(ms, ZipArchiveMode.Create, leaveOpen: true))
                {
                    foreach (var id in seciliIds.ToList())
                    {
                        try
                        {
                            Hakedis? full;
                            if (!detayCache.TryGetValue(id, out full!))
                            {
                                full = await HakedisService.GetByIdAsync(id);
                                if (full != null) detayCache[id] = full;
                            }
                            if (full == null) { hata++; continue; }

                            var pdf = PdfService.GenerateHakedisPdf(full, ReferansAdi(full));
                            var entryName = $"Hakedis_{full.Tip}_{full.Yil}{full.Ay:D2}_{full.Id}.pdf";
                            var entry = zip.CreateEntry(entryName, CompressionLevel.Optimal);
                            using var es = entry.Open();
                            await es.WriteAsync(pdf, 0, pdf.Length);
                            basarili++;
                        }
                        catch
                        {
                            hata++;
                        }
                    }
                }
                zipBytes = ms.ToArray();
            }

            if (basarili == 0)
            {
                ToastService.ShowWarning("PDF üretilemedi.");
                return;
            }

            var fileName = $"Hakedisler_{filtreYil}_{filtreAy:D2}_{DateTime.Now:yyyyMMddHHmmss}.zip";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(zipBytes));
            ToastService.ShowSuccess($"ZIP indirildi: {basarili} PDF" + (hata > 0 ? $", {hata} hata" : "") + ".");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu PDF hatası: {ex.Message}");
        }
        finally
        {
            topluIslemCalisiyor = false;
        }
    }

    private async Task PdfIndir(Hakedis h)
    {
        try
        {
            Hakedis? full;
            if (detayCache.TryGetValue(h.Id, out var cached))
            {
                full = cached;
            }
            else
            {
                full = await HakedisService.GetByIdAsync(h.Id);
                if (full != null) detayCache[h.Id] = full;
            }

            if (full == null)
            {
                ToastService.ShowError("Hakediş bulunamadı.");
                return;
            }

            var pdf = PdfService.GenerateHakedisPdf(full, ReferansAdi(full));
            var fileName = $"Hakedis_{full.Tip}_{full.Yil}{full.Ay:D2}_{full.Id}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(pdf));
            ToastService.ShowSuccess("PDF indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF oluşturulamadı: {ex.Message}");
        }
    }

