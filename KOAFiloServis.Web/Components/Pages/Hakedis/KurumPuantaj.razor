@page "/kurum-puantaj"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IKurumPuantajService KurumPuantajService
@inject IGuzergahService GuzergahService
@inject IAracService AracService
@inject ISoforService SoforService
@inject GuzergahDegisiklikUyariService DegisiklikUyari
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IPuantajSyncService PuantajSyncService
@inject IDuplicateDetectionService DuplicateDetectionService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer

<PageTitle>Kurum Puantaj</PageTitle>

<style>
    .puantaj-table th, .puantaj-table td { font-size: .80rem; padding: 3px 5px; white-space: nowrap; }
    .puantaj-table input[type=number] { width: 36px; text-align: center; padding: 1px 2px; font-size:.78rem; border:1px solid #ced4da; border-radius:3px; }
    .puantaj-table input[type=number]:focus { outline: none; border-color:#0d6efd; box-shadow: 0 0 0 2px rgba(13,110,253,.2); }
    .gun-hdr { text-align:center; width:30px; min-width:28px; }
    .col-guzergah { min-width:160px; max-width:200px; }
    .col-arac { min-width:90px; }
    .col-sofor { min-width:110px; }
    .col-yon { min-width:80px; }
    .col-toplam { min-width:55px; font-weight:700; background:#f0f7ff; text-align:center; }
    .hafta-sonu { background:#fff8e1 !important; }
    .satir-degisik { background:#e8f5e9 !important; }
    .guzergah-grup th { background:#e3eeff; font-weight:600; font-size:.79rem; }
    .sticky-col { position:sticky; left:0; z-index:2; background:#fff; }
    .sticky-col2 { position:sticky; left:160px; z-index:2; background:#fff; }
    .bugun-vurgu { border: 2px solid #dc3545 !important; border-radius: 3px; }
    .bugun-hdr { background: #ffe0e0 !important; font-weight: 700; }
</style>

<div class="container-fluid px-3">

    <!-- Başlık -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-calendar3 me-2 text-primary"></i>Kurum Puantaj</h3>
            <p class="text-muted small mb-0">Kurum bazlı güzergah / araç günlük sefer puantajı</p>
        </div>
        <div class="d-flex gap-2">
            @if (degisiklikVar)
            {
                <button class="btn btn-success" @onclick="TopluKaydet" disabled="@kaydediliyor">
                    @if (kaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    else { <i class="bi bi-floppy me-1"></i> }
                    Tümünü Kaydet
                </button>
            }
            <button class="btn btn-outline-secondary" @onclick="SablonOlustur" disabled="@yukleniyor">
                <i class="bi bi-magic me-1"></i> Şablon Oluştur
            </button>
            @if (seciliKurumId > 0 && kayitlar.Any())
            {
                <button class="btn btn-outline-warning" @onclick="PuantajGuncelle" disabled="@yukleniyor">
                    <i class="bi bi-arrow-repeat me-1"></i> Puantajı Güncelle
                </button>
                <button class="btn btn-outline-danger" @onclick="PuantajKaldir" disabled="@yukleniyor">
                    <i class="bi bi-x-circle me-1"></i> Puantajı Kaldır
                </button>
            }
            @if (seciliKurumId > 0)
            {
                <a href="/operasyon-giris" class="btn btn-outline-primary">
                    <i class="bi bi-plus-circle me-1"></i> Operasyon Girişi
                </a>
            }
            <a href="/puantaj/import" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel Aktar
            </a>
            <button class="btn btn-outline-info" @onclick="SenkronizeEt" disabled="@yukleniyor">
                <i class="bi bi-sync me-1"></i> Senkronize Et
            </button>
            <button class="btn btn-outline-secondary" @onclick="DuplicateRaporuGoster" disabled="@yukleniyor">
                <i class="bi bi-exclamation-triangle me-1"></i> Duplicate Raporu
            </button>
            @if (kullaniciYetkili)
            {
                <button class="btn btn-outline-warning" @onclick="BackfillCalistir" disabled="@yukleniyor">
                    <i class="bi bi-database-add me-1"></i> Eksik Operasyon Kayıtlarını Oluştur
                </button>
                <button class="btn btn-outline-danger" @onclick="PuantajdanYenidenOlustur" disabled="@yukleniyor">
                    <i class="bi bi-arrow-repeat me-1"></i> Puantajdan Yeniden Oluştur
                </button>
            }
        </div>
    </div>

    @if (!yukleniyor && DegisiklikUyari.DegisiklikVar)
    {
        <div class="alert alert-warning alert-dismissible fade show py-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>@DegisiklikUyari.DegisenSayisi güzergah</strong> düzenlendi.
            Puantajı güncellemek için <strong>"Şablon Oluştur"</strong> butonunu kullanın.
            <button type="button" class="btn-close" @onclick="DegisiklikUyari.TumunuTemizle" title="Uyarıyı kapat"></button>
        </div>
    }

    @if (cakismaSonucu != null && cakismaSonucu.Conflicts.Any())
    {
        var blockings = cakismaSonucu.Conflicts.Where(c => c.Severity == ConflictSeverity.Blocking).ToList();
        var warnings = cakismaSonucu.Conflicts.Where(c => c.Severity == ConflictSeverity.Warning).ToList();
        <div class="alert @(blockings.Any() ? "alert-danger" : "alert-warning") alert-dismissible fade show py-2 mb-3">
            <i class="bi @(blockings.Any() ? "bi-x-octagon-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            <strong>@cakismaSonucu.Conflicts.Count çakışma</strong> bulundu:
            @if (blockings.Any()) { <span class="badge bg-danger me-1">@blockings.Count engelleyici</span> }
            @if (warnings.Any()) { <span class="badge bg-warning text-dark">@warnings.Count uyarı</span> }
            <button type="button" class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => CakismaDetayGoster = !CakismaDetayGoster">
                <i class="bi @(CakismaDetayGoster ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>Detay
            </button>
            <button type="button" class="btn-close" @onclick="() => cakismaSonucu = null"></button>
        </div>
        @if (CakismaDetayGoster)
        {
            <div class="card mb-3 border-danger">
                <div class="card-body py-2 small">
                    <table class="table table-sm table-borderless mb-0">
                        @foreach (var c in cakismaSonucu.Conflicts.OrderBy(c => c.Severity).ThenBy(c => c.Gun))
                        {
                            <tr class="@(c.Severity == ConflictSeverity.Blocking ? "table-danger" : "table-warning")">
                                <td style="width:80px">
                                    <span class="badge @(c.Severity == ConflictSeverity.Blocking ? "bg-danger" : "bg-warning text-dark")">@c.Kural</span>
                                </td>
                                <td style="width:50px">@(c.Gun > 0 ? $"Gün {c.Gun}" : "-")</td>
                                <td>@c.Mesaj</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        }
    }

    <!-- Filtre Çubuğu -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold mb-1">Kurum</label>
                    <select class="form-select form-select-sm" @bind="seciliKurumId" @bind:after="KurumDegisti">
                        <option value="0">— Kurum seçin —</option>
                        @foreach (var k in kurumlar)
                        {
                            <option value="@k.Id">@k.KurumAdi</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-semibold mb-1">Yıl</label>
                    <select class="form-select form-select-sm" style="width:90px" @bind="seciliYil" @bind:after="LoadData">
                        @for (int y = DateTime.Now.Year + 1; y >= 2022; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-semibold mb-1">Ay</label>
                    <select class="form-select form-select-sm" style="width:110px" @bind="seciliAy" @bind:after="LoadData">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@AyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-semibold mb-1">Görünüm</label>
                    <div class="btn-group btn-group-sm">
                        <button class="btn @(gorunumDetayli ? "btn-primary" : "btn-outline-primary")"
                                @onclick="@(() => gorunumDetayli = true)">
                            <i class="bi bi-grid-3x3-gap"></i> Günlük
                        </button>
                        <button class="btn @(!gorunumDetayli ? "btn-primary" : "btn-outline-primary")"
                                @onclick="@(() => gorunumDetayli = false)">
                            <i class="bi bi-list-columns"></i> Özet
                        </button>
                    </div>
                </div>
                @if (kayitlar.Any())
                {
                    <div class="col-auto ms-auto text-muted small align-self-end">
                        <strong>@kayitlar.Count</strong> satır &nbsp;|&nbsp;
                        Toplam sefer: <strong>@kayitlar.Sum(k => k.SeferGunuToplami)</strong>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Yükleniyor…</p>
        </div>
    }
    else if (seciliKurumId == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-building fs-1 opacity-25"></i>
            <p class="mt-2">Lütfen bir kurum seçin.</p>
        </div>
    }
    else if (!kayitlar.Any())
    {
        <div class="alert alert-info d-flex align-items-center gap-2">
            <i class="bi bi-info-circle-fill"></i>
            <span>
                Bu dönem için kayıt yok.
                <button class="btn btn-sm btn-primary ms-2" @onclick="SablonOlustur">
                    <i class="bi bi-magic me-1"></i> Şablon Oluştur
                </button>
            </span>
        </div>
    }
    else
    {
        <div class="row g-2 mb-2">
            <div class="col-auto"><span class="badge bg-secondary">@kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.Taslak) Taslak</span></div>
            <div class="col-auto"><span class="badge bg-warning text-dark">@kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.OnayBekliyor) Onay Bekliyor</span></div>
            <div class="col-auto"><span class="badge bg-success">@kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.Onaylandi) Onaylandi</span></div>
            <div class="col-auto"><span class="badge bg-primary">@kayitlar.Sum(k => (decimal)k.SeferGunuToplami) Toplam Gun</span></div>
        </div>

        <!-- Toplu seçim araç çubuğu -->
        <div class="d-flex gap-2 mb-2 flex-wrap">
            <button class="btn btn-sm btn-outline-danger" @onclick="CakismaKontrolEt">
                <i class="bi bi-shield-exclamation me-1"></i> Çakışma Kontrolü
            </button>
            <span class="vr"></span>
            <button class="btn btn-sm btn-outline-success" @onclick="TopluOnayla">
                <i class="bi bi-check-circle me-1"></i> Onayla
            </button>
            <button class="btn btn-sm btn-outline-warning" @onclick="TopluOnayaGonder">
                <i class="bi bi-send me-1"></i> Onaya Gönder
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="TopluOnayKaldir">
                <i class="bi bi-arrow-counterclockwise me-1"></i> Onay Kaldır
            </button>
            <span class="vr"></span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="TumGunleriAc">
                <i class="bi bi-check2-all me-1"></i> Tümü = 1
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="TumGunleriSifirla">
                <i class="bi bi-x-circle me-1"></i> Sıfırla
            </button>
            <button class="btn btn-sm btn-outline-warning" @onclick="SadeceHaftaIciAc">
                <i class="bi bi-briefcase me-1"></i> Hafta İçi = 1
            </button>
            <button class="btn btn-sm btn-outline-warning" @onclick="SadeceHaftaSonuAc">
                <i class="bi bi-calendar-week me-1"></i> Hafta Sonu = 1
            </button>
            <span class="vr"></span>
            <small class="text-muted align-self-center">
                <i class="bi bi-square-fill text-warning me-1"></i>Haftasonu
                &nbsp;
                <span class="badge bg-success-subtle text-success border">Değiştirildi</span>
            </small>
        </div>

        @if (gorunumDetayli)
        {
            <!-- Özet Kartlar -->
            <div class="row g-2 mb-2">
                <div class="col-6 col-md-2">
                    <div class="card bg-primary text-white text-center py-1">
                        <small class="opacity-75">Toplam Kayıt</small>
                        <h5 class="mb-0">@kayitlar.Count</h5>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="card bg-success text-white text-center py-1">
                        <small class="opacity-75">Toplam Gelir</small>
                        <h5 class="mb-0">@kayitlar.Sum(k => k.ToplamGelir).ToString("N0") ₺</h5>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="card bg-danger text-white text-center py-1">
                        <small class="opacity-75">Toplam Gider</small>
                        <h5 class="mb-0">@kayitlar.Sum(k => k.ToplamGider).ToString("N0") ₺</h5>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="card bg-info text-white text-center py-1">
                        <small class="opacity-75">Net Kar</small>
                        <h5 class="mb-0">@((kayitlar.Sum(k => k.ToplamGelir) - kayitlar.Sum(k => k.ToplamGider)).ToString("N0")) ₺</h5>
                    </div>
                </div>
            </div>

            <!-- ─── GÜNLÜK DETAYLI TABLO ─────────────────────────────── -->
            <div class="table-responsive" style="overflow-x:auto; max-height:72vh; overflow-y:auto;">
                <table class="table table-bordered table-sm puantaj-table align-middle">
                    <thead class="table-light" style="position:sticky;top:0;z-index:3;">
                        <tr>
                            <th class="sticky-col col-guzergah">Güzergah</th>
                            <th class="sticky-col2 col-arac">Araç</th>
                            <th class="col-sofor">Şoför</th>
                            <th style="width:60px">Slot</th>
                            <th class="col-yon">Yön</th>
                            @for (int g = 1; g <= AydakiGunSayisi(); g++)
                            {
                                var tarih = new DateTime(seciliYil, seciliAy, g);
                                var gunClass = "gun-hdr";
                                if (HaftaSonuMu(tarih)) gunClass += " hafta-sonu";
                                if (BugunMu(tarih)) gunClass += " bugun-hdr";
                                <th class="@gunClass">
                                    <div>@g</div>
                                    <div style="font-size:.65rem;color:#888">@tarih.ToString("ddd", new System.Globalization.CultureInfo("tr-TR"))</div>
                                </th>
                            }
                            <th class="col-toplam">Top.</th>
                            <th style="width:60px">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var grup in GrupluKayitlar())
                        {
                            <!-- Güzergah grup başlığı -->
                            <tr class="guzergah-grup">
                                <td colspan="@(5 + AydakiGunSayisi() + 2)" class="py-1 px-2">
                                    <i class="bi bi-signpost-split me-1 text-primary"></i>
                                    <strong>@grup.Key</strong>
                                    <span class="badge bg-primary-subtle text-primary ms-2">@grup.Value.Count araç</span>
                                    <span class="text-muted ms-2 small">Toplam: <strong>@grup.Value.Sum(k=>k.SeferGunuToplami)</strong> sefer</span>
                                </td>
                            </tr>

                            @foreach (var kayit in grup.Value)
                            {
                                <tr class="@(degisikSatirlar.Contains(kayit) ? "satir-degisik" : "")">
                                    <td class="sticky-col col-guzergah text-truncate" style="max-width:200px" title="@(kayit.Guzergah?.GuzergahAdi ?? kayit.GuzergahAdi)">
                                        @(kayit.Guzergah?.GuzergahAdi ?? kayit.GuzergahAdi)
                                    </td>
                                    <td class="sticky-col2 col-arac fw-semibold">@kayit.Plaka</td>
                                    <td class="col-sofor text-truncate" style="max-width:130px" title="@kayit.SoforAdi">@kayit.SoforAdi</td>
                                    <td><span class="badge @SlotBadgeClass(kayit.Slot)">@SlotAd(kayit.Slot)</span></td>
                                    <td class="col-yon">
                                        <select class="form-select form-select-sm py-0" style="font-size:.76rem"
                                                value="@kayit.Yon"
                                                @onchange="e => YonDegisti(kayit, e)">
                                            <option value="@PuantajYon.Sabah">Sabah</option>
                                            <option value="@PuantajYon.Aksam">Akşam</option>
                                            <option value="@PuantajYon.SabahAksam">S+A</option>
                                        </select>
                                    </td>
                                    @for (int g = 1; g <= AydakiGunSayisi(); g++)
                                    {
                                        var gunNo = g;
                                        var tarih = new DateTime(seciliYil, seciliAy, gunNo);
                                        var cellClass = HaftaSonuMu(tarih) ? "hafta-sonu" : "";
                                        if (BugunMu(tarih)) cellClass += " bugun-vurgu";
                                        <td class="@cellClass">
                                            <input type="number" min="0" max="2"
                                                   value="@kayit.GetGunDeger(gunNo)"
                                                   @onchange="e => GunDegerDegisti(kayit, gunNo, e)"
                                                   @onclick="e => { }" />
                                        </td>
                                    }
                                    <td class="col-toplam">@kayit.SeferGunuToplami</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-xs btn-outline-primary p-1" title="Düzenle"
                                                    @onclick="() => TekKayitDuzenle(kayit)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-xs btn-outline-danger p-1" title="Sil"
                                                    @onclick="() => KayitSil(kayit)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            var ozetKayitlar = FiltreliKayitlar();
            <!-- ─── ÖZET TABLO + FİLTRE PANELİ ────────────────────────── -->
            <div class="row">
                <div class="col-md-9">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm puantaj-table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Güzergah</th>
                                    <th>Araç</th>
                                    <th>Şoför</th>
                                    <th>Yön</th>
                                    <th class="text-center">Sefer Sayısı</th>
                                    <th class="text-center">Toplam Gün</th>
                                    <th class="text-center" style="width:50px">OpK</th>
                                    <th style="width:60px">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kayit in ozetKayitlar)
                                {
                                    <tr class="@(degisikSatirlar.Contains(kayit) ? "satir-degisik" : "")">
                                        <td>
                                        @(kayit.Guzergah?.GuzergahAdi ?? kayit.GuzergahAdi)
                                        @if (!string.IsNullOrWhiteSpace(kayit.SlotAdi))
                                        { <br /><small class="text-muted">@kayit.SlotAdi</small> }
                                        else if (kayit.Slot >= SeferSlot.Diger1)
                                        { <br /><small class="text-muted">@kayit.Slot</small> }
                                    </td>
                                        <td class="fw-semibold">@kayit.Plaka</td>
                                        <td>@kayit.SoforAdi</td>
                                        <td>
                                            <select class="form-select form-select-sm py-0" style="width:90px;font-size:.76rem"
                                                    value="@kayit.Yon"
                                                    @onchange="e => YonDegisti(kayit, e)">
                                                <option value="@PuantajYon.Sabah">Sabah</option>
                                                <option value="@PuantajYon.Aksam">Akşam</option>
                                                <option value="@PuantajYon.SabahAksam">S+A</option>
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <input type="number" min="0" max="31" style="width:55px;text-align:center"
                                                   class="form-control form-control-sm d-inline-block"
                                                   value="@kayit.SeferSayisi"
                                                   @onchange="e => SeferSayisiDegisti(kayit, e)" />
                                        </td>
                                        <td class="col-toplam">@kayit.SeferGunuToplami</td>
                                        <td class="text-center">
                                            @if (operasyonKaydiVarMiLookup.ContainsKey(kayit.Id))
                                            { <span class="badge bg-success" title="Operasyon kaydı mevcut">OK</span> }
                                            else
                                            { <span class="badge bg-secondary" title="Operasyon kaydı yok">--</span> }
                                        </td>
                                        <td class="text-center">
                                            @if (kayit.OnayDurum == PuantajOnayDurum.Onaylandi)
                                            { <span class="badge bg-success small" style="cursor:pointer" title="Onayı kaldır" @onclick="() => OnayToggle(kayit)">Onayli</span> }
                                            else if (kayit.OnayDurum == PuantajOnayDurum.OnayBekliyor)
                                            { <span class="badge bg-warning text-dark small" style="cursor:pointer" title="Onayla" @onclick="() => OnayToggle(kayit)">Bekliyor</span> }
                                            else if (kayit.OnayDurum == PuantajOnayDurum.Reddedildi)
                                            { <span class="badge bg-danger small" style="cursor:pointer" title="Taslağa çevir" @onclick="() => OnayToggle(kayit)">Red</span> }
                                            else
                                            { <span class="badge bg-secondary small" style="cursor:pointer" title="Onayla" @onclick="() => OnayToggle(kayit)">Taslak</span> }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-xs btn-outline-primary p-1" title="Günlük Düzenle"
                                                        @onclick="() => TekKayitDuzenle(kayit)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-xs btn-outline-danger p-1" title="Sil"
                                                        @onclick="() => KayitSil(kayit)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary fw-bold" style="font-size:.80rem">
                                <tr>
                                    <td colspan="5" class="text-end">
                                        Toplam @if (FiltreAktif) { <text>(filtreli)</text> }:
                                    </td>
                                    <td class="text-center">@ozetKayitlar.Sum(k => k.SeferSayisi)</td>
                                    <td class="text-center">@ozetKayitlar.Sum(k => k.SeferGunuToplami)</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <!-- ─── FİLTRE PANELİ ──────────────────────────────────────── -->
                <div class="col-md-3">
                    <div class="card border-secondary">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center"
                             style="cursor:pointer" @onclick="() => filtrePanelGorunur = !filtrePanelGorunur">
                            <span class="fw-semibold small">
                                <i class="bi bi-funnel me-1"></i> Filtreler
                                @if (FiltreAktif)
                                { <span class="badge bg-primary ms-1">@(seciliFirmalar.Count + seciliPlakalar.Count)</span> }
                            </span>
                            <i class="bi @(filtrePanelGorunur ? "bi-chevron-up" : "bi-chevron-down") small"></i>
                        </div>
                        @if (filtrePanelGorunur)
                        {
                            <div class="card-body py-2" style="font-size:.78rem; max-height:70vh; overflow-y:auto">
                                @if (FiltreAktif)
                                {
                                    <button class="btn btn-sm btn-outline-secondary w-100 mb-2"
                                            @onclick="FiltreleriTemizle">
                                        <i class="bi bi-x-circle me-1"></i> Filtreleri Temizle
                                    </button>
                                }

                                <!-- Sahibi Firma -->
                                <div class="fw-semibold mb-1 small text-secondary">Sahibi Firma</div>
                                @{
                                    var firmaSecenekleri = FirmaSecenekleri();
                                }
                                @if (firmaSecenekleri.Any())
                                {
                                    <div class="mb-3">
                                        @for (int fi = 0; fi < firmaSecenekleri.Count; fi++)
                                        {
                                            var firma = firmaSecenekleri[fi];
                                            <div class="form-check mb-0">
                                                <input class="form-check-input" type="checkbox"
                                                       checked="@seciliFirmalar.Contains(firma)"
                                                       @onchange="() => FirmaFiltreToggle(firma)"
                                                       id="@($"frm_{fi}")" />
                                                <label class="form-check-label" for="@($"frm_{fi}")">
                                                    @firma
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small mb-3">Firma bilgisi yok</p>
                                }

                                <!-- Araç -->
                                <div class="fw-semibold mb-1 small text-secondary">Araç</div>
                                @{
                                    var plakaSecenekleri = PlakaSecenekleri();
                                }
                                @if (plakaSecenekleri.Any())
                                {
                                    <div class="mb-2">
                                        @for (int pi = 0; pi < plakaSecenekleri.Count; pi++)
                                        {
                                            var plaka = plakaSecenekleri[pi];
                                            <div class="form-check mb-0">
                                                <input class="form-check-input" type="checkbox"
                                                       checked="@seciliPlakalar.Contains(plaka)"
                                                       @onchange="() => PlakaFiltreToggle(plaka)"
                                                       id="@($"plk_{pi}")" />
                                                <label class="form-check-label" for="@($"plk_{pi}")">
                                                    @plaka
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small">Plaka bilgisi yok</p>
                                }

                                @if (FiltreAktif)
                                {
                                    <hr class="my-2" />
                                    <small class="text-muted">
                                        <strong>@ozetKayitlar.Count</strong> / @kayitlar.Count satır
                                    </small>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- ── Tek Kayıt Düzenle Modal ─────────────────────────────────────────────── -->
@if (duzenleKayit != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-2"></i>
                        @(duzenleKayit.Guzergah?.GuzergahAdi ?? duzenleKayit.GuzergahAdi) <text>—</text> @duzenleKayit.Plaka
                        <small class="text-muted ms-2">(@AyAdi(seciliAy) @seciliYil)</small>
                    </h5>
                    <button class="btn-close" @onclick="() => duzenleKayit = null"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Güzergah</label>
                            <select class="form-select form-select-sm" @bind="duzenleKayit.GuzergahId" @bind:after="() => duzenleKayit.GuzergahAdi = guzergahListesi.FirstOrDefault(g => g.Id == duzenleKayit.GuzergahId)?.GuzergahAdi">
                                <option value="">-- Seçiniz --</option>
                                @foreach (var g in guzergahListesi)
                                { <option value="@g.Id">@g.GuzergahAdi</option> }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Araç</label>
                            <select class="form-select form-select-sm" @bind="duzenleKayit.AracId" @bind:after="AracDegistigindeSoforYukle">
                                <option value="">-- Seçiniz --</option>
                                @foreach (var a in aracListesi)
                                { <option value="@a.Id">@a.AktifPlaka</option> }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Şoför</label>
                            <select class="form-select form-select-sm" @bind="duzenleKayit.SoforId" @bind:after="() => duzenleKayit.SoforAdi = soforListesi.FirstOrDefault(s => s.Id == duzenleKayit.SoforId)?.TamAd ?? duzenleKayit.SoforAdi">
                                <option value="">-- Seçiniz --</option>
                                @foreach (var s in soforListesi)
                                { <option value="@s.Id">@s.TamAd</option> }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small">Sefer/Gün</label>
                            <input type="number" class="form-control form-control-sm" @bind="duzenleKayit.SeferSayisi" min="0" max="4" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label small">Slot</label>
                            <select class="form-select form-select-sm" @bind="duzenleKayit.Slot">
                                @foreach (SeferSlot s in Enum.GetValues<SeferSlot>())
                                { <option value="@s">@s</option> }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Yön</label>
                            <select class="form-select form-select-sm" @bind="duzenleKayit.Yon">
                                <option value="@PuantajYon.Sabah">Sabah</option>
                                <option value="@PuantajYon.Aksam">Akşam</option>
                                <option value="@PuantajYon.SabahAksam">Sabah + Akşam</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Slot Adı</label>
                            <input class="form-control form-control-sm" @bind="duzenleKayit.SlotAdi" placeholder="Gece Vardiyası..." maxlength="50" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end gap-2">
                            <button class="btn btn-sm btn-outline-success" @onclick="() => DuzenleTumGunleriDoldur(1)">
                                <i class="bi bi-check-all me-1"></i>Tümü=1
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => DuzenleTumGunleriDoldur(0)">
                                <i class="bi bi-x me-1"></i>Sıfırla
                            </button>
                        </div>
                    </div>

                    <!-- Gün tablosu -->
                    <table class="table table-sm table-bordered puantaj-table">
                        <thead class="table-light">
                            <tr>
                                @for (int g = 1; g <= AydakiGunSayisi(); g++)
                                {
                                    var tarih = new DateTime(seciliYil, seciliAy, g);
                                    var gunClass = "gun-hdr";
                                    if (HaftaSonuMu(tarih)) gunClass += " hafta-sonu";
                                    if (BugunMu(tarih)) gunClass += " bugun-hdr";
                                    <th class="@gunClass">
                                        <div>@g</div>
                                        <div style="font-size:.62rem;color:#888">@tarih.ToString("ddd", new System.Globalization.CultureInfo("tr-TR"))</div>
                                    </th>
                                }
                                <th class="col-toplam">Top.</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                @for (int g = 1; g <= AydakiGunSayisi(); g++)
                                {
                                    var gunNo = g;
                                    var tarih = new DateTime(seciliYil, seciliAy, gunNo);
                                    var cellClass = HaftaSonuMu(tarih) ? "hafta-sonu" : "";
                                    if (BugunMu(tarih)) cellClass += " bugun-vurgu";
                                    <td class="@cellClass">
                                        <input type="number" min="0" max="2"
                                               value="@duzenleKayit.GetGunDeger(gunNo)"
                                               @onchange="e => DuzenleGunDegisti(gunNo, e)" />
                                    </td>
                                }
                                <td class="col-toplam">@duzenleKayit.SeferGunuToplami</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => duzenleKayit = null">İptal</button>
                    <button class="btn btn-primary" @onclick="TekKayitKaydet" disabled="@kaydediliyor">
                        @if (kaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-floppy me-1"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    List<Kurum>       kurumlar      = [];
    List<PuantajKayit> kayitlar     = [];
    HashSet<PuantajKayit> degisikSatirlar = [];

    int  seciliKurumId = 0;
    int  seciliYil     = DateTime.Now.Year;
    int  seciliAy      = DateTime.Now.Month;
    bool yukleniyor    = false;
    bool kaydediliyor  = false;
    bool gorunumDetayli = true;

    PuantajKayit? duzenleKayit = null;
    List<Guzergah> guzergahListesi = [];
    List<Arac> aracListesi = [];
    List<Sofor> soforListesi = [];
    ConflictResult? cakismaSonucu = null;
    bool CakismaDetayGoster = false;

    bool degisiklikVar => degisikSatirlar.Count > 0;

    // ── Filtre State ──────────────────────────────────────────────────────────
    HashSet<string> seciliFirmalar = [];
    HashSet<string> seciliPlakalar = [];
    bool filtrePanelGorunur = true;

    // ── Sync State ─────────────────────────────────────────────────────────
    Dictionary<int, bool> operasyonKaydiVarMiLookup = [];
    bool kullaniciYetkili = false;

    // Filtrelenmiş kayıt listesi
    List<PuantajKayit> FiltreliKayitlar()
    {
        var sonuc = kayitlar.AsEnumerable();
        if (seciliFirmalar.Count > 0)
            sonuc = sonuc.Where(k => seciliFirmalar.Contains(SahibiFirma(k)));
        if (seciliPlakalar.Count > 0)
            sonuc = sonuc.Where(k => seciliPlakalar.Contains(k.Plaka ?? ""));
        return sonuc.ToList();
    }

    // Filtre seçenekleri: benzersiz plakalar
    List<string> PlakaSecenekleri() =>
        kayitlar.Select(k => k.Plaka ?? "")
                .Where(p => !string.IsNullOrWhiteSpace(p))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(p => p).ToList();

    // Filtre seçenekleri: benzersiz sahibi firmalar
    List<string> FirmaSecenekleri() =>
        kayitlar.Select(k => SahibiFirma(k))
                .Where(f => !string.IsNullOrWhiteSpace(f))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(f => f).ToList();

    // Araç değiştiğinde aktif şoförü otomatik yükle (PersonelAracAtamalari)
    private async Task AracDegistigindeSoforYukle()
    {
        duzenleKayit!.Plaka = aracListesi.FirstOrDefault(a => a.Id == duzenleKayit.AracId)?.AktifPlaka;

        if (duzenleKayit.AracId is <= 0) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var atama = await db.PersonelAracAtamalari
                .Include(a => a.Sofor)
                .Where(a => a.AracId == duzenleKayit.AracId && a.Aktif)
                .OrderByDescending(a => a.BaslangicTarihi)
                .FirstOrDefaultAsync();

            if (atama?.Sofor != null)
            {
                duzenleKayit.SoforId = atama.Sofor.Id;
                duzenleKayit.SoforAdi = atama.Sofor.TamAd;
            }
        }
        catch { /* sessizce devam et */ }
    }

    // Bir PuantajKayit'ın sahibi firmasını belirle
    string SahibiFirma(PuantajKayit k)
    {
        if (!string.IsNullOrWhiteSpace(k.AitFirmaAdi))
            return k.AitFirmaAdi;

        if (k.AracId.HasValue && k.AracId > 0)
        {
            var arac = aracListesi.FirstOrDefault(a => a.Id == k.AracId.Value);
            if (arac?.Firma != null && !string.IsNullOrWhiteSpace(arac.Firma.FirmaAdi))
                return arac.Firma.FirmaAdi;
        }
        return "";
    }

    void FirmaFiltreToggle(string firma)
    {
        if (!seciliFirmalar.Remove(firma))
            seciliFirmalar.Add(firma);
    }

    void PlakaFiltreToggle(string plaka)
    {
        if (!seciliPlakalar.Remove(plaka))
            seciliPlakalar.Add(plaka);
    }

    void FiltreleriTemizle()
    {
        seciliFirmalar.Clear();
        seciliPlakalar.Clear();
    }

    bool FiltreAktif => seciliFirmalar.Count > 0 || seciliPlakalar.Count > 0;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var roller = authState.User.Claims
            .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
            .Select(c => c.Value).ToList();
        kullaniciYetkili = roller.Any(r => r is "Admin" or "HoldingYoneticisi");

        kurumlar = await KurumPuantajService.GetAktifKurumlarAsync();
        guzergahListesi = await GuzergahService.GetActiveAsync();
        aracListesi = await AracService.GetActiveAsync();
        soforListesi = await SoforService.GetActiveSoforlerAsync();
    }

    // ── Filtre olayları ───────────────────────────────────────────────────────
    async Task KurumDegisti()
    {
        degisikSatirlar.Clear();
        cakismaSonucu = null;
        CakismaDetayGoster = false;
        await LoadData();
    }

    async Task LoadData()
    {
        if (seciliKurumId == 0) { kayitlar = []; operasyonKaydiVarMiLookup = []; return; }
        yukleniyor = true;
        StateHasChanged();
        try
        {
            kayitlar = await KurumPuantajService.GetPuantajlarAsync(seciliYil, seciliAy, seciliKurumId);
            var ids = kayitlar.Where(k => k.Id > 0).Select(k => k.Id).ToList();
            operasyonKaydiVarMiLookup = await KurumPuantajService.GetOperasyonKaydiVarligiAsync(ids);
        }
        finally
        {
            yukleniyor = false;
        }
    }

    async Task SablonOlustur()
    {
        if (seciliKurumId == 0) return;
        yukleniyor = true;
        StateHasChanged();
        try
        {
            kayitlar = await KurumPuantajService.SablonOlusturAsync(seciliKurumId, seciliYil, seciliAy);
            degisikSatirlar.Clear();
            ToastService.ShowSuccess("Şablon oluşturuldu. Değişiklik yaparken 'Tümünü Kaydet' ile kaydedin.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Şablon oluşturulamadı: {ex.Message}");
        }
        finally { yukleniyor = false; }
    }

    async Task PuantajGuncelle()
    {
        if (seciliKurumId == 0) return;
        yukleniyor = true;
        try
        {
            var sonuc = await KurumPuantajService.GuncellePuantajAsync(seciliKurumId, seciliYil, seciliAy);
            if (sonuc.Guncellenen > 0 || sonuc.Eklenen > 0)
            {
                kayitlar = await KurumPuantajService.GetPuantajlarAsync(seciliYil, seciliAy, seciliKurumId);
                degisikSatirlar.Clear();
                ToastService.ShowSuccess($"Puantaj güncellendi: {sonuc.Guncellenen} değişti, {sonuc.Eklenen} eklendi, {sonuc.Degismeyen} aynı.");
            }
            else
            {
                ToastService.ShowInfo($"Tüm kayıtlar güncel ({sonuc.Degismeyen} kayıt).");
            }
        }
        catch (Exception ex) { ToastService.ShowError($"Güncelleme hatası: {ex.Message}"); }
        finally { yukleniyor = false; }
    }

    async Task PuantajKaldir()
    {
        if (seciliKurumId == 0) return;
        var onay = await JS.InvokeAsync<bool>("confirm",
            $"Bu kurumun {AyAdi(seciliAy)} {seciliYil} dönemine ait TÜM puantaj kayıtları silinecek. Devam etmek istiyor musunuz?");
        if (!onay) return;

        yukleniyor = true;
        try
        {
            var silinen = await KurumPuantajService.PuantajKaldirAsync(seciliKurumId, seciliYil, seciliAy);
            kayitlar.Clear();
            degisikSatirlar.Clear();
            cakismaSonucu = null;
            ToastService.ShowSuccess($"{silinen} puantaj kaydı silindi.");
        }
        catch (Exception ex) { ToastService.ShowError($"Hata: {ex.InnerException?.Message ?? ex.Message}"); }
        finally { yukleniyor = false; }
    }

    // ── Toplu kaydet ──────────────────────────────────────────────────────────
    async Task TopluKaydet()
    {
        // Önce çakışma kontrolü
        var degisenListe = degisikSatirlar.ToList();
        var catisma = await KurumPuantajService.CheckConflictsAsync(degisenListe);
        var blockings = catisma.Conflicts.Where(c => c.Severity == ConflictSeverity.Blocking).ToList();
        if (blockings.Any())
        {
            cakismaSonucu = catisma;
            CakismaDetayGoster = true;
            ToastService.ShowError($"{blockings.Count} engelleyici çakışma var, kaydetme iptal edildi.");
            return;
        }

        kaydediliyor = true;
        try
        {
            await KurumPuantajService.TopluSavePuantajAsync(degisikSatirlar);
            degisikSatirlar.Clear();
            cakismaSonucu = null;
            await LoadData();
            ToastService.ShowSuccess("Tüm değişiklikler kaydedildi.");
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            ToastService.ShowError($"Kayıt hatası: {msg}");
        }
        finally { kaydediliyor = false; }
    }

    async Task CakismaKontrolEt()
    {
        var degisenListe = degisikSatirlar.Any() ? degisikSatirlar.ToList() : kayitlar;
        if (!degisenListe.Any())
        {
            ToastService.ShowInfo("Kontrol edilecek kayıt yok.");
            return;
        }
        cakismaSonucu = await KurumPuantajService.CheckConflictsAsync(degisenListe);
        CakismaDetayGoster = cakismaSonucu.Conflicts.Any();
        if (!cakismaSonucu.Conflicts.Any())
            ToastService.ShowSuccess("Hiç çakışma bulunamadı.");
        else
            ToastService.ShowWarning($"{cakismaSonucu.Conflicts.Count} çakışma bulundu.");
    }

    // ── Onay işlemleri ────────────────────────────────────────────────────────
    void TopluOnayla()
    {
        foreach (var k in kayitlar)
        {
            k.OnayDurum = PuantajOnayDurum.Onaylandi;
            degisikSatirlar.Add(k);
        }
        ToastService.ShowSuccess($"{kayitlar.Count} kayıt onaylandı. Değişiklikleri kaydetmek için 'Tümünü Kaydet' butonuna basın.");
    }

    void TopluOnayKaldir()
    {
        foreach (var k in kayitlar)
        {
            k.OnayDurum = PuantajOnayDurum.Taslak;
            degisikSatirlar.Add(k);
        }
        ToastService.ShowSuccess($"{kayitlar.Count} kaydın onayı kaldırıldı. Değişiklikleri kaydetmek için 'Tümünü Kaydet' butonuna basın.");
    }

    void TopluOnayaGonder()
    {
        var taslaklar = kayitlar.Where(k => k.OnayDurum == PuantajOnayDurum.Taslak).ToList();
        foreach (var k in taslaklar)
        {
            k.OnayDurum = PuantajOnayDurum.OnayBekliyor;
            degisikSatirlar.Add(k);
        }
        ToastService.ShowSuccess($"{taslaklar.Count} kayıt onaya gönderildi. Değişiklikleri kaydetmek için 'Tümünü Kaydet' butonuna basın.");
    }

    void OnayToggle(PuantajKayit kayit)
    {
        kayit.OnayDurum = kayit.OnayDurum switch
        {
            PuantajOnayDurum.Taslak => PuantajOnayDurum.Onaylandi,
            PuantajOnayDurum.OnayBekliyor => PuantajOnayDurum.Onaylandi,
            PuantajOnayDurum.Onaylandi => PuantajOnayDurum.Taslak,
            PuantajOnayDurum.Reddedildi => PuantajOnayDurum.Taslak,
            _ => PuantajOnayDurum.Taslak
        };
        degisikSatirlar.Add(kayit);
    }

    // ── Hücre değişim olayları ────────────────────────────────────────────────
    void GunDegerDegisti(PuantajKayit kayit, int gun, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int deger))
        {
            kayit.SetGunDeger(gun, Math.Clamp(deger, 0, 2));
            degisikSatirlar.Add(kayit);
        }
    }

    void YonDegisti(PuantajKayit kayit, ChangeEventArgs e)
    {
        if (Enum.TryParse<PuantajYon>(e.Value?.ToString(), out var yon))
        {
            kayit.Yon = yon;
            degisikSatirlar.Add(kayit);
        }
    }

    void SeferSayisiDegisti(PuantajKayit kayit, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int s))
        {
            kayit.SeferSayisi = Math.Clamp(s, 0, 31);
            degisikSatirlar.Add(kayit);
        }
    }

    // ── Toplu doldur / sıfırla ────────────────────────────────────────────────
    void TumGunleriAc()
    {
        foreach (var k in kayitlar)
        {
            for (int g = 1; g <= AydakiGunSayisi(); g++) k.SetGunDeger(g, 1);
            degisikSatirlar.Add(k);
        }
    }

    void TumGunleriSifirla()
    {
        foreach (var k in kayitlar)
        {
            for (int g = 1; g <= AydakiGunSayisi(); g++) k.SetGunDeger(g, 0);
            degisikSatirlar.Add(k);
        }
    }

    // ── Tek kayıt düzenle ─────────────────────────────────────────────────────
    void TekKayitDuzenle(PuantajKayit kayit)
    {
        // Derin kopya (modal iptal edilirse orijinal bozulmasın)
        duzenleKayit = new PuantajKayit
        {
            Id         = kayit.Id,
            GuzergahId = kayit.GuzergahId,
            Guzergah   = kayit.Guzergah,
            AracId     = kayit.AracId,
            Arac       = kayit.Arac,
            Plaka      = kayit.Plaka,
            SoforId    = kayit.SoforId,
            SoforAdi   = kayit.SoforAdi,
            Yon        = kayit.Yon,
            SeferSayisi= kayit.SeferSayisi,
            Yil        = kayit.Yil,
            Ay         = kayit.Ay,
            Slot       = kayit.Slot,
            SlotAdi    = kayit.SlotAdi,
            KurumId    = kayit.KurumId,
            BirimGelir = kayit.BirimGelir,
            BirimGider = kayit.BirimGider,
            KaynakTipi = kayit.KaynakTipi,
            FinansYonu = kayit.FinansYonu,
            IsverenFirmaId = kayit.IsverenFirmaId,
            OnayDurum = kayit.OnayDurum
        };
        for (int g = 1; g <= 31; g++) duzenleKayit.SetGunDeger(g, kayit.GetGunDeger(g));
    }

    void DuzenleGunDegisti(int gun, ChangeEventArgs e)
    {
        if (duzenleKayit == null) return;
        if (int.TryParse(e.Value?.ToString(), out int d))
            duzenleKayit.SetGunDeger(gun, Math.Clamp(d, 0, 2));
    }

    void DuzenleTumGunleriDoldur(int deger)
    {
        if (duzenleKayit == null) return;
        for (int g = 1; g <= AydakiGunSayisi(); g++) duzenleKayit.SetGunDeger(g, deger);
    }

    async Task TekKayitKaydet()
    {
        if (duzenleKayit == null) return;
        kaydediliyor = true;
        try
        {
            var kaydedilen = await KurumPuantajService.SavePuantajAsync(duzenleKayit);
            // Listedeki satırı güncelle
            var idx = kayitlar.FindIndex(k => k.Id == kaydedilen.Id);
            if (idx >= 0)
            {
                kayitlar[idx] = kaydedilen;
            }
            duzenleKayit = null;
            ToastService.ShowSuccess("Kayıt güncellendi.");
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            ToastService.ShowError($"Hata: {msg}");
        }
        finally { kaydediliyor = false; }
    }

    async Task KayitSil(PuantajKayit kayit)
    {
        if (kayit.Id == 0) { kayitlar.Remove(kayit); degisikSatirlar.Remove(kayit); return; }
        try
        {
            await KurumPuantajService.DeletePuantajAsync(kayit.Id);
            kayitlar.Remove(kayit);
            degisikSatirlar.Remove(kayit);
            ToastService.ShowSuccess("Kayıt silindi.");
        }
        catch (Exception ex) { ToastService.ShowError($"Silinemedi: {ex.Message}"); }
    }

    // ── Yardımcı ─────────────────────────────────────────────────────────────
    Dictionary<string, List<PuantajKayit>> GrupluKayitlar()
        => kayitlar
            .GroupBy(k => k.Guzergah?.GuzergahAdi ?? k.GuzergahAdi ?? "—")
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());

    int AydakiGunSayisi() => DateTime.DaysInMonth(seciliYil, seciliAy);

    static bool HaftaSonuMu(DateTime tarih)
        => tarih.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;

    static bool BugunMu(DateTime tarih)
        => tarih.Date == DateTime.Today;

    void SadeceHaftaIciAc()
    {
        foreach (var k in kayitlar)
        {
            for (int g = 1; g <= AydakiGunSayisi(); g++)
            {
                var tarih = new DateTime(seciliYil, seciliAy, g);
                k.SetGunDeger(g, HaftaSonuMu(tarih) ? 0 : 1);
            }
            degisikSatirlar.Add(k);
        }
    }

    void SadeceHaftaSonuAc()
    {
        foreach (var k in kayitlar)
        {
            for (int g = 1; g <= AydakiGunSayisi(); g++)
            {
                var tarih = new DateTime(seciliYil, seciliAy, g);
                k.SetGunDeger(g, HaftaSonuMu(tarih) ? 1 : 0);
            }
            degisikSatirlar.Add(k);
        }
    }

    static string SlotAd(SeferSlot slot) => slot switch
    {
        SeferSlot.Sabah => "Sabah",
        SeferSlot.Aksam => "Akşam",
        SeferSlot.Mesai => "Mesai",
        _ => slot >= SeferSlot.Diger1 ? $"Diğer{(int)slot - (int)SeferSlot.Diger1 + 1}" : slot.ToString()
    };

    static string SlotBadgeClass(SeferSlot slot) => slot switch
    {
        SeferSlot.Sabah => "bg-primary",
        SeferSlot.Aksam => "bg-warning text-dark",
        SeferSlot.Mesai => "bg-info text-dark",
        _ => "bg-secondary"
    };

    static string AyAdi(int ay) => ay switch
    {
        1=>"Ocak",2=>"Şubat",3=>"Mart",4=>"Nisan",5=>"Mayıs",6=>"Haziran",
        7=>"Temmuz",8=>"Ağustos",9=>"Eylül",10=>"Ekim",11=>"Kasım",12=>"Aralık",_=>"?"
    };

    // ── Sync Metodları ───────────────────────────────────────────────────

    async Task SenkronizeEt()
    {
        if (seciliKurumId == 0) return;
        yukleniyor = true;
        try
        {
            var rapor = await PuantajSyncService.SyncFromPuantajTopluAsync(
                seciliYil, seciliAy, null, PuantajSyncMode.CreateUpdate);
            await LoadData();
            ToastService.ShowSuccess($"Senkronizasyon tamamlandı. Batch={rapor.BatchId}");
        }
        catch (Exception ex) { ToastService.ShowError($"Senkronizasyon hatası: {ex.Message}"); }
        finally { yukleniyor = false; }
    }

    async Task DuplicateRaporuGoster()
    {
        if (seciliKurumId == 0) return;
        yukleniyor = true;
        try
        {
            var rapor = await DuplicateDetectionService.TespitRaporuAsync(seciliYil, seciliAy, seciliKurumId);
            if (!rapor.Any())
                ToastService.ShowSuccess("Duplicate kayıt bulunamadı.");
            else
            {
                foreach (var d in rapor)
                    ToastService.ShowWarning(
                        $"{d.GuzergahAdi} - {d.Plaka}: {d.Satirlar.Count} kayıt. {d.MergeOnerisi}");
            }
        }
        catch (Exception ex) { ToastService.ShowError($"Duplicate tespit hatası: {ex.Message}"); }
        finally { yukleniyor = false; }
    }

    async Task BackfillCalistir()
    {
        if (seciliKurumId == 0) return;
        var onay = await JS.InvokeAsync<bool>("confirm",
            $"{AyAdi(seciliAy)} {seciliYil} dönemi için eksik Operasyon kayıtları puantajdan oluşturulacak. Devam edilsin mi?");
        if (!onay) return;
        yukleniyor = true;
        try
        {
            var rapor = await PuantajSyncService.BackfillAsync(seciliYil, seciliAy, seciliKurumId);
            await LoadData();
            ToastService.ShowSuccess($"Backfill tamamlandı: {rapor.Ozet}");
        }
        catch (Exception ex) { ToastService.ShowError($"Backfill hatası: {ex.Message}"); }
        finally { yukleniyor = false; }
    }

    async Task PuantajdanYenidenOlustur()
    {
        if (seciliKurumId == 0) return;
        var onay = await JS.InvokeAsync<bool>("confirm",
            $"Bu işlem SADECE Puantaj kaynaklı Operasyon kayıtlarını yeniden oluşturacak. " +
            $"Manuel ve ExcelImport kayıtlar KORUNACAK. Kilitli kayıtlar atlanacak. Devam edilsin mi?");
        if (!onay) return;
        yukleniyor = true;
        try
        {
            var rapor = await PuantajSyncService.ForceSyncForDonemAsync(seciliKurumId, seciliYil, seciliAy);
            await LoadData();
            ToastService.ShowSuccess($"Yeniden oluşturma tamamlandı: {rapor.Ozet}");
        }
        catch (Exception ex) { ToastService.ShowError($"Force sync hatası: {ex.Message}"); }
        finally { yukleniyor = false; }
    }
}

