@page "/banka-hesaplari"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using ClosedXML.Excel
@inject IBankaHesapService BankaHesapService
@inject IBankaKasaHareketService BankaKasaHareketService
@inject IFirmaService FirmaService
@inject IAktifFirmaProvider AktifFirmaProvider
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Banka/Kasa Hesapları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-bank me-2"></i>Banka/Kasa Hesapları</h3>
        <button class="btn btn-primary" @onclick="YeniHesap">
            <i class="bi bi-plus-lg me-1"></i>Yeni Hesap
        </button>
    </div>

    @if (hesaplar == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var hesap in hesaplar)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center @(hesap.HesapTipi == HesapTipi.KrediKarti ? "bg-danger text-white" : "")">
                            <span>
                                <i class="bi @GetHesapIcon(hesap.HesapTipi) me-2"></i>
                                @hesap.HesapAdi
                            </span>
                            <span class="badge @(hesap.Aktif ? "bg-success" : "bg-secondary")">
                                @(hesap.Aktif ? "Aktif" : "Pasif")
                            </span>
                        </div>
                        <div class="card-body">
                            <p class="mb-1"><small class="text-muted">Hesap Kodu:</small> <strong>@(hesap.HesapKodu ?? "—")</strong></p>
                            <p class="mb-1"><small class="text-muted">Tip:</small> @GetTipText(hesap.HesapTipi)</p>
                            @if (!string.IsNullOrEmpty(hesap.BankaAdi))
                            {
                                <p class="mb-1"><small class="text-muted">Banka:</small> @hesap.BankaAdi</p>
                            }
                            @if (!string.IsNullOrEmpty(hesap.Iban))
                            {
                                <p class="mb-1"><small class="text-muted">IBAN:</small> @hesap.Iban</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(hesap.VarsayilanMuhasebeKodu))
                            {
                                <p class="mb-1"><small class="text-muted">Muhasebe Kodu:</small> <code>@hesap.VarsayilanMuhasebeKodu</code></p>
                            }
                            @if (!string.IsNullOrWhiteSpace(hesap.VarsayilanKostMerkezi))
                            {
                                <p class="mb-1"><small class="text-muted">Kost Merkezi:</small> <code>@hesap.VarsayilanKostMerkezi</code></p>
                            }
                            <hr />
                            <div class="text-center">
                                <span class="text-muted">@(hesap.HesapTipi == HesapTipi.KrediKarti ? "Kullanılan Limit" : "Güncel Bakiye")</span>
                                <h4 class="mb-0 @(bakiyeler.GetValueOrDefault(hesap.Id) >= 0 ? "text-success" : "text-danger")">
                                    @bakiyeler.GetValueOrDefault(hesap.Id).ToString("N2") ₺
                                </h4>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(hesap.Id)">
                                <i class="bi bi-pencil"></i> Düzenle
                            </button>
                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => Hareketler(hesap.Id)">
                                <i class="bi bi-list"></i> Hareketler
                            </button>
                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => EkstreAc(hesap)" title="Hesap Ekstresi">
                                <i class="bi bi-file-earmark-text"></i> Ekstre
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(hesap)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!hesaplar.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>Henüz banka/kasa hesabı bulunmamaktadır.
            </div>
        }
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekHesap?.HesapAdi</strong> hesabını silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@* Ekstre Modal *@
@if (showEkstreModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-text me-2"></i>
                        @ekstreHesap?.HesapAdi - Hesap Ekstresi
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="EkstreKapat"></button>
                </div>
                <div class="modal-body">
                    @* Tarih Seçimi *@
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Başlangıç Tarihi</label>
                            <input type="date" class="form-control" @bind="ekstreBaslangic" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bitiş Tarihi</label>
                            <input type="date" class="form-control" @bind="ekstreBitis" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary me-2" @onclick="EkstreGetir" disabled="@ekstreYukleniyor">
                                @if (ekstreYukleniyor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-search me-1"></i>Getir
                            </button>
                            <div class="btn-group">
                                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" disabled="@(ekstreHareketler == null || !ekstreHareketler.Any())">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><button class="dropdown-item" @onclick="EkstreYazdir"><i class="bi bi-printer me-2"></i>Yazdır</button></li>
                                    <li><button class="dropdown-item" @onclick="EkstreExcelAktar"><i class="bi bi-file-earmark-excel me-2"></i>Excel'e Aktar</button></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    @* Hızlı Tarih Seçenekleri *@
                    <div class="mb-3">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-secondary" @onclick="() => HizliTarihSec(0)">Bugün</button>
                            <button class="btn btn-outline-secondary" @onclick="() => HizliTarihSec(7)">Son 7 Gün</button>
                            <button class="btn btn-outline-secondary" @onclick="() => HizliTarihSec(30)">Son 30 Gün</button>
                            <button class="btn btn-outline-secondary" @onclick="() => HizliTarihSec(-1)">Bu Ay</button>
                            <button class="btn btn-outline-secondary" @onclick="() => HizliTarihSec(-2)">Geçen Ay</button>
                            <button class="btn btn-outline-secondary" @onclick="() => HizliTarihSec(-3)">Bu Yıl</button>
                        </div>
                    </div>

                    @if (ekstreYukleniyor)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Yükleniyor...</span>
                            </div>
                        </div>
                    }
                    else if (ekstreHareketler != null)
                    {
                        @* Özet Bilgiler *@
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <div class="card bg-light">
                                    <div class="card-body text-center py-2">
                                        <small class="text-muted">Açılış Bakiyesi</small>
                                        <h5 class="mb-0 @(ekstreAcilisBakiye >= 0 ? "text-success" : "text-danger")">
                                            @ekstreAcilisBakiye.ToString("N2") ₺
                                        </h5>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-success bg-opacity-10">
                                    <div class="card-body text-center py-2">
                                        <small class="text-muted">Toplam Giriş</small>
                                        <h5 class="mb-0 text-success">+@ekstreToplamGiris.ToString("N2") ₺</h5>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-danger bg-opacity-10">
                                    <div class="card-body text-center py-2">
                                        <small class="text-muted">Toplam Çıkış</small>
                                        <h5 class="mb-0 text-danger">-@ekstreToplamCikis.ToString("N2") ₺</h5>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-primary bg-opacity-10">
                                    <div class="card-body text-center py-2">
                                        <small class="text-muted">Kapanış Bakiyesi</small>
                                        <h5 class="mb-0 @(ekstreKapanisBakiye >= 0 ? "text-success" : "text-danger")">
                                            @ekstreKapanisBakiye.ToString("N2") ₺
                                        </h5>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Hareket Tablosu *@
                        <div class="table-responsive" id="ekstreTable">
                            <table class="table table-sm table-hover table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th style="width: 100px;">Tarih</th>
                                        <th style="width: 100px;">İşlem No</th>
                                        <th>Açıklama</th>
                                        <th style="width: 80px;">Belge No</th>
                                        <th class="text-end" style="width: 120px;">Giriş</th>
                                        <th class="text-end" style="width: 120px;">Çıkış</th>
                                        <th class="text-end" style="width: 120px;">Bakiye</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        decimal runningBalance = ekstreAcilisBakiye;
                                    }
                                    <tr class="table-secondary">
                                        <td>@ekstreBaslangic.ToString("dd.MM.yyyy")</td>
                                        <td>-</td>
                                        <td><em>Önceki Dönem Bakiyesi</em></td>
                                        <td>-</td>
                                        <td class="text-end text-success">@(ekstreAcilisBakiye > 0 ? ekstreAcilisBakiye.ToString("N2") : "")</td>
                                        <td class="text-end text-danger">@(ekstreAcilisBakiye < 0 ? Math.Abs(ekstreAcilisBakiye).ToString("N2") : "")</td>
                                        <td class="text-end fw-bold @(ekstreAcilisBakiye >= 0 ? "text-success" : "text-danger")">
                                            @ekstreAcilisBakiye.ToString("N2")
                                            <small class="ms-1">@(ekstreAcilisBakiye >= 0 ? "Alacak" : "Borç")</small>
                                        </td>
                                    </tr>
                                    @foreach (var hareket in ekstreHareketler.OrderBy(h => h.IslemTarihi).ThenBy(h => h.Id))
                                    {
                                        var giris = hareket.HareketTipi == HareketTipi.Giris ? hareket.Tutar : 0;
                                        var cikis = hareket.HareketTipi == HareketTipi.Cikis ? hareket.Tutar : 0;
                                        runningBalance += giris - cikis;
                                        <tr>
                                            <td>@hareket.IslemTarihi.ToString("dd.MM.yyyy")</td>
                                            <td><small>@hareket.IslemNo</small></td>
                                            <td>
                                                @hareket.Aciklama
                                                @if (hareket.Cari != null)
                                                {
                                                    <br /><small class="text-muted">@hareket.Cari.Unvan</small>
                                                }
                                            </td>
                                            <td><small>@hareket.BelgeNo</small></td>
                                            <td class="text-end text-success">@(giris > 0 ? giris.ToString("N2") : "")</td>
                                            <td class="text-end text-danger">@(cikis > 0 ? cikis.ToString("N2") : "")</td>
                                            <td class="text-end @(runningBalance >= 0 ? "text-success" : "text-danger") fw-bold">
                                                @runningBalance.ToString("N2")
                                            </td>
                                        </tr>
                                    }
                                    <tr class="table-secondary">
                                        <td>@ekstreBitis.ToString("dd.MM.yyyy")</td>
                                        <td>-</td>
                                        <td><em>Kapanış Bakiyesi</em></td>
                                        <td>-</td>
                                        <td class="text-end text-success fw-bold">@ekstreToplamGiris.ToString("N2")</td>
                                        <td class="text-end text-danger fw-bold">@ekstreToplamCikis.ToString("N2")</td>
                                        <td class="text-end fw-bold @(ekstreKapanisBakiye >= 0 ? "text-success" : "text-danger")">
                                            @ekstreKapanisBakiye.ToString("N2")
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        @if (!ekstreHareketler.Any())
                        {
                            <div class="alert alert-info text-center">
                                <i class="bi bi-info-circle me-2"></i>Seçilen tarih aralığında hareket bulunmamaktadır.
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <span class="text-muted me-auto">
                        <small>Toplam @(ekstreHareketler?.Count ?? 0) hareket</small>
                    </span>
                    <button type="button" class="btn btn-outline-primary me-2" @onclick="EkstreYazdir" disabled="@(ekstreHareketler == null || !ekstreHareketler.Any())">
                        <i class="bi bi-printer me-1"></i>Yazdır
                    </button>
                    <button type="button" class="btn btn-outline-success me-2" @onclick="EkstreExcelAktar" disabled="@(ekstreHareketler == null || !ekstreHareketler.Any())">
                        <i class="bi bi-file-earmark-excel me-1"></i>Excel
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="EkstreKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<BankaHesap>? hesaplar;
    private Dictionary<int, int> firmaAtamaSecim = new();
    private Dictionary<int, decimal> bakiyeler = new();
    private bool showDeleteModal = false;
    private BankaHesap? silinecekHesap;

    // Ekstre değişkenleri
    private bool showEkstreModal = false;
    private BankaHesap? ekstreHesap;
    private DateTime ekstreBaslangic = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime ekstreBitis = DateTime.Now.Date;
    private List<BankaKasaHareket>? ekstreHareketler;
    private bool ekstreYukleniyor = false;
    private decimal ekstreAcilisBakiye = 0;
    private decimal ekstreToplamGiris = 0;
    private decimal ekstreToplamCikis = 0;
    private decimal ekstreKapanisBakiye = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        hesaplar = await BankaHesapService.GetAllAsync();
        foreach (var hesap in hesaplar)
        {
            bakiyeler[hesap.Id] = await BankaHesapService.GetBakiyeAsync(hesap.Id);
        }
    }

    private void YeniHesap()
    {
        Navigation.NavigateTo("/banka-hesaplari/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/banka-hesaplari/{id}");
    }

    private void Hareketler(int id)
    {
        Navigation.NavigateTo($"/banka-hareketleri?hesapId={id}");
    }

    private void SilOnay(BankaHesap hesap)
    {
        silinecekHesap = hesap;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekHesap != null)
        {
            await BankaHesapService.DeleteAsync(silinecekHesap.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekHesap = null;
    }

    private string GetTipText(HesapTipi tip) => tip switch
    {
        HesapTipi.Kasa => "Kasa",
        HesapTipi.VadesizHesap => "Vadesiz Hesap",
        HesapTipi.VadeliHesap => "Vadeli Hesap",
        HesapTipi.KrediHesabi => "Kredi Hesabı",
        HesapTipi.KrediKarti => "Kredi Kartı",
        _ => tip.ToString()
    };

    private string GetHesapIcon(HesapTipi tip) => tip switch
    {
        HesapTipi.Kasa => "bi-cash-coin",
        HesapTipi.VadesizHesap => "bi-bank",
        HesapTipi.VadeliHesap => "bi-piggy-bank",
        HesapTipi.KrediHesabi => "bi-credit-card-2-front",
        HesapTipi.KrediKarti => "bi-credit-card",
        _ => "bi-wallet"
    };

    // ===== Ekstre İşlemleri =====

    private void EkstreAc(BankaHesap hesap)
    {
        ekstreHesap = hesap;
        ekstreBaslangic = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        ekstreBitis = DateTime.Now.Date;
        ekstreHareketler = null;
        showEkstreModal = true;
    }

    private void EkstreKapat()
    {
        showEkstreModal = false;
        ekstreHesap = null;
        ekstreHareketler = null;
    }

    private void HizliTarihSec(int tip)
    {
        var today = DateTime.Now.Date;
        switch (tip)
        {
            case 0: // Bugün
                ekstreBaslangic = today;
                ekstreBitis = today;
                break;
            case 7: // Son 7 gün
                ekstreBaslangic = today.AddDays(-7);
                ekstreBitis = today;
                break;
            case 30: // Son 30 gün
                ekstreBaslangic = today.AddDays(-30);
                ekstreBitis = today;
                break;
            case -1: // Bu ay
                ekstreBaslangic = new DateTime(today.Year, today.Month, 1);
                ekstreBitis = today;
                break;
            case -2: // Geçen ay
                var gecenAy = today.AddMonths(-1);
                ekstreBaslangic = new DateTime(gecenAy.Year, gecenAy.Month, 1);
                ekstreBitis = new DateTime(gecenAy.Year, gecenAy.Month, DateTime.DaysInMonth(gecenAy.Year, gecenAy.Month));
                break;
            case -3: // Bu yıl
                ekstreBaslangic = new DateTime(today.Year, 1, 1);
                ekstreBitis = today;
                break;
        }
    }

    private async Task EkstreGetir()
    {
        if (ekstreHesap == null) return;

        ekstreYukleniyor = true;
        StateHasChanged();

        try
        {
            // Tarih aralığındaki hareketleri getir
            var tumHareketler = await BankaKasaHareketService.GetByHesapIdAsync(ekstreHesap.Id);

            // Açılış bakiyesini hesapla (başlangıç tarihinden önceki tüm hareketlerin toplamı)
            var oncekiHareketler = tumHareketler
                .Where(h => h.IslemTarihi.Date < ekstreBaslangic.Date)
                .ToList();

            ekstreAcilisBakiye = ekstreHesap.AcilisBakiye + oncekiHareketler
                .Sum(h => h.HareketTipi == HareketTipi.Giris ? h.Tutar : -h.Tutar);

            // Seçilen tarih aralığındaki hareketler
            ekstreHareketler = tumHareketler
                .Where(h => h.IslemTarihi.Date >= ekstreBaslangic.Date && h.IslemTarihi.Date <= ekstreBitis.Date)
                .OrderBy(h => h.IslemTarihi)
                .ThenBy(h => h.Id)
                .ToList();

            // Toplam giriş/çıkış
            ekstreToplamGiris = ekstreHareketler.Where(h => h.HareketTipi == HareketTipi.Giris).Sum(h => h.Tutar);
            ekstreToplamCikis = ekstreHareketler.Where(h => h.HareketTipi == HareketTipi.Cikis).Sum(h => h.Tutar);

            // Kapanış bakiyesi
            ekstreKapanisBakiye = ekstreAcilisBakiye + ekstreToplamGiris - ekstreToplamCikis;
        }
        finally
        {
            ekstreYukleniyor = false;
            StateHasChanged();
        }
    }

    private async Task EkstreYazdir()
    {
        if (ekstreHareketler == null || ekstreHesap == null) return;

        var printContent = GeneratePrintHtml();
        await JS.InvokeVoidAsync("printContent", printContent);
    }

    private string GeneratePrintHtml()
    {
        var html = $@"
<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8'>
    <title>Hesap Ekstresi - {ekstreHesap?.HesapAdi}</title>
    <style>
        body {{ font-family: Arial, sans-serif; font-size: 12px; margin: 20px; }}
        h2 {{ text-align: center; margin-bottom: 5px; }}
        .subtitle {{ text-align: center; color: #666; margin-bottom: 20px; }}
        .summary {{ display: flex; justify-content: space-between; margin-bottom: 20px; padding: 10px; background: #f5f5f5; }}
        .summary-item {{ text-align: center; }}
        .summary-item label {{ display: block; font-size: 10px; color: #666; }}
        .summary-item span {{ font-weight: bold; font-size: 14px; }}
        table {{ width: 100%; border-collapse: collapse; }}
        th, td {{ border: 1px solid #ddd; padding: 6px; text-align: left; }}
        th {{ background: #333; color: white; }}
        .text-end {{ text-align: right; }}
        .text-success {{ color: green; }}
        .text-danger {{ color: red; }}
        .fw-bold {{ font-weight: bold; }}
        .acilis-kaparis {{ background: #e9ecef; }}
        .footer {{ margin-top: 20px; text-align: center; font-size: 10px; color: #666; }}
        @media print {{ body {{ margin: 0; }} }}
    </style>
</head>
<body>
    <h2>{ekstreHesap?.HesapAdi} - Hesap Ekstresi</h2>
    <p class='subtitle'>{ekstreBaslangic:dd.MM.yyyy} - {ekstreBitis:dd.MM.yyyy}</p>

    <div class='summary'>
        <div class='summary-item'><label>Açılış Bakiyesi</label><span>{ekstreAcilisBakiye:N2} ₺</span></div>
        <div class='summary-item'><label>Toplam Giriş</label><span class='text-success'>+{ekstreToplamGiris:N2} ₺</span></div>
        <div class='summary-item'><label>Toplam Çıkış</label><span class='text-danger'>-{ekstreToplamCikis:N2} ₺</span></div>
        <div class='summary-item'><label>Kapanış Bakiyesi</label><span>{ekstreKapanisBakiye:N2} ₺</span></div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Tarih</th>
                <th>İşlem No</th>
                <th>Açıklama</th>
                <th>Belge No</th>
                <th class='text-end'>Giriş</th>
                <th class='text-end'>Çıkış</th>
                <th class='text-end'>Bakiye</th>
            </tr>
        </thead>
        <tbody>
            <tr class='acilis-kaparis'>
                <td>{ekstreBaslangic:dd.MM.yyyy}</td>
                <td>-</td>
                <td><em>Açılış Bakiyesi</em></td>
                <td>-</td>
                <td></td>
                <td></td>
                <td class='text-end fw-bold'>{ekstreAcilisBakiye:N2}</td>
            </tr>";

        decimal runningBalance = ekstreAcilisBakiye;
        foreach (var hareket in ekstreHareketler!.OrderBy(h => h.IslemTarihi).ThenBy(h => h.Id))
        {
            var giris = hareket.HareketTipi == HareketTipi.Giris ? hareket.Tutar : 0;
            var cikis = hareket.HareketTipi == HareketTipi.Cikis ? hareket.Tutar : 0;
            runningBalance += giris - cikis;

            html += $@"
            <tr>
                <td>{hareket.IslemTarihi:dd.MM.yyyy}</td>
                <td>{hareket.IslemNo}</td>
                <td>{hareket.Aciklama}{(hareket.Cari != null ? $"<br/><small>{hareket.Cari.Unvan}</small>" : "")}</td>
                <td>{hareket.BelgeNo}</td>
                <td class='text-end text-success'>{(giris > 0 ? giris.ToString("N2") : "")}</td>
                <td class='text-end text-danger'>{(cikis > 0 ? cikis.ToString("N2") : "")}</td>
                <td class='text-end fw-bold'>{runningBalance:N2}</td>
            </tr>";
        }

        html += $@"
            <tr class='acilis-kaparis'>
                <td>{ekstreBitis:dd.MM.yyyy}</td>
                <td>-</td>
                <td><em>Kapanış Bakiyesi</em></td>
                <td>-</td>
                <td class='text-end text-success fw-bold'>{ekstreToplamGiris:N2}</td>
                <td class='text-end text-danger fw-bold'>{ekstreToplamCikis:N2}</td>
                <td class='text-end fw-bold'>{ekstreKapanisBakiye:N2}</td>
            </tr>
        </tbody>
    </table>
    <p class='footer'>Oluşturulma: {DateTime.Now:dd.MM.yyyy HH:mm} | Toplam {ekstreHareketler?.Count ?? 0} hareket</p>
</body>
</html>";

        return html;
    }

    private async Task EkstreExcelAktar()
    {
        if (ekstreHareketler == null || ekstreHesap == null) return;

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Hesap Ekstresi");

        // Başlık
        worksheet.Cell(1, 1).Value = $"{ekstreHesap.HesapAdi} - Hesap Ekstresi";
        worksheet.Range(1, 1, 1, 7).Merge();
        worksheet.Cell(1, 1).Style.Font.Bold = true;
        worksheet.Cell(1, 1).Style.Font.FontSize = 14;
        worksheet.Cell(1, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

        worksheet.Cell(2, 1).Value = $"{ekstreBaslangic:dd.MM.yyyy} - {ekstreBitis:dd.MM.yyyy}";
        worksheet.Range(2, 1, 2, 7).Merge();
        worksheet.Cell(2, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

        // Özet
        worksheet.Cell(4, 1).Value = "Açılış Bakiyesi:";
        worksheet.Cell(4, 2).Value = ekstreAcilisBakiye;
        worksheet.Cell(4, 3).Value = "Toplam Giriş:";
        worksheet.Cell(4, 4).Value = ekstreToplamGiris;
        worksheet.Cell(4, 5).Value = "Toplam Çıkış:";
        worksheet.Cell(4, 6).Value = ekstreToplamCikis;

        worksheet.Cell(5, 1).Value = "Kapanış Bakiyesi:";
        worksheet.Cell(5, 2).Value = ekstreKapanisBakiye;

        // Tablo başlıkları
        var headerRow = 7;
        worksheet.Cell(headerRow, 1).Value = "Tarih";
        worksheet.Cell(headerRow, 2).Value = "İşlem No";
        worksheet.Cell(headerRow, 3).Value = "Açıklama";
        worksheet.Cell(headerRow, 4).Value = "Belge No";
        worksheet.Cell(headerRow, 5).Value = "Giriş";
        worksheet.Cell(headerRow, 6).Value = "Çıkış";
        worksheet.Cell(headerRow, 7).Value = "Bakiye";

        var headerRange = worksheet.Range(headerRow, 1, headerRow, 7);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.DarkGray;
        headerRange.Style.Font.FontColor = XLColor.White;

        // Açılış satırı
        var row = headerRow + 1;
        worksheet.Cell(row, 1).Value = ekstreBaslangic;
        worksheet.Cell(row, 2).Value = "-";
        worksheet.Cell(row, 3).Value = "Açılış Bakiyesi";
        worksheet.Cell(row, 7).Value = ekstreAcilisBakiye;
        worksheet.Range(row, 1, row, 7).Style.Fill.BackgroundColor = XLColor.LightGray;

        // Hareketler
        decimal runningBalance = ekstreAcilisBakiye;
        foreach (var hareket in ekstreHareketler.OrderBy(h => h.IslemTarihi).ThenBy(h => h.Id))
        {
            row++;
            var giris = hareket.HareketTipi == HareketTipi.Giris ? hareket.Tutar : 0;
            var cikis = hareket.HareketTipi == HareketTipi.Cikis ? hareket.Tutar : 0;
            runningBalance += giris - cikis;

            worksheet.Cell(row, 1).Value = hareket.IslemTarihi;
            worksheet.Cell(row, 2).Value = hareket.IslemNo;
            worksheet.Cell(row, 3).Value = hareket.Aciklama + (hareket.Cari != null ? $" ({hareket.Cari.Unvan})" : "");
            worksheet.Cell(row, 4).Value = hareket.BelgeNo ?? "";
            if (giris > 0) worksheet.Cell(row, 5).Value = giris;
            if (cikis > 0) worksheet.Cell(row, 6).Value = cikis;
            worksheet.Cell(row, 7).Value = runningBalance;
        }

        // Kapanış satırı
        row++;
        worksheet.Cell(row, 1).Value = ekstreBitis;
        worksheet.Cell(row, 2).Value = "-";
        worksheet.Cell(row, 3).Value = "Kapanış Bakiyesi";
        worksheet.Cell(row, 5).Value = ekstreToplamGiris;
        worksheet.Cell(row, 6).Value = ekstreToplamCikis;
        worksheet.Cell(row, 7).Value = ekstreKapanisBakiye;
        worksheet.Range(row, 1, row, 7).Style.Fill.BackgroundColor = XLColor.LightGray;
        worksheet.Range(row, 1, row, 7).Style.Font.Bold = true;

        // Format
        worksheet.Column(1).Width = 12;
        worksheet.Column(2).Width = 12;
        worksheet.Column(3).Width = 40;
        worksheet.Column(4).Width = 12;
        worksheet.Column(5).Width = 15;
        worksheet.Column(6).Width = 15;
        worksheet.Column(7).Width = 15;

        worksheet.Column(5).Style.NumberFormat.Format = "#,##0.00";
        worksheet.Column(6).Style.NumberFormat.Format = "#,##0.00";
        worksheet.Column(7).Style.NumberFormat.Format = "#,##0.00";

        // Excel'i indir
        using var stream = new MemoryStream();
        workbook.SaveAs(stream);
        var fileName = $"HesapEkstresi_{ekstreHesap.HesapKodu ?? "KODSUZ"}_{ekstreBaslangic:yyyyMMdd}_{ekstreBitis:yyyyMMdd}.xlsx";
        var content = stream.ToArray();
        await JS.InvokeVoidAsync("downloadFileFromStream", fileName, Convert.ToBase64String(content));
    }
}
