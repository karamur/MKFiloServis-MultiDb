@page "/araclar"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IAracService AracService
@inject IAktifFirmaProvider AktifFirmaProvider
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Araçlar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-truck me-2"></i>Araçlar</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniArac">
                <i class="bi bi-plus-lg me-1"></i>Yeni Araç
            </button>
            @if (firmasizAracSayisi > 0)
            {
                <button class="btn btn-warning" @onclick="FirmasizlariAktifFirmayaAta" title="FirmaId'si boş araçları aktif firmaya atar">
                    <i class="bi bi-building-fill-exclamation me-1"></i>Firmasız (@firmasizAracSayisi) → Aktif Firma
                </button>
            }
            <button class="btn btn-outline-info" @onclick="SablonIndir" title="Excel Sablon Indir">
                <i class="bi bi-download me-1"></i>Şablon
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelImportModalAc" title="Excel'den Aktar">
                <i class="bi bi-upload me-1"></i>Excel Aktar
            </button>
        </div>
    </div>

    <!-- Filtreleme Alanı -->
    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="Tumu">Tümü</option>
                        <option value="Bosta">Boşta</option>
                        <option value="Operasyon">Operasyon</option>
                        <option value="Yonetim">Yönetim</option>
                        <option value="Satis">Satış</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Bağlı Firma</label>
                    <select class="form-select form-select-sm" @bind="filtreFirmaId">
                        <option value="0">Tümü</option>
                        <option value="-1">(Firmasız)</option>
                        @foreach (var f in firmaListesi)
                        {
                            <option value="@f.Id">@f.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Şase No</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreSase" placeholder="Şase no ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Plaka</label>
                    <input type="text"
                           class="form-control form-control-sm"
                           @bind-value="filtrePlaka"
                           @bind-value:event="oninput"
                           @bind-value:after="PlakaFiltreDegisti"
                           list="plakaOnerileri"
                           title="Geçmiş plakalar dahil"
                           placeholder="Plaka ara..." />
                    <datalist id="plakaOnerileri">
                        @foreach (var plaka in GetPlakaOnerileri())
                        {
                            <option value="@plaka"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Marka</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreMarka" placeholder="Marka ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Model Yılı</label>
                    <input type="number" class="form-control form-control-sm" @bind="filtreModelYili" placeholder="Örn: 2020" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Koltuk Sayısı</label>
                    <input type="number" class="form-control form-control-sm" @bind="filtreKoltukSayisi" placeholder="Örn: 27" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Araç Tipi</label>
                    <select class="form-select form-select-sm" @bind="filtreSinif">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracTipi tip in Enum.GetValues(typeof(AracTipi)))
                        {
                            <option value="@tip.ToString()">@GetTipText(tip)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sahiplik</label>
                    <select class="form-select form-select-sm" @bind="filtreSahiplikTipi">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                        {
                            <option value="@sahiplik.ToString()">@GetSahiplikText(sahiplik)</option>
                        }
                    </select>
                    <div class="form-check form-check-sm mt-1">
                        <input class="form-check-input" type="checkbox" id="chkSahiplikHaric" @bind="filtreSahiplikHaric" disabled="@(filtreSahiplikTipi == "Tumu")" />
                        <label class="form-check-label small text-muted" for="chkSahiplikHaric">Hariç tut</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sınıf</label>
                    <select class="form-select form-select-sm" @bind="filtreSinifTipi">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracSinifi sinif in Enum.GetValues(typeof(AracSinifi)))
                        {
                            <option value="@sinif.ToString()">@GetSinifText(sinif)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Kayıt Yılı / Ayı</label>
                    <div class="input-group input-group-sm">
                        <input type="number" class="form-control" @bind="filtreYil" placeholder="Yıl" />
                        <input type="number" class="form-control" @bind="filtreAy" placeholder="Ay" min="1" max="12" />
                    </div>
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button class="btn btn-primary btn-sm w-100" @onclick="Filtrele">
                        <i class="bi bi-search"></i> Ara
                    </button>
                    <button class="btn btn-secondary btn-sm w-100" @onclick="FiltreyiTemizle">
                        <i class="bi bi-x-circle"></i> Temizle
                    </button>
                </div>
            </div>
            <div class="row g-2 align-items-end mt-1">
                <div class="col-md-2">
                    <label class="form-label small">Trafiğe Çıkış (Baş)</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreRuhsatTrafigeCikisBas" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Trafiğe Çıkış (Bit)</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreRuhsatTrafigeCikisBit" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Satış (Baş)</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreRuhsatSatisBas" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Satış (Bit)</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreRuhsatSatisBit" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Tescil (Baş)</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreRuhsatTescilBas" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Tescil (Bit)</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreRuhsatTescilBit" />
                </div>
            </div>
        </div>
    </div>


    @if (!isLoading)
    {
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body py-2">
                        <small class="text-muted">Filtre Sonucu Toplam</small>
                        <div class="fs-4 fw-bold text-primary">@filtrelenmisAraclar.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body py-2">
                        <small class="text-muted">Aktif Araç</small>
                        <div class="fs-4 fw-bold text-success">@filtrelenmisAraclar.Count(a => a.Aktif)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body py-2">
                        <small class="text-muted">Boşta Durumdaki</small>
                        <div class="fs-4 fw-bold text-info">@filtrelenmisAraclar.Count(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body py-2">
                        <small class="text-muted">Satış Durumu</small>
                        <div class="fs-4 fw-bold text-warning">@filtrelenmisAraclar.Count(a => a.Durumu == AracDurumu.Satis || a.SatisaAcik)</div>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!filtrelenmisAraclar.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Kriterlere uygun araç bulunamadı.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Şase No</th>
                                <th>Aktif Plaka</th>
                                <th>Bağlı Firma</th>
                                <th>Geçmiş Plakalar</th>
                                <th>Marka</th>
                                <th>Model</th>
                                <th>Araç Tipi</th>
                                <th>Sınıf</th>
                                <th>Sahiplik Tipi</th>
                                <th>Durum</th>
                                <th>Model Yılı</th>
                                <th>Koltuk</th>
                                <th>Ruhsat Tarihleri</th>
                                <th style="width: 120px;" class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var arac in filtrelenmisAraclar)
                            {
                                <tr>
                                    <td><small class="text-muted">@arac.SaseNo</small></td>
                                    <td>
                                        <span class="badge bg-primary fs-6">@(arac.AktifPlaka ?? "PLAKASIZ")</span>
                                    </td>
                                    <td>
                                        @if (arac.Firma != null)
                                        {
                                            <span class="badge bg-info text-dark" title="@arac.Firma.FirmaAdi">@arac.Firma.FirmaAdi</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" title="Firma atanmamış">Firmasız</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="() => PlakaGecmisiAc(arac)" title="Plaka Geçmişini Yönet">
                                            <small class="text-muted" style="font-size: 0.75rem;">
                                                @{
                                                    var gecmisPlakalar = arac.PlakaGecmisi.Where(p => p.Plaka != arac.AktifPlaka).Select(p => p.Plaka).Distinct().ToList();
                                                }
                                                @if (gecmisPlakalar.Any())
                                                {
                                                    @string.Join(", ", gecmisPlakalar)
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </small>
                                            <i class="bi bi-pencil-square ms-1 text-primary"></i>
                                        </button>
                                    </td>
                                    <td><strong>@arac.Marka</strong></td>
                                    <td><span class="text-muted">@arac.Model</span></td>
                                    <td>
                                        <span class="badge @GetTipBadgeClass(arac.AracTipi)">@GetTipText(arac.AracTipi)</span>
                                    </td>
                                    <td>
                                        <span class="badge @GetSinifBadgeClass(arac.AracSinifi)">@GetSinifText(arac.AracSinifi)</span>
                                    </td>
                                    <td>
                                        <span class="badge @GetSahiplikBadgeClass(arac.SahiplikTipi)">@GetSahiplikText(arac.SahiplikTipi)</span>
                                    </td>
                                    <td>
                                        @{
                                            var durum = arac.Durumu;
                                            var badgeClass = durum switch
                                            {
                                                (AracDurumu)0 => "bg-secondary",
                                                AracDurumu.Bosta => "bg-secondary",
                                                AracDurumu.Operasyon => "bg-primary",
                                                AracDurumu.Yonetim => "bg-info",
                                                AracDurumu.Satis => "bg-warning text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@GetAracDurumuText(arac.Durumu)</span>
                                        @if (!arac.Aktif)
                                        {
                                            <span class="badge bg-danger ms-1">Pasif</span>
                                        }
                                    </td>
                                    <td>@arac.ModelYili</td>
                                    <td>@arac.KoltukSayisi</td>
                                    <td>
                                        <div class="small">
                                            <div><span class="text-muted">Trafiğe Çıkış:</span> @(arac.RuhsatTrafigeCikisTarihi?.ToString("dd.MM.yyyy") ?? "-")</div>
                                            <div><span class="text-muted">Satış:</span> @(arac.RuhsatSatisTarihi?.ToString("dd.MM.yyyy") ?? "-")</div>
                                            <div><span class="text-muted">Tescil:</span> @(arac.RuhsatTescilTarihi?.ToString("dd.MM.yyyy") ?? "-")</div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-info" @onclick="() => EvraklarGit(arac.Id)" title="Evraklar">
                                                <i class="bi bi-folder2-open"></i>
                                            </button>
                                            <button class="btn btn-outline-primary" @onclick="() => Duzenle(arac.Id)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => SilOnay(arac)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    @if (!isLoading && filtrelenmisAraclar.Any())
    {
        <div class="card mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Detaylı Araç Raporu (Filtre Sonucu)</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Araç Tipi Dağılımı</th></tr></thead>
                            <tbody>
                                @foreach (AracTipi tip in Enum.GetValues(typeof(AracTipi)))
                                {
                                    var adet = filtrelenmisAraclar.Count(a => a.AracTipi == tip);
                                    if (adet > 0)
                                    {
                                        <tr><td>@GetTipText(tip)</td><td class="text-end fw-bold">@adet</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Sınıf Dağılımı</th></tr></thead>
                            <tbody>
                                @foreach (AracSinifi sinif in Enum.GetValues(typeof(AracSinifi)))
                                {
                                    var adet = filtrelenmisAraclar.Count(a => a.AracSinifi == sinif);
                                    if (adet > 0)
                                    {
                                        <tr><td>@GetSinifText(sinif)</td><td class="text-end fw-bold">@adet</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-4">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light"><tr><th colspan="2">Sahiplik Dağılımı</th></tr></thead>
                            <tbody>
                                @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                                {
                                    var adet = filtrelenmisAraclar.Count(a => a.SahiplikTipi == sahiplik);
                                    if (adet > 0)
                                    {
                                        <tr><td>@GetSahiplikText(sahiplik)</td><td class="text-end fw-bold">@adet</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@(silinecekArac?.AktifPlaka ?? silinecekArac?.SaseNo)</strong> plakalı aracı silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Excel Import Modal -->
@if (showImportModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Excel'den Araç Aktar</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ImportModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Excel dosyasında şu sütunlar olmalı: <strong>Şase No | Plaka | Marka | Model | Model Yılı | Motor No | Renk | Koltuk Sayısı | Araç Tipi | KM</strong>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Excel Dosyası Seç *</label>
                        <InputFile class="form-control" OnChange="DosyaSecildi" accept=".xlsx,.xls" />
                    </div>
                    
                    @if (importResult != null)
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-md-3 col-6">
                                <div class="card bg-success text-white text-center py-2">
                                    <h4 class="mb-0">@importResult.ImportedCount</h4>
                                    <small>Eklenen</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="card bg-warning text-dark text-center py-2">
                                    <h4 class="mb-0">@importResult.UpdatedCount</h4>
                                    <small>Güncellenen</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="card bg-secondary text-white text-center py-2">
                                    <h4 class="mb-0">@importResult.SkippedCount</h4>
                                    <small>Atlanan</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="card bg-danger text-white text-center py-2">
                                    <h4 class="mb-0">@importResult.ErrorCount</h4>
                                    <small>Hata</small>
                                </div>
                            </div>
                        </div>

                        @if (importResult.SkippedRecords.Any())
                        {
                            <div class="alert alert-warning py-2 mb-2" style="max-height: 200px; overflow-y: auto;">
                                <div class="fw-bold mb-1">Daha önce kayıtlı veya yinelenen plakalar</div>
                                @foreach (var skipped in importResult.SkippedRecords.Take(30))
                                {
                                    <div><small>@skipped</small></div>
                                }
                            </div>
                        }
                        
                        @if (importResult.Errors.Any())
                        {
                            <div class="alert alert-danger py-2" style="max-height: 200px; overflow-y: auto;">
                                @foreach (var error in importResult.Errors.Take(30))
                                {
                                    <div><small>@error</small></div>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-info" @onclick="SablonIndir">
                        <i class="bi bi-download me-1"></i>Şablon İndir
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ImportModalKapat">Kapat</button>
                    <button type="button" class="btn btn-success" @onclick="ExcelImportYap" disabled="@(isImporting || importFile == null)">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-upload me-1"></i>Aktarımı Başlat
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Plaka Geçmişi Modal -->
@if (showPlakaGecmisiModal && seciliArac != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-card-list me-2"></i>Plaka Geçmişi - @seciliArac.SaseNo
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="PlakaGecmisiKapat"></button>
                </div>
                <div class="modal-body">
                    <!-- Yeni Plaka Ekleme Formu -->
                    <div class="card mb-3 bg-light">
                        <div class="card-body">
                            <h6><i class="bi bi-plus-circle me-2"></i>Yeni Plaka Ekle</h6>
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <label class="form-label small">Plaka *</label>
                                    <input type="text" class="form-control form-control-sm" @bind="yeniPlaka.Plaka" 
                                           style="text-transform: uppercase;" placeholder="34 ABC 123" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small">Giriş Tarihi *</label>
                                    <input type="date" class="form-control form-control-sm" @bind="yeniPlakaGirisTarihi" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small">Çıkış Tarihi</label>
                                    <input type="date" class="form-control form-control-sm" @bind="yeniPlakaCikisTarihi" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small">İşlem Tipi</label>
                                    <select class="form-select form-select-sm" @bind="yeniPlaka.IslemTipi">
                                        @foreach (PlakaIslemTipi tip in Enum.GetValues(typeof(PlakaIslemTipi)))
                                        {
                                            <option value="@tip">@GetIslemTipiAdi(tip)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Açıklama</label>
                                    <input type="text" class="form-control form-control-sm" @bind="yeniPlaka.Aciklama" placeholder="Açıklama..." />
                                </div>
                            </div>
                            <div class="mt-2">
                                <button class="btn btn-success btn-sm" @onclick="YeniPlakaEkle" disabled="@(string.IsNullOrWhiteSpace(yeniPlaka.Plaka) || isPlakaKaydediliyor)">
                                    @if (isPlakaKaydediliyor)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-plus me-1"></i>Ekle
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Mevcut Plakalar Listesi -->
                    <h6><i class="bi bi-list-ul me-2"></i>Plaka Geçmişi</h6>
                    @if (plakaGecmisi == null || !plakaGecmisi.Any())
                    {
                        <div class="alert alert-info">Henüz plaka kaydı yok.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Plaka</th>
                                        <th>Giriş Tarihi</th>
                                        <th>Çıkış Tarihi</th>
                                        <th>İşlem Tipi</th>
                                        <th>Açıklama</th>
                                        <th>Durum</th>
                                        <th style="width: 80px;">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var plaka in plakaGecmisi.OrderByDescending(p => p.GirisTarihi))
                                    {
                                        <tr class="@(plaka.Aktif ? "table-success" : "")">
                                            <td>
                                                <strong>@plaka.Plaka</strong>
                                                @if (plaka.Plaka == seciliArac.AktifPlaka)
                                                {
                                                    <span class="badge bg-primary ms-1">Aktif</span>
                                                }
                                            </td>
                                            <td>@plaka.GirisTarihi.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @if (plaka.CikisTarihi.HasValue)
                                                {
                                                    @plaka.CikisTarihi.Value.ToString("dd.MM.yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-success">-</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@GetIslemTipiAdi(plaka.IslemTipi)</span>
                                            </td>
                                            <td><small>@plaka.Aciklama</small></td>
                                            <td>
                                                @if (plaka.Aktif)
                                                {
                                                    <span class="badge bg-success">Aktif</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Kapandı</span>
                                                }
                                            </td>
                                            <td>
                                                @if (plaka.Aktif && plaka.Plaka == seciliArac.AktifPlaka)
                                                {
                                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => PlakayiKapat(plaka)" title="Plakayı Kapat">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => PlakaSil(plaka)" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="PlakaGecmisiKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Arac> tumAraclar = new();
    private List<Arac> filtrelenmisAraclar = new();
    private bool showDeleteModal = false;
    private bool showImportModal = false;
    private Arac? silinecekArac;
    private bool isLoading = true;
    
    // Import
    private bool isImporting = false;
    private IBrowserFile? importFile = null;
    private AracImportResult? importResult = null;

    // Plaka Geçmişi
    private bool showPlakaGecmisiModal = false;
    private Arac? seciliArac;
    private List<AracPlaka>? plakaGecmisi;
    private AracPlaka yeniPlaka = new();
    private DateTime yeniPlakaGirisTarihi = DateTime.Today;
    private DateTime? yeniPlakaCikisTarihi;
    private bool isPlakaKaydediliyor = false;

    // Filtre Değişkenleri
    private string filtreDurum = "Tumu";
    private string? filtreSase;
    private string? filtrePlaka;
    private string? filtreMarka;
    private int? filtreModelYili;
    private int? filtreKoltukSayisi;
    private string filtreSinif = "Tumu";
    // 0 = Tümü, -1 = Firmasız, >0 = Belirli firma
    private int filtreFirmaId = 0;
    private List<KOAFiloServis.Shared.Entities.Firma> firmaListesi = new();
    // Varsayılan: Sahiplik = Tedarikçi, Hariç tut = işaretli
    // (Tedarikçi araçları araç listesinden gizlenmiş gelir; kullanıcı isterse filtreyi değiştirebilir.)
    private string filtreSahiplikTipi = nameof(AracSahiplikTipi.Tedarikci);
    private bool filtreSahiplikHaric = true;
    private string filtreSinifTipi = "Tumu";
    private int? filtreYil;
    private int? filtreAy;
    private DateTime? filtreRuhsatTrafigeCikisBas;
    private DateTime? filtreRuhsatTrafigeCikisBit;
    private DateTime? filtreRuhsatSatisBas;
    private DateTime? filtreRuhsatSatisBit;
    private DateTime? filtreRuhsatTescilBas;
    private DateTime? filtreRuhsatTescilBit;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        tumAraclar = await AracService.GetAllAsync() ?? new List<Arac>();
        try
        {
            firmasizAracSayisi = await AracService.GetFirmaIdYokSayisiAsync();
        }
        catch
        {
            firmasizAracSayisi = 0;
        }
        try
        {
            firmaListesi = await FirmaService.GetAktifFirmalarAsync();
        }
        catch
        {
            firmaListesi = new();
        }
        Filtrele();
        isLoading = false;
    }

    private int firmasizAracSayisi = 0;

    private async Task FirmasizlariAktifFirmayaAta()
    {
        if (AktifFirmaProvider.TumFirmalar || !AktifFirmaProvider.AktifFirmaId.HasValue || AktifFirmaProvider.AktifFirmaId.Value <= 0)
        {
            ToastService.ShowWarning("Önce üst bardaki firma seçiciden bir firma seçin (Tüm Firmalar modunda toplu atama yapılamaz).");
            return;
        }

        var aktifFirma = FirmaService.GetAktifFirma();
        var firmaId = AktifFirmaProvider.AktifFirmaId.Value;
        var onay = await JS.InvokeAsync<bool>("confirm",
            $"{firmasizAracSayisi} adet firmasız araç, '{aktifFirma.FirmaAdi}' firmasına atanacak. Devam edilsin mi?");
        if (!onay) return;

        try
        {
            var sayi = await AracService.BackfillFirmaIdAsync(firmaId);
            ToastService.ShowSuccess($"{sayi} araç '{aktifFirma.FirmaAdi}' firmasına atandı.");
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu firma atama hatası: {ex.GetBaseException().Message}");
        }
    }

    private void Filtrele()
    {
        var sorgu = tumAraclar.AsQueryable();

        // Durum Filtresi
        if (filtreDurum == "Bosta")
        {
            sorgu = sorgu.Where(a => a.Durumu == AracDurumu.Bosta || (int)a.Durumu == 0);
        }
        else if (filtreDurum == "Operasyon")
        {
            sorgu = sorgu.Where(a => a.Durumu == AracDurumu.Operasyon);
        }
        else if (filtreDurum == "Yonetim")
        {
            sorgu = sorgu.Where(a => a.Durumu == AracDurumu.Yonetim);
        }
        else if (filtreDurum == "Satis")
        {
            sorgu = sorgu.Where(a => a.Durumu == AracDurumu.Satis);
        }

        // Bağlı Firma Filtresi
        if (filtreFirmaId == -1)
        {
            sorgu = sorgu.Where(a => a.FirmaId == null);
        }
        else if (filtreFirmaId > 0)
        {
            sorgu = sorgu.Where(a => a.FirmaId == filtreFirmaId);
        }

        // Şase No
        if (!string.IsNullOrWhiteSpace(filtreSase))
        {
            sorgu = sorgu.Where(a => a.SaseNo.Contains(filtreSase, StringComparison.OrdinalIgnoreCase));
        }

        // Plaka (Hem aktif plaka hem geçmiş plakalar)
        if (!string.IsNullOrWhiteSpace(filtrePlaka))
        {
            sorgu = sorgu.Where(a => 
                (a.AktifPlaka != null && a.AktifPlaka.Contains(filtrePlaka, StringComparison.OrdinalIgnoreCase)) ||
                a.PlakaGecmisi.Any(p => p.Plaka.Contains(filtrePlaka, StringComparison.OrdinalIgnoreCase))
            );
        }
        // Marka (tam/parsiyel)
        if (!string.IsNullOrWhiteSpace(filtreMarka))
        {
            sorgu = sorgu.Where(a => a.Marka != null && a.Marka.Contains(filtreMarka, StringComparison.OrdinalIgnoreCase));
        }

        // Model Yılı
        if (filtreModelYili.HasValue)
        {
            sorgu = sorgu.Where(a => a.ModelYili == filtreModelYili.Value);
        }

        // Koltuk Sayısı
        if (filtreKoltukSayisi.HasValue)
        {
            sorgu = sorgu.Where(a => a.KoltukSayisi == filtreKoltukSayisi.Value);
        }

        // Sınıf
        if (filtreSinif != "Tumu" && Enum.TryParse<AracTipi>(filtreSinif, out var sinifTipi))
        {
            sorgu = sorgu.Where(a => a.AracTipi == sinifTipi);
        }

        // Sınıf (AracSinifi)
        if (filtreSinifTipi != "Tumu" && Enum.TryParse<AracSinifi>(filtreSinifTipi, out var aracSinifi))
        {
            sorgu = sorgu.Where(a => a.AracSinifi == aracSinifi);
        }

        // Sahiplik Tipi (Hariç tut destekli)
        if (filtreSahiplikTipi != "Tumu" && Enum.TryParse<AracSahiplikTipi>(filtreSahiplikTipi, out var sahiplikTipi))
        {
            sorgu = filtreSahiplikHaric
                ? sorgu.Where(a => a.SahiplikTipi != sahiplikTipi)
                : sorgu.Where(a => a.SahiplikTipi == sahiplikTipi);
        }

        // Kayıt Yılı
        if (filtreYil.HasValue)
        {
            sorgu = sorgu.Where(a => a.CreatedAt.Year == filtreYil.Value);
        }

        // Kayıt Ayı
        if (filtreAy.HasValue)
        {
            sorgu = sorgu.Where(a => a.CreatedAt.Month == filtreAy.Value);
        }

        // Ruhsat Trafiğe Çıkış Tarihi (aralık)
        if (filtreRuhsatTrafigeCikisBas.HasValue)
        {
            var bas = filtreRuhsatTrafigeCikisBas.Value.Date;
            sorgu = sorgu.Where(a => a.RuhsatTrafigeCikisTarihi.HasValue && a.RuhsatTrafigeCikisTarihi.Value.Date >= bas);
        }
        if (filtreRuhsatTrafigeCikisBit.HasValue)
        {
            var bit = filtreRuhsatTrafigeCikisBit.Value.Date;
            sorgu = sorgu.Where(a => a.RuhsatTrafigeCikisTarihi.HasValue && a.RuhsatTrafigeCikisTarihi.Value.Date <= bit);
        }

        // Ruhsat Satış Tarihi (aralık)
        if (filtreRuhsatSatisBas.HasValue)
        {
            var bas = filtreRuhsatSatisBas.Value.Date;
            sorgu = sorgu.Where(a => a.RuhsatSatisTarihi.HasValue && a.RuhsatSatisTarihi.Value.Date >= bas);
        }
        if (filtreRuhsatSatisBit.HasValue)
        {
            var bit = filtreRuhsatSatisBit.Value.Date;
            sorgu = sorgu.Where(a => a.RuhsatSatisTarihi.HasValue && a.RuhsatSatisTarihi.Value.Date <= bit);
        }

        // Ruhsat Tescil Tarihi (aralık)
        if (filtreRuhsatTescilBas.HasValue)
        {
            var bas = filtreRuhsatTescilBas.Value.Date;
            sorgu = sorgu.Where(a => a.RuhsatTescilTarihi.HasValue && a.RuhsatTescilTarihi.Value.Date >= bas);
        }
        if (filtreRuhsatTescilBit.HasValue)
        {
            var bit = filtreRuhsatTescilBit.Value.Date;
            sorgu = sorgu.Where(a => a.RuhsatTescilTarihi.HasValue && a.RuhsatTescilTarihi.Value.Date <= bit);
        }

        filtrelenmisAraclar = sorgu.ToList();
    }

    private void FiltreyiTemizle()
    {
        filtreDurum = "Tumu";
        filtreFirmaId = 0;
        filtreSase = null;
        filtrePlaka = null;
        filtreMarka = null;
        filtreModelYili = null;
        filtreKoltukSayisi = null;
        filtreSinif = "Tumu";
        filtreSahiplikTipi = nameof(AracSahiplikTipi.Tedarikci);
        filtreSahiplikHaric = true;
        filtreSinifTipi = "Tumu";
        filtreYil = null;
        filtreAy = null;
        filtreRuhsatTrafigeCikisBas = null;
        filtreRuhsatTrafigeCikisBit = null;
        filtreRuhsatSatisBas = null;
        filtreRuhsatSatisBit = null;
        filtreRuhsatTescilBas = null;
        filtreRuhsatTescilBit = null;
        Filtrele();
    }

    private void PlakaFiltreDegisti()
    {
        Filtrele();
    }

    private IEnumerable<string> GetPlakaOnerileri()
    {
        var tumPlakalar = tumAraclar
            .SelectMany(a =>
                new[] { a.AktifPlaka }
                .Concat(a.PlakaGecmisi.Select(p => p.Plaka)))
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Select(p => p!.Trim().ToUpperInvariant())
            .Distinct()
            .OrderBy(p => p)
            .AsEnumerable();

        if (string.IsNullOrWhiteSpace(filtrePlaka))
        {
            return tumPlakalar.Take(20);
        }

        return tumPlakalar
            .Where(p => p.Contains(filtrePlaka.Trim(), StringComparison.OrdinalIgnoreCase))
            .Take(20);
    }

    private void YeniArac()
    {
        Navigation.NavigateTo("/araclar/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/araclar/{id}");
    }

    private void SilOnay(Arac arac)
    {
        silinecekArac = arac;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekArac != null)
        {
            await AracService.DeleteAsync(silinecekArac.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekArac = null;
    }

    private string GetTipText(AracTipi tip) => tip switch
    {
        AracTipi.Minibus => "Minibüs",
        AracTipi.Midibus => "Midibüs",
        AracTipi.Otobus => "Otobüs",
        AracTipi.Otomobil => "Otomobil",
        AracTipi.Panelvan => "Panelvan",
        _ => tip.ToString()
    };

    private string GetSinifText(AracSinifi sinif) => sinif switch
    {
        AracSinifi.PersonelTasiti => "Personel Taşıtı",
        AracSinifi.OkulTasiti => "Okul Taşıtı",
        AracSinifi.Hususi => "Hususi",
        _ => sinif.ToString()
    };

    private string GetTipBadgeClass(AracTipi tip) => tip switch
    {
        AracTipi.Minibus => "bg-primary",
        AracTipi.Midibus => "bg-info text-dark",
        AracTipi.Otobus => "bg-success",
        AracTipi.Otomobil => "bg-warning text-dark",
        AracTipi.Panelvan => "bg-secondary",
        _ => "bg-dark"
    };

    private string GetSinifBadgeClass(AracSinifi sinif) => sinif switch
    {
        AracSinifi.PersonelTasiti => "bg-primary",
        AracSinifi.OkulTasiti => "bg-warning text-dark",
        AracSinifi.Hususi => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private string GetSahiplikBadgeClass(AracSahiplikTipi tip) => SahiplikHelper.GetBadgeClass(tip);

    private string GetSahiplikText(AracSahiplikTipi tip) => SahiplikHelper.GetMetin(tip);

    private string GetAracDurumuText(AracDurumu durum) => durum switch
    {
        (AracDurumu)0 => "Boşta",
        AracDurumu.Bosta => "Boşta",
        AracDurumu.Operasyon => "Operasyon",
        AracDurumu.Yonetim => "Yönetim",
        AracDurumu.Satis => "Satış",
        _ => "Boşta"
    };

    private void EvraklarGit(int aracId)
    {
        Navigation.NavigateTo($"/araclar/{aracId}/evraklar");
    }

    #region Excel Import

    private void ExcelImportModalAc()
    {
        importFile = null;
        importResult = null;
        showImportModal = true;
    }

    private void ImportModalKapat()
    {
        showImportModal = false;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        importFile = e.File;
        importResult = null;
    }

    private async Task SablonIndir()
    {
        try
        {
            var bytes = await AracService.GetExcelSablonAsync();
            await JS.InvokeVoidAsync("downloadFileFromBase64", "arac_sablon.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Şablon indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task ExcelImportYap()
    {
        if (importFile == null) return;
        
        isImporting = true;
        importResult = null;
        StateHasChanged();
        
        try
        {
            using var stream = new MemoryStream();
            await importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
            var fileContent = stream.ToArray();
            
            importResult = await AracService.ImportFromExcelAsync(fileContent);
            
            if (importResult.Success)
            {
                ToastService.ShowSuccess($"{importResult.ImportedCount} araç eklendi, {importResult.UpdatedCount} güncellendi.");
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            importResult = new AracImportResult
            {
                Success = false,
                Errors = new List<string> { $"Import hatası: {ex.Message}" }
            };
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    #endregion

    #region Plaka Geçmişi

    private void PlakaGecmisiAc(Arac arac)
    {
        seciliArac = arac;
        plakaGecmisi = new List<AracPlaka>(arac.PlakaGecmisi);
        showPlakaGecmisiModal = true;
    }

    private void PlakaGecmisiKapat()
    {
        showPlakaGecmisiModal = false;
        seciliArac = null;
        plakaGecmisi = null;
    }

    private async Task YeniPlakaEkle()
    {
        if (seciliArac == null || string.IsNullOrWhiteSpace(yeniPlaka.Plaka)) return;

        isPlakaKaydediliyor = true;
        StateHasChanged();

        try
        {
            yeniPlaka.AracId = seciliArac.Id;
            yeniPlaka.GirisTarihi = yeniPlakaGirisTarihi;
            yeniPlaka.CikisTarihi = yeniPlakaCikisTarihi;
            yeniPlaka.Plaka = yeniPlaka.Plaka.Trim().ToUpperInvariant();
            
            var result = await AracService.AddPlakaToAracAsync(yeniPlaka);
            if (result)
            {
                ToastService.ShowSuccess("Yeni plaka eklendi.");
                await LoadData();
                seciliArac = tumAraclar.FirstOrDefault(a => a.Id == seciliArac.Id);
                plakaGecmisi = seciliArac != null ? new List<AracPlaka>(seciliArac.PlakaGecmisi) : null;
                yeniPlaka = new AracPlaka();
                yeniPlakaGirisTarihi = DateTime.Today;
                yeniPlakaCikisTarihi = null;
            }
            else
            {
                ToastService.ShowError("Plaka eklenirken hata oluştu.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isPlakaKaydediliyor = false;
            StateHasChanged();
        }
    }

    private async Task PlakaSil(AracPlaka plaka)
    {
        if (seciliArac == null) return;

        var result = await AracService.DeletePlakaFromAracAsync(plaka.Id);
        if (result)
        {
            ToastService.ShowSuccess("Plaka silindi.");
            await LoadData();
            seciliArac = tumAraclar.FirstOrDefault(a => a.Id == seciliArac.Id);
            plakaGecmisi = seciliArac != null ? new List<AracPlaka>(seciliArac.PlakaGecmisi) : null;
        }
        else
        {
            ToastService.ShowError("Plaka silinirken hata oluştu.");
        }
    }

    private async Task PlakayiKapat(AracPlaka plaka)
    {
        if (seciliArac == null) return;

        try
        {
            plaka.CikisTarihi = DateTime.Today;
            await AracService.ClosePlakaAsync(plaka.Id, DateTime.Today);
            ToastService.ShowSuccess("Plaka kapatıldı.");
            await LoadData();
            // Modal'ı güncelle
            seciliArac = tumAraclar.FirstOrDefault(a => a.Id == seciliArac.Id);
            plakaGecmisi = seciliArac != null ? new List<AracPlaka>(seciliArac.PlakaGecmisi) : null;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private string GetIslemTipiAdi(PlakaIslemTipi islemTipi) => islemTipi switch
    {
        PlakaIslemTipi.Alis => "Alış",
        PlakaIslemTipi.Satis => "Satış",
        PlakaIslemTipi.PlakaDevir => "Plaka Devir",
        PlakaIslemTipi.Servis => "Servis",
        PlakaIslemTipi.Kiralama => "Kiralama",
        PlakaIslemTipi.KiralamaBitis => "Kiralama Bitiş",
        PlakaIslemTipi.TramerKaydi => "Tramer Kaydı",
        PlakaIslemTipi.Diger => "Diğer",
        _ => islemTipi.ToString()
    };

    #endregion
}
