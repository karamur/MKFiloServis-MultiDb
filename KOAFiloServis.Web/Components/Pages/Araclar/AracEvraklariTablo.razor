    private static string TarihYazi(DateTime? t)
    {
        if (!t.HasValue) return "<span class='badge bg-secondary'>Yok</span>";
        var gun = (t.Value - DateTime.Today).Days;
        var cls = AracBelgeTabloKalemi.BelgeDurumClass(t);
        return $"<span class='badge {cls}'>{t.Value:dd.MM.yyyy} ({(gun < 0 ? $"{Math.Abs(gun)}g geçti" : $"{gun}g")})</span>";
    }

    /// <summary>
    /// Belge alanı (Ruhsat, Sigorta, vb.) için item.EvrakDosyalari içinden
    /// kategori adına göre eşleşen ilk dosya bilgisini döndürür.
    /// </summary>
    private static AracEvrakDosyaBilgisi? AlanDosyaBul(AracBelgeTabloKalemi item, string alan)
    {
        if (item.EvrakDosyalari == null || item.EvrakDosyalari.Count == 0) return null;
        var keys = alan switch
        {
            "Ruhsat" => new[] { "Ruhsat" },
            "Sigorta" => new[] { "Trafik Sigorta", "Trafik Sigortası", "Sigorta Poliçesi" },
            "Muayene" => new[] { "Muayene" },
            "Uygunluk" => new[] { "Uygunluk" },
            "KoltukSigortasi" => new[] { "Koltuk Sigorta", "Koltuk Sigortası" },
            "Kasko" => new[] { "Kasko" },
            _ => Array.Empty<string>()
        };
        return item.EvrakDosyalari.FirstOrDefault(d =>
            keys.Any(k =>
                (d.EvrakKategorisi ?? string.Empty).Contains(k, StringComparison.OrdinalIgnoreCase)
                || (d.EvrakAdi ?? string.Empty).Contains(k, StringComparison.OrdinalIgnoreCase)));
    }
