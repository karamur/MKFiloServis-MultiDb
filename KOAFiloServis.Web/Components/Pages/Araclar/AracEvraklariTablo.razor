    // ── Yardımcılar ──────────────────────────────────────────────────
    private static IEnumerable<DateTime> GetTumTarihler(AracBelgeTabloKalemi p)
    {
        DateTime?[] list = [p.RuhsatGecerlilik, p.SigortaGecerlilik, p.MuayeneGecerlilik,
            p.UygunlukGecerlilik, p.KoltukSigortasiGecerlilik, p.KaskoGecerlilik];
        return list.Where(d => d.HasValue).Select(d => d!.Value);
    }

    private static int GetEksikSayisi(AracBelgeTabloKalemi p)
    {
        DateTime?[] list = [p.RuhsatGecerlilik, p.SigortaGecerlilik, p.MuayeneGecerlilik,
            p.UygunlukGecerlilik, p.KoltukSigortasiGecerlilik, p.KaskoGecerlilik];
        return list.Count(d => !d.HasValue);
    }

    private static string GetBelgeAdi(string alan) => alan switch
    {
        "Ruhsat" => "Ruhsat",
        "Sigorta" => "Trafik Sigortası",
        "Muayene" => "Muayene",
        "Uygunluk" => "Uygunluk Belgesi",
        "KoltukSigortasi" => "Koltuk Sigortası",
        "Kasko" => "Kasko",
        _ => alan
    };

    private static string GercekUzantiAl(string? dosyaYolu)
    {
        if (string.IsNullOrWhiteSpace(dosyaYolu)) return string.Empty;
        var ad = Path.GetFileName(dosyaYolu);
        if (ad.EndsWith(".enc", StringComparison.OrdinalIgnoreCase))
            ad = ad.Substring(0, ad.Length - 4);
        return Path.GetExtension(ad).ToLowerInvariant();
    }

    private static string MimeTipiAl(string uzanti) => uzanti.ToLowerInvariant() switch
    {
        ".pdf" => "application/pdf",
        ".jpg" or ".jpeg" => "image/jpeg",
        ".png" => "image/png",
        ".gif" => "image/gif",
        ".bmp" => "image/bmp",
        ".webp" => "image/webp",
        ".doc" => "application/msword",
        ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        _ => "application/octet-stream"
    };

