@page "/araclar/{AracId:int}/evraklar"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IAracService AracService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject IAktiviteLogService AktiviteLog
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Arac Evraklari</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary" @onclick="GeriDon">
                <i class="bi bi-arrow-left"></i>
            </button>
            <h3 class="mb-0">
                <i class="bi bi-folder2-open me-2"></i>
                @if (arac != null)
                {
                    <span>@arac.AktifPlaka - Evrak Yonetimi</span>
                }
            </h3>
        </div>
        <button class="btn btn-primary" @onclick="@(() => YeniEvrakAc(null))">
            <i class="bi bi-plus-lg me-1"></i>Yeni Evrak
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Kategorilere Gore Evraklar -->
        <div class="row g-3">
            @foreach (var kategori in EvrakKategorileri.TumKategoriler)
            {
                var kategoriEvraklari = evraklar.Where(e => e.EvrakKategorisi == kategori).ToList();
                var aktifEvrak = kategoriEvraklari.FirstOrDefault(e => e.Durum == EvrakDurum.Aktif);
                var suresiDolacak = aktifEvrak?.BitisTarihi.HasValue == true && aktifEvrak.BitisTarihi.Value <= DateTime.Today.AddDays(30);
                var suresiDolmus = aktifEvrak?.BitisTarihi.HasValue == true && aktifEvrak.BitisTarihi.Value < DateTime.Today;

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(suresiDolmus ? "border-danger" : suresiDolacak ? "border-warning" : aktifEvrak != null ? "border-success" : "")">
                        <div class="card-header d-flex justify-content-between align-items-center py-2 @(suresiDolmus ? "bg-danger text-white" : suresiDolacak ? "bg-warning" : aktifEvrak != null ? "bg-success text-white" : "")">
                            <span>
                                <i class="bi @GetKategoriIcon(kategori) me-1"></i>
                                @kategori
                            </span>
                            @if (aktifEvrak != null)
                            {
                                <span class="badge @(suresiDolmus ? "bg-light text-danger" : suresiDolacak ? "bg-dark" : "bg-light text-success")">
                                    @(suresiDolmus ? "Süresi Dolmuş" : suresiDolacak ? "Yaklaşıyor" : "Aktif")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Evrak Yok</span>
                            }
                        </div>
                        <div class="card-body py-2">
                            @if (aktifEvrak != null)
                            {
                                <table class="table table-borderless table-sm mb-0">
                                    @if (aktifEvrak.BitisTarihi.HasValue)
                                    {
                                        <tr>
                                            <th width="80"><small>Bitis:</small></th>
                                            <td><strong class="@(suresiDolmus ? "text-danger" : suresiDolacak ? "text-warning" : "")">@aktifEvrak.BitisTarihi.Value.ToString("dd.MM.yyyy")</strong></td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(aktifEvrak.PoliceNo))
                                    {
                                        <tr>
                                            <th><small>Police:</small></th>
                                            <td>@aktifEvrak.PoliceNo</td>
                                        </tr>
                                    }
                                    @if (aktifEvrak.Tutar.HasValue)
                                    {
                                        <tr>
                                            <th><small>Tutar:</small></th>
                                            <td>@aktifEvrak.Tutar.Value.ToString("N2") TL</td>
                                        </tr>
                                    }
                                </table>
                                <div class="d-flex gap-1 mt-2">
                                    <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => EvrakDetayAc(aktifEvrak)">
                                        <i class="bi bi-eye me-1"></i>Detay
                                    </button>
                                    <button class="btn btn-sm btn-outline-info" @onclick="() => DosyaEkleAc(aktifEvrak)">
                                        <i class="bi bi-paperclip"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EvrakDuzenle(aktifEvrak)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-2">
                                    <small class="text-muted">Bu kategoride evrak yok</small>
                                    <br />
                                    <button class="btn btn-sm btn-primary mt-2" @onclick="() => YeniEvrakAc(kategori)">
                                        <i class="bi bi-plus-lg me-1"></i>Ekle
                                    </button>
                                </div>
                            }
                        </div>
                        @if (kategoriEvraklari.Count > 1)
                        {
                            <div class="card-footer py-1 bg-light">
                                <small class="text-muted">@kategoriEvraklari.Count evrak | </small>
                                <a href="#" class="small" @onclick="() => KategoriEvraklariniGoster(kategori)" @onclick:preventDefault>Tumu</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Evrak Ekle/Duzenle Modal -->
@if (showEvrakModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editEvrak.Id > 0 ? "Evrak Duzenle" : "Yeni Evrak")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kategori *</label>
                            <select class="form-select" @bind="editEvrak.EvrakKategorisi">
                                @foreach (var kat in EvrakKategorileri.TumKategoriler)
                                {
                                    <option value="@kat">@kat</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Evrak Adi</label>
                            <input type="text" class="form-control" @bind="editEvrak.EvrakAdi" placeholder="Ornek: 2024 Trafik Sigortasi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Baslangic Tarihi</label>
                            <input type="date" class="form-control" @bind="editEvrak.BaslangicTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bitis Tarihi</label>
                            <input type="date" class="form-control" @bind="editEvrak.BitisTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hatirlatma</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editEvrak.HatirlatmaGunOnce" min="1" max="90" />
                                <span class="input-group-text">gun once</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tutar</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editEvrak.Tutar" step="0.01" />
                                <span class="input-group-text">TL</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sigorta Sirketi</label>
                            <input type="text" class="form-control" @bind="editEvrak.SigortaSirketi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Police No</label>
                            <input type="text" class="form-control" @bind="editEvrak.PoliceNo" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Aciklama</label>
                            <textarea class="form-control" @bind="editEvrak.Aciklama" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Durum</label>
                            <select class="form-select" @bind="editEvrak.Durum">
                                <option value="@EvrakDurum.Aktif">Aktif</option>
                                <option value="@EvrakDurum.Pasif">Pasif</option>
                                <option value="@EvrakDurum.SuresiDolmus">Suresi Dolmus</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">&nbsp;</label>
                            <div class="form-check mt-2">
                                <input type="checkbox" class="form-check-input" @bind="editEvrak.HatirlatmaAktif" id="chkHatirlatma" />
                                <label class="form-check-label" for="chkHatirlatma">Hatirlatma Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="EvrakKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Dosya Ekle Modal -->
@if (showDosyaModal && dosyaEvrak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-paperclip me-2"></i>Dosya Ekle - @dosyaEvrak.EvrakKategorisi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <!-- Mevcut Dosyalar -->
                    @if (dosyaEvrak.Dosyalar.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">Mevcut Dosyalar</label>
                            <div class="list-group">
                                @foreach (var dosya in dosyaEvrak.Dosyalar)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                        <div>
                                            <i class="bi @GetDosyaIcon(dosya.DosyaTipi) me-2"></i>
                                            @dosya.DosyaAdi
                                            <small class="text-muted ms-2">(@FormatDosyaBoyutu(dosya.DosyaBoyutu))</small>
                                        </div>
                                        <div>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => DosyaIndir(dosya)">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DosyaSil(dosya)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Yeni Dosya Ekle -->
                    <div class="mb-3">
                        <label class="form-label">Yeni Dosya Ekle</label>
                        <InputFile class="form-control" OnChange="DosyaSecildi" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <small class="text-muted">PDF, JPG, PNG, DOC dosyalari yukleyebilirsiniz (Max 10MB)</small>
                    </div>

                    @if (secilenDosyalar.Any())
                    {
                        <div class="alert alert-info py-2">
                            <strong>@secilenDosyalar.Count dosya secildi</strong>
                            <ul class="mb-0 ps-3">
                                @foreach (var dosya in secilenDosyalar)
                                {
                                    <li><small>@dosya.Name (@FormatDosyaBoyutu(dosya.Size))</small></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                    <button type="button" class="btn btn-primary" @onclick="DosyalariYukle" disabled="@(!secilenDosyalar.Any() || isUploading)">
                        @if (isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-upload me-1"></i>Yukle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Evrak Detay Modal -->
@if (showDetayModal && detayEvrak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-text me-2"></i>@detayEvrak.EvrakKategorisi Detay</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm">
                                <tr><th width="120">Kategori:</th><td>@detayEvrak.EvrakKategorisi</td></tr>
                                <tr><th>Evrak Adi:</th><td>@detayEvrak.EvrakAdi</td></tr>
                                <tr><th>Baslangic:</th><td>@detayEvrak.BaslangicTarihi?.ToString("dd.MM.yyyy")</td></tr>
                                <tr><th>Bitis:</th><td><strong>@detayEvrak.BitisTarihi?.ToString("dd.MM.yyyy")</strong></td></tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm">
                                <tr><th width="120">Tutar:</th><td>@(detayEvrak.Tutar?.ToString("N2") ?? "-") TL</td></tr>
                                <tr><th>Sirket:</th><td>@detayEvrak.SigortaSirketi</td></tr>
                                <tr><th>Police No:</th><td>@detayEvrak.PoliceNo</td></tr>
                                <tr><th>Durum:</th><td><span class="badge @GetDurumClass(detayEvrak.Durum)">@detayEvrak.Durum</span></td></tr>
                            </table>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(detayEvrak.Aciklama))
                    {
                        <div class="alert alert-light py-2">
                            <strong>Aciklama:</strong> @detayEvrak.Aciklama
                        </div>
                    }

                    <!-- Dosyalar -->
                    @if (detayEvrak.Dosyalar.Any())
                    {
                        <h6 class="mt-3"><i class="bi bi-paperclip me-1"></i>Dosyalar (@detayEvrak.Dosyalar.Count)</h6>
                        <div class="list-group">
                            @foreach (var dosya in detayEvrak.Dosyalar)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <div>
                                        <i class="bi @GetDosyaIcon(dosya.DosyaTipi) me-2"></i>
                                        @dosya.DosyaAdi
                                        <small class="text-muted ms-2">(@FormatDosyaBoyutu(dosya.DosyaBoyutu))</small>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => DosyaIndir(dosya)">
                                        <i class="bi bi-download"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-info" @onclick="() => DosyaEkleAc(detayEvrak)">
                        <i class="bi bi-paperclip me-1"></i>Dosya Ekle
                    </button>
                    <button type="button" class="btn btn-outline-primary" @onclick="() => EvrakDuzenle(detayEvrak)">
                        <i class="bi bi-pencil me-1"></i>Duzenle
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int AracId { get; set; }

    private Arac? arac;
    private List<AracEvrak> evraklar = new();
    private bool isLoading = true;

    // Modals
    private bool showEvrakModal = false;
    private bool showDosyaModal = false;
    private bool showDetayModal = false;
    private AracEvrak editEvrak = new();
    private AracEvrak? dosyaEvrak;
    private AracEvrak? detayEvrak;

    // Dosya yukleme
    private List<IBrowserFile> secilenDosyalar = new();
    private bool isUploading = false;

    protected override async Task OnInitializedAsync()
    {
        arac = await AracService.GetByIdAsync(AracId);
        if (arac == null)
        {
            Nav.NavigateTo("/araclar");
            return;
        }
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            evraklar = await AracService.GetAracEvraklariAsync(AracId);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GeriDon() => Nav.NavigateTo("/araclar");

    private void YeniEvrakAc(string? kategori = null)
    {
        editEvrak = new AracEvrak
        {
            AracId = AracId,
            EvrakKategorisi = kategori ?? EvrakKategorileri.Ruhsat,
            Durum = EvrakDurum.Aktif,
            HatirlatmaAktif = true,
            HatirlatmaGunOnce = 15
        };
        showEvrakModal = true;
    }

    private void EvrakDuzenle(AracEvrak evrak)
    {
        editEvrak = new AracEvrak
        {
            Id = evrak.Id,
            AracId = evrak.AracId,
            EvrakKategorisi = evrak.EvrakKategorisi,
            EvrakAdi = evrak.EvrakAdi,
            Aciklama = evrak.Aciklama,
            BaslangicTarihi = evrak.BaslangicTarihi,
            BitisTarihi = evrak.BitisTarihi,
            Tutar = evrak.Tutar,
            SigortaSirketi = evrak.SigortaSirketi,
            PoliceNo = evrak.PoliceNo,
            Durum = evrak.Durum,
            HatirlatmaAktif = evrak.HatirlatmaAktif,
            HatirlatmaGunOnce = evrak.HatirlatmaGunOnce
        };
        showDetayModal = false;
        showEvrakModal = true;
    }

    private void EvrakDetayAc(AracEvrak evrak)
    {
        detayEvrak = evrak;
        showDetayModal = true;
    }

    private async Task EvrakKaydet()
    {
        if (string.IsNullOrWhiteSpace(editEvrak.EvrakKategorisi))
        {
            ToastService.ShowWarning("Kategori secin!");
            return;
        }

        try
        {
            if (editEvrak.Id > 0)
                await AracService.UpdateAracEvrakAsync(editEvrak);
            else
                await AracService.CreateAracEvrakAsync(editEvrak);

            ToastService.ShowSuccess("Evrak kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void DosyaEkleAc(AracEvrak evrak)
    {
        dosyaEvrak = evrak;
        secilenDosyalar.Clear();
        showDetayModal = false;
        showDosyaModal = true;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        secilenDosyalar = e.GetMultipleFiles(10).ToList();
    }

    private async Task DosyalariYukle()
    {
        if (dosyaEvrak == null || !secilenDosyalar.Any()) return;

        isUploading = true;
        StateHasChanged();

        try
        {
            foreach (var file in secilenDosyalar)
            {
                await AracService.UploadEvrakDosyaAsync(dosyaEvrak.Id, file);
            }

            ToastService.ShowSuccess($"{secilenDosyalar.Count} dosya yuklendi.");
            secilenDosyalar.Clear();
            await YenileAsync();

            // Dosya modalini guncelle
            dosyaEvrak = evraklar.FirstOrDefault(e => e.Id == dosyaEvrak.Id);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Yukleme hatasi: " + ex.Message);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task DosyaIndir(AracEvrakDosya dosya)
    {
        try
        {
            var bytes = await AracService.GetEvrakDosyaAsync(dosya.Id);
            var mimeType = GetMimeType(dosya.DosyaTipi);
            await AktiviteLog.LogGoruntulemeAsync("Araçlar", "AracEvrakDosya", dosya.Id, dosya.DosyaAdi, $"Araç evrak indirildi: {dosya.DosyaAdi}");
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosya.DosyaAdi, Convert.ToBase64String(bytes), mimeType);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Indirme hatasi: " + ex.Message);
        }
    }

    private static string GetMimeType(string extension)
    {
        return extension?.ToLower() switch
        {
            "pdf" => "application/pdf",
            "jpg" or "jpeg" => "image/jpeg",
            "png" => "image/png",
            "gif" => "image/gif",
            "bmp" => "image/bmp",
            "webp" => "image/webp",
            "doc" => "application/msword",
            "docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "xls" => "application/vnd.ms-excel",
            "xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "ppt" => "application/vnd.ms-powerpoint",
            "pptx" => "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            "txt" => "text/plain",
            "csv" => "text/csv",
            "zip" => "application/zip",
            _ => "application/octet-stream"
        };
    }

    private async Task DosyaSil(AracEvrakDosya dosya)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{dosya.DosyaAdi}' dosyasini silmek istediginizden emin misiniz?");
        if (confirmed)
        {
            try
            {
                await AracService.DeleteEvrakDosyaAsync(dosya.Id);
                ToastService.ShowSuccess("Dosya silindi.");
                await YenileAsync();

                // Modal guncelle
                if (dosyaEvrak != null)
                    dosyaEvrak = evraklar.FirstOrDefault(e => e.Id == dosyaEvrak.Id);
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Silme hatasi: " + ex.Message);
            }
        }
    }

    private void KategoriEvraklariniGoster(string kategori)
    {
        ToastService.ShowInfo($"{kategori} evraklari gosteriliyor...");
    }

    private void ModalKapat()
    {
        showEvrakModal = false;
        showDosyaModal = false;
        showDetayModal = false;
    }

    private string GetKategoriIcon(string kategori) => kategori switch
    {
        "Ruhsat" => "bi-card-text",
        "Trafik Sigortasi" => "bi-shield-check",
        "Kasko" => "bi-shield-plus",
        "Muayene" => "bi-clipboard-check",
        "Yetki Belgesi" => "bi-file-earmark-check",
        "Uygunluk Belgesi" => "bi-truck",
        "Emisyon Belgesi" => "bi-cloud",
        _ => "bi-file-earmark"
    };

    private string GetDosyaIcon(string? dosyaTipi) => dosyaTipi?.ToLower() switch
    {
        "pdf" => "bi-file-earmark-pdf text-danger",
        "jpg" or "jpeg" or "png" => "bi-file-earmark-image text-primary",
        "doc" or "docx" => "bi-file-earmark-word text-primary",
        _ => "bi-file-earmark"
    };

    private string GetDurumClass(EvrakDurum durum) => durum switch
    {
        EvrakDurum.Aktif => "bg-success",
        EvrakDurum.Pasif => "bg-secondary",
        EvrakDurum.SuresiDolmus => "bg-danger",
        _ => "bg-secondary"
    };

    private string FormatDosyaBoyutu(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / 1024 / 1024} MB";
    }
}
