                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="6" class="text-end">Toplam:</th>
                                <th class="text-end">@FiltrelenmisHareketler.Sum(h => h.Tutar).ToString("N2") ₺</th>
                                <th colspan="5"></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    };

    private RenderFragment AracBazliOzet() => __builder =>
    {
        var aracOzet = TumHareketler
            .GroupBy(h => new { h.AracId, h.Plaka, h.MarkaModel, h.SaseNo })
            .Select(g => new
            {
                g.Key.AracId,
                g.Key.Plaka,
                g.Key.MarkaModel,
                g.Key.SaseNo,
                ToplamHareket = g.Count(),
                ToplamTutar = g.Sum(x => x.Tutar),
                MasrafSayi = g.Count(x => x.Kaynak == "Masraf" || x.Kaynak == "PersonelMasraf"),
                ServisSayi = g.Count(x => x.Kaynak == "Servis"),
                ArizaSayi = g.Count(x => x.ArizaKaynaklimi),
                SonHareket = g.Max(x => x.Tarih),
                Hareketler = g.OrderByDescending(x => x.Tarih).ToList()
            })
