            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-truck me-1"></i>Araç Bazlı Toplam Masraflar</span>
                <span class="badge bg-secondary">@aracOzet.Count araç</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle" style="font-size:0.85rem;">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:30px;"></th>
                                <th>Plaka</th>
                                <th>Marka / Model</th>
                                <th>Şase</th>
                                <th class="text-center">Hareket Sayısı</th>
                                <th class="text-center">Masraf</th>
                                <th class="text-center">Servis</th>
                                <th class="text-center">Arıza</th>
