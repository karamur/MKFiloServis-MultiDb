                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="SilOnayla">
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Birleşik hareket modeli
    private class Hareket
    {
        public int Id { get; set; }
        public string Kaynak { get; set; } = string.Empty; // "Masraf" | "Servis"
        public DateTime Tarih { get; set; }
        public int AracId { get; set; }
        public string Plaka { get; set; } = string.Empty;
        public string SaseNo { get; set; } = string.Empty;
        public string MarkaModel { get; set; } = string.Empty;
        public string Kategori { get; set; } = string.Empty;
        public MasrafKategori? KategoriEnum { get; set; }
        public string Aciklama { get; set; } = string.Empty;
        public string BelgeNo { get; set; } = string.Empty;
        public decimal Tutar { get; set; }
        public MasrafOdemeKaynak OdemeKaynak { get; set; }
        public string Odeyen { get; set; } = string.Empty;
        public bool ArizaKaynaklimi { get; set; }
        public bool PersonelCebinden { get; set; }
        public bool PersoneleOdendi { get; set; }
        public bool MuhasebeFisVar { get; set; }
        public int? MuhasebeFisId { get; set; }
    }

    private List<AracMasraf> masraflar = new();
    private List<ServisKaydi> servisler = new();
    private List<BankaKasaHareket> personelHareketleri = new();
    private List<Arac> araclar = new();
    private List<Cari> cariler = new();
    private List<MasrafKalemi> masrafKalemleri = new();
    private bool isLoading = true;

    // Sekmeler
    private string aktifSekme = "hareketler";

    // Özet kart filtresi
    private string seviyeFiltre = "tumu";

    // Filtreler
    private string filtreArama = string.Empty;
    private int filtreAracId = 0;
    private string filtreKaynak = string.Empty;
    private string filtreKategori = string.Empty;
    private string filtreOdemeKaynak = string.Empty;
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private decimal? filtreMinTutar;
    private decimal? filtreMaxTutar;
    private string filtreFisDurumu = string.Empty;
    private string filtreAriza = string.Empty;

    // Sıralama
    private string siralamaAlani = "Tarih";
    private bool siralamaAzalan = true;

    // Modaller
    private bool showServisModal = false;
    private ServisKaydi? editingServis;
    private bool isSaving = false;
    private bool showDetayModal = false;
    private Hareket? detayHareket;
    private bool showDeleteModal = false;
    private Hareket? silinecekHareket;
    private readonly decimal[] servisKdvSecenekleri = [0, 1, 8, 10, 18, 20];

    // Araç bazlı açık satır
    private int? acikAracId;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            masraflar = await AracMasrafService.GetAllAsync();
            servisler = await StokService.GetServisKayitlariAsync();
            // Finans -> Masraf Girişi üzerinden oluşturulan personel cebinden araç masrafları
            var tumHareket = await HareketService.GetAllAsync();
            personelHareketleri = tumHareket
                .Where(h => h.PersonelCebindenId.HasValue && h.AracId.HasValue)
                .ToList();
            araclar = await AracService.GetAllAsync();
            cariler = await CariService.GetAllAsync();
            masrafKalemleri = await MasrafKalemiService.GetAllAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veriler yüklenemedi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<Hareket> TumHareketler
    {
        get
        {
            var liste = new List<Hareket>();
            foreach (var m in masraflar)
            {
                liste.Add(new Hareket
                {
                    Id = m.Id,
                    Kaynak = "Masraf",
                    Tarih = m.MasrafTarihi,
                    AracId = m.AracId,
                    Plaka = m.Arac?.AktifPlaka ?? string.Empty,
                    SaseNo = m.Arac?.SaseNo ?? string.Empty,
                    MarkaModel = $"{m.Arac?.Marka} {m.Arac?.Model}".Trim(),
                    Kategori = m.MasrafKalemi?.MasrafAdi ?? string.Empty,
                    KategoriEnum = m.MasrafKalemi?.Kategori,
                    Aciklama = m.Aciklama ?? string.Empty,
                    BelgeNo = m.BelgeNo ?? string.Empty,
                    Tutar = m.Tutar,
                    OdemeKaynak = m.OdemeKaynak,
                    Odeyen = GetMuhatapText(m),
                    ArizaKaynaklimi = m.ArizaKaynaklimi,
                    PersonelCebinden = m.IsPersonelCebinden || m.SoforId.HasValue,
                    PersoneleOdendi = m.PersoneleOdendi,
                    MuhasebeFisVar = m.MuhasebeFisId.HasValue,
                    MuhasebeFisId = m.MuhasebeFisId
                });
            }
            foreach (var s in servisler)
            {
                liste.Add(new Hareket
                {
                    Id = s.Id,
                    Kaynak = "Servis",
                    Tarih = s.ServisTarihi,
                    AracId = s.AracId,
                    Plaka = s.Arac?.AktifPlaka ?? string.Empty,
                    SaseNo = s.Arac?.SaseNo ?? string.Empty,
                    MarkaModel = $"{s.Arac?.Marka} {s.Arac?.Model}".Trim(),
                    Kategori = GetServisTipiAdi(s.ServisTipi),
                    Aciklama = s.ServisAdi ?? string.Empty,
                    BelgeNo = string.Empty,
                    Tutar = s.ToplamTutar,
                    OdemeKaynak = MasrafOdemeKaynak.Kasa,
                    Odeyen = s.ServisciCari?.Unvan ?? "-",
                    ArizaKaynaklimi = s.ServisTipi == ServisTipi.Onarim,
                    PersonelCebinden = false,
                    PersoneleOdendi = false,
                    MuhasebeFisVar = s.AracMasraf?.MuhasebeFisId.HasValue ?? false,
                    MuhasebeFisId = s.AracMasraf?.MuhasebeFisId
                });
            }
            // Finans -> Masraf Giri\u015fi \u00fczerinden personel cebinden olu\u015fturulan ve ara\u00e7la ili\u015fkilendirilen masraflar
            foreach (var h in personelHareketleri)
            {
                if (h.Arac == null) continue;
                liste.Add(new Hareket
                {
                    Id = h.Id,
                    Kaynak = "PersonelMasraf",
                    Tarih = h.IslemTarihi,
                    AracId = h.AracId ?? 0,
                    Plaka = h.Arac.AktifPlaka ?? string.Empty,
                    SaseNo = h.Arac.SaseNo ?? string.Empty,
                    MarkaModel = $"{h.Arac.Marka} {h.Arac.Model}".Trim(),
                    Kategori = "Personel Cebinden",
                    Aciklama = h.Aciklama ?? string.Empty,
                    BelgeNo = h.BelgeNo ?? string.Empty,
                    Tutar = h.Tutar,
                    OdemeKaynak = MasrafOdemeKaynak.PersonelCebinden,
                    Odeyen = h.PersonelCebinden != null ? $"Personel: {h.PersonelCebinden.TamAd}" : "Personel",
                    ArizaKaynaklimi = false,
                    PersonelCebinden = true,
                    PersoneleOdendi = h.PersoneleOdendi,
                    MuhasebeFisVar = h.MuhasebeFisId.HasValue,
                    MuhasebeFisId = h.MuhasebeFisId
                });
            }
            return liste;
        }
    }

    private List<Hareket> FiltrelenmisHareketler => TumHareketler.Where(h =>
        (string.IsNullOrWhiteSpace(filtreArama)
            || h.Plaka.Contains(filtreArama, StringComparison.OrdinalIgnoreCase)
            || h.SaseNo.Contains(filtreArama, StringComparison.OrdinalIgnoreCase)
            || h.MarkaModel.Contains(filtreArama, StringComparison.OrdinalIgnoreCase)
            || h.Aciklama.Contains(filtreArama, StringComparison.OrdinalIgnoreCase)
            || h.BelgeNo.Contains(filtreArama, StringComparison.OrdinalIgnoreCase))
        && (filtreAracId == 0 || h.AracId == filtreAracId)
        && (string.IsNullOrEmpty(filtreKaynak)
            || (filtreKaynak == "Masraf" && (h.Kaynak == "Masraf" || h.Kaynak == "PersonelMasraf"))
            || (filtreKaynak == "Servis" && h.Kaynak == "Servis"))
        && (string.IsNullOrEmpty(filtreKategori) || h.Kategori.Contains(filtreKategori, StringComparison.OrdinalIgnoreCase)
            || (h.Kaynak == "Masraf" && masraflar.FirstOrDefault(m => m.Id == h.Id)?.MasrafKalemi?.Kategori.ToString() == filtreKategori))
        && (string.IsNullOrEmpty(filtreOdemeKaynak) || h.OdemeKaynak.ToString() == filtreOdemeKaynak)
        && (!filtreBaslangic.HasValue || h.Tarih.Date >= filtreBaslangic.Value.Date)
        && (!filtreBitis.HasValue || h.Tarih.Date <= filtreBitis.Value.Date)
        && (!filtreMinTutar.HasValue || h.Tutar >= filtreMinTutar.Value)
        && (!filtreMaxTutar.HasValue || h.Tutar <= filtreMaxTutar.Value)
        && (string.IsNullOrEmpty(filtreFisDurumu)
            || (filtreFisDurumu == "var" && h.MuhasebeFisVar)
            || (filtreFisDurumu == "yok" && !h.MuhasebeFisVar))
        && (string.IsNullOrEmpty(filtreAriza)
            || (filtreAriza == "evet" && h.ArizaKaynaklimi)
            || (filtreAriza == "hayir" && !h.ArizaKaynaklimi))
        && (seviyeFiltre switch
        {
            "ariza" => h.ArizaKaynaklimi,
            "personel" => h.PersonelCebinden && !h.PersoneleOdendi,
            "fissiz" => !h.MuhasebeFisVar,
            "servis" => h.Kaynak == "Servis",
            _ => true
        })
    ).ToList();

    private List<Hareket> SiraliHareketler => siralamaAlani switch
    {
        "Tutar" => siralamaAzalan
            ? FiltrelenmisHareketler.OrderByDescending(h => h.Tutar).ToList()
            : FiltrelenmisHareketler.OrderBy(h => h.Tutar).ToList(),
        _ => siralamaAzalan
            ? FiltrelenmisHareketler.OrderByDescending(h => h.Tarih).ToList()
            : FiltrelenmisHareketler.OrderBy(h => h.Tarih).ToList(),
    };

    // ── Render Fragments ─────────────────────────────────────────────
    private RenderFragment HareketlerTablosu() => __builder =>
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle" style="font-size:0.85rem;">
