@page "/bakim-onarim"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IAracMasrafService AracMasrafService
@inject IStokService StokService
@inject IAracService AracService
@inject ICariService CariService
@inject IMasrafKalemiService MasrafKalemiService
@inject IBankaKasaHareketService HareketService
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject IExcelService ExcelService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Bakım-Onarım Kayıtları</PageTitle>

<style>
    .ozet-kart { transition: transform .12s ease, box-shadow .12s ease; cursor: pointer; }
    .ozet-kart:hover { transform: translateY(-2px); box-shadow: 0 .4rem .9rem rgba(0,0,0,.12); }
    .ozet-kart-aktif { outline: 3px solid #212529; outline-offset: -3px; }
    .nav-tabs .nav-link.active { font-weight: 600; }
    .arac-row { cursor: pointer; }
    .arac-row.acik { background-color: #fff8e1 !important; }
    .arac-detay-row > td { background-color: #fafafa; padding: 0; }
    .arac-detay-icerik { padding: 1rem; border-top: 2px solid #ffc107; }
</style>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0"><i class="bi bi-wrench-adjustable-circle me-2"></i>Bakım-Onarım Kayıtları</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniMasraf">
                <i class="bi bi-receipt me-1"></i>Yeni Masraf
            </button>
            <button class="btn btn-warning" @onclick="YeniServis">
                <i class="bi bi-tools me-1"></i>Yeni Servis
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelIndir" disabled="@(!FiltrelenmisHareketler.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    <!-- Özet Kartlar -->
    <div class="row g-2 mb-3">
        <div class="col-md-2">
            <div class="card border-primary ozet-kart @(seviyeFiltre == "tumu" ? "ozet-kart-aktif" : "")"
                 @onclick='() => SeviyeFiltreUygula("tumu")'>
                <div class="card-body py-2 text-center">
                    <small class="text-muted d-block">Toplam Hareket</small>
                    <div class="fs-4 fw-bold text-primary">@TumHareketler.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-success ozet-kart @(seviyeFiltre == "tutar" ? "ozet-kart-aktif" : "")"
                 @onclick='() => SeviyeFiltreUygula("tutar")'>
                <div class="card-body py-2 text-center">
                    <small class="text-muted d-block">Toplam Tutar</small>
                    <div class="fs-5 fw-bold text-success">@FiltrelenmisHareketler.Sum(h => h.Tutar).ToString("N2") ₺</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-warning ozet-kart @(seviyeFiltre == "ariza" ? "ozet-kart-aktif" : "")"
                 @onclick='() => SeviyeFiltreUygula("ariza")'>
                <div class="card-body py-2 text-center">
                    <small class="text-muted d-block">Arıza Kaynaklı</small>
                    <div class="fs-4 fw-bold text-warning">@TumHareketler.Count(h => h.ArizaKaynaklimi)</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-info ozet-kart @(seviyeFiltre == "personel" ? "ozet-kart-aktif" : "")"
                 @onclick='() => SeviyeFiltreUygula("personel")'>
                <div class="card-body py-2 text-center">
                    <small class="text-muted d-block">Personel Cebinden (Bekleyen)</small>
                    <div class="fs-5 fw-bold text-info">@TumHareketler.Where(h => h.PersonelCebinden && !h.PersoneleOdendi).Sum(h => h.Tutar).ToString("N2") ₺</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-danger ozet-kart @(seviyeFiltre == "fissiz" ? "ozet-kart-aktif" : "")"
                 @onclick='() => SeviyeFiltreUygula("fissiz")'>
                <div class="card-body py-2 text-center">
                    <small class="text-muted d-block">Muhasebe Fişi Yok</small>
                    <div class="fs-4 fw-bold text-danger">@TumHareketler.Count(h => !h.MuhasebeFisVar)</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-secondary ozet-kart @(seviyeFiltre == "servis" ? "ozet-kart-aktif" : "")"
                 @onclick='() => SeviyeFiltreUygula("servis")'>
                <div class="card-body py-2 text-center">
                    <small class="text-muted d-block">Servis Kayıt</small>
                    <div class="fs-4 fw-bold text-secondary">@TumHareketler.Count(h => h.Kaynak == "Servis")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sekmeler -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "hareketler" ? "active" : "")" @onclick='() => aktifSekme = "hareketler"'>
                <i class="bi bi-list-ul me-1"></i>Tüm Hareketler
                <span class="badge bg-primary ms-1">@FiltrelenmisHareketler.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "arac" ? "active" : "")" @onclick='() => aktifSekme = "arac"'>
                <i class="bi bi-truck me-1"></i>Araç Bazlı Özet
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "butce" ? "active" : "")" @onclick='() => aktifSekme = "butce"'>
                <i class="bi bi-cash-coin me-1"></i>Bütçe / Muhasebe
            </button>
        </li>
    </ul>

    <!-- Filtreler -->
    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Plaka / Şase / Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreArama" @bind:event="oninput" placeholder="Plaka, şase, açıklama..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Araç</label>
                    <select class="form-select form-select-sm" @bind="filtreAracId">
                        <option value="0">Tümü</option>
                        @foreach (var a in araclar.OrderBy(x => x.AktifPlaka))
                        {
                            <option value="@a.Id">@a.AktifPlaka - @a.Marka @a.Model</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Kaynak</label>
                    <select class="form-select form-select-sm" @bind="filtreKaynak">
                        <option value="">Tümü</option>
                        <option value="Masraf">Masraf</option>
                        <option value="Servis">Servis Kaydı</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filtreKategori">
                        <option value="">Tümü</option>
                        @foreach (MasrafKategori k in Enum.GetValues<MasrafKategori>())
                        {
                            <option value="@k.ToString()">@k.ToString()</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ödeme Kaynağı</label>
                    <select class="form-select form-select-sm" @bind="filtreOdemeKaynak">
                        <option value="">Tümü</option>
                        @foreach (MasrafOdemeKaynak k in Enum.GetValues<MasrafOdemeKaynak>())
                        {
                            <option value="@k.ToString()">@GetOdemeKaynakAdi(k)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@filtreBaslangic?.ToString("yyyy-MM-dd")"
                           @onchange="(e) => filtreBaslangic = ParseDate(e.Value)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bitiş</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@filtreBitis?.ToString("yyyy-MM-dd")"
                           @onchange="(e) => filtreBitis = ParseDate(e.Value)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Min Tutar</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" @bind="filtreMinTutar" placeholder="0,00" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Max Tutar</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" @bind="filtreMaxTutar" placeholder="0,00" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Muhasebe Fişi</label>
                    <select class="form-select form-select-sm" @bind="filtreFisDurumu">
                        <option value="">Tümü</option>
                        <option value="var">Var</option>
                        <option value="yok">Yok</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Arıza Kaynaklı</label>
                    <select class="form-select form-select-sm" @bind="filtreAriza">
                        <option value="">Tümü</option>
                        <option value="evet">Evet</option>
                        <option value="hayir">Hayır</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button class="btn btn-secondary btn-sm w-100" @onclick="FiltreyiTemizle">
                        <i class="bi bi-x-circle me-1"></i>Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (aktifSekme == "hareketler")
    {
        @HareketlerTablosu()
    }
    else if (aktifSekme == "arac")
    {
        @AracBazliOzet()
    }
    else if (aktifSekme == "butce")
    {
        @ButceMuhasebe()
    }
</div>

<!-- Servis Modal -->
@if (showServisModal && editingServis != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-tools me-2"></i>
                        @(editingServis.Id > 0 ? "Servis Kaydı Düzenle" : "Yeni Servis Kaydı")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseServisModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingServis" OnValidSubmit="SaveServis">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Araç *</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.AracId">
                                    <option value="0">Seçiniz</option>
                                    @foreach (var a in araclar)
                                    {
                                        <option value="@a.Id">@a.AktifPlaka - @a.Marka @a.Model</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Servis Tarihi *</label>
                                <InputDate class="form-control" @bind-Value="editingServis.ServisTarihi" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Kilometre</label>
                                <InputNumber class="form-control" @bind-Value="editingServis.Kilometre" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Servis Tipi</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.ServisTipi">
                                    @foreach (var tip in Enum.GetValues<ServisTipi>())
                                    {
                                        <option value="@tip">@GetServisTipiAdi(tip)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Servisci Firma</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.ServisciCariId">
                                    <option value="">Seçiniz</option>
                                    @foreach (var c in cariler)
                                    {
                                        <option value="@c.Id">@c.Unvan</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Durum</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.Durum">
                                    @foreach (var d in Enum.GetValues<ServisDurum>())
                                    {
                                        <option value="@d">@GetDurumAdi(d)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Servis Adı *</label>
                                <InputText class="form-control" @bind-Value="editingServis.ServisAdi" />
                            </div>
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    <InputCheckbox class="form-check-input" @bind-Value="editingServis.GarantiKapsaminda" id="garanti" />
                                    <label class="form-check-label" for="garanti">Garanti Kapsamında</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label class="form-label mb-0">Servis Kalemleri</label>
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-primary" @onclick="() => KalemEkle(ServisKalemTipi.Malzeme)">
                                            <i class="bi bi-plus-circle me-1"></i>Malzeme Ekle
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => KalemEkle(ServisKalemTipi.Iscilik)">
                                            <i class="bi bi-plus-circle me-1"></i>İşçilik Ekle
                                        </button>
                                    </div>
                                </div>
                                <div class="table-responsive border rounded">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="min-width: 110px;">Kalem Tipi</th>
                                                <th style="min-width: 220px;">Açıklama</th>
                                                <th style="width: 90px;">Miktar</th>
                                                <th style="width: 100px;">Birim</th>
                                                <th style="width: 120px;">Birim Fiyat</th>
                                                <th style="width: 100px;">KDV %</th>
                                                <th style="width: 120px;">KDV Tutar</th>
                                                <th style="width: 120px;">Net Tutar</th>
                                                <th style="width: 110px;">Stoğa Kaydet</th>
                                                <th style="width: 60px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (editingServis.Parcalar.Any())
                                            {
                                                @foreach (var kalem in editingServis.Parcalar)
                                                {
                                                    <tr>
                                                        <td>
                                                            <InputSelect class="form-select form-select-sm" @bind-Value="kalem.KalemTipi" @bind-Value:after="ServisKalemleriniHesapla">
                                                                <option value="@ServisKalemTipi.Malzeme">Malzeme</option>
                                                                <option value="@ServisKalemTipi.Iscilik">İşçilik</option>
                                                            </InputSelect>
                                                        </td>
                                                        <td>
                                                            <InputText class="form-control form-control-sm" @bind-Value="kalem.ParcaAdi" @bind-Value:after="ServisKalemleriniHesapla" />
                                                        </td>
                                                        <td>
                                                            <InputNumber class="form-control form-control-sm" @bind-Value="kalem.Miktar" @bind-Value:after="ServisKalemleriniHesapla" />
                                                        </td>
                                                        <td>
                                                            <InputText class="form-control form-control-sm" @bind-Value="kalem.Birim" @bind-Value:after="ServisKalemleriniHesapla" />
                                                        </td>
                                                        <td>
                                                            <InputNumber class="form-control form-control-sm" @bind-Value="kalem.BirimFiyat" @bind-Value:after="ServisKalemleriniHesapla" />
                                                        </td>
                                                        <td>
                                                            <InputSelect class="form-select form-select-sm" @bind-Value="kalem.KdvOrani" @bind-Value:after="ServisKalemleriniHesapla">
                                                                @foreach (var kdv in servisKdvSecenekleri)
                                                                {
                                                                    <option value="@kdv">@kdv</option>
                                                                }
                                                            </InputSelect>
                                                        </td>
                                                        <td class="text-end fw-semibold">@ServisKalemKdv(kalem).ToString("N2") ₺</td>
                                                        <td class="text-end fw-semibold">@ServisKalemNet(kalem).ToString("N2") ₺</td>
                                                        <td class="text-center">
                                                            @if (kalem.KalemTipi == ServisKalemTipi.Malzeme)
                                                            {
                                                                <InputCheckbox class="form-check-input" @bind-Value="kalem.StogaKaydet" @bind-Value:after="ServisKalemleriniHesapla" />
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => KalemSil(kalem)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="10" class="text-center text-muted py-3">
                                                        Kalem yok. Malzeme veya işçilik kalemi ekleyin.
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Malzeme Toplamı</label>
                                <input class="form-control" value="@editingServis.ParcaTutari.ToString("N2")" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">İşçilik Toplamı</label>
                                <input class="form-control" value="@editingServis.IscilikTutari.ToString("N2")" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">KDV Toplamı</label>
                                <InputNumber class="form-control" @bind-Value="editingServis.KdvTutar" @bind-Value:after="ServisKalemleriniHesapla" disabled="@(!editingServis.KdvManuelMi)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Genel Toplam</label>
                                <input class="form-control fw-semibold" value="@editingServis.ToplamTutar.ToString("N2")" readonly />
                            </div>

                            <div class="col-md-4">
                                <div class="form-check mt-2">
                                    <InputCheckbox class="form-check-input" @bind-Value="editingServis.KdvManuelMi" @bind-Value:after="ServisKalemleriniHesapla" id="kdvmanuel" />
                                    <label class="form-check-label" for="kdvmanuel">KDV Toplamını Manuel Düzelt</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Açıklama</label>
                                <InputTextArea class="form-control" @bind-Value="editingServis.Aciklama" rows="2" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Notlar</label>
                                <InputTextArea class="form-control" @bind-Value="editingServis.Notlar" rows="2" />
                            </div>
                        </div>
                        <div class="mt-3 d-flex justify-content-end">
                            <button type="button" class="btn btn-secondary me-2" @onclick="CloseServisModal">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Kaydet
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detay Modal -->
@if (showDetayModal && detayHareket != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="() => showDetayModal = false">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2 text-info"></i>@detayHareket.Kaynak Detayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDetayModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6"><strong>Tarih:</strong> @detayHareket.Tarih.ToString("dd.MM.yyyy")</div>
                        <div class="col-md-6"><strong>Plaka:</strong> @detayHareket.Plaka</div>
                        <div class="col-md-6"><strong>Marka/Model:</strong> @detayHareket.MarkaModel</div>
                        <div class="col-md-6"><strong>Kategori/Tip:</strong> @detayHareket.Kategori</div>
                        <div class="col-md-6"><strong>Açıklama:</strong> @detayHareket.Aciklama</div>
                        <div class="col-md-6"><strong>Belge No:</strong> @detayHareket.BelgeNo</div>
                        <div class="col-md-6"><strong>Tutar:</strong> <span class="fs-5 fw-bold text-success">@detayHareket.Tutar.ToString("N2") ₺</span></div>
                        <div class="col-md-6"><strong>Ödeme Kaynağı:</strong> <span class="badge @GetOdemeKaynakBadge(detayHareket.OdemeKaynak)">@GetOdemeKaynakAdi(detayHareket.OdemeKaynak)</span></div>
                        <div class="col-md-6"><strong>Ödeyen:</strong> @detayHareket.Odeyen</div>
                        <div class="col-md-6"><strong>Muhasebe Fişi:</strong>
                            @if (detayHareket.MuhasebeFisVar)
                            {
                                <span class="badge bg-success">#@detayHareket.MuhasebeFisId</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Yok</span>
                            }
                        </div>
                        <div class="col-md-6"><strong>Arıza Kaynaklı:</strong>
                            @if (detayHareket.ArizaKaynaklimi) { <span class="badge bg-warning text-dark">Evet</span> }
                            else { <span class="badge bg-secondary">Hayır</span> }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="() => DuzenleHareket(detayHareket!)">
                        <i class="bi bi-pencil me-1"></i>Düzenle
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="() => showDetayModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay -->
@if (showDeleteModal && silinecekHareket != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Silme Onayı</h5>
