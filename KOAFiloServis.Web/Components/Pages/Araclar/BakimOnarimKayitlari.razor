                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-tools me-1"></i>Servis</span>
                                        }
                                    </td>
                                    <td>@h.Plaka</td>
                                    <td><small>@h.MarkaModel</small></td>
                                    <td>@h.Kategori</td>
                                    <td><small>@h.Aciklama</small></td>
                                    <td class="text-end"><strong>@h.Tutar.ToString("N2") ₺</strong></td>
                                    <td><span class="badge @GetOdemeKaynakBadge(h.OdemeKaynak)">@GetOdemeKaynakAdi(h.OdemeKaynak)</span></td>
                                    <td><small>@h.Odeyen</small></td>
                                    <td class="text-center">
                                        @if (h.MuhasebeFisVar)
                                        {
                                            <span class="badge bg-success" title="Fiş No: @h.MuhasebeFisId">Var</span>
                                        }
                                        else if (h.Kaynak == "Masraf" || h.Kaynak == "PersonelMasraf")
                                        {
                                            <span class="badge bg-secondary">Yok</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (h.ArizaKaynaklimi)
                                        {
                                            <span class="badge bg-warning text-dark">Evet</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-info" @onclick="() => DetayAc(h)" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-primary" @onclick="() => DuzenleHareket(h)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => { silinecekHareket = h; showDeleteModal = true; }" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
