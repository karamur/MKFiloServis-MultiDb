                                <tr class="@(h.ArizaKaynaklimi ? "table-warning" : "")">
                                    <td><strong>@h.Tarih.ToString("dd.MM.yyyy")</strong></td>
                                    <td>
                                        @if (h.Kaynak == "Masraf" || h.Kaynak == "PersonelMasraf")
