                    </table>
                </div>
            </div>
        </div>
    };

    private RenderFragment ButceMuhasebe() => __builder =>
    {
        var hareketler = FiltrelenmisHareketler;
        var kategoriOzet = hareketler
            .GroupBy(h => h.Kategori)
            .Select(g => new { Kategori = g.Key, Adet = g.Count(), Tutar = g.Sum(x => x.Tutar) })
            .OrderByDescending(x => x.Tutar)
            .ToList();

        var odemeOzet = hareketler
            .GroupBy(h => h.OdemeKaynak)
            .Select(g => new { Kaynak = g.Key, Adet = g.Count(), Tutar = g.Sum(x => x.Tutar) })
            .OrderByDescending(x => x.Tutar)
            .ToList();

        var ayOzet = hareketler
            .GroupBy(h => new { h.Tarih.Year, h.Tarih.Month })
            .Select(g => new { Yil = g.Key.Year, Ay = g.Key.Month, Adet = g.Count(), Tutar = g.Sum(x => x.Tutar) })
            .OrderByDescending(x => x.Yil).ThenByDescending(x => x.Ay)
            .Take(12)
            .ToList();

        var muhasebe = hareketler;
        var fisliTutar = muhasebe.Where(h => h.MuhasebeFisVar).Sum(h => h.Tutar);
        var fissizTutar = muhasebe.Where(h => !h.MuhasebeFisVar).Sum(h => h.Tutar);

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 bg-info bg-opacity-25"><strong><i class="bi bi-tags me-1"></i>Kategori Bazlı Dağılım</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-light"><tr><th>Kategori</th><th class="text-center">Adet</th><th class="text-end">Tutar</th><th class="text-end">%</th></tr></thead>
                            <tbody>
                                @{
                                    var kategoriToplam = kategoriOzet.Sum(x => x.Tutar);
                                }
                                @foreach (var k in kategoriOzet)
                                {
                                    <tr>
                                        <td>@k.Kategori</td>
                                        <td class="text-center">@k.Adet</td>
                                        <td class="text-end">@k.Tutar.ToString("N2") ₺</td>
                                        <td class="text-end"><small>@(kategoriToplam == 0 ? "0" : ((k.Tutar / kategoriToplam) * 100).ToString("N1"))%</small></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-dark"><tr><th>Toplam</th><th class="text-center">@kategoriOzet.Sum(x => x.Adet)</th><th class="text-end">@kategoriToplam.ToString("N2") ₺</th><th></th></tr></tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 bg-success bg-opacity-25"><strong><i class="bi bi-credit-card me-1"></i>Ödeme Kaynağı Dağılımı</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-light"><tr><th>Kaynak</th><th class="text-center">Adet</th><th class="text-end">Tutar</th></tr></thead>
                            <tbody>
                                @foreach (var o in odemeOzet)
                                {
                                    <tr>
                                        <td><span class="badge @GetOdemeKaynakBadge(o.Kaynak)">@GetOdemeKaynakAdi(o.Kaynak)</span></td>
                                        <td class="text-center">@o.Adet</td>
                                        <td class="text-end">@o.Tutar.ToString("N2") ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 bg-warning bg-opacity-25"><strong><i class="bi bi-calendar3 me-1"></i>Aylık Bütçe (Son 12 Ay)</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-light"><tr><th>Dönem</th><th class="text-center">Adet</th><th class="text-end">Tutar</th></tr></thead>
                            <tbody>
                                @foreach (var a in ayOzet)
                                {
                                    <tr>
                                        <td>@($"{a.Yil}/{a.Ay:D2}")</td>
                                        <td class="text-center">@a.Adet</td>
                                        <td class="text-end">@a.Tutar.ToString("N2") ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 bg-danger bg-opacity-25"><strong><i class="bi bi-journal-bookmark me-1"></i>Muhasebe Fişi Durumu</strong></div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="border rounded p-2 text-center">
                                    <small class="text-muted d-block">Fişli Masraflar</small>
                                    <div class="fs-5 fw-bold text-success">@muhasebe.Count(h => h.MuhasebeFisVar)</div>
                                    <small>@fisliTutar.ToString("N2") ₺</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="border rounded p-2 text-center">
                                    <small class="text-muted d-block">Fişsiz Masraflar</small>
                                    <div class="fs-5 fw-bold text-danger">@muhasebe.Count(h => !h.MuhasebeFisVar)</div>
                                    <small>@fissizTutar.ToString("N2") ₺</small>
                                </div>
                            </div>
                            <div class="col-12 mt-2">
                                <small class="text-muted">Personel cebinden bekleyen ödemeler:</small>
                                <div class="fw-bold text-info">
                                    @hareketler.Where(h => h.PersonelCebinden && !h.PersoneleOdendi).Sum(h => h.Tutar).ToString("N2") ₺
                                    (@hareketler.Count(h => h.PersonelCebinden && !h.PersoneleOdendi) kayıt)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    };

    // ── Eylemler ─────────────────────────────────────────────────────
    private void Sirala(string alan)
    {
        if (siralamaAlani == alan) siralamaAzalan = !siralamaAzalan;
        else { siralamaAlani = alan; siralamaAzalan = true; }
    }

    private MarkupString SiralamaIkonu(string alan)
    {
        if (siralamaAlani != alan) return new MarkupString("<i class=\"bi bi-arrow-down-up text-muted\"></i>");
        return new MarkupString(siralamaAzalan ? "<i class=\"bi bi-arrow-down\"></i>" : "<i class=\"bi bi-arrow-up\"></i>");
    }

    private void SeviyeFiltreUygula(string seviye) => seviyeFiltre = seviyeFiltre == seviye ? "tumu" : seviye;

    private void FiltreyiTemizle()
    {
        filtreArama = filtreKaynak = filtreKategori = filtreOdemeKaynak = filtreFisDurumu = filtreAriza = string.Empty;
        filtreAracId = 0;
        filtreBaslangic = filtreBitis = null;
        filtreMinTutar = filtreMaxTutar = null;
        seviyeFiltre = "tumu";
    }

    private static DateTime? ParseDate(object? raw)
        => raw == null ? null : DateTime.TryParse(raw.ToString(), out var d) ? d : null;

    private void YeniMasraf() => Navigation.NavigateTo("/arac-masraflari/yeni");

    private void YeniServis()
    {
        editingServis = new ServisKaydi
        {
            ServisTarihi = DateTime.Today,
            ServisTipi = ServisTipi.PeriyodikBakim,
            KdvOrani = 20,
            Durum = ServisDurum.Tamamlandi,
            KdvManuelMi = false,
            Parcalar =
            [
                new ServisParca
                {
                    KalemTipi = ServisKalemTipi.Malzeme,
                    ParcaAdi = string.Empty,
                    Miktar = 1,
                    Birim = "Adet",
                    BirimFiyat = 0,
                    KdvOrani = 20
                }
            ]
        };
        ServisKalemleriniHesapla();
        showServisModal = true;
    }

    private void DetayAc(Hareket h)
    {
        detayHareket = h;
        showDetayModal = true;
    }

    private void DuzenleHareket(Hareket h)
    {
        showDetayModal = false;
        if (h.Kaynak == "Masraf")
        {
            Navigation.NavigateTo($"/arac-masraflari/{h.Id}");
        }
        else if (h.Kaynak == "PersonelMasraf")
        {
            Navigation.NavigateTo("/personel-odenecekler");
        }
        else
        {
            var s = servisler.FirstOrDefault(x => x.Id == h.Id);
            if (s == null) return;
            editingServis = new ServisKaydi
            {
                Id = s.Id,
                AracId = s.AracId,
                ServisTarihi = s.ServisTarihi,
                ServisciCariId = s.ServisciCariId,
                ServisTipi = s.ServisTipi,
                ServisAdi = s.ServisAdi,
                Aciklama = s.Aciklama,
                IscilikTutari = s.IscilikTutari,
                KdvOrani = s.KdvOrani,
                KdvTutar = s.KdvTutar,
                ToplamTutar = s.ToplamTutar,
                KdvManuelMi = s.KdvManuelMi,
                Kilometre = s.Kilometre,
                Durum = s.Durum,
                GarantiKapsaminda = s.GarantiKapsaminda,
                Notlar = s.Notlar,
                Parcalar = s.Parcalar.Select(p => new ServisParca
                {
                    Id = p.Id,
                    ServisKaydiId = p.ServisKaydiId,
                    StokKartiId = p.StokKartiId,
                    KalemTipi = p.KalemTipi,
                    ParcaAdi = p.ParcaAdi,
                    Miktar = p.Miktar,
                    Birim = p.Birim,
                    BirimFiyat = p.BirimFiyat,
                    KdvOrani = p.KdvOrani,
                    StogaKaydet = p.StogaKaydet,
                    Aciklama = p.Aciklama
                }).ToList()
            };
            if (!editingServis.Parcalar.Any())
                KalemEkle(ServisKalemTipi.Malzeme);
            ServisKalemleriniHesapla();
            showServisModal = true;
        }
    }

    private void KalemEkle(ServisKalemTipi tip)
    {
        if (editingServis == null)
            return;

        editingServis.Parcalar.Add(new ServisParca
        {
            KalemTipi = tip,
            ParcaAdi = string.Empty,
            Miktar = 1,
            Birim = tip == ServisKalemTipi.Iscilik ? "Saat" : "Adet",
            BirimFiyat = 0,
            KdvOrani = 20,
            StogaKaydet = false
        });

        ServisKalemleriniHesapla();
    }

    private void KalemSil(ServisParca kalem)
    {
        if (editingServis == null)
            return;

        editingServis.Parcalar.Remove(kalem);
        ServisKalemleriniHesapla();
    }

    private static decimal ServisKalemNet(ServisParca kalem)
        => (kalem.Miktar <= 0 ? 1 : kalem.Miktar) * kalem.BirimFiyat;

    private static decimal ServisKalemKdv(ServisParca kalem)
        => ServisKalemNet(kalem) * kalem.KdvOrani / 100;

    private void ServisKalemleriniHesapla()
    {
        if (editingServis == null)
            return;

        foreach (var kalem in editingServis.Parcalar)
        {
            if (kalem.Miktar <= 0)
                kalem.Miktar = 1;
            if (string.IsNullOrWhiteSpace(kalem.Birim))
                kalem.Birim = kalem.KalemTipi == ServisKalemTipi.Iscilik ? "Saat" : "Adet";
            if (kalem.KalemTipi == ServisKalemTipi.Iscilik)
                kalem.StogaKaydet = false;
        }

        editingServis.ParcaTutari = editingServis.Parcalar
            .Where(k => k.KalemTipi == ServisKalemTipi.Malzeme)
            .Sum(ServisKalemNet);

        editingServis.IscilikTutari = editingServis.Parcalar
            .Where(k => k.KalemTipi == ServisKalemTipi.Iscilik)
            .Sum(ServisKalemNet);

        var kdvToplami = editingServis.Parcalar.Sum(ServisKalemKdv);
        if (!editingServis.KdvManuelMi)
            editingServis.KdvTutar = kdvToplami;

        var netToplam = editingServis.ParcaTutari + editingServis.IscilikTutari;
        editingServis.KdvOrani = netToplam > 0 ? Math.Round(editingServis.KdvTutar / netToplam * 100, 2) : 0;
        editingServis.ToplamTutar = netToplam + editingServis.KdvTutar;
    }

    private async Task SaveServis()
    {
        if (editingServis == null || editingServis.AracId == 0) return;
        try
        {
            ServisKalemleriniHesapla();
            isSaving = true;
            if (editingServis.Id > 0)
            {
                await StokService.UpdateServisKaydiAsync(editingServis);
                ToastService.ShowSuccess("Servis kaydı güncellendi");
            }
            else
            {
                await StokService.CreateServisKaydiAsync(editingServis);
                ToastService.ShowSuccess("Servis kaydı oluşturuldu");
            }
            showServisModal = false;
            editingServis = null;
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt hatası: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CloseServisModal()
    {
        showServisModal = false;
        editingServis = null;
    }

    private async Task SilOnayla()
    {
        if (silinecekHareket == null) return;
        try
        {
            if (silinecekHareket.Kaynak == "Masraf")
                await AracMasrafService.DeleteAsync(silinecekHareket.Id);
            else if (silinecekHareket.Kaynak == "PersonelMasraf")
                await HareketService.DeleteAsync(silinecekHareket.Id);
            else
                await StokService.DeleteServisKaydiAsync(silinecekHareket.Id);
            ToastService.ShowSuccess("Kayıt silindi.");
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme hatası: {ex.Message}");
        }
        finally
        {
            showDeleteModal = false;
            silinecekHareket = null;
        }
    }

    private async Task ExcelIndir()
    {
        try
        {
            var rows = SiraliHareketler.Select(h => new
            {
                Tarih = h.Tarih.ToString("dd.MM.yyyy"),
                Kaynak = h.Kaynak,
                Plaka = h.Plaka,
                MarkaModel = h.MarkaModel,
                Kategori = h.Kategori,
                Aciklama = h.Aciklama,
                BelgeNo = h.BelgeNo,
                Tutar = h.Tutar,
                OdemeKaynak = GetOdemeKaynakAdi(h.OdemeKaynak),
                Odeyen = h.Odeyen,
                MuhasebeFisi = h.MuhasebeFisVar ? "Var" : "Yok",
                ArizaKaynakli = h.ArizaKaynaklimi ? "Evet" : "Hayır"
            }).ToList();

            var bytes = ExcelService.ExportToExcel(rows, "BakimOnarim");
            var ad = $"BakimOnarim_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", ad, Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel hatası: {ex.Message}");
        }
    }

    // ── Yardımcılar ──────────────────────────────────────────────────
    private static string GetMuhatapText(AracMasraf m)
    {
        if (m.Sofor != null) return $"Personel: {m.Sofor.TamAd}";
        if (m.Cari?.CariTipi == CariTipi.Personel) return $"Personel: {m.Cari.Unvan}";
        if (m.Cari != null) return $"Cari: {m.Cari.Unvan}";
        return "Kasa";
    }

    private static string GetOdemeKaynakAdi(MasrafOdemeKaynak k) => k switch
    {
        MasrafOdemeKaynak.Kasa => "Kasa",
        MasrafOdemeKaynak.Banka => "Banka",
        MasrafOdemeKaynak.PersonelCebinden => "Personel Cebinden",
        _ => k.ToString()
    };

    private static string GetOdemeKaynakBadge(MasrafOdemeKaynak k) => k switch
    {
        MasrafOdemeKaynak.Kasa => "bg-success",
        MasrafOdemeKaynak.Banka => "bg-primary",
        MasrafOdemeKaynak.PersonelCebinden => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string GetServisTipiAdi(ServisTipi tip) => tip switch
    {
        ServisTipi.PeriyodikBakim => "Periyodik Bakım",
        ServisTipi.Onarim => "Onarım",
        ServisTipi.Kasko => "Kasko",
        ServisTipi.TrafikSigortasi => "Trafik Sigortası",
        ServisTipi.Muayene => "Muayene",
        ServisTipi.LastikDegisimi => "Lastik Değişimi",
        ServisTipi.YagDegisimi => "Yağ Değişimi",
        ServisTipi.FrenBakimi => "Fren Bakımı",
        ServisTipi.KlimaBakimi => "Klima Bakımı",
        ServisTipi.MotorBakimi => "Motor Bakımı",
        ServisTipi.KaportaBoya => "Kaporta/Boya",
        ServisTipi.CamDegisimi => "Cam Değişimi",
        ServisTipi.AkuDegisimi => "Akü Değişimi",
        ServisTipi.Cekici => "Çekici",
        _ => "Diğer"
    };

    private static string GetDurumAdi(ServisDurum durum) => durum switch
    {
        ServisDurum.Beklemede => "Beklemede",
        ServisDurum.Devam => "Devam Ediyor",
        ServisDurum.Tamamlandi => "Tamamlandı",
        ServisDurum.IptalEdildi => "İptal Edildi",
        _ => durum.ToString()
    };
}
