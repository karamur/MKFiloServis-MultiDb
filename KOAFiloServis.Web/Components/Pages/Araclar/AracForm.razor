    private string GetEvrakDurumClass(AracEvrak evrak)
    {
        if (evrak.EvrakKategorisi == EvrakKategorileri.Ruhsat) return "";
        if (!evrak.BitisTarihi.HasValue) return "";
        var gunKaldi = (evrak.BitisTarihi.Value - DateTime.Today).Days;
        if (gunKaldi < 0) return "text-danger fw-bold";
        if (gunKaldi <= 30) return "text-warning fw-bold";
        return "";
    }

    private string GetDosyaIkon(string? dosyaTipi) => dosyaTipi?.ToLower() switch
    {
        "pdf" => "bi-file-earmark-pdf text-danger",
        "jpg" or "jpeg" or "png" => "bi-file-earmark-image text-primary",
        "doc" or "docx" => "bi-file-earmark-word text-info",
        _ => "bi-file-earmark"
    };

    private string FormatDosyaBoyutu(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private string GetMimeType(string? extension) => extension?.ToLower() switch
    {
        "pdf" => "application/pdf",
        "jpg" or "jpeg" => "image/jpeg",
        "png" => "image/png",
        "doc" => "application/msword",
        "docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        _ => "application/octet-stream"
    };

