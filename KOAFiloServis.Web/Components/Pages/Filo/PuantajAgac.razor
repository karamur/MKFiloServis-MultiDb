@page "/filo/puantaj-agac"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Models
@using KOAFiloServis.Web.Services.Interfaces
@rendermode InteractiveServer
@inject IPuantajFaturaRaporService RaporService
@inject IPuantajIstisnaService IstisnaService
@inject IFirmaService FirmaService

<PageTitle>Puantaj Ağacı</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-diagram-3 me-2"></i>Puantaj Ağacı</h4>
    </div>

    @if (_hata != null)
    {
        <div class="alert alert-danger">@_hata</div>
    }

    @if (_yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (_agac != null && _agac.Any())
    {
        foreach (var seviye1 in _agac)
        {
            <div class="card mb-3">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-building me-1"></i>@seviye1.Etiket</span>
                    <span class="badge bg-light text-dark">
                        @seviye1.SatirSayisi kayıt |
                        @seviye1.ToplamSefer sefer |
                        ₺@seviye1.NetTutar.ToString("N2")
                        @if (seviye1.ToplamCeza > 0) { <span class="text-danger ms-2">⚠ @seviye1.ToplamCeza.ToString("N0")₺ ceza</span> }
                        @if (seviye1.ToplamMasraf > 0) { <span class="text-warning ms-2">💰 @seviye1.ToplamMasraf.ToString("N0")₺ masraf</span> }
                    </span>
                </div>
                <div class="card-body p-2">
                    @foreach (var seviye2 in seviye1.Cocuklar ?? new())
                    {
                        <div class="ms-3 mb-2">
                            <div class="fw-bold text-primary">
                                🚌 @seviye2.Etiket
                                <small class="text-muted ms-2">@seviye2.SatirSayisi güzergah, @seviye2.ToplamSefer sefer</small>
                            </div>
                            @foreach (var satir in seviye2.Satirlar ?? new())
                            {
                                <div class="ms-4 border-start ps-3 mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-secondary">@satir.GuzergahAdi</span>
                                        <span class="text-muted small">@satir.SoforAdi</span>
                                        <button class="btn btn-sm @(_seciliSatir?.KayitId == satir.KayitId ? "btn-warning" : "btn-outline-secondary")"
                                                @onclick="() => SatirSec(satir)" title="İstisna ekle/düzenle">
                                            @if (satir.IstisnaSayisi > 0)
                                            {
                                                <span>⚠️ @satir.IstisnaSayisi</span>
                                            }
                                            else
                                            {
                                                <span>+</span>
                                            }
                                        </button>
                                    </div>
                                    <div class="small text-muted ms-3">
                                        Gün: @satir.ToplamSefer sefer |
                                        Gelir: ₺@satir.ToplamGelir.ToString("N2") |
                                        Gider: ₺@satir.ToplamGider.ToString("N2")
                                        @if (satir.IstisnaSayisi > 0)
                                        {
                                            <span class="ms-2">
                                                @if (satir.CezaTutar > 0) { <span class="text-danger">⚠ Ceza: ₺@satir.CezaTutar.ToString("N2")</span> }
                                                @if (satir.MasrafTutar > 0) { <span class="text-warning">💰 Masraf: ₺@satir.MasrafTutar.ToString("N2")</span> }
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(satir.IstisnaOzeti))
                                        {
                                            <br /><small class="text-info">İstisna: @satir.IstisnaOzeti</small>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">Seçilen dönem için puantaj kaydı bulunamadı. Lütfen önce puantaj hesaplaması yapın.</div>
    }
</div>

@if (_seciliSatir != null)
{
    <IstisnaModal Satir="@_seciliSatir"
                  OnKaydedildi="IstisnaKaydedildi"
                  OnKapat="() => _seciliSatir = null" />
}

@code {
    private List<PuantajFaturaAgacNodeDto>? _agac;
    private PuantajFaturaSatirDto? _seciliSatir;
    private string? _hata;
    private bool _yukleniyor;

    protected override async Task OnInitializedAsync()
    {
        _yukleniyor = true;
        try
        {
            var firma = FirmaService.GetAktifFirma();
            var bugun = DateTime.Today;
            var yil = firma.AktifDonemYil > 0 ? firma.AktifDonemYil : bugun.Year;
            var ay = firma.AktifDonemAy > 0 ? firma.AktifDonemAy : bugun.Month;
            if (ay == 1) { ay = 12; yil--; } else { ay--; } // Önceki ay

            var request = new PuantajFaturaRaporRequest
            {
                Yil = yil, Ay = ay,
                Agac = PuantajFaturaAgacYapisi.CariAracGuzergah,
                Yon = PuantajFaturaYonu.Tumu,
            };
            _agac = await RaporService.GetAgacAsync(request);
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    private void SatirSec(PuantajFaturaSatirDto satir) => _seciliSatir = satir;

    private async Task IstisnaKaydedildi()
    {
        _seciliSatir = null;
        await OnInitializedAsync();
        StateHasChanged();
    }
}
