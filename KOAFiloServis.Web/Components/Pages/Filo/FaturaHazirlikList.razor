@page "/filo/fatura-hazirlik"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Models
@using KOAFiloServis.Web.Services.Interfaces
@rendermode InteractiveServer
@inject IPuantajFaturaHazirlikService HazirlikService
@inject IFirmaService FirmaService

<PageTitle>Fatura Hazırlık</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-file-earmark-text me-2"></i>Fatura Hazırlık</h4>
        <button class="btn btn-primary btn-sm" @onclick="YeniHazirlikAsync" disabled="@_islemYapiliyor">
            <i class="bi bi-plus-lg me-1"></i>Yeni Hazırlık Oluştur
        </button>
    </div>

    @if (_hata != null) { <div class="alert alert-danger">@_hata</div> }
    @if (_bilgi != null) { <div class="alert alert-success">@_bilgi</div> }

    @if (_yukleniyor) { <div class="text-center py-5"><div class="spinner-border"></div></div> }
    else if (_hazirliklar.Any())
    {
        <table class="table table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th>ID</th><th>Dönem</th><th>Yön</th><th>Ağaç</th><th>Durum</th>
                    <th class="text-end">Sefer</th><th class="text-end">Gelir</th><th class="text-end">Gider</th>
                    <th class="text-end">KDV</th><th class="text-end">Kesinti</th><th class="text-end">Net</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in _hazirliklar)
                {
                    <tr>
                        <td>@h.Id</td>
                        <td>@h.Yil/@h.Ay.ToString("00")</td>
                        <td>@h.FaturaYonu</td>
                        <td>@h.AgacYapisi</td>
                        <td>
                            @if (h.Durum == PuantajFaturaHazirlikDurum.Taslak) { <span class="badge bg-secondary">Taslak</span> }
                            else if (h.Durum == PuantajFaturaHazirlikDurum.Onaylandi) { <span class="badge bg-success">Onaylandı</span> }
                            else if (h.Durum == PuantajFaturaHazirlikDurum.Faturalasti) { <span class="badge bg-primary">Faturalaştı</span> }
                        </td>
                        <td class="text-end">@h.ToplamSefer</td>
                        <td class="text-end">₺@h.ToplamGelir.ToString("N2")</td>
                        <td class="text-end">₺@h.ToplamGider.ToString("N2")</td>
                        <td class="text-end">₺@h.ToplamKdv.ToString("N2")</td>
                        <td class="text-end">₺@h.ToplamKesinti.ToString("N2")</td>
                        <td class="text-end fw-bold">₺@h.NetTutar.ToString("N2")</td>
                        <td>
                            @if (h.Durum == PuantajFaturaHazirlikDurum.Taslak)
                            {
                                <button class="btn btn-success btn-sm me-1" @onclick="() => OnaylaAsync(h.Id)" disabled="@_islemYapiliyor">Onayla</button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => SilAsync(h.Id)" disabled="@_islemYapiliyor">Sil</button>
                            }
                            else if (h.Durum == PuantajFaturaHazirlikDurum.Onaylandi)
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => FaturalastiAsync(h.Id)" disabled="@_islemYapiliyor">Faturalaştır</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">Henüz fatura hazırlık kaydı yok. "Yeni Hazırlık Oluştur" butonuna tıklayın.</div>
    }
</div>

@code {
    private List<PuantajFaturaHazirlik> _hazirliklar = new();
    private string? _hata, _bilgi;
    private bool _yukleniyor, _islemYapiliyor;

    protected override async Task OnInitializedAsync()
    {
        _yukleniyor = true;
        try
        {
            var firma = FirmaService.GetAktifFirma();
            var bugun = DateTime.Today;
            var yil = firma.AktifDonemYil > 0 ? firma.AktifDonemYil : bugun.Year;
            var ay = firma.AktifDonemAy > 0 ? firma.AktifDonemAy : bugun.Month;
            if (ay == 1) { ay = 12; yil--; } else { ay--; }
            _hazirliklar = await HazirlikService.GetByDonemAsync(yil, ay);
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    private async Task YeniHazirlikAsync()
    {
        _islemYapiliyor = true; _bilgi = null; _hata = null;
        try
        {
            var firma = FirmaService.GetAktifFirma();
            var bugun = DateTime.Today;
            var yil = firma.AktifDonemYil > 0 ? firma.AktifDonemYil : bugun.Year;
            var ay = firma.AktifDonemAy > 0 ? firma.AktifDonemAy : bugun.Month;
            if (ay == 1) { ay = 12; yil--; } else { ay--; }

            var h = new PuantajFaturaHazirlik { Yil = yil, Ay = ay, FaturaYonu = PuantajFaturaYonu.Tumu, FirmaId = firma.FirmaId };
            await HazirlikService.CreateAsync(h);
            _bilgi = "Hazırlık oluşturuldu.";
            _hazirliklar = await HazirlikService.GetByDonemAsync(yil, ay);
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _islemYapiliyor = false; }
    }

    private async Task OnaylaAsync(int id)
    {
        _islemYapiliyor = true; _hata = null;
        try { await HazirlikService.OnaylaAsync(id, "Kullanici"); _bilgi = "Onaylandı."; await OnInitializedAsync(); }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _islemYapiliyor = false; }
    }

    private async Task FaturalastiAsync(int id)
    {
        _islemYapiliyor = true; _hata = null;
        try { await HazirlikService.FaturalastiAsync(id); _bilgi = "Faturalaştı."; await OnInitializedAsync(); }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _islemYapiliyor = false; }
    }

    private async Task SilAsync(int id)
    {
        _islemYapiliyor = true; _hata = null;
        try { await HazirlikService.DeleteAsync(id); await OnInitializedAsync(); }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _islemYapiliyor = false; }
    }
}
