@page "/filo/puantaj"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject ISoforService SoforService
@inject IAracService AracService
@inject IGuzergahService GuzergahService
@inject IServisCalismaService ServisCalismaService
@inject ICariService CariService
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Filo Puantaj</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-journal-check me-2"></i>Filo Puantaj</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/servis-calismalari">Servis Çalışmaları</a></li>
                    <li class="breadcrumb-item active">Filo Puantaj</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a href="/servis-calismalari" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-list-ul me-1"></i>Tüm Kayıtlar
            </a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Sol panel: Giriş formu -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Yeni Kayıt</h5>
                </div>
                <div class="card-body">
                    <!-- Tarih & Sefer Türü -->
                    <div class="row g-2 mb-3">
                        <div class="col-7">
                            <label class="form-label fw-semibold">Tarih <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" @bind="kayitTarihi" />
                        </div>
                        <div class="col-5">
                            <label class="form-label fw-semibold">Sefer</label>
                            <select class="form-select" @bind="secilenServisTuru">
                                <option value="@ServisTuru.Sabah">Sabah</option>
                                <option value="@ServisTuru.Aksam">Akşam</option>
                                <option value="@ServisTuru.SabahAksam">Sabah+Akşam</option>
                                <option value="@ServisTuru.Ozel">Özel</option>
                            </select>
                        </div>
                    </div>

                    <!-- Personel Seçimi -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Personel <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Ad, soyad veya kod ile ara..."
                                   value="@personelArama" @oninput="PersonelAramaGuncelle" />
                            @if (secilenSoforId > 0)
                            {
                                <button class="btn btn-outline-secondary" type="button" @onclick="PersonelTemizle" title="Temizle">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>
                        @if (personelArama.Length >= 1 && filtreliSoforler.Any() && secilenSoforId == 0)
                        {
                            <div class="list-group mt-1 shadow-sm" style="position:absolute;z-index:1000;width:calc(100% - 3rem);">
                                @foreach (var s in filtreliSoforler.Take(8))
                                {
                                    <button type="button" class="list-group-item list-group-item-action py-1"
                                            @onclick="() => PersonelSec(s)">
                                        <strong>@s.TamAd</strong>
                                        <small class="text-muted ms-2">@s.SoforKodu</small>
                                    </button>
                                }
                            </div>
                        }
                        @if (secilenSoforId > 0)
                        {
                            <div class="mt-1">
                                <span class="badge bg-success fs-6 px-3 py-2">
                                    <i class="bi bi-person-check me-1"></i>@secilenSoforAd
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Araç -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Araç / Plaka <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Plaka ara..."
                                   value="@aracArama" @oninput="AracAramaGuncelle"
                                   disabled="@(secilenSoforId == 0)" />
                            @if (secilenAracId > 0)
                            {
                                <button class="btn btn-outline-secondary" type="button" @onclick="AracTemizle" title="Temizle">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                            <button class="btn btn-outline-success" type="button" @onclick="YeniAracModalAc" title="Yeni araç ekle" disabled="@(secilenSoforId == 0)">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        @if (aracArama.Length >= 1 && filtreliAraclar.Any() && secilenAracId == 0)
                        {
                            <div class="list-group mt-1 shadow-sm" style="position:absolute;z-index:1000;width:calc(100% - 3rem);">
                                @foreach (var a in filtreliAraclar.Take(8))
                                {
                                    <button type="button" class="list-group-item list-group-item-action py-1"
                                            @onclick="() => AracSec(a)">
                                        <strong>@a.AktifPlaka</strong>
                                        <small class="text-muted ms-2">@a.Marka @a.Model @a.ModelYili</small>
                                    </button>
                                }
                            </div>
                        }
                        @if (secilenAracId > 0)
                        {
                            <div class="mt-1">
                                <span class="badge bg-primary fs-6 px-3 py-2">
                                    <i class="bi bi-truck me-1"></i>@secilenAracPlaka
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Güzergah -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Güzergah <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Güzergah ara veya yaz..."
                                   value="@guzergahArama" @oninput="GuzergahAramaGuncelle" />
                            @if (secilenGuzergahId > 0)
                            {
                                <button class="btn btn-outline-secondary" type="button" @onclick="GuzergahTemizle" title="Temizle">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                            <button class="btn btn-outline-success" type="button" @onclick="HizliGuzergahModalAc" title="Hızlı güzergah ekle">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        @if (guzergahArama.Length >= 1 && filtreliGuzergahlar.Any() && secilenGuzergahId == 0)
                        {
                            <div class="list-group mt-1 shadow-sm" style="position:absolute;z-index:1000;width:calc(100% - 3rem);">
                                @foreach (var g in filtreliGuzergahlar.Take(8))
                                {
                                    <button type="button" class="list-group-item list-group-item-action py-1"
                                            @onclick="() => GuzergahSec(g)">
                                        <strong>@g.GuzergahAdi</strong>
                                        <small class="text-muted ms-2">@g.BirimFiyat.ToString("N0") ₺</small>
                                        @if (!string.IsNullOrWhiteSpace(g.BaslangicNoktasi) || !string.IsNullOrWhiteSpace(g.BitisNoktasi))
                                        {
                                            <small class="text-muted ms-1">(@g.BaslangicNoktasi → @g.BitisNoktasi)</small>
                                        }
                                    </button>
                                }
                            </div>
                        }
                        @if (secilenGuzergahId > 0)
                        {
                            <div class="mt-1">
                                <span class="badge bg-info fs-6 px-3 py-2">
                                    <i class="bi bi-sign-turn-right me-1"></i>@secilenGuzergahAdi
                                    @if (secilenGuzergahFiyat > 0)
                                    {
                                        <span class="ms-2">@secilenGuzergahFiyat.ToString("N0") ₺</span>
                                    }
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Fiyat (opsiyonel override) -->
                    <div class="mb-3">
                        <label class="form-label">Fiyat Geçersiz Kıl <small class="text-muted">(boş bırakılırsa güzergah fiyatı)</small></label>
                        <div class="input-group">
                            <span class="input-group-text">₺</span>
                            <input type="number" class="form-control" placeholder="@(secilenGuzergahFiyat > 0 ? secilenGuzergahFiyat.ToString("N0") : "Güzergah fiyatı")"
                                   @bind="overrideFiyat" min="0" step="0.01" />
                        </div>
                    </div>

                    <!-- Notlar -->
                    <div class="mb-3">
                        <label class="form-label">Notlar</label>
                        <input type="text" class="form-control" placeholder="İsteğe bağlı not..." @bind="notlar" maxlength="500" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="KaydetVeDevam"
                            disabled="@(secilenSoforId == 0 || secilenAracId == 0 || secilenGuzergahId == 0 || isSaving)">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-plus-circle me-1"></i>Kaydet & Devam
                    </button>
                </div>
            </div>
        </div>

        <!-- Sağ panel: Bugünün kayıtları -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-calendar-day me-2"></i>
                        @kayitTarihi.ToString("dd MMMM yyyy dddd")
                    </h5>
                    <span class="badge bg-secondary">@gunKayitlari.Count kayıt</span>
                </div>
                <div class="card-body p-0">
                    @if (isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary spinner-border-sm"></div>
                        </div>
                    }
                    else if (!gunKayitlari.Any())
                    {
                        <div class="p-3 text-muted text-center">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            Bu tarih için kayıt yok.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Personel</th>
                                        <th>Araç</th>
                                        <th>Güzergah</th>
                                        <th>Sefer</th>
                                        <th class="text-end">Fiyat</th>
                                        <th class="text-center">Durum</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var kayit in gunKayitlari)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@kayit.Sofor?.TamAd</strong>
                                                <br /><small class="text-muted">@kayit.Sofor?.SoforKodu</small>
                                            </td>
                                            <td><span class="badge bg-primary">@kayit.Arac?.AktifPlaka</span></td>
                                            <td>
                                                @kayit.Guzergah?.GuzergahAdi
                                                @if (kayit.Fiyat.HasValue)
                                                {
                                                    <small class="text-warning ms-1">(özel)</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge @GetServisTuruBadge(kayit.ServisTuru)">
                                                    @GetServisTuruAdi(kayit.ServisTuru)
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                @((kayit.Fiyat ?? kayit.Guzergah?.BirimFiyat ?? 0).ToString("N0")) ₺
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @GetDurumBadge(kayit.Durum)">
                                                    @GetDurumAdi(kayit.Durum)
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => KayitSil(kayit.Id)" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="4"><strong>Toplam</strong></td>
                                        <td class="text-end">
                                            <strong>
                                                @gunKayitlari.Sum(k => k.Fiyat ?? k.Guzergah?.BirimFiyat ?? 0).ToString("N0") ₺
                                            </strong>
                                        </td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* Hızlı Güzergah Ekleme Modal *@
@if (showGuzergahModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-sign-turn-right me-2"></i>Hızlı Güzergah Ekle</h5>
                    <button type="button" class="btn-close" @onclick="() => showGuzergahModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Güzergah Adı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="yeniGuzergahAdi" placeholder="Örn: Kadıköy - Ataşehir" maxlength="200" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label">Başlangıç Noktası</label>
                            <input type="text" class="form-control" @bind="yeniGuzergahBaslangic" placeholder="Nereden?" maxlength="200" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Bitiş Noktası</label>
                            <input type="text" class="form-control" @bind="yeniGuzergahBitis" placeholder="Nereye?" maxlength="200" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Birim Fiyat (₺)</label>
                        <input type="number" class="form-control" @bind="yeniGuzergahFiyat" min="0" step="0.01" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Müşteri (Cari) <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="yeniGuzergahCariId">
                            <option value="0">-- Cari Seçin --</option>
                            @foreach (var cari in cariler)
                            {
                                <option value="@cari.Id">@cari.Unvan</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showGuzergahModal = false">İptal</button>
                    <button type="button" class="btn btn-success" @onclick="HizliGuzergahKaydet"
                            disabled="@(string.IsNullOrWhiteSpace(yeniGuzergahAdi) || yeniGuzergahCariId == 0 || isGuzergahSaving)">
                        @if (isGuzergahSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Ekle & Seç
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Yeni Araç Ekleme Modal *@
@if (showAracModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-truck me-2"></i>Araç Seç / Eşleştir</h5>
                    <button type="button" class="btn-close" @onclick="() => showAracModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Plaka Ara</label>
                        <input type="text" class="form-control" @bind="aracModalArama"
                               @oninput="AracModalAramaGuncelle" placeholder="Plaka yazın..." />
                    </div>
                    @if (aracModalSonuclar.Any())
                    {
                        <div class="list-group">
                            @foreach (var a in aracModalSonuclar)
                            {
                                <button type="button" class="list-group-item list-group-item-action"
                                        @onclick="() => AracModalSec(a)">
                                    <strong>@a.AktifPlaka</strong>
                                    <small class="text-muted ms-2">@a.Marka @a.Model @a.ModelYili</small>
                                    @if (!a.Aktif) { <span class="badge bg-secondary ms-1">Pasif</span> }
                                </button>
                            }
                        </div>
                    }
                    else if (aracModalArama.Length > 0)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-1"></i>Araç bulunamadı.
                            <a href="/araclar/yeni" class="alert-link ms-2">Yeni araç ekle</a>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showAracModal = false">İptal</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Form alanları
    private DateTime kayitTarihi = DateTime.Today;
    private ServisTuru secilenServisTuru = ServisTuru.Sabah;

    // Personel
    private string personelArama = "";
    private int secilenSoforId = 0;
    private string secilenSoforAd = "";
    private List<Sofor> tumSoforler = new();
    private List<Sofor> filtreliSoforler = new();

    // Araç
    private string aracArama = "";
    private int secilenAracId = 0;
    private string secilenAracPlaka = "";
    private List<Arac> tumAraclar = new();
    private List<Arac> filtreliAraclar = new();

    // Güzergah
    private string guzergahArama = "";
    private int secilenGuzergahId = 0;
    private string secilenGuzergahAdi = "";
    private decimal secilenGuzergahFiyat = 0;
    private List<Guzergah> tumGuzergahlar = new();
    private List<Guzergah> filtreliGuzergahlar = new();

    // Ek alanlar
    private decimal? overrideFiyat;
    private string notlar = "";
    private bool isSaving = false;
    private bool isLoading = false;

    // Günlük kayıtlar
    private List<ServisCalisma> gunKayitlari = new();

    // Güzergah modal
    private bool showGuzergahModal = false;
    private string yeniGuzergahAdi = "";
    private string yeniGuzergahBaslangic = "";
    private string yeniGuzergahBitis = "";
    private decimal yeniGuzergahFiyat = 0;
    private int yeniGuzergahCariId = 0;
    private bool isGuzergahSaving = false;
    private List<Cari> cariler = new();

    // Araç modal
    private bool showAracModal = false;
    private string aracModalArama = "";
    private List<Arac> aracModalSonuclar = new();

    protected override async Task OnInitializedAsync()
    {
        var tasks = new List<Task>
        {
            LoadSoforler(),
            LoadAraclar(),
            LoadGuzergahlar(),
            LoadCariler()
        };
        await Task.WhenAll(tasks);
        await LoadGunKayitlari();
    }

    private async Task LoadSoforler()
    {
        tumSoforler = await SoforService.GetActiveAsync();
    }

    private async Task LoadAraclar()
    {
        tumAraclar = await AracService.GetAllAsync();
    }

    private async Task LoadGuzergahlar()
    {
        tumGuzergahlar = await GuzergahService.GetActiveAsync();
    }

    private async Task LoadCariler()
    {
        cariler = await CariService.GetAllAsync();
    }

    private async Task LoadGunKayitlari()
    {
        isLoading = true;
        try
        {
            gunKayitlari = await ServisCalismaService.GetByDateRangeAsync(
                kayitTarihi.Date, kayitTarihi.Date.AddDays(1).AddSeconds(-1));
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıtlar yüklenemedi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // Personel arama
    private void PersonelAramaGuncelle(ChangeEventArgs e)
    {
        personelArama = e.Value?.ToString() ?? "";
        secilenSoforId = 0;
        secilenSoforAd = "";
        if (personelArama.Length >= 1)
        {
            var aranan = personelArama.ToLowerInvariant();
            filtreliSoforler = tumSoforler.Where(s =>
                (s.Ad + " " + s.Soyad).ToLowerInvariant().Contains(aranan) ||
                (s.SoforKodu ?? "").ToLowerInvariant().Contains(aranan))
                .Take(8).ToList();
        }
        else
        {
            filtreliSoforler = new();
        }
    }

    private async Task PersonelSec(Sofor sofor)
    {
        secilenSoforId = sofor.Id;
        secilenSoforAd = sofor.TamAd;
        personelArama = sofor.TamAd;
        filtreliSoforler = new();

        // Personelin aktif araç atamasını yükle
        await PersonelAracAtamasiniYukle(sofor.Id);
    }

    private void PersonelTemizle()
    {
        secilenSoforId = 0;
        secilenSoforAd = "";
        personelArama = "";
        filtreliSoforler = new();
        AracTemizle();
    }

    private async Task PersonelAracAtamasiniYukle(int soforId)
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var atama = await ctx.PersonelAracAtamalari
                .Include(a => a.Arac)
                .Where(a => a.SoforId == soforId && a.Aktif)
                .OrderByDescending(a => a.BaslangicTarihi)
                .FirstOrDefaultAsync();

            if (atama?.Arac != null)
            {
                secilenAracId = atama.Arac.Id;
                secilenAracPlaka = atama.Arac.AktifPlaka ?? "";
                aracArama = secilenAracPlaka;
                filtreliAraclar = new();
            }
        }
        catch { /* sessizce devam et */ }
    }

    // Araç seçildiğinde aktif şoförü otomatik yükle (PersonelAracAtamalari)
    private async Task AracinSoforunuYukle(int aracId)
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var atama = await ctx.PersonelAracAtamalari
                .Include(a => a.Sofor)
                .Where(a => a.AracId == aracId && a.Aktif)
                .OrderByDescending(a => a.BaslangicTarihi)
                .FirstOrDefaultAsync();

            if (atama?.Sofor != null)
            {
                secilenSoforId = atama.Sofor.Id;
                secilenSoforAd = atama.Sofor.TamAd;
                personelArama = atama.Sofor.TamAd;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* sessizce devam et */ }
    }

    // Araç arama
    private void AracAramaGuncelle(ChangeEventArgs e)
    {
        aracArama = e.Value?.ToString() ?? "";
        secilenAracId = 0;
        secilenAracPlaka = "";
        if (aracArama.Length >= 1)
        {
            var aranan = aracArama.ToLowerInvariant();
            filtreliAraclar = tumAraclar.Where(a =>
                (a.AktifPlaka ?? "").ToLowerInvariant().Contains(aranan) ||
                (a.Marka ?? "").ToLowerInvariant().Contains(aranan))
                .Take(8).ToList();
        }
        else
        {
            filtreliAraclar = new();
        }
    }

    private void AracSec(Arac arac)
    {
        secilenAracId = arac.Id;
        secilenAracPlaka = arac.AktifPlaka ?? "";
        aracArama = secilenAracPlaka;
        filtreliAraclar = new();
        _ = AracinSoforunuYukle(arac.Id);
    }

    private void AracTemizle()
    {
        secilenAracId = 0;
        secilenAracPlaka = "";
        aracArama = "";
        filtreliAraclar = new();
    }

    // Güzergah arama
    private void GuzergahAramaGuncelle(ChangeEventArgs e)
    {
        guzergahArama = e.Value?.ToString() ?? "";
        secilenGuzergahId = 0;
        secilenGuzergahAdi = "";
        secilenGuzergahFiyat = 0;
        if (guzergahArama.Length >= 1)
        {
            var aranan = guzergahArama.ToLowerInvariant();
            filtreliGuzergahlar = tumGuzergahlar.Where(g =>
                (g.GuzergahAdi ?? "").ToLowerInvariant().Contains(aranan) ||
                (g.BaslangicNoktasi ?? "").ToLowerInvariant().Contains(aranan) ||
                (g.BitisNoktasi ?? "").ToLowerInvariant().Contains(aranan))
                .Take(8).ToList();
        }
        else
        {
            filtreliGuzergahlar = new();
        }
    }

    private void GuzergahSec(Guzergah g)
    {
        secilenGuzergahId = g.Id;
        secilenGuzergahAdi = g.GuzergahAdi;
        secilenGuzergahFiyat = g.BirimFiyat;
        guzergahArama = g.GuzergahAdi;
        filtreliGuzergahlar = new();
    }

    private void GuzergahTemizle()
    {
        secilenGuzergahId = 0;
        secilenGuzergahAdi = "";
        secilenGuzergahFiyat = 0;
        guzergahArama = "";
        filtreliGuzergahlar = new();
    }

    // Sefer çakışma kontrolü (aynı gün, aynı sefer dilimi, aynı şoför veya araç)
    private static bool ServisCakisir(ServisTuru a, ServisTuru b)
    {
        if (a == b) return true;
        if (a == ServisTuru.Ozel || b == ServisTuru.Ozel) return false;
        if (a == ServisTuru.SabahAksam && (b == ServisTuru.Sabah || b == ServisTuru.Aksam)) return true;
        if (b == ServisTuru.SabahAksam && (a == ServisTuru.Sabah || a == ServisTuru.Aksam)) return true;
        return false;
    }

    private List<ServisCalisma> CakisanKayitlar()
    {
        if (secilenSoforId == 0 && secilenAracId == 0) return new();
        return gunKayitlari
            .Where(k => ServisCakisir(k.ServisTuru, secilenServisTuru) &&
                        ((secilenSoforId > 0 && k.SoforId == secilenSoforId) ||
                         (secilenAracId > 0 && k.AracId == secilenAracId)))
            .ToList();
    }

    // Kaydet & devam
    private async Task KaydetVeDevam()
    {
        if (secilenSoforId == 0 || secilenAracId == 0 || secilenGuzergahId == 0) return;

        // Çakışma varsa kullanıcıdan onay al
        var cakisan = CakisanKayitlar();
        if (cakisan.Any())
        {
            var ilk = cakisan.First();
            var mesaj = $"Bu tarih ve sefer için çakışma tespit edildi:\n\n" +
                        $"• {GetServisTuruAdi(ilk.ServisTuru)} - {ilk.Sofor?.TamAd} / {ilk.Arac?.AktifPlaka} ({ilk.Guzergah?.GuzergahAdi})\n" +
                        (cakisan.Count > 1 ? $"  ve {cakisan.Count - 1} kayıt daha...\n\n" : "\n") +
                        "Yine de kaydetmek istiyor musunuz?";
            var onay = await JS.InvokeAsync<bool>("confirm", mesaj);
            if (!onay) return;
        }

        isSaving = true;
        try
        {
            var kayit = new ServisCalisma
            {
                CalismaTarihi = kayitTarihi.Date,
                ServisTuru = secilenServisTuru,
                SoforId = secilenSoforId,
                AracId = secilenAracId,
                GuzergahId = secilenGuzergahId,
                Fiyat = overrideFiyat > 0 ? overrideFiyat : null,
                Durum = CalismaDurum.Tamamlandi,
                Notlar = string.IsNullOrWhiteSpace(notlar) ? null : notlar
            };

            await ServisCalismaService.CreateAsync(kayit);
            ToastService.ShowSuccess("Kayıt eklendi.");

            // Formu sıfırla (personel ve tarih korunsun)
            secilenGuzergahId = 0;
            secilenGuzergahAdi = "";
            secilenGuzergahFiyat = 0;
            guzergahArama = "";
            overrideFiyat = null;
            notlar = "";

            await LoadGunKayitlari();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt sırasında hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task KayitSil(int id)
    {
        try
        {
            await ServisCalismaService.DeleteAsync(id);
            ToastService.ShowSuccess("Kayıt silindi.");
            await LoadGunKayitlari();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme hatası: {ex.Message}");
        }
    }

    // Tarih değişince kayıtları yenile
    private DateTime _oncekiTarih = DateTime.Today;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && kayitTarihi != _oncekiTarih)
        {
            _oncekiTarih = kayitTarihi;
            await LoadGunKayitlari();
            StateHasChanged();
        }
    }

    // Hızlı güzergah modal
    private void HizliGuzergahModalAc()
    {
        yeniGuzergahAdi = guzergahArama;
        yeniGuzergahBaslangic = "";
        yeniGuzergahBitis = "";
        yeniGuzergahFiyat = 0;
        yeniGuzergahCariId = 0;
        showGuzergahModal = true;
    }

    private async Task HizliGuzergahKaydet()
    {
        if (string.IsNullOrWhiteSpace(yeniGuzergahAdi) || yeniGuzergahCariId == 0) return;

        isGuzergahSaving = true;
        try
        {
            var kod = await GuzergahService.GenerateNextKodAsync();
            var yeni = new Guzergah
            {
                GuzergahKodu = kod,
                GuzergahAdi = yeniGuzergahAdi.Trim(),
                BaslangicNoktasi = string.IsNullOrWhiteSpace(yeniGuzergahBaslangic) ? null : yeniGuzergahBaslangic.Trim(),
                BitisNoktasi = string.IsNullOrWhiteSpace(yeniGuzergahBitis) ? null : yeniGuzergahBitis.Trim(),
                BirimFiyat = yeniGuzergahFiyat,
                CariId = yeniGuzergahCariId,
                Aktif = true
            };

            var kaydedilen = await GuzergahService.CreateAsync(yeni);
            tumGuzergahlar.Add(kaydedilen);
            GuzergahSec(kaydedilen);
            showGuzergahModal = false;
            ToastService.ShowSuccess($"Güzergah eklendi: {kaydedilen.GuzergahAdi}");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Güzergah eklenirken hata: {ex.Message}");
        }
        finally
        {
            isGuzergahSaving = false;
        }
    }

    // Araç modal
    private void YeniAracModalAc()
    {
        aracModalArama = "";
        aracModalSonuclar = new();
        showAracModal = true;
    }

    private void AracModalAramaGuncelle(ChangeEventArgs e)
    {
        aracModalArama = e.Value?.ToString() ?? "";
        if (aracModalArama.Length >= 1)
        {
            var aranan = aracModalArama.ToLowerInvariant();
            aracModalSonuclar = tumAraclar.Where(a =>
                (a.AktifPlaka ?? "").ToLowerInvariant().Contains(aranan) ||
                (a.Marka ?? "").ToLowerInvariant().Contains(aranan))
                .Take(10).ToList();
        }
        else
        {
            aracModalSonuclar = new();
        }
    }

    private void AracModalSec(Arac arac)
    {
        AracSec(arac);
        showAracModal = false;
    }

    // Helper methods
    private static string GetServisTuruAdi(ServisTuru tur) => tur switch
    {
        ServisTuru.Sabah => "Sabah",
        ServisTuru.Aksam => "Akşam",
        ServisTuru.SabahAksam => "Sabah+Akşam",
        ServisTuru.Ozel => "Özel",
        _ => tur.ToString()
    };

    private static string GetServisTuruBadge(ServisTuru tur) => tur switch
    {
        ServisTuru.Sabah => "bg-warning text-dark",
        ServisTuru.Aksam => "bg-info text-dark",
        ServisTuru.SabahAksam => "bg-primary",
        ServisTuru.Ozel => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static string GetDurumAdi(CalismaDurum durum) => durum switch
    {
        CalismaDurum.Tamamlandi => "Tamamlandı",
        CalismaDurum.Planli => "Planlı",
        CalismaDurum.IptalEdildi => "İptal",
        CalismaDurum.ArizaNedeniyleYapilamadi => "Arıza",
        _ => durum.ToString()
    };

    private static string GetDurumBadge(CalismaDurum durum) => durum switch
    {
        CalismaDurum.Tamamlandi => "bg-success",
        CalismaDurum.Planli => "bg-info",
        CalismaDurum.IptalEdildi => "bg-danger",
        CalismaDurum.ArizaNedeniyleYapilamadi => "bg-warning text-dark",
        _ => "bg-secondary"
    };
