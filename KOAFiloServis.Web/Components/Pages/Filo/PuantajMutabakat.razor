@page "/puantaj/mutabakat"
@using System.Text
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.JSInterop
@inject IPuantajEslestirmeService EslestirmeService
@inject IFirmaService FirmaService
@inject ITasimaTedarikciService TedarikciService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Puantaj-Fatura Mutabakat</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-clipboard-data me-2"></i>Puantaj ↔ Fatura Mutabakat</h3>
        <button class="btn btn-success btn-sm" @onclick="ExportCsv" disabled="@(!HasData)">
            <i class="bi bi-file-earmark-spreadsheet me-1"></i> CSV / Excel İndir
        </button>
    </div>

    @if (eksikCariFirmalar.Count > 0)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center py-2">
            <div>
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>@eksikCariFirmalar.Count</strong> firmanın <em>Karşılık Gelen Cari</em> tanımı eksik.
                Mutabakatın doğru çalışması için her firmaya bir Cari atanmalıdır.
                <span class="text-muted small ms-2">(@string.Join(", ", eksikCariFirmalar.Take(5).Select(x => x.FirmaAdi))@(eksikCariFirmalar.Count > 5 ? ", ..." : ""))</span>
            </div>
            <button class="btn btn-sm btn-outline-dark" @onclick="@(() => Nav.NavigateTo("/ayarlar/firmalar"))">
                <i class="bi bi-gear me-1"></i> Firma Yönetimi
            </button>
        </div>
    }

    @if (eksikCariTedarikciler.Count > 0)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center py-2">
            <div>
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>@eksikCariTedarikciler.Count</strong> taşıma tedarikçisinin <em>Cari</em> bağlantısı eksik.
                Tedarikçi mutabakatı ve gelen fatura eşleşmesi için her tedarikçiye bir Cari atanmalıdır.
                <span class="text-muted small ms-2">(@string.Join(", ", eksikCariTedarikciler.Take(5).Select(x => x.Unvan))@(eksikCariTedarikciler.Count > 5 ? ", ..." : ""))</span>
            </div>
            <button class="btn btn-sm btn-outline-dark" @onclick="@(() => Nav.NavigateTo("/personel-tasima/tedarikciler"))">
                <i class="bi bi-truck me-1"></i> Tedarikçiler
            </button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Firma</label>
                    <select class="form-select" @bind="firmaId">
                        <option value="0">-- Firma --</option>
                        @foreach (var f in firmalar)
                        {
                            <option value="@f.Id">@f.FirmaAdi @(f.CariId == null ? "(Cari yok!)" : "")</option>
                        }
                    </select>
                    @if (SelectedFirma is { CariId: null })
                    {
                        <div class="form-text text-danger">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            Bu firmaya Cari atanmamış. Cari bazlı mutabakat <em>Unvan</em> eşleşmesine düşer.
                        </div>
                    }
                </div>
                <div class="col-md-3">
                    <label class="form-label">Başlangıç</label>
                    <input type="date" class="form-control" @bind="baslangic" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bitiş</label>
                    <input type="date" class="form-control" @bind="bitis" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" @onclick="HesaplaMutabakat" disabled="@(firmaId == 0)">
                        <i class="bi bi-calculator me-1"></i> Mutabakatı Hesapla
                    </button>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(tab == "cari" ? "active" : "")" href="javascript:void(0)" @onclick='() => tab = "cari"'>
                <i class="bi bi-person-vcard me-1"></i> Cari (Müşteri / Kesilen Fatura)
                <span class="badge bg-primary ms-1">@FilteredCariRows.Count / @cariRows.Count</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(tab == "tedarikci" ? "active" : "")" href="javascript:void(0)" @onclick='() => tab = "tedarikci"'>
                <i class="bi bi-truck-front me-1"></i> Taşıma Tedarikçisi (Gelen Fatura)
                <span class="badge bg-warning text-dark ms-1">@FilteredTedarikciRows.Count / @tedarikciRows.Count</span>
            </a>
        </li>
        <li class="nav-item ms-auto d-flex align-items-center gap-2">
            <div class="form-check form-switch m-0" title="Farkı tolerans altında olan satırları gizle">
                <input class="form-check-input" type="checkbox" id="chkSadeceFark" @bind="sadeceFarkliGoster" />
                <label class="form-check-label small" for="chkSadeceFark">Sadece farklı olanlar</label>
            </div>
            <div class="input-group input-group-sm" style="width:170px" title="Tolerans (mutlak fark)">
                <span class="input-group-text">±</span>
                <input type="number" min="0" step="0.01" class="form-control" @bind="farkTolerans" />
                <span class="input-group-text">₺</span>
            </div>
        </li>
    </ul>

    @if (tab == "cari")
    {
        <div class="card">
            <div class="card-header bg-primary bg-opacity-10">
                <strong>Cari Bazlı Mutabakat</strong> - Tahakkuk (puantajdan) vs Kesilen Fatura
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Cari (Kurum)</th>
                            <th class="text-end">Tahakkuk Tutar</th>
                            <th class="text-end">Kesilen Fatura</th>
                            <th class="text-end">Fark</th>
                            <th class="text-center">Puantaj #</th>
                            <th class="text-center">Fatura #</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredCariRows)
                        {
                            <tr class="@DurumClass(r.Fark)" style="cursor:pointer" @onclick="() => CariDetayAc(r)">
                                <td>@r.CariUnvan</td>
                                <td class="text-end">@r.TahakkukEdenTutar.ToString("N2")</td>
                                <td class="text-end">@r.KesilenFaturaTutari.ToString("N2")</td>
                                <td class="text-end fw-bold">@r.Fark.ToString("N2")</td>
                                <td class="text-center">@r.PuantajSayisi</td>
                                <td class="text-center">@r.FaturaSayisi</td>
                                <td><span class="badge @DurumBadge(r.Fark)">@r.Durum</span></td>
                            </tr>
                        }
                        @if (cariRows.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted p-3">Veri yok. Tarih aralığı seçip Hesapla'ya basın.</td></tr>
                        }
                        else if (FilteredCariRows.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted p-3">Tolerans (±@farkTolerans.ToString("N2") ₺) içinde, gösterilecek farklı satır yok.</td></tr>
                        }
                    </tbody>
                    @if (FilteredCariRows.Count > 0)
                    {
                        <tfoot class="table-light">
                            <tr>
                                <th>TOPLAM (@(sadeceFarkliGoster ? "farklı" : "tümü"))</th>
                                <th class="text-end">@FilteredCariRows.Sum(x => x.TahakkukEdenTutar).ToString("N2")</th>
                                <th class="text-end">@FilteredCariRows.Sum(x => x.KesilenFaturaTutari).ToString("N2")</th>
                                <th class="text-end">@FilteredCariRows.Sum(x => x.Fark).ToString("N2")</th>
                                <th colspan="3"></th>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header bg-warning bg-opacity-25">
                <strong>Taşıma Tedarikçisi Mutabakat</strong> - Tahakkuk vs Gelen Fatura
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tedarikçi</th>
                            <th class="text-end">Tahakkuk Tutar</th>
                            <th class="text-end">Gelen Fatura</th>
                            <th class="text-end">Fark</th>
                            <th class="text-center">Puantaj #</th>
                            <th class="text-center">Fatura #</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredTedarikciRows)
                        {
                            <tr class="@DurumClass(r.Fark)" style="cursor:pointer" @onclick="() => TedarikciDetayAc(r)">
                                <td>@r.TedarikciUnvan</td>
                                <td class="text-end">@r.TahakkukEdenTutar.ToString("N2")</td>
                                <td class="text-end">@r.GelenFaturaTutari.ToString("N2")</td>
                                <td class="text-end fw-bold">@r.Fark.ToString("N2")</td>
                                <td class="text-center">@r.PuantajSayisi</td>
                                <td class="text-center">@r.FaturaSayisi</td>
                                <td><span class="badge @DurumBadge(r.Fark)">@r.Durum</span></td>
                            </tr>
                        }
                        @if (tedarikciRows.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted p-3">Veri yok.</td></tr>
                        }
                        else if (FilteredTedarikciRows.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted p-3">Tolerans (±@farkTolerans.ToString("N2") ₺) içinde, gösterilecek farklı satır yok.</td></tr>
                        }
                    </tbody>
                    @if (FilteredTedarikciRows.Count > 0)
                    {
                        <tfoot class="table-light">
                            <tr>
                                <th>TOPLAM (@(sadeceFarkliGoster ? "farklı" : "tümü"))</th>
                                <th class="text-end">@FilteredTedarikciRows.Sum(x => x.TahakkukEdenTutar).ToString("N2")</th>
                                <th class="text-end">@FilteredTedarikciRows.Sum(x => x.GelenFaturaTutari).ToString("N2")</th>
                                <th class="text-end">@FilteredTedarikciRows.Sum(x => x.Fark).ToString("N2")</th>
                                <th colspan="3"></th>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    }
</div>

@* ====================== DETAY MODAL ====================== *@
@if (detayAcik && detay != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)" @onclick="DetayKapat">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-zoom-in me-2"></i>Mutabakat Detayı: <strong>@detay.Baslik</strong>
                    </h5>
                    <button type="button" class="btn-close" @onclick="DetayKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <div class="card border-primary">
                                <div class="card-body p-2 text-center">
                                    <div class="small text-muted">Tahakkuk (Puantaj)</div>
                                    <div class="h5 mb-0 text-primary">@detay.TahakkukToplam.ToString("N2")</div>
                                    <div class="small">@detay.Puantajlar.Count adet</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-info">
                                <div class="card-body p-2 text-center">
                                    <div class="small text-muted">Fatura</div>
                                    <div class="h5 mb-0 text-info">@detay.FaturaToplam.ToString("N2")</div>
                                    <div class="small">@detay.Faturalar.Count adet</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-@(detay.Fark == 0 ? "success" : "danger")">
                                <div class="card-body p-2 text-center">
                                    <div class="small text-muted">Fark</div>
                                    <div class="h5 mb-0 text-@(detay.Fark == 0 ? "success" : "danger")">@detay.Fark.ToString("N2")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-7">
                            <h6><i class="bi bi-calendar2-check me-1"></i> Puantaj Kayıtları</h6>
                            <div style="max-height:50vh; overflow-y:auto">
                                <table class="table table-sm table-striped">
                                    <thead class="table-light"><tr><th>Tarih</th><th>Araç</th><th>Şoför</th><th>Güzergah</th><th class="text-end">Sefer</th><th class="text-end">Tutar</th><th>Fat.</th></tr></thead>
                                    <tbody>
                                        @foreach (var p in detay.Puantajlar)
                                        {
                                            <tr>
                                                <td>@p.Tarih.ToString("dd.MM")</td>
                                                <td><small>@p.AracPlaka</small></td>
                                                <td><small>@p.Sofor</small></td>
                                                <td><small>@p.Guzergah</small></td>
                                                <td class="text-end">@p.SeferSayisi</td>
                                                <td class="text-end">@p.Tutar.ToString("N2")</td>
                                                <td>
                                                    @if (p.Faturalandi)
                                                    { <span class="badge bg-success">✓</span> }
                                                    else
                                                    { <span class="badge bg-secondary">-</span> }
                                                </td>
                                            </tr>
                                        }
                                        @if (detay.Puantajlar.Count == 0)
                                        { <tr><td colspan="7" class="text-center text-muted">Puantaj kaydı yok</td></tr> }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <h6><i class="bi bi-receipt me-1"></i> Faturalar</h6>
                            <div style="max-height:50vh; overflow-y:auto">
                                <table class="table table-sm table-striped">
                                    <thead class="table-light"><tr><th>Tarih</th><th>Fatura No</th><th class="text-end">Tutar</th><th>Bağlı</th></tr></thead>
                                    <tbody>
                                        @foreach (var f in detay.Faturalar)
                                        {
                                            <tr>
                                                <td>@f.Tarih.ToString("dd.MM")</td>
                                                <td><small>@f.FaturaNo</small></td>
                                                <td class="text-end">@f.Tutar.ToString("N2")</td>
                                                <td>
                                                    @if (f.PuantajaBagli)
                                                    { <span class="badge bg-success">✓</span> }
                                                    else
                                                    { <span class="badge bg-warning text-dark">?</span> }
                                                </td>
                                            </tr>
                                        }
                                        @if (detay.Faturalar.Count == 0)
                                        { <tr><td colspan="4" class="text-center text-muted">Fatura yok</td></tr> }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-success" @onclick="ExportDetayCsv">
                        <i class="bi bi-file-earmark-spreadsheet me-1"></i> Detayı CSV İndir
                    </button>
                    <button class="btn btn-secondary" @onclick="DetayKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int firmaId = 0;
    private DateTime baslangic = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bitis = DateTime.Today;
    private string tab = "cari";

    private List<Firma> firmalar = new();
    private List<TasimaTedarikci> tumTedarikciler = new();
    private List<CariFaturaMutabakatRow> cariRows = new();
    private List<TasimaTedarikciMutabakatRow> tedarikciRows = new();

    private List<Firma> eksikCariFirmalar => firmalar.Where(f => f.Aktif && f.CariId == null).ToList();
    private List<TasimaTedarikci> eksikCariTedarikciler => tumTedarikciler.Where(t => t.Aktif && t.CariId == null).ToList();
    private Firma? SelectedFirma => firmalar.FirstOrDefault(f => f.Id == firmaId);

    private bool sadeceFarkliGoster = false;
    private decimal farkTolerans = 0.01m;

    private List<CariFaturaMutabakatRow> FilteredCariRows => sadeceFarkliGoster
        ? cariRows.Where(r => Math.Abs(r.Fark) > farkTolerans).ToList()
        : cariRows;
    private List<TasimaTedarikciMutabakatRow> FilteredTedarikciRows => sadeceFarkliGoster
        ? tedarikciRows.Where(r => Math.Abs(r.Fark) > farkTolerans).ToList()
        : tedarikciRows;

    private bool detayAcik = false;
    private MutabakatDetay? detay;

    private bool HasData => cariRows.Count > 0 || tedarikciRows.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        firmalar = (await FirmaService.GetAllAsync()).ToList();
        tumTedarikciler = await TedarikciService.GetAllAsync();
        if (firmalar.Count > 0) firmaId = firmalar[0].Id;
    }

    private async Task HesaplaMutabakat()
    {
        if (firmaId == 0) return;
        cariRows = await EslestirmeService.GetCariMutabakatAsync(firmaId, baslangic, bitis);
        tedarikciRows = await EslestirmeService.GetTasimaTedarikciMutabakatAsync(firmaId, baslangic, bitis);
        ToastService.ShowSuccess($"Mutabakat hesaplandı: {cariRows.Count} cari, {tedarikciRows.Count} tedarikçi.");
    }

    private async Task CariDetayAc(CariFaturaMutabakatRow r)
    {
        detay = await EslestirmeService.GetCariMutabakatDetayAsync(firmaId, r.CariId, baslangic, bitis);
        detayAcik = true;
    }
    private async Task TedarikciDetayAc(TasimaTedarikciMutabakatRow r)
    {
        detay = await EslestirmeService.GetTasimaTedarikciMutabakatDetayAsync(firmaId, r.TedarikciId, baslangic, bitis);
        detayAcik = true;
    }
    private void DetayKapat() { detayAcik = false; detay = null; }

    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        // UTF-8 BOM Excel için
        sb.Append('\uFEFF');
        if (tab == "cari")
        {
            sb.AppendLine("Cari;Tahakkuk;Kesilen Fatura;Fark;Puantaj Sayisi;Fatura Sayisi;Durum");
            foreach (var r in FilteredCariRows)
                sb.AppendLine($"{Csv(r.CariUnvan)};{r.TahakkukEdenTutar:F2};{r.KesilenFaturaTutari:F2};{r.Fark:F2};{r.PuantajSayisi};{r.FaturaSayisi};{r.Durum}");
        }
        else
        {
            sb.AppendLine("Tedarikci;Tahakkuk;Gelen Fatura;Fark;Puantaj Sayisi;Fatura Sayisi;Durum");
            foreach (var r in FilteredTedarikciRows)
                sb.AppendLine($"{Csv(r.TedarikciUnvan)};{r.TahakkukEdenTutar:F2};{r.GelenFaturaTutari:F2};{r.Fark:F2};{r.PuantajSayisi};{r.FaturaSayisi};{r.Durum}");
        }
        await IndirCsv($"mutabakat_{tab}_{baslangic:yyyyMMdd}_{bitis:yyyyMMdd}.csv", sb.ToString());
    }

    private async Task ExportDetayCsv()
    {
        if (detay == null) return;
        var sb = new StringBuilder();
        sb.Append('\uFEFF');
        sb.AppendLine($"Mutabakat Detayi - {detay.Baslik}");
        sb.AppendLine($"Tahakkuk Toplam;{detay.TahakkukToplam:F2}");
        sb.AppendLine($"Fatura Toplam;{detay.FaturaToplam:F2}");
        sb.AppendLine($"Fark;{detay.Fark:F2}");
        sb.AppendLine();
        sb.AppendLine("PUANTAJLAR");
        sb.AppendLine("Tarih;Arac;Sofor;Guzergah;Sefer;Tutar;Faturalandi");
        foreach (var p in detay.Puantajlar)
            sb.AppendLine($"{p.Tarih:dd.MM.yyyy};{Csv(p.AracPlaka)};{Csv(p.Sofor)};{Csv(p.Guzergah)};{p.SeferSayisi};{p.Tutar:F2};{(p.Faturalandi ? "Evet" : "Hayir")}");
        sb.AppendLine();
        sb.AppendLine("FATURALAR");
        sb.AppendLine("Tarih;Fatura No;Tutar;Puantaja Bagli");
        foreach (var f in detay.Faturalar)
            sb.AppendLine($"{f.Tarih:dd.MM.yyyy};{Csv(f.FaturaNo)};{f.Tutar:F2};{(f.PuantajaBagli ? "Evet" : "Hayir")}");
        await IndirCsv($"mutabakat_detay_{detay.Baslik}_{baslangic:yyyyMMdd}_{bitis:yyyyMMdd}.csv", sb.ToString());
    }

    private static string Csv(string? s) => string.IsNullOrEmpty(s) ? "" : s.Replace(";", ",").Replace("\r", " ").Replace("\n", " ");

    private async Task IndirCsv(string fileName, string content)
    {
        var bytes = Encoding.UTF8.GetBytes(content);
        var b64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval",
            $"(function(){{var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='{fileName}';document.body.appendChild(a);a.click();document.body.removeChild(a);}})()");
    }

    private string DurumClass(decimal fark) => fark switch
    {
        0 => "table-success",
        > 0 => "table-warning",
        < 0 => "table-danger"
    };
    private string DurumBadge(decimal fark) => fark switch
    {
        0 => "bg-success",
        > 0 => "bg-warning text-dark",
        < 0 => "bg-danger"
    };
}
