        public string AracPlaka { get; set; } = string.Empty;
        public int SoforId { get; set; }
        public string SoforAdi { get; set; } = string.Empty;
        public string? SoforTelefon { get; set; }
        public ServisTuru ServisTuru { get; set; }
        public decimal GelirFiyat { get; set; }
        public decimal GiderFiyat { get; set; }
        public int Kapasite { get; set; }
        public int Gun { get; set; }
