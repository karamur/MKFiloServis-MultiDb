@page "/filo-gunluk-puantaj"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Data
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IFirmaService FirmaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Filo Günlük Puantaj</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-calendar2-check me-2"></i>Filo Günlük Puantaj</h2>
            <p class="text-muted mb-0">Günlük operasyon kayıtları (Sabah / Akşam / Yarda Mesai). Hakediş ve maliyet snapshot'ları bu kayıtlardan üretilir.</p>
        </div>
        <button class="btn btn-primary" @onclick="YeniKayitAc">
            <i class="bi bi-plus-lg me-1"></i> Yeni Kayıt
        </button>
    </div>

    @if (topluPanelAcik)
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-journal-plus me-2"></i>Toplu Puantaj Oluştur</span>
                <button type="button" class="btn btn-sm btn-light" @onclick="PuantajOlusturModuAcKapat">Kapat</button>
            </div>
            <div class="card-body">
                <div class="row g-2 mb-3">
                    <div class="col-md-3">
                        <label class="form-label small">Kurum *</label>
                        <select class="form-select form-select-sm" value="@secilenKurumId" @onchange="KurumSecimiDegisti">
                            <option value="0">-- Kurum Seçiniz --</option>
                            @foreach (var f in firmalar)
                            {
                                <option value="@f.Id">@f.FirmaAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Kapasite</label>
                        <select class="form-select form-select-sm" @bind="secilenKapasite">
                            <option value="0">Güzergah kartından</option>
                            @foreach (var k in kapasiteSecenekleri)
                            {
                                <option value="@k">@k</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Gün</label>
                        <input type="number" min="1" max="31" class="form-control form-control-sm" @bind="secilenGun" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Sefer Sayısı</label>
                        <input type="number" min="0.5" step="0.5" class="form-control form-control-sm" @bind="secilenSeferSayisi" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Ara (Güzergah/Plaka/Şoför)</label>
                        <input class="form-control form-control-sm" @bind="puantajAramaMetni" />
                    </div>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button class="btn btn-sm btn-outline-primary" @onclick="TopluSatirlarOlustur" disabled="@(secilenKurumId == 0)">
                        <i class="bi bi-list-check me-1"></i>Satırları Getir
                    </button>
                    <button class="btn btn-sm btn-success" @onclick="TopluPuantajKaydet" disabled="@(isSaving || !topluSatirlar.Any())">
                        <i class="bi bi-save me-1"></i>Toplu Puantaj Kaydet
                    </button>
                </div>

                @if (topluSatirlar.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th></th>
                                    <th>Kurum</th>
                                    <th>Güzergah</th>
                                    <th>Araç</th>
                                    <th>Şoför</th>
                                    <th>Telefon</th>
                                    <th>Yön</th>
                                    <th>Gelir</th>
                                    <th>Gider</th>
                                    <th>Kapasite</th>
                                    <th>Gün</th>
                                    <th>Sefer</th>
                                    <th>Firma Tipi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var satir in topluSatirlar)
                                {
                                    <tr>
                                        <td>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => SatirDetayToggle(satir.EslestirmeId)">
                                                <i class="bi @(SatirDetayAcikMi(satir.EslestirmeId) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                            </button>
                                        </td>
                                        <td>@satir.KurumAdi</td>
                                        <td>@satir.GuzergahAdi</td>
                                        <td>@satir.AracPlaka</td>
                                        <td>@satir.SoforAdi</td>
                                        <td>@(string.IsNullOrWhiteSpace(satir.SoforTelefon) ? "-" : satir.SoforTelefon)</td>
                                        <td><span class="badge @ServisTuruBadge(satir.ServisTuru)">@ServisTuruAdi(satir.ServisTuru)</span></td>
                                        <td class="text-end">@satir.GelirFiyat.ToString("N2")</td>
                                        <td class="text-end">@satir.GiderFiyat.ToString("N2")</td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="0" @bind="satir.Kapasite" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="1" max="31" @bind="satir.Gun" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="0.5" step="0.5" @bind="satir.SeferSayisi" />
                                        </td>
                                        <td>@satir.FirmaTipi</td>
                                    </tr>
                                    @if (SatirDetayAcikMi(satir.EslestirmeId))
                                    {
                                        <tr class="table-secondary">
                                            <td></td>
                                            <td colspan="12">
                                                <div class="row g-2 align-items-end">
                                                    <div class="col-md-3">
                                                        <label class="form-label small mb-1">Şoför Değiştir</label>
                                                        <select class="form-select form-select-sm" @bind="satir.SoforId">
                                                            @foreach (var s in soforler)
                                                            {
                                                                <option value="@s.Id">@s.TamAd</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small mb-1">Araç Değiştir</label>
                                                        <select class="form-select form-select-sm" @bind="satir.AracId">
                                                            @foreach (var a in araclar)
                                                            {
                                                                <option value="@a.Id">@a.Plaka</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label small mb-1">Not</label>
                                                        <input class="form-control form-control-sm" @bind="satir.Notlar" />
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
    <!-- Filtre -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBaslangic" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBitis" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Kurum</label>
                    <select class="form-select form-select-sm" @bind="filtreKurumId" @bind:after="LoadAsync">
                        <option value="0">Tümü</option>
                        @foreach (var f in firmalar)
                        {
                            <option value="@f.Id">@f.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Araç</label>
                    <select class="form-select form-select-sm" @bind="filtreAracId" @bind:after="LoadAsync">
                        <option value="0">Tümü</option>
                        @foreach (var a in araclar)
                        {
                            <option value="@a.Id">@a.Plaka</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Servis Türü</label>
                    <select class="form-select form-select-sm" @bind="filtreServisTuru" @bind:after="LoadAsync">
                        <option value="">Tümü</option>
                        <option value="Sabah">Sabah</option>
                        <option value="Aksam">Akşam</option>
                        <option value="SabahAksam">Sabah+Akşam</option>
                        <option value="YardaMesai">Yarda Mesai</option>
                        <option value="Ozel">Özel</option>
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreyiTemizle">
                        <i class="bi bi-x-lg me-1"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Özet -->
    @if (kayitlar.Any())
    {
        <div class="row g-2 mb-3">
            <div class="col-md-3"><div class="card border-primary"><div class="card-body py-2"><div class="text-muted small">Kayıt</div><div class="fs-5 fw-bold">@kayitlar.Count</div></div></div></div>
            <div class="col-md-3"><div class="card border-info"><div class="card-body py-2"><div class="text-muted small">Toplam Sefer</div><div class="fs-5 fw-bold">@kayitlar.Sum(k => k.SeferSayisi).ToString("N2")</div></div></div></div>
            <div class="col-md-3"><div class="card border-success"><div class="card-body py-2"><div class="text-muted small">Tahakkuk Gelir</div><div class="fs-5 fw-bold text-success">@kayitlar.Sum(k => k.TahakkukEdenKurumUcreti).ToString("N2") ₺</div></div></div></div>
            <div class="col-md-3"><div class="card border-warning"><div class="card-body py-2"><div class="text-muted small">Tahakkuk Gider</div><div class="fs-5 fw-bold text-warning">@kayitlar.Sum(k => k.TahakkukEdenTaseronUcreti + (k.MaliyetOzmalKiralik ?? 0)).ToString("N2") ₺</div></div></div></div>
        </div>
    }

    <!-- Liste -->
    <div class="card">
        <div class="card-body p-0">
            @if (yukleniyor)
            {
                <div class="p-4 text-center text-muted"><div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...</div>
            }
            else if (!kayitlar.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Bu kriterlere uygun kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>Servis</th>
                                <th class="text-end">Sefer</th>
                                <th>Kurum</th>
                                <th>Araç</th>
                                <th>Sahiplik</th>
                                <th>Şoför</th>
                                <th>Güzergah</th>
                                <th class="text-end">Gelir</th>
                                <th class="text-end">Gider/Maliyet</th>
                                <th>Durum</th>
                                <th>Faturalama</th>
                                <th class="text-center" style="width:100px;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var k in kayitlar)
                            {
                                <tr>
                                    <td>@k.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td><span class="badge @ServisTuruBadge(k.ServisTuru)">@ServisTuruAdi(k.ServisTuru)</span></td>
                                    <td class="text-end">@k.SeferSayisi.ToString("N2")</td>
                                    <td>@(k.KurumFirma?.FirmaAdi ?? "-")</td>
                                    <td><strong>@(k.Arac?.Plaka ?? "-")</strong></td>
                                    <td><span class="badge @SahiplikBadge(k.Arac?.SahiplikTipi ?? AracSahiplikTipi.Ozmal)">@(k.Arac?.SahiplikTipi.ToString() ?? "-")</span></td>
                                    <td>@(k.Sofor?.TamAd ?? "-")</td>
                                    <td>@(k.Guzergah?.GuzergahAdi ?? "-")</td>
                                    <td class="text-end text-success">@k.TahakkukEdenKurumUcreti.ToString("N2")</td>
                                    <td class="text-end text-warning">@((k.Arac?.SahiplikTipi == AracSahiplikTipi.Tedarikci ? k.TahakkukEdenTaseronUcreti : (k.MaliyetOzmalKiralik ?? 0)).ToString("N2"))</td>
                                    <td><span class="badge @DurumBadge(k.Durum)">@k.Durum</span></td>
                                    <td>
                                        @if (k.KurumFaturaKesildiMi) { <span class="badge bg-success me-1" title="Kurum faturası kesildi"><i class="bi bi-receipt"></i> G</span> }
                                        @if (k.TaseronOdemeYapildiMi) { <span class="badge bg-info text-dark" title="Tedarikçi ödemesi yapıldı"><i class="bi bi-cash"></i> Ö</span> }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" title="Düzenle" @onclick="() => Duzenle(k)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" title="Sil" @onclick="() => Sil(k)" disabled="@(k.KurumFaturaKesildiMi || k.TaseronOdemeYapildiMi)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Kayıt Modal -->
@if (kayitModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-@(form.Id > 0 ? "pencil" : "plus-lg") me-2"></i>
                        @(form.Id > 0 ? "Puantaj Düzenle" : "Yeni Puantaj Kaydı")
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => kayitModalAcik = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label small">Tarih *</label>
                            <input type="date" class="form-control form-control-sm" @bind="form.Tarih" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Servis Türü *</label>
                            <select class="form-select form-select-sm" @bind="form.ServisTuru" @bind:after="ServisTuruDegisti">
                                <option value="@ServisTuru.Sabah">Sabah</option>
                                <option value="@ServisTuru.Aksam">Akşam</option>
                                <option value="@ServisTuru.SabahAksam">Sabah + Akşam</option>
                                <option value="@ServisTuru.YardaMesai">Yarda Mesai</option>
                                <option value="@ServisTuru.Ozel">Özel</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Sefer Sayısı *</label>
                            <input type="number" step="0.5" min="0" class="form-control form-control-sm" @bind="form.SeferSayisi" @bind:after="SeferSayisiHataGider" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small">Kurum (Firma) *</label>
                            <select class="form-select form-select-sm" @bind="form.KurumFirmaId">
                                <option value="0">-- Seçiniz --</option>
                                @foreach (var f in firmalar)
                                {
                                    <option value="@f.Id">@f.FirmaAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Güzergah *</label>
                            <select class="form-select form-select-sm" @bind="form.GuzergahId" @bind:after="GuzergahDegisti">
                                <option value="0">-- Seçiniz --</option>
                                @foreach (var g in guzergahlar)
                                {
                                    <option value="@g.Id">@g.GuzergahAdi</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small">Araç *</label>
                            <select class="form-select form-select-sm" @bind="form.AracId" @bind:after="AracDegisti">
                                <option value="0">-- Seçiniz --</option>
                                @foreach (var a in araclar)
                                {
                                    <option value="@a.Id">@a.Plaka — @a.SahiplikTipi</option>
                                }
                            </select>
                            @if (secilenSahiplik != null)
                            {
                                <span class="badge mt-1 @SahiplikBadge(secilenSahiplik.Value)">Sahiplik: @secilenSahiplik</span>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Şoför *</label>
                            <select class="form-select form-select-sm" @bind="form.SoforId">
                                <option value="0">-- Seçiniz --</option>
                                @foreach (var s in soforler)
                                {
                                    <option value="@s.Id">@s.TamAd</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small">Operasyon Durumu</label>
                            <select class="form-select form-select-sm" @bind="form.Durum">
                                <option value="@OperasyonDurumu.Gitti">Gitti</option>
                                <option value="@OperasyonDurumu.Gitmedi_Mazeretli">Gitmedi (Mazeretli)</option>
                                <option value="@OperasyonDurumu.Gitmedi_Mazeretsiz">Gitmedi (Mazeretsiz)</option>
                                <option value="@OperasyonDurumu.Taksiyle_Gidildi">Taksiyle Gidildi</option>
                                <option value="@OperasyonDurumu.Arizalandi_YoldaKaldi">Arızalandı / Yolda Kaldı</option>
                                <option value="@OperasyonDurumu.Iptal_KurumTarafindan">İptal (Kurum)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Kurum Ücreti (Gelir) ₺</label>
                            <input type="number" step="0.01" min="0" class="form-control form-control-sm" @bind="form.TahakkukEdenKurumUcreti" />
                        </div>
                        <div class="col-md-4">
                            @if (secilenSahiplik == AracSahiplikTipi.Tedarikci)
                            {
                                <label class="form-label small">Tedarikçi Ücreti (Gider) ₺</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm" @bind="form.TahakkukEdenTaseronUcreti" />
                            }
                            else
                            {
                                <label class="form-label small">Maliyet Özmal/Kiralık ₺</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm" @bind="maliyetOzmalKiralikInput" />
                                <div class="form-text">Boş bırakılırsa snapshot'tan otomatik hesaplanabilir.</div>
                            }
                        </div>

                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="cbTaksi" @bind="form.TaksiKullanildiMi" />
                                <label class="form-check-label small" for="cbTaksi">Taksi Kullanıldı</label>
                            </div>
                        </div>
                        @if (form.TaksiKullanildiMi)
                        {
                            <div class="col-md-4">
                                <label class="form-label small">Taksi Fiş ₺</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm" @bind="taksiFisInput" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Taksi Açıklama</label>
                                <input type="text" class="form-control form-control-sm" @bind="form.TaksiFisAciklama" />
                            </div>
                        }

                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="cbAriza" @bind="form.ArizaYaptiMi" />
                                <label class="form-check-label small" for="cbAriza">Arıza Yaptı</label>
                            </div>
                        </div>
                        @if (form.ArizaYaptiMi)
                        {
                            <div class="col-md-8">
                                <label class="form-label small">Arıza Açıklaması</label>
                                <input type="text" class="form-control form-control-sm" @bind="form.ArizaAciklamasi" />
                            </div>
                        }

                        <div class="col-12">
                            <label class="form-label small">Notlar</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="form.Notlar"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    @if (form.Id == 0)
                    {
                        <div class="form-check me-auto">
                            <input class="form-check-input" type="checkbox" id="kaydetVeYeni" @bind="kaydetVeYeniKayit">
                            <label class="form-check-label small" for="kaydetVeYeni">Kaydet ve Yeni Ekle</label>
                        </div>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="() => kayitModalAcik = false">İptal</button>
                    <button class="btn btn-primary btn-sm" @onclick="Kaydet" disabled="@(isSaving || !FormGecerli())">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool topluPanelAcik = false;
    private int secilenKurumId = 0;
    private int secilenKapasite = 0;
    private int secilenGun = DateTime.Today.Day;
    private decimal secilenSeferSayisi = 1m;
    private string puantajAramaMetni = string.Empty;
    private List<FiloGuzergahEslestirme> tumEslestirmeler = new();
    private List<int> kapasiteSecenekleri = new() { 8, 12, 16, 20, 27, 31, 46 };
    private List<TopluPuantajSatiri> topluSatirlar = new();
    private Dictionary<int, bool> satirDetayAcik = new();

    private bool yukleniyor = true;
    private bool isSaving = false;
    private bool kayitModalAcik = false;

    private DateTime filtreBaslangic = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime filtreBitis = DateTime.Today;
    private int filtreKurumId = 0;
    private int filtreAracId = 0;
    private string filtreServisTuru = "";

    private List<FiloGunlukPuantaj> kayitlar = new();
    private List<Firma> firmalar = new();
    private List<Arac> araclar = new();
    private List<Sofor> soforler = new();
    private List<Guzergah> guzergahlar = new();

    private FiloGunlukPuantaj form = new();
    private AracSahiplikTipi? secilenSahiplik = null;
    private decimal? maliyetOzmalKiralikInput;
    private decimal? taksiFisInput;
    private bool kaydetVeYeniKayit = false;

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        araclar = await AracService.GetActiveAsync();
        soforler = await SoforService.GetActiveAsync();
        guzergahlar = await GuzergahService.GetAllAsync();
        await LoadAsync();
    }

    private async Task LoadEslestirmelerAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        tumEslestirmeler = await ctx.FiloGuzergahEslestirmeleri
            .Include(x => x.KurumFirma)
            .Include(x => x.Guzergah)
            .Include(x => x.Arac)
            .Include(x => x.Sofor)
            .Where(x => x.IsActive)
            .OrderBy(x => x.KurumFirma!.FirmaAdi)
            .ThenBy(x => x.Guzergah!.GuzergahAdi)
            .ToListAsync();
    }

    private IEnumerable<FiloGuzergahEslestirme> FiltreliEslestirmeler =>
        tumEslestirmeler
            .Where(x => secilenKurumId == 0 || x.KurumFirmaId == secilenKurumId)
            .Where(x => string.IsNullOrWhiteSpace(puantajAramaMetni)
                || (x.Guzergah?.GuzergahAdi ?? string.Empty).Contains(puantajAramaMetni, StringComparison.OrdinalIgnoreCase)
                || (x.Arac?.AktifPlaka ?? string.Empty).Contains(puantajAramaMetni, StringComparison.OrdinalIgnoreCase)
                || (x.Sofor?.TamAd ?? string.Empty).Contains(puantajAramaMetni, StringComparison.OrdinalIgnoreCase));

    private void PuantajOlusturModuAcKapat()
    {
        topluPanelAcik = !topluPanelAcik;
        if (!topluPanelAcik)
        {
            topluSatirlar.Clear();
            satirDetayAcik.Clear();
            secilenKurumId = 0;
            puantajAramaMetni = string.Empty;
        }
    }

    private void KurumSecimiDegisti(ChangeEventArgs e)
    {
        if (int.TryParse(e?.Value?.ToString(), out var kurumId)) secilenKurumId = kurumId;
        else secilenKurumId = 0;

        topluSatirlar.Clear();
        satirDetayAcik.Clear();
    }

    private async Task TopluSatirlarOlustur()
    {
        if (secilenKurumId <= 0)
        {
            ToastService.ShowWarning("Önce kurum seçmelisiniz.");
            return;
        }

        var seciliKurum = firmalar.FirstOrDefault(f => f.Id == secilenKurumId);
        topluSatirlar = FiltreliEslestirmeler.Select(es => new TopluPuantajSatiri
        {
            EslestirmeId = es.Id,
            KurumId = es.KurumFirmaId,
            KurumAdi = seciliKurum?.FirmaAdi ?? es.KurumFirma?.FirmaAdi ?? "-",
            GuzergahId = es.GuzergahId,
            GuzergahAdi = es.Guzergah?.GuzergahAdi ?? "-",
            AracId = es.AracId,
            AracPlaka = es.Arac?.AktifPlaka ?? "-",
            SoforId = es.SoforId,
            SoforAdi = es.Sofor?.TamAd ?? "-",
            SoforTelefon = es.Sofor?.Telefon,
            ServisTuru = es.ServisTuru,
            GelirFiyat = es.KurumaKesilecekUcret,
            GiderFiyat = es.TaseronaOdenenUcret,
            Kapasite = secilenKapasite > 0 ? secilenKapasite : Math.Max(es.Guzergah?.PersonelSayisi ?? 0, 0),
            Gun = secilenGun,
            SeferSayisi = secilenSeferSayisi,
            FirmaTipi = FirmaTipiniBelirle(es.Arac)
        }).ToList();

        satirDetayAcik = topluSatirlar.ToDictionary(x => x.EslestirmeId, _ => false);
        if (!topluSatirlar.Any()) ToastService.ShowInfo("Seçili kurum için eşleştirme bulunamadı.");
        await InvokeAsync(StateHasChanged);
    }

    private void SatirDetayToggle(int eslestirmeId)
    {
        if (!satirDetayAcik.ContainsKey(eslestirmeId)) satirDetayAcik[eslestirmeId] = true;
        else satirDetayAcik[eslestirmeId] = !satirDetayAcik[eslestirmeId];
    }

    private bool SatirDetayAcikMi(int eslestirmeId) => satirDetayAcik.TryGetValue(eslestirmeId, out var acik) && acik;

    private async Task TopluPuantajKaydet()
    {
        if (!topluSatirlar.Any())
        {
            ToastService.ShowWarning("Önce satırları oluşturmalısınız.");
            return;
        }

        isSaving = true;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            foreach (var satir in topluSatirlar)
            {
                var gun = Math.Clamp(satir.Gun, 1, DateTime.DaysInMonth(filtreBaslangic.Year, filtreBaslangic.Month));
                var tarih = new DateTime(filtreBaslangic.Year, filtreBaslangic.Month, gun);
                var entity = new FiloGunlukPuantaj
                {
                    FirmaId = satir.KurumId,
                    Tarih = tarih,
                    FiloGuzergahEslestirmeId = satir.EslestirmeId,
                    KurumFirmaId = satir.KurumId,
                    GuzergahId = satir.GuzergahId,
                    AracId = satir.AracId,
                    SoforId = satir.SoforId,
                    Durum = OperasyonDurumu.Gitti,
                    ServisTuru = satir.ServisTuru,
                    SeferSayisi = satir.SeferSayisi,
                    PuantajCarpani = 1m,
                    TahakkukEdenKurumUcreti = satir.GelirFiyat * satir.SeferSayisi,
                    TahakkukEdenTaseronUcreti = satir.GiderFiyat * satir.SeferSayisi,
                    Notlar = satir.Notlar
                };
                ctx.FiloGunlukPuantajlar.Add(entity);
            }

            await ctx.SaveChangesAsync();
            ToastService.ShowSuccess($"{topluSatirlar.Count} satır toplu puantaj kaydedildi.");
            await LoadAsync();
            topluSatirlar.Clear();
            satirDetayAcik.Clear();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Toplu puantaj kaydedilemedi: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string FirmaTipiniBelirle(Arac? arac)
    {
        if (arac == null) return "Cari";
        return arac.SahiplikTipi == AracSahiplikTipi.Tedarikci ? "Tedarikçi" : "Cari";
    }
    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var q = ctx.FiloGunlukPuantajlar
                .Include(p => p.KurumFirma)
                .Include(p => p.Arac)
                .Include(p => p.Sofor)
                .Include(p => p.Guzergah)
                .Where(p => p.Tarih >= filtreBaslangic.Date && p.Tarih <= filtreBitis.Date);

            if (filtreKurumId > 0) q = q.Where(p => p.KurumFirmaId == filtreKurumId);
            if (filtreAracId > 0) q = q.Where(p => p.AracId == filtreAracId);
            if (!string.IsNullOrEmpty(filtreServisTuru) && Enum.TryParse<ServisTuru>(filtreServisTuru, out var st))
                q = q.Where(p => p.ServisTuru == st);

            kayitlar = await q.OrderByDescending(p => p.Tarih).ThenBy(p => p.Arac!.AktifPlaka).ToListAsync();
        }
        finally { yukleniyor = false; }
    }

    private async Task FiltreyiTemizle()
    {
        filtreBaslangic = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        filtreBitis = DateTime.Today;
        filtreKurumId = 0; filtreAracId = 0; filtreServisTuru = "";
        await LoadAsync();
    }

    private void YeniKayitAc()
    {
        form = new FiloGunlukPuantaj
        {
            Tarih = DateTime.Today,
            ServisTuru = ServisTuru.SabahAksam,
            SeferSayisi = 1m,
            Durum = OperasyonDurumu.Gitti
        };
        secilenSahiplik = null;
        maliyetOzmalKiralikInput = null;
        taksiFisInput = null;
        kayitModalAcik = true;
    }

    private void Duzenle(FiloGunlukPuantaj k)
    {
        kaydetVeYeniKayit = false;
        form = new FiloGunlukPuantaj
        {
            Id = k.Id,
            FirmaId = k.FirmaId,
            Tarih = k.Tarih,
            KurumFirmaId = k.KurumFirmaId,
            GuzergahId = k.GuzergahId,
            AracId = k.AracId,
            SoforId = k.SoforId,
            Durum = k.Durum,
            ServisTuru = k.ServisTuru,
            SeferSayisi = k.SeferSayisi,
            PuantajCarpani = k.PuantajCarpani,
            TahakkukEdenKurumUcreti = k.TahakkukEdenKurumUcreti,
            TahakkukEdenTaseronUcreti = k.TahakkukEdenTaseronUcreti,
            TaksiKullanildiMi = k.TaksiKullanildiMi,
            TaksiFisTutari = k.TaksiFisTutari,
            TaksiFisAciklama = k.TaksiFisAciklama,
            ArizaYaptiMi = k.ArizaYaptiMi,
            ArizaAciklamasi = k.ArizaAciklamasi,
            Notlar = k.Notlar,
            KurumFaturaKesildiMi = k.KurumFaturaKesildiMi,
            TaseronOdemeYapildiMi = k.TaseronOdemeYapildiMi,
            MaliyetOzmalKiralik = k.MaliyetOzmalKiralik,
            KurumFaturaId = k.KurumFaturaId,
            TedarikciOdemeFaturaId = k.TedarikciOdemeFaturaId
        };
        secilenSahiplik = k.Arac?.SahiplikTipi;
        maliyetOzmalKiralikInput = k.MaliyetOzmalKiralik;
        taksiFisInput = k.TaksiFisTutari;
        kayitModalAcik = true;
    }

    private void AracDegisti()
    {
        var a = araclar.FirstOrDefault(x => x.Id == form.AracId);
        secilenSahiplik = a?.SahiplikTipi;

        // Arac uzerinde VarsayilanSoforId yokmus, kaldirildi

        HesaplaMaliyetVeKurumFiyat();
    }

    private void ServisTuruDegisti()
    {
        if (form.ServisTuru == ServisTuru.Sabah || form.ServisTuru == ServisTuru.Aksam || form.ServisTuru == ServisTuru.YardaMesai) form.SeferSayisi = 0.5m;
        else if (form.ServisTuru == ServisTuru.SabahAksam) form.SeferSayisi = 1.0m;

        HesaplaMaliyetVeKurumFiyat();
    }

    private void SeferSayisiHataGider() => HesaplaMaliyetVeKurumFiyat();

    private void GuzergahDegisti()
    {
        var g = guzergahlar.FirstOrDefault(x => x.Id == form.GuzergahId);
        if (g != null)
        {
            if (form.KurumFirmaId == 0 && g.FirmaId.HasValue) form.KurumFirmaId = g.FirmaId.Value;
            if (form.AracId == 0 && g.VarsayilanAracId.HasValue) { form.AracId = g.VarsayilanAracId.Value; AracDegisti(); }
            if (form.SoforId == 0 && g.VarsayilanSoforId.HasValue) form.SoforId = g.VarsayilanSoforId.Value;
        }
        HesaplaMaliyetVeKurumFiyat();
    }

    private void HesaplaMaliyetVeKurumFiyat()
    {
        if (form.GuzergahId > 0)
        {
            var g = guzergahlar.FirstOrDefault(x => x.Id == form.GuzergahId);
            if (g != null && g.BirimFiyat > 0) form.TahakkukEdenKurumUcreti = (g.BirimFiyat * form.SeferSayisi);
        }

        if (form.AracId > 0 && secilenSahiplik == AracSahiplikTipi.Tedarikci)
        {
            if (form.TahakkukEdenTaseronUcreti == 0 && form.TahakkukEdenKurumUcreti > 0) form.TahakkukEdenTaseronUcreti = form.TahakkukEdenKurumUcreti * 0.8m;
        }
    }

    private bool FormGecerli() =>
        form.Tarih != default
        && form.KurumFirmaId > 0
        && form.GuzergahId > 0
        && form.AracId > 0
        && form.SoforId > 0
        && form.SeferSayisi > 0;

    private async Task Kaydet()
    {
        if (!FormGecerli()) { ToastService.ShowWarning("Zorunlu alanları doldurun."); return; }
        isSaving = true;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();

            if (secilenSahiplik == AracSahiplikTipi.Tedarikci)
            {
                form.MaliyetOzmalKiralik = null;
            }
            else
            {
                form.TahakkukEdenTaseronUcreti = 0;
                form.MaliyetOzmalKiralik = maliyetOzmalKiralikInput;
            }

            if (form.TaksiKullanildiMi) form.TaksiFisTutari = taksiFisInput;
            else { form.TaksiFisTutari = null; form.TaksiFisAciklama = null; }

            if (!form.ArizaYaptiMi) form.ArizaAciklamasi = null;

            if (form.Id == 0)
            {
                if (form.FirmaId == 0) form.FirmaId = form.KurumFirmaId;
                ctx.FiloGunlukPuantajlar.Add(form);
            }
            else
            {
                var existing = await ctx.FiloGunlukPuantajlar.FirstOrDefaultAsync(x => x.Id == form.Id);
                if (existing == null) { ToastService.ShowError("Kayıt bulunamadı."); return; }
                ctx.Entry(existing).CurrentValues.SetValues(form);
            }

            await ctx.SaveChangesAsync();
            ToastService.ShowSuccess("Kayıt kaydedildi.");
            if (kaydetVeYeniKayit && form.Id > 0)
            {
                var k = form;
                form = new FiloGunlukPuantaj { Tarih = k.Tarih, KurumFirmaId = k.KurumFirmaId, GuzergahId = k.GuzergahId, AracId = k.AracId, SoforId = k.SoforId, Durum = k.Durum, ServisTuru = k.ServisTuru == ServisTuru.Sabah ? ServisTuru.Aksam : k.ServisTuru == ServisTuru.Aksam ? ServisTuru.Sabah : k.ServisTuru, TahakkukEdenKurumUcreti = k.TahakkukEdenKurumUcreti, TahakkukEdenTaseronUcreti = k.TahakkukEdenTaseronUcreti, MaliyetOzmalKiralik = k.MaliyetOzmalKiralik, SeferSayisi = k.SeferSayisi };
                ServisTuruDegisti();
                kayitModalAcik = true;
            }
            else { kayitModalAcik = false; }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally { isSaving = false; }
    }

    private async Task Sil(FiloGunlukPuantaj k)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"{k.Tarih:dd.MM.yyyy} tarihli kayıt silinsin mi?")) return;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var entity = await ctx.FiloGunlukPuantajlar.FirstOrDefaultAsync(x => x.Id == k.Id);
            if (entity == null) return;
            ctx.FiloGunlukPuantajlar.Remove(entity);
            await ctx.SaveChangesAsync();
            ToastService.ShowSuccess("Kayıt silindi.");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
    }

    private static string ServisTuruAdi(ServisTuru t) => t switch
    {
        ServisTuru.Sabah => "Sabah",
        ServisTuru.Aksam => "Akşam",
        ServisTuru.SabahAksam => "Sabah+Akşam",
        ServisTuru.YardaMesai => "Yarda Mesai",
        ServisTuru.Ozel => "Özel",
        _ => t.ToString()
    };

