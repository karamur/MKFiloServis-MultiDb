@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IKullaniciService KullaniciService
@inject KOAFiloServis.Web.Services.LicenseService LicenseSvc
@inject IPortalProjectCatalogService PortalProjectCatalogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject ProtectedLocalStorage LocalStorage
@inject IJSRuntime JSRuntime
@inject ILogger<Login> Logger

<PageTitle>Giris - @(selectedProject?.Name ?? "ÜSTÜN GRUP FİLO")</PageTitle>

<div class="login-container">
    <div class="login-background">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <div class="login-card">
        <div class="login-header">
            <div class="logo-container">
                <img src="images/logo.png" alt="Logo" class="logo-img" />
                <img src="images/YaziLogo.png" alt="USTUN GRUP FILO" class="logo-text-img" />
            </div>
            @if (selectedProject is not null)
            {
                <div class="selected-project-badge">@selectedProject.Category</div>
            }
            <p>@(selectedProject?.Subtitle ?? "Filo Yonetim ve Muhasebe Platformu")</p>
            <a href="/" class="project-switch-link">
                <i class="bi bi-grid me-1"></i>Projeleri Gor
            </a>
        </div>

        @if (lisansSuresiDoldu)
        {
            <div class="license-expired-card">
                <div class="license-expired-icon">
                    <i class="bi bi-clock-history"></i>
                </div>
                <h4 class="mb-2" style="color: #e67e22;">🔐 Lisans Aktivasyonu</h4>
                <p class="text-muted mb-2">
                    Sistemi kullanmaya devam etmek için lisans anahtarı girmeniz yeterlidir.
                </p>

                @if (lisans != null)
                {
                    var remainingDays = LicenseService.GetRemainingDays(lisans);
                    <div class="license-detail-box mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Lisans Tipi:</span>
                            <span class="fw-semibold">@(lisans.IsDemo ? "Demo (30 gün)" : "Yıllık")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Bitiş:</span>
                            <span class="fw-semibold text-danger">@lisans.ExpireDate.ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>
                }

                @* 3 Adımlı Yönlendirme *@
                <div class="card bg-light mb-3">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <span class="badge bg-primary rounded-pill mt-1">1</span>
                            <span>Makine kodunu <strong>kopyalayın</strong></span>
                        </div>
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <span class="badge bg-primary rounded-pill mt-1">2</span>
                            <span>Bu kodu <strong>yetkili kişiye gönderin</strong></span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <span class="badge bg-primary rounded-pill mt-1">3</span>
                            <span>Size verilen lisans anahtarını <strong>aşağıya yapıştırın</strong></span>
                        </div>
                    </div>
                </div>
                <p class="text-muted small text-center mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Lisans anahtarı, yetkili tarafından özel olarak sizin bilgisayarınız için üretilir.
                </p>

                @* Makine Kodu — tek tuş *@
                <div class="license-machine-code mb-3">
                    <label class="form-label text-muted small mb-1">Makine Kodu</label>
                    <div class="input-group">
                        <input type="text" class="form-control text-center font-monospace" value="@makineKodu" readonly />
                        <button class="btn btn-primary" @onclick="MakineKoduKopyala" title="Kopyala">
                            <i class="bi @(_makineKoduKopyalandi ? "bi-check-lg" : "bi-clipboard") me-1"></i>
                            @(_makineKoduKopyalandi ? "Kopyalandı" : "Kopyala")
                        </button>
                    </div>
                </div>

                @* Lisans girişi *@
                <div class="license-key-input mb-3">
                    <label class="form-label text-muted small mb-1">Lisans Anahtarı</label>
                    <textarea class="form-control font-monospace" rows="4"
                              placeholder="Ctrl+V ile lisans anahtarını buraya yapıştırın"
                              @bind="yeniLisansAnahtari" @bind:event="oninput"></textarea>
                </div>

                @* Hata mesajı *@
                @if (!string.IsNullOrEmpty(lisansHataMesaji))
                {
                    <div class="alert alert-warning py-2 small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Girilen lisans anahtarı geçersiz görünüyor. Lütfen doğru anahtarı kullandığınızdan emin olun.
                    </div>
                }

                @* Başarı mesajı *@
                @if (!string.IsNullOrEmpty(lisansBasariMesaji))
                {
                    <div class="alert alert-success py-2 small mb-3">
                        <i class="bi bi-check-circle me-1"></i>@lisansBasariMesaji
                    </div>
                }

                @* Buton *@
                <button class="btn btn-success btn-lg w-100 mb-3" @onclick="LisansAktiveEtAsync"
                        disabled="@(string.IsNullOrWhiteSpace(yeniLisansAnahtari) || lisansAktivasyonYukleniyor)">
                    @if (lisansAktivasyonYukleniyor)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Doğrulanıyor...</span>
                    }
                    else
                    {
                        <i class="bi bi-rocket-takeoff me-2"></i>
                        <span>Lisansı Aktif Et ve Devam Et</span>
                    }
                </button>

                @* Güven ver *@
                <p class="text-muted small text-center mb-0">
                    <i class="bi bi-shield-check text-success me-1"></i>
                    Verileriniz güvende. Sadece lisans doğrulaması yapılır, hiçbir veriniz silinmez.
                </p>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@successMessage
                    <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
                </div>
            }

            <div class="login-form">
                @if (!ikiFaktorDogrulamaBekleniyor)
                {
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="kullaniciAdi" placeholder="Kullanici Adi"
                               @bind="kullaniciAdi" @bind:event="oninput" @onkeypress="HandleKeyPress" autocomplete="username" />
                        <label for="kullaniciAdi"><i class="bi bi-person me-2"></i>Kullanici Adi</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="@(showPassword ? "text" : "password")" class="form-control" id="sifre" placeholder="Sifre"
                               @bind="sifre" @bind:event="oninput" @onkeypress="HandleKeyPress" autocomplete="current-password" />
                        <label for="sifre"><i class="bi bi-lock me-2"></i>Sifre</label>
                        <button type="button" class="password-toggle" @onclick="() => showPassword = !showPassword">
                            <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="beniHatirla" @bind="beniHatirla" />
                            <label class="form-check-label" for="beniHatirla">Beni Hatirla</label>
                        </div>
                        <a href="#" class="forgot-password" @onclick="SifremiUnuttum" @onclick:preventDefault>Sifremi Unuttum</a>
                    </div>

                    @if (showForgotPasswordPanel)
                    {
                        <div class="alert alert-info">
                            <div class="mb-2 fw-semibold">Şifre Sıfırlama</div>
                            <div class="mb-2">
                                <input type="text" class="form-control" placeholder="Kullanıcı adı veya e-posta"
                                       @bind="forgotPasswordInput" @bind:event="oninput" />
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-primary" @onclick="SifreSifirlamaTalebiGonderAsync" disabled="@forgotPasswordLoading">
                                    @if (forgotPasswordLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    Gönder
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="KapatSifrePaneli">Vazgeç</button>
                            </div>
                            <small class="d-block mt-2 text-muted">Eşleşen aktif kullanıcı ve kayıtlı e-posta varsa geçici şifre gönderilir.</small>
                        </div>
                    }

                    <button class="btn btn-primary btn-login w-100" @onclick="GirisYapAsync" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Giris Yapiliyor...</span>
                        }
                        else
                        {
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            <span>Giris Yap</span>
                        }
                    </button>
                }
                else
                {
                    <div class="alert alert-info">
                        <div class="fw-semibold mb-1">İki Faktörlü Doğrulama</div>
                        <div class="small">@(ikiFaktorHedefi ?? "Authenticator uygulamanız") üzerinden üretilen 6 haneli kodu girin.</div>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="ikiFaktorKodu" placeholder="123456"
                               @bind="ikiFaktorKodu" @bind:event="oninput" @onkeypress="HandleKeyPress" autocomplete="one-time-code" maxlength="6" />
                        <label for="ikiFaktorKodu"><i class="bi bi-shield-lock me-2"></i>Doğrulama Kodu</label>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-login w-100" @onclick="IkiFaktorGirisiTamamlaAsync" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Dogrulaniyor...</span>
                            }
                            else
                            {
                                <i class="bi bi-shield-check me-2"></i>
                                <span>Kodu Doğrula</span>
                            }
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="IkiFaktorAdiminiIptalEt" disabled="@isLoading">
                            <i class="bi bi-arrow-left me-1"></i>Geri Dön
                        </button>
                    </div>
                }
            </div>
        }

        <div class="login-footer">
            @if (lisans != null)
            {
                var remainingDays = LicenseService.GetRemainingDays(lisans);
                <div class="license-info">
                    <span class="badge @(remainingDays <= 7 ? "bg-danger" : "bg-success")">
                        @(lisans.IsDemo ? "Demo" : "Aktif") - @remainingDays Gun Kaldi
                    </span>
                </div>
            }
            <p class="version mb-1">v1.0.0 © @DateTime.Now.Year Allbatros Global Teknoloji</p>
            <p class="version small">Tum Haklari Saklidir</p>
        </div>
    </div>
</div>

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        position: relative;
        overflow: hidden;
        padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    }

    .login-background {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.1;
    }

    .shape-1 {
        width: 400px;
        height: 400px;
        background: white;
        top: -100px;
        left: -100px;
        animation: float 8s ease-in-out infinite;
    }

    .shape-2 {
        width: 300px;
        height: 300px;
        background: white;
        bottom: -50px;
        right: -50px;
        animation: float 6s ease-in-out infinite reverse;
    }

    .shape-3 {
        width: 200px;
        height: 200px;
        background: white;
        top: 50%;
        right: 20%;
        animation: float 10s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-30px) rotate(10deg); }
    }

    .login-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        padding: 40px;
        width: 100%;
        max-width: 420px;
        position: relative;
        z-index: 10;
        animation: slideUp 0.5s ease-out;
        margin: 20px;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .logo-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin: 0 auto 20px;
    }

    .logo-img {
        width: 80px;
        height: 80px;
        object-fit: contain;
        filter: drop-shadow(0 8px 20px rgba(30, 60, 114, 0.3));
    }

    .logo-text-img {
        max-width: 240px;
        height: auto;
        object-fit: contain;
        opacity: 0.9;
    }

    .login-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #2a5298;
        margin-bottom: 5px;
    }

    .brand-koa {
        color: #1e3c72;
        font-weight: 800;
    }

    .login-header p {
        color: #6c757d;
        font-size: 0.9rem;
    }

    .form-floating {
        position: relative;
    }

    .form-floating .form-control {
        height: 55px;
        border-radius: 12px;
        border: 2px solid #e9ecef;
        padding-left: 45px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-floating .form-control:focus {
        border-color: #1e3c72;
        box-shadow: 0 0 0 4px rgba(30, 60, 114, 0.1);
    }

    .form-floating label {
        padding-left: 45px;
        color: #6c757d;
    }

    .form-floating label i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #1e3c72;
    }

    .password-toggle {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #6c757d;
        cursor: pointer;
        z-index: 10;
    }

    .password-toggle:hover {
        color: #1e3c72;
    }

    .form-check-input:checked {
        background-color: #1e3c72;
        border-color: #1e3c72;
    }

    .forgot-password {
        color: #1e3c72;
        text-decoration: none;
        font-size: 0.875rem;
    }

    .forgot-password:hover {
        text-decoration: underline;
    }

    .btn-login {
        height: 55px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        border: none;
        transition: all 0.3s ease;
    }

    .btn-login:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px -5px rgba(30, 60, 114, 0.4);
    }

    .btn-login:disabled {
        opacity: 0.7;
    }

    .login-footer {
        text-align: center;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .license-info {
        margin-bottom: 10px;
    }

    .version {
        color: #adb5bd;
        font-size: 0.8rem;
        margin: 0;
    }

    .alert {
        border-radius: 12px;
        margin-bottom: 20px;
    }

    @@media (max-width: 480px) {
        .login-card {
            padding: 25px;
            margin: 10px;
        }

        .logo-img {
            width: 60px;
            height: 60px;
        }

        .logo-text-img {
            max-width: 180px;
        }

        .login-header h1 {
            font-size: 1.4rem;
        }

        .form-floating .form-control {
            height: 50px;
        }

        .btn-login {
            height: 50px;
            font-size: 1rem;
        }
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "project")]
    public string? Project { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string kullaniciAdi = "";
    private string sifre = "";
    private bool beniHatirla = false;
    private bool showPassword = false;
    private bool isLoading = false;
    private bool forgotPasswordLoading = false;
    private bool showForgotPasswordPanel = false;
    private bool ikiFaktorDogrulamaBekleniyor = false;
    private int? bekleyenIkiFaktorKullaniciId;
    private string? ikiFaktorHedefi;
    private string ikiFaktorKodu = "";
    private string? errorMessage;
    private string? successMessage;
    private string forgotPasswordInput = "";
    private KOAFiloServis.Shared.Entities.LicenseInfo? lisans;
    private PortalProjectDefinition? selectedProject;

    // Lisans kontrol alanlari
    private bool lisansSuresiDoldu = false;
    private string makineKodu = "";
    private string yeniLisansAnahtari = "";
    private string? lisansHataMesaji;
    private string? lisansBasariMesaji;
    private bool lisansAktivasyonYukleniyor = false;

    private const string REMEMBER_KEY = "KOAFiloServis_RememberMe";

    protected override async Task OnInitializedAsync()
    {
        lisans = await LicenseSvc.GetCurrentLicenseAsync();
        selectedProject = PortalProjectCatalogService.GetProjectBySlug(Project)
            ?? PortalProjectCatalogService.GetDefaultProject();

        // Lisans gecerlilik kontrolu
        makineKodu = LicenseService.GetMachineId();
        if (lisans == null || (lisans.IsDemo && LicenseService.IsDemoExpired(lisans)))
        {
            lisansSuresiDoldu = true;
            return;
        }
        if (DateTime.UtcNow > lisans.ExpireDate)
        {
            lisansSuresiDoldu = true;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(GetSafeReturnUrl(), forceLoad: false);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HatirlananKullaniciAdiniYukleAsync();
        }
    }

    private async Task GirisYapAsync()
    {
        if (isLoading)
        {
            return;
        }

        // Input degerlerini temizle (bosluk karakterleri)
        kullaniciAdi = kullaniciAdi?.Trim() ?? "";
        sifre = sifre ?? "";

        if (string.IsNullOrWhiteSpace(kullaniciAdi) || string.IsNullOrWhiteSpace(sifre))
        {
            errorMessage = "Kullanici adi ve sifre zorunludur!";
            return;
        }

        isLoading = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            var sonuc = await KullaniciService.GirisYapAsync(kullaniciAdi, sifre);

            if (sonuc.IkiFaktorGerekli && sonuc.BekleyenKullaniciId.HasValue)
            {
                bekleyenIkiFaktorKullaniciId = sonuc.BekleyenKullaniciId;
                ikiFaktorHedefi = sonuc.IkiFaktorHedefi;
                ikiFaktorKodu = string.Empty;
                ikiFaktorDogrulamaBekleniyor = true;
                sifre = string.Empty;
                errorMessage = sonuc.Mesaj;
            }
            else if (sonuc.Basarili)
            {
                await HatirlamaTercihiniKaydetAsync();

                successMessage = "Giris basarili! Yonlendiriliyorsunuz...";
                StateHasChanged();

                // Kisa bir bekleme ile authentication state'in tum componentlere yayilmasini sagla
                // 150ms - auth state propagation icin yeterli sure
                await Task.Delay(150);

                // Dashboard'a yonlendir - forceLoad: false ile ayni circuit icinde
                // navigation yaparak authentication state'in korunmasini sagliyoruz
                sifre = string.Empty;
                Navigation.NavigateTo(GetSafeReturnUrl(), forceLoad: true); // 🔥 forceLoad: true — App.razor lisans gate'i yeniden değerlendirsin
            }
            else
            {
                errorMessage = sonuc.Mesaj ?? "Giris basarisiz!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Bir hata olustu: " + ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (ikiFaktorDogrulamaBekleniyor)
            {
                await IkiFaktorGirisiTamamlaAsync();
            }
            else
            {
                await GirisYapAsync();
            }
        }
    }

    private async Task IkiFaktorGirisiTamamlaAsync()
    {
        if (isLoading || !bekleyenIkiFaktorKullaniciId.HasValue)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(ikiFaktorKodu))
        {
            errorMessage = "Doğrulama kodu zorunludur!";
            return;
        }

        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var sonuc = await KullaniciService.IkiFaktorGirisiTamamlaAsync(bekleyenIkiFaktorKullaniciId.Value, ikiFaktorKodu);
            if (sonuc.Basarili)
            {
                await HatirlamaTercihiniKaydetAsync();
                successMessage = "Giriş başarılı! Yönlendiriliyorsunuz...";
                StateHasChanged();
                await Task.Delay(150);
                Navigation.NavigateTo(GetSafeReturnUrl(), forceLoad: true); // 🔥 forceLoad: true — App.razor lisans gate'i yeniden değerlendirsin
            }
            else
            {
                errorMessage = sonuc.Mesaj ?? "Doğrulama başarısız!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Bir hata oluştu: " + ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void IkiFaktorAdiminiIptalEt()
    {
        ikiFaktorDogrulamaBekleniyor = false;
        bekleyenIkiFaktorKullaniciId = null;
        ikiFaktorHedefi = null;
        ikiFaktorKodu = string.Empty;
        errorMessage = null;
        successMessage = null;
    }

    private void SifremiUnuttum()
    {
        errorMessage = null;
        successMessage = null;
        forgotPasswordInput = kullaniciAdi;
        showForgotPasswordPanel = true;
    }

    private void KapatSifrePaneli()
    {
        showForgotPasswordPanel = false;
        forgotPasswordInput = string.Empty;
    }

    private async Task SifreSifirlamaTalebiGonderAsync()
    {
        if (forgotPasswordLoading)
            return;

        if (string.IsNullOrWhiteSpace(forgotPasswordInput))
        {
            errorMessage = "Kullanıcı adı veya e-posta girin.";
            successMessage = null;
            return;
        }

        forgotPasswordLoading = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            var result = await KullaniciService.SifremiUnuttumAsync(forgotPasswordInput);
            if (result)
            {
                successMessage = "Geçici şifre e-posta adresinize gönderildi.";
                showForgotPasswordPanel = false;
                forgotPasswordInput = string.Empty;
            }
            else
            {
                errorMessage = "Şifre sıfırlama işlemi tamamlanamadı. Kullanıcı adı/e-posta veya e-posta ayarlarını kontrol edin.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Bir hata oluştu: " + ex.Message;
        }
        finally
        {
            forgotPasswordLoading = false;
            StateHasChanged();
        }
    }

    private async Task HatirlananKullaniciAdiniYukleAsync()
    {
        try
        {
            var yeniFormat = await LocalStorage.GetAsync<RememberedLoginInfo>(REMEMBER_KEY);
            if (yeniFormat.Success && !string.IsNullOrWhiteSpace(yeniFormat.Value?.KullaniciAdi))
            {
                kullaniciAdi = yeniFormat.Value.KullaniciAdi.Trim();
                beniHatirla = true;
                StateHasChanged();
                return;
            }

            var eskiFormat = await LocalStorage.GetAsync<string>(REMEMBER_KEY);
            if (eskiFormat.Success && !string.IsNullOrWhiteSpace(eskiFormat.Value))
            {
                kullaniciAdi = eskiFormat.Value.Trim();
                beniHatirla = true;
                await LocalStorage.SetAsync(REMEMBER_KEY, new RememberedLoginInfo
                {
                    KullaniciAdi = kullaniciAdi,
                    KaydedilmeTarihi = DateTime.UtcNow
                });
                StateHasChanged();
                return;
            }

            if ((yeniFormat.Success && string.IsNullOrWhiteSpace(yeniFormat.Value?.KullaniciAdi))
                || (eskiFormat.Success && string.IsNullOrWhiteSpace(eskiFormat.Value)))
            {
                await LocalStorage.DeleteAsync(REMEMBER_KEY);
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Login hatirlanan kullanici adi yuklenirken hata olustu");
        }
    }

    private async Task HatirlamaTercihiniKaydetAsync()
    {
        try
        {
            if (beniHatirla)
            {
                await LocalStorage.SetAsync(REMEMBER_KEY, new RememberedLoginInfo
                {
                    KullaniciAdi = kullaniciAdi,
                    KaydedilmeTarihi = DateTime.UtcNow
                });
            }
            else
            {
                await LocalStorage.DeleteAsync(REMEMBER_KEY);
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Login hatirlama tercihi kaydedilirken hata olustu");
        }
    }

    private string GetSafeReturnUrl()
    {
        // Aşama H (K2): Login sonrası önce firma seçim ekranına gönder.
        // FirmaSec tek firma varsa otomatik olarak hedef URL'e yönlendirir,
        // birden fazla firma varsa kullanıcıya seçim sunar.
        var hedef = "/dashboard";
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
        {
            var decoded = Uri.UnescapeDataString(ReturnUrl);
            if (decoded.StartsWith('/') && !decoded.StartsWith("//") &&
                !decoded.StartsWith("/login", StringComparison.OrdinalIgnoreCase) &&
                !decoded.StartsWith("/firma-sec", StringComparison.OrdinalIgnoreCase))
            {
                hedef = decoded;
            }
        }

        return $"/firma-sec?returnUrl={Uri.EscapeDataString(hedef)}";
    }

    private string GetRegisterUrl()
    {
        return string.IsNullOrWhiteSpace(Project)
            ? "/register"
            : $"/register?project={Uri.EscapeDataString(Project)}";
    }

    private async Task LisansAktiveEtAsync()
    {
        if (string.IsNullOrWhiteSpace(yeniLisansAnahtari))
        {
            lisansHataMesaji = "Lisans anahtari bos olamaz!";
            return;
        }

        lisansAktivasyonYukleniyor = true;
        lisansHataMesaji = null;
        lisansBasariMesaji = null;
        StateHasChanged();

        try
        {
            // Auto-trim
            yeniLisansAnahtari = yeniLisansAnahtari.Trim().Replace("\r", "").Replace("\n", "").Replace(" ", "");

            var yeniLisans = await LicenseSvc.ActivateFromKeyAsync(yeniLisansAnahtari);

            lisans = yeniLisans;
            lisansSuresiDoldu = false;
            yeniLisansAnahtari = "";
            lisansBasariMesaji = null;
            var kalanGun = LicenseService.GetRemainingDays(yeniLisans);
            successMessage = $"✅ Lisans basariyla aktive edildi! {kalanGun} gun gecerli. Yonlendiriliyorsunuz...";
            StateHasChanged();

            // Sayfayi yeniden yukle — lisans kontrolu tekrar calissin, FULL MODE acilsin
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            lisansHataMesaji = "Girilen lisans anahtarı geçersiz görünüyor. Lütfen doğru anahtarı kullandığınızdan emin olun.";
        }
        finally
        {
            lisansAktivasyonYukleniyor = false;
            StateHasChanged();
        }
    }

    private bool _makineKoduKopyalandi;

    private async Task MakineKoduKopyala()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", makineKodu);
            _makineKoduKopyalandi = true;
            StateHasChanged();
            await Task.Delay(2000);
            _makineKoduKopyalandi = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Login makine kodu panoya kopyalanirken hata olustu");
        }
    }

    private sealed class RememberedLoginInfo
    {
        public string KullaniciAdi { get; set; } = string.Empty;
        public DateTime KaydedilmeTarihi { get; set; }
    }
}

