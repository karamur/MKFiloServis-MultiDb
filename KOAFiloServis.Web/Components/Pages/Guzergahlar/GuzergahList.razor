    private void ImportModalAc()
    {
        importDosya = null;
        importDosyaAdi = null;
        importDosyaBoyutu = 0;
        importEdiliyor = false;
        importYapildi = false;
        importSonuc = null;
        showImportModal = true;
    }

    private void ImportModalKapat()
    {
        showImportModal = false;
        importDosya = null;
        importDosyaAdi = null;
    }

    private async Task ImportVeYenile()
    {
        showImportModal = false;
        importDosya = null;
        await LoadData();
        StateHasChanged();
    }

    private async Task ImportDosyaSecildi(InputFileChangeEventArgs e)
    {
        importDosya = e.File;
        importDosyaAdi = e.File.Name;
        importDosyaBoyutu = e.File.Size;
        importYapildi = false;
        importSonuc = null;
        await Task.CompletedTask;
    }

    private async Task ImportCalistir()
    {
        if (importDosya == null) return;

        importEdiliyor = true;
        importYapildi = false;
        importSonuc = null;
        StateHasChanged();

        try
        {
            var firmaId = AktifFirma.AktifFirmaId ?? 1;
            await using var stream = importDosya.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            importSonuc = await GuzergahService.ImportFromExcelAsync(stream, firmaId);
            importYapildi = true;
        }
        catch (Exception ex)
        {
            importSonuc = new GuzergahImportSonuc
            {
                Hatali = 1,
                Satirlar = { new GuzergahImportSatir { SatirNo = 0, Basarili = false, Mesaj = $"Dosya okuma hatası: {ex.Message}" } }
            };
            importYapildi = true;
        }
        finally
        {
            importEdiliyor = false;
        }
    }

