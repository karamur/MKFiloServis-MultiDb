    private string TruncateText(string? text, int maxLength) => string.IsNullOrEmpty(text) ? "" : text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    private string FormatPara(decimal tutar) => tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR"));

    private List<FaturaKalem> GetSeciliKalemlerVeTekrarlari()
    {
        var secilenler = eslesmemisKalemler.Where(k => seciliKalemler.Contains(k.Id)).ToList();
        return GetKalemlerVeTekrarlari(secilenler);
    }

    private List<FaturaKalem> GetDegistirilmisKalemlerVeTekrarlari()
    {
        var degistirilenler = eslesmemisKalemler.Where(k => degistirilmisKalemler.Contains(k.Id)).ToList();
        return GetKalemlerVeTekrarlari(degistirilenler);
    }

    private List<FaturaKalem> GetKalemlerVeTekrarlari(List<FaturaKalem> kaynakKalemler)
    {
        if (!kaynakKalemler.Any())
            return new List<FaturaKalem>();

        var sonuc = new Dictionary<int, FaturaKalem>();

        foreach (var secilen in kaynakKalemler)
        {
            var ayniKalemler = eslesmemisKalemler.Where(k =>
                NormalizeMatchValue(k.Aciklama) == NormalizeMatchValue(secilen.Aciklama) &&
                NormalizeMatchValue(k.UrunKodu) == NormalizeMatchValue(secilen.UrunKodu));

            foreach (var kalem in ayniKalemler)
                sonuc[kalem.Id] = kalem;
        }

        return sonuc.Values.ToList();
    }

    private static string NormalizeMatchValue(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim().ToLowerInvariant();

    private string GetStokKoduInputValue(FaturaKalem kalem)
    {
        if (string.IsNullOrWhiteSpace(kalem.UrunKodu))
            return string.Empty;

        var stok = stokKartlari.FirstOrDefault(s => string.Equals(s.StokKodu, kalem.UrunKodu, StringComparison.OrdinalIgnoreCase));
        return stok == null ? kalem.UrunKodu : GetStokKoduOptionValue(stok);
    }

    private static string GetStokKoduOptionValue(StokKarti stok) => $"{stok.StokKodu} | {stok.StokAdi}";

    // Güzergah İşlemleri
    private bool TasimaHizmetiSeciliMi()
    {
        // Toplu tür olarak Hizmet ve Taşıma seçilmişse
        if (!string.IsNullOrEmpty(topluKalemTipi) && int.TryParse(topluKalemTipi, out var tipInt))
        {
            if ((FaturaKalemTipi)tipInt == FaturaKalemTipi.Hizmet)
            {
                if (!string.IsNullOrEmpty(topluAltTipi) && int.TryParse(topluAltTipi, out var altTipInt))
                {
                    return (FaturaKalemAltTipi)altTipInt == FaturaKalemAltTipi.TasimaHizmeti;
                }
            }
        }
        return false;
    }

    private async Task GuzergahOnizlemeAc()
    {
        if (!seciliKalemler.Any()) return;

        var secilenKalemler = eslesmemisKalemler.Where(k => seciliKalemler.Contains(k.Id)).ToList();
        guzergahListesi = secilenKalemler.Select(k => ParseGuzergahFromKalem(k)).ToList();

        await MevcutGuzergahKontrolEtAsync();
        showGuzergahModal = true;
    }

    private async Task MevcutGuzergahKontrolEtAsync()
    {
        foreach (var item in guzergahListesi)
        {
            var mevcut = await GuzergahService.GetByFaturaKalemIdAsync(item.FaturaKalemId);
            if (mevcut != null)
            {
                item.ZatenMevcut = true;
                item.MevcutGuzergahAdi = mevcut.GuzergahAdi;
                item.Secili = false; // Mevcut olanları otomatik seçme
            }
        }
        StateHasChanged();
    }

    private GuzergahOnizlemeItem ParseGuzergahFromKalem(FaturaKalem kalem)
    {
        var aciklama = kalem.Aciklama ?? "";
        var firmaAdi = kalem.Fatura?.Cari?.Unvan ?? "";

        // Açıklamadan sefer tipini çıkar (SABAH-AKŞAM, SABAH, AKŞAM, SAATLİK)
        var seferTipi = SeferTipi.SabahAksam;
        var aciklamaLower = aciklama.ToLowerInvariant();

        if (aciklamaLower.Contains("sabah-akşam") || aciklamaLower.Contains("sabah-aksam") || aciklamaLower.Contains("s-a"))
            seferTipi = SeferTipi.SabahAksam;
        else if (aciklamaLower.Contains("saatlik") || aciklamaLower.Contains("saat"))
            seferTipi = SeferTipi.Saatlik;
        else if (aciklamaLower.Contains("sabah"))
            seferTipi = SeferTipi.Sabah;
        else if (aciklamaLower.Contains("akşam") || aciklamaLower.Contains("aksam"))
            seferTipi = SeferTipi.Aksam;

        // Güzergah adını temizle (sefer tipi ifadelerini kaldır)
        var guzergahAdi = aciklama
            .Replace("SABAH-AKŞAM", "", StringComparison.OrdinalIgnoreCase)
            .Replace("SABAH-AKSAM", "", StringComparison.OrdinalIgnoreCase)
            .Replace("SAATLİK", "", StringComparison.OrdinalIgnoreCase)
            .Replace("SAATLIK", "", StringComparison.OrdinalIgnoreCase)
            .Replace("SABAH", "", StringComparison.OrdinalIgnoreCase)
            .Replace("AKŞAM", "", StringComparison.OrdinalIgnoreCase)
            .Replace("AKSAM", "", StringComparison.OrdinalIgnoreCase)
            .Replace("S-A", "", StringComparison.OrdinalIgnoreCase)
            .Replace("()", "")
            .Replace("( )", "")
            .Trim();

        // Parantez içindekileri temizle
        while (guzergahAdi.Contains("(") && guzergahAdi.Contains(")"))
        {
            var start = guzergahAdi.IndexOf("(");
            var end = guzergahAdi.IndexOf(")");
            if (end > start)
                guzergahAdi = guzergahAdi.Remove(start, end - start + 1).Trim();
            else
                break;
        }

        // Firma eşleştir
        var firmaId = 0;
        var cariId = kalem.Fatura?.CariId ?? 0;

        if (kalem.Fatura?.Cari != null)
        {
            var eslesenFirma = firmalar.FirstOrDefault(f => 
                f.FirmaAdi.Contains(kalem.Fatura.Cari.Unvan, StringComparison.OrdinalIgnoreCase) ||
                kalem.Fatura.Cari.Unvan.Contains(f.FirmaAdi, StringComparison.OrdinalIgnoreCase));
            if (eslesenFirma != null)
                firmaId = eslesenFirma.Id;
        }

        return new GuzergahOnizlemeItem
        {
            FaturaKalemId = kalem.Id,
            CariId = cariId,
            FirmaAdi = firmaAdi,
            FirmaId = firmaId,
            GuzergahAdi = guzergahAdi,
            SeferTipi = seferTipi,
            PersonelSayisi = (int)kalem.Miktar,
            BirimFiyat = kalem.BirimFiyat,
            Miktar = kalem.Miktar,
            Secili = true
        };
    }

    private void GuzergahTumunuSec(bool secili)
    {
        foreach (var g in guzergahListesi)
            g.Secili = secili;
    }

    private async Task GuzergahlariOlustur()
    {
        var ilgiliKalemIds = guzergahListesi.Select(g => g.FaturaKalemId).ToHashSet();
        var ilgiliKalemler = GetKalemlerVeTekrarlari(eslesmemisKalemler
            .Where(k => ilgiliKalemIds.Contains(k.Id))
            .ToList());

        foreach (var kalem in ilgiliKalemler)
        {
            kalem.KalemTipi = FaturaKalemTipi.Hizmet;
            kalem.AltTipi = FaturaKalemAltTipi.KiralamaHizmeti;
            degistirilmisKalemler.Add(kalem.Id);
        }

        StokKartiOlusturSonuc? stokSonuc = null;

        if (ilgiliKalemler.Any())
        {
            stokSonuc = await FaturaService.UpdateFaturaKalemleriVeStokKartiOlusturAsync(ilgiliKalemler, true);
            foreach (var kalemId in ilgiliKalemler.Select(k => k.Id))
                degistirilmisKalemler.Remove(kalemId);
        }

        // Mevcut olmayan ve firma seçilmiş güzergahları al
        var seciliGuzergahlar = guzergahListesi
            .Where(g => g.Secili && g.FirmaId > 0 && !g.ZatenMevcut)
            .ToList();

        if (!seciliGuzergahlar.Any())
        {
            if (stokSonuc?.OlusturulanStokKartiSayisi > 0)
            {
                ToastService.ShowSuccess($"{stokSonuc.OlusturulanStokKartiSayisi} stok kartı Hizmet / Kiralama olarak oluşturuldu.");
            }

            if (stokSonuc?.AtlananStokKartiSayisi > 0)
            {
                ToastService.ShowInfo($"{stokSonuc.AtlananStokKartiSayisi} stok kartı zaten mevcut olduğu için güncellendi/atlanıldı.");
            }

            ToastService.ShowInfo("Seçili satırlar için oluşturulacak yeni güzergah bulunamadı. Mevcut güzergahlar tekrar oluşturulmaz.");
            return;
        }

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            var olusturulanSayisi = 0;
            var atladiSayisi = 0;
            var hataListesi = new List<string>();

            foreach (var item in seciliGuzergahlar)
            {
                try
                {
                    // Zaten bu fatura kaleminden oluşturulmuş mu kontrol et
                    if (await GuzergahService.FaturaKalemdenGuzergahVarMiAsync(item.FaturaKalemId))
                    {
                        atladiSayisi++;
                        continue;
                    }

                    // Aynı firma + güzergah adı benzersiz mi kontrol et
                    if (!await GuzergahService.BenzersizGuzergahMiAsync(item.FirmaId, item.GuzergahAdi))
                    {
                        hataListesi.Add($"{item.GuzergahAdi}: Bu firma için zaten mevcut");
                        continue;
                    }

                    // Güzergah kodu oluştur
                    var guzergahKodu = await GuzergahService.GenerateGuzergahKoduAsync(item.FirmaId);

                    var guzergah = new Guzergah
                    {
                        GuzergahKodu = guzergahKodu,
                        GuzergahAdi = item.GuzergahAdi,
                        FirmaId = item.FirmaId,
                        CariId = item.CariId, // Fatura carisinin Id'si (doğru değer)
                        SeferTipi = item.SeferTipi,
                        PersonelSayisi = item.PersonelSayisi,
                        BirimFiyat = item.BirimFiyat,
                        FaturaKalemId = item.FaturaKalemId,
                        Aktif = true
                    };

                    await GuzergahService.AddAsync(guzergah);
                    olusturulanSayisi++;
                }
                catch (Exception ex)
                {
                    hataListesi.Add($"{item.GuzergahAdi}: {ex.Message}");
                }
            }

            if (olusturulanSayisi > 0)
            {
                ToastService.ShowSuccess($"{olusturulanSayisi} güzergah oluşturuldu.");
            }

            if (stokSonuc != null)
            {
                if (stokSonuc.OlusturulanStokKartiSayisi > 0)
                {
                    ToastService.ShowSuccess($"{stokSonuc.OlusturulanStokKartiSayisi} stok kartı Hizmet / Kiralama olarak oluşturuldu.");
                }

                if (stokSonuc.AtlananStokKartiSayisi > 0)
                {
                    ToastService.ShowInfo($"{stokSonuc.AtlananStokKartiSayisi} stok kartı zaten mevcut olduğu için güncellendi/atlanıldı.");
                }
            }

            if (atladiSayisi > 0)
            {
                ToastService.ShowInfo($"{atladiSayisi} güzergah zaten mevcut olduğu için atlandı.");
            }

            foreach (var hata in hataListesi.Take(3))
            {
                ToastService.ShowWarning(hata);
            }

            showGuzergahModal = false;
            seciliKalemler.Clear();
            topluKalemTipi = "";
            topluAltTipi = "";
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

    // Güzergah Önizleme DTO
    private class GuzergahOnizlemeItem
    {
        public int FaturaKalemId { get; set; }
        public int CariId { get; set; } // Fatura carisinin Id'si
        public string FirmaAdi { get; set; } = "";
        public int FirmaId { get; set; }
        public string GuzergahAdi { get; set; } = "";
        public SeferTipi SeferTipi { get; set; }
        public int PersonelSayisi { get; set; }
        public decimal BirimFiyat { get; set; }
        public decimal Miktar { get; set; }
        public bool Secili { get; set; }
        public bool ZatenMevcut { get; set; } // Bu fatura kaleminden zaten güzergah oluşturulmuş mu
        public string? MevcutGuzergahAdi { get; set; } // Varsa mevcut güzergah adı
    }

    // Yansıtma için değişkenler
    private DateTime yansitmaFaturaTarihi = DateTime.Today;
    private string yansitmaFaturaNotu = "";

    // Masraf Yansıtma kontrolü
    private bool MasrafYansitmaSeciliMi()
    {
        if (!string.IsNullOrEmpty(topluKalemTipi) && int.TryParse(topluKalemTipi, out var tipInt))
        {
            if ((FaturaKalemTipi)tipInt == FaturaKalemTipi.Masraf)
            {
                return true;
            }
        }
        return false;
    }

    // Araç değiştirme handler
    private void AracDegistiHandler(ChangeEventArgs e, FaturaKalem kalem)
    {
        if (int.TryParse(e.Value?.ToString(), out var yeniAracId))
        {
            kalem.AracId = yeniAracId == 0 ? null : yeniAracId;
            degistirilmisKalemler.Add(kalem.Id);
        }
    }

    // Toplu araç atama
    private async Task TopluAracAtaAsync()
    {
        if (string.IsNullOrEmpty(topluAracId) || !seciliKalemler.Any()) return;

        var aracId = int.Parse(topluAracId);
        var arac = araclar.FirstOrDefault(a => a.Id == aracId);
        var secilenKalemler = GetSeciliKalemlerVeTekrarlari();
        var sayac = 0;

        foreach (var kalem in secilenKalemler)
        {
            kalem.AracId = aracId;
            degistirilmisKalemler.Add(kalem.Id);
            sayac++;
        }

        ToastService.ShowSuccess($"{sayac} kaleme '{arac?.AktifPlaka}' plakası atandı.");
        StateHasChanged();
    }

    // Yansıtma önizleme aç
    private void YansitmaOnizlemeAc()
    {
        if (!seciliKalemler.Any()) return;

        var secilenKalemler = eslesmemisKalemler.Where(k => seciliKalemler.Contains(k.Id)).ToList();

        yansitmaListesi = secilenKalemler.Select(k => {
            var arac = k.AracId.HasValue ? araclar.FirstOrDefault(a => a.Id == k.AracId) : null;
            return new YansitmaOnizlemeItem
            {
                FaturaKalemId = k.Id,
                AracId = k.AracId,
                Plaka = arac?.AktifPlaka ?? "Araç Seçilmedi",
                AracMarkaModel = arac != null ? $"{arac.Marka} {arac.Model}" : "",
                Aciklama = $"Yansıtma: {k.Aciklama}",
                FaturaTarihi = k.Fatura?.FaturaTarihi ?? DateTime.Today,
                Tutar = k.ToplamTutar,
                KdvOrani = k.KdvOrani,
                Secili = true
            };
        }).ToList();

        yansitmaFaturaTarihi = DateTime.Today;
        yansitmaFaturaNotu = "Araç masrafı yansıtma faturası";
        showYansitmaModal = true;
    }

    private void YansitmaTumunuSec(bool secili)
    {
        foreach (var y in yansitmaListesi)
            y.Secili = secili;
    }

    private async Task YansitmaFaturaOlustur()
    {
        var seciliYansitmalar = yansitmaListesi.Where(y => y.Secili).ToList();
        if (!seciliYansitmalar.Any())
        {
            ToastService.ShowWarning("En az bir kalem seçmelisiniz.");
            return;
        }

        // Araç seçilmemiş kalem var mı kontrol et
        var aracsizlar = seciliYansitmalar.Where(y => !y.AracId.HasValue).ToList();
        if (aracsizlar.Any())
        {
            var onay = await JS.InvokeAsync<bool>("confirm", $"{aracsizlar.Count} kalemde araç seçili değil. Devam etmek istiyor musunuz?");
            if (!onay) return;
        }

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            // Yansıtma faturası için kalem listesi hazırla
            var yansitmaKalemleri = seciliYansitmalar.Select(y => new FaturaKalem
            {
                Aciklama = y.Aciklama,
                Miktar = 1,
                BirimFiyat = y.Tutar,
                KdvOrani = y.KdvOrani,
                KdvTutar = y.Tutar * y.KdvOrani / 100,
                ToplamTutar = y.Tutar * (1 + y.KdvOrani / 100),
                AracId = y.AracId,
                KalemTipi = FaturaKalemTipi.Masraf,
                AltTipi = FaturaKalemAltTipi.YansitmaBedeli
            }).ToList();

            var toplamTutar = yansitmaKalemleri.Sum(k => k.ToplamTutar);

            // Burada yansıtma faturası oluşturma servisi çağrılabilir
            // await FaturaService.YansitmaFaturasiOlusturAsync(yansitmaKalemleri, yansitmaFaturaTarihi, yansitmaFaturaNotu);

            ToastService.ShowSuccess($"{seciliYansitmalar.Count} kalem için yansıtma faturası hazırlandı. Toplam: {FormatPara(toplamTutar)} TL");
            ToastService.ShowInfo("Fatura oluşturmak için Faturalar sayfasına yönlendirileceksiniz.");

            showYansitmaModal = false;
            seciliKalemler.Clear();
            topluKalemTipi = "";
            topluAltTipi = "";
            topluAracId = "";
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

    // Yansıtma Önizleme DTO
    private class YansitmaOnizlemeItem
    {
        public int FaturaKalemId { get; set; }
        public int? AracId { get; set; }
        public string Plaka { get; set; } = "";
        public string AracMarkaModel { get; set; } = "";
        public string Aciklama { get; set; } = "";
        public DateTime FaturaTarihi { get; set; }
        public decimal Tutar { get; set; }
        public decimal KdvOrani { get; set; } = 20;
        public bool Secili { get; set; }
    }
}
