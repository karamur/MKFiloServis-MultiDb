@page "/raporlar/sozlesme-yenileme-takvimi"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@inject ITasimaTedarikciService TedarikciService
@inject IKiralikPlakaTakipService KiralikService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Sözleşme Yenileme Takvimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-calendar-event-fill me-2 text-primary"></i>Sözleşme Yenileme Takvimi</h2>
            <p class="text-muted mb-0">Tedarikçi + kiralık plaka sözleşme bitişlerinin zaman çizelgesi</p>
        </div>
        <div>
            <button class="btn btn-success btn-sm" @onclick="ExcelIndir" disabled="@(!satirlar.Any())">
                <i class="bi bi-file-earmark-excel-fill me-1"></i>Excel
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Önümüzdeki (gün)</label>
                    <select class="form-select form-select-sm" @bind="onumuzdekiGun" @bind:after="LoadAsync">
                        <option value="30">30 gün</option>
                        <option value="60">60 gün</option>
                        <option value="90">90 gün</option>
                        <option value="180">180 gün</option>
                        <option value="365">365 gün</option>
                        <option value="9999">Tümü</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Tip</label>
                    <select class="form-select form-select-sm" @bind="tipFiltre" @bind:after="FiltreUygula">
                        <option value="">Tümü</option>
                        <option value="Tedarikci">Tedarikçi</option>
                        <option value="Kiralik">Kiralık Plaka</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Durum</label>
                    <select class="form-select form-select-sm" @bind="durumFiltre" @bind:after="FiltreUygula">
                        <option value="">Tümü</option>
                        <option value="gecmis">Süresi Geçmiş</option>
                        <option value="kritik">Kritik (≤30 gün)</option>
                        <option value="uyari">Uyarı (31-90 gün)</option>
                        <option value="bilgi">Bilgi (>90 gün)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Arama</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Ünvan / plaka..." @bind="aramaMetni" @bind:after="FiltreUygula" />
                </div>
                <div class="col-md-3 text-end">
                    <span class="badge bg-danger me-1">Geçmiş: @gecmisSayi</span>
                    <span class="badge bg-warning text-dark me-1">Kritik: @kritikSayi</span>
                    <span class="badge bg-info">Uyarı: @uyariSayi</span>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Sözleşme verileri yükleniyor...</p>
        </div>
    }
    else
    {
        <!-- AYLIK ZAMAN ÇİZELGESİ -->
        <div class="card mb-3">
            <div class="card-header bg-light">
                <strong><i class="bi bi-calendar3 me-2"></i>12 Aylık Bitiş Dağılımı</strong>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    @foreach (var ay in aylikDagilim)
                    {
                        var renk = ay.Adet == 0 ? "light" : ay.Adet >= 5 ? "danger" : ay.Adet >= 3 ? "warning" : "info";
                        var textRenk = ay.Adet == 0 ? "muted" : renk == "warning" ? "dark" : "white";
                        <div class="col">
                            <div class="card border-@renk @(ay.Adet == 0 ? "" : $"bg-{renk}")">
                                <div class="card-body p-2 text-center text-@textRenk">
                                    <div class="small">@ay.AyAdi</div>
                                    <h4 class="mb-0">@ay.Adet</h4>
                                    <small>sözleşme</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- TABLO -->
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-list-check me-2"></i>Sözleşme Listesi</strong>
                <span class="badge bg-primary">@filtreliSatirlar.Count / @satirlar.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Durum</th>
                                <th>Tip</th>
                                <th>Sözleşme/Tarafa</th>
                                <th>No / Plaka</th>
                                <th>Başlangıç</th>
                                <th>Bitiş</th>
                                <th class="text-end">Kalan Gün</th>
                                <th class="text-end">Tutar</th>
                                <th>İletişim</th>
                                <th>Aksiyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in filtreliSatirlar)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @SeviyeClass(s.KalanGun)">@SeviyeMetin(s.KalanGun)</span>
                                    </td>
                                    <td><span class="badge bg-secondary">@s.Tip</span></td>
                                    <td><strong>@s.Unvan</strong></td>
                                    <td><small>@(s.SozlesmeNo ?? "—")</small></td>
                                    <td><small>@(s.Baslangic?.ToString("dd.MM.yyyy") ?? "—")</small></td>
                                    <td><small><strong>@s.Bitis.ToString("dd.MM.yyyy")</strong></small></td>
                                    <td class="text-end">
                                        @if (s.KalanGun < 0)
                                        {
                                            <span class="text-danger fw-bold">@(-s.KalanGun) gün geçti</span>
                                        }
                                        else
                                        {
                                            <span class="@(s.KalanGun <= 30 ? "text-warning fw-bold" : "")">@s.KalanGun gün</span>
                                        }
                                    </td>
                                    <td class="text-end">@(s.Tutar.HasValue ? s.Tutar.Value.ToString("N2") + " ₺" : "—")</td>
                                    <td><small>@(s.Iletisim ?? "—")</small></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(s.DetayUrl))
                                        {
                                            <a href="@s.DetayUrl" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-arrow-right"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!filtreliSatirlar.Any())
                            {
                                <tr><td colspan="10" class="text-center text-muted py-4">Kayıt yok</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private int onumuzdekiGun = 90;
    private string tipFiltre = "";
    private string durumFiltre = "";
    private string aramaMetni = "";

    private List<SozlesmeSatir> satirlar = new();
    private List<SozlesmeSatir> filtreliSatirlar = new();
    private List<AylikDagilim> aylikDagilim = new();

    private int gecmisSayi;
    private int kritikSayi;
    private int uyariSayi;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        yukleniyor = true;
        try
        {
            var bugun = DateTime.Today;
            var kesim = onumuzdekiGun >= 9999 ? DateTime.MaxValue : bugun.AddDays(onumuzdekiGun);

            var liste = new List<SozlesmeSatir>();

            // Tedarikçi sözleşmeleri
            var tedarikciler = await TedarikciService.GetAllAsync(false);
            foreach (var t in tedarikciler.Where(x => x.SozlesmeBitisTarihi.HasValue))
            {
                var bitis = t.SozlesmeBitisTarihi!.Value.Date;
                if (onumuzdekiGun < 9999 && bitis > kesim) continue;
                liste.Add(new SozlesmeSatir
                {
                    Tip = "Tedarikçi",
                    Unvan = t.Unvan,
                    SozlesmeNo = t.SozlesmeNo,
                    Baslangic = t.SozlesmeBaslangicTarihi,
                    Bitis = bitis,
                    KalanGun = (bitis - bugun).Days,
                    Tutar = t.VarsayilanSeferUcreti,
                    Iletisim = !string.IsNullOrEmpty(t.YetkiliKisi)
                                ? $"{t.YetkiliKisi} {(string.IsNullOrEmpty(t.Telefon) ? "" : "• " + t.Telefon)}"
                                : t.Telefon,
                    DetayUrl = $"/tedarikciler"
                });
            }

            // Kiralık plakalar
            var kiraliklar = await KiralikService.GetAllAsync();
            foreach (var k in kiraliklar)
            {
                var bitis = k.BitisTarihi.Date;
                if (onumuzdekiGun < 9999 && bitis > kesim) continue;
                liste.Add(new SozlesmeSatir
                {
                    Tip = "Kiralık",
                    Unvan = k.IsimSoyisim,
                    SozlesmeNo = k.Plaka,
                    Baslangic = k.BaslamaTarihi,
                    Bitis = bitis,
                    KalanGun = (bitis - bugun).Days,
                    Tutar = k.Toplam,
                    Iletisim = $"{k.Durum} • {k.Periyot}",
                    DetayUrl = $"/kiralik-plaka-takip"
                });
            }

            satirlar = liste.OrderBy(x => x.Bitis).ToList();

            gecmisSayi = satirlar.Count(x => x.KalanGun < 0);
            kritikSayi = satirlar.Count(x => x.KalanGun >= 0 && x.KalanGun <= 30);
            uyariSayi = satirlar.Count(x => x.KalanGun > 30 && x.KalanGun <= 90);

            // Aylık dağılım: bugünden itibaren 12 ay
            aylikDagilim = Enumerable.Range(0, 12).Select(i =>
            {
                var d = new DateTime(bugun.Year, bugun.Month, 1).AddMonths(i);
                var sayi = satirlar.Count(s => s.Bitis.Year == d.Year && s.Bitis.Month == d.Month);
                return new AylikDagilim
                {
                    AyAdi = d.ToString("MMM yy", new CultureInfo("tr-TR")),
                    Adet = sayi
                };
            }).ToList();

            FiltreUygula();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Yükleme hatası: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void FiltreUygula()
    {
        IEnumerable<SozlesmeSatir> q = satirlar;
        if (!string.IsNullOrEmpty(tipFiltre))
            q = q.Where(x => x.Tip == tipFiltre);
        if (!string.IsNullOrEmpty(durumFiltre))
        {
            q = durumFiltre switch
            {
                "gecmis" => q.Where(x => x.KalanGun < 0),
                "kritik" => q.Where(x => x.KalanGun >= 0 && x.KalanGun <= 30),
                "uyari" => q.Where(x => x.KalanGun > 30 && x.KalanGun <= 90),
                "bilgi" => q.Where(x => x.KalanGun > 90),
                _ => q
            };
        }
        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            var k = aramaMetni.Trim().ToLowerInvariant();
            q = q.Where(x => x.Unvan.ToLowerInvariant().Contains(k)
                            || (x.SozlesmeNo?.ToLowerInvariant().Contains(k) ?? false));
        }
        filtreliSatirlar = q.ToList();
    }

    private string SeviyeClass(int kalan) => kalan switch
    {
        < 0 => "bg-danger",
        <= 30 => "bg-warning text-dark",
        <= 90 => "bg-info",
        _ => "bg-secondary"
    };

    private string SeviyeMetin(int kalan) => kalan switch
    {
        < 0 => "Geçmiş",
        <= 30 => "Kritik",
        <= 90 => "Uyarı",
        _ => "Bilgi"
    };

    private async Task ExcelIndir()
    {
        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Sözleşme Takvimi");
            string[] headers = { "Durum", "Tip", "Taraf", "No/Plaka", "Başlangıç", "Bitiş", "Kalan Gün", "Tutar ₺", "İletişim" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int row = 2;
            foreach (var s in filtreliSatirlar)
            {
                ws.Cell(row, 1).Value = SeviyeMetin(s.KalanGun);
                ws.Cell(row, 2).Value = s.Tip;
                ws.Cell(row, 3).Value = s.Unvan;
                ws.Cell(row, 4).Value = s.SozlesmeNo ?? "";
                if (s.Baslangic.HasValue) ws.Cell(row, 5).Value = s.Baslangic.Value;
                ws.Cell(row, 6).Value = s.Bitis;
                ws.Cell(row, 7).Value = s.KalanGun;
                if (s.Tutar.HasValue) ws.Cell(row, 8).Value = (double)s.Tutar.Value;
                ws.Cell(row, 9).Value = s.Iletisim ?? "";
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            await JS.InvokeVoidAsync("downloadFileFromBytes",
                $"Sozlesme_Takvimi_{DateTime.Today:yyyyMMdd}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(ms.ToArray()));
            ToastService.ShowSuccess("Excel indirildi");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel hatası: {ex.Message}");
        }
    }

    private class SozlesmeSatir
    {
        public string Tip { get; set; } = "";
        public string Unvan { get; set; } = "";
        public string? SozlesmeNo { get; set; }
        public DateTime? Baslangic { get; set; }
        public DateTime Bitis { get; set; }
        public int KalanGun { get; set; }
        public decimal? Tutar { get; set; }
        public string? Iletisim { get; set; }
        public string? DetayUrl { get; set; }
    }

    private class AylikDagilim
    {
        public string AyAdi { get; set; } = "";
        public int Adet { get; set; }
    }
}
