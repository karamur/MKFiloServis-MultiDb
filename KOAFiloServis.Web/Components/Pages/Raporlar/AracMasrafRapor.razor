@page "/rapor/arac-masraf"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Models
@using Microsoft.JSInterop
@inject IRaporService RaporService
@inject IAracService AracService
@inject IExcelService ExcelService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Araç Masraf Raporu</PageTitle>

<div class="container-fluid">
    <h3 class="mb-3"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Araç Masraf Raporu</h3>

    <div class="card mb-3">
        <div class="card-header">
            <h6 class="mb-0">Filtre</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Başlangıç Tarihi</label>
                        <input type="date" class="form-control" @bind="baslangicTarihi" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Bitiş Tarihi</label>
                        <input type="date" class="form-control" @bind="bitisTarihi" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Araç</label>
                        <select class="form-select" @bind="secilenAracId">
                            <option value="0">Tümü</option>
                            @foreach (var arac in filtreliAraclar)
                            {
                                <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Sahiplik</label>
                        <select class="form-select" @bind="secilenSahiplikTipi" @bind:after="SahiplikDegisti">
                            <option value="">Tümü</option>
                            <option value="Ozmal">Özmal</option>
                            <option value="Kiralik">Kiralık</option>
                            <option value="Komisyon">Komisyon</option>
                            <option value="Tedarikci">Tedarikçi</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" @onclick="RaporGetir">
                                <i class="bi bi-search me-1"></i>Rapor Al
                            </button>
                            <button class="btn btn-success" @onclick="ExceleAktar" disabled="@(raporData == null || !raporData.Any())">
                                <i class="bi bi-file-earmark-excel me-1"></i>Excel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (raporData != null)
    {
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Masraf Sayısı</h6>
                        <h3>@raporData.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center">
                        <h6>Toplam Masraf Tutarı</h6>
                        <h3>@raporData.Sum(r => r.Tutar).ToString("N2") ?</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center">
                        <h6>Arıza Kaynaklı Masraf</h6>
                        <h3>@raporData.Where(r => r.ArizaKaynakli).Sum(r => r.Tutar).ToString("N2") ?</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h6>Araç Sayısı</h6>
                        <h3>@raporData.Select(r => r.Plaka).Distinct().Count()</h3>
                    </div>
                </div>
            </div>
        </div>

        @* Kategori bazlı özet *@
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">Kategori Özeti</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var kategori in raporData.GroupBy(r => r.Kategori))
                    {
                        <div class="col-md-2 mb-2">
                            <div class="border rounded p-2 text-center">
                                <small class="text-muted">@kategori.Key</small>
                                <h5 class="mb-0">@kategori.Sum(k => k.Tutar).ToString("N2") ?</h5>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Tarih</th>
                                <th>Plaka</th>
                                <th>Masraf Kalemi</th>
                                <th>Kategori</th>
                                <th>Güzergah</th>
                                <th class="text-end">Tutar</th>
                                <th>Belge No</th>
                                <th>Arıza</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in raporData)
                            {
                                <tr class="@(item.ArizaKaynakli ? "table-warning" : "")">
                                    <td>@item.MasrafTarihi.ToString("dd.MM.yyyy")</td>
                                    <td><strong>@item.Plaka</strong></td>
                                    <td>@item.MasrafKalemi</td>
                                    <td><span class="badge bg-secondary">@item.Kategori</span></td>
                                    <td>@item.GuzergahAdi</td>
                                    <td class="text-end"><strong class="text-danger">@item.Tutar.ToString("N2") ?</strong></td>
                                    <td>@item.BelgeNo</td>
                                    <td>
                                        @if (item.ArizaKaynakli)
                                        {
                                            <span class="badge bg-warning text-dark">Evet</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary">
                            <tr>
                                <td colspan="5" class="text-end"><strong>TOPLAM:</strong></td>
                                <td class="text-end"><strong class="text-danger">@raporData.Sum(r => r.Tutar).ToString("N2") ?</strong></td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-30);
    private DateTime bitisTarihi = DateTime.Today;
    private int secilenAracId = 0;
    private string secilenSahiplikTipi = "";
    private bool isLoading = false;

    private List<Arac> araclar = new();
    private List<AracMasrafRaporItem>? raporData;

    // Sahiplik tipine göre filtrelenmiş araçlar
    private IEnumerable<Arac> filtreliAraclar => string.IsNullOrEmpty(secilenSahiplikTipi) 
        ? araclar 
        : secilenSahiplikTipi == "Tedarikci"
            ? araclar.Where(a => a.SahiplikTipi == AracSahiplikTipi.Tedarikci || a.SahiplikTipi == AracSahiplikTipi.Diger)
            : araclar.Where(a => a.SahiplikTipi.ToString() == secilenSahiplikTipi);

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetAllAsync();
    }

    private void SahiplikDegisti()
    {
        // Eğer seçili araç, yeni sahiplik tipine uygun değilse sıfırla
        if (secilenAracId > 0 && !string.IsNullOrEmpty(secilenSahiplikTipi))
        {
            var seciliArac = araclar.FirstOrDefault(a => a.Id == secilenAracId);
            if (seciliArac != null && seciliArac.SahiplikTipi.ToString() != secilenSahiplikTipi)
            {
                secilenAracId = 0;
            }
        }
    }

    private async Task RaporGetir()
    {
        isLoading = true;
        try
        {
            AracSahiplikTipi? sahiplikTipi = null;
            if (!string.IsNullOrEmpty(secilenSahiplikTipi) && Enum.TryParse<AracSahiplikTipi>(secilenSahiplikTipi, out var parsed))
                sahiplikTipi = parsed;

            raporData = await RaporService.GetAracMasrafRaporuAsync(
                baslangicTarihi,
                bitisTarihi,
                secilenAracId > 0 ? secilenAracId : null,
                sahiplikTipi
            );
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExceleAktar()
    {
        if (raporData == null || !raporData.Any())
            return;

        var excelBytes = ExcelService.ExportAracMasrafRaporu(raporData);
        var fileName = $"AracMasrafRaporu_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(excelBytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }
}
