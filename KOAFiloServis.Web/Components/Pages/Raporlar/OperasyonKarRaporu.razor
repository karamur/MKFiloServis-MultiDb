@page "/raporlar/operasyon-kar"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Models
@using KOAFiloServis.Web.Services
@inject IRaporService RaporService
@inject IAracService AracService
@inject IGuzergahService GuzergahService
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Operasyon Kar Raporu</PageTitle>

<div class="container-fluid px-3">
    <h4 class="mb-3"><i class="bi bi-graph-up me-2 text-success"></i>Operasyon Kar Raporu</h4>

    <!-- Filtre -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small mb-1">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="baslangic" />
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="bitis" />
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Firma Tipi</label>
                    <select class="form-select form-select-sm" @bind="seciliSahiplikTipi">
                        <option value="">— Tümü —</option>
                        @foreach (AracSahiplikTipi t in Enum.GetValues<AracSahiplikTipi>())
                        {
                            <option value="@t">@SahiplikHelper.GetMetin(t)</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Araç</label>
                    <select class="form-select form-select-sm" @bind="seciliAracId">
                        <option value="">— Tümü —</option>
                        @foreach (var a in aracListesi)
                        {
                            <option value="@a.Id">@(a.AktifPlaka ?? a.Plaka)</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Güzergah</label>
                    <select class="form-select form-select-sm" @bind="seciliGuzergahId">
                        <option value="">— Tümü —</option>
                        @foreach (var g in guzergahListesi)
                        {
                            <option value="@g.Id">@g.GuzergahAdi</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" @onclick="LoadRapor" disabled="@yukleniyor">
                        @if (yukleniyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-search me-1"></i> Sorgula
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Yükleniyor…</p>
        </div>
    }
    else if (!satirlar.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 opacity-25"></i>
            <p class="mt-2">Seçili kriterlere uygun veri bulunamadı.</p>
        </div>
    }
    else
    {
        <!-- Özet Kartlar -->
        <div class="row g-2 mb-3">
            @foreach (var ozet in firmaTipiOzetleri)
            {
                <div class="col-md-3">
                    <div class="card text-center py-2 border-start border-4 @SahiplikBorderClass(ozet.SahiplikTipi)">
                        <small class="text-muted">@ozet.Baslik</small>
                        <h5 class="mb-0">@ozet.ToplamGelir.ToString("N0") ₺</h5>
                        <small>@ozet.AracSayisi araç · @ozet.ToplamSefer sefer</small>
                    </div>
                </div>
            }
        </div>

        <!-- Detay Tablo -->
        <div class="table-responsive">
            <table class="table table-bordered table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Firma Tipi</th>
                        <th>Plaka</th>
                        <th>Şoför</th>
                        <th>Güzergah</th>
                        <th>Slot</th>
                        <th class="text-center">Sefer</th>
                        <th class="text-end">Birim Fiyat</th>
                        <th class="text-end">Toplam Gelir</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        AracSahiplikTipi? currentSahiplik = null;
                        int? currentAracId = null;
                    }
                    @foreach (var s in satirlar)
                    {
                        // Firma tipi grup başlığı
                        @if (currentSahiplik != s.SahiplikTipi)
                        {
                            currentSahiplik = s.SahiplikTipi;
                            currentAracId = null;
                            var ozet = firmaTipiOzetleri.FirstOrDefault(o => o.SahiplikTipi == s.SahiplikTipi);
                            <tr class="table-secondary fw-bold">
                                <td colspan="8" class="py-1">
                                    <span class="badge @SahiplikHelper.GetBadgeClass(s.SahiplikTipi) me-2">@s.FirmaTipi</span>
                                    @if (ozet != null)
                                    {
                                        <span class="text-muted small">@ozet.AracSayisi araç · @ozet.ToplamSefer sefer · @ozet.ToplamGelir.ToString("N0") ₺</span>
                                    }
                                </td>
                            </tr>
                        }
                        // Araç alt-grup başlığı
                        @if (currentAracId != s.AracId)
                        {
                            currentAracId = s.AracId;
                            var aracToplam = satirlar.Where(x => x.AracId == s.AracId).Sum(x => x.ToplamGelir);
                            var aracSefer = satirlar.Where(x => x.AracId == s.AracId).Sum(x => x.SeferSayisi);
                            <tr class="table-light">
                                <td></td>
                                <td colspan="7" class="py-1">
                                    <i class="bi bi-truck me-1"></i>
                                    <strong>@s.Plaka</strong>
                                    <span class="text-muted ms-2 small">@aracSefer sefer · @aracToplam.ToString("N0") ₺</span>
                                </td>
                            </tr>
                        }
                        <tr>
                            <td></td>
                            <td></td>
                            <td>@s.SoforAdi</td>
                            <td>@s.GuzergahAdi</td>
                            <td>@s.Slot</td>
                            <td class="text-center">@s.SeferSayisi</td>
                            <td class="text-end">@s.BirimFiyat.ToString("N2")</td>
                            <td class="text-end fw-semibold">@s.ToplamGelir.ToString("N2")</td>
                        </tr>
                    }
                    <!-- Genel Toplam -->
                    <tr class="table-primary fw-bold">
                        <td colspan="5">Genel Toplam</td>
                        <td class="text-center">@satirlar.Sum(x => x.SeferSayisi)</td>
                        <td></td>
                        <td class="text-end">@satirlar.Sum(x => x.ToplamGelir).ToString("N2") ₺</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private DateTime baslangic = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bitis = DateTime.Today;
    private string? seciliSahiplikTipi;
    private int? seciliAracId;
    private int? seciliGuzergahId;

    private List<Arac> aracListesi = [];
    private List<Guzergah> guzergahListesi = [];
    private List<OperasyonKarRaporuSatir> satirlar = [];
    private List<(AracSahiplikTipi SahiplikTipi, string Baslik, int AracSayisi, int ToplamSefer, decimal ToplamGelir)> firmaTipiOzetleri = [];
    private bool yukleniyor;

    protected override async Task OnInitializedAsync()
    {
        aracListesi = await AracService.GetActiveAsync();
        guzergahListesi = await GuzergahService.GetActiveAsync();
    }

    private async Task LoadRapor()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            AracSahiplikTipi? sahiplik = string.IsNullOrEmpty(seciliSahiplikTipi)
                ? null
                : Enum.Parse<AracSahiplikTipi>(seciliSahiplikTipi);

            satirlar = await RaporService.GetOperasyonKarRaporuAsync(
                baslangic, bitis, sahiplik, seciliAracId, seciliGuzergahId);

            firmaTipiOzetleri = satirlar
                .GroupBy(s => s.SahiplikTipi)
                .Select(g => (
                    SahiplikTipi: g.Key,
                    Baslik: SahiplikHelper.GetMetin(g.Key),
                    AracSayisi: g.Select(x => x.AracId).Distinct().Count(),
                    ToplamSefer: g.Sum(x => x.SeferSayisi),
                    ToplamGelir: g.Sum(x => x.ToplamGelir)
                ))
                .OrderBy(x => x.SahiplikTipi)
                .ToList();
        }
        finally { yukleniyor = false; }
    }

    private static string SahiplikBorderClass(AracSahiplikTipi tip) => tip switch
    {
        AracSahiplikTipi.Ozmal => "border-primary",
        AracSahiplikTipi.Kiralik => "border-warning",
        AracSahiplikTipi.Komisyon => "border-info",
        AracSahiplikTipi.Tedarikci => "border-danger",
        _ => "border-secondary"
    };
}
