@page "/raporlar/arac-maliyet-gelir"
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@inject IServisCalismaService ServisCalismaService
@inject IAracMasrafService AracMasrafService
@inject IAracService AracService
@inject IToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Araç Maliyet vs Gelir</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-fuel-pump-diesel me-2 text-primary"></i>Araç Maliyet vs Gelir Karşılaştırma</h2>
            <p class="text-muted mb-0">Tek araç bazında gider kalemleri (yakıt, bakım, sigorta, vb.) ile servis gelirinin kıyaslaması</p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm" @bind="bas" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Bitiş</label>
                    <input type="date" class="form-control form-control-sm" @bind="bit" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sahiplik</label>
                    <select class="form-select form-select-sm" @bind="sahiplikFiltre" @bind:after="StateHasChanged">
                        <option value="-1">Tümü</option>
                        @foreach (AracSahiplikTipi t in Enum.GetValues(typeof(AracSahiplikTipi)))
                        {
                            <option value="@((int)t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="cbBosGizle"
                               @bind="bosAracGizle" @bind:after="StateHasChanged" />
                        <label class="form-check-label small" for="cbBosGizle">Hareketsiz araçları gizle</label>
                    </div>
                </div>
                <div class="col-md-2 text-end">
                    <button class="btn btn-outline-primary btn-sm" @onclick="ExcelIndir" disabled="@yukleniyor">
                        <i class="bi bi-file-earmark-excel me-1"></i> Excel
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="card"><div class="card-body p-4 text-center text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
        </div></div>
    }
    else
    {
        var matris = HesaplaMatris();
        var gosterilen = (sahiplikFiltre >= 0 ? matris.Where(m => (int)m.Sahiplik == sahiplikFiltre) : matris)
            .Where(m => !bosAracGizle || m.Gelir > 0 || m.ToplamGider > 0)
            .ToList();

        var tGelir = gosterilen.Sum(x => x.Gelir);
        var tGider = gosterilen.Sum(x => x.ToplamGider);
        var tNet = tGelir - tGider;
        var marj = tGelir > 0 ? (tNet / tGelir * 100m) : 0m;

        <!-- Özet kartlar -->
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-info shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Araç Sayısı</div>
                        <div class="fs-4 fw-bold text-info">@gosterilen.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Toplam Gelir</div>
                        <div class="fs-4 fw-bold text-success">@tGelir.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-danger shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Toplam Gider</div>
                        <div class="fs-4 fw-bold text-danger">@tGider.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(tNet >= 0 ? "border-success" : "border-danger") shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small">Net (Marj %@marj.ToString("N1"))</div>
                        <div class="fs-4 fw-bold @(tNet >= 0 ? "text-success" : "text-danger")">@tNet.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
        </div>

        var kategoriDagilim = gosterilen
            .SelectMany(g => g.KategoriBazli)
            .GroupBy(k => k.Key)
            .Select(g => new { Kategori = g.Key, Tutar = g.Sum(x => x.Value) })
            .OrderByDescending(x => x.Tutar)
            .ToList();

        if (kategoriDagilim.Any())
        {
            <div class="card mb-3">
                <div class="card-header bg-light"><strong><i class="bi bi-pie-chart me-1"></i>Gider Kategorisine Göre Dağılım</strong></div>
                <div class="card-body p-0">
                    <table class="table table-sm table-striped mb-0 align-middle">
                        <thead class="table-light"><tr><th>Kategori</th><th class="text-end">Tutar (₺)</th><th class="text-end">Pay (%)</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var k in kategoriDagilim)
                            {
                                var pay = tGider > 0 ? (k.Tutar / tGider * 100m) : 0m;
                                <tr>
                                    <td><span class="badge bg-secondary">@k.Kategori</span></td>
                                    <td class="text-end fw-bold text-danger">@k.Tutar.ToString("N2")</td>
                                    <td class="text-end">@pay.ToString("N1")%</td>
                                    <td style="width:30%;">
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-danger" style="width:@(pay.ToString("F0", CultureInfo.InvariantCulture))%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Araç bazında matris -->
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between">
                <strong><i class="bi bi-table me-1"></i>Araç Bazında Maliyet & Gelir</strong>
                <span class="text-muted small">@gosterilen.Count araç</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="min-width:60px;">#</th>
                                <th style="min-width:200px;">Araç</th>
                                <th class="text-center">Sahiplik</th>
                                <th class="text-center">Sefer</th>
                                <th class="text-end">Gelir (₺)</th>
                                @foreach (var kat in tumKategoriler)
                                {
                                    <th class="text-end" style="min-width:80px;">@kat</th>
                                }
                                <th class="text-end">Toplam Gider</th>
                                <th class="text-end">Net Kâr</th>
                                <th class="text-end">Marj %</th>
                                <th class="text-center">₺/Sefer</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!gosterilen.Any())
                            {
                                <tr><td colspan="@(10 + tumKategoriler.Count)" class="text-center text-muted p-4">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>Bu dönem için kayıt bulunamadı.
                                </td></tr>
                            }
                            else
                            {
                                int sira = 1;
                                foreach (var a in gosterilen.OrderByDescending(x => x.NetKar))
                                {
                                    var aMarj = a.Gelir > 0 ? (a.NetKar / a.Gelir * 100m) : 0m;
                                    var birimMaliyet = a.SeferSayisi > 0 ? (a.ToplamGider / a.SeferSayisi) : 0m;
                                    <tr>
                                        <td>@(sira++)</td>
                                        <td>
                                            <strong>@a.Plaka</strong>
                                            <div class="small text-muted">@a.MarkaModel</div>
                                        </td>
                                        <td class="text-center"><span class="badge bg-light text-dark">@a.Sahiplik</span></td>
                                        <td class="text-center"><span class="badge bg-primary">@a.SeferSayisi</span></td>
                                        <td class="text-end fw-semibold text-success">@a.Gelir.ToString("N2")</td>
                                        @foreach (var kat in tumKategoriler)
                                        {
                                            var v = a.KategoriBazli.TryGetValue(kat, out var x) ? x : 0m;
                                            <td class="text-end @(v > 0 ? "text-danger" : "text-muted")">@(v > 0 ? v.ToString("N2") : "-")</td>
                                        }
                                        <td class="text-end fw-semibold text-danger">@a.ToplamGider.ToString("N2")</td>
                                        <td class="text-end fw-bold @(a.NetKar >= 0 ? "text-success" : "text-danger")">@a.NetKar.ToString("N2")</td>
                                        <td class="text-end small @(aMarj >= 0 ? "text-success" : "text-danger")">@aMarj.ToString("N1")%</td>
                                        <td class="text-center small text-muted">@birimMaliyet.ToString("N2")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="3">TOPLAM</td>
                                <td class="text-center">@gosterilen.Sum(x => x.SeferSayisi)</td>
                                <td class="text-end text-success">@tGelir.ToString("N2")</td>
                                @foreach (var kat in tumKategoriler)
                                {
                                    var t = gosterilen.Sum(x => x.KategoriBazli.TryGetValue(kat, out var v) ? v : 0m);
                                    <td class="text-end">@(t > 0 ? t.ToString("N2") : "-")</td>
                                }
                                <td class="text-end text-danger">@tGider.ToString("N2")</td>
                                <td class="text-end @(tNet >= 0 ? "text-success" : "text-danger")">@tNet.ToString("N2")</td>
                                <td class="text-end @(marj >= 0 ? "text-success" : "text-danger")">@marj.ToString("N1")%</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-2 small text-muted">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Gelir:</strong> Servis çalışmalarındaki güzergah/override fiyatlarının toplamı.
            <strong>Gider:</strong> AracMasraf kayıtlarındaki MasrafKalemi → Kategori bazlı toplam.
            <strong>₺/Sefer:</strong> Toplam gider ÷ sefer sayısı (sefer başı ortalama maliyet).
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private DateTime bas = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bit = DateTime.Today;
    private int sahiplikFiltre = -1;
    private bool bosAracGizle = true;

    private List<ServisCalisma> calismalar = new();
    private List<AracMasraf> masraflar = new();
    private List<Arac> araclar = new();

    private List<MasrafKategori> tumKategoriler = new();

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetAllAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            var basT = bas.Date;
            var bitT = bit.Date.AddDays(1).AddSeconds(-1);
            calismalar = await ServisCalismaService.GetByDateRangeAsync(basT, bitT);
            masraflar = await AracMasrafService.GetByDateRangeAsync(basT, bitT);

            tumKategoriler = masraflar
                .Where(m => m.MasrafKalemi != null)
                .Select(m => m.MasrafKalemi!.Kategori)
                .Distinct()
                .OrderBy(k => k.ToString())
                .ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenemedi: {ex.GetBaseException().Message}");
        }
        finally { yukleniyor = false; }
    }

    private record AracRow(
        int AracId, string Plaka, string MarkaModel, AracSahiplikTipi Sahiplik,
        int SeferSayisi, decimal Gelir, decimal ToplamGider, decimal NetKar,
        Dictionary<MasrafKategori, decimal> KategoriBazli);

    private List<AracRow> HesaplaMatris()
    {
        var aracIds = calismalar.Select(c => c.AracId)
            .Concat(masraflar.Select(m => m.AracId)).Distinct().ToHashSet();

        var liste = new List<AracRow>();
        foreach (var aId in aracIds)
        {
            var a = araclar.FirstOrDefault(x => x.Id == aId);
            if (a == null) continue;

            var aCalismalar = calismalar.Where(c => c.AracId == aId).ToList();
            int sefer = aCalismalar.Count;
            decimal gelir = aCalismalar.Sum(c => c.HesaplananFiyat > 0
                ? c.HesaplananFiyat
                : (c.Guzergah?.BirimFiyat ?? 0));

            var aMasraflar = masraflar.Where(m => m.AracId == aId).ToList();
            var katBazli = aMasraflar
                .Where(m => m.MasrafKalemi != null)
                .GroupBy(m => m.MasrafKalemi!.Kategori)
                .ToDictionary(g => g.Key, g => g.Sum(x => x.Tutar));

            decimal toplamGider = aMasraflar.Sum(m => m.Tutar);
            decimal net = gelir - toplamGider;

            liste.Add(new AracRow(
                a.Id, a.Plaka, $"{a.Marka} {a.Model}", a.SahiplikTipi,
                sefer, gelir, toplamGider, net, katBazli));
        }
        return liste;
    }

    private async Task ExcelIndir()
    {
        try
        {
            var matris = HesaplaMatris();
            var gosterilen = (sahiplikFiltre >= 0 ? matris.Where(m => (int)m.Sahiplik == sahiplikFiltre) : matris)
                .Where(m => !bosAracGizle || m.Gelir > 0 || m.ToplamGider > 0)
                .ToList();

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Arac Maliyet Gelir");

            ws.Cell(1, 1).Value = $"Araç Maliyet vs Gelir — {bas:dd.MM.yyyy} - {bit:dd.MM.yyyy}";
            ws.Cell(1, 1).Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 13;

            int colIdx = 1;
            ws.Cell(3, colIdx++).Value = "#";
            ws.Cell(3, colIdx++).Value = "Plaka";
            ws.Cell(3, colIdx++).Value = "Marka/Model";
            ws.Cell(3, colIdx++).Value = "Sahiplik";
            ws.Cell(3, colIdx++).Value = "Sefer";
            ws.Cell(3, colIdx++).Value = "Gelir";
            int katStart = colIdx;
            foreach (var k in tumKategoriler)
                ws.Cell(3, colIdx++).Value = k.ToString();
            ws.Cell(3, colIdx++).Value = "Toplam Gider";
            ws.Cell(3, colIdx++).Value = "Net Kâr";
            ws.Cell(3, colIdx++).Value = "Marj %";

            var hr = ws.Range(3, 1, 3, colIdx - 1);
            hr.Style.Font.Bold = true;
            hr.Style.Fill.BackgroundColor = XLColor.LightSteelBlue;

            int r = 4, sira = 1;
            foreach (var a in gosterilen.OrderByDescending(x => x.NetKar))
            {
                int c = 1;
                ws.Cell(r, c++).Value = sira++;
                ws.Cell(r, c++).Value = a.Plaka;
                ws.Cell(r, c++).Value = a.MarkaModel;
                ws.Cell(r, c++).Value = a.Sahiplik.ToString();
                ws.Cell(r, c++).Value = a.SeferSayisi;
                ws.Cell(r, c++).Value = a.Gelir;
                foreach (var k in tumKategoriler)
                    ws.Cell(r, c++).Value = a.KategoriBazli.TryGetValue(k, out var v) ? v : 0;
                ws.Cell(r, c++).Value = a.ToplamGider;
                ws.Cell(r, c++).Value = a.NetKar;
                ws.Cell(r, c++).Value = a.Gelir > 0 ? (a.NetKar / a.Gelir * 100m) : 0m;
                r++;
            }

            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            wb.SaveAs(stream);
            var fileName = $"arac_maliyet_gelir_{bas:yyyyMMdd}_{bit:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(stream.ToArray()));
            ToastService.ShowSuccess("Excel indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel indirilemedi: {ex.GetBaseException().Message}");
        }
    }
}
