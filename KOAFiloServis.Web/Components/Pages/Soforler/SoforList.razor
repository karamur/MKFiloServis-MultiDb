@page "/soforler"
@page "/personel"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ISoforService SoforService
@inject IPersonelOzlukService OzlukService
@inject IJSRuntime JS
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@rendermode InteractiveServer

<PageTitle>Personel Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people me-2"></i>Personel Listesi</h3>
        <div class="d-flex gap-2 flex-wrap">
            <input type="text" class="form-control" style="width: 200px;" placeholder="Ad, kod, telefon ara..." 
                   @bind="aramaMetni" @bind:after="FiltreleAsync" />
            <select class="form-select" style="width: 160px;" @bind="secilenGorev" @bind:after="FiltreleAsync">
                <option value="">Tüm Görevler</option>
                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                {
                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                }
            </select>
            <select class="form-select" style="width: 160px;" @bind="secilenFirmaId" @bind:after="FiltreleAsync">
                <option value="0">Tüm Firmalar</option>
                @foreach (var firma in firmalar)
                {
                    <option value="@firma.Id">@firma.FirmaAdi</option>
                }
            </select>
            <select class="form-select" style="width: 200px;" @bind="secilenPersonelKaynak" @bind:after="FiltreleAsync" title="Personel kaynağı (Kendi / Tedarikçi)">
                <option value="">Tüm Personel Kaynakları</option>
                <option value="kendi">Kendi Personelimiz</option>
                <option value="tedarikci">Tedarikçi Personeli</option>
            </select>
            <select class="form-select" style="width: 180px;" @bind="secilenTedarikciId" @bind:after="FiltreleAsync">
                <option value="0">Tüm Tedarikçiler</option>
                @foreach (var t in tedarikciler)
                {
                    <option value="@t.Id">@t.Unvan</option>
                }
            </select>
            <div class="btn-group" role="group" aria-label="Durum filtresi">
                <button type="button" class="btn @(secilenAktifDurum == "" ? "btn-secondary" : "btn-outline-secondary")" 
                        @onclick='() => AktifDurumFiltrele("")'>
                    <i class="bi bi-people me-1"></i>Tümü
                </button>
                <button type="button" class="btn @(secilenAktifDurum == "aktif" ? "btn-success" : "btn-outline-success")" 
                        @onclick='() => AktifDurumFiltrele("aktif")'>
                    <i class="bi bi-check-circle me-1"></i>Aktif
                </button>
                <button type="button" class="btn @(secilenAktifDurum == "pasif" ? "btn-danger" : "btn-outline-danger")" 
                        @onclick='() => AktifDurumFiltrele("pasif")'>
                    <i class="bi bi-x-circle me-1"></i>Pasif
                </button>
            </div>
            <div class="btn-group">
                <button class="btn btn-outline-success" @onclick="ImportSablonIndir" title="Import Şablonu İndir">
                    <i class="bi bi-download me-1"></i>Şablon
                </button>
                <button class="btn btn-success" @onclick="() => showImportModal = true" title="Excel'den Personel Yükle">
                    <i class="bi bi-upload me-1"></i>Excel Import
                </button>
                <button class="btn btn-outline-primary" @onclick="ExportToExcel" title="Excel'e Aktar">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel Export
                </button>
            </div>
            <button class="btn btn-outline-info" @onclick="PersonelHesapBaglantilariniOnar" title="Personel 335/195 hesap bağlantılarını deterministik kurala göre onar">
                <i class="bi bi-calculator me-1"></i>Personel Hesap Bağlantılarını Onar
            </button>
            <button class="btn btn-outline-secondary" @onclick="BosPersonelDosyasiIndir">
                <i class="bi bi-file-earmark-text me-1"></i>Boş Personel Dosyası
            </button>
            <button class="btn btn-primary" @onclick="YeniPersonel">
                <i class="bi bi-plus-lg me-1"></i>Yeni Personel
            </button>
        </div>
    </div>

    @if (personeller == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!personeller.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            @if (tumPersoneller?.Any() == true)
            {
                <span>Seçilen filtreye uygun personel bulunamadı.</span>
            }
            else
            {
                <span>Henüz personel kaydı bulunmamaktadır.</span>
            }
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 70px;">Sıra No</th>
                                <th>Personel Kodu</th>
                                <th>Ad Soyad</th>
                                <th>Görev</th>
                                <th>Firma / Tedarikçi</th>
                                <th>Telefon</th>
                                <th>Araç</th>
                                <th>İşe Başlama</th>
                                <th>İşten Çıkış</th>
                                <th>SGK Çıkış</th>
                                <th class="text-end">Maaş</th>
                                <th class="text-center">Belgeler</th>
                                <th class="text-center">Durum</th>
                                <th style="width: 120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var personel in personeller.OrderBy(p => p.SiralamaNo == 0 ? int.MaxValue : p.SiralamaNo).ThenBy(p => p.Ad))
                            {
                                <tr>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" style="width: 60px;" 
                                               value="@personel.SiralamaNo" 
                                               @onchange="(e) => SiralamaNoGuncelle(personel, e)" />
                                    </td>
                                    <td><strong>@personel.SoforKodu</strong></td>
                                    <td>@personel.TamAd</td>
                                    <td>
                                        <span class="badge @GetGorevBadgeClass(personel.Gorev)">
                                            @GetGorevAdi(personel.Gorev)
                                        </span>
                                    </td>
                                    <td>
                                        @if (personel.TasimaTedarikciId.HasValue && personel.TasimaTedarikci != null)
                                        {
                                            <span class="badge bg-primary" title="Tedarikçi Personeli"><i class="bi bi-truck me-1"></i>@personel.TasimaTedarikci.Unvan</span>
                                        }
                                        else if (personel.Firma != null)
                                        {
                                            <span class="badge bg-secondary" title="Kendi Personelimiz"><i class="bi bi-building me-1"></i>@personel.Firma.FirmaAdi</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@(personel.Telefon ?? "-")</td>
                                    <td>
                                        @if (personelAraclar.TryGetValue(personel.Id, out var plaka))
                                        {
                                            <span class="badge bg-primary">@plaka</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy")</td>
                                     <td>@personel.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy")</td>
                                     <td>@personel.SgkCikisTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end">@personel.NetMaas.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</td>
                                    <td class="text-center">
                                        @if (personel.IsSofor)
                                        {
                                            @* Ehliyet durumu *@
                                            @if (personel.EhliyetGecerlilikTarihi.HasValue)
                                            {
                                                var gunKaldi = (personel.EhliyetGecerlilikTarihi.Value - DateTime.Today).Days;
                                                <span class="badge @(gunKaldi < 30 ? "bg-danger" : gunKaldi < 60 ? "bg-warning text-dark" : "bg-success")" 
                                                      title="Ehliyet: @personel.EhliyetGecerlilikTarihi.Value.ToString("dd.MM.yyyy")">
                                                    <i class="bi bi-card-text"></i>
                                                </span>
                                            }
                                            @* MYK durumu *@
                                            @if (personel.MykBelgesiGecerlilikTarihi.HasValue)
                                            {
                                                var gunKaldi = (personel.MykBelgesiGecerlilikTarihi.Value - DateTime.Today).Days;
                                                <span class="badge @(gunKaldi < 30 ? "bg-danger" : gunKaldi < 60 ? "bg-warning text-dark" : "bg-success") ms-1" 
                                                      title="MYK: @personel.MykBelgesiGecerlilikTarihi.Value.ToString("dd.MM.yyyy")">
                                                    <i class="bi bi-award"></i>
                                                </span>
                                            }
                                            @* SRC belgesi durumu *@
                                            @if (personel.YayginEgitimSertifikasiVarMi || personel.SrcBelgesiGecerlilikTarihi.HasValue)
                                            {
                                                <span class="badge bg-success ms-1" title="SRC Belgesi: Var">
                                                    <i class="bi bi-mortarboard"></i>
                                                </span>
                                            }
                                            @* Yaygın Eğitim Sertifikası durumu *@
                                            @if (personel.YayginEgitimSertifikasiVarMi)
                                            {
                                                <span class="badge bg-info ms-1" title="Yaygın Eğitim Sertifikası: Var">
                                                    <i class="bi bi-journal-check"></i>
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (personel.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pasif</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => PersonelDosyasiIndir(personel.Id)" title="Dosya Hazırla">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick='() => Navigation.NavigateTo($"/personel/{personel.Id}/bordrolar")' title="Bordrolar">
                                            <i class="bi bi-file-earmark-text"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(personel.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(personel)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Özet Bilgiler -->
        <div class="row mt-3">
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Gösterilen / Toplam</small>
                        <h5 class="mb-0">@personeller.Count / @(tumPersoneller?.Count ?? 0)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Şoför Sayısı</small>
                        <h5 class="mb-0">@personeller.Count(p => p.Gorev == PersonelGorev.Sofor)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Aktif Personel</small>
                        <h5 class="mb-0">@personeller.Count(p => p.Aktif)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Toplam Maaş</small>
                        <h5 class="mb-0">@personeller.Where(p => p.Aktif).Sum(p => p.NetMaas).ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</h5>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekPersonel?.TamAd</strong> isimli personeli silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showImportModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Excel'den Personel Import</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseImportModal"></button>
                </div>
                <div class="modal-body">
                    @if (importSonuc == null)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Önemli:</strong> Import şablonunu indirip doldurun. TC Kimlik No ile mevcut personel kontrolü yapılır.
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Excel Dosyası Seçin</label>
                            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls" class="form-control" />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" @bind="mevcutGuncelle" id="mevcutGuncelle">
                            <label class="form-check-label" for="mevcutGuncelle">
                                Mevcut personelleri güncelle (TC eşleşirse)
                            </label>
                        </div>

                        @if (selectedFile != null)
                        {
                            <div class="alert alert-secondary">
                                <i class="bi bi-file-earmark-excel me-2"></i>
                                <strong>Seçilen:</strong> @selectedFile.Name (@(selectedFile.Size / 1024) KB)
                            </div>
                        }

                        @if (importHata != null)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle me-2"></i>@importHata
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert @(importSonuc.Basarili ? "alert-success" : "alert-warning")">
                            <h5><i class="bi bi-check-circle me-2"></i>Import Tamamlandı</h5>
                        </div>

                        <div class="row text-center mb-3">
                            <div class="col-md-3">
                                <div class="card bg-light">
                                    <div class="card-body py-2">
                                        <small class="text-muted">Toplam Satır</small>
                                        <h4 class="mb-0">@importSonuc.ToplamSatir</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-success text-white">
                                    <div class="card-body py-2">
                                        <small>Eklenen</small>
                                        <h4 class="mb-0">@importSonuc.BasariliEklenen</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-info text-white">
                                    <div class="card-body py-2">
                                        <small>Güncellenen</small>
                                        <h4 class="mb-0">@importSonuc.BasariliGuncellenen</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-warning">
                                    <div class="card-body py-2">
                                        <small>Atlanan</small>
                                        <h4 class="mb-0">@importSonuc.Atlanan</h4>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (importSonuc.Hatalar.Any())
                        {
                            <div class="card">
                                <div class="card-header bg-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i>Uyarılar ve Hatalar
                                </div>
                                <div class="card-body" style="max-height: 200px; overflow-y: auto;">
                                    <ul class="mb-0">
                                        @foreach (var hata in importSonuc.Hatalar.Take(20))
                                        {
                                            <li class="@(hata.Kritik ? "text-danger" : "text-warning")">
                                                <strong>Satır @hata.SatirNo:</strong> [@hata.Kolon] @hata.Mesaj
                                            </li>
                                        }
                                        @if (importSonuc.Hatalar.Count > 20)
                                        {
                                            <li class="text-muted">...ve @(importSonuc.Hatalar.Count - 20) hata daha</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    @if (importSonuc == null)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseImportModal">İptal</button>
                        <button type="button" class="btn btn-success" @onclick="ImportBaslat" disabled="@(selectedFile == null || isImporting)">
                            @if (isImporting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-upload me-1"></i>Import Başlat
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" @onclick="CloseImportModal">Tamam</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Sofor>? tumPersoneller;
    private List<Sofor>? personeller;
    private Dictionary<int, string> personelAraclar = new();
    private List<KOAFiloServis.Shared.Entities.Firma> firmalar = new();
    private List<KOAFiloServis.Shared.Entities.TasimaTedarikci> tedarikciler = new();
    private bool showDeleteModal = false;
    private Sofor? silinecekPersonel;
    private string secilenGorev = "";
    private string secilenAktifDurum = "aktif";
    private string aramaMetni = "";
    private int secilenFirmaId = 0;
    private int secilenTedarikciId = 0;
    private string secilenPersonelKaynak = "";

    // Import değişkenleri
    private bool showImportModal = false;
    private IBrowserFile? selectedFile;
    private bool mevcutGuncelle = false;
    private bool isImporting = false;
    private string? importHata;
    private PersonelImportSonuc? importSonuc;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        tumPersoneller = await ctx.Soforler
            .Include(s => s.Firma)
            .Include(s => s.TasimaTedarikci)
            .Where(s => !s.IsDeleted)
            .OrderBy(s => s.Ad)
            .ThenBy(s => s.Soyad)
            .AsNoTracking()
            .ToListAsync();
        await LoadPersonelAraclarAsync();
        await LoadFirmalarAsync();
        await LoadTedarikcilerAsync();
        UygulaFiltre();
    }

    private async Task FiltreleAsync()
    {
        if (tumPersoneller == null)
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            tumPersoneller = await ctx.Soforler
                .Include(s => s.Firma)
                .Include(s => s.TasimaTedarikci)
                .Where(s => !s.IsDeleted)
                .OrderBy(s => s.Ad)
                .ThenBy(s => s.Soyad)
                .AsNoTracking()
                .ToListAsync();
        }
        UygulaFiltre();
    }

    private void AktifDurumFiltrele(string durum)
    {
        secilenAktifDurum = durum;
        UygulaFiltre();
    }

    private void UygulaFiltre()
    {
        var sorgu = tumPersoneller?.AsEnumerable() ?? Enumerable.Empty<Sofor>();

        if (!string.IsNullOrEmpty(secilenGorev) && Enum.TryParse<PersonelGorev>(secilenGorev, out var gorev))
            sorgu = sorgu.Where(p => p.Gorev == gorev);

        if (secilenAktifDurum == "aktif")
            sorgu = sorgu.Where(p => p.Aktif);
        else if (secilenAktifDurum == "pasif")
            sorgu = sorgu.Where(p => !p.Aktif);

        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            var aranan = aramaMetni.Trim().ToLowerInvariant();
            sorgu = sorgu.Where(p =>
                (p.Ad + " " + p.Soyad).ToLowerInvariant().Contains(aranan) ||
                (p.SoforKodu ?? "").ToLowerInvariant().Contains(aranan) ||
                (p.Telefon ?? "").Contains(aranan));
        }

        if (secilenFirmaId > 0)
            sorgu = sorgu.Where(p => p.FirmaId == secilenFirmaId);

        if (secilenTedarikciId > 0)
            sorgu = sorgu.Where(p => p.TasimaTedarikciId == secilenTedarikciId);

        if (secilenPersonelKaynak == "kendi")
            sorgu = sorgu.Where(p => !p.TasimaTedarikciId.HasValue);
        else if (secilenPersonelKaynak == "tedarikci")
            sorgu = sorgu.Where(p => p.TasimaTedarikciId.HasValue);

        personeller = sorgu.ToList();
    }

    private async Task LoadPersonelAraclarAsync()
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var atamalar = await ctx.PersonelAracAtamalari
                .Include(a => a.Arac)
                .Where(a => a.Aktif)
                .ToListAsync();
            personelAraclar = atamalar
                .GroupBy(a => a.SoforId)
                .ToDictionary(g => g.Key, g => g.OrderByDescending(a => a.BaslangicTarihi).First().Arac?.AktifPlaka ?? "");
        }
        catch { /* araç ataması yüklenemezse sessizce devam et */ }
    }

    private async Task LoadFirmalarAsync()
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            firmalar = await ctx.Firmalar
                .Where(f => !f.IsDeleted)
                .OrderBy(f => f.FirmaAdi)
                .AsNoTracking()
                .ToListAsync();
        }
        catch { }
    }

    private async Task LoadTedarikcilerAsync()
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            tedarikciler = await ctx.TasimaTedarikciler
                .Where(t => !t.IsDeleted)
                .OrderBy(t => t.Unvan)
                .AsNoTracking()
                .ToListAsync();
        }
        catch { }
    }

    private void YeniPersonel()
    {
        Navigation.NavigateTo("/soforler/yeni");
    }

