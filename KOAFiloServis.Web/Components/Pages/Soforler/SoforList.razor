    #region Muhasebe Hesap İşlemleri

    private async Task PersonelHesapBaglantilariniOnar()
    {
        var onay = await JS.InvokeAsync<bool>("confirm", "Tüm aktif personeller için 335/195 hesap bağlantıları PersonelId bazlı deterministik kurala göre onarılsın mı?");
        if (!onay) return;

        try
        {
            var onarimSonucu = await SoforService.TopluMuhasebeHesabiOlusturAsync();

            if (onarimSonucu.NullKalanPersonelMuhasebeHesapId > 0 || onarimSonucu.NullKalanCariPersonelAvansHesapId > 0)
            {
                ToastService.ShowWarning($"Onarım tamamlandı fakat eksik FK kaldı. 335 boş: {onarimSonucu.NullKalanPersonelMuhasebeHesapId}, 195 boş: {onarimSonucu.NullKalanCariPersonelAvansHesapId}");
            }
            else
            {
                ToastService.ShowSuccess($"Onarım tamamlandı. Toplam: {onarimSonucu.ToplamPersonel}, 335 bağlı: {onarimSonucu.Baglanan335Personel}, 195 bağlı: {onarimSonucu.Baglanan195Cari}, yeni 335: {onarimSonucu.Olusturulan335Hesap}, yeni 195: {onarimSonucu.Olusturulan195Hesap}");
            }

            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

