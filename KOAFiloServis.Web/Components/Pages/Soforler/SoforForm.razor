@page "/soforler/yeni"
@page "/soforler/{Id:int}"
@page "/personel/yeni"
@page "/personel/{Id:int}"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject ISoforService SoforService
@inject IMuhasebeService MuhasebeService
@inject IPersonelOzlukService OzlukService
@inject ISecureFileService SecureFileService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IAktiviteLogService AktiviteLog
@inject IAracService AracService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject IFirmaService FirmaService
@inject IDbContextFactory<KOAFiloServis.Web.Data.ApplicationDbContext> DbContextFactory
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Personel Düzenle" : "Yeni Personel")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-person-badge me-2"></i>@(IsEdit ? "Personel Düzenle" : "Yeni Personel")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="sofor" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <!-- Temel Bilgiler -->
                <h5 class="text-primary mb-3"><i class="bi bi-person me-2"></i>Temel Bilgiler</h5>
                <div class="row">
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Sıralama No</label>
                            <InputNumber @bind-Value="sofor.SiralamaNo" class="form-control" />
                            <small class="text-muted">Bordro sıralama için</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Personel Kodu *</label>
                            <InputText @bind-Value="sofor.SoforKodu" class="form-control" readonly="@IsEdit" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Ad *</label>
                            <InputText @bind-Value="sofor.Ad" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Soyad *</label>
                            <InputText @bind-Value="sofor.Soyad" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">TC Kimlik No</label>
                            <InputText @bind-Value="sofor.TcKimlikNo" class="form-control" maxlength="11" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Görev *</label>
                            <InputSelect @bind-Value="sofor.Gorev" class="form-select" @bind-Value:after="GorevDegisti">
                                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                                {
                                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Firma</label>
                            <InputSelect @bind-Value="sofor.FirmaId" class="form-select">
                                <option value="">-- Firma Seçin --</option>
                                @foreach (var firma in firmalar)
                                {
                                    <option value="@firma.Id">@firma.FirmaAdi</option>
                                }
                            </InputSelect>
                            <small class="text-muted">Bordro bu firmaya göre hazırlanır</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Taşıma Tedarikçisi</label>
                            <InputSelect @bind-Value="sofor.TasimaTedarikciId" class="form-select">
                                <option value="">-- Tedarikçi Yok (Kendi Personeli) --</option>
                                @foreach (var t in tasimaTedarikciler)
                                {
                                    <option value="@t.Id">@(string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}")</option>
                                }
                            </InputSelect>
                            <small class="text-muted">Alt yüklenici (taşıma) tedarikçisi seçilirse personel o tedarikçiye bağlanır</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Departman</label>
                            <InputText @bind-Value="sofor.Departman" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Pozisyon</label>
                            <InputText @bind-Value="sofor.Pozisyon" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">İşe Başlama Tarihi</label>
                            <InputDate @bind-Value="sofor.IseBaslamaTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">İşten Çıkış Tarihi</label>
                            <InputDate @bind-Value="sofor.IstenAyrilmaTarihi" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">SGK Çıkış Tarihi</label>
                            <InputDate @bind-Value="sofor.SgkCikisTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="sofor.Telefon" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="sofor.Email" class="form-control" type="email" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Adres</label>
                            <InputText @bind-Value="sofor.Adres" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Şoför Belgeleri (Sadece Şoför seçiliyse göster) -->
                @if (sofor.Gorev == PersonelGorev.Sofor)
                {
                    <hr />
                    <h5 class="text-primary mb-3"><i class="bi bi-file-earmark-text me-2"></i>Şoför Belgeleri</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Ehliyet No</label>
                                <InputText @bind-Value="sofor.EhliyetNo" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Ehliyet Geçerlilik</label>
                                <InputDate @bind-Value="sofor.EhliyetGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">MYK Belgesi Geçerlilik</label>
                                <InputDate @bind-Value="sofor.MykBelgesiGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Psikoteknik Geçerlilik</label>
                                <InputDate @bind-Value="sofor.PsikoteknikGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Sağlık Raporu Geçerlilik</label>
                                <InputDate @bind-Value="sofor.SaglikRaporuGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">SRC Belgesi</label>
                                <div class="form-check mt-2">
                                    <InputCheckbox @bind-Value="_srcBelgesiVarMi" class="form-check-input" id="srcBelgesiVar" />
                                    <label class="form-check-label" for="srcBelgesiVar">SRC belgesi mevcut</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Yaygın Eğitim Sertifikası</label>
                                <div class="form-check mt-2">
                                    <InputCheckbox @bind-Value="sofor.YayginEgitimSertifikasiVarMi" class="form-check-input" id="yayginEgitimVar" />
                                    <label class="form-check-label" for="yayginEgitimVar">Yaygın eğitim sertifikası mevcut</label>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Maaş ve Banka Bilgileri -->
                <hr />
                <h5 class="text-primary mb-3"><i class="bi bi-cash-stack me-2"></i>Maaş ve Banka Bilgileri</h5>
                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Ücret Türü</label>
                            <InputSelect @bind-Value="sofor.BrutMaasHesaplamaTipi" class="form-select" @bind-Value:after="BrutMaasHesaplaAsync">
                                <option value="@BrutMaasHesaplamaTipi.Manuel">Manuel Giriş</option>
                                <option value="@BrutMaasHesaplamaTipi.Saatlik">Saatlik Ücret</option>
                                <option value="@BrutMaasHesaplamaTipi.Gunluk">Günlük Ücret</option>
                                <option value="@BrutMaasHesaplamaTipi.Aylik">Aylık Ücret</option>
                            </InputSelect>
                        </div>
                    </div>
                    @if (sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)
                    {
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">@GetCalismaMiktariLabel()</label>
                                <InputNumber @bind-Value="sofor.CalismaMiktari" class="form-control" @bind-Value:after="BrutMaasHesaplaAsync" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">@GetBirimUcretLabel()</label>
                                <InputNumber @bind-Value="sofor.BirimUcret" class="form-control" @bind-Value:after="BrutMaasHesaplaAsync" />
                            </div>
                        </div>
                    }
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">@GetBrutUcretLabel()</label>
                            <InputNumber @bind-Value="sofor.BrutMaas" class="form-control" readonly="@(sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)" @bind-Value:after="BrutMaasHesaplaAsync" />
                            @if (sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)
                            {
                                <small class="text-muted">Hesaplanan: @sofor.CalismaMiktari x @sofor.BirimUcret = @sofor.BrutMaas.ToString("N2")</small>
                            }
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Bankaya Yatan / Resmi Net Maaş (₺) *</label>
                            <InputNumber @bind-Value="sofor.ResmiNetMaas" class="form-control" @bind-Value:after="MaasHesaplaAsync" />
                            <small class="text-muted">Bordroda ve banka ödemesinde kullanılacak resmi net tutar. Banka ödeme listesinde bu değer gösterilir ve güncellenebilir.</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Gerçek Maaş (₺) *</label>
                            <InputNumber @bind-Value="gercekMaas" class="form-control" @bind-Value:after="GercekMaasDegistiAsync" />
                            <small class="text-muted">Personele ödenen toplam gerçek maaş.</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Elden / Ek Ödeme Farkı (₺)</label>
                            <input type="text" class="form-control bg-light" readonly value="@sofor.DigerMaas.ToString("N2")" />
                            <small class="text-muted">Gerçek Maaş - Bankaya Yatan = @sofor.DigerMaas.ToString("N2") ₺</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Elden Ödenecek Önizleme (₺)</label>
                            <input type="text" class="form-control bg-light" readonly value="@EldenOdenecekOnizleme.ToString("N2")" />
                            <small class="text-muted">Şimdilik bankaya yatan hariç kalan maaş farkını gösterir.</small>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Banka Adı</label>
                            <InputText @bind-Value="sofor.BankaAdi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">IBAN</label>
                            <InputText @bind-Value="sofor.IBAN" class="form-control" placeholder="TR00 0000 0000 0000 0000 0000 00" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <div class="form-check form-switch mt-4">
                                <InputCheckbox @bind-Value="sofor.SGKBordroDahilMi" class="form-check-input" id="sgkBordro" />
                                <label class="form-check-label" for="sgkBordro">
                                    <strong>@(sofor.SGKBordroDahilMi ? "✓ SGK Bordro Düzenlenecek" : "SGK Bordro Düzenlensin")</strong>
                                    @if (sofor.SGKBordroDahilMi)
                                    {
                                        <span class="badge bg-success ms-1">Aktif</span>
                                    }
                                </label>
                            </div>
                        </div>
                    </div>
                    @if (sofor.SGKBordroDahilMi)
                    {
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Bordro Tipi *</label>
                                <InputSelect @bind-Value="sofor.BordroTipiPersonel" class="form-select" @bind-Value:after="BordroTipiDegisti">
                                    <option value="@PersonelBordroTipi.Normal">Normal</option>
                                    <option value="@PersonelBordroTipi.Arge">ARGE</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">SGK Çalışma Türü *</label>
                                <InputSelect @bind-Value="sofor.SgkCalismaTuru" class="form-select">
                                    <option value="@SgkCalismaTuru.TamZamanli">Tam Zamanlı (Full-time)</option>
                                    <option value="@SgkCalismaTuru.KismiZamanli">Kısmi Süreli (Part-time)</option>
                                    <option value="@SgkCalismaTuru.Cirak">Çırak (3308 say. Kanun)</option>
                                    <option value="@SgkCalismaTuru.StajYuksekOgretim">Stajyer - Yükseköğretim</option>
                                    <option value="@SgkCalismaTuru.IsBasiEgitimiIskur">İş Başı Eğitim Programı (İŞKUR)</option>
                                    <option value="@SgkCalismaTuru.EvHizmetleri10Alti">Ev Hizmetleri (10 gün altı)</option>
                                    <option value="@SgkCalismaTuru.EvHizmetleri10Ustu">Ev Hizmetleri (10 gün üstü)</option>
                                    <option value="@SgkCalismaTuru.MevsimlikTarim">Mevsimlik Tarım İşçisi</option>
                                    <option value="@SgkCalismaTuru.YabanciUyruklu">Yabancı Uyruklu</option>
                                    <option value="@SgkCalismaTuru.EmekliAktif">Emekli (Aktif Çalışan)</option>
                                    <option value="@SgkCalismaTuru.AsgariIscilikMuaf">Asgari İşçilik Muaf</option>
                                    <option value="@SgkCalismaTuru.Engelli">Engelli Çalışan</option>
                                    <option value="@SgkCalismaTuru.EskiHukumlu">Eski Hükümlü</option>
                                    <option value="@SgkCalismaTuru.TerörMagduru">Terör Mağduru</option>
                                </InputSelect>
                            </div>
                        </div>
                    }
                </div>

                <!-- Sosyal Yardımlar -->
                @if (sofor.SGKBordroDahilMi)
                {
                    <hr />
                    <h5 class="text-primary mb-3"><i class="bi bi-gift me-2"></i>Sosyal Yardımlar (Aylık)</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Yemek Yardımı</label>
                                <InputNumber @bind-Value="sofor.YemekYardimi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Yol Yardımı</label>
                                <InputNumber @bind-Value="sofor.YolYardimi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Aile Yardımı</label>
                                <InputNumber @bind-Value="sofor.AileYardimi" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <h5 class="text-danger mb-3"><i class="bi bi-scissors me-2"></i>Özel Kesintiler (Aylık)</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">İcra Kesintisi</label>
                                <InputNumber @bind-Value="sofor.IcraKesintisi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">BES Kesintisi</label>
                                <InputNumber @bind-Value="sofor.BESKesintisi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Sendika Aidatı</label>
                                <InputNumber @bind-Value="sofor.SendikaKesintisi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Hayat Sigortası</label>
                                <InputNumber @bind-Value="sofor.HayatSigortasi" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Bireysel Emeklilik</label>
                                <InputNumber @bind-Value="sofor.BireyselEmeklilik" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Diğer Özel Kesinti</label>
                                <InputNumber @bind-Value="sofor.DigerOzelKesinti" class="form-control" />
                            </div>
                        </div>
                    </div>
                }

                <!-- Muhasebe Hesap Entegrasyonu -->
                <hr />
                <h5 class="text-primary mb-3"><i class="bi bi-calculator me-2"></i>Muhasebe Hesap Entegrasyonu</h5>
                <div class="row">
                    <!-- 335 - Personele Borçlar Hesabı -->
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label"><span class="badge bg-secondary me-1">335</span>Personele Borçlar Hesabı</label>
                            <div class="input-group">
                                <InputSelect @bind-Value="sofor.MuhasebeHesapId" class="form-select">
                                    <option value="">-- Otomatik Oluşturulsun --</option>
                                    @foreach (var hesap in muhasebeHesaplari)
                                    {
                                        <option value="@hesap.Id">@hesap.HesapKodu - @hesap.HesapAdi</option>
                                    }
                                </InputSelect>
                                <button type="button" class="btn btn-outline-secondary" @onclick="HesaplariYenile" title="Hesapları Yenile">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>
                            <small class="text-muted">
                                @if (!IsEdit || !sofor.MuhasebeHesapId.HasValue)
                                {
                                    <text>Boş bırakılırsa ayarlardaki önek + otomatik sayaç ile oluşturulur (örn: 335.01.0001).</text>
                                }
                                else
                                {
                                    <text>Personele borç (maaş, avans vb.) muhasebe işlemlerinde kullanılır.</text>
                                }
                            </small>
                        </div>
                    </div>
                    @if (sofor.MuhasebeHesapId.HasValue)
                    {
                        var secilenHesap = muhasebeHesaplari.FirstOrDefault(h => h.Id == sofor.MuhasebeHesapId);
                        @if (secilenHesap != null)
                        {
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">335 Hesap Bilgisi</label>
                                    <div class="alert alert-info py-2 mb-0">
                                        <small>
                                            <strong>@secilenHesap.HesapKodu</strong> - @secilenHesap.HesapAdi
                                            <br />
                                            <span class="text-muted">@secilenHesap.HesapGrubu</span>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="row">
                    <!-- 195 - Personel Avans Hesabı -->
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label"><span class="badge bg-secondary me-1">195</span>Personel Avans Hesabı</label>
                            <div class="input-group">
                                <InputSelect @bind-Value="seciliAvansHesapId" class="form-select">
                                    <option value="0">-- Otomatik Oluşturulsun --</option>
                                    <option value="-1">-- Hesap Planından Seç --</option>
                                    @foreach (var hesap in avansHesaplari)
                                    {
                                        <option value="@hesap.Id">@hesap.HesapKodu - @hesap.HesapAdi</option>
                                    }
                                </InputSelect>
                                <button type="button" class="btn btn-outline-secondary" @onclick="HesaplariYenile" title="Hesapları Yenile">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>
                            <small class="text-muted">
                                @if (personelAvansHesap != null)
                                {
                                    <text>Mevcut: <strong>@personelAvansHesap.HesapKodu</strong> - @personelAvansHesap.HesapAdi</text>
                                }
                                else if (seciliAvansHesapId == 0)
                                {
                                    <text>Ayarlardaki önek + otomatik sayaç ile oluşturulur (örn: 195.01.0001).</text>
                                }
                                else
                                {
                                    <text>Hesap planından seçin veya otomatik oluşturmayı seçin.</text>
                                }
                            </small>
                        </div>
                    </div>
                    @if (avansHesaplari.Any())
                    {
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Mevcut 195.01 Avans Hesapları</label>
                                <div class="list-group list-group-flush border rounded" style="max-height:120px;overflow-y:auto;">
                                    @foreach (var ah in avansHesaplari)
                                    {
                                        <div class="list-group-item list-group-item-action py-1 px-2 @(personelAvansHesap?.Id == ah.Id ? "active" : "")">
                                            <small><strong>@ah.HesapKodu</strong> - @ah.HesapAdi</small>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* ARGE Personeli Uyarıları *@
                @if (sofor.SGKBordroDahilMi && sofor.BordroTipiPersonel == PersonelBordroTipi.Arge)
                {
                    <div class="alert alert-warning">
                        <h6><i class="bi bi-lightbulb me-2"></i>ARGE Personeli - Yasal Mevzuat Uyarıları</h6>
                        <ul class="mb-0 small">
                            <li>ARGE personeli 5746 sayılı Ar-Ge Faaliyetlerinin Desteklenmesi Hakkında Kanun kapsamında değerlendirilmektedir.</li>
                            <li>ARGE personeli için SGK işveren payı desteği (%100'e kadar) uygulanabilir.</li>
                            <li>Gelir vergisi stopaj teşviki uygulanabilir (Ar-Ge merkezleri için %100, diğerleri için %80).</li>
                            <li>Personelin ARGE faaliyetlerinde çalıştığını belgeleyen kayıtlar düzenli tutulmalıdır.</li>
                            <li>ARGE projelerinde çalışma süreleri ve saatleri ayrı takip edilmelidir.</li>
                        </ul>
                        @if (string.IsNullOrWhiteSpace(sofor.TcKimlikNo))
                        {
                            <div class="mt-2 text-danger">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                <strong>Uyarı:</strong> ARGE personeli için TC Kimlik No zorunludur!
                            </div>
                        }
                    </div>
                }

                <!-- Durum ve Notlar -->
                <hr />
                <div class="row">
                    <div class="col-md-2">
                        <div class="mb-3">
                            <div class="form-check form-switch mt-4">
                                <InputCheckbox @bind-Value="sofor.Aktif" class="form-check-input" id="aktif" />
                                <label class="form-check-label" for="aktif">
                                    <strong>@(sofor.Aktif ? "Aktif" : "Pasif")</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-10">
                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="sofor.Notlar" class="form-control" rows="2" />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    @* Araç Eşleştirme Bölümü - Tüm personel görevleri için *@
    <div class="card mt-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-truck me-2"></i>Araç Eşleştirmeleri</h5>
                @if (IsEdit)
                {
                    <button class="btn btn-sm btn-primary" @onclick="AtamaModalAc">
                        <i class="bi bi-plus-lg me-1"></i>Araç Ekle
                    </button>
                }
            </div>
            <div class="card-body">
                @if (!IsEdit)
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>Araç eşleştirmesi yapabilmek için önce personeli <strong>kaydedin</strong>, ardından bu bölümden araç ekleyebilirsiniz.
                    </div>
                }
                else if (aracAtamalari == null)
                {
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                }
                else if (!aracAtamalari.Any())
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>Henüz araç eşleştirmesi yapılmamış.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Plaka</th>
                                    <th>Araç</th>
                                    <th>Başlangıç</th>
                                    <th>Bitiş</th>
                                    <th>Notlar</th>
                                    <th class="text-center">Durum</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var atama in aracAtamalari.OrderByDescending(a => a.Aktif).ThenByDescending(a => a.BaslangicTarihi))
                                {
                                    <tr class="@(atama.Aktif ? "" : "table-secondary text-muted")">
                                        <td><strong>@atama.Arac?.AktifPlaka</strong></td>
                                        <td>@atama.Arac?.Marka @atama.Arac?.Model @atama.Arac?.ModelYili</td>
                                        <td>@atama.BaslangicTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>@(atama.BitisTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td><small>@atama.Notlar</small></td>
                                        <td class="text-center">
                                            @if (atama.Aktif)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Pasif</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-1 justify-content-center">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => AtamaDuzenleAc(atama)" title="Düzenle">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                @if (atama.Aktif)
                                                {
                                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => AtamaKapat(atama.Id)" title="Eşleştirmeyi Kapat">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => AtamaSil(atama.Id)" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    @* Özlük Belgeleri Bölümü - Sadece Düzenleme Modunda *@
    @if (IsEdit)
    {
        <div class="card mt-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-folder-fill me-2"></i>Özlük Belgeleri</h5>
                <a href="/ebys/ozluk-dosyasi/@Id" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Tüm Evraklar (EBYS)
                </a>
            </div>
            <div class="card-body">
                @if (evrakDurumuYukleniyor)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Yükleniyor...</span>
                        </div>
                    </div>
                }
                else if (evrakDurumu == null)
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Özlük evrak durumu yüklenemedi.
                    </div>
                }
                else
                {
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar @GetProgressBarClass(evrakDurumu.TamamlanmaYuzdesi)" 
                                     role="progressbar" 
                                     style="width: @evrakDurumu.TamamlanmaYuzdesi%"
                                     aria-valuenow="@evrakDurumu.TamamlanmaYuzdesi" aria-valuemin="0" aria-valuemax="100">
                                    %@evrakDurumu.TamamlanmaYuzdesi.ToString("F0")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <span class="badge bg-success me-2">@evrakDurumu.TamamlananEvrak Tamamlanan</span>
                            <span class="badge bg-danger">@evrakDurumu.EksikEvrak Eksik</span>
                        </div>
                    </div>

                    @* Şoför Belgeleri (Ehliyet, SRC, Psikoteknik) - Hızlı Erişim *@
                    @if (sofor.Gorev == PersonelGorev.Sofor)
                    {
                        <h6 class="text-primary mb-3"><i class="bi bi-card-checklist me-2"></i>Şoför Belgeleri (Hızlı Erişim)</h6>
                        <div class="row g-3 mb-4">
                            @foreach (var evrak in evrakDurumu.Evraklar.Where(e => e.Kategori == OzlukEvrakKategori.SoforBelgeleri))
                            {
                                <div class="col-md-4">
                                    <div class="card h-100 @(evrak.Tamamlandi ? "border-success" : "border-warning")">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h6 class="card-title mb-1">@evrak.EvrakAdi</h6>
                                                    @if (evrak.Tamamlandi)
                                                    {
                                                        <small class="text-success">
                                                            <i class="bi bi-check-circle me-1"></i>
                                                            @(evrak.TamamlanmaTarihi?.ToString("dd.MM.yyyy") ?? "Yüklendi")
                                                        </small>
                                                    }
                                                    else
                                                    {
                                                        <small class="text-warning">
                                                            <i class="bi bi-exclamation-circle me-1"></i>Eksik
                                                        </small>
                                                    }
                                                </div>
                                                <div>
                                                    @if (evrak.Tamamlandi && !string.IsNullOrWhiteSpace(evrak.DosyaYolu))
                                                    {
                                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EvrakDosyaIndir(evrak)" title="İndir">
                                                            <i class="bi bi-download"></i>
                                                        </button>
                                                    }
                                                    <button class="btn btn-sm btn-outline-success ms-1" @onclick="() => EvrakYukleModalAc(evrak)" title="Yükle">
                                                        <i class="bi bi-upload"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @* Özlük Evrak Checklist - Tüm Belgeler *@
                    <h6 class="text-secondary mb-3 d-flex justify-content-between align-items-center">
                        <span>
                            <i class="bi bi-list-check me-2"></i>Özlük Evrak Checklist
                            <span class="badge bg-light text-dark ms-2">@evrakDurumu.Evraklar.Count(e => e.Kategori != OzlukEvrakKategori.SoforBelgeleri || sofor.Gorev != PersonelGorev.Sofor) belge</span>
                        </span>
                        <a class="btn btn-sm btn-outline-info" href="/personel/ozluk-evrak?soforId=@Id">
                            <i class="bi bi-folder2-open me-1"></i>Tam Checklist Sayfası
                        </a>
                    </h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Belge</th>
                                    <th>Kategori</th>
                                    <th>Durum</th>
                                    <th class="text-end">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    // Şoför ise üstteki "Hızlı Erişim" kartlarında zaten gösterilen şoför belgeleri tabloda tekrar etmesin.
                                    var checklistEvraklar = sofor.Gorev == PersonelGorev.Sofor
                                        ? evrakDurumu.Evraklar.Where(e => e.Kategori != OzlukEvrakKategori.SoforBelgeleri)
                                        : evrakDurumu.Evraklar.AsEnumerable();
                                }
                                @foreach (var evrak in checklistEvraklar.OrderBy(e => e.Kategori).ThenBy(e => e.EvrakAdi))
                                {
                                    <tr>
                                        <td>
                                            @evrak.EvrakAdi
                                            @if (evrak.Zorunlu)
                                            {
                                                <span class="badge bg-danger ms-1">Zorunlu</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-secondary">@GetKategoriAdi(evrak.Kategori)</span></td>
                                        <td>
                                            @if (evrak.Tamamlandi)
                                            {
                                                <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Tamam</span>
                                            }
                                            else
                                            {
                                                <span class="text-warning"><i class="bi bi-exclamation-circle-fill me-1"></i>Eksik</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (evrak.Tamamlandi && !string.IsNullOrWhiteSpace(evrak.DosyaYolu))
                                            {
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EvrakDosyaIndir(evrak)" title="İndir">
                                                    <i class="bi bi-download"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => EvrakYukleModalAc(evrak)" title="Yükle">
                                                <i class="bi bi-upload"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Araç Atama Modal *@
@if (showAtamaModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-truck me-2"></i>Araç Eşleştir</h5>
                    <button type="button" class="btn-close" @onclick="AtamaModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Araç (Plaka) *</label>
                        <div class="position-relative">
                            <input type="text" class="form-control" placeholder="Plaka veya marka ara..."
                                   value="@modalPlakaArama"
                                   @oninput="ModalPlakaFiltrele"
                                   @onfocus="() => modalPlakaDropAcik = true"
                                   @onblur="ModalPlakaDropKapat" />
                            @if (modalPlakaDropAcik && modalFiltreliAraclar.Any())
                            {
                                <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1060;">
                                    @foreach (var a in modalFiltreliAraclar)
                                    {
                                        <button type="button" class="dropdown-item" @onmousedown="() => ModalAracSec(a)">
                                            <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                        @if (yeniAtamaAracId > 0)
                        {
                            <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @modalPlakaArama</small>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Başlangıç Tarihi *</label>
                        <input type="date" class="form-control" @bind="yeniAtamaBaslangic" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notlar</label>
                        <input type="text" class="form-control" @bind="yeniAtamaNot" placeholder="İsteğe bağlı açıklama..." maxlength="500" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="AtamaModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="AtamaKaydet" disabled="@(yeniAtamaAracId == 0 || atamaSaving)">
                        @if (atamaSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Araç Atama Düzenleme Modal *@
@if (showDuzenleModal && duzenleAtama != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Araç Eşleştirmeyi Düzenle</h5>
                    <button type="button" class="btn-close" @onclick="() => showDuzenleModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Araç (Plaka) *</label>
                        <div class="position-relative">
                            <input type="text" class="form-control" placeholder="Plaka veya marka ara..."
                                   value="@duzenleModalPlakaArama"
                                   @oninput="DuzenleModalPlakaFiltrele"
                                   @onfocus="() => duzenleModalDropAcik = true"
                                   @onblur="DuzenleModalDropKapat" />
                            @if (duzenleModalDropAcik && duzenleModalFiltreliAraclar.Any())
                            {
                                <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1060;">
                                    @foreach (var a in duzenleModalFiltreliAraclar)
                                    {
                                        <button type="button" class="dropdown-item" @onmousedown="() => DuzenleModalAracSec(a)">
                                            <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                        @if (duzenleAtama.AracId > 0)
                        {
                            <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @duzenleModalPlakaArama</small>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Başlangıç Tarihi *</label>
                        <input type="date" class="form-control" @bind="duzenleAtama.BaslangicTarihi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bitiş Tarihi</label>
                        <input type="date" class="form-control" @bind="duzenleAtama.BitisTarihi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notlar</label>
                        <input type="text" class="form-control" @bind="duzenleAtama.Notlar" placeholder="İsteğe bağlı açıklama..." maxlength="500" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="duzenleAktif" @bind="duzenleAtama.Aktif" />
                        <label class="form-check-label" for="duzenleAktif">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDuzenleModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="AtamaDuzenleKaydet" disabled="@(duzenleAtama.AracId == 0 || atamaDuzenleSaving)">
                        @if (atamaDuzenleSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Evrak Yükleme Modal *@
@if (showEvrakYukleModal && seciliEvrakDetay != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>@seciliEvrakDetay.EvrakAdi Yükle</h5>
                    <button type="button" class="btn-close" @onclick="EvrakYukleModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <strong>@sofor.TamAd</strong> için <strong>@seciliEvrakDetay.EvrakAdi</strong> belgesi yükleyin.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dosya Seçin *</label>
                        <InputFile OnChange="OnEvrakDosyaSecildi" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <small class="text-muted">PDF, JPG, PNG, DOC formatları desteklenir. Maks 10MB.</small>
                    </div>
                    @if (secilenEvrakDosya != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-file-earmark-check me-2"></i>
                            @secilenEvrakDosya.Name (@FormatDosyaBoyutu(secilenEvrakDosya.Size))
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="EvrakYukleModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="EvrakDosyaYukle" disabled="@(secilenEvrakDosya == null || evrakYukleniyor)">
                        @if (evrakYukleniyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-upload me-1"></i>Yükle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private Sofor sofor = new();
    private bool IsEdit => Id.HasValue;
    private bool _srcBelgesiVarMi;
    private decimal ToplamNetMaas => sofor.NetMaas;
    private decimal EldenOdenecekOnizleme => YuvarlaPara(Math.Max(0, sofor.NetMaas - sofor.ResmiNetMaas));
    private List<MuhasebeHesap> muhasebeHesaplari = new();
    private List<MuhasebeHesap> avansHesaplari = new();
    private MuhasebeHesap? personelAvansHesap;
    private int seciliAvansHesapId; // 0=otomatik, -1=seçim yok, >0=seçili hesap

    // Gerçek maaş için ayrı değişken (manuel giriş)
    private decimal gercekMaas;

    // Özlük Evrak Yönetimi
    private PersonelOzlukEvrakDurum? evrakDurumu;
    private bool evrakDurumuYukleniyor = false;
    private bool showEvrakYukleModal = false;
    private OzlukEvrakDetay? seciliEvrakDetay;
    private IBrowserFile? secilenEvrakDosya;
    private bool evrakYukleniyor = false;

    // Araç Eşleştirme
    private List<PersonelAracAtama>? aracAtamalari;
    private List<Arac> aktifAraclar = new();
    private bool showAtamaModal = false;
    private int yeniAtamaAracId = 0;
    private DateTime yeniAtamaBaslangic = DateTime.Today;
    private string yeniAtamaNot = "";
    private bool atamaSaving = false;
    private string modalPlakaArama = string.Empty;
    private bool modalPlakaDropAcik = false;
    private List<Arac> modalFiltreliAraclar = new();

    // Araç Eşleştirme Düzenleme
    private bool showDuzenleModal = false;
    private PersonelAracAtama? duzenleAtama = null;
    private bool atamaDuzenleSaving = false;
