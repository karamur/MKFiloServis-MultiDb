    private Task BrutMaasHesaplaAsync()
    {
        sofor.CalismaMiktari = YuvarlaPara(sofor.CalismaMiktari);
        sofor.BirimUcret = YuvarlaPara(sofor.BirimUcret);

        if (sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)
        {
            sofor.BrutMaas = YuvarlaPara(sofor.CalismaMiktari * sofor.BirimUcret);
        }
        else
        {
            sofor.BrutMaas = YuvarlaPara(sofor.BrutMaas);
        }

        sofor.ResmiNetMaas = YuvarlaPara(sofor.ResmiNetMaas);
        // Gerçek maaş değiştiyse farkı hesapla
        sofor.DigerMaas = YuvarlaPara(gercekMaas - sofor.ResmiNetMaas);
        sofor.NetMaas = YuvarlaPara(gercekMaas);

        return Task.CompletedTask;
    }

    private Task MaasHesaplaAsync()
    {
        // Bankaya yatan değiştiğinde farkı yeniden hesapla
        sofor.ResmiNetMaas = YuvarlaPara(sofor.ResmiNetMaas);
        sofor.DigerMaas = YuvarlaPara(gercekMaas - sofor.ResmiNetMaas);
        sofor.NetMaas = YuvarlaPara(gercekMaas);
        return Task.CompletedTask;
    }

    private Task GercekMaasDegistiAsync()
    {
        // Gerçek maaş manuel girildiğinde farkı hesapla
        gercekMaas = YuvarlaPara(gercekMaas);
        sofor.DigerMaas = YuvarlaPara(gercekMaas - sofor.ResmiNetMaas);
        sofor.NetMaas = YuvarlaPara(gercekMaas);
        return Task.CompletedTask;
    }

    private Task GercekMaastanFarkiHesaplaAsync()
    {
        sofor.ResmiNetMaas = YuvarlaPara(sofor.ResmiNetMaas);
        gercekMaas = YuvarlaPara(gercekMaas);

        if (gercekMaas < sofor.ResmiNetMaas)
        {
            gercekMaas = sofor.ResmiNetMaas;
        }

        sofor.DigerMaas = YuvarlaPara(gercekMaas - sofor.ResmiNetMaas);
        sofor.NetMaas = YuvarlaPara(gercekMaas);
        return Task.CompletedTask;
    }

    private static decimal YuvarlaPara(decimal value)
        => Math.Round(value, 2, MidpointRounding.AwayFromZero);

