    [SupplyParameterFromQuery(Name = "tedarikciId")]
    public int? TedarikciIdQuery { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await HesaplariYukle();
        await FirmalariYukle();
        await TasimaTedarikcileriYukle();

        if (IsEdit)
        {
            var existing = await SoforService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                sofor = existing;
                _srcBelgesiVarMi = existing.SrcBelgesiGecerlilikTarihi.HasValue;
                // Gerçek maaşı hesapla (ResmiNetMaas + DigerMaas)
                gercekMaas = sofor.ResmiNetMaas + sofor.DigerMaas;
                personelAvansHesap = await SoforService.GetPersonelAvansHesabiAsync(Id!.Value);
                seciliAvansHesapId = personelAvansHesap?.Id ?? 0;
                await EvrakDurumuYukle();
                await AracAtamalariniYukle();
            }
            else
            {
                Navigation.NavigateTo("/personel");
            }
        }
        else
        {
            sofor = new Sofor
            {
                Aktif = true,
                Gorev = PersonelGorev.Sofor,
                TasimaTedarikciId = TedarikciIdQuery,
                FirmaId = aktifFirmaBilgisi.FirmaId > 0 ? aktifFirmaBilgisi.FirmaId : null
            };
            _srcBelgesiVarMi = false;
            sofor.SoforKodu = await SoforService.GenerateNextKodAsync(sofor.Gorev);
            gercekMaas = 0;
        }
    }

