    private async Task AracAtamalariniYukle()
    {
        try
        {
            aktifAraclar = await AracService.GetActiveAsync();
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            aracAtamalari = await ctx.PersonelAracAtamalari
                .Include(a => a.Arac)
                .Where(a => a.SoforId == Id!.Value)
                .OrderByDescending(a => a.Aktif)
                .ThenByDescending(a => a.BaslangicTarihi)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Araç atamaları yüklenirken hata: {ex.Message}");
        }
    }

    private async Task AtamaModalAc()
    {
        if (!aktifAraclar.Any())
            aktifAraclar = await AracService.GetActiveAsync();
        yeniAtamaAracId = 0;
        yeniAtamaBaslangic = DateTime.Today;
        yeniAtamaNot = "";
        modalPlakaArama = string.Empty;
        modalFiltreliAraclar = aktifAraclar;
        modalPlakaDropAcik = false;
        showAtamaModal = true;
    }

    private void AtamaModalKapat()
    {
        showAtamaModal = false;
        modalPlakaDropAcik = false;
    }

    private void ModalPlakaFiltrele(ChangeEventArgs e)
    {
        modalPlakaArama = e.Value?.ToString() ?? string.Empty;
        yeniAtamaAracId = 0;
        modalPlakaDropAcik = true;
        var ara = modalPlakaArama.Trim().ToLowerInvariant();
        modalFiltreliAraclar = string.IsNullOrEmpty(ara)
            ? aktifAraclar
            : aktifAraclar.Where(a =>
                (a.AktifPlaka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Marka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Model ?? string.Empty).ToLowerInvariant().Contains(ara)).ToList();
    }

    private void ModalAracSec(Arac arac)
    {
        yeniAtamaAracId = arac.Id;
        modalPlakaArama = $"{arac.AktifPlaka} - {arac.Marka} {arac.Model}";
        modalPlakaDropAcik = false;
        modalFiltreliAraclar = aktifAraclar;
    }

    private async Task ModalPlakaDropKapat()
    {
        await Task.Delay(150);
        modalPlakaDropAcik = false;
    }

    private async Task AtamaKaydet()
    {
        if (yeniAtamaAracId == 0) return;
        atamaSaving = true;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            // Aynı araca aktif atama varsa kapat
            var mevcutAktif = await ctx.PersonelAracAtamalari
                .Where(a => a.SoforId == Id!.Value && a.AracId == yeniAtamaAracId && a.Aktif && !a.IsDeleted)
                .FirstOrDefaultAsync();
            if (mevcutAktif != null)
            {
                ToastService.ShowWarning("Bu araç zaten bu personele atanmış ve aktif durumda.");
                return;
            }
            var atama = new PersonelAracAtama
            {
                SoforId = Id!.Value,
                AracId = yeniAtamaAracId,
                BaslangicTarihi = yeniAtamaBaslangic,
                Aktif = true,
                Notlar = string.IsNullOrWhiteSpace(yeniAtamaNot) ? null : yeniAtamaNot
            };
            ctx.PersonelAracAtamalari.Add(atama);
            await ctx.SaveChangesAsync();
            ToastService.ShowSuccess("Araç eşleştirmesi eklendi.");
            showAtamaModal = false;
            await AracAtamalariniYukle();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Araç eklenirken hata: {ex.Message}");
        }
        finally
        {
            atamaSaving = false;
        }
    }

    private async Task AtamaKapat(int atamaId)
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var atama = await ctx.PersonelAracAtamalari.FindAsync(atamaId);
            if (atama != null)
            {
                atama.Aktif = false;
                atama.BitisTarihi = DateTime.Today;
                atama.UpdatedAt = DateTime.UtcNow;
                await ctx.SaveChangesAsync();
                ToastService.ShowSuccess("Araç eşleştirmesi kapatıldı.");
                await AracAtamalariniYukle();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"İşlem sırasında hata: {ex.Message}");
        }
    }

    private void AtamaDuzenleAc(PersonelAracAtama atama)
    {
        if (!aktifAraclar.Any())
        {
            _ = Task.Run(async () =>
            {
                aktifAraclar = await AracService.GetActiveAsync();
                await InvokeAsync(StateHasChanged);
            });
        }
        duzenleAtama = new PersonelAracAtama
        {
            Id = atama.Id,
            SoforId = atama.SoforId,
            AracId = atama.AracId,
            BaslangicTarihi = atama.BaslangicTarihi,
            BitisTarihi = atama.BitisTarihi,
            Aktif = atama.Aktif,
            Notlar = atama.Notlar
        };
        var secilenArac = aktifAraclar.FirstOrDefault(a => a.Id == atama.AracId) ?? atama.Arac;
        duzenleModalPlakaArama = secilenArac != null
            ? $"{secilenArac.AktifPlaka} - {secilenArac.Marka} {secilenArac.Model}"
            : atama.Arac?.AktifPlaka ?? "";
        duzenleModalFiltreliAraclar = aktifAraclar;
        duzenleModalDropAcik = false;
        showDuzenleModal = true;
    }

    private void DuzenleModalPlakaFiltrele(ChangeEventArgs e)
    {
        duzenleModalPlakaArama = e.Value?.ToString() ?? string.Empty;
        if (duzenleAtama != null) duzenleAtama.AracId = 0;
        duzenleModalDropAcik = true;
        var ara = duzenleModalPlakaArama.Trim().ToLowerInvariant();
        duzenleModalFiltreliAraclar = string.IsNullOrEmpty(ara)
            ? aktifAraclar
            : aktifAraclar.Where(a =>
                (a.AktifPlaka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Marka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Model ?? string.Empty).ToLowerInvariant().Contains(ara)).ToList();
    }

    private void DuzenleModalAracSec(Arac arac)
    {
        if (duzenleAtama == null) return;
        duzenleAtama.AracId = arac.Id;
        duzenleModalPlakaArama = $"{arac.AktifPlaka} - {arac.Marka} {arac.Model}";
        duzenleModalDropAcik = false;
        duzenleModalFiltreliAraclar = aktifAraclar;
    }

    private async Task DuzenleModalDropKapat()
    {
        await Task.Delay(150);
        duzenleModalDropAcik = false;
    }

    private async Task AtamaDuzenleKaydet()
    {
        if (duzenleAtama == null || duzenleAtama.AracId == 0) return;
        atamaDuzenleSaving = true;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var atama = await ctx.PersonelAracAtamalari.FindAsync(duzenleAtama.Id);
            if (atama != null)
            {
                atama.AracId = duzenleAtama.AracId;
                atama.BaslangicTarihi = duzenleAtama.BaslangicTarihi;
                atama.BitisTarihi = duzenleAtama.BitisTarihi;
                atama.Aktif = duzenleAtama.Aktif;
                atama.Notlar = duzenleAtama.Notlar;
                atama.UpdatedAt = DateTime.UtcNow;
                await ctx.SaveChangesAsync();
                ToastService.ShowSuccess("Araç eşleştirmesi güncellendi.");
                showDuzenleModal = false;
                await AracAtamalariniYukle();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Güncelleme sırasında hata: {ex.Message}");
        }
        finally
        {
            atamaDuzenleSaving = false;
        }
    }

    private async Task AtamaSil(int atamaId)
    {
        var onay = await JS.InvokeAsync<bool>("confirm", "Bu araç eşleştirmesini silmek istediğinize emin misiniz?");
        if (!onay) return;
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            var atama = await ctx.PersonelAracAtamalari.FindAsync(atamaId);
            if (atama != null)
            {
                atama.IsDeleted = true;
                atama.UpdatedAt = DateTime.UtcNow;
                await ctx.SaveChangesAsync();
                ToastService.ShowSuccess("Araç eşleştirmesi silindi.");
                await AracAtamalariniYukle();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme sırasında hata: {ex.Message}");
        }
    }

