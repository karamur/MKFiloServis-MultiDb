    private string formAracArama = string.Empty;
    private bool formAracDropAcik = false;
    private List<Arac> formFiltreliAraclar = new();

    private void FormAracAramaGuncelle(ChangeEventArgs e)
    {
        formAracArama = e.Value?.ToString() ?? string.Empty;
        formFiltreliAraclar = string.IsNullOrWhiteSpace(formAracArama)
            ? araclar
            : araclar.Where(a =>
                (a.AktifPlaka?.Contains(formAracArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Marka?.Contains(formAracArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Model?.Contains(formAracArama, StringComparison.OrdinalIgnoreCase) ?? false))
              .ToList();
        formAracDropAcik = true;
    }

    private void FormAracSec(Arac arac)
    {
        editDegisim.AracId = arac.Id;
        formAracArama = $"{arac.AktifPlaka} {arac.Marka} {arac.Model}".Trim();
        formAracDropAcik = false;
    }

    private async Task FormAracDropKapat()
    {
        await Task.Delay(200);
        formAracDropAcik = false;
    }

    private void YeniDegisim()
    {
        editDegisim = new LastikDegisim
        {
            DegisimTarihi = DateTime.Today,
            DegisimTipi = LastikDegisimTipi.Mevsimlik
        };
        degisimGirisSekli = "standart";
        degisimAdet = 4;
        serbestNot = string.Empty;
        ortakTakilanStokId = null;
        ortakKaynakDepoId = null;
        ortakHedefDepoId = null;
        HazirlaDegisimSatirlari(degisimAdet);
        showForm = true;
    }

    private void Duzenle(LastikDegisim d)
    {
        editDegisim = new LastikDegisim
        {
            Id = d.Id, AracId = d.AracId, DegisimTarihi = d.DegisimTarihi,
            KmDurumu = d.KmDurumu, DegisimTipi = d.DegisimTipi,
            TakilanStokId = d.TakilanStokId, TakilanPozisyon = d.TakilanPozisyon,
            KaynakDepoId = d.KaynakDepoId,
            SokulenStokId = d.SokulenStokId, SokulenPozisyon = d.SokulenPozisyon,
            HedefDepoId = d.HedefDepoId,
            YapilanYer = d.YapilanYer, Ucret = d.Ucret, Notlar = d.Notlar
        };
        YukleDegisimFormDurumu(d);
        showForm = true;
    }

    private async Task Kaydet()
    {
        kaydediliyor = true;
        try
        {
            var gecerliSatirlar = degisimSatirlari
                .Where(s => s.TakilanStokId.HasValue || s.SokulenStokId.HasValue)
                .ToList();

            if (!gecerliSatirlar.Any())
            {
                ToastService.ShowWarning("En az bir takılan veya sökülen lastik satırı girin.");
                return;
            }

            var ilkSatir = gecerliSatirlar.First();
            editDegisim.TakilanStokId = ilkSatir.TakilanStokId;
            editDegisim.SokulenStokId = ilkSatir.SokulenStokId;
            editDegisim.KaynakDepoId = ilkSatir.KaynakDepoId;
            editDegisim.HedefDepoId = ilkSatir.HedefDepoId;
            editDegisim.TakilanPozisyon = ilkSatir.Pozisyon;
            editDegisim.SokulenPozisyon = ilkSatir.Pozisyon;

            var payload = new LastikDegisimNotPayload
            {
                GirisTipi = degisimGirisSekli,
                Adet = gecerliSatirlar.Count,
                UserNot = serbestNot,
                Satirlar = gecerliSatirlar.Select(s => new LastikDegisimNotSatir
                {
                    Pozisyon = s.Pozisyon,
                    TakilanStokId = s.TakilanStokId,
                    TakilanEtiket = GetStokEtiket(s.TakilanStokId),
                    KaynakDepoId = s.KaynakDepoId,
                    KaynakDepoAdi = GetDepoAdi(s.KaynakDepoId),
                    SokulenStokId = s.SokulenStokId,
                    SokulenEtiket = GetStokEtiket(s.SokulenStokId),
                    HedefDepoId = s.HedefDepoId,
                    HedefDepoAdi = GetDepoAdi(s.HedefDepoId)
                }).ToList()
            };

            editDegisim.Notlar = JsonSerializer.Serialize(payload);

            if (editDegisim.Id == 0)
                await LastikService.CreateDegisimAsync(editDegisim);
            else
                await LastikService.UpdateDegisimAsync(editDegisim);

            showForm = false;
            await Filtrele();
            if (showAracDetayModal && seciliAracDetay != null)
                await AracDetayAc(seciliAracDetay.AracId);
            ToastService.ShowSuccess("Değişim kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally { kaydediliyor = false; }
    }

    private void SilOnay(LastikDegisim d) { silinecek = d; showDeleteModal = true; }

    private async Task Sil()
    {
        if (silinecek == null) return;
        await LastikService.DeleteDegisimAsync(silinecek.Id);
        showDeleteModal = false;
        await Filtrele();
        if (showAracDetayModal && seciliAracDetay != null)
            await AracDetayAc(seciliAracDetay.AracId);
        ToastService.ShowSuccess("Kayıt silindi.");
    }

    private void DegisimSekliDegisti(ChangeEventArgs e)
    {
        degisimGirisSekli = e.Value?.ToString() == "adet" ? "adet" : "standart";
        if (degisimGirisSekli == "standart")
            degisimAdet = 4;

        HazirlaDegisimSatirlari(degisimAdet);
    }

    private void DegisimAdetDegisti(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var adet))
            degisimAdet = Math.Clamp(adet, 1, 4);
        else
            degisimAdet = 4;

        HazirlaDegisimSatirlari(degisimAdet);
    }

    private void StandartDortluUygula()
    {
        degisimGirisSekli = "standart";
        degisimAdet = 4;
        HazirlaDegisimSatirlari(degisimAdet);
    }

    private void OrtakTakilanStokDegisti(ChangeEventArgs e)
    {
        ortakTakilanStokId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value!.ToString()!);
        OrtakAlanlariUygula();
    }

    private void OrtakKaynakDepoDegisti(ChangeEventArgs e)
    {
        ortakKaynakDepoId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value!.ToString()!);
        OrtakAlanlariUygula();
    }

    private void OrtakHedefDepoDegisti(ChangeEventArgs e)
    {
        ortakHedefDepoId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value!.ToString()!);
        OrtakAlanlariUygula();
    }

    private void OrtakAlanlariUygula()
    {
        foreach (var s in degisimSatirlari)
        {
            if (ortakTakilanStokId.HasValue)
                s.TakilanStokId = ortakTakilanStokId;
            if (ortakKaynakDepoId.HasValue)
                s.KaynakDepoId = ortakKaynakDepoId;
            if (ortakHedefDepoId.HasValue)
                s.HedefDepoId = ortakHedefDepoId;
        }
    }

    private void HazirlaDegisimSatirlari(int adet)
    {
        var hedefAdet = Math.Clamp(adet, 1, 4);
        var onceki = degisimSatirlari.ToList();

        degisimSatirlari = Enumerable.Range(0, hedefAdet)
            .Select(i =>
            {
                var mevcut = i < onceki.Count ? onceki[i] : null;
                return new LastikDegisimSatirForm
                {
                    Pozisyon = mevcut?.Pozisyon ?? StandartPozisyonlar[i],
                    TakilanStokId = mevcut?.TakilanStokId,
                    KaynakDepoId = mevcut?.KaynakDepoId,
                    SokulenStokId = mevcut?.SokulenStokId,
                    HedefDepoId = mevcut?.HedefDepoId
                };
            })
            .ToList();
    }

    private void YukleDegisimFormDurumu(LastikDegisim degisim)
    {
        var payload = ParseDegisimNotPayload(degisim.Notlar);
        if (payload != null && payload.Satirlar.Any())
        {
            degisimGirisSekli = payload.GirisTipi == "adet" ? "adet" : "standart";
            degisimAdet = Math.Clamp(payload.Adet > 0 ? payload.Adet : payload.Satirlar.Count, 1, 4);
            serbestNot = payload.UserNot ?? string.Empty;
            degisimSatirlari = payload.Satirlar
                .Take(4)
                .Select((s, i) => new LastikDegisimSatirForm
                {
                    Pozisyon = string.IsNullOrWhiteSpace(s.Pozisyon) ? StandartPozisyonlar[Math.Min(i, 3)] : s.Pozisyon,
                    TakilanStokId = s.TakilanStokId,
                    KaynakDepoId = s.KaynakDepoId,
                    SokulenStokId = s.SokulenStokId,
                    HedefDepoId = s.HedefDepoId
                })
                .ToList();
            return;
        }

        degisimGirisSekli = "adet";
        degisimAdet = 1;
        serbestNot = degisim.Notlar ?? string.Empty;
        degisimSatirlari = new List<LastikDegisimSatirForm>
        {
            new()
            {
                Pozisyon = degisim.TakilanPozisyon ?? degisim.SokulenPozisyon ?? StandartPozisyonlar[0],
                TakilanStokId = degisim.TakilanStokId,
                KaynakDepoId = degisim.KaynakDepoId,
                SokulenStokId = degisim.SokulenStokId,
                HedefDepoId = degisim.HedefDepoId
            }
        };
    }

    private List<string> GetTakilanOzetSatirlari(LastikDegisim degisim)
    {
        var payload = ParseDegisimNotPayload(degisim.Notlar);
        if (payload != null && payload.Satirlar.Any())
        {
            return payload.Satirlar
                .Where(s => !string.IsNullOrWhiteSpace(s.TakilanEtiket))
                .Select(s => $"{(string.IsNullOrWhiteSpace(s.Pozisyon) ? "Pozisyon?" : s.Pozisyon)}: {s.TakilanEtiket} | {s.KaynakDepoAdi ?? "-"}")
                .ToList();
        }

        if (degisim.TakilanStok == null)
            return new List<string>();

        return new List<string>
        {
            $"{degisim.TakilanStok.Ebat} {degisim.TakilanStok.Marka} ({GetSezonText(degisim.TakilanStok.Sezon)}) | {degisim.KaynakDepo?.DepoAdi ?? "-"} | {degisim.TakilanPozisyon ?? "-"}"
        };
    }

    private List<string> GetSokulenOzetSatirlari(LastikDegisim degisim)
    {
        var payload = ParseDegisimNotPayload(degisim.Notlar);
        if (payload != null && payload.Satirlar.Any())
        {
            return payload.Satirlar
                .Where(s => !string.IsNullOrWhiteSpace(s.SokulenEtiket))
                .Select(s => $"{(string.IsNullOrWhiteSpace(s.Pozisyon) ? "Pozisyon?" : s.Pozisyon)}: {s.SokulenEtiket} | {s.HedefDepoAdi ?? "-"}")
                .ToList();
        }

        if (degisim.SokulenStok == null)
            return new List<string>();

        return new List<string>
        {
            $"{degisim.SokulenStok.Ebat} {degisim.SokulenStok.Marka} ({GetSezonText(degisim.SokulenStok.Sezon)}) | {degisim.HedefDepo?.DepoAdi ?? "-"} | {degisim.SokulenPozisyon ?? "-"}"
        };
    }

    private LastikDegisimNotPayload? ParseDegisimNotPayload(string? notlar)
    {
        if (string.IsNullOrWhiteSpace(notlar))
            return null;

        try
        {
            return JsonSerializer.Deserialize<LastikDegisimNotPayload>(notlar);
        }
        catch
        {
            return null;
        }
    }

    private string? GetStokEtiket(int? stokId)
    {
        if (!stokId.HasValue)
            return null;

        var stok = stoklar.FirstOrDefault(s => s.Id == stokId.Value);
        if (stok == null)
            return null;

        return $"{stok.Ebat} {stok.Marka}";
    }

    private string? GetDepoAdi(int? depoId)
    {
        if (!depoId.HasValue)
            return null;

        return depolar.FirstOrDefault(d => d.Id == depoId.Value)?.DepoAdi;
    }

    private string GetTurBadge(LastikDegisimTipi t) => t switch
    {
        LastikDegisimTipi.Mevsimlik => "bg-primary",
        LastikDegisimTipi.Periyodik => "bg-success",
        LastikDegisimTipi.Ariza => "bg-danger",
        _ => "bg-secondary"
    };
    private string GetTurText(LastikDegisimTipi t) => t switch
    {
        LastikDegisimTipi.Mevsimlik => "Mevsimlik",
        LastikDegisimTipi.Periyodik => "Periyodik",
        LastikDegisimTipi.Ariza => "Arıza",
        LastikDegisimTipi.Diger => "Diğer",
        _ => t.ToString()
    };

    private string GetSezonBadge(LastikSezon s) => s switch
    {
        LastikSezon.YazLastigi => "bg-warning text-dark",
        LastikSezon.KisLastigi => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private string GetSezonText(LastikSezon s) => s switch
    {
        LastikSezon.YazLastigi => "Yaz",
        LastikSezon.KisLastigi => "Kis",
        LastikSezon.DortMevsim => "4 Mevsim",
        _ => s.ToString()
    };

    private string GetDurumBadge(LastikDurum d) => d switch
    {
        LastikDurum.Kullanilabilir => "bg-success",
        LastikDurum.Hasarli => "bg-warning text-dark",
        LastikDurum.Hurda => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetDurumText(LastikDurum d) => d switch
    {
        LastikDurum.Kullanilabilir => "Kullanilabilir",
        LastikDurum.Hasarli => "Hasarli",
        LastikDurum.Hurda => "Hurda",
        _ => d.ToString()
    };

    private sealed class LastikDegisimSatirForm
    {
        public string Pozisyon { get; set; } = string.Empty;
        public int? TakilanStokId { get; set; }
        public int? KaynakDepoId { get; set; }
        public int? SokulenStokId { get; set; }
        public int? HedefDepoId { get; set; }
    }

    private sealed class LastikDegisimNotPayload
    {
        public string? GirisTipi { get; set; }
        public int Adet { get; set; }
        public string? UserNot { get; set; }
        public List<LastikDegisimNotSatir> Satirlar { get; set; } = new();
    }

    private sealed class LastikDegisimNotSatir
    {
        public string? Pozisyon { get; set; }

        public int? TakilanStokId { get; set; }
        public string? TakilanEtiket { get; set; }
        public int? KaynakDepoId { get; set; }
        public string? KaynakDepoAdi { get; set; }

        public int? SokulenStokId { get; set; }
        public string? SokulenEtiket { get; set; }
        public int? HedefDepoId { get; set; }
        public string? HedefDepoAdi { get; set; }
    }
}
