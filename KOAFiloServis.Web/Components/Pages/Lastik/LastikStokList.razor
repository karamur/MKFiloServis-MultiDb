@page "/lastik/stok"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@inject ILastikService LastikService
@inject IAracService AracService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Lastik Takip</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-stack me-2"></i>Lastik Takip</h3>
        <button class="btn btn-primary" @onclick="YeniStok">
            <i class="bi bi-plus-lg me-1"></i>Yeni Lastik Ekle
        </button>
    </div>

    <!-- Sekmeler -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "liste" ? "active" : "")" @onclick='() => SekmeDegistir("liste")'>
                <i class="bi bi-list me-1"></i>Stok Listesi
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "plaka" ? "active" : "")" @onclick='() => SekmeDegistir("plaka")'>
                <i class="bi bi-truck me-1"></i>Plaka Bazlı Envanter
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "eksik" ? "active" : "")" @onclick='() => SekmeDegistir("eksik")'>
                <i class="bi bi-exclamation-triangle me-1"></i>Eksik Sezon Lastiği
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "kayip" ? "active" : "")" @onclick='() => SekmeDegistir("kayip")'>
                <i class="bi bi-x-octagon me-1"></i>Kayıp Lastikler
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "copeat" ? "active" : "")" @onclick='() => SekmeDegistir("copeat")'>
                <i class="bi bi-trash3 me-1"></i>Çöpe Atılanlar
            </button>
        </li>
    </ul>

    @if (aktifSekme == "liste")
    {
    <!-- Aktif / Pasif Filtre -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-auto">
                    <div class="btn-group" role="group">
                        <button type="button" class="btn @(filtreAktif == true ? "btn-success" : "btn-outline-success")"
                                @onclick='() => AktifFiltreDegistir(true)'>
                            <i class="bi bi-check-circle me-1"></i>Aktif
                        </button>
                        <button type="button" class="btn @(filtreAktif == false ? "btn-secondary" : "btn-outline-secondary")"
                                @onclick='() => AktifFiltreDegistir(false)'>
                            <i class="bi bi-archive me-1"></i>Pasif
                        </button>
                        <button type="button" class="btn @(filtreAktif == null ? "btn-dark" : "btn-outline-dark")"
                                @onclick='() => AktifFiltreDegistir(null)'>
                            Tümü
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @onchange="DepoFilter">
                        <option value="">-- Tüm Depolar --</option>
                        @foreach (var d in depolar)
                        {
                            <option value="@d.Id">@d.DepoAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-auto">
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn @(filtreTakimaDurum == null ? "btn-dark" : "btn-outline-dark")" @onclick='() => TakimaDurumFiltreDegistir(null)'>
                            Tümü
                        </button>
                        <button type="button" class="btn @(filtreTakimaDurum == true ? "btn-primary" : "btn-outline-primary")" @onclick='() => TakimaDurumFiltreDegistir(true)'>
                            <i class="bi bi-truck me-1"></i>Takılı
                        </button>
                        <button type="button" class="btn @(filtreTakimaDurum == false ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => TakimaDurumFiltreDegistir(false)'>
                            <i class="bi bi-archive me-1"></i>Depoda
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="position-relative">
                        <input type="text" class="form-control form-control-sm" placeholder="Plaka ile filtrele..."
                               value="@filtreAracArama"
                               @oninput="AracAramaGuncelle"
                               @onfocus="() => aracDropAcik = true"
                               @onblur="AracDropKapat" />
                        @if (aracDropAcik && filtreliAraclar.Any())
                        {
                            <div class="dropdown-menu show w-100" style="max-height:200px;overflow-y:auto;z-index:1060;">
                                <button type="button" class="dropdown-item" @onmousedown="() => AracSec(null)">
                                    <span class="text-muted">-- Tüm Araçlar --</span>
                                </button>
                                @foreach (var a in filtreliAraclar)
                                {
                                    <button type="button" class="dropdown-item" @onmousedown="() => AracSec(a)">
                                        <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    @if (filtreAracId.HasValue)
                    {
                        <small class="text-success"><i class="bi bi-check-circle me-1"></i>@filtreAracArama</small>
                    }
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="filtreSahiplikTipi" @bind:after="YukleStoklar">
                        <option value="Tumu">Sahiplik: Tümü</option>
                        @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                        {
                            <option value="@sahiplik.ToString()">@GetSahiplikText(sahiplik)</option>
                        }
                    </select>
                    <div class="form-check form-check-sm mt-1">
                        <input class="form-check-input" type="checkbox" id="chkStokSahiplikHaric" @bind="filtreSahiplikHaric" @bind:after="YukleStoklar" disabled="@(filtreSahiplikTipi == "Tumu")" />
                        <label class="form-check-label small text-muted" for="chkStokSahiplikHaric">Hariç tut</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (stoklar == null)
    {
        <div class="text-center"><div class="spinner-border" role="status"></div></div>
    }
    else if (!stoklar.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Depo</th>
                                <th>Marka / Ebat</th>
                                <th class="text-center">Sezon</th>
                                <th class="text-center">Durum</th>
                                <th>Araç / Plaka</th>
                                <th>Seri No</th>
                                <th style="width:130px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in stoklar)
                            {
                                <tr class="@(!s.Aktif ? "table-secondary text-muted" : "")">
                                    <td>@(s.Depo?.DepoAdi ?? "—")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(s.Marka))
                                        {
                                            <strong>@s.Marka</strong>
                                            <small class="text-muted ms-1">@s.Ebat</small>
                                        }
                                        else
                                        {
                                            <span>@s.Ebat</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetSezonBadge(s.Sezon)">@GetSezonText(s.Sezon)</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetDurumBadge(s.Durum)">@GetDurumText(s.Durum)</span>
                                    </td>
                                    <td>
                                        @if (s.AracId != null && s.Arac != null)
                                        {
                                            <span class="badge bg-primary me-1"><i class="bi bi-truck"></i> Takılı</span>
                                            <span>@s.Arac.AktifPlaka</span>
                                        }
                                        else if (s.KaynakAracId != null && s.KaynakArac != null)
                                        {
                                            <span class="badge bg-info text-dark me-1"><i class="bi bi-archive"></i> Depoda</span>
                                            <small class="text-info" title="Plakaya bağlı depoda">@s.KaynakArac.AktifPlaka</small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-archive"></i> Depoda</span>
                                        }
                                    </td>
                                    <td><small class="text-muted">@s.SeriNo</small></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(s)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (s.Aktif)
                                        {
                                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => PasifOnay(s)" title="Pasife Al">
                                                <i class="bi bi-archive"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(s)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="p-2 text-muted small">Toplam: <strong>@stoklar.Count</strong> lastik</div>
            </div>
        </div>
    }
    } @* aktifSekme == liste *@

    @if (aktifSekme == "plaka")
    {
        @if (plakaEnvanteri == null)
        {
            <div class="text-center"><div class="spinner-border" role="status"></div></div>
        }
        else if (!plakaEnvanteri.Any())
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Hiçbir araca atanmış aktif lastik kaydı yok.</div>
        }
        else
        {
            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                <button type="button" class="btn btn-sm @(plakaYazFiltresiAktif ? "btn-warning" : "btn-outline-warning")"
                        @onclick="() => { plakaYazFiltresiAktif = !plakaYazFiltresiAktif; if (plakaYazFiltresiAktif) plakaKisFiltresiAktif = false; }">
                    <i class="bi bi-sun me-1"></i>Sadece Yaz Lastiği Olanlar
                    @if (plakaYazFiltresiAktif)
                    {
                        <span class="badge bg-dark ms-1">@plakaEnvanteri.Count(p => p.YazVar)</span>
                    }
                </button>
                <button type="button" class="btn btn-sm @(plakaKisFiltresiAktif ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => { plakaKisFiltresiAktif = !plakaKisFiltresiAktif; if (plakaKisFiltresiAktif) plakaYazFiltresiAktif = false; }">
                    <i class="bi bi-snow2 me-1"></i>Sadece Kış Lastiği Olanlar
                    @if (plakaKisFiltresiAktif)
                    {
                        <span class="badge bg-white text-primary ms-1">@plakaEnvanteri.Count(p => p.KisVar)</span>
                    }
                </button>
                @if (plakaKisFiltresiAktif || plakaYazFiltresiAktif)
                {
                    <small class="text-muted"><i class="bi bi-funnel-fill me-1"></i>@FiltreliPlakaListesi.Count / @plakaEnvanteri.Count plaka</small>
                }
            </div>
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Plaka</th>
                                    <th>Araç</th>
                                    <th class="text-center">Son Değişim</th>
                                    <th class="text-center">Takılı</th>
                                    <th class="text-center">Yedek</th>
                                    <th class="text-center">Yaz</th>
                                    <th class="text-center">Kış</th>
                                    <th class="text-center" style="width:80px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in FiltreliPlakaListesi)
                                {
                                    var acik = acikDetaylar.Contains(p.AracId);
                                    <tr class="@(acik ? "table-active" : "")" style="cursor:pointer;" @onclick="() => ToggleDetay(p.AracId)">
                                        <td><strong>@p.Plaka</strong></td>
                                        <td><small class="text-muted">@p.AracBilgisi</small></td>
                                        <td class="text-center">
                                            <span class="badge @GetSonDegisimBadgeClass(p.SonDegisimTarihi)">
                                                @GetSonDegisimText(p.SonDegisimTarihi)
                                            </span>
                                        </td>
                                        <td class="text-center"><span class="badge bg-primary">@p.TakiliSayisi</span></td>
                                        <td class="text-center"><span class="badge bg-secondary">@p.YedekSayisi</span></td>
                                        <td class="text-center">
                                            @if (p.YazVar) { <i class="bi bi-check-circle-fill text-success fs-5"></i> }
                                            else { <i class="bi bi-x-circle-fill text-danger fs-5"></i> }
                                        </td>
                                        <td class="text-center">
                                            @if (p.KisVar) { <i class="bi bi-check-circle-fill text-success fs-5"></i> }
                                            else { <i class="bi bi-x-circle-fill text-danger fs-5"></i> }
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-sm @(acik ? "btn-secondary" : "btn-outline-secondary")" @onclick:stopPropagation="true" @onclick="() => ToggleDetay(p.AracId)" title="Detayı Göster/Gizle">
                                                <i class="bi bi-@(acik ? "chevron-up" : "chevron-down")"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    @if (acik)
                                    {
                                        <tr class="table-light">
                                            <td colspan="8" class="p-0 border-top-0">
                                                <div class="px-3 py-2">
                                                    <table class="table table-sm table-bordered mb-0 bg-white">
                                                        <thead class="table-secondary">
                                                            <tr>
                                                                <th>Konum</th>
                                                                <th>Sezon</th>
                                                                <th>Marka / Ebat</th>
                                                                <th>Durum</th>
                                                                <th>Depo</th>
                                                                <th>Seri No</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var l in p.Lastikler)
                                                            {
                                                                <tr>
                                                                    <td>
                                                                        @if (l.Takili)
                                                                        {
                                                                            <span class="badge bg-primary"><i class="bi bi-truck me-1"></i>Takılı</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="badge bg-light text-dark border"><i class="bi bi-archive me-1"></i>Depoda</span>
                                                                        }
                                                                    </td>
                                                                    <td><span class="badge @GetSezonBadge(l.Sezon)">@GetSezonText(l.Sezon)</span></td>
                                                                    <td>
                                                                        @if (!string.IsNullOrEmpty(l.Marka)) { <strong>@l.Marka</strong><span class="text-muted ms-1">@l.Ebat</span> }
                                                                        else { <span>@l.Ebat</span> }
                                                                    </td>
                                                                    <td><span class="badge @GetDurumBadge(l.Durum)">@GetDurumText(l.Durum)</span></td>
                                                                    <td><small class="text-muted">@(l.DepoAdi ?? "—")</small></td>
                                                                    <td><small class="text-muted">@(l.SeriNo ?? "—")</small></td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="p-2 text-muted small">Toplam: <strong>@FiltreliPlakaListesi.Count</strong> plaka @((plakaKisFiltresiAktif || plakaYazFiltresiAktif) ? $"(filtreli, tümü: {plakaEnvanteri.Count})" : "")</div>
                </div>
            </div>
        }
    }

    @if (aktifSekme == "eksik")
    {
        @if (eksikSezonRapor == null)
        {
            <div class="text-center"><div class="spinner-border" role="status"></div></div>
        }
        else
        {
            <!-- Filtreler -->
            <div class="card mb-3">
                <div class="card-body py-2">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <input class="form-control form-control-sm" placeholder="Plaka / araç ara..."
                                   @bind="eksikAramaTerimi" @bind:event="oninput" />
                        </div>
                        <div class="col-md-4">
                            <select class="form-select form-select-sm" @bind="eksikSezonFiltresi">
                                <option value="tum">Tümü (@eksikSezonRapor.Count plaka)</option>
                                <option value="yazeksik">Yaz Eksik</option>
                                <option value="kiseksik">Kış Eksik</option>
                                <option value="herikieksik">Her İkisi Eksik</option>
                                <option value="tamam">Tamamlanmış (Yaz + Kış Var)</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-center">
                            <small class="text-muted">
                                <i class="bi bi-funnel me-1"></i>
                                Gösterilen: <strong>@FiltreliEksikListesi.Count</strong> /
                                Eksik: <strong>@eksikSezonRapor.Count(x => x.YazEksik || x.KisEksik)</strong> plaka
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            @if (!FiltreliEksikListesi.Any())
            {
                @if (eksikSezonFiltresi == "tamam" || eksikSezonFiltresi == "tum")
                {
                    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>Tüm plakalarda yaz ve kış lastiği mevcut.</div>
                }
                else
                {
                    <div class="alert alert-info"><i class="bi bi-funnel me-2"></i>Filtreye uygun plaka bulunamadı.</div>
                }
            }
            else
            {
                <div class="card">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Plaka</th>
                                        <th>Araç</th>
                                        <th class="text-center">Son Değişim</th>
                                        <th class="text-center">Yaz</th>
                                        <th class="text-center">Kış</th>
                                        <th class="text-center">Toplam Lastik</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in FiltreliEksikListesi)
                                    {
                                        <tr>
                                            <td><strong>@e.Plaka</strong></td>
                                            <td><small>@e.AracBilgisi</small></td>
                                            <td class="text-center">
                                                <span class="badge @GetSonDegisimBadgeClass(e.SonDegisimTarihi)">
                                                    @GetSonDegisimText(e.SonDegisimTarihi)
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                @if (e.YazEksik) { <span class="badge bg-danger">Eksik</span> }
                                                else { <span class="badge bg-success">Var</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (e.KisEksik) { <span class="badge bg-danger">Eksik</span> }
                                                else { <span class="badge bg-success">Var</span> }
                                            </td>
                                            <td class="text-center">@e.ToplamLastikSayisi</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="p-2 text-muted small">
                            Toplam: <strong>@FiltreliEksikListesi.Count</strong> plaka gösteriliyor.
                            Eksik sezonlu: <strong>@eksikSezonRapor.Count(x => x.YazEksik || x.KisEksik)</strong> /
                            Tüm plakalar: <strong>@eksikSezonRapor.Count</strong>
                        </div>
                    </div>
                </div>
            }
        }
    }

    @if (aktifSekme == "kayip")
    {
        <div class="alert alert-warning py-2">
            <i class="bi bi-info-circle me-1"></i>
            Lastik değişiminde sökülen ancak depoya teslim edilmediği için <strong>kayıp</strong> sayılan lastikler aşağıda listelenir.
            Sökülen lastik için <em>Hedef Depo</em> seçilmediğinde sistem otomatik olarak bu listeye ekler.
        </div>
        @if (kayipLastikRapor == null)
        {
            <div class="text-center"><div class="spinner-border" role="status"></div></div>
        }
        else if (!kayipLastikRapor.Any())
        {
            <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>Kayıp lastik kaydı bulunmuyor.</div>
        }
        else
        {
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Kayıp Tarihi</th>
                                    <th>Plaka (Sökülen Araç)</th>
                                    <th>Marka / Ebat</th>
                                    <th class="text-center">Sezon</th>
                                    <th>Seri No</th>
                                    <th>Notlar</th>
                                    <th style="width:170px;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var k in kayipLastikRapor)
                                {
                                    <tr>
                                        <td>@(k.KayipTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td><strong>@(k.KaynaklandigiPlaka ?? "-")</strong></td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(k.Marka)) { <strong>@k.Marka</strong> }
                                            <small class="text-muted ms-1">@k.Ebat</small>
                                        </td>
                                        <td class="text-center"><span class="badge @GetSezonBadge(k.Sezon)">@GetSezonText(k.Sezon)</span></td>
                                        <td><small>@k.SeriNo</small></td>
                                        <td><small class="text-muted">@k.Notlar</small></td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => KayipBulunduOnay(k)">
                                                <i class="bi bi-box-arrow-in-down me-1"></i>Depoya Al
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => KayipCopeyAtOnay(k)">
                                                <i class="bi bi-trash3 me-1"></i>Çöpe At
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="p-2 text-muted small">Toplam: <strong>@kayipLastikRapor.Count</strong> kayıp lastik.</div>
                </div>
            </div>
        }
    }    @if (aktifSekme == "copeat")
    {
        <div class="alert alert-secondary py-2">
            <i class="bi bi-trash3 me-1"></i>
            Kayıp listesinden <strong>çöpe atılan</strong> lastikler. Plaka ve şoför bilgisi, atılma anındaki değerler olarak saklanır — sonradan değişse bile bu kayıtlar korunur.
        </div>
        @if (copeyAtilanlar == null)
        {
            <div class="text-center"><div class="spinner-border" role="status"></div></div>
        }
        else if (!copeyAtilanlar.Any())
        {
            <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>Çöpe atılan lastik kaydı bulunmuyor.</div>
        }
        else
        {
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Atılma Tarihi</th>
                                    <th>Plaka (Anındaki)</th>
                                    <th>Şoför (Anındaki)</th>
                                    <th>Marka / Ebat</th>
                                    <th class="text-center">Sezon</th>
                                    <th>Seri No</th>
                                    <th>Not</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in copeyAtilanlar)
                                {
                                    <tr>
                                        <td>@(c.CopeyAtmaTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td><strong>@(c.Plaka ?? "-")</strong></td>
                                        <td>@(c.SoforAdi ?? "-")</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(c.Marka)) { <strong>@c.Marka</strong> }
                                            <small class="text-muted ms-1">@c.Ebat</small>
                                        </td>
                                        <td class="text-center"><span class="badge @GetSezonBadge(c.Sezon)">@GetSezonText(c.Sezon)</span></td>
                                        <td><small>@c.SeriNo</small></td>
                                        <td><small class="text-muted">@c.Notlar</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="p-2 text-muted small">Toplam: <strong>@copeyAtilanlar.Count</strong> çöpe atılmış lastik.</div>
                </div>
            </div>
        }
    }
</div>


