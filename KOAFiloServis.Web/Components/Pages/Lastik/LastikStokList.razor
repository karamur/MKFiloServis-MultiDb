                            <div class="col-md-6 mb-3">
                                <label class="form-label">Araç (Plaka)</label>
                                <div class="btn-group btn-group-sm mb-1 w-100" role="group">
                                    <input type="radio" class="btn-check" name="konumModu" id="konumModuArac" value="arac"
                                           checked="@(formAracKonumModu == "arac")"
