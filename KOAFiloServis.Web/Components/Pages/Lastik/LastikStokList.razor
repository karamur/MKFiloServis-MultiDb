                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Sezon</label>
                                <InputSelect @bind-Value="editStok.Sezon" class="form-select">
                                    <option value="@LastikSezon.YazLastigi">Yaz Lastiği</option>
                                    <option value="@LastikSezon.KisLastigi">Kış Lastiği</option>
                                    <option value="@LastikSezon.DortMevsim">Dört Mevsim</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Durum</label>
                                <InputSelect @bind-Value="editStok.Durum" class="form-select">
                                    <option value="@LastikDurum.Kullanilabilir">Kullanılabilir</option>
                                    <option value="@LastikDurum.Hasarli">Hasarlı</option>
                                    <option value="@LastikDurum.Tamir">Tamirde</option>
                                    <option value="@LastikDurum.Hurda">Hurda</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Seri / DOT No</label>
                                <InputText @bind-Value="editStok.SeriNo" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check mt-4">
                                    <InputCheckbox @bind-Value="editStok.YedekMi" class="form-check-input" id="yedekMiCheck" />
                                    <label class="form-check-label" for="yedekMiCheck">Yedek lastik (plaka atanmaz)</label>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="editStok.Notlar" class="form-control" rows="2" />
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@kaydediliyor">
                                @if (kaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Kaydet
