                                    <label class="btn btn-outline-primary" for="konumModuArac"><i class="bi bi-truck me-1"></i>Araç Üzerinde</label>
                                    <input type="radio" class="btn-check" name="konumModu" id="konumModuDepo" value="depo"
                                           checked="@(formAracKonumModu == "depo")"
                                           @onchange='() => { formAracKonumModu = "depo"; editStok.AracId = null; }' />
                                    <label class="btn btn-outline-secondary" for="konumModuDepo"><i class="bi bi-archive me-1"></i>Depoda (Plakaya Bağlı)</label>
                                </div>
                                <div class="position-relative">
                                    <input type="text" class="form-control" placeholder="Plaka veya araç ara..."
                                           value="@formAracArama"
                                           @oninput="FormAracAramaGuncelle"
                                           @onfocus="() => formAracDropAcik = true"
                                           @onblur="FormAracDropKapat" />
                                    @if (formAracDropAcik && formFiltreliAraclar.Any())
                                    {
                                        <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1060;">
                                            <button type="button" class="dropdown-item" @onmousedown="() => FormAracSec(null)">
                                                <span class="text-muted">-- Atama Yok --</span>
                                            </button>
                                            @foreach (var a in formFiltreliAraclar)
                                            {
                                                <button type="button" class="dropdown-item" @onmousedown="() => FormAracSec(a)">
                                                    <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (formAracKonumModu == "depo" && editStok.KaynakAracId.HasValue)
                                {
                                    <small class="text-info"><i class="bi bi-info-circle me-1"></i>Lastik depoda muhafaza edilecek, plakaya bağlı olarak izlenecek.</small>
                                }
                            </div>
                        </div>
                        @if (editStok.Id == 0)
                        {
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Adet *</label>
                                    <InputNumber @bind-Value="yeniAdet" class="form-control" min="1" max="20" />
                                    <small class="text-muted">Aynı özelliklerde belirtilen adette ayrı stok kaydı oluşturulur (1-20).</small>
                                </div>
                                <div class="col-md-8 mb-3">
                                    <label class="form-label">Marka</label>
                                    <InputText @bind-Value="editStok.Marka" class="form-control" placeholder="Bridgestone, Michelin..." />
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label class="form-label">Marka</label>
                                    <InputText @bind-Value="editStok.Marka" class="form-control" placeholder="Bridgestone, Michelin..." />
                                </div>
                            </div>
                        }
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Ebat *</label>
                                <InputText @bind-Value="editStok.Ebat" class="form-control" placeholder="195/65R15" />
