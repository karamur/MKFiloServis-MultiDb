<!-- Form Modal -->
@if (showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-stack me-2"></i>@(editStok.Id == 0 ? "Yeni Lastik Ekle" : "Lastik Düzenle")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showForm = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editStok" OnValidSubmit="Kaydet">
                        <DataAnnotationsValidator />
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Depo</label>
                                <InputSelect @bind-Value="editStok.DepoId" class="form-select">
                                    <option value="">-- Depo Seçin (opsiyonel) --</option>
                                    @foreach (var d in depolar)
                                    {
                                        <option value="@d.Id">@d.DepoAdi</option>
                                    }
