@code {
    private List<LastikStok>? stoklar;
    private List<LastikDepo> depolar = new();
    private List<Arac> tumAraclar = new();
    private List<Arac> filtreliAraclar = new();
    private List<LastikPlakaEnvanteri>? plakaEnvanteri;
    private List<LastikEksikSezonSatiri>? eksikSezonRapor;
    private List<LastikKayipSatiri>? kayipLastikRapor;
    private List<LastikCopeyAtilanSatiri>? copeyAtilanlar;
    private string aktifSekme = "liste";
    private LastikStok editStok = new();
    private LastikStok? silinecek;
    private LastikStok? pasifYapilacak;
    private LastikKayipSatiri? seciliKayipSatir;
    private bool showKayipBulunduModal;
    private int? kayipBulunduDepoId;
    private string kayipBulunduNot = string.Empty;
    // Çöpe atma
    private LastikKayipSatiri? copeyAtilacakSatir;
    private bool showCopeyAtModal;
    private string copeyAtPlaka = string.Empty;
    private string copeyAtSofor = string.Empty;
    private string copeyAtNot = string.Empty;
    private bool showForm;
    private bool showDeleteModal;
    private bool showPasifModal;
    private bool kaydediliyor;
    private int? filtreDepoId;
    private bool? filtreAktif = true;
    private int? filtreAracId;
    private string filtreAracArama = string.Empty;
    private bool aracDropAcik = false;
    private bool plakaKisFiltresiAktif = false;
    private bool? filtreTakimaDurum = null; // null = Tümü, true = Takılı, false = Depoda
    private bool plakaYazFiltresiAktif = false;
    private HashSet<int> acikDetaylar = new();

    // Eksik sezon sekme filtreleri
    private string eksikAramaTerimi = string.Empty;
    private string eksikSezonFiltresi = "tum"; // tum | yazeksik | kiseksik | herikieksik | tamam

    private List<LastikEksikSezonSatiri> FiltreliEksikListesi
    {
        get
        {
            if (eksikSezonRapor == null) return new();
            IEnumerable<LastikEksikSezonSatiri> q = eksikSezonRapor;
            if (!string.IsNullOrWhiteSpace(eksikAramaTerimi))
                q = q.Where(x => x.Plaka.Contains(eksikAramaTerimi, StringComparison.OrdinalIgnoreCase) ||
                                  x.AracBilgisi.Contains(eksikAramaTerimi, StringComparison.OrdinalIgnoreCase));
            q = eksikSezonFiltresi switch
            {
                "yazeksik"    => q.Where(x => x.YazEksik),
                "kiseksik"    => q.Where(x => x.KisEksik),
                "herikieksik" => q.Where(x => x.YazEksik && x.KisEksik),
                "tamam"       => q.Where(x => !x.YazEksik && !x.KisEksik),
                _             => q
            };
            return q.ToList();
        }
    }

    private List<LastikPlakaEnvanteri> FiltreliPlakaListesi
    {
        get
        {
            if (plakaEnvanteri == null) return new List<LastikPlakaEnvanteri>();
            IEnumerable<LastikPlakaEnvanteri> query = plakaEnvanteri;
            // Sadece yaz = yaz var VE kış yok; sadece kış = kış var VE yaz yok
            if (plakaYazFiltresiAktif) query = query.Where(x => x.YazVar && !x.KisVar);
            if (plakaKisFiltresiAktif) query = query.Where(x => x.KisVar && !x.YazVar);
            return query.ToList();
        }
    }

    // Form: adet bazlı kayıt + araç seçimi
    private int yeniAdet = 1;
    private string formAracArama = string.Empty;
    private bool formAracDropAcik = false;
    private List<Arac> formFiltreliAraclar = new();
    /// <summary>Araç seçim modu: "arac" = araç üzerinde (AracId), "depo" = depoda ama plakaya bağlı (KaynakAracId)</summary>
    private string formAracKonumModu = "arac";

    protected override async Task OnInitializedAsync()
    {
        depolar = await LastikService.GetDepoListAsync();
        tumAraclar = await AracService.GetAllAsync();
        filtreliAraclar = tumAraclar;
        formFiltreliAraclar = tumAraclar;
        await YukleStoklar();
    }

    private async Task SekmeDegistir(string sekme)
    {
        aktifSekme = sekme;
        if (sekme == "plaka" && plakaEnvanteri == null)
            plakaEnvanteri = await LastikService.GetPlakaBazliEnvanterAsync();
        else if (sekme == "eksik" && eksikSezonRapor == null)
            eksikSezonRapor = await LastikService.GetEksikSezonRaporuAsync();
        else if (sekme == "kayip" && kayipLastikRapor == null)
            kayipLastikRapor = await LastikService.GetKayipLastikRaporuAsync();
        else if (sekme == "copeat" && copeyAtilanlar == null)
            copeyAtilanlar = await LastikService.GetCopeyAtilanLastiklerAsync();
    }

    private async Task RaporlariYenile()
    {
        if (plakaEnvanteri != null)
            plakaEnvanteri = await LastikService.GetPlakaBazliEnvanterAsync();
        if (eksikSezonRapor != null)
            eksikSezonRapor = await LastikService.GetEksikSezonRaporuAsync();
        if (kayipLastikRapor != null)
            kayipLastikRapor = await LastikService.GetKayipLastikRaporuAsync();
        if (copeyAtilanlar != null)
            copeyAtilanlar = await LastikService.GetCopeyAtilanLastiklerAsync();
    }

    private void FormAracAramaGuncelle(ChangeEventArgs e)
    {
        formAracArama = e.Value?.ToString() ?? string.Empty;
        formFiltreliAraclar = string.IsNullOrWhiteSpace(formAracArama)
            ? tumAraclar
            : tumAraclar.Where(a =>
                (a.AktifPlaka?.Contains(formAracArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Marka?.Contains(formAracArama, StringComparison.OrdinalIgnoreCase) ?? false))
              .ToList();
        formAracDropAcik = true;
    }

    private void FormAracSec(Arac? arac)
    {
        if (formAracKonumModu == "depo")
        {
            // Depoda ama plakaya bağlı
            editStok.AracId = null;
            editStok.KaynakAracId = arac?.Id;
        }
        else
        {
            // Araç üzerinde
            editStok.AracId = arac?.Id;
            editStok.KaynakAracId = null;
        }
        formAracArama = arac != null ? $"{arac.AktifPlaka} {arac.Marka} {arac.Model}".Trim() : string.Empty;
        formAracDropAcik = false;
    }

    private async Task FormAracDropKapat()
    {
        await Task.Delay(200);
        formAracDropAcik = false;
    }

    private async Task YukleStoklar()
    {
        var tumStoklar = await LastikService.GetStokListAsync(filtreDepoId, filtreAktif);
        IEnumerable<LastikStok> sonuc = tumStoklar;
        if (filtreAracId.HasValue)
            sonuc = sonuc.Where(s => s.AracId == filtreAracId);
        if (filtreTakimaDurum == true)
            sonuc = sonuc.Where(s => s.AracId != null);
        else if (filtreTakimaDurum == false)
            sonuc = sonuc.Where(s => s.AracId == null);
        if (filtreSahiplikTipi != "Tumu" && Enum.TryParse<AracSahiplikTipi>(filtreSahiplikTipi, out var sht))
        {
            sonuc = sonuc.Where(s =>
            {
                var ar = s.Arac ?? s.KaynakArac;
                if (ar is null) return filtreSahiplikHaric; // araç yoksa: dahil et yalnızca hariç tut modunda
                return filtreSahiplikHaric ? ar.SahiplikTipi != sht : ar.SahiplikTipi == sht;
            });
        }
        stoklar = sonuc.ToList();
        await Task.CompletedTask;
    }

    // Sahiplik filtresi alanları
    private string filtreSahiplikTipi = "Tumu";
    private bool filtreSahiplikHaric;

    private static string GetSahiplikText(AracSahiplikTipi sahiplik) => sahiplik switch
    {
        AracSahiplikTipi.Ozmal => "Özmal",
        AracSahiplikTipi.Kiralik => "Kiralık",
        AracSahiplikTipi.Komisyon => "Komisyon",
        AracSahiplikTipi.Diger => "Diğer",
        AracSahiplikTipi.Tedarikci => "Tedarikçi",
        _ => sahiplik.ToString()
    };

    private async Task TakimaDurumFiltreDegistir(bool? durum)
    {
        filtreTakimaDurum = durum;
        await YukleStoklar();
    }

    private void AracAramaGuncelle(ChangeEventArgs e)
    {
        filtreAracArama = e.Value?.ToString() ?? string.Empty;
        filtreliAraclar = string.IsNullOrWhiteSpace(filtreAracArama)
            ? tumAraclar
            : tumAraclar.Where(a =>
                (a.AktifPlaka?.Contains(filtreAracArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Marka?.Contains(filtreAracArama, StringComparison.OrdinalIgnoreCase) ?? false))
              .ToList();
        aracDropAcik = true;
    }

    private async Task AracSec(Arac? arac)
    {
        filtreAracId = arac?.Id;
        filtreAracArama = arac != null ? $"{arac.AktifPlaka} {arac.Marka} {arac.Model}".Trim() : string.Empty;
        aracDropAcik = false;
        await YukleStoklar();
    }

    private async Task AracDropKapat()
    {
        await Task.Delay(200);
        aracDropAcik = false;
    }

    private async Task AktifFiltreDegistir(bool? aktif)
    {
        filtreAktif = aktif;
        await YukleStoklar();
    }

    private async Task DepoFilter(ChangeEventArgs e)
    {
        filtreDepoId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!);
        await YukleStoklar();
    }

    private void YeniStok()
    {
        editStok = new LastikStok { Sezon = LastikSezon.YazLastigi, Durum = LastikDurum.Kullanilabilir, Aktif = true };
        yeniAdet = 1;
        formAracArama = string.Empty;
        formFiltreliAraclar = tumAraclar;
        showForm = true;
    }

    private void Duzenle(LastikStok s)
    {
        editStok = new LastikStok
        {
            Id = s.Id, DepoId = s.DepoId, AracId = s.AracId,
            Marka = s.Marka, Ebat = s.Ebat,
            Sezon = s.Sezon, SeriNo = s.SeriNo,
            YedekMi = s.YedekMi, Durum = s.Durum,
            Aktif = s.Aktif, Notlar = s.Notlar
        };
        yeniAdet = 1;
        var arac = s.AracId.HasValue ? tumAraclar.FirstOrDefault(a => a.Id == s.AracId.Value) : null;
        formAracArama = arac != null ? $"{arac.AktifPlaka} {arac.Marka} {arac.Model}".Trim() : string.Empty;
        formFiltreliAraclar = tumAraclar;
        showForm = true;
    }

    private async Task Kaydet()
    {
        kaydediliyor = true;
        try
        {
            if (editStok.Id == 0)
            {
                if (yeniAdet < 1) yeniAdet = 1;
                if (yeniAdet > 20) yeniAdet = 20;
                if (yeniAdet == 1)
                    await LastikService.CreateStokAsync(editStok);
                else
                    await LastikService.CreateStokToplualAsync(editStok, yeniAdet);
            }
            else
                await LastikService.UpdateStokAsync(editStok);

            showForm = false;
            await YukleStoklar();
            await RaporlariYenile();
            ToastService.ShowSuccess(editStok.Id == 0 && yeniAdet > 1
                ? $"{yeniAdet} adet lastik kaydedildi."
                : "Lastik kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally { kaydediliyor = false; }
    }


    private void KayipBulunduOnay(LastikKayipSatiri satir)
    {
        seciliKayipSatir = satir;
        kayipBulunduDepoId = depolar.FirstOrDefault()?.Id;
        kayipBulunduNot = string.Empty;
        showKayipBulunduModal = true;
    }

    private void KayipCopeyAtOnay(LastikKayipSatiri satir)
    {
        copeyAtilacakSatir = satir;
        copeyAtPlaka = satir.KaynaklandigiPlaka ?? string.Empty;
        copeyAtSofor = string.Empty;
        copeyAtNot = string.Empty;
        showCopeyAtModal = true;
    }

    private async Task CopeyAtKaydet()
    {
        if (copeyAtilacakSatir == null) return;
        try
        {
            await LastikService.KayipLastigiCopeyAtAsync(
                copeyAtilacakSatir.StokId,
                copeyAtNot,
                copeyAtPlaka,
                copeyAtSofor);

            showCopeyAtModal = false;
            copeyAtilacakSatir = null;
            copeyAtilanlar = null; // yeniden yüklensin
            await YukleStoklar();
            await RaporlariYenile();
            ToastService.ShowSuccess("Lastik çöpe atıldı / imha edildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task KayipBulunduKaydet()
    {
        if (seciliKayipSatir == null || kayipBulunduDepoId == null)
            return;

        try
        {
            var sonuc = await LastikService.KayipLastigiDepoyaAlAsync(seciliKayipSatir.StokId, kayipBulunduDepoId.Value, kayipBulunduNot);
            if (sonuc == null)
            {
                ToastService.ShowWarning("Kayıp lastik bulunamadı.");
                return;
            }

            showKayipBulunduModal = false;
            seciliKayipSatir = null;
            await YukleStoklar();
            await RaporlariYenile();
            ToastService.ShowSuccess("Kayıp lastik depoya alındı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }
    private void PasifOnay(LastikStok s) { pasifYapilacak = s; showPasifModal = true; }

    private async Task PasifYap()
    {
        if (pasifYapilacak == null) return;
        await LastikService.PasifAlAsync(pasifYapilacak.Id);
        showPasifModal = false;
        await YukleStoklar();
        ToastService.ShowSuccess("Lastik pasife alındı.");
    }

    private void SilOnay(LastikStok s) { silinecek = s; showDeleteModal = true; }

    private async Task Sil()
    {
        if (silinecek == null) return;
        await LastikService.DeleteStokAsync(silinecek.Id);
        showDeleteModal = false;
        await YukleStoklar();
        ToastService.ShowSuccess("Kayıt silindi.");
    }

