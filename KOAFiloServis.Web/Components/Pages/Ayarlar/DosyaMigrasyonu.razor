@page "/ayarlar/dosya-migrasyonu"
@using KOAFiloServis.Web.Services
@inject DosyaMigrasyonService MigrasyonService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Dosya Şifreleme Migrasyonu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3><i class="bi bi-shield-lock me-2"></i>Dosya Şifreleme Migrasyonu</h3>
            <p class="text-muted mb-0">Eski düz metin dosyaları AES-256-GCM şifreli depolamaya taşır.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="OnizlemeYukleAsync" disabled="@calisıyor">
            <i class="bi bi-search me-1"></i>Tara
        </button>
    </div>

    @if (ozet == null && !calisıyor)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Bekleyen dosyaları görmek için <strong>Tara</strong> düğmesine tıklayın.
        </div>
    }

    @if (ozet != null)
    {
        <div class="row mb-4">
            <div class="col-md-2">
                <div class="card border-warning">
                    <div class="card-body text-center">
                        <div class="fs-2 fw-bold text-warning">@ozet.EbysAnaCount</div>
                        <div class="text-muted small">EBYS Dosya</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-warning">
                    <div class="card-body text-center">
                        <div class="fs-2 fw-bold text-warning">@ozet.EbysVersiyonCount</div>
                        <div class="text-muted small">EBYS Versiyon</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-info">
                    <div class="card-body text-center">
                        <div class="fs-2 fw-bold text-info">@ozet.AracEvrakCount</div>
                        <div class="text-muted small">Araç Dosya</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-info">
                    <div class="card-body text-center">
                        <div class="fs-2 fw-bold text-info">@ozet.AracVersiyonCount</div>
                        <div class="text-muted small">Araç Versiyon</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card border-primary">
                    <div class="card-body text-center">
                        <div class="fs-2 fw-bold text-primary">@ozet.Toplam</div>
                        <div class="text-muted small">Toplam Bekleyen</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 d-flex align-items-center">
                @if (ozet.Toplam == 0)
                {
                    <div class="alert alert-success mb-0 w-100">
                        <i class="bi bi-check-circle me-1"></i>Tüm dosyalar şifreli!
                    </div>
                }
                else
                {
                    <button class="btn btn-danger w-100" @onclick="MigrasyonBaslatAsync" disabled="@calisıyor">
                        <i class="bi bi-play-fill me-1"></i>Migrasyonu Başlat
                    </button>
                }
            </div>
        </div>
    }

    @if (calisıyor)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span><i class="bi bi-hourglass-split me-1"></i>Migrasyon çalışıyor...</span>
                    <span class="text-muted">@tamamlanan / @toplamAdim</span>
                </div>
                <div class="progress" style="height:8px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         style="width: @(toplamAdim > 0 ? (tamamlanan * 100 / toplamAdim) : 0)%"></div>
                </div>
            </div>
        </div>
    }

    @if (adimlar.Count > 0)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">Sonuçlar</h6>
            <div>
                <span class="badge bg-success me-1">@adimlar.Count(a => a.Durum == MigrasyonDurum.Basarili) başarılı</span>
                <span class="badge bg-secondary me-1">@adimlar.Count(a => a.Durum == MigrasyonDurum.Atildi) atlandı</span>
                <span class="badge bg-danger">@adimlar.Count(a => a.Durum == MigrasyonDurum.Hata) hata</span>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Dosya</th>
                        <th>Eski Yol</th>
                        <th>Durum</th>
                        <th>Mesaj</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in adimlar.AsEnumerable().Reverse())
                    {
                        <tr>
                            <td class="text-truncate" style="max-width:150px;" title="@a.DosyaAdi">@a.DosyaAdi</td>
                            <td class="text-truncate text-muted small" style="max-width:200px;" title="@a.EskiYol">@a.EskiYol</td>
                            <td>
                                @switch (a.Durum)
                                {
                                    case MigrasyonDurum.Basarili:
                                        <span class="badge bg-success"><i class="bi bi-check"></i> Taşındı</span>
                                        break;
                                    case MigrasyonDurum.Atildi:
                                        <span class="badge bg-secondary"><i class="bi bi-skip-forward"></i> Atlandı</span>
                                        break;
                                    case MigrasyonDurum.Hata:
                                        <span class="badge bg-danger"><i class="bi bi-x"></i> Hata</span>
                                        break;
                                }
                            </td>
                            <td class="small text-muted">@a.Mesaj</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private DosyaMigrasyonOzet? ozet;
    private List<DosyaMigrasyonAdim> adimlar = new();
    private bool calisıyor;
    private int tamamlanan;
    private int toplamAdim;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await OnizlemeYukleAsync();
    }

    private async Task OnizlemeYukleAsync()
    {
        calisıyor = true;
        try
        {
            ozet = await MigrasyonService.OnizlemeAsync();
        }
        finally
        {
            calisıyor = false;
        }
    }

    private async Task MigrasyonBaslatAsync()
    {
        if (calisıyor) return;
        adimlar.Clear();
        tamamlanan = 0;
        toplamAdim = ozet?.Toplam ?? 0;
        calisıyor = true;
        _cts = new CancellationTokenSource();

        try
        {
            await foreach (var adim in MigrasyonService.MigrateAsync(_cts.Token))
            {
                adimlar.Add(adim);
                tamamlanan++;
                StateHasChanged();
                await Task.Delay(10); // UI'ın nefes alması için
            }

            var basarili = adimlar.Count(a => a.Durum == MigrasyonDurum.Basarili);
            var hata = adimlar.Count(a => a.Durum == MigrasyonDurum.Hata);

            if (hata == 0)
                ToastService.ShowSuccess($"Migrasyon tamamlandı: {basarili} dosya şifrelendi.");
            else
                ToastService.ShowWarning($"Tamamlandı: {basarili} başarılı, {hata} hata.");

            ozet = await MigrasyonService.OnizlemeAsync();
        }
        catch (OperationCanceledException)
        {
            ToastService.ShowInfo("Migrasyon iptal edildi.");
        }
        finally
        {
            calisıyor = false;
        }
    }

    public void Dispose() => _cts?.Cancel();
}
