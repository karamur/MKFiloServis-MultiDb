@page "/ayarlar/lisans"
@layout KOAFiloServis.Web.Components.Layout.EmptyLayout
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject LicenseService LicenseService
@inject IKullaniciService KullaniciService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Lisans Bilgileri</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-key me-2"></i>Lisans Aktivasyonu</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert @statusClass mb-3">
                            <i class="bi @statusIcon me-2"></i>@statusMessage
                        </div>
                    }

                    @if (lisans != null)
                    {
                        var gecerli = !LicenseService.IsDemoExpired(lisans) && DateTime.UtcNow <= lisans.ExpireDate;
                        var kalanGun = LicenseService.GetRemainingDays(lisans);
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h6 class="text-muted">Mevcut Lisans</h6>
                                        <h5 class="@(gecerli ? "text-success" : "text-danger")">
                                            @(gecerli ? "Aktif" : "Geçersiz")
                                        </h5>
                                        <small>Bitiş: @lisans.ExpireDate.ToString("dd.MM.yyyy")</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h6 class="text-muted">Kalan Gün</h6>
                                        <h5 class="@(kalanGun > 7 ? "text-success" : "text-danger")">
                                            @kalanGun gün
                                        </h5>
                                        <small>Lisans Tipi: @(lisans.IsDemo ? "Demo" : "Aktif")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <label class="form-label fw-bold">Makine Kodu</label>
                        <div class="input-group">
                            <input type="text" class="form-control font-monospace" value="@makineKodu" readonly />
                            <button type="button" class="btn btn-outline-secondary" @onclick="MakineKoduKopyala">
                                <i class="bi bi-clipboard"></i> Kopyala
                            </button>
                        </div>
                        <small class="text-muted">Bu kodu lisans almak için yetkili kişiye gönderin</small>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Yeni Lisans Anahtarı</label>
                        <textarea class="form-control font-monospace"
                                  @bind="lisansAnahtari"
                                  rows="4"
                                  placeholder="Lisans anahtarını buraya yapıştırın..."></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-success btn-lg"
                                @onclick="LisansAktiveEt"
                                disabled="@isActivating">
                            @if (isActivating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Aktive Ediliyor...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-2"></i>
                                <span>Lisansı Aktive Et</span>
                            }
                        </button>

                        <a href="/" class="btn btn-outline-primary">
                            <i class="bi bi-house me-2"></i>Ana Sayfaya Dön
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LicenseInfo? lisans;
    private string makineKodu = "";
    private string lisansAnahtari = "";
    private bool isActivating = false;
    private string? statusMessage;
    private string statusClass = "alert-info";
    private string statusIcon = "bi-info-circle";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            lisans = await LicenseService.GetCurrentLicenseAsync();
            makineKodu = LicenseService.GetMachineId();
        }
        catch (Exception ex)
        {
            statusMessage = $"Hata: {ex.Message}";
            statusClass = "alert-danger";
            statusIcon = "bi-exclamation-circle";
        }
    }

    private async Task LisansAktiveEt()
    {
        if (string.IsNullOrWhiteSpace(lisansAnahtari))
        {
            statusMessage = "Lütfen lisans anahtarını girin!";
            statusClass = "alert-warning";
            statusIcon = "bi-exclamation-triangle";
            return;
        }

        isActivating = true;
        statusMessage = "Lisans aktive ediliyor...";
        statusClass = "alert-info";
        statusIcon = "bi-hourglass-split";
        StateHasChanged();

        try
        {
            var temizLisans = lisansAnahtari.Trim();
            lisans = await LicenseService.ActivateLicenseKeyAsync(temizLisans);

            statusMessage = "Lisans başarıyla aktive edildi! Ana sayfaya yönlendiriliyorsunuz...";
            statusClass = "alert-success";
            statusIcon = "bi-check-circle";
            lisansAnahtari = "";
            StateHasChanged();

            // 2 saniye bekle ve ana sayfaya yönlendir
            await Task.Delay(2000);
            Navigation.NavigateTo("/", true);
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            statusClass = "alert-danger";
            statusIcon = "bi-exclamation-circle";
        }
        finally
        {
            isActivating = false;
            StateHasChanged();
        }
    }

    private async Task MakineKoduKopyala()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", makineKodu);
            statusMessage = "Makine kodu panoya kopyalandı!";
            statusClass = "alert-success";
            statusIcon = "bi-check-circle";
        }
        catch
        {
            statusMessage = $"Makine Kodu: {makineKodu}";
            statusClass = "alert-info";
            statusIcon = "bi-info-circle";
        }
        StateHasChanged();
    }
}
