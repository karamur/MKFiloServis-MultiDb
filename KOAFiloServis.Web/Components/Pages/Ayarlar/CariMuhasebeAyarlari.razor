    /// <summary>Girilen hesap koduna karşılık gelen hesap adını döndürür. Bulunamazsa null.</summary>
    private string? GetHesapAdi(string? kod)
    {
        if (string.IsNullOrWhiteSpace(kod) || !muhasebeHesaplar.Any()) return null;
        var hesap = muhasebeHesaplar.FirstOrDefault(h =>
            h.HesapKodu.Equals(kod.Trim(), StringComparison.OrdinalIgnoreCase));
        return hesap?.HesapAdi;
    }
