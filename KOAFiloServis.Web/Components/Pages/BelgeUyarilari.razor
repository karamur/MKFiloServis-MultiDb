                                        <td class="text-center p-1">@BelgeHucre(item, "Kimlik", item.KimlikGecerlilik)</td>
                                        <td class="text-center p-1">@BelgeHucre(item, "MykBelgesi", item.MykBelgesiGecerlilik)</td>
                                        <td class="text-center p-1">@BelgeBoolHucre(item, "SrcBelgesi", item.SrcBelgesiVarMi)</td>
