        if (!seciliDosyalar.Any()) { ToastService.ShowWarning("Lütfen belge seçin."); return; }
        try
        {
            var seciliYollar = seciliDosyalar.Select(d => d.DosyaYolu!).ToList();
            var zipBytes = await BelgeUyariService.SeciliPersonelBelgelerZipAsync(
                new List<int> { ozlukModalItem.SoforId }, seciliYollar);
            if (zipBytes.Length == 0) { ToastService.ShowWarning("İndirilebilecek belge bulunamadı."); return; }
            var dosyaAdi = seciliDosyalar.Count == 1
                ? (seciliDosyalar[0].DosyaAdi ?? $"{seciliDosyalar[0].EvrakAdi}{GercekUzantiAl(seciliDosyalar[0].DosyaYolu)}") 
                : $"{ozlukModalItem.PersonelKodu}_Belgeler_{DateTime.Now:yyyyMMdd_HHmm}.zip";
            var contentType = seciliDosyalar.Count == 1
                ? MimeTipiAl(GercekUzantiAl(seciliDosyalar[0].DosyaYolu))
                : "application/zip";
            await JS.InvokeVoidAsync("downloadFile", dosyaAdi, Convert.ToBase64String(zipBytes), contentType);
            ToastService.ShowSuccess($"{seciliDosyalar.Count} belge indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"İndirme hatası: {ex.Message}");
        }
    }

    private async Task OzlukSeciliBelgeleriYazdir()
    {
        if (ozlukModalItem == null) return;
        var seciliDosyalar = ozlukModalItem.EvrakDosyalari
            .Where(d => d.Secili && d.DosyaVar)
            .ToList();

        if (!seciliDosyalar.Any())
        {
            ToastService.ShowWarning("Lütfen yazdırmak istediğiniz belgeleri seçin.");
            return;
        }

        try
        {
            var items = new List<object>();
            foreach (var dosya in seciliDosyalar)
            {
                if (string.IsNullOrEmpty(dosya.DosyaYolu)) continue;
                var bytes = await SecureFileService.ReadDecryptedAsync(dosya.DosyaYolu);
                if (bytes == null || bytes.Length == 0) continue;

                var uzanti = GercekUzantiAl(dosya.DosyaYolu);
                var mime = MimeTipiAl(uzanti);
                var ad = !string.IsNullOrWhiteSpace(dosya.DosyaAdi)
                    ? dosya.DosyaAdi!
                    : $"{dosya.EvrakAdi}{uzanti}";

                items.Add(new
                {
                    name = ad,
                    base64 = Convert.ToBase64String(bytes),
                    mime = mime
                });
            }

            if (items.Count == 0)
            {
                ToastService.ShowWarning("Yazdırılabilecek belge bulunamadı.");
                return;
            }

            await JS.InvokeVoidAsync("printDocumentFiles", items);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Belge yazdırma hatası SoforId={SoforId}", ozlukModalItem.SoforId);
            ToastService.ShowError($"Yazdırma hatası: {ex.Message}");
        }
    }
