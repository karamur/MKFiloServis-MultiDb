    private List<AracBelgeTabloKalemi> FiltrelenmisAracBelgeTablosu => (aracBelgeTablosu ?? new())
        .Where(p => p.SahiplikTipi != AracSahiplikTipi.Tedarikci)
        .Where(p => string.IsNullOrWhiteSpace(aracTabloArama)
            || (p.Plaka ?? string.Empty).Contains(aracTabloArama, StringComparison.OrdinalIgnoreCase)
            || (p.SaseNo ?? string.Empty).Contains(aracTabloArama, StringComparison.OrdinalIgnoreCase)
            || (p.MarkaModel ?? string.Empty).Contains(aracTabloArama, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrWhiteSpace(aracTabloTipFiltre) || p.AracTipi.ToString() == aracTabloTipFiltre)
        .Where(p => aracTabloAktifFiltre switch
        {
            "aktif" => p.Aktif,
            "pasif" => !p.Aktif,
            _ => true
        })
        .Where(p => aracTabloBelgeFiltre switch
        {
            "eksik" => GetEksikAracBelgeSayisi(p) > 0,
            "gecmis" => GetTumAracBelgeTarihleri(p).Any(t => t < DateTime.Today),
            "yaklasan" => GetTumAracBelgeTarihleri(p).Any(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30),
            _ => true
        })
        .ToList();

