@page "/belge-uyarilari"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Shared.Entities
@using System.IO
@inject IBelgeUyariService BelgeUyariService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject ISecureFileService SecureFileService
@inject IPersonelOzlukService OzlukService
@inject IExcelService ExcelService
@inject IPdfService PdfService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject ILogger<KOAFiloServis.Web.Components.Pages.BelgeUyarilari> Logger

<PageTitle>Belge Sure Uyarilari</PageTitle>

<style>
    .ozet-kart { transition: transform .12s ease, box-shadow .12s ease; }
    .ozet-kart:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15); }
    .ozet-kart-aktif { outline: 3px solid #212529; outline-offset: -3px; box-shadow: 0 .5rem 1rem rgba(0,0,0,.25) !important; }
</style>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-file-earmark-medical me-2"></i>Belge Süre Uyarıları</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 180px;" @bind="gunFiltre" @bind:after="YenileAsync">
                <option value="7">7 Gün İçinde</option>
                <option value="15">15 Gün İçinde</option>
                <option value="30">30 Gün İçinde</option>
                <option value="60">60 Gün İçinde</option>
                <option value="90">90 Gün İçinde</option>
            </select>
            <button type="button" class="btn btn-danger" @onclick="PdfExport" disabled="@(uyarilar == null || !FiltrelenmisTumUyarilar.Any())">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
            <button type="button" class="btn btn-success" @onclick="ExcelExport" disabled="@(uyarilar == null || !FiltrelenmisTumUyarilar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    <!-- Sekme Navigasyonu -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button type="button" class="nav-link @(aktifSekme == "uyarilar" ? "active" : "")" @onclick='() => aktifSekme = "uyarilar"'>
                <i class="bi bi-exclamation-triangle me-1"></i>Süre Uyarıları
                @if (uyarilar != null && uyarilar.TumUyarilar.Any())
                {
                    <span class="badge bg-danger ms-1">@uyarilar.TumUyarilar.Count(u => u.Seviye == BelgeUyariSeviye.Kritik)</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(aktifSekme == "tablo" ? "active" : "")" @onclick="SekmeTabloAc" @onclick:preventDefault="true">
                <i class="bi bi-table me-1"></i>Personel Belge Tablosu
                @if (belgeTablosu != null)
                {
                    <span class="badge bg-secondary ms-1">@belgeTablosu.Count</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(aktifSekme == "aractablo" ? "active" : "")" @onclick="SekmeAracTabloAc" @onclick:preventDefault="true">
                <i class="bi bi-truck me-1"></i>Araç Belge Tablosu
                @if (aracBelgeTablosu != null)
                {
                    <span class="badge bg-secondary ms-1">@aracBelgeTablosu.Count(x => x.SahiplikTipi != AracSahiplikTipi.Tedarikci)</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(aktifSekme == "tedarikci" ? "active" : "")" @onclick="SekmeTedarikciTabloAc" @onclick:preventDefault="true">
                <i class="bi bi-building me-1"></i>Tedarikçi Belgeleri
                @if (tedarikciEvrakTablosu != null)
                {
                    <span class="badge bg-secondary ms-1">@tedarikciEvrakTablosu.Count</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(aktifSekme == "tedarikci-personel" ? "active" : "")" @onclick="SekmeTedarikciPersonelTabloAc" @onclick:preventDefault="true">
                <i class="bi bi-person-badge me-1"></i>Ted. Personeli
                @if (belgeTablosu != null)
                {
                    <span class="badge bg-secondary ms-1">@belgeTablosu.Count(x => x.TasimaTedarikciId.HasValue)</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(aktifSekme == "tedarikci-arac" ? "active" : "")" @onclick="SekmeTedarikciAracTabloAc" @onclick:preventDefault="true">
                <i class="bi bi-truck me-1"></i>Ted. Araçları
                @if (aracBelgeTablosu != null)
                {
                    <span class="badge bg-secondary ms-1">@aracBelgeTablosu.Count(x => x.SahiplikTipi == AracSahiplikTipi.Tedarikci)</span>
                }
            </button>
        </li>
    </ul>

    <!-- Süre Uyarıları Sekmesi -->
    @if (aktifSekme == "uyarilar")
    {
    <div class="card mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Kaynak</label>
                    <select class="form-select form-select-sm" @bind="kaynakFiltre">
                        <option value="Tumu">Tümü</option>
                        <option value="Personel">Personel</option>
                        <option value="Araç">Araç</option>
                        <option value="Tedarikçi">Tedarikçi</option>
                        <option value="Kiralık Plaka">Kiralık C Plaka</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="tedarikciFiltre">
                        <option value="">Tümü</option>
                        <option value="-1">Sadece kendi kaynağımız</option>
                        @foreach (var unvan in TedarikciUnvanlari)
                        {
                            <option value="@unvan">@unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Seviye</label>
                    <select class="form-select form-select-sm" @bind="seviyeFiltre">
                        <option value="Tumu">Tümü</option>
                        <option value="Kritik">Süresi Geçmiş</option>
                        <option value="Acil">7 Gün İçinde</option>
                        <option value="Uyari">Yaklaşan</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="aramaMetni" @bind:event="oninput" placeholder="Belge türü, personel veya plaka ara..." />
                </div>
                <div class="col-md-12 text-end">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="FiltreleriTemizle" disabled="@(!FiltreVarMi)">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Filtreleri Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (uyarilar != null)
    {
        <!-- Ozet Kartlari (tıklanabilir - alttaki Tüm Uyarilar listesini filtreler) -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-danger text-white h-100 ozet-kart @(seviyeFiltre == "Kritik" ? "ozet-kart-aktif" : "")"
                     style="cursor: pointer;" @onclick='() => OzetKartaTikla("Kritik")' title="Tıklayın: Süresi geçmiş kayıtları filtreler">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@OzetSayim(BelgeUyariSeviye.Kritik)</h1>
                        <small>Suresi Gecmis</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100 ozet-kart @(seviyeFiltre == "Acil" ? "ozet-kart-aktif" : "")"
                     style="cursor: pointer;" @onclick='() => OzetKartaTikla("Acil")' title="Tıklayın: 7 gün içindeki kayıtları filtreler">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@OzetSayim(BelgeUyariSeviye.Acil)</h1>
                        <small>7 Gun Icinde</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white h-100 ozet-kart @(seviyeFiltre == "Uyari" ? "ozet-kart-aktif" : "")"
                     style="cursor: pointer;" @onclick='() => OzetKartaTikla("Uyari")' title="Tıklayın: 30 gün içindeki kayıtları filtreler">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@OzetSayim(BelgeUyariSeviye.Uyari)</h1>
                        <small>30 Gun Icinde</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100 ozet-kart @(seviyeFiltre == "Tumu" ? "ozet-kart-aktif" : "")"
                     style="cursor: pointer;" @onclick='() => OzetKartaTikla("Tumu")' title="Tıklayın: Tüm uyarıları gösterir">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@OzetSayim(null)</h1>
                        <small>Toplam Uyari</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Arac Belgeleri (öne alındı) -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="bi bi-truck me-2"></i>Arac Belgeleri</h6>
                    </div>
                    <div class="card-body p-0">
                        @if (FiltrelenmisAracUyarilari.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Plaka</th>
                                            <th>Belge</th>
                                            <th>Bitis</th>
                                            <th class="text-center">Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var u in FiltrelenmisAracUyarilari)
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@u.DetayUrl" class="text-decoration-none">
                                                        <strong>@u.Baslik</strong>
                                                    </a>
                                                </td>
                                                <td>@u.BelgeTuru</td>
                                                <td>@u.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                                <td class="text-center">
                                                    <span class="badge @u.SeviyeClass">
                                                        @if (u.KalanGun < 0)
                                                        {
                                                            @(Math.Abs(u.KalanGun) + " gun gecti")
                                                        }
                                                        else
                                                        {
                                                            @(u.KalanGun + " gun")
                                                        }
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-success py-4">
                                <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-2">Arac belgeleri guncel!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Personel Belgeleri -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0"><i class="bi bi-person-badge me-2"></i>Personel Belgeleri</h6>
                    </div>
                    <div class="card-body p-0">
                        @if (FiltrelenmisPersonelUyarilari.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Personel</th>
                                            <th>Belge</th>
                                            <th>Bitis</th>
                                            <th class="text-center">Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var u in FiltrelenmisPersonelUyarilari)
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@u.DetayUrl" class="text-decoration-none">
                                                        <strong>@u.Baslik</strong>
                                                    </a>
                                                </td>
                                                <td>@u.BelgeTuru</td>
                                                <td>@u.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                                <td class="text-center">
                                                    <span class="badge @u.SeviyeClass">
                                                        @if (u.KalanGun < 0)
                                                        {
                                                            @(Math.Abs(u.KalanGun) + " gun gecti")
                                                        }
                                                        else
                                                        {
                                                            @(u.KalanGun + " gun")
                                                        }
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-success py-4">
                                <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-2">Personel belgeleri guncel!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Tum Uyarilar</h6>
                <span class="badge bg-dark">@FiltrelenmisTumUyarilar.Count kayıt</span>
            </div>
            <div class="card-body p-0">
                @if (FiltrelenmisTumUyarilar.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Kaynak</th>
                                    <th>Belge Türü</th>
                                    <th>Ad / Plaka</th>
                                    <th>Tedarikçi</th>
                                    <th>Bitiş</th>
                                    <th class="text-center">Durum</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var uyari in FiltrelenmisTumUyarilar)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @(uyari.Kaynak == "Personel" ? "bg-primary" : "bg-success")">@uyari.Kaynak</span>
                                        </td>
                                        <td>@uyari.BelgeTuru</td>
                                        <td><strong>@uyari.Baslik</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(uyari.TasimaTedarikciUnvan))
                                            {
                                                <span class="badge bg-info text-dark" title="Alt yüklenici">@uyari.TasimaTedarikciUnvan</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Kendi kaynağımız</span>
                                            }
                                        </td>
                                        <td>@uyari.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                        <td class="text-center">
                                            <span class="badge @uyari.SeviyeClass">
                                                @(uyari.KalanGun < 0 ? $"{Math.Abs(uyari.KalanGun)} gün geçti" : $"{uyari.KalanGun} gün")
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-outline-primary" href="@uyari.DetayUrl">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">Filtreye uygun uyarı bulunamadı.</div>
                }
            </div>
        </div>

        <!-- Belge Turu Bazinda Ozet -->
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Belge Turu Ozeti</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.EhliyetUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-card-text" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.EhliyetUyarilari.Count</h4>
                            <small class="text-muted">Ehliyet</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.MykBelgesiUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-file-earmark-check" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.MykBelgesiUyarilari.Count</h4>
                            <small class="text-muted">MYK Belgesi</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.PsikoteknikUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-clipboard2-pulse" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.PsikoteknikUyarilari.Count</h4>
                            <small class="text-muted">Psikoteknik</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.MuayeneUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-wrench-adjustable" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.MuayeneUyarilari.Count</h4>
                            <small class="text-muted">Muayene</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.KaskoUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-shield-check" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.KaskoUyarilari.Count</h4>
                            <small class="text-muted">Kasko</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.TrafikSigortasiUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-shield-exclamation" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.TrafikSigortasiUyarilari.Count</h4>
                            <small class="text-muted">Trafik Sigortasi</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.DigerAracEvrakUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-folder2-open" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.DigerAracEvrakUyarilari.Count</h4>
                            <small class="text-muted">Diger Evraklar</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.TedarikciSozlesmeUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-file-earmark-medical" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.TedarikciSozlesmeUyarilari.Count</h4>
                            <small class="text-muted">Tedarikçi Sözleşme</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.KiralikPlakaUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-card-text" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.KiralikPlakaUyarilari.Count</h4>
                            <small class="text-muted">Kiralık C Plaka</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    } @* /uyarilar sekmesi *@

    <!-- Personel Belge Tablosu Sekmesi -->
    @if (aktifSekme == "tablo")
    {
        <!-- Filtreler -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Personel Ara</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Ad, soyad veya kod..."
                               @bind="tabloArama" @bind:event="oninput" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Görev</label>
                        <select class="form-select form-select-sm" @bind="tabloGorevFiltre">
                            <option value="">Tümü</option>
                            @foreach (PersonelGorev g in Enum.GetValues(typeof(PersonelGorev)))
                            {
                                <option value="@g">@GetGorevAdi(g)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Durum</label>
                        <select class="form-select form-select-sm" @bind="tabloAktifFiltre">
                            <option value="">Tümü</option>
                            <option value="aktif">Aktif</option>
                            <option value="pasif">Pasif</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Belge Filtresi</label>
                        <select class="form-select form-select-sm" @bind="tabloBelgeFiltre">
                            <option value="">Tümü</option>
                            <option value="eksik">Tarihi Girilmemiş</option>
                            <option value="gecmis">Süresi Geçmiş</option>
                            <option value="yaklasan">30 Gün İçinde</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-1 align-items-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="TabloFiltreleriniTemizle">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-success" @onclick="TabloExcelAktar" disabled="@(FiltrelenmisBelgeTablosu.Count == 0)">
                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="TabloYazdir" disabled="@(FiltrelenmisBelgeTablosu.Count == 0)">
                            <i class="bi bi-printer me-1"></i>Yazdır
                        </button>
                        <button type="button" class="btn btn-sm btn-success" @onclick="SeciliPersonellerinBelgeleriniIndir"
                                disabled="@(belgeTablosu == null || !belgeTablosu.Any(x => x.Secili))">
                            <i class="bi bi-download me-1"></i>Seçilenleri İndir
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Özet Kartlar -->
        @if (belgeTablosu != null)
        {
            <div class="row mb-3 g-2">
                <div class="col">
                    <div class="card border-danger text-center py-2">
                        <div class="fw-bold text-danger fs-4">@belgeTablosu.SelectMany(GetTumBelgeTarihleri).Count(t => t < DateTime.Today)</div>
                        <small class="text-muted">Süresi Geçmiş</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-warning text-center py-2">
                        <div class="fw-bold text-warning fs-4">@belgeTablosu.SelectMany(GetTumBelgeTarihleri).Count(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30)</div>
                        <small class="text-muted">30 Gün İçinde</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-secondary text-center py-2">
                        <div class="fw-bold text-secondary fs-4">@belgeTablosu.Sum(p => GetEksikBelgeSayisi(p))</div>
                        <small class="text-muted">Tarihi Girilmemiş</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-primary text-center py-2">
                        <div class="fw-bold text-primary fs-4">@belgeTablosu.Count</div>
                        <small class="text-muted">Toplam Personel</small>
                    </div>
                </div>
            </div>
        }

        @if (isTabloyukleniyor)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (belgeTablosu != null)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span>
                        <i class="bi bi-table me-1"></i>
                        Personel Belge Takip Tablosu
                        <span class="badge bg-secondary ms-1">@FiltrelenmisBelgeTablosu.Count kayıt</span>
                    </span>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="small text-muted">
                            @belgeTablosu.Count(x => x.Secili) personel seçildi
                        </span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="TumunuSecToggle">
                            <i class="bi bi-check-all me-1"></i>@(belgeTablosu.All(x => x.Secili) ? "Seçimi Kaldır" : "Tümünü Seç")
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover mb-0 align-middle" id="belgeTablosu" style="font-size:0.82rem;">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th style="width:36px;" class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@(FiltrelenmisBelgeTablosu.Any() && FiltrelenmisBelgeTablosu.All(x => x.Secili))"
                                               @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th class="text-center" style="width:40px;">Görev</th>
                                    <th class="text-center bg-primary bg-opacity-25" style="width:90px;" title="Ehliyet Geçerlilik">Ehliyet</th>
                                    <th class="text-center bg-info bg-opacity-25" style="width:90px;" title="Kimlik Geçerlilik">Kimlik</th>
                                    <th class="text-center bg-success bg-opacity-25" style="width:90px;" title="MYK Belgesi">MYK</th>
                                    <th class="text-center bg-light" style="width:90px;" title="SRC Belgesi">SRC</th>
                                    <th class="text-center bg-light" style="width:90px;" title="Yaygın Eğitim Sertifikası">Yaygın Eğt.</th>
                                    <th class="text-center bg-warning bg-opacity-25" style="width:90px;" title="Psikoteknik">Psikoteknik</th>
                                    <th class="text-center bg-danger bg-opacity-25" style="width:90px;" title="Adli Sicil">Adli Sicil</th>
                                    <th class="text-center bg-secondary bg-opacity-25" style="width:90px;" title="Sağlık Raporu">Sağlık</th>
                                    <th class="text-center" style="width:90px;" title="Sürücü Ceza Barkodlu Belge">Ceza Barkod</th>
                                    <th class="text-center" style="width:60px;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in FiltrelenmisBelgeTablosu)
                                {
                                    <tr class="@(!item.Aktif ? "table-secondary opacity-75" : "")">
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@item.Secili"
                                                   @onchange="(e) => item.Secili = (bool)(e.Value ?? false)" />
                                        </td>
                                        <td>
                                            <strong>@item.PersonelAdi</strong>
                                            <br /><small class="text-muted">@item.PersonelKodu</small>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @GetGorevBadgeClass(item.Gorev)" style="font-size:0.7rem;">@GetGorevAdi(item.Gorev)</span>
                                        </td>
                                        <!-- Ehliyet -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "Ehliyet", item.EhliyetGecerlilik)
                                        </td>
                                        <!-- Kimlik -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "Kimlik", item.KimlikGecerlilik)
                                        </td>
                                        <!-- MYK -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "MykBelgesi", item.MykBelgesiGecerlilik)
                                        </td>
                                        <!-- SRC -->
                                        <td class="text-center p-1">
                                            @BelgeBoolHucre(item, "SrcBelgesi", item.SrcBelgesiVarMi)
                                        </td>
                                        <!-- Yaygın Eğitim Sertifikası -->
                                        <td class="text-center p-1">
                                            @BelgeBoolHucre(item, "YayginEgitim", item.YayginEgitimSertifikasiVarMi || item.YayginEgitimGecerlilik.HasValue)
                                        </td>
                                        <!-- Psikoteknik -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "Psikoteknik", item.PsikoteknikGecerlilik)
                                        </td>
                                        <!-- Adli Sicil -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "AdliSicil", item.AdliSicilGecerlilik)
                                        </td>
                                        <!-- Sağlık Raporu -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "SaglikRaporu", item.SaglikRaporuGecerlilik)
                                        </td>
                                        <!-- Sürücü Ceza Barkod -->
                                        <td class="text-center p-1">
                                            @BelgeHucre(item, "SuruculCezaBarkod", item.SuruculCezaBarkodGecerlilik)
                                        </td>
                                        <td class="text-center p-1" style="min-width:110px;">
                                            <div class="d-flex flex-column align-items-center gap-1">
                                                <div class="d-flex gap-1">
                                                    <button type="button" class="btn btn-xs btn-outline-info" title="Özlük İşlem — Belgeleri Görüntüle / İndir"
                                                            @onclick="() => OzlukIslemAc(item)" @onclick:preventDefault="true">
                                                        <i class="bi bi-file-earmark-person"></i>
                                                    </button>
                                                    <a class="btn btn-xs btn-outline-secondary" href="/personel/ozluk-evrak?soforId=@item.SoforId" title="Özlük Evrak Sayfası">
                                                        <i class="bi bi-folder2-open"></i>
                                                    </a>
                                                </div>
                                                @if (item.ToplamEvrakSayisi > 0)
                                                {
                                                    <span class="badge @(item.YuklenmisEvrakSayisi == item.ToplamEvrakSayisi ? "bg-success" : item.YuklenmisEvrakSayisi == 0 ? "bg-secondary" : "bg-warning text-dark")" style="font-size:0.65rem;">
                                                        @item.YuklenmisEvrakSayisi/@item.ToplamEvrakSayisi
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    } @* /tablo sekmesi *@

    <!-- Araç Belge Tablosu Sekmesi -->
    @if (aktifSekme == "aractablo")
    {
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Araç Ara</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Plaka, şase, marka/model..."
                               @bind="aracTabloArama" @bind:event="oninput" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Araç Tipi</label>
                        <select class="form-select form-select-sm" @bind="aracTabloTipFiltre">
                            <option value="">Tümü</option>
                            @foreach (AracTipi t in Enum.GetValues(typeof(AracTipi)))
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Durum</label>
                        <select class="form-select form-select-sm" @bind="aracTabloAktifFiltre">
                            <option value="">Tümü</option>
                            <option value="aktif">Aktif</option>
                            <option value="pasif">Pasif</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Belge Filtresi</label>
                        <select class="form-select form-select-sm" @bind="aracTabloBelgeFiltre">
                            <option value="">Tümü</option>
                            <option value="eksik">Tarihi Girilmemiş</option>
                            <option value="gecmis">Süresi Geçmiş</option>
                            <option value="yaklasan">30 Gün İçinde</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-1 align-items-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AracTabloFiltreleriniTemizle">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AracTabloYazdir" disabled="@(FiltrelenmisAracBelgeTablosu.Count == 0)">
                            <i class="bi bi-printer me-1"></i>Yazdır
                        </button>
                        <button type="button" class="btn btn-sm btn-success" @onclick="SeciliAraclarinBelgeleriniIndir"
                                disabled="@(aracBelgeTablosu == null || !aracBelgeTablosu.Any(x => x.Secili))">
                            <i class="bi bi-download me-1"></i>Seçilenleri İndir
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (aracBelgeTablosu != null)
        {
            var ozmalAraclar = aracBelgeTablosu.Where(x => x.SahiplikTipi != AracSahiplikTipi.Tedarikci).ToList();
            <div class="row mb-3 g-2">
                <div class="col">
                    <div class="card border-danger text-center py-2">
                        <div class="fw-bold text-danger fs-4">@ozmalAraclar.SelectMany(GetTumAracBelgeTarihleri).Count(t => t < DateTime.Today)</div>
                        <small class="text-muted">Süresi Geçmiş</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-warning text-center py-2">
                        <div class="fw-bold text-warning fs-4">@ozmalAraclar.SelectMany(GetTumAracBelgeTarihleri).Count(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30)</div>
                        <small class="text-muted">30 Gün İçinde</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-secondary text-center py-2">
                        <div class="fw-bold text-secondary fs-4">@ozmalAraclar.Sum(p => GetEksikAracBelgeSayisi(p))</div>
                        <small class="text-muted">Tarihi Girilmemiş</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-primary text-center py-2">
                        <div class="fw-bold text-primary fs-4">@ozmalAraclar.Count</div>
                        <small class="text-muted">Toplam Araç</small>
                    </div>
                </div>
            </div>
        }

        @if (isAracTabloyukleniyor)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (aracBelgeTablosu != null)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span>
                        <i class="bi bi-truck me-1"></i>
                        Araç Belge Takip Tablosu
                        <span class="badge bg-secondary ms-1">@FiltrelenmisAracBelgeTablosu.Count kayıt</span>
                    </span>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="small text-muted">@aracBelgeTablosu.Count(x => x.Secili) araç seçildi</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AracTumunuSecToggle">
                            <i class="bi bi-check-all me-1"></i>@(aracBelgeTablosu.All(x => x.Secili) ? "Seçimi Kaldır" : "Tümünü Seç")
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover mb-0 align-middle" id="aracBelgeTablosu" style="font-size:0.82rem;">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th style="width:36px;" class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@(FiltrelenmisAracBelgeTablosu.Any() && FiltrelenmisAracBelgeTablosu.All(x => x.Secili))"
                                               @onchange="AracTumunuSecToggle" />
                                    </th>
                                    <th>Araç</th>
                                    <th class="text-center" style="width:90px;">Tip</th>
                                    <th class="text-center bg-light" style="width:90px;" title="Ruhsat">Ruhsat</th>
                                    <th class="text-center bg-info bg-opacity-25" style="width:100px;" title="Trafik Sigortası">Sigorta</th>
                                    <th class="text-center bg-success bg-opacity-25" style="width:100px;" title="Muayene">Muayene</th>
                                    <th class="text-center bg-warning bg-opacity-25" style="width:100px;" title="Uygunluk Belgesi">Uygunluk</th>
                                    <th class="text-center bg-danger bg-opacity-25" style="width:110px;" title="Koltuk Sigortası">Koltuk Sig.</th>
                                    <th class="text-center bg-secondary bg-opacity-25" style="width:100px;" title="Kasko">Kasko</th>
                                    <th class="text-center" style="width:60px;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in FiltrelenmisAracBelgeTablosu)
                                {
                                    <tr class="@(!item.Aktif ? "table-secondary opacity-75" : "")">
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@item.Secili"
                                                   @onchange="(e) => item.Secili = (bool)(e.Value ?? false)" />
                                        </td>
                                        <td>
                                            <strong>@(string.IsNullOrEmpty(item.Plaka) ? item.SaseNo : item.Plaka)</strong>
                                            <br /><small class="text-muted">@item.MarkaModel</small>
                                        </td>
                                        <td class="text-center"><span class="badge bg-dark" style="font-size:0.7rem;">@item.AracTipi</span></td>
                                        <td class="text-center p-1">@AracBelgeBoolHucre(item.RuhsatVarMi)</td>
                                        <td class="text-center p-1">@AracBelgeHucre(item, "Sigorta", item.SigortaGecerlilik)</td>
                                        <td class="text-center p-1">@AracBelgeHucre(item, "Muayene", item.MuayeneGecerlilik)</td>
                                        <td class="text-center p-1">@AracBelgeHucre(item, "Uygunluk", item.UygunlukGecerlilik)</td>
                                        <td class="text-center p-1">@AracBelgeHucre(item, "KoltukSigortasi", item.KoltukSigortasiGecerlilik)</td>
                                        <td class="text-center p-1">@AracBelgeHucre(item, "Kasko", item.KaskoGecerlilik)</td>
                                        <td class="text-center p-1" style="min-width:90px;">
                                            <div class="d-flex flex-column align-items-center gap-1">
                                                <div class="d-flex gap-1">
                                                    <button type="button" class="btn btn-xs btn-outline-info" title="Belgeleri Görüntüle / İndir"
                                                            @onclick="() => AracBelgeIslemAc(item)" @onclick:preventDefault="true">
                                                        <i class="bi bi-file-earmark-text"></i>
                                                    </button>
                                                    <a class="btn btn-xs btn-outline-secondary" href="/araclar/@item.AracId" title="Araç Kartı">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>
                                                </div>
                                                @if (item.ToplamEvrakSayisi > 0)
                                                {
                                                    <span class="badge @(item.YuklenmisEvrakSayisi == item.ToplamEvrakSayisi ? "bg-success" : item.YuklenmisEvrakSayisi == 0 ? "bg-secondary" : "bg-warning text-dark")" style="font-size:0.65rem;">
                                                        @item.YuklenmisEvrakSayisi/@item.ToplamEvrakSayisi
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    } @* /aractablo sekmesi *@

    <!-- Araç Tarih Düzenleme Modal -->
    @if (showAracTarihModal && editAracItem != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title"><i class="bi bi-pencil me-2"></i>@editAracBelgeAdi Tarihi</h6>
                        <button type="button" class="btn-close btn-sm" @onclick="AracModalKapat"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2 small text-muted">@(string.IsNullOrEmpty(editAracItem.Plaka) ? editAracItem.SaseNo : editAracItem.Plaka) – @editAracItem.MarkaModel</p>
                        <label class="form-label small">Geçerlilik Bitiş Tarihi</label>
                        <input type="date" class="form-control form-control-sm"
                               value="@editAracTarih?.ToString("yyyy-MM-dd")"
                               @onchange="(e) => editAracTarih = e.Value != null && DateTime.TryParse(e.Value.ToString(), out var d) ? d : (DateTime?)null" />
                        <div class="mt-2">
                            <button type="button" class="btn btn-sm btn-link text-danger p-0" @onclick="() => editAracTarih = null">
                                <i class="bi bi-x-circle me-1"></i>Tarihi Kaldır
                            </button>
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="AracModalKapat">İptal</button>
                        <button type="button" class="btn btn-sm btn-primary" @onclick="AracTarihKaydet" disabled="@isAracTarihKaydediliyor">
                            @if (isAracTarihKaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Kaydet
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Araç Belge İşlem Modal -->
    @if (showAracBelgeModal && aracBelgeModalItem != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);" @onclick="AracBelgeModalKapat">
            <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">
                            <i class="bi bi-truck me-2 text-success"></i>
                            <strong>@(string.IsNullOrEmpty(aracBelgeModalItem.Plaka) ? aracBelgeModalItem.SaseNo : aracBelgeModalItem.Plaka)</strong>
                            <small class="text-muted ms-2">@aracBelgeModalItem.MarkaModel</small>
                        </h6>
                        <button type="button" class="btn-close btn-sm" @onclick="AracBelgeModalKapat"></button>
                    </div>
                    <div class="modal-body">
                        @{
                            var aracEvraklar = aracBelgeModalItem.EvrakDosyalari;
                            var aracToplam = aracEvraklar.Count;
                            var aracYuklenmis = aracEvraklar.Count(e => e.DosyaVar);
                        }
                        <div class="mb-3 d-flex align-items-center gap-2">
                            <span class="badge bg-primary">@aracYuklenmis / @aracToplam belge yüklü</span>
                            @if (aracEvraklar.Any(e => e.DosyaVar))
                            {
                                <span class="text-muted small">İndirmek istediğiniz belgeleri seçin</span>
                            }
                        </div>
                        @if (!aracEvraklar.Any(e => e.DosyaVar))
                        {
                            <div class="alert alert-warning py-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>Bu araca ait yüklenmiş belge bulunmamaktadır.
                                <a href="/araclar/@aracBelgeModalItem.AracId" class="alert-link ms-1">Belge yüklemek için araç kartını açın.</a>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width:36px;">
                                                <input type="checkbox" class="form-check-input"
                                                       checked="@aracEvraklar.Where(e => e.DosyaVar).All(e => e.Secili)"
                                                       @onchange="AracBelgeModalTumunuSec" />
                                            </th>
                                            <th>Belge</th>
                                            <th style="width:120px;">Dosya</th>
                                            <th style="width:80px;" class="text-center">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var dosya in aracEvraklar)
                                        {
                                            <tr class="@(!dosya.DosyaVar ? "text-muted" : "")">
                                                <td>
                                                    @if (dosya.DosyaVar)
                                                    {
                                                        <input type="checkbox" class="form-check-input"
                                                               checked="@dosya.Secili"
                                                               @onchange="(e) => dosya.Secili = (bool)(e.Value ?? false)" />
                                                    }
                                                </td>
                                                <td>@(string.IsNullOrWhiteSpace(dosya.EvrakAdi) ? dosya.EvrakKategorisi : dosya.EvrakAdi)</td>
                                                <td>
                                                    @if (dosya.DosyaVar)
                                                    {
                                                        <span class="badge bg-success"><i class="bi bi-paperclip me-1"></i>Var</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Yok</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    @if (dosya.DosyaVar)
                                                    {
                                                        <button type="button" class="btn btn-xs btn-outline-primary" title="Önizle"
                                                                @onclick="() => AracBelgeOnizle(dosya)" @onclick:preventDefault="true">
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-xs btn-outline-dark" title="Yazdır"
                                                                @onclick="() => AracBelgeYazdir(dosya)" @onclick:preventDefault="true">
                                                            <i class="bi bi-printer"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-xs btn-outline-secondary" title="İndir"
                                                                @onclick="() => AracTekDosyaIndir(dosya)" @onclick:preventDefault="true">
                                                            <i class="bi bi-download"></i>
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="modal-footer py-2 gap-2">
                        @if (aracBelgeModalItem.EvrakDosyalari.Any(e => e.DosyaVar))
                        {
                            <button type="button" class="btn btn-sm btn-success" @onclick="AracBelgeSecilenleriIndir" @onclick:preventDefault="true"
                                    disabled="@(!aracBelgeModalItem.EvrakDosyalari.Any(e => e.Secili))">
                                <i class="bi bi-download me-1"></i>Seçilenleri İndir
                            </button>
                        }
                        <a class="btn btn-sm btn-outline-info" href="/araclar/@aracBelgeModalItem.AracId">
                            <i class="bi bi-pencil-square me-1"></i>Araç Kartı
                        </a>
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="AracBelgeModalKapat">Kapat</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Araç Belge Önizleme Modal -->
    @if (belgeOnizlemeModalAcik)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.5);">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@belgeOnizlemeBaslik</h5>
                        <button type="button" class="btn-close" @onclick="BelgeOnizlemeKapat"></button>
                    </div>

                    <div class="modal-body" style="min-height: 75vh;">
                        @if (!belgeOnizlemeDestekleniyor)
                        {
                            <div class="alert alert-warning">
                                Bu belge türü için önizleme desteklenmiyor. Dosyayı indirerek açabilirsiniz.
                            </div>
                        }
                        else if (belgeOnizlemeContentType == "application/pdf")
                        {
                            <iframe src="@belgeOnizlemeDataUrl"
                                    style="width:100%; height:75vh; border:0;">
                            </iframe>
                        }
                        else if (belgeOnizlemeContentType?.StartsWith("image/") == true)
                        {
                            <img src="@belgeOnizlemeDataUrl"
                                 style="max-width:100%; height:auto;"
                                 alt="@belgeOnizlemeBaslik" />
                        }
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="BelgeOnizlemeKapat">Kapat</button>
                        <button class="btn btn-outline-primary"
                                @onclick="BelgeOnizlenenDosyayiIndir">
                            <i class="bi bi-download me-1"></i>İndir
                        </button>
                        <button class="btn btn-primary"
                                @onclick="BelgeOnizlenenDosyayiYazdir"
                                disabled="@(!belgeOnizlemeDestekleniyor)">
                            <i class="bi bi-printer me-1"></i>Yazdır
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Tedarikçi Belge Tablosu Sekmesi -->
    @if (aktifSekme == "tedarikci")
    {
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Tedarikçi Ara</label>
                        <input type="text" class="form-control form-control-sm" @bind="tedarikciTabloArama" @bind:event="oninput" placeholder="Tedarikçi unvanı..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Durum</label>
                        <select class="form-select form-select-sm" @bind="tedarikciTabloAktifFiltre">
                            <option value="">Tümü</option>
                            <option value="aktif">Aktif</option>
                            <option value="pasif">Pasif</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Belge Filtresi</label>
                        <select class="form-select form-select-sm" @bind="tedarikciTabloBelgeFiltre">
                            <option value="">Tümü</option>
                            <option value="eksik">Tarihi Girilmemiş</option>
                            <option value="gecmis">Süresi Geçmiş</option>
                            <option value="yaklasan">30 Gün İçinde</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-1 align-items-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="TedarikciTabloFiltreleriniTemizle">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (isTedarikciTabloyukleniyor)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (tedarikciEvrakTablosu != null)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span>
                        <i class="bi bi-building me-1"></i>
                        Tedarikçi Belge Takip Tablosu
                        <span class="badge bg-secondary ms-1">@FiltrelenmisTedarikciEvrakTablosu.Count kayıt</span>
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover mb-0 align-middle" style="font-size:0.82rem;">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th>Tedarikçi</th>
                                    <th class="text-center" style="width:50px;">Durum</th>
                                    @foreach (var kat in TedarikciEvrakKategorileri.TumKategoriler)
                                    {
                                        <th class="text-center" style="width:90px;" title="@kat">@KisaKategoriAdi(kat)</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in FiltrelenmisTedarikciEvrakTablosu)
                                {
                                    <tr class="@(!item.Aktif ? "table-secondary opacity-75" : "")">
                                        <td>
                                            <a href="/personel-tasima/tedarikciler/@item.TedarikciId/evraklar" class="text-decoration-none">
                                                <strong>@item.TedarikciUnvan</strong>
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            @if (item.Aktif)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Pasif</span>
                                            }
                                        </td>
                                        @foreach (var kat in TedarikciEvrakKategorileri.TumKategoriler)
                                        {
                                            var tarih = item.Belgeler.TryGetValue(kat, out var t) ? t : null;
                                            var cls = TedarikciEvrakTabloKalemi.BelgeDurumClass(tarih);
                                            var txt = TedarikciEvrakTabloKalemi.BelgeDurumMetin(tarih);
                                            <td class="text-center p-1">
                                                <a href="/personel-tasima/tedarikciler/@item.TedarikciId/evraklar"
                                                   class="badge @cls text-decoration-none w-100" style="font-size:0.75rem;"
                                                   title="@kat — @txt">@txt</a>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }

