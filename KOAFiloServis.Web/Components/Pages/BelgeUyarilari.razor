        @if (isAracTabloyukleniyor)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (aracBelgeTablosu != null)
        {
            <div class="card">
                <div class="card-header py-2">
                    <span>
                        <i class="bi bi-truck me-1"></i>
                        Tedarikçi Araçlar Belge Tablosu
                        <span class="badge bg-secondary ms-1">@FiltrelenmisTedarikciAracTablosu.Count kayıt</span>
                    </span>
                </div>
