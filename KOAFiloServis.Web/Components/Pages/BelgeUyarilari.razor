    private async Task AracBelgeOnizle(AracEvrakDosyaBilgisi dosya)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(dosya.DosyaYolu))
            {
                ToastService.ShowWarning("Belge dosya yolu bulunamadı.");
                return;
            }

            var bytes = await SecureFileService.ReadDecryptedAsync(dosya.DosyaYolu);
            if (bytes == null || bytes.Length == 0)
            {
                ToastService.ShowWarning("Dosya okunamadı veya boş.");
                return;
            }

            var uzanti = GercekUzantiAl(dosya.DosyaYolu);
            var contentType = MimeTipiAl(uzanti);
            var ad = !string.IsNullOrWhiteSpace(dosya.DosyaAdi)
                ? EncExtensionTemizle(dosya.DosyaAdi)
                : $"{(string.IsNullOrWhiteSpace(dosya.EvrakAdi) ? dosya.EvrakKategorisi : dosya.EvrakAdi)}{uzanti}";

            belgeOnizlemeBaslik = ad;
            belgeOnizlemeDosyaAdi = ad;
            belgeOnizlemeContentType = contentType;
            belgeOnizlemeBase64 = Convert.ToBase64String(bytes);
            belgeOnizlemeDataUrl = $"data:{contentType};base64,{belgeOnizlemeBase64}";

            belgeOnizlemeDestekleniyor =
                contentType == "application/pdf" ||
                contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);

            belgeOnizlemeModalAcik = true;

            Logger.LogInformation(
                "Araç belge önizleniyor. Belge={Belge}, DosyaAdi={DosyaAdi}, ContentType={ContentType}",
                dosya.EvrakAdi ?? dosya.EvrakKategorisi, ad, contentType);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Araç belge önizleme hatası. DosyaYolu={DosyaYolu}, Belge={Belge}",
                dosya.DosyaYolu, dosya.EvrakAdi ?? dosya.EvrakKategorisi);
            ToastService.ShowError("Belge önizlenemedi. Dosya şifresi çözülemedi veya dosya bulunamadı.");
        }
    }

