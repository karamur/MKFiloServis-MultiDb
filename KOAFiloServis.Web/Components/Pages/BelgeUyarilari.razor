    private List<TedarikciEvrakTabloKalemi>? tedarikciEvrakTablosu;
    private bool isTedarikciTabloyukleniyor = false;
    private string tedarikciTabloArama = string.Empty;
    private string tedarikciTabloAktifFiltre = string.Empty;
    private string tedarikciTabloBelgeFiltre = string.Empty;

    // Tedarikçi Personel (belgeTablosu'nun filtreli görünümü)
    private string tedarikciPersonelTedarikciFiltre = string.Empty;
    private string tedarikciPersonelArama = string.Empty;
    private string tedarikciPersonelAktifFiltre = string.Empty;
    private string tedarikciPersonelBelgeFiltre = string.Empty;

    // Tedarikçi Araçlar (aracBelgeTablosu'nun filtreli görünümü)
    private string tedarikciAracTedarikciFiltre = string.Empty;
    private string tedarikciAracArama = string.Empty;
    private string tedarikciAracAktifFiltre = string.Empty;
    private string tedarikciAracBelgeFiltre = string.Empty;

    private List<TedarikciEvrakTabloKalemi> FiltrelenmisTedarikciEvrakTablosu => (tedarikciEvrakTablosu ?? new())
        .Where(p => string.IsNullOrWhiteSpace(tedarikciTabloArama)
            || p.TedarikciUnvan.Contains(tedarikciTabloArama, StringComparison.OrdinalIgnoreCase))
        .Where(p => tedarikciTabloAktifFiltre switch
        {
            "aktif" => p.Aktif,
            "pasif" => !p.Aktif,
            _ => true
        })
        .Where(p => tedarikciTabloBelgeFiltre switch
        {
            "eksik" => p.Belgeler.Values.Any(t => t == null),
            "gecmis" => p.Belgeler.Values.Any(t => t.HasValue && t.Value < DateTime.Today),
            "yaklasan" => p.Belgeler.Values.Any(t => t.HasValue && t.Value >= DateTime.Today && (t.Value - DateTime.Today).Days <= 30),
            _ => true
        })
        .ToList();

    private List<PersonelBelgeTabloKalemi> FiltrelenmisTedarikciPersonelTablosu => (belgeTablosu ?? new())
        .Where(p => p.TasimaTedarikciId.HasValue)
        .Where(p => string.IsNullOrWhiteSpace(tedarikciPersonelTedarikciFiltre)
            || p.TasimaTedarikciId.ToString() == tedarikciPersonelTedarikciFiltre)
        .Where(p => string.IsNullOrWhiteSpace(tedarikciPersonelArama)
            || p.PersonelAdi.Contains(tedarikciPersonelArama, StringComparison.OrdinalIgnoreCase)
            || p.PersonelKodu.Contains(tedarikciPersonelArama, StringComparison.OrdinalIgnoreCase))
        .Where(p => tedarikciPersonelAktifFiltre switch
        {
            "aktif" => p.Aktif,
            "pasif" => !p.Aktif,
            _ => true
        })
        .Where(p => tedarikciPersonelBelgeFiltre switch
        {
            "eksik" => GetEksikBelgeSayisi(p) > 0,
            "gecmis" => GetTumBelgeTarihleri(p).Any(t => t < DateTime.Today),
            "yaklasan" => GetTumBelgeTarihleri(p).Any(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30),
            _ => true
        })
        .ToList();

    private List<AracBelgeTabloKalemi> FiltrelenmisTedarikciAracTablosu => (aracBelgeTablosu ?? new())
        .Where(p => p.SahiplikTipi == AracSahiplikTipi.Tedarikci)
        .Where(p => string.IsNullOrWhiteSpace(tedarikciAracTedarikciFiltre)
            || p.TasimaTedarikciId.ToString() == tedarikciAracTedarikciFiltre)
        .Where(p => string.IsNullOrWhiteSpace(tedarikciAracArama)
            || (p.Plaka ?? string.Empty).Contains(tedarikciAracArama, StringComparison.OrdinalIgnoreCase)
            || (p.SaseNo ?? string.Empty).Contains(tedarikciAracArama, StringComparison.OrdinalIgnoreCase)
            || (p.MarkaModel ?? string.Empty).Contains(tedarikciAracArama, StringComparison.OrdinalIgnoreCase))
        .Where(p => tedarikciAracAktifFiltre switch
        {
            "aktif" => p.Aktif,
            "pasif" => !p.Aktif,
            _ => true
        })
        .Where(p => tedarikciAracBelgeFiltre switch
        {
            "eksik" => GetEksikAracBelgeSayisi(p) > 0,
            "gecmis" => GetTumAracBelgeTarihleri(p).Any(t => t < DateTime.Today),
            "yaklasan" => GetTumAracBelgeTarihleri(p).Any(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30),
            _ => true
        })
        .ToList();

    private async Task SekmeTedarikciTabloAc()
    {
        aktifSekme = "tedarikci";
        if (tedarikciEvrakTablosu != null) return;
        isTedarikciTabloyukleniyor = true;
        StateHasChanged();
        try
        {
            tedarikciEvrakTablosu = await BelgeUyariService.GetTedarikciEvrakTablosuAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "TedarikciEvrakTablosuYukle hatası");
            ToastService.ShowError($"Tedarikçi belge tablosu yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isTedarikciTabloyukleniyor = false;
            StateHasChanged();
        }
    }

