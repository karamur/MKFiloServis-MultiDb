                                    <th class="text-center" style="width:90px;" title="Koltuk Sigortası">Koltuk Sig.</th>
                                    <th class="text-center" style="width:90px;" title="Kasko">Kasko</th>
                                    <th class="text-center" style="width:60px;">İşlem</th>
