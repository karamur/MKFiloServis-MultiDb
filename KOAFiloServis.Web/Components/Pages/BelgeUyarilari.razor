                        <label class="form-label small mb-1">Tedarikçi Filtresi</label>
                        <select class="form-select form-select-sm" @bind="tedarikciAracTedarikciFiltre">
                            <option value="">Tümü</option>
                            @foreach (var td in tedarikciler)
                            {
                                <option value="@td.Id">@td.Unvan</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Araç Ara</label>
                        <input type="text" class="form-control form-control-sm" @bind="tedarikciAracArama" @bind:event="oninput" placeholder="Plaka, şase, marka/model..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Durum</label>
                        <select class="form-select form-select-sm" @bind="tedarikciAracAktifFiltre">
                            <option value="">Tümü</option>
                            <option value="aktif">Aktif</option>
                            <option value="pasif">Pasif</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Belge Filtresi</label>
                        <select class="form-select form-select-sm" @bind="tedarikciAracBelgeFiltre">
                            <option value="">Tümü</option>
                            <option value="eksik">Tarihi Girilmemiş</option>
                            <option value="gecmis">Süresi Geçmiş</option>
                            <option value="yaklasan">30 Gün İçinde</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-1 align-items-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="TedarikciAracFiltreleriniTemizle">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
            </div>
