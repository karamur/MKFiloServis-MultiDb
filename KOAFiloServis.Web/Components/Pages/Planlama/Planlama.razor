@page "/planlama"
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IKurumPuantajService KurumPuantajService
@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject ILogger<Planlama> Logger

<PageTitle>Planlama</PageTitle>

@if (yukleniyor)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-1"><i class="bi bi-calendar-check me-2"></i>Operasyon Planlama</h4>
                <p class="text-muted small mb-0">Gunluk sefer planlamasi - coklu slot (Sabah / Aksam / Mesai)</p>
            </div>
            <div>
                <button class="btn btn-outline-secondary me-2" @onclick="OncekiAydanKopyala">
                    <i class="bi bi-copy me-1"></i> Onceki Aydan Kopyala
                </button>
                <button class="btn btn-outline-danger me-2" @onclick="DonemTemizle">
                    <i class="bi @(donemTemizleOnay ? "bi-exclamation-triangle" : "bi-eraser") me-1"></i>
                    @(donemTemizleOnay ? "Emin misiniz?" : "Donem Temizle")
                </button>
                <button class="btn btn-primary" @onclick="YeniKayitAc">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Sefer
                </button>
                <div class="btn-group ms-2" role="group">
                    <button class="@SlotBtnClass()" @onclick='() => gruplandirma = "slot"'>Slot</button>
                    <button class="@GuzergahBtnClass()" @onclick='() => gruplandirma = "guzergah"'>Guzergah</button>
                </div>
            </div>
        </div>

        <!-- Filtreler -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small mb-1">Kurum</label>
                        <select class="form-select form-select-sm" @bind="seciliKurumId" @bind:after="FiltreDegisti">
                            <option value="">Tum Kurumlar</option>
                            @foreach (var k in kurumlar)
                            {
                                <option value="@k.Id">@k.KurumAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Slot</label>
                        <select class="form-select form-select-sm" @bind="seciliSlot" @bind:after="FiltreDegisti">
                            <option value="">Tum Slotlar</option>
                            @foreach (SeferSlot s in Enum.GetValues<SeferSlot>())
                            {
                                <option value="@((int)s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Yil</label>
                        <select class="form-select form-select-sm" @bind="seciliYil" @bind:after="FiltreDegisti">
                            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Ay</label>
                        <select class="form-select form-select-sm" @bind="seciliAy" @bind:after="FiltreDegisti">
                            @for (int a = 1; a <= 12; a++)
                            {
                                <option value="@a">@(new DateTime(2024, a, 1).ToString("MMMM"))</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Onay</label>
                        <select class="form-select form-select-sm" @bind="seciliOnay" @bind:after="FiltreDegisti">
                            <option value="">Tum Durumlar</option>
                            <option value="Taslak">Taslak</option>
                            <option value="OnayBekliyor">Onay Bekliyor</option>
                            <option value="Onaylandi">Onaylandi</option>
                            <option value="Reddedildi">Reddedildi</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="SablonOlustur">
                            <i class="bi bi-lightning me-1"></i> Sablon Olustur
                        </button>
                    </div>
                    @if (seciliKurumId.HasValue && seciliKurumId.Value > 0 && kayitlar.Any())
                    {
                        <div class="col-auto">
                            <button class="btn btn-outline-warning btn-sm" @onclick="PuantajGuncelle" disabled="@kaydediliyor">
                                <i class="bi bi-arrow-repeat me-1"></i> Puantajı Güncelle
                            </button>
                        </div>
                    }
                    @if (kayitlar.Any())
                    {
                        var hepsiDaraltildi = daraltilanSlotlar.Count >= kayitlar.Select(k => k.Slot).Distinct().Count();
                        <div class="col-auto">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="TumSlotlariToggle">
                                <i class="bi @(hepsiDaraltildi ? "bi-chevron-down" : "bi-chevron-up") me-1"></i>
                                @(hepsiDaraltildi ? "Tumunu Genislet" : "Tumunu Daralt")
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (kayitlar.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Secilen donemde kayit bulunamadi. "Sablon Olustur" ile bos sablon olusturabilir veya "Yeni Sefer" ile manuel ekleyebilirsiniz.
            </div>
        }
        else
        {
            var onayTaslak = kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.Taslak);
            var onayBekleyen = kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.OnayBekliyor);
            var onaylandi = kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.Onaylandi);
            var reddedildi = kayitlar.Count(k => k.OnayDurum == PuantajOnayDurum.Reddedildi);
            <div class="row g-2 mb-3">
                <div class="col-auto"><span class="badge bg-secondary fs-6">@onayTaslak Taslak</span></div>
                <div class="col-auto"><span class="badge bg-warning text-dark fs-6">@onayBekleyen Onay Bekliyor</span></div>
                <div class="col-auto"><span class="badge bg-success fs-6">@onaylandi Onaylandi</span></div>
                @if (reddedildi > 0) { <div class="col-auto"><span class="badge bg-danger fs-6">@reddedildi Reddedildi</span></div> }
            </div>
            @if (gruplandirma == "guzergah")
            {
                var guzergahGruplari = kayitlar.GroupBy(k => k.Guzergah?.GuzergahAdi ?? k.GuzergahAdi ?? "?").OrderBy(g => g.Key);
                @foreach (var grup in guzergahGruplari)
                {
                    var daraltildi = daraltilanGuzergahlar.Contains(grup.Key);
                    <h5 class="mt-3 mb-2" style="cursor:pointer" @onclick="() => GuzergahToggle(grup.Key)">
                        <i class="bi @(daraltildi ? "bi-chevron-right" : "bi-chevron-down") me-1"></i>
                        <strong>@grup.Key</strong>
                        <small class="text-muted ms-2">@grup.Count() sefer — @grup.Sum(k => (decimal)k.Gun) gun</small>
                        <small class="text-success ms-2">Gelir: @grup.Sum(k => k.BirimGelir * k.Gun).ToString("N2")</small>
                    </h5>
                    @if (!daraltildi)
                    {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped table-hover align-middle">
                            <thead class="table-dark"><tr><th>Slot</th><th>Arac</th><th>Sofor</th><th class="text-center">Gun</th><th class="text-center">Onay</th><th>Islem</th></tr></thead>
                            <tbody>
                                @foreach (var k in grup.OrderBy(k => k.Slot))
                                {
                                    var catisanGunler = catismaHaritasi.GetValueOrDefault(k, new());
                                    var rowClass = degisenSatirlar.Contains(k) ? "table-warning" : (catisanGunler.Any(c => c.Severity == ConflictSeverity.Blocking) ? "table-danger" : catisanGunler.Any() ? "table-warning" : "");
                                    <tr class="@rowClass">
                                        <td><span class="badge @SlotBadgeClass(k.Slot)">@SlotDisplayName(k.Slot, k.SlotAdi)</span></td>
                                        <td>@(k.Arac?.AktifPlaka ?? k.Plaka)</td>
                                        <td>@(k.Sofor != null ? $"{k.Sofor.Ad} {k.Sofor.Soyad}" : k.SoforAdi)</td>
                                        <td class="text-center">@k.Gun</td>
                                        <td class="text-center">@(k.OnayDurum == PuantajOnayDurum.Onaylandi ? "✅" : k.OnayDurum == PuantajOnayDurum.OnayBekliyor ? "⏳" : "")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary p-1" @onclick="() => KayitDuzenle(k)" title="Duzenle"><i class="bi bi-pencil"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    }
                }
            }
            else
            {
            var slotGruplari = kayitlar.GroupBy(k => k.Slot).OrderBy(g => g.Key);
            @foreach (var slotGrubu in slotGruplari)
            {
                var daraltildi = daraltilanSlotlar.Contains(slotGrubu.Key);
                <h5 class="mt-3 mb-2" style="cursor:pointer" @onclick="() => SlotToggle(slotGrubu.Key)">
                    <i class="bi @(daraltildi ? "bi-chevron-right" : "bi-chevron-down") me-1"></i>
                    <span class="badge @SlotBadgeClass(slotGrubu.Key) me-2">@SlotDisplayName(slotGrubu.Key, slotGrubu.FirstOrDefault()?.SlotAdi)</span>
                    <small class="text-muted">@slotGrubu.Count() sefer</small>
                    @if (daraltildi) { <small class="text-muted ms-1">(daraltildi)</small> }
                </h5>
                @if (!daraltildi)
                {
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th style="cursor:pointer" @onclick='() => SiralamaYap("Guzergah")'>
                                    Guzergah @SiralamaIkonu("Guzergah")
                                </th>
                                <th style="cursor:pointer" @onclick='() => SiralamaYap("Arac")'>
                                    Arac @SiralamaIkonu("Arac")
                                </th>
                                <th>Sofor</th>
                                <th>Kaynak</th>
                                <th>Finans</th>
                                <th>Yon</th>
                                <th class="text-center">Onay</th>
                                <th class="text-center">Sefer</th>
                                <th class="text-center" style="min-width:200px">Gun / Gunluk Dagilim</th>
                                <th class="text-end" style="cursor:pointer" @onclick='() => SiralamaYap("BirimGelir")'>
                                    Birim Gelir @SiralamaIkonu("BirimGelir")
                                </th>
                                <th class="text-end" style="cursor:pointer" @onclick='() => SiralamaYap("BirimGider")'>
                                    Birim Gider @SiralamaIkonu("BirimGider")
                                </th>
                                <th style="width:120px">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var k in SiralanmisKayitlar(slotGrubu))
                            {
                                var catisanGunler = catismaHaritasi.GetValueOrDefault(k, new());
                                var rowClass = degisenSatirlar.Contains(k) ? "table-warning" : "";
                                if (catisanGunler.Any(c => c.Severity == ConflictSeverity.Blocking))
                                    rowClass = "table-danger";
                                else if (catisanGunler.Any())
                                    rowClass = "table-warning";
                                var finansRenk = k.FinansYonu switch
                                {
                                    PlanlamaFinansYonu.Gelen => "border-left: 4px solid #198754;",
                                    PlanlamaFinansYonu.Giden => "border-left: 4px solid #dc3545;",
                                    PlanlamaFinansYonu.IcDagitim => "border-left: 4px solid #0d6efd;",
                                    _ => ""
                                };
                                <tr class="@rowClass" style="@finansRenk">
                                    <td>
                                        <button class="btn btn-outline-success btn-sm me-1"
                                                @onclick="() => AyniGuzergahaSeferEkle(k)" title="Bu güzergaha yeni sefer/slot ekle">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                        @if (k.GuzergahId.HasValue && k.GuzergahId > 0)
                                        {
                                            <a href="/guzergahlar/@k.GuzergahId" target="_blank" class="text-decoration-none" title="Guzergahı düzenle">
                                                @(k.Guzergah?.GuzergahAdi ?? k.GuzergahAdi) <i class="bi bi-box-arrow-up-right small text-muted"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            @(k.Guzergah?.GuzergahAdi ?? k.GuzergahAdi)
                                        }
                                        @{
                                            var kurumAdi = k.Kurum?.KurumAdi ?? k.KurumAdi ?? k.Guzergah?.Kurum?.KurumAdi;
                                        }
                                        @if (!string.IsNullOrEmpty(kurumAdi) && !seciliKurumId.HasValue)
                                        {
                                            <br /><small class="text-muted">@kurumAdi</small>
                                        }
                                    </td>
                                    <td>@(k.Arac?.AktifPlaka ?? k.Plaka)</td>
                                    <td>
                                        @(k.Sofor != null ? $"{k.Sofor.Ad} {k.Sofor.Soyad}" : k.SoforAdi)
                                        @if (catisanGunler.Any(c => c.Kural == "Tek Sofor"))
                                        {
                                            <span class="badge bg-warning text-dark ms-1" title="Sofor cakismasi">!</span>
                                        }
                                    </td>
                                    <td><span class="badge @(k.KaynakTipi == PlanlamaKaynakTipi.Kendi ? "bg-primary" : "bg-secondary")">@k.KaynakTipi</span></td>
                                    <td><span class="badge @(k.FinansYonu == PlanlamaFinansYonu.Gelen ? "bg-success" : k.FinansYonu == PlanlamaFinansYonu.Giden ? "bg-danger" : "bg-info")">@k.FinansYonu</span></td>
                                    <td>@k.Yon</td>
                                    <td class="text-center">
                                        @if (k.OnayDurum == PuantajOnayDurum.Onaylandi)
                                        { <span class="badge bg-success" style="cursor:pointer" @onclick="() => OnayToggle(k)" title="Onayı kaldır">Onaylandi</span> }
                                        else if (k.OnayDurum == PuantajOnayDurum.OnayBekliyor)
                                        { <span class="badge bg-warning text-dark" style="cursor:pointer" @onclick="() => OnayToggle(k)" title="Onayla">Onay Bekliyor</span> }
                                        else if (k.OnayDurum == PuantajOnayDurum.Reddedildi)
                                        { <span class="badge bg-danger" style="cursor:pointer" @onclick="() => OnayToggle(k)" title="Taslak yap">Reddedildi</span> }
                                        else
                                        { <span class="badge bg-secondary" style="cursor:pointer" @onclick="() => OnayToggle(k)" title="Onayla">Taslak</span> }
                                    </td>
                                    <td class="text-center">@k.SeferSayisi</td>
                                    <td class="text-center" style="position:relative;">
                                        <div class="d-flex align-items-center gap-1 justify-content-center">
                                            <span class="fw-bold small">@k.Gun</span>
                                            @if (catisanGunler.Any())
                                            {
                                                <span class="badge @(catisanGunler.Any(c => c.Severity == ConflictSeverity.Blocking) ? "bg-danger" : "bg-warning text-dark")"
                                                      title="@string.Join("; ", catisanGunler.Select(c => $"Gun {c.Gun}: {c.Kural} - {c.Mesaj}"))">
                                                    @catisanGunler.Count
                                                </span>
                                            }
                                        </div>
                                        @{
                                            var gunTooltipLines = new List<string>();
                                            for (int g = 1; g <= 31; g++)
                                            {
                                                var d = k.GetGunDeger(g);
                                                if (d > 0) gunTooltipLines.Add($"Gun {g}: {(d == 2 ? "S+A" : "Tek Sefer")}");
                                            }
                                        }
                                        <div class="d-flex mt-1 justify-content-center" style="gap:1px;" title="@string.Join(", ", gunTooltipLines)">
                                            @for (int gun = 1; gun <= 31; gun++)
                                            {
                                                var gunNo = gun;
                                                var kayitRef = k;
                                                var deger = kayitRef.GetGunDeger(gunNo);
                                                var tarih = new DateTime(k.Yil, k.Ay, Math.Min(gunNo, DateTime.DaysInMonth(k.Yil, k.Ay)));
                                                var haftaSonu = tarih.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                                var color = deger == 2 ? "#0d6efd" : deger == 1 ? "#198754" : (haftaSonu ? "#dee2e6" : "#e9ecef");
                                                <div style="width:4px; height:12px; background:@color; border-radius:1px; cursor:pointer;@(haftaSonu ? " border-bottom:2px solid #adb5bd;" : "")"
                                                     @onclick="() => GunInlineToggle(kayitRef, gunNo)"
                                                     title="Gun @gunNo (@tarih.ToString("ddd", new System.Globalization.CultureInfo("tr-TR"))): @(deger == 2 ? "S+A" : deger == 1 ? "Tek Sefer" : "Gitmedi") - Tikla degistir"></div>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end">@k.BirimGelir.ToString("N2")</td>
                                    <td class="text-end">@k.BirimGider.ToString("N2")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary btn-sm" title="Duzenle"
                                                    @onclick="() => KayitDuzenle(k)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-info btn-sm" title="Kopyala"
                                                    @onclick="() => KayitKopyala(k)">
                                                <i class="bi bi-copy"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" title="Sil"
                                                    @onclick="() => KayitSil(k)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @{
                            var slotKayitlar = slotGrubu.ToList();
                            var slotToplamGelir = slotKayitlar.Sum(k => k.BirimGelir * k.Gun);
                            var slotToplamGider = slotKayitlar.Sum(k => k.BirimGider * k.Gun);
                            var slotNetKar = slotToplamGelir - slotToplamGider;
                        }
                        <tfoot class="table-secondary fw-bold small">
                            <tr>
                                <td colspan="11" class="text-end">
                                    <span class="text-success me-3">Gelir: @slotToplamGelir.ToString("N2") TL</span>
                                    <span class="text-danger me-3">Gider: @slotToplamGider.ToString("N2") TL</span>
                                    <span class="@(slotNetKar >= 0 ? "text-primary" : "text-danger")">Net: @slotNetKar.ToString("N2") TL</span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                }
            }
            }

            @* Genel Toplam *@
            @if (kayitlar.Any())
            {
                var genelGelir = kayitlar.Sum(k => k.BirimGelir * k.Gun);
                var genelGider = kayitlar.Sum(k => k.BirimGider * k.Gun);
                var genelKar = genelGelir - genelGider;
                <div class="card mt-3 border-2 @(genelKar >= 0 ? "border-success" : "border-danger")">
                    <div class="card-body py-2">
                        <div class="row text-center">
                            <div class="col">
                                <small class="text-muted">Toplam Sefer</small>
                                <h5 class="mb-0">@kayitlar.Sum(k => k.SeferSayisi)</h5>
                            </div>
                            <div class="col">
                                <small class="text-muted">Toplam Gun</small>
                                <h5 class="mb-0">@kayitlar.Sum(k => (decimal)k.Gun)</h5>
                            </div>
                            <div class="col">
                                <small class="text-muted text-success">Toplam Gelir</small>
                                <h5 class="mb-0 text-success">@genelGelir.ToString("N2") TL</h5>
                            </div>
                            <div class="col">
                                <small class="text-muted text-danger">Toplam Gider</small>
                                <h5 class="mb-0 text-danger">@genelGider.ToString("N2") TL</h5>
                            </div>
                            <div class="col">
                                <small class="text-muted">Net Kar/Zarar</small>
                                <h5 class="mb-0 @(genelKar >= 0 ? "text-primary" : "text-danger")">@genelKar.ToString("N2") TL</h5>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Cakisma Paneli *@
            @if (sonConflict != null && !sonConflict.IsClean)
            {
                <div class="mt-3">
                    @if (sonConflict.HasBlocking)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-octagon-fill me-2"></i>
                            <strong>Engelleyici cakisma!</strong> Asagidaki sorunlari duzeltmeden kaydedemezsiniz:
                            <ul class="mb-0 mt-2">
                                @foreach (var c in sonConflict.Conflicts.Where(c => c.Severity == ConflictSeverity.Blocking).Take(5))
                                {
                                    <li>@c.Mesaj</li>
                                }
                                @if (sonConflict.Conflicts.Count(c => c.Severity == ConflictSeverity.Blocking) > 5)
                                {
                                    <li>... ve @(sonConflict.Conflicts.Count(c => c.Severity == ConflictSeverity.Blocking) - 5) tane daha</li>
                                }
                            </ul>
                        </div>
                    }
                    else if (sonConflict.HasWarning)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Uyari:</strong> @sonConflict.Conflicts.Count(c => c.Severity == ConflictSeverity.Warning) adet cakisma bulundu.
                            <ul class="mb-0 mt-2">
                                @foreach (var c in sonConflict.Conflicts.Where(c => c.Severity == ConflictSeverity.Warning).Take(3))
                                {
                                    <li>@c.Mesaj</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }

            @if (degisenSatirlar.Any())
            {
                <div class="sticky-bottom bg-light p-3 border-top mt-3 text-end">
                    <span class="text-warning me-3">@degisenSatirlar.Count degisiklik</span>
                    @if (sonConflict?.HasBlocking == true)
                    {
                        <button class="btn btn-secondary me-2" @onclick="CakismalariTemizle">
                            <i class="bi bi-eraser me-1"></i> Cakismalari Temizle
                        </button>
                        <button class="btn btn-danger" title="Engelleyici cakismalar var, kaydedilemez" disabled>
                            <i class="bi bi-x-octagon me-1"></i> Kaydedilemez
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-success me-2" @onclick="TopluOnayla"
                                disabled="@kaydediliyor" title="Degisen kayitlari Onaylandi olarak isaretler">
                            <i class="bi bi-check-all me-1"></i> Toplu Onayla
                        </button>
                        <button class="btn btn-outline-secondary me-2" @onclick="TopluTaslakYap"
                                disabled="@kaydediliyor" title="Degisen kayitlarin onayini kaldir">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Onay Kaldir
                        </button>
                        <button class="btn btn-outline-warning me-2" @onclick="CakismaKontrolEt"
                                disabled="@kontrolEdiliyor">
                            <i class="bi bi-shield-check me-1"></i>
                            @(kontrolEdiliyor ? "Kontrol ediliyor..." : "Cakisma Kontrol")
                        </button>
                        <button class="btn btn-success" @onclick="TopluKaydet" disabled="@kaydediliyor">
                            <i class="bi bi-save me-1"></i> Tumunu Kaydet
                            @if (sonConflict?.HasWarning == true)
                            {
                                <span class="badge bg-dark ms-1">Uyari Var</span>
                            }
                        </button>
                    }
                </div>
            }
        }
    </div>
}

@* Edit Modal *@
@if (duzenleKayit != null)
{
    <PlanlamaEditModal Kayit="duzenleKayit"
                        Kurumlar="kurumlar"
                        Firmalar="firmalar"
                        GuzergahListesi="guzergahListesi"
                        AracListesi="aracListesi"
                        SoforListesi="soforListesi"
                        MevcutKayitlar="kayitlar"
                        OnKaydet="KayitKaydetCallback"
                        OnKapat="() => duzenleKayit = null" />
}

@if (kopyalamaModaliAcik)
{
    <CopyPreviousMonthModal HedefYil="seciliYil"
                             HedefAy="seciliAy"
                             Kurumlar="kurumlar"
                             OnKopyalandi="KopyalamaTamamlandi"
                             OnKapat="() => kopyalamaModaliAcik = false" />
}

@code {
    private bool yukleniyor = true;
    private bool kaydediliyor;
    private List<Kurum> kurumlar = new();
    private List<PuantajKayit> kayitlar = new();
    private List<Firma> firmalar = new();
    private List<Guzergah> guzergahListesi = new();
    private List<Arac> aracListesi = new();
    private List<Sofor> soforListesi = new();
    private HashSet<PuantajKayit> degisenSatirlar = new();
    private HashSet<SeferSlot> daraltilanSlotlar = new();
    private HashSet<string> daraltilanGuzergahlar = new();

    private void SlotToggle(SeferSlot slot)
    {
        if (daraltilanSlotlar.Contains(slot))
            daraltilanSlotlar.Remove(slot);
        else
            daraltilanSlotlar.Add(slot);
    }

    private void GuzergahToggle(string guzergahAdi)
    {
        if (daraltilanGuzergahlar.Contains(guzergahAdi))
            daraltilanGuzergahlar.Remove(guzergahAdi);
        else
            daraltilanGuzergahlar.Add(guzergahAdi);
    }

    private void TumSlotlariToggle()
    {
        var tumSlotlar = kayitlar.Select(k => k.Slot).Distinct().ToList();
        var hepsiDaraltildi = daraltilanSlotlar.Count >= tumSlotlar.Count;
        if (hepsiDaraltildi)
            daraltilanSlotlar.Clear();
        else
            foreach (var s in tumSlotlar) daraltilanSlotlar.Add(s);
    }

    private int? seciliKurumId;
    private int seciliYil = DateTime.Now.Year;
    private int seciliAy = DateTime.Now.Month;
    private string seciliSlot = "";
    private string seciliOnay = "";
    private string gruplandirma = "guzergah";
    private string SlotBtnClass() => "btn btn-sm " + (gruplandirma == "slot" ? "btn-secondary" : "btn-outline-secondary");
    private string GuzergahBtnClass() => "btn btn-sm " + (gruplandirma == "guzergah" ? "btn-secondary" : "btn-outline-secondary");

    private PuantajKayit? duzenleKayit;
    private bool kopyalamaModaliAcik;
    private ConflictResult? sonConflict;
    private Dictionary<PuantajKayit, List<ConflictItem>> catismaHaritasi = new();
    private bool kontrolEdiliyor;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tasks = new Task[]
            {
                Task.Run(async () => kurumlar = await KurumPuantajService.GetAktifKurumlarAsync()),
                Task.Run(async () => firmalar = await FirmaService.GetAktifFirmalarAsync()),
                Task.Run(async () => guzergahListesi = await GuzergahService.GetActiveAsync()),
                Task.Run(async () => aracListesi = await AracService.GetActiveAsync()),
                Task.Run(async () => soforListesi = await SoforService.GetActiveAsync()),
                VeriYukle()
            };
            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Planlama verisi yuklenemedi");
        }
        finally { yukleniyor = false; }
    }

    private async Task VeriYukle()
    {
        kayitlar = await KurumPuantajService.GetPuantajlarAsync(seciliYil, seciliAy, seciliKurumId);

        // OnayDurum filtresi (client-side)
        if (!string.IsNullOrEmpty(seciliOnay) && Enum.TryParse<PuantajOnayDurum>(seciliOnay, out var onayDurum))
            kayitlar = kayitlar.Where(k => k.OnayDurum == onayDurum).ToList();

        // Slot filtresi (client-side)
        if (!string.IsNullOrEmpty(seciliSlot))
            kayitlar = kayitlar.Where(k => k.Slot == (SeferSlot)int.Parse(seciliSlot)).ToList();

        degisenSatirlar.Clear();
    }

    private async Task FiltreDegisti() => await VeriYukle();

    private void YeniKayitAc()
    {
        duzenleKayit = new PuantajKayit
        {
            Yil = seciliYil,
            Ay = seciliAy,
            KurumId = seciliKurumId,
            Slot = string.IsNullOrEmpty(seciliSlot) ? SeferSlot.Sabah : (SeferSlot)int.Parse(seciliSlot),
            SeferSayisi = 1,
            Gun = 0
        };
    }

    private void KayitDuzenle(PuantajKayit k) => duzenleKayit = k;

    private void AyniGuzergahaSeferEkle(PuantajKayit kaynak)
    {
        // Bu guzergah icin kullanilan slotlari bul
        var kullanilanSlotlar = kayitlar
            .Where(k => k.GuzergahId == kaynak.GuzergahId)
            .Select(k => k.Slot).ToHashSet();

        // Ilk bos slotu bul
        var yeniSlot = SeferSlot.Sabah;
        foreach (SeferSlot s in Enum.GetValues<SeferSlot>())
        {
            if (!kullanilanSlotlar.Contains(s)) { yeniSlot = s; break; }
        }

        // Guzergah'in varsayilan arac/sofor bilgilerini al
        var guzergah = guzergahListesi.FirstOrDefault(g => g.Id == kaynak.GuzergahId);
        var varsayilanAracId = guzergah?.VarsayilanAracId ?? kaynak.AracId;
        var varsayilanSoforId = guzergah?.VarsayilanSoforId ?? kaynak.SoforId;
        Arac? varsayilanArac = null;
        Sofor? varsayilanSofor = null;
        if (varsayilanAracId.HasValue) varsayilanArac = aracListesi.FirstOrDefault(a => a.Id == varsayilanAracId.Value);
        if (varsayilanSoforId.HasValue) varsayilanSofor = soforListesi.FirstOrDefault(s => s.Id == varsayilanSoforId.Value);

        var yeni = new PuantajKayit
        {
            GuzergahId = kaynak.GuzergahId, Guzergah = kaynak.Guzergah, GuzergahAdi = kaynak.GuzergahAdi,
            KurumId = kaynak.KurumId, IsverenFirmaId = kaynak.IsverenFirmaId,
            AracId = varsayilanAracId, Arac = varsayilanArac,
            Plaka = varsayilanArac?.AktifPlaka ?? varsayilanArac?.Plaka,
            SoforId = varsayilanSoforId, Sofor = varsayilanSofor,
            SoforAdi = varsayilanSofor != null ? $"{varsayilanSofor.Ad} {varsayilanSofor.Soyad}" : null,
            Slot = yeniSlot, Yil = kaynak.Yil, Ay = kaynak.Ay,
            BirimGelir = kaynak.BirimGelir, BirimGider = kaynak.BirimGider,
            KaynakTipi = kaynak.KaynakTipi, FinansYonu = kaynak.FinansYonu,
            OnayDurum = PuantajOnayDurum.Taslak
        };
        kayitlar.Add(yeni);
        degisenSatirlar.Add(yeni);
        ToastService.ShowSuccess($"Yeni sefer eklendi: Slot = {SlotDisplayName(yeniSlot, null)}");
    }

    private void KayitKopyala(PuantajKayit k)
    {
        var yeni = new PuantajKayit
        {
            GuzergahId = k.GuzergahId, Guzergah = k.Guzergah, GuzergahAdi = k.GuzergahAdi,
            AracId = k.AracId, Arac = k.Arac, Plaka = k.Plaka,
            SoforId = k.SoforId, Sofor = k.Sofor, SoforAdi = k.SoforAdi,
            KurumId = k.KurumId, KurumCariId = k.KurumCariId, KurumAdi = k.KurumAdi,
            IsverenFirmaId = k.IsverenFirmaId,
            Slot = k.Slot, SlotAdi = k.SlotAdi, Yon = k.Yon, Yil = k.Yil, Ay = k.Ay,
            SeferSayisi = k.SeferSayisi, Gun = k.Gun,
            BirimGelir = k.BirimGelir, BirimGider = k.BirimGider,
            SoforOdemeTipi = k.SoforOdemeTipi,
            KaynakTipi = k.KaynakTipi, FinansYonu = k.FinansYonu,
            BelgeNo = k.BelgeNo, TransferDurum = k.TransferDurum,
            OnayDurum = PuantajOnayDurum.Taslak
        };
        for (int g = 1; g <= 31; g++) yeni.SetGunDeger(g, k.GetGunDeger(g));
        yeni.HesaplaPuantajToplam();
        kayitlar.Add(yeni);
        degisenSatirlar.Add(yeni);
        ToastService.ShowSuccess("Satir kopyalandi. Kaydetmek icin Tumunu Kaydet'e basin.");
    }

    private async Task KayitKaydetCallback(PuantajKayit kayit)
    {
        if (kayit.Id == 0 && !kayitlar.Contains(kayit))
            kayitlar.Add(kayit);
        degisenSatirlar.Add(kayit);
        duzenleKayit = null;
    }

    private async Task KayitSil(PuantajKayit k)
    {
        if (k.Id > 0)
        {
            await KurumPuantajService.DeletePuantajAsync(k.Id);
        }
        kayitlar.Remove(k);
        degisenSatirlar.Remove(k);
    }

    private async Task CakismaKontrolEt()
    {
        kontrolEdiliyor = true;
        sonConflict = null;
        catismaHaritasi.Clear();
        try
        {
            var kontrolListesi = degisenSatirlar.Any() ? degisenSatirlar.ToList() : kayitlar;
            sonConflict = await KurumPuantajService.CheckConflictsAsync(kontrolListesi);

            // Harita olustur: her kayit -> cakisan ConflictItem listesi
            foreach (var c in sonConflict.Conflicts)
            {
                var hedefKayit = kontrolListesi.FirstOrDefault(k => k.Id == c.EtkilenenKayitId);
                if (hedefKayit != null)
                {
                    if (!catismaHaritasi.ContainsKey(hedefKayit))
                        catismaHaritasi[hedefKayit] = new();
                    catismaHaritasi[hedefKayit].Add(c);
                }
            }

            if (sonConflict.IsClean)
                ToastService.ShowSuccess("Cakisma bulunamadi - kaydedebilirsiniz.");
        }
        finally { kontrolEdiliyor = false; }
    }

    private void TopluOnayla()
    {
        var hedef = (degisenSatirlar.Any() ? degisenSatirlar.AsEnumerable() : kayitlar).ToList();
        foreach (var k in hedef)
        {
            k.OnayDurum = PuantajOnayDurum.Onaylandi;
            k.OnaylayanKullanici = "toplu";
            k.OnayTarihi = DateTime.UtcNow;
            degisenSatirlar.Add(k);
        }
        ToastService.ShowSuccess($"{hedef.Count()} kayit onaylandi. Kaydetmek icin Tumunu Kaydet'e basin.");
    }

    private void TopluTaslakYap()
    {
        var hedef = (degisenSatirlar.Any() ? degisenSatirlar.AsEnumerable() : kayitlar).ToList();
        foreach (var k in hedef)
        {
            k.OnayDurum = PuantajOnayDurum.Taslak;
            k.OnaylayanKullanici = null;
            k.OnayTarihi = null;
            degisenSatirlar.Add(k);
        }
        ToastService.ShowSuccess($"{hedef.Count} kaydin onayi kaldirildi. Kaydetmek icin Tumunu Kaydet'e basin.");
    }

    private void CakismalariTemizle()
    {
        sonConflict = null;
        catismaHaritasi.Clear();
    }

    private async Task TopluKaydet()
    {
        // Kaydetmeden once cakisma kontrolu
        if (sonConflict == null || !sonConflict.IsClean)
        {
            await CakismaKontrolEt();
        }

        if (sonConflict?.HasBlocking == true)
        {
            ToastService.ShowError("Engelleyici cakismalar var! Once duzeltin.");
            return;
        }

        kaydediliyor = true;
        try
        {
            await KurumPuantajService.TopluSavePuantajAsync(degisenSatirlar);
            degisenSatirlar.Clear();
            sonConflict = null;
            catismaHaritasi.Clear();
            await VeriYukle();
            ToastService.ShowSuccess("Tum degisiklikler kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayit hatasi: {ex.Message}");
        }
        finally { kaydediliyor = false; }
    }

    private string siralamaAlani = "Guzergah";
    private bool siralamaArtan = true;

    private void SiralamaYap(string alan)
    {
        if (siralamaAlani == alan)
            siralamaArtan = !siralamaArtan;
        else { siralamaAlani = alan; siralamaArtan = true; }
    }

    private string SiralamaIkonu(string alan) =>
        siralamaAlani == alan ? (siralamaArtan ? "▲" : "▼") : "";

    private IOrderedEnumerable<PuantajKayit> SiralanmisKayitlar(IGrouping<SeferSlot, PuantajKayit> slotGrubu)
    {
        IOrderedEnumerable<PuantajKayit> q;
        q = siralamaAlani switch
        {
            "Guzergah" => siralamaArtan ? slotGrubu.OrderBy(k => k.Guzergah?.GuzergahAdi) : slotGrubu.OrderByDescending(k => k.Guzergah?.GuzergahAdi),
            "Arac" => siralamaArtan ? slotGrubu.OrderBy(k => k.Arac?.AktifPlaka ?? k.Plaka) : slotGrubu.OrderByDescending(k => k.Arac?.AktifPlaka ?? k.Plaka),
            "BirimGelir" => siralamaArtan ? slotGrubu.OrderBy(k => k.BirimGelir) : slotGrubu.OrderByDescending(k => k.BirimGelir),
            "BirimGider" => siralamaArtan ? slotGrubu.OrderBy(k => k.BirimGider) : slotGrubu.OrderByDescending(k => k.BirimGider),
            _ => slotGrubu.OrderBy(k => k.Guzergah?.GuzergahAdi)
        };
        return siralamaAlani is "Guzergah" or "Arac" ? q : (siralamaArtan ? q.ThenBy(k => k.Guzergah?.GuzergahAdi) : q.ThenByDescending(k => k.Guzergah?.GuzergahAdi));
    }

    private void OnayToggle(PuantajKayit kayit)
    {
        kayit.OnayDurum = kayit.OnayDurum == PuantajOnayDurum.Onaylandi
            ? PuantajOnayDurum.Taslak
            : PuantajOnayDurum.Onaylandi;
        kayit.OnaylayanKullanici = kayit.OnayDurum == PuantajOnayDurum.Onaylandi ? "hizli" : null;
        kayit.OnayTarihi = kayit.OnayDurum == PuantajOnayDurum.Onaylandi ? DateTime.UtcNow : null;
        degisenSatirlar.Add(kayit);
    }

    private void GunInlineToggle(PuantajKayit kayit, int gun)
    {
        var mevcut = kayit.GetGunDeger(gun);
        var yeni = mevcut >= 2 ? 0 : mevcut + 1;
        kayit.SetGunDeger(gun, yeni);
        kayit.HesaplaPuantajToplam();
        degisenSatirlar.Add(kayit);
    }

    private async Task SablonOlustur()
    {
        if (!seciliKurumId.HasValue || seciliKurumId.Value == 0)
        {
            ToastService.ShowInfo("Sablon olusturmak icin bir Kurum secin.");
            return;
        }
        yukleniyor = true;
        try
        {
            kayitlar = await KurumPuantajService.SablonOlusturAsync(seciliKurumId.Value, seciliYil, seciliAy);
            ToastService.ShowSuccess("Sablon olusturuldu.");
        }
        finally { yukleniyor = false; }
    }

    private async Task PuantajGuncelle()
    {
        if (!seciliKurumId.HasValue || seciliKurumId.Value == 0) return;
        yukleniyor = true;
        try
        {
            var sonuc = await KurumPuantajService.GuncellePuantajAsync(seciliKurumId.Value, seciliYil, seciliAy);
            if (sonuc.Guncellenen > 0 || sonuc.Eklenen > 0)
            {
                await VeriYukle();
                ToastService.ShowSuccess($"Puantaj güncellendi: {sonuc.Guncellenen} güncellendi, {sonuc.Eklenen} eklendi, {sonuc.Degismeyen} değişmedi.");
            }
            else
            {
                ToastService.ShowInfo($"Tüm kayıtlar güncel ({sonuc.Degismeyen} kayıt değişmedi).");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Güncelleme hatası: {ex.Message}");
        }
        finally { yukleniyor = false; }
    }

    private void OncekiAydanKopyala() => kopyalamaModaliAcik = true;

    private bool donemTemizleOnay;

    private async Task DonemTemizle()
    {
        if (kayitlar.Count == 0) return;
        if (!donemTemizleOnay)
        {
            donemTemizleOnay = true;
            ToastService.ShowWarning($"{kayitlar.Count} kayit silinecek. Emin misiniz? Tekrar basin.");
            return;
        }
        donemTemizleOnay = false;
        var silinenSayi = kayitlar.Count;
        yukleniyor = true;
        try
        {
            foreach (var k in kayitlar)
                await KurumPuantajService.DeletePuantajAsync(k.Id);
            kayitlar.Clear();
            degisenSatirlar.Clear();
            sonConflict = null;
            catismaHaritasi.Clear();
            ToastService.ShowSuccess($"Donem temizlendi: {silinenSayi} kayit silindi.");
        }
        finally { yukleniyor = false; }
    }

    private async Task KopyalamaTamamlandi(List<PuantajKayit> kopyalananlar)
    {
        kopyalamaModaliAcik = false;
        if (!kopyalananlar.Any())
        {
            ToastService.ShowInfo("Kopyalanacak kayit bulunamadi.");
            return;
        }
        kayitlar.AddRange(kopyalananlar);
        foreach (var k in kopyalananlar) degisenSatirlar.Add(k);
        ToastService.ShowSuccess($"{kopyalananlar.Count} kayit yuklendi. Kaydetmek icin 'Tumunu Kaydet' dugmesine basin.");
    }

    private static string SlotDisplayName(SeferSlot slot, string? slotAdi) =>
        !string.IsNullOrWhiteSpace(slotAdi) ? slotAdi : slot switch
        {
            SeferSlot.Sabah => "Sabah",
            SeferSlot.Aksam => "Akşam",
            SeferSlot.Mesai => "Mesai",
            SeferSlot.Diger1 => "Diğer 1",
            SeferSlot.Diger2 => "Diğer 2",
            SeferSlot.Diger3 => "Diğer 3",
            SeferSlot.Diger4 => "Diğer 4",
            SeferSlot.Diger5 => "Diğer 5",
            _ => slot.ToString()
        };

    private string SlotBadgeClass(SeferSlot slot) => slot switch
    {
        SeferSlot.Sabah => "bg-warning text-dark",
        SeferSlot.Aksam => "bg-info text-dark",
        SeferSlot.Mesai => "bg-secondary",
        SeferSlot.Diger1 or SeferSlot.Diger2 => "bg-primary",
        SeferSlot.Diger3 or SeferSlot.Diger4 or SeferSlot.Diger5 => "bg-dark",
        _ => "bg-light text-dark"
    };

}
