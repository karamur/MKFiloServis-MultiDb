@page "/planlama"
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IKurumPuantajService KurumPuantajService
@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject ILogger<Planlama> Logger

<PageTitle>Planlama</PageTitle>

@if (yukleniyor)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-1"><i class="bi bi-calendar-check me-2"></i>Operasyon Planlama</h4>
                <p class="text-muted small mb-0">Gunluk sefer planlamasi - coklu slot (Sabah / Aksam / Mesai)</p>
            </div>
            <div>
                <button class="btn btn-outline-secondary me-2" @onclick="OncekiAydanKopyala">
                    <i class="bi bi-copy me-1"></i> Onceki Aydan Kopyala
                </button>
                <button class="btn btn-outline-danger me-2" @onclick="DonemTemizle">
                    <i class="bi bi-eraser me-1"></i> Donem Temizle
                </button>
                <button class="btn btn-primary" @onclick="YeniKayitAc">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Sefer
                </button>
            </div>
        </div>

        <!-- Filtreler -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small mb-1">Kurum</label>
                        <select class="form-select form-select-sm" @bind="seciliKurumId" @bind:after="FiltreDegisti">
                            <option value="">Tum Kurumlar</option>
                            @foreach (var k in kurumlar)
                            {
                                <option value="@k.Id">@k.KurumAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Slot</label>
                        <select class="form-select form-select-sm" @bind="seciliSlot" @bind:after="FiltreDegisti">
                            <option value="">Tum Slotlar</option>
                            @foreach (SeferSlot s in Enum.GetValues<SeferSlot>())
                            {
                                <option value="@((int)s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Yil</label>
                        <select class="form-select form-select-sm" @bind="seciliYil" @bind:after="FiltreDegisti">
                            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Ay</label>
                        <select class="form-select form-select-sm" @bind="seciliAy" @bind:after="FiltreDegisti">
                            @for (int a = 1; a <= 12; a++)
                            {
                                <option value="@a">@(new DateTime(2024, a, 1).ToString("MMMM"))</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Onay</label>
                        <select class="form-select form-select-sm" @bind="seciliOnay" @bind:after="FiltreDegisti">
                            <option value="">Tum Durumlar</option>
                            <option value="Taslak">Taslak</option>
                            <option value="OnayBekliyor">Onay Bekliyor</option>
                            <option value="Onaylandi">Onaylandi</option>
                            <option value="Reddedildi">Reddedildi</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="SablonOlustur">
                            <i class="bi bi-lightning me-1"></i> Sablon Olustur
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (kayitlar.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Secilen donemde kayit bulunamadi. "Sablon Olustur" ile bos sablon olusturabilir veya "Yeni Sefer" ile manuel ekleyebilirsiniz.
            </div>
        }
        else
        {
            var slotGruplari = kayitlar.GroupBy(k => k.Slot).OrderBy(g => g.Key);
            @foreach (var slotGrubu in slotGruplari)
            {
                <h5 class="mt-3 mb-2">
                    <span class="badge @SlotBadgeClass(slotGrubu.Key) me-2">@slotGrubu.Key</span>
                    <small class="text-muted">@slotGrubu.Count() sefer</small>
                </h5>
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th style="cursor:pointer" @onclick='() => SiralamaYap("Guzergah")'>
                                    Guzergah @SiralamaIkonu("Guzergah")
                                </th>
                                <th style="cursor:pointer" @onclick='() => SiralamaYap("Arac")'>
                                    Arac @SiralamaIkonu("Arac")
                                </th>
                                <th>Sofor</th>
                                <th>Kaynak</th>
                                <th>Finans</th>
                                <th>Yon</th>
                                <th class="text-center">Onay</th>
                                <th class="text-center">Sefer</th>
                                <th class="text-center" style="min-width:200px">Gun / Gunluk Dagilim</th>
                                <th class="text-end" style="cursor:pointer" @onclick='() => SiralamaYap("BirimGelir")'>
                                    Birim Gelir @SiralamaIkonu("BirimGelir")
                                </th>
                                <th class="text-end" style="cursor:pointer" @onclick='() => SiralamaYap("BirimGider")'>
                                    Birim Gider @SiralamaIkonu("BirimGider")
                                </th>
                                <th style="width:120px">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var k in SiralanmisKayitlar(slotGrubu))
                            {
                                var catisanGunler = catismaHaritasi.GetValueOrDefault(k, new());
                                var rowClass = degisenSatirlar.Contains(k) ? "table-warning" : "";
                                if (catisanGunler.Any(c => c.Severity == ConflictSeverity.Blocking))
                                    rowClass = "table-danger";
                                else if (catisanGunler.Any())
                                    rowClass = "table-warning";
                                <tr class="@rowClass">
                                    <td>@(k.Guzergah?.GuzergahAdi ?? k.GuzergahAdi)</td>
                                    <td>@(k.Arac?.AktifPlaka ?? k.Plaka)</td>
                                    <td>
                                        @(k.Sofor != null ? $"{k.Sofor.Ad} {k.Sofor.Soyad}" : k.SoforAdi)
                                        @if (catisanGunler.Any(c => c.Kural == "Tek Sofor"))
                                        {
                                            <span class="badge bg-warning text-dark ms-1" title="Sofor cakismasi">!</span>
                                        }
                                    </td>
                                    <td><span class="badge @(k.KaynakTipi == PlanlamaKaynakTipi.Kendi ? "bg-primary" : "bg-secondary")">@k.KaynakTipi</span></td>
                                    <td><span class="badge @(k.FinansYonu == PlanlamaFinansYonu.Gelen ? "bg-success" : k.FinansYonu == PlanlamaFinansYonu.Giden ? "bg-danger" : "bg-info")">@k.FinansYonu</span></td>
                                    <td>@k.Yon</td>
                                    <td class="text-center">
                                        @if (k.OnayDurum == PuantajOnayDurum.Onaylandi)
                                        { <span class="badge bg-success">Onaylandi</span> }
                                        else if (k.OnayDurum == PuantajOnayDurum.OnayBekliyor)
                                        { <span class="badge bg-warning text-dark">Onay Bekliyor</span> }
                                        else if (k.OnayDurum == PuantajOnayDurum.Reddedildi)
                                        { <span class="badge bg-danger">Reddedildi</span> }
                                        else
                                        { <span class="badge bg-secondary">Taslak</span> }
                                    </td>
                                    <td class="text-center">@k.SeferSayisi</td>
                                    <td class="text-center" style="position:relative;">
                                        <div class="d-flex align-items-center gap-1 justify-content-center">
                                            <span class="fw-bold small">@k.Gun</span>
                                            @if (catisanGunler.Any())
                                            {
                                                <span class="badge @(catisanGunler.Any(c => c.Severity == ConflictSeverity.Blocking) ? "bg-danger" : "bg-warning text-dark")"
                                                      title="@string.Join("; ", catisanGunler.Select(c => $"Gun {c.Gun}: {c.Kural} - {c.Mesaj}"))">
                                                    @catisanGunler.Count
                                                </span>
                                            }
                                        </div>
                                        @{
                                            var gunTooltipLines = new List<string>();
                                            for (int g = 1; g <= 31; g++)
                                            {
                                                var d = k.GetGunDeger(g);
                                                if (d > 0) gunTooltipLines.Add($"Gun {g}: {(d == 2 ? "S+A" : "Tek Sefer")}");
                                            }
                                        }
                                        <div class="d-flex mt-1 justify-content-center" style="gap:1px;" title="@string.Join(", ", gunTooltipLines)">
                                            @for (int gun = 1; gun <= 31; gun++)
                                            {
                                                var gunNo = gun;
                                                var kayitRef = k;
                                                var deger = kayitRef.GetGunDeger(gunNo);
                                                var color = deger == 2 ? "#0d6efd" : deger == 1 ? "#198754" : "#e9ecef";
                                                <div style="width:4px; height:12px; background:@color; border-radius:1px; cursor:pointer;"
                                                     @onclick="() => GunInlineToggle(kayitRef, gunNo)"
                                                     title="Gun @gunNo: @(deger == 2 ? "S+A" : deger == 1 ? "Tek Sefer" : "Gitmedi") - Tikla degistir"></div>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end">@k.BirimGelir.ToString("N2")</td>
                                    <td class="text-end">@k.BirimGider.ToString("N2")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary btn-sm" title="Duzenle"
                                                    @onclick="() => KayitDuzenle(k)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" title="Sil"
                                                    @onclick="() => KayitSil(k)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @* Cakisma Paneli *@
            @if (sonConflict != null && !sonConflict.IsClean)
            {
                <div class="mt-3">
                    @if (sonConflict.HasBlocking)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-octagon-fill me-2"></i>
                            <strong>Engelleyici cakisma!</strong> Asagidaki sorunlari duzeltmeden kaydedemezsiniz:
                            <ul class="mb-0 mt-2">
                                @foreach (var c in sonConflict.Conflicts.Where(c => c.Severity == ConflictSeverity.Blocking).Take(5))
                                {
                                    <li>@c.Mesaj</li>
                                }
                                @if (sonConflict.Conflicts.Count(c => c.Severity == ConflictSeverity.Blocking) > 5)
                                {
                                    <li>... ve @(sonConflict.Conflicts.Count(c => c.Severity == ConflictSeverity.Blocking) - 5) tane daha</li>
                                }
                            </ul>
                        </div>
                    }
                    else if (sonConflict.HasWarning)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Uyari:</strong> @sonConflict.Conflicts.Count(c => c.Severity == ConflictSeverity.Warning) adet cakisma bulundu.
                            <ul class="mb-0 mt-2">
                                @foreach (var c in sonConflict.Conflicts.Where(c => c.Severity == ConflictSeverity.Warning).Take(3))
                                {
                                    <li>@c.Mesaj</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }

            @if (degisenSatirlar.Any())
            {
                <div class="sticky-bottom bg-light p-3 border-top mt-3 text-end">
                    <span class="text-warning me-3">@degisenSatirlar.Count degisiklik</span>
                    @if (sonConflict?.HasBlocking == true)
                    {
                        <button class="btn btn-secondary me-2" @onclick="CakismalariTemizle">
                            <i class="bi bi-eraser me-1"></i> Cakismalari Temizle
                        </button>
                        <button class="btn btn-danger" title="Engelleyici cakismalar var, kaydedilemez" disabled>
                            <i class="bi bi-x-octagon me-1"></i> Kaydedilemez
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-success me-2" @onclick="TopluOnayla"
                                disabled="@kaydediliyor" title="Degisen kayitlari Onaylandi olarak isaretler">
                            <i class="bi bi-check-all me-1"></i> Toplu Onayla
                        </button>
                        <button class="btn btn-outline-warning me-2" @onclick="CakismaKontrolEt"
                                disabled="@kontrolEdiliyor">
                            <i class="bi bi-shield-check me-1"></i>
                            @(kontrolEdiliyor ? "Kontrol ediliyor..." : "Cakisma Kontrol")
                        </button>
                        <button class="btn btn-success" @onclick="TopluKaydet" disabled="@kaydediliyor">
                            <i class="bi bi-save me-1"></i> Tumunu Kaydet
                            @if (sonConflict?.HasWarning == true)
                            {
                                <span class="badge bg-dark ms-1">Uyari Var</span>
                            }
                        </button>
                    }
                </div>
            }
        }
    </div>
}

@* Edit Modal *@
@if (duzenleKayit != null)
{
    <PlanlamaEditModal Kayit="duzenleKayit"
                        Kurumlar="kurumlar"
                        Firmalar="firmalar"
                        GuzergahListesi="guzergahListesi"
                        AracListesi="aracListesi"
                        SoforListesi="soforListesi"
                        OnKaydet="KayitKaydetCallback"
                        OnKapat="() => duzenleKayit = null" />
}

@if (kopyalamaModaliAcik)
{
    <CopyPreviousMonthModal HedefYil="seciliYil"
                             HedefAy="seciliAy"
                             Kurumlar="kurumlar"
                             OnKopyalandi="KopyalamaTamamlandi"
                             OnKapat="() => kopyalamaModaliAcik = false" />
}

@code {
    private bool yukleniyor = true;
    private bool kaydediliyor;
    private List<Kurum> kurumlar = new();
    private List<PuantajKayit> kayitlar = new();
    private List<Firma> firmalar = new();
    private List<Guzergah> guzergahListesi = new();
    private List<Arac> aracListesi = new();
    private List<Sofor> soforListesi = new();
    private HashSet<PuantajKayit> degisenSatirlar = new();

    private int? seciliKurumId;
    private int seciliYil = DateTime.Now.Year;
    private int seciliAy = DateTime.Now.Month;
    private string seciliSlot = "";
    private string seciliOnay = "";

    private PuantajKayit? duzenleKayit;
    private bool kopyalamaModaliAcik;
    private ConflictResult? sonConflict;
    private Dictionary<PuantajKayit, List<ConflictItem>> catismaHaritasi = new();
    private bool kontrolEdiliyor;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tasks = new Task[]
            {
                Task.Run(async () => kurumlar = await KurumPuantajService.GetAktifKurumlarAsync()),
                Task.Run(async () => firmalar = await FirmaService.GetAktifFirmalarAsync()),
                Task.Run(async () => guzergahListesi = await GuzergahService.GetActiveAsync()),
                Task.Run(async () => aracListesi = await AracService.GetActiveAsync()),
                Task.Run(async () => soforListesi = await SoforService.GetActiveAsync()),
                VeriYukle()
            };
            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Planlama verisi yuklenemedi");
        }
        finally { yukleniyor = false; }
    }

    private async Task VeriYukle()
    {
        kayitlar = await KurumPuantajService.GetPuantajlarAsync(seciliYil, seciliAy, seciliKurumId);

        // OnayDurum filtresi (client-side)
        if (!string.IsNullOrEmpty(seciliOnay) && Enum.TryParse<PuantajOnayDurum>(seciliOnay, out var onayDurum))
            kayitlar = kayitlar.Where(k => k.OnayDurum == onayDurum).ToList();

        // Slot filtresi (client-side)
        if (!string.IsNullOrEmpty(seciliSlot))
            kayitlar = kayitlar.Where(k => k.Slot == (SeferSlot)int.Parse(seciliSlot)).ToList();

        degisenSatirlar.Clear();
    }

    private async Task FiltreDegisti() => await VeriYukle();

    private void YeniKayitAc()
    {
        duzenleKayit = new PuantajKayit
        {
            Yil = seciliYil,
            Ay = seciliAy,
            KurumId = seciliKurumId,
            Slot = string.IsNullOrEmpty(seciliSlot) ? SeferSlot.Sabah : (SeferSlot)int.Parse(seciliSlot),
            SeferSayisi = 1,
            Gun = 0
        };
    }

    private void KayitDuzenle(PuantajKayit k) => duzenleKayit = k;

    private async Task KayitKaydetCallback(PuantajKayit kayit)
    {
        if (kayit.Id == 0 && !kayitlar.Contains(kayit))
            kayitlar.Add(kayit);
        degisenSatirlar.Add(kayit);
        duzenleKayit = null;
    }

    private async Task KayitSil(PuantajKayit k)
    {
        if (k.Id > 0)
        {
            await KurumPuantajService.DeletePuantajAsync(k.Id);
        }
        kayitlar.Remove(k);
        degisenSatirlar.Remove(k);
    }

    private async Task CakismaKontrolEt()
    {
        kontrolEdiliyor = true;
        sonConflict = null;
        catismaHaritasi.Clear();
        try
        {
            var kontrolListesi = degisenSatirlar.Any() ? degisenSatirlar.ToList() : kayitlar;
            sonConflict = await KurumPuantajService.CheckConflictsAsync(kontrolListesi);

            // Harita olustur: her kayit -> cakisan ConflictItem listesi
            foreach (var c in sonConflict.Conflicts)
            {
                var hedefKayit = kontrolListesi.FirstOrDefault(k => k.Id == c.EtkilenenKayitId);
                if (hedefKayit != null)
                {
                    if (!catismaHaritasi.ContainsKey(hedefKayit))
                        catismaHaritasi[hedefKayit] = new();
                    catismaHaritasi[hedefKayit].Add(c);
                }
            }

            if (sonConflict.IsClean)
                ToastService.ShowSuccess("Cakisma bulunamadi - kaydedebilirsiniz.");
        }
        finally { kontrolEdiliyor = false; }
    }

    private void TopluOnayla()
    {
        var hedef = (degisenSatirlar.Any() ? degisenSatirlar.AsEnumerable() : kayitlar).ToList();
        foreach (var k in hedef)
        {
            k.OnayDurum = PuantajOnayDurum.Onaylandi;
            k.OnaylayanKullanici = "toplu";
            k.OnayTarihi = DateTime.UtcNow;
            degisenSatirlar.Add(k);
        }
        ToastService.ShowSuccess($"{hedef.Count()} kayit onaylandi. Kaydetmek icin Tumunu Kaydet'e basin.");
    }

    private void CakismalariTemizle()
    {
        sonConflict = null;
        catismaHaritasi.Clear();
    }

    private async Task TopluKaydet()
    {
        // Kaydetmeden once cakisma kontrolu
        if (sonConflict == null || !sonConflict.IsClean)
        {
            await CakismaKontrolEt();
        }

        if (sonConflict?.HasBlocking == true)
        {
            ToastService.ShowError("Engelleyici cakismalar var! Once duzeltin.");
            return;
        }

        kaydediliyor = true;
        try
        {
            await KurumPuantajService.TopluSavePuantajAsync(degisenSatirlar);
            degisenSatirlar.Clear();
            sonConflict = null;
            catismaHaritasi.Clear();
            await VeriYukle();
            ToastService.ShowSuccess("Tum degisiklikler kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayit hatasi: {ex.Message}");
        }
        finally { kaydediliyor = false; }
    }

    private string siralamaAlani = "Guzergah";
    private bool siralamaArtan = true;

    private void SiralamaYap(string alan)
    {
        if (siralamaAlani == alan)
            siralamaArtan = !siralamaArtan;
        else { siralamaAlani = alan; siralamaArtan = true; }
    }

    private string SiralamaIkonu(string alan) =>
        siralamaAlani == alan ? (siralamaArtan ? "▲" : "▼") : "";

    private IOrderedEnumerable<PuantajKayit> SiralanmisKayitlar(IGrouping<SeferSlot, PuantajKayit> slotGrubu)
    {
        IOrderedEnumerable<PuantajKayit> q;
        q = siralamaAlani switch
        {
            "Guzergah" => siralamaArtan ? slotGrubu.OrderBy(k => k.Guzergah?.GuzergahAdi) : slotGrubu.OrderByDescending(k => k.Guzergah?.GuzergahAdi),
            "Arac" => siralamaArtan ? slotGrubu.OrderBy(k => k.Arac?.AktifPlaka ?? k.Plaka) : slotGrubu.OrderByDescending(k => k.Arac?.AktifPlaka ?? k.Plaka),
            "BirimGelir" => siralamaArtan ? slotGrubu.OrderBy(k => k.BirimGelir) : slotGrubu.OrderByDescending(k => k.BirimGelir),
            "BirimGider" => siralamaArtan ? slotGrubu.OrderBy(k => k.BirimGider) : slotGrubu.OrderByDescending(k => k.BirimGider),
            _ => slotGrubu.OrderBy(k => k.Guzergah?.GuzergahAdi)
        };
        return siralamaAlani is "Guzergah" or "Arac" ? q : (siralamaArtan ? q.ThenBy(k => k.Guzergah?.GuzergahAdi) : q.ThenByDescending(k => k.Guzergah?.GuzergahAdi));
    }

    private void GunInlineToggle(PuantajKayit kayit, int gun)
    {
        var mevcut = kayit.GetGunDeger(gun);
        var yeni = mevcut >= 2 ? 0 : mevcut + 1;
        kayit.SetGunDeger(gun, yeni);
        kayit.HesaplaPuantajToplam();
        degisenSatirlar.Add(kayit);
    }

    private async Task SablonOlustur()
    {
        if (!seciliKurumId.HasValue || seciliKurumId.Value == 0)
        {
            ToastService.ShowInfo("Sablon olusturmak icin bir Kurum secin.");
            return;
        }
        yukleniyor = true;
        try
        {
            kayitlar = await KurumPuantajService.SablonOlusturAsync(seciliKurumId.Value, seciliYil, seciliAy);
            ToastService.ShowSuccess("Sablon olusturuldu.");
        }
        finally { yukleniyor = false; }
    }

    private void OncekiAydanKopyala() => kopyalamaModaliAcik = true;

    private async Task DonemTemizle()
    {
        if (kayitlar.Count == 0) return;
        var silinenSayi = kayitlar.Count;
        yukleniyor = true;
        try
        {
            foreach (var k in kayitlar)
                await KurumPuantajService.DeletePuantajAsync(k.Id);
            kayitlar.Clear();
            degisenSatirlar.Clear();
            sonConflict = null;
            catismaHaritasi.Clear();
            ToastService.ShowSuccess($"Donem temizlendi: {silinenSayi} kayit silindi.");
        }
        finally { yukleniyor = false; }
    }

    private async Task KopyalamaTamamlandi(List<PuantajKayit> kopyalananlar)
    {
        kopyalamaModaliAcik = false;
        if (!kopyalananlar.Any())
        {
            ToastService.ShowInfo("Kopyalanacak kayit bulunamadi.");
            return;
        }
        kayitlar.AddRange(kopyalananlar);
        foreach (var k in kopyalananlar) degisenSatirlar.Add(k);
        ToastService.ShowSuccess($"{kopyalananlar.Count} kayit yuklendi. Kaydetmek icin 'Tumunu Kaydet' dugmesine basin.");
    }

    private string SlotBadgeClass(SeferSlot slot) => slot switch
    {
        SeferSlot.Sabah => "bg-warning text-dark",
        SeferSlot.Aksam => "bg-info text-dark",
        SeferSlot.Mesai => "bg-secondary",
        _ => "bg-light text-dark"
    };

}
