@page "/planlama/dashboard"
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IKurumPuantajService PuantajService
@inject ILogger<PlanlamaDashboard> Logger

<PageTitle>Planlama Dashboard</PageTitle>

@if (yukleniyor)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Yukleniyor...</span></div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-1"><i class="bi bi-speedometer2 me-2"></i>Planlama Dashboard</h4>
                <p class="text-muted small mb-0">Operasyon KPI Ozeti</p>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <select class="form-select form-select-sm" style="width:80px" @bind="seciliYil" @bind:after="DonemDegisti">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                    { <option value="@y">@y</option> }
                </select>
                <select class="form-select form-select-sm" style="width:110px" @bind="seciliAy" @bind:after="DonemDegisti">
                    @for (int a = 1; a <= 12; a++)
                    { <option value="@a">@(new DateTime(2024, a, 1).ToString("MMMM"))</option> }
                </select>
                <button class="btn btn-outline-secondary btn-sm" @onclick="YenidenYukle" disabled="@yukleniyor">
                    <i class="bi bi-arrow-repeat"></i>
                </button>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body text-center py-3">
                        <h6 class="text-muted">Toplam Sefer</h6>
                        <h2 class="text-primary">@toplamSefer</h2>
                        @if (oncekiToplamSefer > 0)
                        {
                            var degisim = toplamSefer - oncekiToplamSefer;
                            <small class="@(degisim >= 0 ? "text-success" : "text-danger")">
                                <i class="bi @(degisim >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i> @Math.Abs(degisim)
                            </small>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(cakisanSayisi > 0 ? "border-danger" : "border-success")">
                    <div class="card-body text-center py-3">
                        <h6 class="text-muted">Cakisan Kayit</h6>
                        <h2 class="@(cakisanSayisi > 0 ? "text-danger" : "text-success")">@cakisanSayisi</h2>
                        @if (oncekiCakisanSayisi > 0)
                        {
                            var degisim = cakisanSayisi - oncekiCakisanSayisi;
                            <small class="@(degisim <= 0 ? "text-success" : "text-danger")">
                                <i class="bi @(degisim <= 0 ? "bi-arrow-down" : "bi-arrow-up")"></i> @Math.Abs(degisim)
                            </small>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body text-center py-3">
                        <h6 class="text-muted">Fatura Bekleyen</h6>
                        <h2 class="text-warning">@faturaBekleyen</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body text-center py-3">
                        <h6 class="text-muted">Tedarikci Kayit</h6>
                        <h2 class="text-info">@tedarikciSayisi</h2>
                    </div>
                </div>
            </div>
        </div>

        @if (toplamGelir > 0 || toplamGider > 0)
        {
            var netKar = toplamGelir - toplamGider;
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card border-success">
                        <div class="card-body text-center py-3">
                            <h6 class="text-muted">Toplam Gelir</h6>
                            <h3 class="text-success">@toplamGelir.ToString("N2") TL</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-danger">
                        <div class="card-body text-center py-3">
                            <h6 class="text-muted">Toplam Gider</h6>
                            <h3 class="text-danger">@toplamGider.ToString("N2") TL</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card @(netKar >= 0 ? "border-primary" : "border-danger")">
                        <div class="card-body text-center py-3">
                            <h6 class="text-muted">Net Kar/Zarar</h6>
                            <h3 class="@(netKar >= 0 ? "text-primary" : "text-danger")">@netKar.ToString("N2") TL</h3>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row g-3">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header"><i class="bi bi-clock me-2"></i>Slot Dagilimi</div>
                    <div class="card-body">
                        @foreach (var s in slotDagilimi)
                        {
                            var pct = toplamSefer > 0 ? (int)(s.Value * 100.0 / toplamSefer) : 0;
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@s.Key</span><span>@s.Value (@pct%)</span>
                                </div>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar @SlotBarClass(s.Key)" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header"><i class="bi bi-cash-stack me-2"></i>Finans Yonu</div>
                    <div class="card-body">
                        @foreach (var f in finansDagilimi)
                        {
                            var pct = toplamSefer > 0 ? (int)(f.Value * 100.0 / toplamSefer) : 0;
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@f.Key</span><span>@f.Value (@pct%)</span>
                                </div>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar @FinansBarClass(f.Key)" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header"><i class="bi bi-truck me-2"></i>Kaynak Tipi</div>
                    <div class="card-body">
                        @foreach (var k in kaynakDagilimi)
                        {
                            var pct = toplamSefer > 0 ? (int)(k.Value * 100.0 / toplamSefer) : 0;
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@k.Key</span><span>@k.Value (@pct%)</span>
                                </div>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar @(k.Key == "Kendi" ? "bg-primary" : "bg-secondary")" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (cakisanDetay.Any())
        {
            <div class="card mt-3 border-danger">
                <div class="card-header bg-danger text-white"><i class="bi bi-exclamation-triangle me-2"></i>Cakisma Detaylari</div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Gun</th><th>Slot</th><th>Kural</th><th>Mesaj</th></tr></thead>
                        <tbody>
                            @foreach (var c in cakisanDetay.Take(20))
                            {
                                <tr><td>@c.Gun</td><td>@c.Slot</td><td>@c.Kural</td><td>@c.Mesaj</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool yukleniyor = true;
    private int seciliYil = DateTime.Now.Year;
    private int seciliAy = DateTime.Now.Month;
    private string seciliAyAdi => new DateTime(2024, seciliAy, 1).ToString("MMMM");

    private int toplamSefer;
    private int cakisanSayisi;
    private int faturaBekleyen;
    private int tedarikciSayisi;
    private int oncekiToplamSefer;
    private int oncekiCakisanSayisi;
    private decimal toplamGelir;
    private decimal toplamGider;
    private Dictionary<string, int> slotDagilimi = new();
    private Dictionary<string, int> finansDagilimi = new();
    private Dictionary<string, int> kaynakDagilimi = new();
    private List<ConflictItem> cakisanDetay = new();

    protected override async Task OnInitializedAsync()
    {
        await VeriYukleAsync();
    }

    private async Task VeriYukleAsync()
    {
        yukleniyor = true;
        try
        {
            // Reset
            slotDagilimi.Clear(); finansDagilimi.Clear(); kaynakDagilimi.Clear();
            cakisanDetay.Clear();
            toplamSefer = cakisanSayisi = faturaBekleyen = tedarikciSayisi = 0;
            oncekiToplamSefer = oncekiCakisanSayisi = 0;
            toplamGelir = toplamGider = 0;

            var kayitlar = await PuantajService.GetPuantajlarAsync(seciliYil, seciliAy);
            toplamSefer = kayitlar.Count;

            // Onceki ay verisi (trend oklari icin)
            var oncekiAy = seciliAy == 1 ? 12 : seciliAy - 1;
            var oncekiYil = seciliAy == 1 ? seciliYil - 1 : seciliYil;
            var oncekiKayitlar = await PuantajService.GetPuantajlarAsync(oncekiYil, oncekiAy);
            oncekiToplamSefer = oncekiKayitlar.Count;
            if (oncekiKayitlar.Any())
            {
                var prevConflicts = await PuantajService.CheckConflictsAsync(oncekiKayitlar);
                oncekiCakisanSayisi = prevConflicts.Conflicts.Count;
            }

            if (kayitlar.Any())
            {
                toplamGelir = kayitlar.Sum(k => k.BirimGelir * k.Gun);
                toplamGider = kayitlar.Sum(k => k.BirimGider * k.Gun);
                slotDagilimi = kayitlar.GroupBy(k => k.Slot.ToString()).ToDictionary(g => g.Key, g => g.Count());
                finansDagilimi = kayitlar.GroupBy(k => k.FinansYonu.ToString()).ToDictionary(g => g.Key, g => g.Count());
                kaynakDagilimi = kayitlar.GroupBy(k => k.KaynakTipi.ToString()).ToDictionary(g => g.Key, g => g.Count());
                tedarikciSayisi = kayitlar.Count(k => k.KaynakTipi == PlanlamaKaynakTipi.Tedarikci);
                faturaBekleyen = kayitlar.Count(k => !k.GelirFaturaKesildi && k.BirimGelir > 0 && k.Gun > 0);
                var conflicts = await PuantajService.CheckConflictsAsync(kayitlar);
                cakisanSayisi = conflicts.Conflicts.Count;
                cakisanDetay = conflicts.Conflicts.Take(50).ToList();
            }
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Dashboard verisi yuklenemedi"); }
        finally { yukleniyor = false; }
    }

    private async Task DonemDegisti() => await VeriYukleAsync();
    private async Task YenidenYukle() => await VeriYukleAsync();

    private string SlotBarClass(string slot) => slot switch
    {
        "Sabah" => "bg-warning",
        "Aksam" => "bg-info",
        "Mesai" => "bg-secondary",
        _ => "bg-light"
    };

    private string FinansBarClass(string yon) => yon switch
    {
        "Gelen" => "bg-success",
        "Giden" => "bg-danger",
        "IcDagitim" => "bg-info",
        _ => "bg-light"
    };
}
