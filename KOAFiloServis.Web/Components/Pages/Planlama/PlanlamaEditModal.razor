@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IGuzergahSeferService GuzergahSeferService

<div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi @(Kayit.Id > 0 ? "bi-pencil" : "bi-plus-circle") me-2"></i>
                    @(Kayit.Id > 0 ? "Sefer Duzenle" : "Yeni Sefer")
                </h5>
                <button type="button" class="btn-close" @onclick="OnKapat"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Kurum</label>
                        <select class="form-select" @bind="Kayit.KurumId">
                            <option value="">Seciniz...</option>
                            @foreach (var k in Kurumlar)
                            {
                                <option value="@k.Id">@k.KurumAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Isveren Firma</label>
                        <select class="form-select" @bind="Kayit.IsverenFirmaId">
                            <option value="">Seciniz...</option>
                            @foreach (var f in Firmalar)
                            {
                                <option value="@f.Id">@f.FirmaAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Guzergah</label>
                        <select class="form-select" @bind="Kayit.GuzergahId" @bind:after="GuzergahDegisti">
                            <option value="">Seciniz...</option>
                            @foreach (var g in GuzergahListesi)
                            {
                                <option value="@g.Id">@g.GuzergahAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Slot</label>
                        <select class="form-select" @bind="Kayit.Slot">
                            @foreach (SeferSlot s in Enum.GetValues<SeferSlot>())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Yon</label>
                        <select class="form-select" @bind="Kayit.Yon">
                            @foreach (PuantajYon y in Enum.GetValues<PuantajYon>())
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Arac</label>
                        <select class="form-select" @bind="Kayit.AracId">
                            <option value="">Seciniz...</option>
                            @foreach (var a in filtrelenmisAraclar)
                            {
                                <option value="@a.Id">@a.AktifPlaka</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Sofor</label>
                        <select class="form-select" @bind="Kayit.SoforId">
                            <option value="">Seciniz...</option>
                            @foreach (var s in SoforListesi)
                            {
                                <option value="@s.Id">@s.TamAd</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sefer Sayisi</label>
                        <input type="number" class="form-control" @bind="Kayit.SeferSayisi" min="1" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Gun (Carpan) <small class="text-muted">- gun grid'den otomatik</small></label>
                        <input type="number" class="form-control" @bind="Kayit.Gun" step="0.5" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Kaynak Tipi *</label>
                        <select class="form-select" @bind="Kayit.KaynakTipi">
                            @foreach (PlanlamaKaynakTipi t in Enum.GetValues<PlanlamaKaynakTipi>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Finans Yonu *</label>
                        <select class="form-select" @bind="Kayit.FinansYonu">
                            @foreach (PlanlamaFinansYonu f in Enum.GetValues<PlanlamaFinansYonu>())
                            {
                                <option value="@f">@f</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sofor Odeme Tipi</label>
                        <select class="form-select" @bind="Kayit.SoforOdemeTipi">
                            @foreach (SoforOdemeTipi t in Enum.GetValues<SoforOdemeTipi>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Birim Gelir</label>
                        <input type="number" class="form-control" @bind="Kayit.BirimGelir" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Birim Gider</label>
                        <input type="number" class="form-control" @bind="Kayit.BirimGider" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Belge No</label>
                        <input type="text" class="form-control" @bind="Kayit.BelgeNo" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Transfer Durum</label>
                        <select class="form-select" @bind="Kayit.TransferDurum">
                            <option value="">Yok</option>
                            <option value="Bekliyor">Bekliyor</option>
                            <option value="Aktarildi">Aktarıldı</option>
                            <option value="Iptal">İptal</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Onay Durumu</label>
                        <select class="form-select" @bind="Kayit.OnayDurum" @bind:after="OnayDurumDegisti">
                            @foreach (PuantajOnayDurum d in Enum.GetValues<PuantajOnayDurum>())
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notlar</label>
                        <textarea class="form-control" rows="2" @bind="Kayit.Notlar"></textarea>
                    </div>

                    @* Gun Bazli Puantaj Grid *@
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-header py-2 d-flex justify-content-between align-items-center"
                                 @onclick="() => gunGridAcik = !gunGridAcik" style="cursor:pointer;">
                                <span><i class="bi bi-calendar3 me-2"></i>Gun Bazli Puantaj</span>
                                <div>
                                    <span class="badge bg-primary me-2">Toplam: @Kayit.SeferGunuToplami gun</span>
                                    <i class="bi @(gunGridAcik ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                </div>
                            </div>
                            @if (gunGridAcik)
                            {
                                <div class="card-body py-2">
                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => HepsiniSec(1)" title="Tum gunlere tek sefer ata">
                                            <i class="bi bi-grid me-1"></i>Tum Gunler Tek
                                        </button>
                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => HepsiniSec(2)" title="Tum gunlere S+A ata">
                                            <i class="bi bi-grid-fill me-1"></i>Tum Gunler S+A
                                        </button>
                                        <button class="btn btn-outline-success btn-sm" @onclick="() => SadeceHaftaIci(1)" title="Sadece hafta ici tek sefer">
                                            <i class="bi bi-briefcase me-1"></i>Sadece HaftaIci
                                        </button>
                                        <button class="btn btn-outline-success btn-sm" @onclick="() => SadeceHaftaIci(2)" title="Sadece hafta ici S+A">
                                            <i class="bi bi-briefcase-fill me-1"></i>HI S+A
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="Temizle" title="Tum gunleri sifirla">
                                            <i class="bi bi-eraser me-1"></i>Temizle
                                        </button>
                                    </div>
                                    <div class="d-flex flex-column gap-1">
                                        @for (int hafta = 0; hafta < 5; hafta++)
                                        {
                                            <div class="d-flex gap-1">
                                                @for (int gun = hafta * 7 + 1; gun <= Math.Min(hafta * 7 + 7, 31); gun++)
                                                {
                                                    var gunNo = gun;
                                                    var deger = Kayit.GetGunDeger(gunNo);
                                                    var cellClass = deger switch
                                                    {
                                                        2 => "bg-primary text-white",
                                                        1 => "bg-primary bg-opacity-25",
                                                        _ => "bg-white"
                                                    };
                                                    <div class="text-center rounded @cellClass"
                                                         style="width:36px; height:36px; line-height:36px; font-size:12px; cursor:pointer; border:1px solid #dee2e6; user-select:none;"
                                                         @onclick="() => GunToggle(gunNo)"
                                                         title="Gun @gunNo: @(deger == 2 ? "S+A" : deger == 1 ? "Tek Sefer" : "Gitmedi")">
                                                        @gunNo
                                                    </div>
                                                }
                                                @for (int bos = (hafta * 7 + 7) - 31; bos > 0 && bos < 7; bos--)
                                                {
                                                    <div style="width:36px;"></div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-2 small text-muted">
                                        <span class="me-2"><span class="badge bg-white text-dark border">1</span> Gitmedi</span>
                                        <span class="me-2"><span class="badge bg-primary bg-opacity-25">1</span> Tek Sefer</span>
                                        <span><span class="badge bg-primary">1</span> S+A</span>
                                        <span class="ms-2">(tiklayarak degistir: 0 → 1 → 2 → 0)</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="OnKapat">Iptal</button>
                <button type="button" class="btn btn-primary" @onclick="Kaydet" disabled="@kaydediliyor">
                    <i class="bi bi-save me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PuantajKayit Kayit { get; set; } = null!;
    [Parameter, EditorRequired] public List<Kurum> Kurumlar { get; set; } = null!;
    [Parameter, EditorRequired] public List<Firma> Firmalar { get; set; } = null!;
    [Parameter, EditorRequired] public List<Guzergah> GuzergahListesi { get; set; } = null!;
    [Parameter, EditorRequired] public List<Arac> AracListesi { get; set; } = null!;
    [Parameter, EditorRequired] public List<Sofor> SoforListesi { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback<PuantajKayit> OnKaydet { get; set; }
    [Parameter, EditorRequired] public EventCallback OnKapat { get; set; }

    private bool kaydediliyor;
    private bool gunGridAcik = true;
    private List<Arac> filtrelenmisAraclar = new();

    private void GunToggle(int gun)
    {
        var mevcut = Kayit.GetGunDeger(gun);
        var yeni = mevcut >= 2 ? 0 : mevcut + 1;
        Kayit.SetGunDeger(gun, yeni);
        Kayit.HesaplaPuantajToplam();
    }

    private void HepsiniSec(int deger)
    {
        for (int g = 1; g <= 31; g++)
            Kayit.SetGunDeger(g, deger);
        Kayit.HesaplaPuantajToplam();
    }

    private void SadeceHaftaIci(int deger)
    {
        // Hedef ayin ilk gunune gore hafta ici hesapla
        var ilkGun = new DateTime(Kayit.Yil > 0 ? Kayit.Yil : DateTime.Now.Year, Kayit.Ay > 0 ? Kayit.Ay : 1, 1);
        for (int g = 1; g <= DateTime.DaysInMonth(ilkGun.Year, ilkGun.Month); g++)
        {
            var tarih = new DateTime(ilkGun.Year, ilkGun.Month, g);
            Kayit.SetGunDeger(g, tarih.DayOfWeek is not (DayOfWeek.Saturday or DayOfWeek.Sunday) ? deger : 0);
        }
        for (int g = DateTime.DaysInMonth(ilkGun.Year, ilkGun.Month) + 1; g <= 31; g++)
            Kayit.SetGunDeger(g, 0);
        Kayit.HesaplaPuantajToplam();
    }

    private void Temizle()
    {
        for (int g = 1; g <= 31; g++)
            Kayit.SetGunDeger(g, 0);
        Kayit.HesaplaPuantajToplam();
    }

    protected override void OnParametersSet()
    {
        filtrelenmisAraclar = AracListesi;
    }

    private async Task GuzergahDegisti()
    {
        if (!Kayit.GuzergahId.HasValue)
        {
            filtrelenmisAraclar = AracListesi;
            return;
        }

        var seferler = await GuzergahSeferService.GetByGuzergahIdAsync(Kayit.GuzergahId.Value);
        var seferAracIds = seferler.Where(s => s.AracId.HasValue).Select(s => s.AracId!.Value).Distinct().ToList();

        filtrelenmisAraclar = seferAracIds.Any()
            ? AracListesi.Where(a => seferAracIds.Contains(a.Id)).ToList()
            : AracListesi;
    }

    private void OnayDurumDegisti()
    {
        if (Kayit.OnayDurum == PuantajOnayDurum.Onaylandi)
        {
            Kayit.OnaylayanKullanici ??= "manuel";
            Kayit.OnayTarihi = DateTime.UtcNow;
        }
        else if (Kayit.OnayDurum == PuantajOnayDurum.Taslak)
        {
            Kayit.OnaylayanKullanici = null;
            Kayit.OnayTarihi = null;
        }
    }

    private async Task Kaydet()
    {
        kaydediliyor = true;
        try
        {
            await OnKaydet.InvokeAsync(Kayit);
        }
        finally { kaydediliyor = false; }
    }
}
