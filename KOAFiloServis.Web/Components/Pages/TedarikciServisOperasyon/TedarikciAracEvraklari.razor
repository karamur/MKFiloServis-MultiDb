@page "/tedarikci-servis/arac-evraklari"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using ClosedXML.Excel
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@inject IAracService AracService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Tedarikçi Araç Evrakları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-folder2-open me-2"></i>Tedarikçi Araç Evrakları</h3>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-secondary" @onclick="OnizlemeAc" disabled="@(!FiltreliAraclar.Any())">
                <i class="bi bi-eye me-1"></i>Önizleme
            </button>
            <button class="btn btn-outline-danger" @onclick="PdfAktar" disabled="@(!FiltreliAraclar.Any())">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelAktar" disabled="@(!FiltreliAraclar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/personel-tasima/tedarikciler")'>
                <i class="bi bi-truck me-1"></i>Tedarikçi Yönetimi
            </button>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/arac-evraklari")'>
                <i class="bi bi-table me-1"></i>Genel Evrak Takibi
            </button>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small">Ara (Plaka, Şase, Marka/Model)</label>
                    <input class="form-control form-control-sm" @bind="arama" @bind:event="oninput" placeholder="Arama..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="seciliTedarikciId">
                        <option value="0">Tümü</option>
                        @foreach (var t in tedarikciler)
                        {
                            <option value="@t.Id">@t.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Sahiplik</label>
                    <select class="form-select form-select-sm" @bind="filtreSahiplikTipi">
                        <option value="Tumu">Tümü</option>
                        @foreach (AracSahiplikTipi sahiplik in Enum.GetValues(typeof(AracSahiplikTipi)))
                        {
                            <option value="@sahiplik.ToString()">@GetSahiplikText(sahiplik)</option>
                        }
                    </select>
                    <div class="form-check form-check-sm mt-1">
                        <input class="form-check-input" type="checkbox" id="chkEvrSahiplikHaric" @bind="filtreSahiplikHaric" disabled="@(filtreSahiplikTipi == "Tumu")" />
                        <label class="form-check-label small text-muted" for="chkEvrSahiplikHaric">Hariç tut</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Evrak Durumu</label>
                    <select class="form-select form-select-sm" @bind="filtreEvrakDurum">
                        <option value="Tumu">Tümü</option>
                        <option value="Dolmus">Süresi Dolmuş</option>
                        <option value="Yaklasan">30 Gün İçinde Bitiyor</option>
                        <option value="Gecerli">Geçerli</option>
                        <option value="Eksik">Eksik (Tarih Yok)</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button class="btn btn-secondary btn-sm w-100" @onclick="FiltreleriTemizle">
                        <i class="bi bi-x-circle"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!yukleniyor)
    {
        <div class="row g-2 mb-3">
            <div class="col-md-2">
                <div class="card border-primary"><div class="card-body py-2">
                    <small class="text-muted">Filtre Sonucu</small>
                    <div class="fs-4 fw-bold text-primary">@FiltreliAraclar.Count()</div>
                </div></div>
            </div>
            <div class="col-md-2">
                <div class="card border-success"><div class="card-body py-2">
                    <small class="text-muted">Tüm Evraklar Geçerli</small>
                    <div class="fs-4 fw-bold text-success">@FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Gecerli")</div>
                </div></div>
            </div>
            <div class="col-md-2">
                <div class="card border-warning"><div class="card-body py-2">
                    <small class="text-muted">30 Gün İçinde</small>
                    <div class="fs-4 fw-bold text-warning">@FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Yaklasan")</div>
                </div></div>
            </div>
            <div class="col-md-2">
                <div class="card border-danger"><div class="card-body py-2">
                    <small class="text-muted">Süresi Dolmuş</small>
                    <div class="fs-4 fw-bold text-danger">@FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Dolmus")</div>
                </div></div>
            </div>
            <div class="col-md-2">
                <div class="card border-secondary"><div class="card-body py-2">
                    <small class="text-muted">Eksik Tarih</small>
                    <div class="fs-4 fw-bold text-secondary">@FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Eksik")</div>
                </div></div>
            </div>
            <div class="col-md-2">
                <div class="card border-info"><div class="card-body py-2">
                    <small class="text-muted">Tedarikçi Sayısı</small>
                    <div class="fs-4 fw-bold text-info">@FiltreliAraclar.Select(a => a.TasimaTedarikciId).Distinct().Count()</div>
                </div></div>
            </div>
        </div>
    }

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!FiltreliAraclar.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <span>
                    <i class="bi bi-folder2-open me-1"></i>Tedarikçi Araç Evrakları
                    <span class="badge bg-secondary ms-1">@FiltreliAraclar.Count() kayıt</span>
                </span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Plaka</th>
                                <th>Şase No</th>
                                <th>Marka / Model</th>
                                <th>Tedarikçi</th>
                                <th>Muayene</th>
                                <th>Trafik Sigorta</th>
                                <th>Kasko</th>
                                <th>Koltuk Sig.</th>
                                <th>Genel Durum</th>
                                <th class="text-end">Evrak İşlemi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var arac in FiltreliAraclar)
                            {
                                var genel = GetAracEvrakDurumu(arac);
                                <tr>
                                    <td><strong>@(arac.AktifPlaka ?? "-")</strong></td>
                                    <td><small class="text-muted">@arac.SaseNo</small></td>
                                    <td>@arac.Marka @arac.Model</td>
                                    <td><span class="badge bg-info text-dark">@GetTedarikciEtiket(arac.TasimaTedarikciId)</span></td>
                                    <td>@TarihRozet(arac.MuayeneBitisTarihi)</td>
                                    <td>@TarihRozet(arac.TrafikSigortaBitisTarihi)</td>
                                    <td>@TarihRozet(arac.KaskoBitisTarihi)</td>
                                    <td>@TarihRozet(arac.KoltukSigortasiBitisTarihi)</td>
                                    <td><span class="badge @GenelDurumBadgeClass(genel)">@GenelDurumText(genel)</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-warning" @onclick='() => Navigation.NavigateTo($"/araclar/{arac.Id}/evraklar")'>
                                            <i class="bi bi-folder2-open me-1"></i>Evraklar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showOnizlemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Rapor Önizleme - Tedarikçi Araç Evrakları (@FiltreliAraclar.Count() kayıt)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOnizlemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-primary">Toplam: @FiltreliAraclar.Count()</span>
                        <span class="badge bg-success">Geçerli: @FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Gecerli")</span>
                        <span class="badge bg-warning text-dark">Yaklaşan: @FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Yaklasan")</span>
                        <span class="badge bg-danger">Süresi Dolmuş: @FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Dolmus")</span>
                        <span class="badge bg-secondary">Eksik: @FiltreliAraclar.Count(a => GetAracEvrakDurumu(a) == "Eksik")</span>
                    </div>

                    @{
                        var tedarikciGruplari = FiltreliAraclar
                            .GroupBy(a => GetTedarikciEtiket(a.TasimaTedarikciId))
                            .OrderByDescending(g => g.Count())
                            .ToList();
                    }

                    <div class="card mb-3">
                        <div class="card-header py-2 bg-light"><strong><i class="bi bi-truck me-1"></i>Tedarikçiye Göre Evrak Durumu</strong></div>
                        <div class="card-body py-2">
                            <table class="table table-sm mb-0">
                                <thead><tr>
                                    <th>Tedarikçi</th>
                                    <th class="text-end">Araç</th>
                                    <th class="text-end">Geçerli</th>
                                    <th class="text-end">Yaklaşan</th>
                                    <th class="text-end">Dolmuş</th>
                                    <th class="text-end">Eksik</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var g in tedarikciGruplari)
                                    {
                                        <tr>
                                            <td>@g.Key</td>
                                            <td class="text-end">@g.Count()</td>
                                            <td class="text-end text-success">@g.Count(a => GetAracEvrakDurumu(a) == "Gecerli")</td>
                                            <td class="text-end text-warning">@g.Count(a => GetAracEvrakDurumu(a) == "Yaklasan")</td>
                                            <td class="text-end text-danger">@g.Count(a => GetAracEvrakDurumu(a) == "Dolmus")</td>
                                            <td class="text-end text-secondary">@g.Count(a => GetAracEvrakDurumu(a) == "Eksik")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Plaka</th>
                                    <th>Şase</th>
                                    <th>Marka/Model</th>
                                    <th>Tedarikçi</th>
                                    <th>Muayene</th>
                                    <th>Trafik</th>
                                    <th>Kasko</th>
                                    <th>Koltuk Sig.</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var ix = 1; }
                                @foreach (var a in FiltreliAraclar)
                                {
                                    var d = GetAracEvrakDurumu(a);
                                    <tr>
                                        <td>@(ix++)</td>
                                        <td><strong>@(a.AktifPlaka ?? "-")</strong></td>
                                        <td><small>@a.SaseNo</small></td>
                                        <td>@a.Marka @a.Model</td>
                                        <td><small>@GetTedarikciEtiket(a.TasimaTedarikciId)</small></td>
                                        <td>@TarihRozet(a.MuayeneBitisTarihi)</td>
                                        <td>@TarihRozet(a.TrafikSigortaBitisTarihi)</td>
                                        <td>@TarihRozet(a.KaskoBitisTarihi)</td>
                                        <td>@TarihRozet(a.KoltukSigortasiBitisTarihi)</td>
                                        <td><span class="badge @GenelDurumBadgeClass(d)">@GenelDurumText(d)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger" @onclick="PdfAktar"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</button>
                    <button class="btn btn-outline-success" @onclick="ExcelAktar"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary" @onclick="() => showOnizlemeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool yukleniyor = true;
    private bool showOnizlemeModal;
    private string arama = string.Empty;
    private int seciliTedarikciId;
    private string filtreEvrakDurum = "Tumu";
    private string filtreSahiplikTipi = nameof(AracSahiplikTipi.Tedarikci);
    private bool filtreSahiplikHaric;
    private List<Arac> araclar = new();
    private List<TasimaTedarikci> tedarikciler = new();

    private IEnumerable<Arac> FiltreliAraclar => araclar
        .Where(a => a.TasimaTedarikciId.HasValue)
        .Where(a => seciliTedarikciId == 0 || a.TasimaTedarikciId == seciliTedarikciId)
        .Where(a => SahiplikUygun(a))
        .Where(a => filtreEvrakDurum == "Tumu" || GetAracEvrakDurumu(a) == filtreEvrakDurum)
        .Where(a => string.IsNullOrWhiteSpace(arama)
            || (a.AktifPlaka?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (a.SaseNo?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (a.Marka?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (a.Model?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || GetTedarikciEtiket(a.TasimaTedarikciId).Contains(arama, StringComparison.OrdinalIgnoreCase))
        .OrderBy(a => a.AktifPlaka);

    protected override async Task OnInitializedAsync()
    {
        tedarikciler = await TasimaTedarikciService.GetAllAsync(sadeceAktif: false);
        araclar = await AracService.GetAllAsync();
        yukleniyor = false;
    }

    private void FiltreleriTemizle()
    {
        arama = string.Empty;
        seciliTedarikciId = 0;
        filtreEvrakDurum = "Tumu";
        filtreSahiplikTipi = nameof(AracSahiplikTipi.Tedarikci);
        filtreSahiplikHaric = false;
    }

    private bool SahiplikUygun(Arac a)
    {
        if (filtreSahiplikTipi == "Tumu") return true;
        if (!Enum.TryParse<AracSahiplikTipi>(filtreSahiplikTipi, out var s)) return true;
        return filtreSahiplikHaric ? a.SahiplikTipi != s : a.SahiplikTipi == s;
    }

    private static string GetSahiplikText(AracSahiplikTipi sahiplik) => sahiplik switch
    {
        AracSahiplikTipi.Ozmal => "Özmal",
        AracSahiplikTipi.Kiralik => "Kiralık",
        AracSahiplikTipi.Komisyon => "Komisyon",
        AracSahiplikTipi.Diger => "Diğer",
        AracSahiplikTipi.Tedarikci => "Tedarikçi",
        _ => sahiplik.ToString()
    };

    private void OnizlemeAc() => showOnizlemeModal = true;

    private string GetTedarikciUnvan(int? id)
    {
        if (!id.HasValue) return "-";
        return tedarikciler.FirstOrDefault(t => t.Id == id.Value)?.Unvan ?? "-";
    }

    private string GetTedarikciEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t is null) return "-";
        return string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}";
    }

    // Tek bir tarih için durum
    private static string TarihDurum(DateTime? tarih)
    {
        if (!tarih.HasValue) return "Eksik";
        var gun = (tarih.Value - DateTime.Today).Days;
        if (gun < 0) return "Dolmus";
        if (gun < 30) return "Yaklasan";
        return "Gecerli";
    }

    // Aracın tüm evraklarına bakarak en kötü durumu döner.
    // Öncelik: Dolmus > Yaklasan > Eksik > Gecerli
    private static string GetAracEvrakDurumu(Arac a)
    {
        var tarihler = new[] { a.MuayeneBitisTarihi, a.TrafikSigortaBitisTarihi, a.KaskoBitisTarihi, a.KoltukSigortasiBitisTarihi };
        var durumlar = tarihler.Select(TarihDurum).ToList();
        if (durumlar.Contains("Dolmus")) return "Dolmus";
        if (durumlar.Contains("Yaklasan")) return "Yaklasan";
        if (durumlar.Contains("Eksik")) return "Eksik";
        return "Gecerli";
    }

    private static string GenelDurumText(string d) => d switch
    {
        "Gecerli" => "Geçerli",
        "Yaklasan" => "30 Gün İçinde",
        "Dolmus" => "Süresi Dolmuş",
        "Eksik" => "Eksik Tarih",
        _ => d
    };

    private static string GenelDurumBadgeClass(string d) => d switch
    {
        "Gecerli" => "bg-success",
        "Yaklasan" => "bg-warning text-dark",
        "Dolmus" => "bg-danger",
        "Eksik" => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static MarkupString TarihRozet(DateTime? tarih)
    {
        if (!tarih.HasValue)
            return new MarkupString("<span class=\"badge bg-light text-muted\">-</span>");
        var d = TarihDurum(tarih);
        var cls = d switch
        {
            "Dolmus" => "bg-danger",
            "Yaklasan" => "bg-warning text-dark",
            _ => "bg-success"
        };
        return new MarkupString($"<span class=\"badge {cls}\">{tarih.Value:dd.MM.yyyy}</span>");
    }

    private async Task ExcelAktar()
    {
        try
        {
            var data = FiltreliAraclar.ToList();
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            using var workbook = new XLWorkbook();

            // Özet
            var ozet = workbook.Worksheets.Add("Özet");
            ozet.Cell(1, 1).Value = "TEDARİKÇİ ARAÇ EVRAK RAPORU";
            ozet.Range(1, 1, 1, 6).Merge();
            ozet.Cell(1, 1).Style.Font.Bold = true;
            ozet.Cell(1, 1).Style.Font.FontSize = 16;
            ozet.Cell(1, 1).Style.Fill.BackgroundColor = XLColor.DarkBlue;
            ozet.Cell(1, 1).Style.Font.FontColor = XLColor.White;
            ozet.Cell(1, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ozet.Row(1).Height = 28;

            ozet.Cell(2, 1).Value = $"Oluşturma: {DateTime.Now:dd.MM.yyyy HH:mm}";
            ozet.Range(2, 1, 2, 6).Merge();
            ozet.Cell(2, 1).Style.Font.Italic = true;

            int r = 4;
            ozet.Cell(r, 1).Value = "GENEL DURUM";
            ozet.Range(r, 1, r, 6).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;

            void Stat(string label, object value, XLColor? bg = null)
            {
                ozet.Cell(r, 1).Value = label;
                ozet.Cell(r, 2).Value = XLCellValue.FromObject(value);
                ozet.Cell(r, 1).Style.Font.Bold = true;
                if (bg != null)
                {
                    ozet.Cell(r, 2).Style.Fill.BackgroundColor = bg;
                    ozet.Cell(r, 2).Style.Font.Bold = true;
                }
                r++;
            }
            Stat("Toplam Araç", data.Count);
            Stat("Tüm Evrakları Geçerli", data.Count(a => GetAracEvrakDurumu(a) == "Gecerli"), XLColor.LightGreen);
            Stat("30 Gün İçinde Bitiyor", data.Count(a => GetAracEvrakDurumu(a) == "Yaklasan"), XLColor.LightYellow);
            Stat("Süresi Dolmuş", data.Count(a => GetAracEvrakDurumu(a) == "Dolmus"), XLColor.LightPink);
            Stat("Eksik Tarih", data.Count(a => GetAracEvrakDurumu(a) == "Eksik"), XLColor.LightGray);
            Stat("Tedarikçi Sayısı", data.Select(a => a.TasimaTedarikciId).Distinct().Count());

            r += 2;
            ozet.Cell(r, 1).Value = "TEDARİKÇİYE GÖRE EVRAK DAĞILIMI";
            ozet.Range(r, 1, r, 6).Merge();
            ozet.Cell(r, 1).Style.Font.Bold = true;
            ozet.Cell(r, 1).Style.Fill.BackgroundColor = XLColor.LightSteelBlue;
            r++;
            ozet.Cell(r, 1).Value = "Tedarikçi";
            ozet.Cell(r, 2).Value = "Araç";
            ozet.Cell(r, 3).Value = "Geçerli";
            ozet.Cell(r, 4).Value = "Yaklaşan";
            ozet.Cell(r, 5).Value = "Dolmuş";
            ozet.Cell(r, 6).Value = "Eksik";
            ozet.Range(r, 1, r, 6).Style.Font.Bold = true;
            ozet.Range(r, 1, r, 6).Style.Fill.BackgroundColor = XLColor.Gainsboro;
            r++;
            foreach (var g in data.GroupBy(a => GetTedarikciEtiket(a.TasimaTedarikciId)).OrderByDescending(g => g.Count()))
            {
                ozet.Cell(r, 1).Value = g.Key;
                ozet.Cell(r, 2).Value = g.Count();
                ozet.Cell(r, 3).Value = g.Count(a => GetAracEvrakDurumu(a) == "Gecerli");
                ozet.Cell(r, 4).Value = g.Count(a => GetAracEvrakDurumu(a) == "Yaklasan");
                ozet.Cell(r, 5).Value = g.Count(a => GetAracEvrakDurumu(a) == "Dolmus");
                ozet.Cell(r, 6).Value = g.Count(a => GetAracEvrakDurumu(a) == "Eksik");
                r++;
            }
            ozet.Columns().AdjustToContents();

            // Detay
            var ws = workbook.Worksheets.Add("Detay");
            var headers = new[] { "S.NO", "TEDARİKÇİ", "PLAKA", "ŞASE NO", "MARKA", "MODEL", "MUAYENE", "TRAFİK SİG.", "KASKO", "KOLTUK SİG.", "GENEL DURUM" };
            for (int i = 0; i < headers.Length; i++)
                ws.Cell(1, i + 1).Value = headers[i];

            var hr = ws.Range(1, 1, 1, headers.Length);
            hr.Style.Font.Bold = true;
            hr.Style.Font.FontColor = XLColor.White;
            hr.Style.Fill.BackgroundColor = XLColor.DarkBlue;
            hr.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ws.Row(1).Height = 22;

            int row = 2;
            int sira = 1;

            void TarihHucresi(int rIdx, int cIdx, DateTime? tarih)
            {
                if (!tarih.HasValue)
                {
                    ws.Cell(rIdx, cIdx).Value = "-";
                    ws.Cell(rIdx, cIdx).Style.Fill.BackgroundColor = XLColor.LightGray;
                    return;
                }
                ws.Cell(rIdx, cIdx).Value = tarih.Value;
                ws.Cell(rIdx, cIdx).Style.DateFormat.Format = "dd.MM.yyyy";
                var gun = (tarih.Value - DateTime.Today).Days;
                if (gun < 0) ws.Cell(rIdx, cIdx).Style.Fill.BackgroundColor = XLColor.LightPink;
                else if (gun < 30) ws.Cell(rIdx, cIdx).Style.Fill.BackgroundColor = XLColor.LightYellow;
                else ws.Cell(rIdx, cIdx).Style.Fill.BackgroundColor = XLColor.LightGreen;
            }

            foreach (var a in data)
            {
                ws.Cell(row, 1).Value = sira++;
                ws.Cell(row, 2).Value = GetTedarikciEtiket(a.TasimaTedarikciId);
                ws.Cell(row, 3).Value = a.AktifPlaka ?? string.Empty;
                ws.Cell(row, 4).Value = a.SaseNo;
                ws.Cell(row, 5).Value = a.Marka ?? string.Empty;
                ws.Cell(row, 6).Value = a.Model ?? string.Empty;
                TarihHucresi(row, 7, a.MuayeneBitisTarihi);
                TarihHucresi(row, 8, a.TrafikSigortaBitisTarihi);
                TarihHucresi(row, 9, a.KaskoBitisTarihi);
                TarihHucresi(row, 10, a.KoltukSigortasiBitisTarihi);

                var d = GetAracEvrakDurumu(a);
                ws.Cell(row, 11).Value = GenelDurumText(d);
                ws.Cell(row, 11).Style.Fill.BackgroundColor = d switch
                {
                    "Gecerli" => XLColor.LightGreen,
                    "Yaklasan" => XLColor.LightYellow,
                    "Dolmus" => XLColor.LightPink,
                    _ => XLColor.LightGray
                };
                ws.Cell(row, 11).Style.Font.Bold = true;
                row++;
            }

            ws.Range(1, 1, row - 1, headers.Length).Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
            ws.Range(1, 1, row - 1, headers.Length).Style.Border.InsideBorder = XLBorderStyleValues.Thin;
            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(1);
            ws.RangeUsed()!.SetAutoFilter();

            using var ms = new MemoryStream();
            workbook.SaveAs(ms);
            var bytes = ms.ToArray();
            var fileName = $"tedarikci-arac-evrak-rapor-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
            ToastService.ShowSuccess("Excel raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel aktarım hatası: {ex.Message}");
        }
    }

    private async Task PdfAktar()
    {
        try
        {
            var data = FiltreliAraclar.ToList();
            if (!data.Any()) { ToastService.ShowWarning("Aktarılacak kayıt yok."); return; }

            QuestPDF.Settings.License = LicenseType.Community;

            var tedarikciGruplari = data
                .GroupBy(a => GetTedarikciEtiket(a.TasimaTedarikciId))
                .OrderByDescending(g => g.Count())
                .ToList();

            var document = Document.Create(container =>
            {
                container.Page(page =>
                {
                    page.Size(PageSizes.A4.Landscape());
                    page.Margin(20);
                    page.DefaultTextStyle(x => x.FontSize(8));

                    page.Header().Column(col =>
                    {
                        col.Item().Background(Colors.Blue.Darken3).Padding(10).Column(c =>
                        {
                            c.Item().Text("TEDARİKÇİ ARAÇ EVRAK RAPORU").Bold().FontSize(16).FontColor(Colors.White);
                            c.Item().Text("KOA Filo Servis").FontSize(9).FontColor(Colors.Grey.Lighten2);
                        });
                        col.Item().PaddingTop(4).Row(row =>
                        {
                            row.RelativeItem().Text($"Oluşturma: {DateTime.Now:dd.MM.yyyy HH:mm}").FontSize(8).FontColor(Colors.Grey.Darken2);
                            row.RelativeItem().AlignRight().Text($"Toplam Kayıt: {data.Count}").Bold().FontSize(9);
                        });
                    });

                    page.Content().PaddingVertical(8).Column(content =>
                    {
                        content.Spacing(8);

                        // Özet kartlar
                        content.Item().Row(row =>
                        {
                            row.Spacing(5);
                            void Kart(QuestPDF.Infrastructure.IContainer c, string baslik, string deger, string bg)
                            {
                                c.Background(bg).Padding(6).Column(k =>
                                {
                                    k.Item().Text(baslik).FontSize(7).FontColor(Colors.White);
                                    k.Item().Text(deger).Bold().FontSize(13).FontColor(Colors.White);
                                });
                            }
                            Kart(row.RelativeItem(), "Toplam", data.Count.ToString(), Colors.Blue.Darken2);
                            Kart(row.RelativeItem(), "Geçerli", data.Count(a => GetAracEvrakDurumu(a) == "Gecerli").ToString(), Colors.Green.Darken1);
                            Kart(row.RelativeItem(), "Yaklaşan", data.Count(a => GetAracEvrakDurumu(a) == "Yaklasan").ToString(), Colors.Orange.Darken2);
                            Kart(row.RelativeItem(), "Dolmuş", data.Count(a => GetAracEvrakDurumu(a) == "Dolmus").ToString(), Colors.Red.Darken1);
                            Kart(row.RelativeItem(), "Eksik", data.Count(a => GetAracEvrakDurumu(a) == "Eksik").ToString(), Colors.Grey.Darken2);
                            Kart(row.RelativeItem(), "Tedarikçi", data.Select(a => a.TasimaTedarikciId).Distinct().Count().ToString(), Colors.Teal.Darken2);
                        });

                        // Tedarikçi dağılım tablosu
                        content.Item().Border(1).BorderColor(Colors.Grey.Lighten1).Column(col =>
                        {
                            col.Item().Background(Colors.Blue.Lighten4).Padding(5).Text("TEDARİKÇİYE GÖRE EVRAK DURUMU").Bold().FontSize(9);
                            col.Item().Table(t =>
                            {
                                t.ColumnsDefinition(c =>
                                {
                                    c.RelativeColumn(4);
                                    c.RelativeColumn(1);
                                    c.RelativeColumn(1);
                                    c.RelativeColumn(1);
                                    c.RelativeColumn(1);
                                    c.RelativeColumn(1);
                                });
                                t.Header(h =>
                                {
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text("Tedarikçi").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Araç").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Geçerli").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Yaklaşan").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Dolmuş").Bold().FontSize(8);
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).AlignRight().Text("Eksik").Bold().FontSize(8);
                                });
                                foreach (var g in tedarikciGruplari)
                                {
                                    t.Cell().Padding(3).Text(g.Key).FontSize(8);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count().ToString()).FontSize(8);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count(a => GetAracEvrakDurumu(a) == "Gecerli").ToString()).FontSize(8).FontColor(Colors.Green.Darken2);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count(a => GetAracEvrakDurumu(a) == "Yaklasan").ToString()).FontSize(8).FontColor(Colors.Orange.Darken2);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count(a => GetAracEvrakDurumu(a) == "Dolmus").ToString()).FontSize(8).FontColor(Colors.Red.Darken2);
                                    t.Cell().Padding(3).AlignRight().Text(g.Count(a => GetAracEvrakDurumu(a) == "Eksik").ToString()).FontSize(8).FontColor(Colors.Grey.Darken2);
                                }
                            });
                        });

                        content.Item().Background(Colors.Blue.Darken3).Padding(5).Text("DETAY LİSTE").Bold().FontSize(10).FontColor(Colors.White);

                        content.Item().Table(table =>
                        {
                            table.ColumnsDefinition(c =>
                            {
                                c.ConstantColumn(20);
                                c.RelativeColumn(2);   // Plaka
                                c.RelativeColumn(3);   // Şase
                                c.RelativeColumn(3);   // Marka/Model
                                c.RelativeColumn(3);   // Tedarikçi
                                c.RelativeColumn(2);   // Muayene
                                c.RelativeColumn(2);   // Trafik
                                c.RelativeColumn(2);   // Kasko
                                c.RelativeColumn(2);   // Koltuk
                                c.RelativeColumn(2);   // Durum
                            });

                            table.Header(h =>
                            {
                                string[] hs = { "#", "Plaka", "Şase", "Marka/Model", "Tedarikçi", "Muayene", "Trafik", "Kasko", "Koltuk Sig.", "Durum" };
                                foreach (var hh in hs)
                                    h.Cell().Background(Colors.Grey.Lighten2).Padding(3).Text(hh).Bold().FontSize(8);
                            });

                            string TarihStr(DateTime? d) => d.HasValue ? d.Value.ToString("dd.MM.yyyy") : "-";
                            string TarihRenk(DateTime? d)
                            {
                                if (!d.HasValue) return Colors.Grey.Darken1;
                                var gun = (d.Value - DateTime.Today).Days;
                                if (gun < 0) return Colors.Red.Darken1;
                                if (gun < 30) return Colors.Orange.Darken2;
                                return Colors.Green.Darken2;
                            }

                            int sira = 1;
                            foreach (var a in data)
                            {
                                var d = GetAracEvrakDurumu(a);
                                var bg = d switch
                                {
                                    "Dolmus" => Colors.Red.Lighten4,
                                    "Yaklasan" => Colors.Orange.Lighten4,
                                    "Eksik" => Colors.Grey.Lighten3,
                                    _ => Colors.White
                                };

                                table.Cell().Background(bg).Padding(3).Text(sira++.ToString()).FontSize(8);
                                table.Cell().Background(bg).Padding(3).Text(a.AktifPlaka ?? "-").Bold().FontSize(8);
                                table.Cell().Background(bg).Padding(3).Text(a.SaseNo ?? "-").FontSize(7);
                                table.Cell().Background(bg).Padding(3).Text($"{a.Marka} {a.Model}").FontSize(8);
                                table.Cell().Background(bg).Padding(3).Text(GetTedarikciEtiket(a.TasimaTedarikciId)).FontSize(7);
                                table.Cell().Background(bg).Padding(3).Text(TarihStr(a.MuayeneBitisTarihi)).FontSize(8).FontColor(TarihRenk(a.MuayeneBitisTarihi));
                                table.Cell().Background(bg).Padding(3).Text(TarihStr(a.TrafikSigortaBitisTarihi)).FontSize(8).FontColor(TarihRenk(a.TrafikSigortaBitisTarihi));
                                table.Cell().Background(bg).Padding(3).Text(TarihStr(a.KaskoBitisTarihi)).FontSize(8).FontColor(TarihRenk(a.KaskoBitisTarihi));
                                table.Cell().Background(bg).Padding(3).Text(TarihStr(a.KoltukSigortasiBitisTarihi)).FontSize(8).FontColor(TarihRenk(a.KoltukSigortasiBitisTarihi));
                                table.Cell().Background(bg).Padding(3).Text(GenelDurumText(d)).Bold().FontSize(8);
                            }
                        });
                    });

                    page.Footer().AlignCenter().Text(t =>
                    {
                        t.Span("Sayfa ").FontSize(8);
                        t.CurrentPageNumber().FontSize(8);
                        t.Span(" / ").FontSize(8);
                        t.TotalPages().FontSize(8);
                    });
                });
            });

            var pdfBytes = document.GeneratePdf();
            var fileName = $"tedarikci-arac-evrak-rapor-{DateTime.Now:yyyyMMdd-HHmm}.pdf";
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/pdf", base64);
            ToastService.ShowSuccess("PDF raporu aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"PDF aktarım hatası: {ex.Message}");
        }
    }
}
