    // ===== DURUM TABLOSU METHODS =====
    private async Task YenileDurumData()
    {
        isLoading = true;
        try
        {
            var donemBaslangic = new DateTime(durYil, durAy, 1);

            // Firma kapsamı: Aktif Firma → normal tenant filter yeterli.
            // Tüm Firmalar → IgnoreQueryFilters + firmaIds güvenli sınırlama.
            var firmaIds = GetCiktiFirmaIds();
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            IQueryable<Sofor> personelQuery = ctx.Soforler;
            if (ciktiFirmaSecim == 1)
                personelQuery = personelQuery.IgnoreQueryFilters().Where(s => firmaIds.Contains(s.FirmaId!.Value));

            durTumPersoneller = await personelQuery
                .Include(s => s.Firma)
                .Include(s => s.AracAtamalari.Where(a => a.Aktif)).ThenInclude(a => a.Arac)
                .Where(s => !s.IsDeleted && s.Aktif)
                .Where(s => s.IstenAyrilmaTarihi == null || s.IstenAyrilmaTarihi >= donemBaslangic)
                .OrderBy(s => s.SiralamaNo == 0 ? int.MaxValue : s.SiralamaNo)
                .ThenBy(s => s.Ad)
                .AsNoTracking()
                .ToListAsync();

            var aktifler = durTumPersoneller
                .OrderBy(p => p.SiralamaNo == 0 ? int.MaxValue : p.SiralamaNo)
                .ThenBy(p => p.Ad)
                .ToList();

            var donemMaasKayitlari = await PersonelService.GetMaaslarAsync(durYil, durAy);
            var donemMaasMap = donemMaasKayitlari
                .GroupBy(m => m.SoforId)
                .ToDictionary(g => g.Key, g => g.First());

            durSatirlar = new List<PersonelDurumSatir>();
            foreach (var p in aktifler)
            {
                PersonelFinansOzet? finansOzet = null;
                try
                {
                    finansOzet = await PersonelFinansService.GetPersonelFinansOzetAsync(p.Id);
                }
                catch (InvalidOperationException)
                {
                    // Personel farklı firmaya aitse veya tenant filter dışındaysa
                    // finans özeti alınamaz — atla, maaş satırı oluşturmaya devam et.
                }
                donemMaasMap.TryGetValue(p.Id, out var donemMaas);

                var bankayaYatan = p.ResmiNetMaas;
                var gercekMaas = donemMaas != null
                    ? donemMaas.NetMaas + donemMaas.ToplamEklemeler
                    : p.ResmiNetMaas + p.DigerMaas;

                var satir = new PersonelDurumSatir
                {
                    PersonelId = p.Id,
                    AdSoyad = p.TamAd,
                    SoforKodu = p.SoforKodu,
                    GorevAdi = GetGorevAdi(p.Gorev),
                    GorevEnum = p.Gorev,
                    SiralamaNo = p.SiralamaNo,
                    GercekMaas = gercekMaas,
                    BankayaYatan = bankayaYatan,
                    Avans = finansOzet?.KalanAvans ?? 0,
                    Kesinti = 0,
                    Harcamasi = (finansOzet?.ToplamHarcama ?? 0) + (finansOzet?.KalanBorc > 0 ? finansOzet!.KalanBorc : 0),
                    // Excel / yazdirma ek kolonlar
                    Plaka = p.AracAtamalari?.FirstOrDefault(a => a.Aktif)?.Arac?.AktifPlaka,
                    Telefon = p.Telefon,
                    Adres = p.Adres,
                    AsgariUcret = 0,
                    FirmaAdi = p.Firma?.FirmaAdi,
                    SgkDurum = p.SGKBordroDahilMi ? "SGK'lı" : "SGK'sız",
                    IseGirisTarihi = p.IseBaslamaTarihi,
                    IstenCikisTarihi = p.IstenAyrilmaTarihi
                };
                satir.Fark = satir.GercekMaas - satir.AsgariUcret;
                satir.Odenecek = satir.GercekMaas - satir.BankayaYatan - satir.Avans - satir.Kesinti + satir.Harcamasi;
                durSatirlar.Add(satir);
            }
            if (durSecilenPersonelId > 0)
                await DurumPersonelDetayYukle();
        }
        catch (Exception ex)
        {
            BildirimGoster($"Durum tablosu yüklenirken hata: {ex.Message}", false);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DurumPersonelSec(int personelId)
    {
        if (durSecilenPersonelId == personelId)
        {
            DurumPaneliKapat();
            return;
        }
        durSecilenPersonelId = personelId;
        durSecilenPersonel = durTumPersoneller.FirstOrDefault(p => p.Id == personelId);
        durAktifSekme = "ekstra";
        await DurumPersonelDetayYukle();
    }

    private void DurumPaneliKapat()
    {
        durSecilenPersonelId = 0;
        durSecilenPersonel = null;
    }

    private async Task DurumSekmeDegistir(string sekme)
    {
        durAktifSekme = sekme;
        await DurumPersonelDetayYukle();
    }

    private async Task DurumPersonelDetayYukle()
    {
        if (durSecilenPersonelId == 0) return;
        durDetayYukleniyor = true;
        StateHasChanged();
        try
        {
            durFinansOzet = await PersonelFinansService.GetPersonelFinansOzetAsync(durSecilenPersonelId);
            if (durAktifSekme == "ekstra")
            {
                durAvanslar = await PersonelFinansService.GetAvanslarAsync(personelId: durSecilenPersonelId);
                durBorclar = await PersonelFinansService.GetBorclarAsync(personelId: durSecilenPersonelId);
                durCebHarcamalar = await PersonelFinansService.GetPersonelCebindenHarcamalarAsync(durSecilenPersonelId);
                durEkstreHareketler = DurumOlusturEkstre(durAvanslar, durBorclar, durCebHarcamalar);
            }
            else if (durAktifSekme == "avans")
                durAvanslar = await PersonelFinansService.GetAvanslarAsync(personelId: durSecilenPersonelId);
            else if (durAktifSekme == "borc")
                durBorclar = await PersonelFinansService.GetBorclarAsync(personelId: durSecilenPersonelId);
            else if (durAktifSekme == "maas")
                durMaasGecmisi = await PersonelService.GetSoforMaasGecmisiAsync(durSecilenPersonelId);
            else if (durAktifSekme == "harcama")
                durCebHarcamalar = await PersonelFinansService.GetPersonelCebindenHarcamalarAsync(durSecilenPersonelId);
            else if (durAktifSekme == "pusula")
            {
                durBordroDetay = null;
                var bordrolar = await BordroService.GetBordrolarAsync(yil: durYil);
                foreach (var bordro in bordrolar.Where(b => b.Ay == durAy))
                {
                    var detaylar = await BordroService.GetBordroDetaylarAsync(bordro.Id);
                    var detay = detaylar.FirstOrDefault(d => d.PersonelId == durSecilenPersonelId);
                    if (detay != null) { durBordroDetay = detay; break; }
                }
            }
        }
        catch (Exception ex)
        {
            BildirimGoster($"Detay yüklenirken hata: {ex.Message}", false);
        }
        finally
        {
            durDetayYukleniyor = false;
            StateHasChanged();
        }
    }

    private async Task DurumBorcKaydiniSil(PersonelBorc borc)
    {
        if (!CanBorcKaydiKaliciSil)
        {
            BildirimGoster("Borç kaydı silme yetkiniz yok.", false);
            return;
        }

        var onay = await JS.InvokeAsync<bool>("confirm",
            $"{borc.BorcTarihi:dd.MM.yyyy} tarihli borç kaydı kalıcı olarak silinecek. Bağlı ödeme hareketleri de silinecek. Devam edilsin mi?");
        if (!onay)
            return;

        try
        {
            await PersonelFinansService.DeleteBorcAsync(borc.Id);
            await YenileDurumData();
            if (durSecilenPersonelId > 0)
                await DurumPersonelDetayYukle();

            BildirimGoster("Borç kaydı ve bağlı hareketleri kalıcı olarak silindi.", true);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Borç silme hatası: {ex.Message}", false);
        }
    }

    private static List<EkstreHareket> DurumOlusturEkstre(List<PersonelAvans> avanslar, List<PersonelBorc> borclar, List<PersonelCebindenHarcamaItem>? harcamalar = null)
    {
        var hareketler = new List<EkstreHareket>();
        foreach (var a in avanslar)
            hareketler.Add(new EkstreHareket { Tarih = a.AvansTarihi, Aciklama = $"Avans - {a.Aciklama ?? ""}", Tutar = -a.Tutar });
        foreach (var b in borclar)
            hareketler.Add(new EkstreHareket { Tarih = b.BorcTarihi, Aciklama = $"Borç - {b.Aciklama ?? b.BorcTipi.ToString()}", Tutar = -b.Tutar });
        foreach (var h in (harcamalar ?? new()))
            hareketler.Add(new EkstreHareket { Tarih = h.Tarih, Aciklama = $"Harcama - {h.Aciklama}", Tutar = h.Tutar });
        return hareketler.OrderByDescending(h => h.Tarih).ToList();
    }

