<!-- Maaş Silme Onay Modal -->
@if (silinecekMaas != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Maaş Kaydını Sil</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="MaasSilIptal"></button>
                </div>
                <div class="modal-body">
                    <p>Aşağıdaki maaş kaydını silmek istediğinize emin misiniz?</p>
                    <ul class="list-unstyled mb-0">
                        <li><strong>Personel:</strong> @silinecekMaas.Sofor?.TamAd</li>
                        <li><strong>Dönem:</strong> @(new DateTime(silinecekMaas.Yil, silinecekMaas.Ay, 1).ToString("MMMM yyyy"))</li>
                        <li><strong>Ödenecek:</strong> @silinecekMaas.OdenecekTutar.ToString("N0") ₺</li>
                    </ul>
                    <div class="alert alert-warning mt-3 mb-0 py-2">
                        <i class="bi bi-info-circle me-1"></i> Bu işlem geri alınamaz. Kayıt veritabanından kalıcı olarak silinecek.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="MaasSilIptal">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="MaasSilOnayla" disabled="@isSiliniyor">
                        @if (isSiliniyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Maaş Düzenleme Modal -->
@if (duzenlenenMaas != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Maaş Düzenle - @duzenlenenMaas.Sofor?.TamAd</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary">Maaş Bilgileri</h6>
                            <div class="mb-2">
                                <label class="form-label small">Brüt Maaş</label>
                                <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.BrutMaas" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Net Maaş</label>
                                <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.NetMaas" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Çalışma Günü</label>
                                <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.CalismaGunu" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-success">Ek Ödemeler</h6>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Prim</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Prim" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">İkramiye</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Ikramiye" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Mesai</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Mesai" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Yemek</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Yemek" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Yol Parası</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Yol" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Personel Harcaması</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.DigerEklemeler" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-danger">Kesintiler</h6>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Avans</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Avans" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">İcra Takibi</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.IcraTakibi" />
                                </div>
                            </div>

                            <div class="mt-3 border rounded p-3 bg-light-subtle">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 text-dark"><i class="bi bi-wallet2 me-2"></i>Açık Avans Mahsubu</h6>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="AcikAvanslariMaasaMahsupEt"
                                            disabled="@(isMahsupUygulaniyor || !acikAvanslar.Any() || MahsupEdilebilirTutar <= 0 || duzenlenenMaas.OdemeDurum == MaasOdemeDurum.Odendi)">
                                        @if (isMahsupUygulaniyor)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-arrow-down-circle me-1"></i>Maaşa Mahsup Et
                                    </button>
                                </div>
                                <div class="small text-muted mb-2">
                                    Açık Avans: <strong>@ToplamAcikAvans.ToString("N2") ₺</strong> |
                                    Mahsup Edilebilir: <strong>@MahsupEdilebilirTutar.ToString("N2") ₺</strong>
                                </div>
                                @if (acikAvanslar.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Tarih</th>
                                                    <th class="text-end">Tutar</th>
                                                    <th class="text-end">Mahsup</th>
                                                    <th class="text-end">Kalan</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var avans in acikAvanslar)
                                                {
                                                    <tr>
                                                        <td>@avans.AvansTarihi.ToString("dd.MM.yyyy")</td>
                                                        <td class="text-end">@avans.Tutar.ToString("N2") ₺</td>
                                                        <td class="text-end">@avans.MahsupEdilen.ToString("N2") ₺</td>
                                                        <td class="text-end text-danger"><strong>@avans.Kalan.ToString("N2") ₺</strong></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="small text-muted">Bu personel için açık avans bulunmuyor.</div>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-info">Hesaplanan</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td>Ödenecek Tutar:</td>
                                    <td class="text-end"><strong>@duzenlenenMaas.OdenecekTutar.ToString("N0") ₺</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button class="btn btn-primary" @onclick="MaasKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Ödeme Onay Modal -->
@if (odemeOnayModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Ödeme Yap</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="OdemeModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (secilenOdemeMaas != null)
                    {
                        <div class="alert alert-info">
                            <strong>@secilenOdemeMaas.SoforAdSoyad</strong> - Ödenecek Tutar: <strong>@secilenOdemeMaas.OdenecekTutar.ToString("N2") ₺</strong>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ödeme Yöntemi</label>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var yontem in new[] { ("Elden", "bi-hand-index-thumb", "btn-warning"), ("Banka", "bi-bank", "btn-primary"), ("Mahsup", "bi-arrow-left-right", "btn-secondary"), ("KrediKarti", "bi-credit-card", "btn-info") })
                                {
                                    <button type="button" class="btn btn-sm @(odemeYontemi == yontem.Item1 ? yontem.Item3 : "btn-outline-secondary")"
                                            @onclick="() => { odemeYontemi = yontem.Item1; secilenOdemeBankaHesapId = null; }">
                                        <i class="bi @yontem.Item2 me-1"></i>@(yontem.Item1 == "KrediKarti" ? "Kredi Kartı" : yontem.Item1)
                                    </button>
                                }
                            </div>
                        </div>
                        @if (odemeYontemi == "Banka" || odemeYontemi == "KrediKarti")
                        {
                            <div class="mb-3">
                                <label class="form-label">Hesap Seç</label>
                                <select class="form-select" @bind="secilenOdemeBankaHesapId">
                                    <option value="">-- Hesap Seçin --</option>
                                    @foreach (var h in bankaHesapListesi)
                                    {
                                        <option value="@h.Id">@h.HesapAdi (@h.BankaAdi)</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Ödeme Tarihi</label>
                            <input type="date" class="form-control" @bind="odemeTarihi" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Açıklama (Opsiyonel)</label>
                            <textarea class="form-control" rows="2" @bind="odemeAciklama" placeholder="Ödeme ile ilgili not..."></textarea>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="OdemeModalKapat" disabled="@isOdemeYapiliyor">İptal</button>
                    <button class="btn btn-success" @onclick="OdemeOnayla" disabled="@isOdemeYapiliyor">
                        @if (isOdemeYapiliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>İşleniyor...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                            <span>Ödemeyi Onayla</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Hareket Detay Modal -->
@if (detayMaas != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-receipt me-2"></i>Maaş Detayı - @(detayMaas.Sofor != null ? detayMaas.Sofor.TamAd : "-")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="DetayKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <h6 class="text-primary mb-2">Dönem Bilgisi</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr><td class="text-muted">Dönem:</td><td class="text-end fw-bold">@(new DateTime(detayMaas.Yil, detayMaas.Ay, 1).ToString("MMMM yyyy"))</td></tr>
                                        <tr><td class="text-muted">Çalışma Günü:</td><td class="text-end">@detayMaas.CalismaGunu gün</td></tr>
                                        <tr><td class="text-muted">İzinli Gün:</td><td class="text-end">@detayMaas.IzinliGun gün</td></tr>
                                        <tr><td class="text-muted">Raporlu Gün:</td><td class="text-end">@detayMaas.RaporluGun gün</td></tr>
                                        <tr><td class="text-muted">Devamsızlık:</td><td class="text-end">@detayMaas.DevamsizlikGun gün</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <h6 class="text-primary mb-2">Ödeme Bilgisi</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td class="text-muted">Durum:</td>
                                            <td class="text-end">
                                                @switch (detayMaas.OdemeDurum)
                                                {
                                                    case MaasOdemeDurum.Odendi:
                                                        <span class="badge bg-success">Ödendi</span>
                                                        break;
                                                    case MaasOdemeDurum.Bekliyor:
                                                        <span class="badge bg-warning text-dark">Bekliyor</span>
                                                        break;
                                                    case MaasOdemeDurum.KismiOdendi:
                                                        <span class="badge bg-info">Kısmi</span>
                                                        break;
                                                    case MaasOdemeDurum.IptalEdildi:
                                                        <span class="badge bg-secondary">İptal</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                        <tr><td class="text-muted">Ödeme Tarihi:</td><td class="text-end">@(detayMaas.OdemeTarihi.HasValue ? detayMaas.OdemeTarihi.Value.ToString("dd.MM.yyyy") : "-")</td></tr>
                                        @if (!string.IsNullOrEmpty(detayMaas.OdemeAciklama))
                                        {
                                            <tr><td class="text-muted">Açıklama:</td><td class="text-end">@detayMaas.OdemeAciklama</td></tr>
                                        }
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white py-1"><small class="fw-bold">Maaş Bilgileri</small></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr><td>Brüt Maaş:</td><td class="text-end fw-bold">@detayMaas.BrutMaas.ToString("N2") ₺</td></tr>
                                        <tr><td>Net Maaş:</td><td class="text-end fw-bold">@detayMaas.NetMaas.ToString("N2") ₺</td></tr>
                                    </table>
