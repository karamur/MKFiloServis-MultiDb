    private async Task HareketleriVeriYukle()
    {
        var tumKayitlar = new List<PersonelMaas>();
        if (hSecilenSoforId > 0)
        {
            tumKayitlar = await PersonelService.GetSoforMaasGecmisiAsync(hSecilenSoforId);
        }
        else if (hareketYil > 0 && hareketAy > 0)
        {
            tumKayitlar = await PersonelService.GetMaaslarAsync(hareketYil, hareketAy);
        }
        else if (hareketYil > 0)
        {
            for (int ay = 1; ay <= 12; ay++)
            {
                var aylik = await PersonelService.GetMaaslarAsync(hareketYil, ay);
                tumKayitlar.AddRange(aylik);
            }
        }
        else
        {
            for (int ay = 1; ay <= 12; ay++)
            {
                var aylik = await PersonelService.GetMaaslarAsync(DateTime.Today.Year, ay);
                tumKayitlar.AddRange(aylik);
            }
        }
        hareketler = tumKayitlar
            .OrderByDescending(h => h.Yil)
            .ThenByDescending(h => h.Ay)
            .ThenBy(h => h.Sofor != null ? h.Sofor.TamAd : "")
            .ToList();
        UygulaHareketFiltre();
    }

    private async Task HareketFiltrele()
    {
        isLoading = true;
        try { await HareketleriVeriYukle(); }
        finally { isLoading = false; }
    }

    private void UygulaHareketFiltre()
    {
        var sonuc = hareketler.AsEnumerable();
        if (hSecilenDurum >= 0)
        {
            var durum = (MaasOdemeDurum)hSecilenDurum;
            sonuc = sonuc.Where(h => h.OdemeDurum == durum);
        }
        filtrelenmisHareketler = sonuc.ToList();
        HesaplaPersonelOzetleri();
    }

    private void HesaplaPersonelOzetleri()
    {
        personelOzetleri = filtrelenmisHareketler
            .GroupBy(h => h.SoforId)
            .Select(g => new PersonelBazliOzet
            {
                SoforId = g.Key,
                AdSoyad = g.First().Sofor != null ? g.First().Sofor.TamAd : "-",
                KayitSayisi = g.Count(),
                ToplamBrut = g.Sum(h => h.BrutMaas),
                ToplamNet = g.Sum(h => h.NetMaas),
                ToplamOdenecek = g.Sum(h => h.OdenecekTutar),
                OdenenSayisi = g.Count(h => h.OdemeDurum == MaasOdemeDurum.Odendi),
                BekleyenSayisi = g.Count(h => h.OdemeDurum == MaasOdemeDurum.Bekliyor)
            })
            .OrderBy(o => o.AdSoyad)
            .ToList();
    }

