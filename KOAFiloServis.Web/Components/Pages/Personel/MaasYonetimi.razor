            var excelFirmaAdi = ciktiFirmaSecim == 0
                ? (AktifFirmaProvider.Mevcut?.FirmaAdi ?? "Maaş / Ödeme Yönetimi")
                : "Tüm Firmalar";
            ws.Cell("A1").Value = excelFirmaAdi;
            ws.Cell("A2").Value = "Maaş / Ödeme Yönetimi";
            ws.Cell("A3").Value = $"Dönem: {new DateTime(durYil, durAy, 1):MMMM yyyy}  |  {DateTime.Now:dd.MM.yyyy HH:mm}";
            ws.Range("A1:O1").Merge().Style.Font.Bold = true;
            ws.Range("A1:O1").Style.Font.FontSize = 14;
            ws.Range("A1:O1").Style.Fill.BackgroundColor = XLColor.DarkRed;
            ws.Range("A1:O1").Style.Font.FontColor = XLColor.White;
            ws.Range("A2:O3").Merge();

            var header = ws.Row(5);
            var basliklar = new[] { "S.NO", "PLAKA", "AD SOYAD", "TELEFON", "ADRES", "GERÇEK MAAŞ", "BANKAYA YATAN", "AVANS (-)", "KESİNTİ (-)", "HARCAMASI (+)", "FARK / ÖDENECEK", "FİRMA", "SGK", "İŞE GİRİŞ", "İŞTEN ÇIKIŞ" };
            for (int i = 0; i < basliklar.Length; i++)
                header.Cell(i + 1).Value = basliklar[i];
            header.Style.Font.Bold = true;
            header.Style.Fill.BackgroundColor = XLColor.Red;
            header.Style.Font.FontColor = XLColor.White;

            var row = 6; var sira = 0; decimal toplamGercek = 0, toplamBankaya = 0, toplamAvans = 0, toplamKesinti = 0, toplamHarcama = 0, toplamFark = 0;
            foreach (var item in filtreliler)
            {
                sira++;
                var farkOdenecek = item.GercekMaas - item.BankayaYatan - item.Avans - item.Kesinti + item.Harcamasi;
                toplamGercek += item.GercekMaas;
                toplamBankaya += item.BankayaYatan;
                toplamAvans += item.Avans;
                toplamKesinti += item.Kesinti;
                toplamHarcama += item.Harcamasi;
                toplamFark += farkOdenecek;

                ws.Cell(row, 1).Value = item.SiralamaNo > 0 ? item.SiralamaNo : sira;
                ws.Cell(row, 2).Value = item.Plaka ?? "-";
                ws.Cell(row, 3).Value = item.AdSoyad;
                ws.Cell(row, 4).Value = item.Telefon ?? "-";
                ws.Cell(row, 5).Value = item.Adres ?? "-";
                ws.Cell(row, 6).Value = item.GercekMaas;
                ws.Cell(row, 7).Value = item.BankayaYatan;
                ws.Cell(row, 8).Value = item.Avans;
                ws.Cell(row, 9).Value = item.Kesinti;
                ws.Cell(row, 10).Value = item.Harcamasi;
                ws.Cell(row, 11).Value = farkOdenecek;
                ws.Cell(row, 12).Value = item.FirmaAdi ?? "-";
                ws.Cell(row, 13).Value = item.SgkDurum ?? "-";
                ws.Cell(row, 14).Value = item.IseGirisTarihi?.ToString("dd.MM.yyyy") ?? "-";
                ws.Cell(row, 15).Value = item.IstenCikisTarihi?.ToString("dd.MM.yyyy") ?? "-";
                row++;
            }

            // Toplam satırı
            ws.Cell(row, 1).Value = "TOPLAM"; ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 6).Value = toplamGercek;
            ws.Cell(row, 7).Value = toplamBankaya;
            ws.Cell(row, 8).Value = toplamAvans;
            ws.Cell(row, 9).Value = toplamKesinti;
            ws.Cell(row, 10).Value = toplamHarcama;
            ws.Cell(row, 11).Value = toplamFark;
            for (int c = 1; c <= 15; c++) ws.Cell(row, c).Style.Font.Bold = true;

            for (int c = 6; c <= 11; c++) ws.Column(c).Style.NumberFormat.Format = "#,##0.00";
            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var bytes = stream.ToArray();
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"MaasOdeme_{durYil}_{durAy:D2}.xlsx", Convert.ToBase64String(bytes));
            BildirimGoster($"Excel dışa aktarıldı: {filtreliler.Count} kayıt.", true);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Excel hatası: {ex.Message}", false);
        }
    }

