@code {
    // ===== MAAŞ YÖNETİMİ STATE =====
    private int maasYil = DateTime.Today.Year;
    private int maasAy = DateTime.Today.Month;
    private MaasRaporOzet? maasRapor;
    private HashSet<int> seciliMaasIds = new();
    private HashSet<int> seciliOlusturmaPersonelIds = new();
    private PersonelMaas? duzenlenenMaas;
    private bool isLoading = false;
    private List<PersonelAvans> acikAvanslar = new();
    private bool isMahsupUygulaniyor = false;
    private bool odemeOnayModal = false;
    private MaasDetay? secilenOdemeMaas;
    private DateTime odemeTarihi = DateTime.Today;
    private string? odemeAciklama;
    private bool isOdemeYapiliyor = false;
    private string? bildirimMesaj;
    private bool bildirimBasarili;
    private System.Threading.Timer? bildirimTimer;
    private HashSet<string> kullaniciYetkileri = new();

    // Ödeme yöntemi
    private string odemeYontemi = "Elden"; // Elden | Banka | Mahsup | KrediKarti
    private int? secilenOdemeBankaHesapId;
    private List<BankaHesap> bankaHesapListesi = new();

    // Silme
    private PersonelMaas? silinecekMaas;
    private bool isSiliniyor = false;

    // Avans düzenleme
    private PersonelAvans? duzenlenenAvans;
    private bool isAvansKaydediliyor = false;

    // Yeni avans ekleme
    private PersonelAvans? yeniAvans;
    private bool isYeniAvansKaydediliyor = false;

    // Borç düzenleme & ödeme
    private PersonelBorc? duzenlenenBorc;
    private bool isBorcKaydediliyor = false;
    private PersonelBorc? borcOdemeHedef;
    private decimal borcOdemeTutari;
    private DateTime borcOdemeTarihi = DateTime.Today;
    private BorcOdemeSekli borcOdemeYontemi = BorcOdemeSekli.Nakit;
    private int? borcOdemeBankaHesapId;
    private bool isBorcOdemeYapiliyor = false;

    // ===== MAAŞ HAREKETLERİ STATE =====
    private List<Sofor> soforler = new();
    private List<PersonelMaas> hareketler = new();
    private List<PersonelMaas> filtrelenmisHareketler = new();
    private List<PersonelBazliOzet> personelOzetleri = new();
    private PersonelMaas? detayMaas;
    private int hSecilenSoforId = 0;
    private int hareketYil = 0;
    private int hareketAy = 0;
    private int hSecilenDurum = -1;

    // ===== DURUM TABLOSU STATE =====
    private string durAramaMetni = string.Empty;
    private string durSecilenGorev = string.Empty;
    private int durYil = DateTime.Today.Year;
    private int durAy = DateTime.Today.Month;
    private bool durDetayYukleniyor = false;
    private List<PersonelDurumSatir> durSatirlar = new();
    private List<Sofor> durTumPersoneller = new();
    private int durSecilenPersonelId;
    private Sofor? durSecilenPersonel;
    private string durAktifSekme = "ekstra";
    private PersonelFinansOzet? durFinansOzet;
    private List<PersonelAvans> durAvanslar = new();
    private List<PersonelBorc> durBorclar = new();
    private List<PersonelMaas> durMaasGecmisi = new();
    private List<EkstreHareket> durEkstreHareketler = new();
    private BordroDetay? durBordroDetay;
    private List<PersonelCebindenHarcamaItem> durCebHarcamalar = new();
    private bool CanBorcKaydiKaliciSil => kullaniciYetkileri.Contains("*") || kullaniciYetkileri.Contains(Yetkiler.PersonelBorcSil);
    // Firma seçimi (Excel/Yazdır için)
    private int ciktiFirmaSecim = 0; // 0=Aktif, 1=Tüm Firmalar
    private List<Firma> ciktiFirmaListesi = new();
    private List<Sofor> OlusturulabilirMaasPersoneller => soforler
        .Where(s => s.Aktif && !s.IsDeleted)
        .Where(s => s.IstenAyrilmaTarihi == null || s.IstenAyrilmaTarihi >= new DateTime(maasYil, maasAy, 1))
        .Where(s => maasRapor == null || maasRapor.Detaylar.All(d => d.SoforId != s.Id))
        .OrderBy(s => s.SiralamaNo == 0 ? int.MaxValue : s.SiralamaNo)
        .ThenBy(s => s.Ad)
        .ThenBy(s => s.Soyad)
        .ToList();
    private IEnumerable<PersonelDurumSatir> DurFiltreliSatirlar => durSatirlar
        .Where(s => (string.IsNullOrWhiteSpace(durAramaMetni)
                || s.AdSoyad.Contains(durAramaMetni, StringComparison.OrdinalIgnoreCase)
                || s.SoforKodu.Contains(durAramaMetni, StringComparison.OrdinalIgnoreCase))
            && (string.IsNullOrWhiteSpace(durSecilenGorev)
                || s.GorevEnum.ToString() == durSecilenGorev));

    // ===== LIFECYCLE =====
    private async Task CiktiFirmaListesiniYukle()
    {
        try
        {
            await using var ctx = await DbContextFactory.CreateDbContextAsync();
            ciktiFirmaListesi = await ctx.Firmalar
                .Where(f => f.Aktif && !f.IsDeleted)
                .OrderBy(f => f.FirmaAdi)
                .AsNoTracking()
                .ToListAsync();
        }
        catch { ciktiFirmaListesi = new(); }
    }

    protected override async Task OnInitializedAsync()
    {
        kullaniciYetkileri = await KullaniciService.GetCurrentUserYetkilerAsync();
        bankaHesapListesi = await BankaHesapService.GetActiveAsync();
        AktifFirmaProvider.AktifFirmaDegisti += HandleAktifFirmaDegisti;
        await CiktiFirmaListesiniYukle();
        await YenileDurumData();
    }

    private async void HandleAktifFirmaDegisti()
    {
        await InvokeAsync(async () =>
        {
            ciktiFirmaSecim = 0;
            await CiktiFirmaListesiniYukle();
            await YenileDurumData();
            StateHasChanged();
        });
    }

    // ===== MAAŞ YÖNETİMİ METHODS =====
    private async Task YenileMaasData()
    {
        isLoading = true;
        try
        {
            maasRapor = await PersonelService.GetMaasRaporuAsync(maasYil, maasAy);
            seciliMaasIds.RemoveWhere(id => maasRapor.Detaylar.All(m => m.MaasId != id));
            seciliOlusturmaPersonelIds.RemoveWhere(id => OlusturulabilirMaasPersoneller.All(s => s.Id != id));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task TopluMaasOlustur()
    {
        var tumAktifPersonelIds = soforler.Where(s => s.Aktif && !s.IsDeleted).Select(s => s.Id).ToList();
        var sonuc = await PersonelService.CreateMaasForPersonellerAsync(maasYil, maasAy, tumAktifPersonelIds);
        await YenileMaasData();

        if (sonuc.OlusturulanSayisi == 0 && sonuc.ZatenVarSayisi > 0)
        {
            BildirimGoster("Bu ay için tüm personellerde maaş zaten mevcut. Yeniden oluşturulmadı.", false);
            return;
        }

        BildirimGoster($"Toplu maaş oluşturma tamamlandı. Oluşturulan: {sonuc.OlusturulanSayisi}, Zaten var: {sonuc.ZatenVarSayisi}.", true);
    }

    private async Task SeciliPersonellerIcinMaasOlustur()
    {
        if (!seciliOlusturmaPersonelIds.Any())
        {
            BildirimGoster("Önce maaş oluşturulacak personelleri işaretleyin.", false);
            return;
        }

        var sonuc = await PersonelService.CreateMaasForPersonellerAsync(maasYil, maasAy, seciliOlusturmaPersonelIds.ToList());
        await YenileMaasData();

        if (sonuc.OlusturulanSayisi == 0 && sonuc.ZatenVarSayisi > 0)
        {
