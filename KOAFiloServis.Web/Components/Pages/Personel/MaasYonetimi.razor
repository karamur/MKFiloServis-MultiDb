    private async Task DurumExcelAktar()
    {
        try
        {
            var filtreliler = DurFiltreliSatirlar.ToList();
            if (!filtreliler.Any()) { BildirimGoster("Dışa aktarılacak kayıt bulunamadı.", false); return; }

            using var workbook = new XLWorkbook();
