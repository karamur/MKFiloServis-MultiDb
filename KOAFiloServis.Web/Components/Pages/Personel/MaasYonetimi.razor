    private async Task HareketExcelExport()
    {
        try
        {
            using var workbook = new XLWorkbook();
            var ws = workbook.Worksheets.Add("Maaş Hareketleri");
            ws.Cell(1, 1).Value = "Maaş Hareket Listesi";
            ws.Range(1, 1, 1, 10).Merge().Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 14;
            var filtreBilgi = "Filtre: ";
            if (hareketYil > 0) filtreBilgi += $"Yıl: {hareketYil} ";
            if (hareketAy > 0) filtreBilgi += $"Ay: {new DateTime(2024, hareketAy, 1):MMMM} ";
            if (hSecilenSoforId > 0)
            {
                var sofor = soforler.FirstOrDefault(s => s.Id == hSecilenSoforId);
                if (sofor != null) filtreBilgi += $"Personel: {sofor.TamAd}";
            }
            ws.Cell(2, 1).Value = filtreBilgi;
            ws.Range(2, 1, 2, 10).Merge();
            var basliklar = new[] { "Personel", "Dönem", "Brüt Maaş", "Net Maaş (Bankaya Yatan)", "Gerçek Maaş", "Eklemeler", "Kesintiler", "Ödenecek", "Durum", "Ödeme Tarihi" };
            for (int i = 0; i < basliklar.Length; i++)
            {
                ws.Cell(4, i + 1).Value = basliklar[i];
                ws.Cell(4, i + 1).Style.Font.Bold = true;
                ws.Cell(4, i + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int satir = 5;
            foreach (var h in filtrelenmisHareketler)
            {
                ws.Cell(satir, 1).Value = h.Sofor != null ? h.Sofor.TamAd : "-";
                ws.Cell(satir, 2).Value = new DateTime(h.Yil, h.Ay, 1).ToString("MMMM yyyy");
                ws.Cell(satir, 3).Value = h.BrutMaas;
                ws.Cell(satir, 4).Value = GetBankayaYatan(h);
                ws.Cell(satir, 5).Value = GetGercekMaas(h);
                ws.Cell(satir, 6).Value = GetGorunenEklemeler(h);
                ws.Cell(satir, 7).Value = h.ToplamKesintiler;
                ws.Cell(satir, 8).Value = GetGorunenOdenecek(h);
                ws.Cell(satir, 9).Value = h.OdemeDurum.ToString();
                ws.Cell(satir, 10).Value = h.OdemeTarihi.HasValue ? h.OdemeTarihi.Value.ToString("dd.MM.yyyy") : "-";
                for (int col = 3; col <= 8; col++)
                    ws.Cell(satir, col).Style.NumberFormat.Format = "#,##0.00";
                satir++;
            }
            ws.Cell(satir, 1).Value = "TOPLAM";
            ws.Cell(satir, 1).Style.Font.Bold = true;
            ws.Cell(satir, 3).Value = filtrelenmisHareketler.Sum(h => h.BrutMaas);
            ws.Cell(satir, 4).Value = filtrelenmisHareketler.Sum(GetBankayaYatan);
            ws.Cell(satir, 5).Value = filtrelenmisHareketler.Sum(GetGercekMaas);
            ws.Cell(satir, 6).Value = filtrelenmisHareketler.Sum(GetGorunenEklemeler);
            ws.Cell(satir, 7).Value = filtrelenmisHareketler.Sum(h => h.ToplamKesintiler);
            ws.Cell(satir, 8).Value = filtrelenmisHareketler.Sum(GetGorunenOdenecek);
            for (int col = 3; col <= 8; col++)
                ws.Cell(satir, col).Style.NumberFormat.Format = "#,##0.00";
            ws.Columns().AdjustToContents();
            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var bytes = stream.ToArray();
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"Maas_Hareketleri_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx", Convert.ToBase64String(bytes));
        }
        catch (Exception ex)
        {
            BildirimGoster($"Excel export hatası: {ex.Message}", false);
        }
    }

