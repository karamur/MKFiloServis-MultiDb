        _ => gorev.ToString()
    };

    private static decimal GetGorunenToplamEklemeler(PersonelMaas maas)
        => maas.ToplamEklemeler > 0 ? maas.ToplamEklemeler : maas.Sofor?.DigerMaas ?? 0;

    private static decimal GetGorunenDigerEklemeler(PersonelMaas maas)
        => maas.DigerEklemeler > 0 ? maas.DigerEklemeler : maas.Sofor?.DigerMaas ?? 0;

    private static decimal GetBankayaYatan(PersonelMaas maas)
        => maas.Sofor?.ResmiNetMaas ?? maas.NetMaas;

    private static decimal GetBankayaYatan(MaasDetay maas)
        => maas.NetMaas;

    private static decimal GetGercekMaas(PersonelMaas maas)
        => maas.Sofor?.NetMaas > 0 ? maas.Sofor.NetMaas : maas.NetMaas + GetGorunenToplamEklemeler(maas);

    private static decimal GetGercekMaas(MaasDetay maas)
        => maas.NetMaas + maas.ToplamEklemeler;

    private static decimal GetGorunenEklemeler(PersonelMaas maas)
        => -maas.Avans - maas.ToplamKesintiler + GetGorunenDigerEklemeler(maas);

    private static decimal GetGorunenEklemeler(MaasDetay maas)
        => -maas.Avans - maas.ToplamKesintiler + maas.DigerEklemeler;

    private static decimal GetGorunenOdenecek(PersonelMaas maas)
        => GetGercekMaas(maas) - GetBankayaYatan(maas) + GetGorunenEklemeler(maas);

    private static decimal GetGorunenOdenecek(MaasDetay maas)
        => GetGercekMaas(maas) - GetBankayaYatan(maas) + GetGorunenEklemeler(maas);

    private void BildirimGoster(string mesaj, bool basarili)
    {
        bildirimMesaj = mesaj;
        bildirimBasarili = basarili;
        bildirimTimer?.Dispose();
        bildirimTimer = new System.Threading.Timer(_ =>
        {
            bildirimMesaj = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose()
    {
        AktifFirmaProvider.AktifFirmaDegisti -= HandleAktifFirmaDegisti;
        bildirimTimer?.Dispose();
    }

