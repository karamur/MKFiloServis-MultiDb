    private async Task OdemeOnayla()
    {
        if (secilenOdemeMaas == null) return;
        isOdemeYapiliyor = true;
        try
        {
            await PersonelService.MaasOdemeYapAsync(secilenOdemeMaas.MaasId, odemeTarihi);
            var maas = await PersonelService.GetMaasByIdAsync(secilenOdemeMaas.MaasId);
            if (maas != null)
            {
                var yontemAdi = odemeYontemi switch
                {
                    "Elden" => "Elden Ödeme",
                    "Banka" => "Banka Transferi",
                    "Mahsup" => "Mahsup",
                    "KrediKarti" => "Kredi Kartı",
                    _ => odemeYontemi
                };
                var aciklamaParçalar = new List<string> { yontemAdi };
                if ((odemeYontemi == "Banka" || odemeYontemi == "KrediKarti") && secilenOdemeBankaHesapId.HasValue)
                {
                    var hesap = bankaHesapListesi.FirstOrDefault(h => h.Id == secilenOdemeBankaHesapId.Value);
                    if (hesap != null) aciklamaParçalar.Add($"{hesap.HesapAdi}");
                }
                if (!string.IsNullOrWhiteSpace(odemeAciklama))
                    aciklamaParçalar.Add(odemeAciklama);
                maas.OdemeAciklama = string.Join(" - ", aciklamaParçalar);
                await PersonelService.UpdateMaasAsync(maas);
            }
            OdemeModalKapat();
            await YenileMaasData();
            if (durSecilenPersonelId > 0) await DurumPersonelDetayYukle();
            await YenileDurumData();
            BildirimGoster($"Ödeme başarıyla kaydedildi ({(odemeYontemi == "KrediKarti" ? "Kredi Kartı" : odemeYontemi)}).", true);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Ödeme sırasında hata: {ex.Message}", false);
        }
        finally
        {
            isOdemeYapiliyor = false;
        }
    }

