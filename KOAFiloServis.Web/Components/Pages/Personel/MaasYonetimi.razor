@page "/personel/maas"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@using ClosedXML.Excel
@inject IPersonelMaasIzinService PersonelService
@inject IPersonelFinansService PersonelFinansService
@inject ISoforService SoforService
@inject IBordroService BordroService
@inject IKullaniciService KullaniciService
@inject IBankaHesapService BankaHesapService
@inject IAktifFirmaProvider AktifFirmaProvider
@inject IJSRuntime JS
@inject IDbContextFactory<KOAFiloServis.Web.Data.ApplicationDbContext> DbContextFactory
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Maaş / Ödeme Yönetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-cash-coin me-2"></i>Maaş / Ödeme Yönetimi</h3>
        <div class="d-flex gap-2 align-items-center">
            <input type="text" class="form-control form-control-sm" style="width: 200px;" placeholder="Personel ara..."
                @bind="durAramaMetni" @bind:event="oninput" />
            <select class="form-select form-select-sm" style="width: 160px;" @bind="durSecilenGorev" @bind:after="StateHasChanged">
                <option value="">Tüm Görevler</option>
                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                {
                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 110px;" @bind="durYil" @bind:after="YenileDurumData">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 140px;" @bind="durAy" @bind:after="YenileDurumData">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 160px;" @bind="ciktiFirmaSecim">
                <option value="0">Aktif Firma</option>
                <option value="1">Tüm Firmalar</option>
            </select>
            <button class="btn btn-outline-success btn-sm" @onclick="DurumExcelAktar" disabled="@(!DurFiltreliSatirlar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-info btn-sm" @onclick="DurumYazdir" disabled="@(!DurFiltreliSatirlar.Any())">
                <i class="bi bi-printer me-1"></i>Yazdır
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="YenileDurumData" disabled="@isLoading" title="Yenile">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <div class="mb-3 text-muted small">
        <i class="bi bi-person-lines-fill me-1"></i>Ödeme / Durum
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- ============================================================ -->
        <!-- TAB 3: ÖDEME / DURUM TABLOSU                                 -->
        <!-- ============================================================ -->
        @if (true)
        {
            <div class="row">
                <!-- SOL: Personel Listesi -->
                <div class="@(durSecilenPersonelId > 0 ? "col-lg-7" : "col-12")">
                    <!-- Özet Kartları -->
                    <div class="row mb-3 g-2">
                        <div class="col">
                            <div class="card border-0 bg-primary bg-opacity-10">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Personel</small>
                                    <h5 class="mb-0 text-primary">@DurFiltreliSatirlar.Count()</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card border-0 bg-secondary bg-opacity-10">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Gerçek Maaş</small>
                                    <h6 class="mb-0">@FormatPara(DurFiltreliSatirlar.Sum(s => s.GercekMaas))</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card border-0 bg-info bg-opacity-10">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Bankaya Yatan</small>
                                    <h6 class="mb-0">@FormatPara(DurFiltreliSatirlar.Sum(s => s.BankayaYatan))</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card border-0 bg-warning bg-opacity-10">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Avans + Kesinti</small>
                                    <h6 class="mb-0">@FormatPara(DurFiltreliSatirlar.Sum(s => s.Avans + s.Kesinti))</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card border-0 bg-success bg-opacity-10">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Harcaması</small>
                                    <h6 class="mb-0 text-success">@FormatPara(DurFiltreliSatirlar.Sum(s => s.Harcamasi))</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card border-0 bg-danger bg-opacity-10">
                                <div class="card-body py-2 text-center">
                                    <small class="text-muted">Ödenecek</small>
                                    <h6 class="mb-0 text-danger fw-bold">@FormatPara(DurFiltreliSatirlar.Sum(s => s.Odenecek))</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Ana Tablo -->
                    <div class="card shadow-sm">
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 75vh;">
                                <table class="table table-hover table-sm mb-0 align-middle">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th style="width:30px;">#</th>
                                            <th>Personel</th>
                                            <th>Görev</th>
                                            <th class="text-end" title="Personelin gerçek net maaşı">Gerçek Maaş</th>
                                            <th class="text-end" title="Bordrodan bankaya yatan resmi net maaş">Bankaya Yatan</th>
                                            <th class="text-end text-warning" title="Mahsup edilecek açık avans">Avans (-)</th>
                                            <th class="text-end text-danger" title="Borç / kesinti">Kesinti (-)</th>
                                            <th class="text-end text-success" title="Personelin şirket adına cebinden yaptığı harcama">Harcaması (+)</th>
                                            <th class="text-end fw-bold" title="Gerçek Maaş - Bankaya Yatan - Avans - Kesinti + Harcaması">Ödenecek</th>
                                                    <th>Durum</th>
                                                    <th style="width:50px;"></th>
                                                </tr>
                                            </thead>
                                    <tbody>
                                        @{ int durSira = 0; }
                                        @foreach (var s in DurFiltreliSatirlar)
                                        {
                                            durSira++;
                                            var secili = s.PersonelId == durSecilenPersonelId;
                                            <tr class="@(secili ? "table-active" : "")" style="cursor:pointer;" @onclick="() => DurumPersonelSec(s.PersonelId)">
                                                <td class="text-muted small">@(s.SiralamaNo > 0 ? s.SiralamaNo : durSira)</td>
                                                <td>
                                                    <strong class="@(secili ? "text-primary" : "")">@s.AdSoyad</strong>
                                                    <br />
                                                    <small class="text-muted">@s.SoforKodu</small>
                                                </td>
                                                <td><small>@s.GorevAdi</small></td>
                                                <td class="text-end">@FormatPara(s.GercekMaas)</td>
                                                <td class="text-end">
                                                    @if (s.BankayaYatan > 0) { @FormatPara(s.BankayaYatan) }
                                                    else { <span class="text-muted">-</span> }
                                                </td>
                                                <td class="text-end text-warning">
                                                    @if (s.Avans > 0) { <span>-@FormatPara(s.Avans)</span> }
                                                    else { <span class="text-muted">-</span> }
                                                </td>
                                                <td class="text-end text-danger">
                                                    @if (s.Kesinti > 0) { <span>-@FormatPara(s.Kesinti)</span> }
                                                    else { <span class="text-muted">-</span> }
                                                </td>
                                                <td class="text-end text-success">
                                                    @if (s.Harcamasi > 0) { <span>+@FormatPara(s.Harcamasi)</span> }
                                                    else { <span class="text-muted">-</span> }
                                                </td>
                                                <td class="text-end fw-bold @(s.Odenecek >= 0 ? "text-success" : "text-danger")">
                                                    @FormatPara(s.Odenecek)
                                                </td>
                                                        <td>
                                                            @if (s.Odenecek > 0)
                                                            {
                                                                <span class="badge bg-warning text-dark" style="font-size:0.65rem;">Elden Ödenecek</span>
                                                            }
                                                            else if (s.BankayaYatan > 0)
                                                            {
                                                                <span class="badge bg-success" style="font-size:0.65rem;">Banka Ödemesi</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-secondary" style="font-size:0.65rem;">Ödeme Yok</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary py-0 px-2" title="Detay" @onclick:stopPropagation="true"
                                                                    @onclick="() => DurumPersonelSec(s.PersonelId)">
                                                                <i class="bi bi-person-lines-fill"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                    </tbody>
                                    <tfoot class="table-dark">
                                        <tr>
                                            <td colspan="3"><strong>TOPLAM (@DurFiltreliSatirlar.Count() personel)</strong></td>
                                            <td class="text-end"><strong>@FormatPara(DurFiltreliSatirlar.Sum(s => s.GercekMaas))</strong></td>
                                            <td class="text-end"><strong>@FormatPara(DurFiltreliSatirlar.Sum(s => s.BankayaYatan))</strong></td>
                                            <td class="text-end text-warning"><strong>-@FormatPara(DurFiltreliSatirlar.Sum(s => s.Avans))</strong></td>
                                            <td class="text-end text-danger"><strong>-@FormatPara(DurFiltreliSatirlar.Sum(s => s.Kesinti))</strong></td>
                                            <td class="text-end text-success"><strong>+@FormatPara(DurFiltreliSatirlar.Sum(s => s.Harcamasi))</strong></td>
                                                    <td class="text-end"><strong>@FormatPara(DurFiltreliSatirlar.Sum(s => s.Odenecek))</strong></td>
                                                    <td></td>
                                                    <td></td>
                                                </tr>
                                            </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SAĞ: Personel Detay Paneli -->
                @if (durSecilenPersonelId > 0 && durSecilenPersonel != null)
                {
                    <div class="col-lg-5">
                        <div class="card shadow-sm sticky-top" style="top: 10px;">
                            <div class="card-header bg-primary text-white py-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-0">@durSecilenPersonel.TamAd</h5>
                                        <small>@GetGorevAdi(durSecilenPersonel.Gorev) @(!string.IsNullOrEmpty(durSecilenPersonel.Departman) ? $"/ {durSecilenPersonel.Departman}" : "")</small>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a href="/personel/@durSecilenPersonel.Id" class="btn btn-sm btn-outline-light" title="Personel Kartını Düzenle">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-light" @onclick="DurumPaneliKapat" title="Paneli Kapat">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body p-0" style="max-height: 75vh; overflow-y: auto;">
                                <!-- Maaş Özet -->
                                <div class="p-3 border-bottom">
                                    <h6 class="text-primary mb-2"><i class="bi bi-wallet2 me-1"></i>Maaş Bilgileri</h6>
                                    <div class="row g-2 text-center">
                                        <div class="col-4">
                                            <div class="bg-light rounded p-2">
                                                <small class="text-muted d-block">Gerçek Maaş</small>
                                                <strong>@FormatPara(durSecilenPersonel.NetMaas)</strong>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="bg-light rounded p-2">
                                                <small class="text-muted d-block">Bankaya Yatan</small>
                                                <strong>@FormatPara(durSecilenPersonel.ResmiNetMaas)</strong>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="bg-light rounded p-2">
                                                <small class="text-muted d-block">Brüt</small>
                                                <strong>@FormatPara(durSecilenPersonel.BrutMaas)</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Alt Sekmeler -->
                                <ul class="nav nav-tabs px-3 pt-2" role="tablist">
                                    <li class="nav-item">
                                        <button class="nav-link small py-1 @(durAktifSekme == "ekstra" ? "active" : "")" @onclick='() => DurumSekmeDegistir("ekstra")'>
                                            <i class="bi bi-receipt me-1"></i>Ekstre
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link small py-1 @(durAktifSekme == "avans" ? "active" : "")" @onclick='() => DurumSekmeDegistir("avans")'>
                                            <i class="bi bi-cash me-1"></i>Avanslar
                                            @if (durAvanslar.Any(a => a.Durum == AvansDurum.Verildi || a.Durum == AvansDurum.KismenMahsup))
                                            {
                                                <span class="badge bg-warning text-dark ms-1">@durAvanslar.Count(a => a.Durum == AvansDurum.Verildi || a.Durum == AvansDurum.KismenMahsup)</span>
                                            }
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link small py-1 @(durAktifSekme == "borc" ? "active" : "")" @onclick='() => DurumSekmeDegistir("borc")'>
                                            <i class="bi bi-exclamation-triangle me-1"></i>Borçlar
                                            @if (durBorclar.Any(b => b.OdemeDurum != BorcOdemeDurum.TamamenOdendi))
                                            {
                                                <span class="badge bg-danger ms-1">@durBorclar.Count(b => b.OdemeDurum != BorcOdemeDurum.TamamenOdendi)</span>
                                            }
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link small py-1 @(durAktifSekme == "maas" ? "active" : "")" @onclick='() => DurumSekmeDegistir("maas")'>
                                            <i class="bi bi-clock-history me-1"></i>Maaş Geçmişi
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link small py-1 @(durAktifSekme == "harcama" ? "active" : "")" @onclick='() => DurumSekmeDegistir("harcama")'>
                                            <i class="bi bi-bag me-1"></i>Harcamalar
                                            @if (durCebHarcamalar.Any())
                                            {
                                                <span class="badge bg-success ms-1">@durCebHarcamalar.Count</span>
                                            }
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link small py-1 @(durAktifSekme == "pusula" ? "active" : "")" @onclick='() => DurumSekmeDegistir("pusula")'>
                                            <i class="bi bi-file-text me-1"></i>H.Pusulası
                                        </button>
                                    </li>
                                </ul>
                                <div class="p-3">
                                    @if (durDetayYukleniyor)
                                    {
                                        <div class="text-center py-3">
                                            <div class="spinner-border spinner-border-sm text-primary"></div>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (durAktifSekme == "ekstra")
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm mb-0">
                                                    @if (durFinansOzet != null)
                                                    {
                                                        <tr><td>Açık Avans</td><td class="text-end text-warning fw-bold">@FormatPara(durFinansOzet.KalanAvans)</td></tr>
                                                        <tr><td>Kalan Borç</td><td class="text-end text-danger fw-bold">@FormatPara(durFinansOzet.KalanBorc)</td></tr>
                                                        @if (durFinansOzet.ToplamHarcama > 0)
                                                        {
                                                            <tr>
                                                                <td>Cebinden Harcama
                                                                    <button class="btn btn-link btn-sm p-0 ms-1" style="font-size:0.7rem;" @onclick='() => DurumSekmeDegistir("harcama")' title="Harcama Detayı">
                                                                        <i class="bi bi-list-ul"></i> detay
                                                                    </button>
                                                                </td>
                                                                <td class="text-end text-success fw-bold">+@FormatPara(durFinansOzet.ToplamHarcama)</td>
                                                            </tr>
                                                        }
                                                        <tr class="table-light">
                                                            <td><strong>Net Durum</strong></td>
                                                            <td class="text-end fw-bold @(durFinansOzet.NetDurum >= 0 ? "text-danger" : "text-success")">
                                                                @FormatPara(Math.Abs(durFinansOzet.NetDurum))
                                                                <small>(@durFinansOzet.NetDurumAciklama)</small>
                                                            </td>
                                                        </tr>
                                                    }
                                                </table>
                                            </div>
                                            @if (durEkstreHareketler.Any())
                                            {
                                                <h6 class="mt-3 mb-2 small text-muted">Son Hareketler</h6>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light">
                                                            <tr><th>Tarih</th><th>Açıklama</th><th class="text-end">Tutar</th></tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var hareket in durEkstreHareketler.Take(20))
                                                            {
                                                                <tr>
                                                                    <td><small>@hareket.Tarih.ToString("dd.MM.yy")</small></td>
                                                                    <td><small>@hareket.Aciklama</small></td>
                                                                    <td class="text-end @(hareket.Tutar >= 0 ? "text-success" : "text-danger")">
                                                                        <small><strong>@(hareket.Tutar >= 0 ? "+" : "")@FormatPara(hareket.Tutar)</strong></small>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-center text-muted py-3"><i class="bi bi-inbox fs-3"></i><p class="small mt-1">Henüz hareket yok</p></div>
                                            }
                                        }
                                        @if (durAktifSekme == "avans")
                                        {
                                            <div class="d-flex justify-content-end mb-2">
                                                <button class="btn btn-sm btn-success" @onclick="YeniAvansModalAc" disabled="@(durSecilenPersonelId == 0)">
                                                    <i class="bi bi-plus-circle me-1"></i>Yeni Avans
                                                </button>
                                            </div>
                                            @if (durAvanslar.Any())
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light"><tr><th>Tarih</th><th class="text-end">Tutar</th><th class="text-end">Kalan</th><th>Durum</th><th style="width:72px;"></th></tr></thead>
                                                        <tbody>
                                                            @foreach (var avans in durAvanslar.OrderByDescending(a => a.AvansTarihi))
                                                            {
                                                                <tr>
                                                                    <td><small>@avans.AvansTarihi.ToString("dd.MM.yy")</small></td>
                                                                    <td class="text-end"><small>@FormatPara(avans.Tutar)</small></td>
                                                                    <td class="text-end"><small class="fw-bold text-warning">@FormatPara(avans.Kalan)</small></td>
                                                                    <td><span class="badge @GetAvansDurumBadge(avans.Durum)" style="font-size:0.65rem;">@GetAvansDurumAdi(avans.Durum)</span></td>
                                                                    <td class="text-end">
                                                                        <button class="btn btn-sm btn-outline-primary py-0 px-1 me-1" title="Düzenle" @onclick="() => AvanssDuzenleAc(avans)">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </button>
                                                                        <button class="btn btn-sm btn-outline-danger py-0 px-1" title="Sil" @onclick="() => AvansSil(avans)">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot class="table-light">
                                                            <tr>
                                                                <td><strong>Toplam</strong></td>
                                                                <td class="text-end"><strong>@FormatPara(durAvanslar.Sum(a => a.Tutar))</strong></td>
                                                                <td class="text-end"><strong class="text-warning">@FormatPara(durAvanslar.Sum(a => a.Kalan))</strong></td>
                                                                <td></td><td></td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            }
                                            else { <div class="text-center text-muted py-3"><i class="bi bi-cash fs-3"></i><p class="small mt-1">Avans kaydı yok</p><button class="btn btn-sm btn-success mt-1" @onclick="YeniAvansModalAc"><i class="bi bi-plus-circle me-1"></i>Yeni Avans Ekle</button></div> }
                                        }
                                        @if (durAktifSekme == "borc")
                                        {
                                            @if (durBorclar.Any())
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light"><tr><th>Tarih</th><th>Açıklama</th><th class="text-end">Tutar</th><th class="text-end">Kalan</th><th>Durum</th><th style="width:90px;"></th></tr></thead>
                                                        <tbody>
                                                            @foreach (var borc in durBorclar.OrderByDescending(b => b.BorcTarihi))
                                                            {
                                                                <tr>
                                                                    <td><small>@borc.BorcTarihi.ToString("dd.MM.yy")</small></td>
                                                                    <td><small>@(borc.Aciklama ?? borc.BorcTipi.ToString())</small></td>
                                                                    <td class="text-end"><small>@FormatPara(borc.Tutar)</small></td>
                                                                    <td class="text-end"><small class="fw-bold text-danger">@FormatPara(borc.KalanBorc)</small></td>
                                                                    <td><span class="badge @GetBorcDurumBadge(borc.OdemeDurum)" style="font-size:0.65rem;">@GetBorcDurumAdi(borc.OdemeDurum)</span></td>
                                                                    <td class="text-end">
                                                                        @if (borc.OdemeDurum != BorcOdemeDurum.TamamenOdendi)
                                                                        {
                                                                            <button class="btn btn-sm btn-outline-success py-0 px-1 me-1" title="Öde" @onclick="() => BorcOdemeModalAc(borc)">
                                                                                <i class="bi bi-cash-coin"></i>
                                                                            </button>
                                                                        }
                                                                        <button class="btn btn-sm btn-outline-primary py-0 px-1 me-1" title="Düzenle" @onclick="() => BorcDuzenleAc(borc)">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </button>
                                                                        @if (CanBorcKaydiKaliciSil)
                                                                        {
                                                                            <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => DurumBorcKaydiniSil(borc)" title="Kalıcı Sil">
                                                                                <i class="bi bi-trash"></i>
                                                                            </button>
                                                                        }
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot class="table-light">
                                                            <tr>
                                                                <td colspan="2"><strong>Toplam</strong></td>
                                                                <td class="text-end"><strong>@FormatPara(durBorclar.Sum(b => b.Tutar))</strong></td>
                                                                <td class="text-end"><strong class="text-danger">@FormatPara(durBorclar.Sum(b => b.KalanBorc))</strong></td>
                                                                <td></td><td></td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            }
                                            else { <div class="text-center text-muted py-3"><i class="bi bi-check-circle fs-3 text-success"></i><p class="small mt-1">Borç kaydı yok</p></div> }
                                        }
                                        @if (durAktifSekme == "maas")
                                        {
                                            @if (durMaasGecmisi.Any())
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light"><tr><th>Dönem</th><th class="text-end">Brüt</th><th class="text-end">Net</th><th>Durum</th><th style="width:60px;"></th></tr></thead>
                                                        <tbody>
                                                            @foreach (var maas in durMaasGecmisi.OrderByDescending(m => m.Yil * 100 + m.Ay))
                                                            {
                                                                <tr>
                                                                    <td><small>@(new DateTime(maas.Yil, maas.Ay, 1).ToString("MMM yyyy"))</small></td>
                                                                    <td class="text-end"><small>@maas.BrutMaas.ToString("N2")</small></td>
                                                                    <td class="text-end"><small class="fw-bold">@maas.NetMaas.ToString("N2")</small></td>
                                                                    <td>
                                                                        @if (maas.OdemeTarihi.HasValue) { <span class="badge bg-success" style="font-size:0.6rem;">Ödendi</span> }
                                                                        else { <span class="badge bg-warning text-dark" style="font-size:0.6rem;">Bekliyor</span> }
                                                                    </td>
                                                                    <td class="text-end">
                                                                        <button class="btn btn-sm btn-outline-primary py-0 px-1 me-1" title="Düzenle" @onclick="() => DuzenleAc(maas.Id)">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </button>
                                                                        <button class="btn btn-sm btn-outline-danger py-0 px-1" title="Sil" @onclick="() => MaasSilOnay(maas)">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                            else { <div class="text-center text-muted py-3"><i class="bi bi-calendar-x fs-3"></i><p class="small mt-1">Maaş geçmişi yok</p></div> }
                                        }
                                        @if (durAktifSekme == "harcama")
                                        {
                                            @if (durCebHarcamalar.Any())
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light"><tr><th>Tarih</th><th>Açıklama</th><th>Kaynak</th><th class="text-end">Tutar</th><th>Durum</th></tr></thead>
                                                        <tbody>
                                                            @foreach (var h in durCebHarcamalar.OrderByDescending(x => x.Tarih))
                                                            {
                                                                <tr>
                                                                    <td><small>@h.Tarih.ToString("dd.MM.yy")</small></td>
                                                                    <td><small>@h.Aciklama</small></td>
                                                                    <td><small class="text-muted">@(h.Kaynak == "AracMasraf" ? "Araç Masraf" : "Banka/Kasa")</small></td>
                                                                    <td class="text-end"><small class="fw-bold text-success">+@FormatPara(h.Tutar)</small></td>
                                                                    <td>
                                                                        @if (h.PersoneleOdendi) { <span class="badge bg-success" style="font-size:0.6rem;">Ödendi</span> }
                                                                        else { <span class="badge bg-warning text-dark" style="font-size:0.6rem;">Bekliyor</span> }
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot class="table-light">
                                                            <tr>
                                                                <td colspan="3"><strong>Toplam</strong></td>
                                                                <td class="text-end"><strong class="text-success">+@FormatPara(durCebHarcamalar.Sum(h => h.Tutar))</strong></td>
                                                                <td><small class="text-muted">@durCebHarcamalar.Count(h => !h.PersoneleOdendi) bekliyor</small></td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            }
                                            else { <div class="text-center text-muted py-3"><i class="bi bi-bag-check fs-3 text-success"></i><p class="small mt-1">Cebinden harcama kaydı yok</p></div> }
                                        }
                                        @if (durAktifSekme == "pusula")
                                        {
                                            @if (durBordroDetay != null)
                                            {
                                                <table class="table table-sm mb-0">
                                                    <tr><td>Brüt Maaş</td><td class="text-end">@durBordroDetay.BrutMaas.ToString("N2") ₺</td></tr>
                                                    <tr><td>SGK / İşsizlik</td><td class="text-end text-danger">-@durBordroDetay.SgkIssizlikKesinti.ToString("N2") ₺</td></tr>
                                                    <tr><td>Gelir Vergisi</td><td class="text-end text-danger">-@durBordroDetay.GelirVergisi.ToString("N2") ₺</td></tr>
                                                    <tr><td>Damga Vergisi</td><td class="text-end text-danger">-@durBordroDetay.DamgaVergisi.ToString("N2") ₺</td></tr>
                                                    <tr class="table-info"><td><strong>Net Maaş (Bordro)</strong></td><td class="text-end"><strong>@durBordroDetay.NetMaas.ToString("N2") ₺</strong></td></tr>
                                                    @if (durBordroDetay.ToplamEkOdeme > 0) { <tr><td>Ek Ödemeler</td><td class="text-end text-success">+@durBordroDetay.ToplamEkOdeme.ToString("N2") ₺</td></tr> }
                                                    @if (durBordroDetay.ToplamKesinti > 0) { <tr><td>Kesintiler</td><td class="text-end text-danger">-@durBordroDetay.ToplamKesinti.ToString("N2") ₺</td></tr> }
                                                    <tr class="table-success"><td><strong>Toplam Ödenecek</strong></td><td class="text-end"><strong>@durBordroDetay.ToplamOdenecek.ToString("N2") ₺</strong></td></tr>
                                                    <tr class="table-secondary"><td><i class="bi bi-building me-1"></i>İşveren Maliyeti</td><td class="text-end">@durBordroDetay.ToplamIsverenMaliyet.ToString("N2") ₺</td></tr>
                                                </table>
                                            }
                                            else { <div class="text-center text-muted py-3"><i class="bi bi-file-earmark-x fs-3"></i><p class="small mt-1">Bu dönem için bordro bulunamadı</p></div> }
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- ============================================================ -->
<!-- MODALS                                                        -->
