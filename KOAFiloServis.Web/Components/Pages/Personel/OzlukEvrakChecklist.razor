    private static string EncExtensionTemizle(string? fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName))
            return "evrak.pdf";

        while (fileName.EndsWith(".enc", StringComparison.OrdinalIgnoreCase))
            fileName = fileName[..^4];

        return fileName;
    }

    private async Task EvrakOnizle(OzlukEvrakDetay evrak)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(evrak.DosyaYolu))
            {
                ToastService.ShowWarning("Evrak dosya yolu bulunamadı.");
                return;
            }

            var bytes = await SecureFileService.ReadDecryptedAsync(evrak.DosyaYolu);
            if (bytes == null || bytes.Length == 0)
            {
                var onay = await JS.InvokeAsync<bool>(
                    "confirm",
                    $"'{evrak.EvrakAdi}' dosyası bulunamadı veya boş. Bozuk dosya kaydını temizleyip yeniden yüklemek ister misiniz?");

                if (onay && seciliDurum != null)
                {
                    await TemizleBozukEvrakReferansiAsync(seciliDurum.SoforId, evrak);
                }
                else
                {
                    ToastService.ShowWarning("Dosya bulunamadı veya boş.");
                }

                return;
            }

            var dosyaAdi = EncExtensionTemizle(
                BuildEvrakDosyaAdi(evrak.EvrakAdi, evrak.DosyaYolu));

            var contentType = GetMimeType(dosyaAdi);

            onizlemeBaslik = dosyaAdi;
            onizlemeDosyaAdi = dosyaAdi;
            onizlemeContentType = contentType;
            onizlemeBase64 = Convert.ToBase64String(bytes);
            onizlemeDataUrl = $"data:{contentType};base64,{onizlemeBase64}";

            onizlemeDestekleniyor =
                contentType == "application/pdf" ||
                contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);

            onizlemeModalAcik = true;

            Logger.LogInformation(
                "Personel evrak önizleniyor. EvrakAdi={EvrakAdi}, DosyaAdi={DosyaAdi}, ContentType={ContentType}",
                evrak.EvrakAdi, dosyaAdi, contentType);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Personel evrak önizleme hatası. Evrak={EvrakAdi}, DosyaYolu={DosyaYolu}",
                evrak.EvrakAdi, evrak.DosyaYolu);
            ToastService.ShowError("Evrak önizlenemedi. Dosya şifresi çözülemedi veya dosya bulunamadı.");
        }
    }

    private async Task TemizleBozukEvrakReferansiAsync(int soforId, OzlukEvrakDetay evrak)
    {
        try
        {
            var personelEvrak = await OzlukService.EvrakIsaretle(soforId, evrak.EvrakTanimId, false, evrak.Aciklama);
            personelEvrak.DosyaYolu = null;
            personelEvrak.DosyaAdi = null;
            personelEvrak.DosyaTipi = null;
            personelEvrak.DosyaBoyutu = null;
            personelEvrak.Tamamlandi = false;
            personelEvrak.TamamlanmaTarihi = null;
            personelEvrak.SonDegisiklikNotu = "Bozuk dosya referansı temizlendi";

            await OzlukService.UpdatePersonelEvrakAsync(personelEvrak);
            seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
            await EvrakGecerlilikTarihleriniYukleAsync(soforId);
            await LoadData();

            ToastService.ShowInfo($"{evrak.EvrakAdi} için bozuk dosya kaydı temizlendi. 'Dosya Seç' ile yeniden yükleyebilirsiniz.");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Bozuk evrak referansı temizlenemedi. SoforId={SoforId}, EvrakTanimId={EvrakTanimId}", soforId, evrak.EvrakTanimId);
            ToastService.ShowError("Bozuk dosya kaydı temizlenemedi.");
        }
    }

    private async Task EvrakYazdir(OzlukEvrakDetay evrak)
    {
        // Önce önizle (state'i doldur), sonra modalda kullanıcı yazdırsın
        await EvrakOnizle(evrak);
    }

    private async Task OnizlenenDosyayiIndir()
    {
        if (string.IsNullOrWhiteSpace(onizlemeBase64) ||
            string.IsNullOrWhiteSpace(onizlemeDosyaAdi) ||
            string.IsNullOrWhiteSpace(onizlemeContentType))
            return;

        await JS.InvokeVoidAsync(
            "downloadFileFromBase64",
            onizlemeDosyaAdi,
            onizlemeBase64,
            onizlemeContentType);
    }

    private async Task OnizlenenDosyayiYazdir()
    {
        if (string.IsNullOrWhiteSpace(onizlemeBase64) ||
            string.IsNullOrWhiteSpace(onizlemeContentType))
            return;

        if (!onizlemeDestekleniyor)
        {
            ToastService.ShowWarning("Bu dosya türü yazdırma için desteklenmiyor.");
            return;
        }

        await JS.InvokeVoidAsync(
            "printBase64File",
            onizlemeBase64,
            onizlemeContentType);
    }

    private void OnizlemeKapat()
    {
        onizlemeModalAcik = false;
        onizlemeBaslik = null;
        onizlemeContentType = null;
        onizlemeBase64 = null;
        onizlemeDataUrl = null;
        onizlemeDosyaAdi = null;
        onizlemeDestekleniyor = false;
    }

    private static string GetMimeType(string fileName)
    {
        return Path.GetExtension(fileName).ToLowerInvariant() switch
        {
            ".pdf" => "application/pdf",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".webp" => "image/webp",
            ".doc" => "application/msword",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            ".xls" => "application/vnd.ms-excel",
            ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            _ => "application/octet-stream"
        };
    }

    private static int GetZorunluEksikEvrakSayisi(PersonelOzlukEvrakDurum durum)
        => durum.Evraklar.Count(e => !e.Tamamlandi && e.Zorunlu);

    private static string GetEksikEvrakOzeti(PersonelOzlukEvrakDurum durum, int maxAdet = 3)
    {
        var eksikEvraklar = durum.Evraklar
            .Where(e => !e.Tamamlandi)
            .OrderByDescending(e => e.Zorunlu)
            .ThenBy(e => e.Kategori)
            .ThenBy(e => e.EvrakAdi)
            .Select(e => e.EvrakAdi)
            .ToList();

        if (!eksikEvraklar.Any())
            return "Eksik evrak bulunmuyor.";

        var gosterilecekler = eksikEvraklar.Take(maxAdet).ToList();
        var ozet = string.Join(", ", gosterilecekler);
        var kalan = eksikEvraklar.Count - gosterilecekler.Count;

        return kalan > 0 ? $"{ozet} + {kalan} evrak daha" : ozet;
    }

