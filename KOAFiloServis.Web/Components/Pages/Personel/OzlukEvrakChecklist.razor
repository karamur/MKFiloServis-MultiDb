@page "/personel/ozluk-evrak"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Data
@using KOAFiloServis.Web.Helpers
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject IPersonelOzlukService OzlukService
@inject ISoforService SoforService
@inject ISecureFileService SecureFileService
@inject IEvrakArsivService EvrakArsivService
@inject IToastService ToastService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS
@inject ILogger<OzlukEvrakChecklist> Logger
@rendermode InteractiveServer

<PageTitle>Personel Özlük Evrak Checklist</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4><i class="bi bi-clipboard-check me-2 text-warning"></i>Personel Özlük Evrak Checklist</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/dashboard">Ana Sayfa</a></li>
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Özlük Evrak Checklist</li>
                </ol>
            </nav>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-primary" @onclick="SeciliEksikListeAc" disabled="@(!seciliSoforIdler.Any())">
                <i class="bi bi-list-check me-1"></i>Seçili Eksik Listesi
            </button>
            <button class="btn btn-outline-dark" @onclick="BosPersonelDosyasiIndir">
                <i class="bi bi-file-earmark-plus me-1"></i>Boş Personel Dosyası
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelIndir">
                <i class="bi bi-file-earmark-excel me-1"></i>Tüm Checklist Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick="EvrakTanimModalAc">
                <i class="bi bi-gear me-1"></i>Evrak Tanımları
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="filtreGorev">
                        <option value="">Tüm Görevler</option>
                        @foreach (PersonelGorev gorev in Enum.GetValues<PersonelGorev>())
                        {
                            <option value="@((int)gorev)">@GetGorevAdi(gorev)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tüm Durumlar</option>
                        <option value="eksik">Eksik Evraklı</option>
                        <option value="tamam">Tamamlanmış</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input type="text" class="form-control form-control-sm" placeholder="Personel ara..." 
                           @bind="aramaMetni" @bind:event="oninput" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-sm btn-primary w-100" @onclick="LoadData">
                        <i class="bi bi-search me-1"></i>Filtrele
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Özet Kartlar -->
    @if (durumlar != null)
    {
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@durumlar.Count</h3>
                        <small>Toplam Personel</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@durumlar.Count(d => d.EksikEvrak == 0)</h3>
                        <small>Dosyası Tam</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@durumlar.Count(d => d.EksikEvrak > 0)</h3>
                        <small>Eksik Evraklı</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center py-3">
                        <h3 class="mb-0">@(durumlar.Count > 0 ? Math.Round(durumlar.Average(d => d.TamamlanmaYuzdesi), 1) : 0)%</h3>
                        <small>Ortalama Tamamlanma</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Personel Listesi -->
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center" style="width: 40px;">
                                    <input class="form-check-input" type="checkbox" checked="@TumFiltrelenmislerSecili" @onchange="TumunuSec" />
                                </th>
                                <th>Personel</th>
                                <th>Görev</th>
                                <th class="text-center">Toplam</th>
                                <th class="text-center">Tamam</th>
                                <th class="text-center">Eksik</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center" style="width: 150px;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var durum in FiltrelenmisListe)
                            {
                                <tr>
                                    <td class="text-center align-middle">
                                        <input class="form-check-input" type="checkbox" checked="@seciliSoforIdler.Contains(durum.SoforId)"
                                               @onchange="e => PersonelSecimDegistir(durum.SoforId, (bool)e.Value!)" />
                                    </td>
                                    <td>
                                        <strong>@durum.PersonelAdi</strong>
                                        <br /><small class="text-muted">@durum.PersonelKodu</small>
                                        @if (durum.EksikEvrak > 0)
                                        {
                                            <div class="mt-1">
                                                @if (GetZorunluEksikEvrakSayisi(durum) > 0)
                                                {
                                                    <span class="badge bg-danger me-1">@GetZorunluEksikEvrakSayisi(durum) zorunlu eksik</span>
                                                }
                                                <small class="text-danger d-block">
                                                    <i class="bi bi-exclamation-circle me-1"></i>@GetEksikEvrakOzeti(durum)
                                                </small>
                                            </div>
                                        }
                                    </td>
                                    <td>@GetGorevAdi(durum.Gorev)</td>
                                    <td class="text-center">@durum.ToplamEvrak</td>
                                    <td class="text-center text-success">@durum.TamamlananEvrak</td>
                                    <td class="text-center text-danger">@durum.EksikEvrak</td>
                                    <td class="text-center">
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar @(durum.TamamlanmaYuzdesi == 100 ? "bg-success" : durum.TamamlanmaYuzdesi >= 50 ? "bg-warning" : "bg-danger")" 
                                                 role="progressbar" style="width: @durum.TamamlanmaYuzdesi%">
                                                %@durum.TamamlanmaYuzdesi
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => DetayAc(durum.SoforId)"
                                                title="Detay Görüntüle">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-dark me-1" @onclick="() => PersonelDosyasiIndir(durum.SoforId)"
                                                title="Dosya Hazırla">
                                            <i class="bi bi-file-earmark-text"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => PdfIndir(durum.SoforId)"
                                                title="PDF İndir">
                                            <i class="bi bi-file-pdf"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
</div>

<!-- Detay Modal -->
@if (showDetayModal && seciliDurum != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-clipboard-check me-2"></i>
                        @seciliDurum.PersonelAdi - Özlük Evrak Checklist
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="DetayKapat"></button>
                </div>
                <div class="modal-body">

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button type="button" class="btn btn-sm @(detayBelgeFiltre == "" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => detayBelgeFiltre = ""'>Tümü</button>
                        <button type="button" class="btn btn-sm @(detayBelgeFiltre == "ehliyet" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => detayBelgeFiltre = "ehliyet"'>Ehliyet</button>
                        <button type="button" class="btn btn-sm @(detayBelgeFiltre == "diploma" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => detayBelgeFiltre = "diploma"'>Diploma</button>
                        <button type="button" class="btn btn-sm @(detayBelgeFiltre == "sertifika" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => detayBelgeFiltre = "sertifika"'>Sertifika</button>
                        <button type="button" class="btn btn-sm @(detayBelgeFiltre == "saglik" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => detayBelgeFiltre = "saglik"'>Sağlık Raporu</button>
                        <button type="button" class="btn btn-sm @(detayBelgeFiltre == "sozlesme" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => detayBelgeFiltre = "sozlesme"'>İş Sözleşmesi</button>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-8">
                            <input type="text"
                                   class="form-control form-control-sm"
                                   placeholder="Evrak ara..."
                                   @bind="detayAramaMetni"
                                   @bind:event="oninput" />
                        </div>
                        <div class="col-md-4 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="detaySadeceEksik" @bind="detaySadeceEksik" />
                                <label class="form-check-label" for="detaySadeceEksik">Sadece eksikler</label>
                            </div>
                        </div>
                    </div>

                    <!-- Özet -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="card border-primary">
                                <div class="card-body text-center py-2">
                                    <h4 class="mb-0 text-primary">@seciliDurum.ToplamEvrak</h4>
                                    <small>Toplam Evrak</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-success">
                                <div class="card-body text-center py-2">
                                    <h4 class="mb-0 text-success">@seciliDurum.TamamlananEvrak</h4>
                                    <small>Tamamlanan</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-danger">
                                <div class="card-body text-center py-2">
                                    <h4 class="mb-0 text-danger">@seciliDurum.EksikEvrak</h4>
                                    <small>Eksik</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-info">
                                <div class="card-body text-center py-2">
                                    <h4 class="mb-0 text-info">%@seciliDurum.TamamlanmaYuzdesi</h4>
                                    <small>Tamamlanma</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (seciliDurum.EksikEvrak > 0)
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <div class="fw-semibold mb-1">
                                <i class="bi bi-exclamation-triangle me-1"></i>Eksik Evrak Özeti
                            </div>
                            <small>@GetEksikEvrakOzeti(seciliDurum, 6)</small>
                        </div>
                    }

                    <!-- Evrak Listesi Kategorilere Göre -->
                    @foreach (var kategori in FiltrelenmisSeciliEvraklar.GroupBy(e => e.Kategori).OrderBy(g => g.Key))
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-light py-2">
                                <strong><i class="bi bi-folder me-1"></i>@GetKategoriAdi(kategori.Key)</strong>
                                <span class="badge @(kategori.All(e => e.Tamamlandi) ? "bg-success" : "bg-warning") float-end">
                                    @kategori.Count(e => e.Tamamlandi) / @kategori.Count()
                                </span>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <tbody>
                                        @foreach (var evrak in kategori.OrderBy(e => e.EvrakAdi))
                                        {
                                            <tr class="@(GetRowClass(evrak))">
                                                <td style="width: 40px;">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox"
                                                               checked="@IsEvrakTamam(evrak)"
                                                               @onchange="e => EvrakDurumDegistir(seciliDurum.SoforId, evrak.EvrakTanimId, (bool)e.Value!)" />
                                                    </div>
                                                </td>
                                                <td>
                                                    @evrak.EvrakAdi
                                                    @if (evrak.Zorunlu)
                                                    {
                                                        <span class="badge bg-danger ms-1">Zorunlu</span>
                                                    }
                                                    @{ var ye = GetYeniEvrak(evrak.EvrakAdi); }
                                                    @if (ye != null)
                                                    {
                                                        <br /><small class="text-success"><i class="bi bi-file-check me-1"></i>@ye.DosyaAdi</small>
                                                    }
                                                    @if (!string.IsNullOrEmpty(evrak.Aciklama))
                                                    {
                                                        <br /><small class="text-muted">@evrak.Aciklama</small>
                                                    }
                                                </td>
                                                <td class="text-center" style="width: 100px;">
                                                    @if (IsEvrakTamam(evrak))
                                                    {
                                                        <span class="badge bg-success">
                                                            <i class="bi bi-check-circle me-1"></i>@(ye != null && !evrak.Tamamlandi ? "DB'de var" : "Tamam")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">
                                                            <i class="bi bi-x-circle me-1"></i>Eksik
                                                        </span>
                                                    }
                                                </td>
                                                 <td class="text-end text-muted" style="width: 100px;">
                                                    @if (evrak.TamamlanmaTarihi.HasValue)
                                                    {
                                                        <small>@evrak.TamamlanmaTarihi.Value.ToString("dd.MM.yyyy")</small>
                                                    }
                                                </td>
                                                 <td style="width: 420px;">
                                                     <div class="d-flex gap-2 align-items-center">
                                                         @if (GecerlilikTarihiDestekleniyor(evrak))
                                                         {
                                                             <input type="date"
                                                                    class="form-control form-control-sm"
                                                                    style="max-width: 150px;"
                                                                    value="@FormatDateInput(GetEvrakGecerlilikTarihi(evrak.EvrakTanimId))"
                                                                    title="@(EvrakTuruBelirle(evrak) == "Sozlesme" ? "Sözleşme tarihi" : "Geçerlilik tarihi")"
                                                                    @onchange="e => EvrakGecerlilikTarihiDegistiAsync(seciliDurum.SoforId, evrak, e)" />
                                                         }
                                                         @if (!string.IsNullOrWhiteSpace(evrak.DosyaYolu))
                                                         {
                                                             <button type="button" class="btn btn-sm btn-outline-primary"
                                                                     title="Önizle"
                                                                     @onclick="() => EvrakOnizle(evrak)">
                                                                 <i class="bi bi-eye"></i>
                                                             </button>
                                                             <button type="button" class="btn btn-sm btn-outline-secondary"
                                                                     title="Dosyayı indir"
                                                                     @onclick="() => EvrakDosyasiIndir(evrak)">
                                                                 <i class="bi bi-download"></i>
                                                             </button>
                                                             <button type="button" class="btn btn-sm btn-outline-dark"
                                                                     title="Yazdır"
                                                                     @onclick="() => EvrakYazdir(evrak)">
                                                                 <i class="bi bi-printer"></i>
                                                             </button>
                                                         }
                                                         <InputFile class="form-control form-control-sm"
                                                                    OnChange="e => EvrakDosyaSecildi(seciliDurum.SoforId, evrak, e)"
                                                                    accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                                                     </div>
                                                 </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" @onclick="() => PdfIndir(seciliDurum.SoforId)">
                        <i class="bi bi-file-pdf me-1"></i>PDF İndir
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="DetayKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Önizleme Modal -->
@if (onizlemeModalAcik)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@onizlemeBaslik</h5>
                    <button type="button" class="btn-close" @onclick="OnizlemeKapat"></button>
                </div>

                <div class="modal-body" style="min-height: 75vh;">
                    @if (!onizlemeDestekleniyor)
                    {
                        <div class="alert alert-warning">
                            Bu dosya türü için önizleme desteklenmiyor. Dosyayı indirerek açabilirsiniz.
                        </div>
                    }
                    else if (onizlemeContentType == "application/pdf")
                    {
                        <iframe src="@onizlemeDataUrl"
                                style="width:100%; height:75vh; border:0;">
                        </iframe>
                    }
                    else if (onizlemeContentType?.StartsWith("image/") == true)
                    {
                        <img src="@onizlemeDataUrl"
                             style="max-width:100%; height:auto;"
                             alt="@onizlemeBaslik" />
                    }
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="OnizlemeKapat">Kapat</button>
                    <button class="btn btn-outline-primary"
                            @onclick="OnizlenenDosyayiIndir">
                        <i class="bi bi-download me-1"></i>İndir
                    </button>
                    <button class="btn btn-primary"
                            @onclick="OnizlenenDosyayiYazdir"
                            disabled="@(!onizlemeDestekleniyor)">
                        <i class="bi bi-printer me-1"></i>Yazdır
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Evrak Tanım Modal -->
@if (showTanimModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-gear me-2"></i>Evrak Tanımları
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="TanimModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-end mb-3">
                        <button class="btn btn-sm btn-success" @onclick="YeniEvrakTanimEkle">
                            <i class="bi bi-plus-lg me-1"></i>Yeni Evrak Ekle
                        </button>
                    </div>

                    @if (evrakTanimlari != null)
                    {
                        @foreach (var kategori in evrakTanimlari.GroupBy(e => e.Kategori).OrderBy(g => g.Key))
                        {
                            <div class="card mb-2">
                                <div class="card-header bg-light py-2">
                                    <strong>@GetKategoriAdi(kategori.Key)</strong>
                                </div>
                                <ul class="list-group list-group-flush">
                                    @foreach (var tanim in kategori.OrderBy(t => t.SiraNo))
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                @tanim.EvrakAdi
                                                @if (tanim.Zorunlu)
                                                {
                                                    <span class="badge bg-danger ms-1">Zorunlu</span>
                                                }
                                                @if (!tanim.Aktif)
                                                {
                                                    <span class="badge bg-secondary ms-1">Pasif</span>
                                                }
                                            </div>
                                            <div>
                                                <button class="btn btn-sm btn-outline-primary me-1" 
                                                        @onclick="() => EvrakTanimDuzenle(tanim)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" 
                                                        @onclick="() => EvrakTanimSil(tanim.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="TanimModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Evrak Tanım Düzenle Modal -->
@if (showTanimDuzenleModal && duzenlenecekTanim != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil me-2"></i>Evrak Tanımı @(duzenlenecekTanim.Id == 0 ? "Ekle" : "Düzenle")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="TanimDuzenleKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Evrak Adı *</label>
                        <input type="text" class="form-control" @bind="duzenlenecekTanim.EvrakAdi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select class="form-select" @bind="duzenlenecekTanim.Kategori">
                            @foreach (OzlukEvrakKategori kat in Enum.GetValues<OzlukEvrakKategori>())
                            {
                                <option value="@kat">@GetKategoriAdi(kat)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" rows="2" @bind="duzenlenecekTanim.Aciklama"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Sıra No</label>
                                <input type="number" class="form-control" @bind="duzenlenecekTanim.SiraNo" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Geçerli Görevler</label>
                                <input type="text" class="form-control" @bind="duzenlenecekTanim.GecerliGorevler" 
                                       placeholder="Boş: Tümü, örn: 1,2" />
                                <small class="text-muted">1:Şoför, 2:Ofis, 3:Muhasebe, 4:Yönetici</small>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="duzenlenecekTanim.Zorunlu" id="zorunluCheck" />
                                <label class="form-check-label" for="zorunluCheck">Zorunlu</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="duzenlenecekTanim.Aktif" id="aktifCheck" />
                                <label class="form-check-label" for="aktifCheck">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="EvrakTanimKaydet">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="TanimDuzenleKapat">İptal</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Seçili Eksik Evrak Listesi Modal -->
@if (showEksikListeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Seçili Personeller Eksik Evrak Listesi
                    </h5>
                    <button type="button" class="btn-close" @onclick="EksikListeKapat"></button>
                </div>
                <div class="modal-body">
                    @if (!seciliEksikDurumlar.Any())
                    {
                        <div class="alert alert-success mb-0">
                            Seçili personellerde eksik evrak bulunmuyor.
                        </div>
                    }
                    else
                    {
                        @foreach (var durum in seciliEksikDurumlar)
                        {
                            var eksikEvraklar = durum.Evraklar.Where(e => !e.Tamamlandi).OrderBy(e => e.Kategori).ThenBy(e => e.EvrakAdi).ToList();

                            <div class="card mb-3">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@durum.PersonelAdi</strong>
                                        <small class="text-muted ms-2">@durum.PersonelKodu</small>
                                    </div>
                                    <span class="badge bg-danger">@eksikEvraklar.Count eksik</span>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-sm mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Kategori</th>
                                                    <th>Evrak</th>
                                                    <th>Durum</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var evrak in eksikEvraklar)
                                                {
                                                    <tr>
                                                        <td>@GetKategoriAdi(evrak.Kategori)</td>
                                                        <td>
                                                            @evrak.EvrakAdi
                                                            @if (evrak.Zorunlu)
                                                            {
                                                                <span class="badge bg-danger ms-1">Zorunlu</span>
                                                            }
                                                        </td>
                                                        <td><span class="badge bg-secondary">Eksik</span></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="EksikListeKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@* Çoklu Aday Seçim Modalı — Sertifika gibi birden fazla OzlukEvrakTanim olan tipler için *@
@if (showCokluAdayModal && _cokluAdaylar.Count > 1)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-question-circle me-2"></i>Hangi Evrak Tipi?
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CokluAdayIptal"></button>
                </div>
                <div class="modal-body">
                    <p>"@_cokluAdayCanonicalTip" için birden fazla evrak tanımı bulundu. Lütfen yüklemek istediğiniz belgeyi seçin:</p>

                    <div class="list-group">
                        @foreach (var aday in _cokluAdaylar.OrderBy(a => a.Zorunlu ? 0 : 1).ThenBy(a => a.SiraNo))
                        {
                            <label class="list-group-item list-group-item-action @(_cokluAdaySeciliTanimId == aday.Id ? "active" : "")"
                                   @onclick="() => _cokluAdaySeciliTanimId = aday.Id">
                                <input type="radio" class="form-check-input me-2"
                                       checked="@(_cokluAdaySeciliTanimId == aday.Id)"
                                       @onchange="() => _cokluAdaySeciliTanimId = aday.Id" />
                                <strong>@aday.EvrakAdi</strong>
                                @if (aday.Zorunlu)
                                {
                                    <span class="badge bg-danger ms-1">Zorunlu</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(aday.Aciklama))
                                {
                                    <br /><small class="text-muted">@aday.Aciklama</small>
                                }
                            </label>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CokluAdayIptal">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="CokluAdayOnayla"
                            disabled="@(_cokluAdaySeciliTanimId == 0)">
                        <i class="bi bi-upload me-1"></i>Bu Belgeyi Yükle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PersonelOzlukEvrakDurum>? durumlar;
    private List<OzlukEvrakTanim>? evrakTanimlari;
    private List<PersonelOzlukEvrakDurum> seciliEksikDurumlar = new();
    private PersonelOzlukEvrakDurum? seciliDurum;
    private OzlukEvrakTanim? duzenlenecekTanim;

    private bool showDetayModal;
    private bool showTanimModal;
    private bool showTanimDuzenleModal;
    private bool showEksikListeModal;
    private bool showCokluAdayModal; // Sertifika gibi çoklu OzlukEvrakTanim adayı için seçim modalı
    private bool _hizliEvrakAcik = true;
    private static readonly List<string> _personelEvrakTipleri = new() { "Kimlik", "Ehliyet", "Diploma", "Sertifika", "Saglik Raporu", "Is Sozlesmesi", "Diger" };
    private List<EvrakDosya> _yeniEvraklar = new(); // YENI sistem — EvrakDosya tablosu
    /// <summary>
    /// Eski sistemden (PersonelOzlukEvrak) tamamlanmış evrakların canonical kategorileri.
    /// EvrakYonetimi bileşenine gönderilir, böylece hızlı kartlar eksik göstermez.
    /// </summary>
    private HashSet<string> _mevcutTipler = new();

    // Çoklu aday (Sertifika) seçim state
    private List<OzlukEvrakTanim> _cokluAdaylar = new();
    private string _cokluAdayCanonicalTip = string.Empty;
    private IBrowserFile? _cokluAdayFile;
    private DateTime? _cokluAdayGecerlilikTarihi;
    private int _cokluAdaySeciliTanimId;

    // Önizleme state
    private bool onizlemeModalAcik;
    private string? onizlemeBaslik;
    private string? onizlemeContentType;
    private string? onizlemeBase64;
    private string? onizlemeDataUrl;
    private string? onizlemeDosyaAdi;
    private bool onizlemeDestekleniyor;

    private string filtreGorev = "";
    private string filtreDurum = "";
    private string aramaMetni = "";
    private string detayBelgeFiltre = "";
    private string detayAramaMetni = "";
    private bool detaySadeceEksik;
    private HashSet<int> seciliSoforIdler = new();
    private readonly Dictionary<int, DateTime?> evrakGecerlilikTarihleri = new();

    private IEnumerable<PersonelOzlukEvrakDurum> FiltrelenmisListe => durumlar?
        .Where(d => string.IsNullOrEmpty(filtreGorev) || ((int)d.Gorev).ToString() == filtreGorev)
        .Where(d => string.IsNullOrEmpty(filtreDurum) || 
                    (filtreDurum == "eksik" && d.EksikEvrak > 0) || 
                    (filtreDurum == "tamam" && d.EksikEvrak == 0))
        .Where(d => string.IsNullOrEmpty(aramaMetni) || 
                    d.PersonelAdi.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
                    d.PersonelKodu.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<PersonelOzlukEvrakDurum>();

    private bool TumFiltrelenmislerSecili => FiltrelenmisListe.Any() && FiltrelenmisListe.All(d => seciliSoforIdler.Contains(d.SoforId));

    private IEnumerable<OzlukEvrakDetay> FiltrelenmisSeciliEvraklar => (seciliDurum?.Evraklar ?? new List<OzlukEvrakDetay>())
        .Where(e => DetayBelgeFiltreUyuyor(e, detayBelgeFiltre))
        .Where(e => !detaySadeceEksik || !e.Tamamlandi)
        .Where(e => string.IsNullOrWhiteSpace(detayAramaMetni)
                    || e.EvrakAdi.Contains(detayAramaMetni, StringComparison.OrdinalIgnoreCase)
                    || GetKategoriAdi(e.Kategori).Contains(detayAramaMetni, StringComparison.OrdinalIgnoreCase)
                    || (!string.IsNullOrWhiteSpace(e.Aciklama) && e.Aciklama.Contains(detayAramaMetni, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        if (SoforId.HasValue && SoforId.Value > 0)
        {
            await DetayAc(SoforId.Value);
        }
    }

    [SupplyParameterFromQuery(Name = "soforId")]
    public int? SoforId { get; set; }

    private async Task LoadData()
    {
        durumlar = await OzlukService.GetTumPersonelEvrakDurumlariAsync();
        seciliSoforIdler.IntersectWith(durumlar.Select(d => d.SoforId));
    }

    private async Task DetayAc(int soforId)
    {
        seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
        await EvrakGecerlilikTarihleriniYukleAsync(soforId);

        // YENI sistem — EvrakDosya tablosundan bu personelin evraklarını yükle
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _yeniEvraklar = await db.EvrakDosyalari
                .Where(x => x.PersonelId == soforId && !x.IsDeleted)
                .ToListAsync();
        }
        catch { _yeniEvraklar = new(); }

        // Eski sistemden tamamlanmış evrakların canonical kategorilerini hesapla
        _mevcutTipler = new HashSet<string>();
        if (seciliDurum != null)
        {
            foreach (var evrak in seciliDurum.Evraklar.Where(e => e.Tamamlandi))
            {
                var canonical = EvrakTipiCanonicalMapper.GetCanonicalName(evrak.EvrakAdi);
                if (canonical != null)
                    _mevcutTipler.Add(canonical);
            }
        }

        showDetayModal = true;
    }

    /// <summary>
    /// Eski evrak tipine (Örn: "Kimlik Fotokopisi") karşılık gelen yeni EvrakDosya kaydını bul.
    /// Canonical mapper ile aynı kategoriye ait olup olmadığını kontrol eder.
    /// </summary>
    private EvrakDosya? GetYeniEvrak(string evrakAdi)
    {
        if (string.IsNullOrWhiteSpace(evrakAdi))
            return null;

        var canonical = EvrakTipiCanonicalMapper.GetCanonicalName(evrakAdi);
        if (canonical == null)
        {
            // Fallback: eski Contains mantığı
            return _yeniEvraklar.FirstOrDefault(x =>
                string.Equals(x.EvrakTipi, evrakAdi, StringComparison.OrdinalIgnoreCase) ||
                x.EvrakTipi.Contains(evrakAdi, StringComparison.OrdinalIgnoreCase) ||
                evrakAdi.Contains(x.EvrakTipi, StringComparison.OrdinalIgnoreCase));
        }

        return _yeniEvraklar.FirstOrDefault(x =>
            EvrakTipiCanonicalMapper.BelongsToCategory(x.EvrakTipi, canonical));
    }

    private bool IsEvrakTamam(OzlukEvrakDetay evrak)
    {
        return evrak.Tamamlandi || GetYeniEvrak(evrak.EvrakAdi) != null;
    }

    private string GetRowClass(OzlukEvrakDetay evrak)
    {
        return IsEvrakTamam(evrak) ? "table-success" : "";
    }

    private void DetayKapat()
    {
        showDetayModal = false;
        seciliDurum = null;
        detayBelgeFiltre = "";
        detayAramaMetni = "";
        detaySadeceEksik = false;
        evrakGecerlilikTarihleri.Clear();
    }

    /// <summary>EvrakYonetimi component'inden gelen refresh sinyali — detayı ve ana listeyi DB'den yeniler.</summary>
    private async Task EvrakGuncellendi()
    {
        if (seciliDurum == null) return;
        await DetayAc(seciliDurum.SoforId);
        await LoadData();
        StateHasChanged();
    }

    private async Task EvrakDurumDegistir(int soforId, int evrakTanimId, bool tamamlandi)
    {
        try
        {
            await OzlukService.EvrakIsaretle(soforId, evrakTanimId, tamamlandi);
            seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
            await LoadData();
            ToastService.ShowSuccess(tamamlandi ? "Evrak tamamlandı olarak işaretlendi." : "Evrak işareti kaldırıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    /// <summary>Detay checklist input'undan gelen upload.</summary>
    private async Task EvrakDosyaSecildi(int soforId, OzlukEvrakDetay evrak, InputFileChangeEventArgs e)
    {
        if (e.File == null) return;
        await UploadOzlukEvrakDosyasiAsync(soforId, evrak, e.File);
    }

    /// <summary>
    /// ORTAK UPLOAD METODU — hem detay checklist hem hızlı kart burayı kullanır.
    /// SecureFileService + PersonelOzlukEvrak üzerinden kaydeder.
    /// </summary>
    private async Task UploadOzlukEvrakDosyasiAsync(int soforId, OzlukEvrakDetay evrak, IBrowserFile file)
    {
        string? yeniDosyaYolu = null;
        try
        {
            var oncekiDosyaYolu = evrak.DosyaYolu;
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var icerik = memoryStream.ToArray();
            var uzanti = Path.GetExtension(file.Name);

            // Personel arşiv klasörünü oluştur: {Ad Soyad} - {FirmaAdi}
            string personelKlasoru;
            string normAd, normSoyad;
            try
            {
                var sofor = await SoforService.GetByIdAsync(soforId);
                var firmaAdi = sofor?.Firma?.FirmaAdi;
                normAd = AppStoragePaths.NormalizeFolderName(sofor?.Ad ?? "PERSONEL");
                normSoyad = AppStoragePaths.NormalizeFolderName(sofor?.Soyad ?? soforId.ToString());
                personelKlasoru = AppStoragePaths.BuildPersonelArsivKlasoru(
                    sofor?.Ad ?? "PERSONEL",
                    sofor?.Soyad ?? soforId.ToString(),
                    firmaAdi);
            }
            catch
            {
                var fallbackAdSoyad = seciliDurum?.PersonelAdi ?? soforId.ToString();
                normAd = AppStoragePaths.NormalizeFolderName(fallbackAdSoyad);
                normSoyad = "";
                personelKlasoru = AppStoragePaths.NormalizeFolderName(fallbackAdSoyad);
            }

            // Dosya adı: {PERSONELADSOYAD}{EvrakTipi}_{yyyyMMdd_HHmmss}.uzanti
            var normEvrakAdi = AppStoragePaths.NormalizeFolderName(evrak.EvrakAdi).Replace(" ", "").Replace("-", "");
            var arsivDosyaAdi = $"{normAd}{normSoyad}{normEvrakAdi}_{DateTime.Now:yyyyMMdd_HHmmss}{uzanti}";

            yeniDosyaYolu = await SecureFileService.SaveEncryptedAsync(
                $"{AppStoragePaths.PersonelEvrakRelativeRoot}/{personelKlasoru}",
                arsivDosyaAdi,
                icerik);

            // Arşiv kopyaları
            var adSoyad = seciliDurum?.PersonelAdi ?? soforId.ToString();
            try
            {
                await EvrakArsivService.ArsivlePersonelEvrakAsync(adSoyad, evrak.EvrakAdi, icerik, uzanti);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Personel evrak arşivleme başarısız oldu. PersonelId={PersonelId}, Evrak={Evrak}", soforId, evrak.EvrakAdi);
            }

            await OzlukService.EvrakDosyaYukle(soforId, evrak.EvrakTanimId, yeniDosyaYolu);
            await PersonelBelgeTarihiniGuncelleAsync(soforId, evrak);
            seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
            await EvrakGecerlilikTarihleriniYukleAsync(soforId);
            await LoadData();

            // Yeni kayıt başarıyla tamamlandıktan sonra eski fiziksel dosyayı temizle.
            if (!string.IsNullOrWhiteSpace(oncekiDosyaYolu) &&
                !string.Equals(oncekiDosyaYolu, yeniDosyaYolu, StringComparison.OrdinalIgnoreCase))
            {
                try
                {
                    await SecureFileService.DeleteAsync(oncekiDosyaYolu);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Eski personel evrak dosyası silinemedi. SoforId={SoforId}, Yol={Yol}", soforId, oncekiDosyaYolu);
                }
            }

            ToastService.ShowSuccess($"{evrak.EvrakAdi} dosyası yüklendi.");

            // Başarılı upload sonrası: aynı canonical kategorideki eski/kayıp EvrakDosya kayıtlarını temizle.
            // Bunlar eski bozuk hızlı upload sisteminden kalma, yanlış path'li kayıtlardır.
            // Yeni kayıt PersonelOzlukEvrak'ta olduğu için EvrakDosya'daki gölge kayda gerek yok.
            await TemizleStaleEvrakDosyaKayitlariAsync(soforId, evrak.EvrakAdi);
        }
        catch (Exception ex)
        {
            if (!string.IsNullOrWhiteSpace(yeniDosyaYolu))
            {
                try
                {
                    await SecureFileService.DeleteAsync(yeniDosyaYolu);
                }
                catch (Exception cleanupEx)
                {
                    Logger.LogWarning(cleanupEx, "Başarısız upload sonrası yeni dosya temizlenemedi. SoforId={SoforId}, Yol={Yol}", soforId, yeniDosyaYolu);
                }
            }

            Logger.LogError(ex, "Personel ozluk evrak yukleme hatasi. SoforId={SoforId}, EvrakTanimId={EvrakTanimId}, FileName={FileName}",
                soforId, evrak.EvrakTanimId, file?.Name);
            ToastService.ShowError($"Dosya yüklenemedi: {ex.Message}");
        }
    }

    /// <summary>
    /// Hızlı Evrak Yükleme kartından gelen upload isteği.
    /// Canonical tipi ("Kimlik") → doğru OzlukEvrakTanim ("Kimlik Fotokopisi") bulur
    /// → ortak UploadOzlukEvrakDosyasiAsync ile kaydeder.
    /// Çoklu aday (Sertifika → SRC/Psikoteknik/ADR/MYK) varsa seçim modalı gösterir.
    /// </summary>
    private async Task HizliEvrakYukleAsync(IBrowserFile file, string canonicalTip, DateTime? gecerlilikTarihi)
    {
        if (seciliDurum == null) return;
        var soforId = seciliDurum.SoforId;

        // Tüm eşleşen adayları bul
        var evrakTanimlari = await OzlukService.GetAktifEvrakTanimlariAsync();
        var candidates = evrakTanimlari
            .Where(t => EvrakTipiCanonicalMapper.BelongsToCategory(t.EvrakAdi, canonicalTip))
            .ToList();

        if (candidates.Count == 0)
        {
            // Fallback: GetPrimaryAlias ile dene
            var primaryAlias = EvrakTipiCanonicalMapper.GetPrimaryAlias(canonicalTip);
            if (primaryAlias != null)
            {
                var exact = evrakTanimlari.FirstOrDefault(t =>
                    string.Equals(t.EvrakAdi, primaryAlias, StringComparison.OrdinalIgnoreCase));
                if (exact != null) candidates.Add(exact);
            }
        }

        if (candidates.Count == 0)
        {
            ToastService.ShowWarning($"'{canonicalTip}' için eşleşen evrak tanımı bulunamadı.");
            return;
        }

        // Çoklu aday → kullanıcıya seçim modalı göster
        if (candidates.Count > 1)
        {
            _cokluAdaylar = candidates;
            _cokluAdayCanonicalTip = canonicalTip;
            _cokluAdayFile = file;
            _cokluAdayGecerlilikTarihi = gecerlilikTarihi;
            _cokluAdaySeciliTanimId = candidates.FirstOrDefault(t => t.Zorunlu)?.Id ?? candidates[0].Id;
            showCokluAdayModal = true;
            return;
        }

        // Tek aday → doğrudan yükle
        await DogrudanYukleAsync(soforId, candidates[0], file, gecerlilikTarihi);
    }

    /// <summary>Çoklu aday modalında kullanıcı seçim yapıp onaylayınca çağrılır.</summary>
    private async Task CokluAdayOnayla()
    {
        showCokluAdayModal = false;
        if (seciliDurum == null || _cokluAdayFile == null || _cokluAdaySeciliTanimId == 0) return;

        var secilenTanim = _cokluAdaylar.FirstOrDefault(a => a.Id == _cokluAdaySeciliTanimId);
        if (secilenTanim == null) return;

        await DogrudanYukleAsync(seciliDurum.SoforId, secilenTanim, _cokluAdayFile, _cokluAdayGecerlilikTarihi);
        CokluAdayTemizle();
    }

    /// <summary>Çoklu aday modalında kullanıcı iptal edince çağrılır.</summary>
    private void CokluAdayIptal()
    {
        showCokluAdayModal = false;
        ToastService.ShowInfo("Yükleme iptal edildi.");
        CokluAdayTemizle();
    }

    private void CokluAdayTemizle()
    {
        _cokluAdaylar = new();
        _cokluAdayCanonicalTip = string.Empty;
        _cokluAdayFile = null;
        _cokluAdayGecerlilikTarihi = null;
        _cokluAdaySeciliTanimId = 0;
    }

    /// <summary>Tek adaylı veya kullanıcı seçimi sonrası ortak yükleme.</summary>
    private async Task DogrudanYukleAsync(int soforId, OzlukEvrakTanim tanim, IBrowserFile file, DateTime? gecerlilikTarihi)
    {
        var detay = new OzlukEvrakDetay
        {
            EvrakTanimId = tanim.Id,
            EvrakAdi = tanim.EvrakAdi,
            Kategori = tanim.Kategori,
            Zorunlu = tanim.Zorunlu
        };

        await UploadOzlukEvrakDosyasiAsync(soforId, detay, file);

        // Hızlı karttan gelen geçerlilik tarihini uygula
        if (gecerlilikTarihi.HasValue)
        {
            try
            {
                evrakGecerlilikTarihleri[detay.EvrakTanimId] = gecerlilikTarihi.Value.Date;
                await PersonelBelgeTarihiniGuncelleAsync(soforId, detay);
                seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
                await EvrakGecerlilikTarihleriniYukleAsync(soforId);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Hizli upload: gecerlilik tarihi uygulanamadi. EvrakTanimId={Id}", detay.EvrakTanimId);
            }
        }
    }

    /// <summary>
    /// Canonical tip ("Kimlik") → aktif OzlukEvrakTanim ("Kimlik Fotokopisi") bulur.
    /// GetPrimaryAlias ile en olası adı dener, bulamazsa BelongsToCategory ile tarar.
    /// Birden fazla aday varsa ilkini döner; 0 aday varsa null.
    /// </summary>
    private async Task<OzlukEvrakTanim?> FindOzlukEvrakTanimForCanonicalTipAsync(string canonicalTip)
    {
        var evrakTanimlari = await OzlukService.GetAktifEvrakTanimlariAsync();

        // 1. Önce GetPrimaryAlias ile en olası adı dene (örn: "Kimlik" → "Kimlik Fotokopisi")
        var primaryAlias = EvrakTipiCanonicalMapper.GetPrimaryAlias(canonicalTip);
        if (primaryAlias != null)
        {
            var exact = evrakTanimlari.FirstOrDefault(t =>
                string.Equals(t.EvrakAdi, primaryAlias, StringComparison.OrdinalIgnoreCase));
            if (exact != null) return exact;
        }

        // 2. Canonical kategoriye ait tüm tanımları tara
        var candidates = evrakTanimlari
            .Where(t => EvrakTipiCanonicalMapper.BelongsToCategory(t.EvrakAdi, canonicalTip))
            .ToList();

        if (candidates.Count == 1)
            return candidates[0];

        if (candidates.Count > 1)
        {
            // Birden fazla aday → zorunlu olanı tercih et, yoksa ilkini al
            var zorunlu = candidates.FirstOrDefault(t => t.Zorunlu);
            Logger.LogInformation("HizliEvrakYukle: '{Tip}' için {Count} aday bulundu, zorunlu={Zorunlu}",
                canonicalTip, candidates.Count, zorunlu?.EvrakAdi ?? "ilk kayıt");
            return zorunlu ?? candidates[0];
        }

        Logger.LogWarning("HizliEvrakYukle: '{Tip}' için eşleşen OzlukEvrakTanim bulunamadı.", canonicalTip);
        return null;
    }

    /// <summary>
    /// Hızlı Evrak Yükleme kartından gelen silme isteği.
    /// Canonical tip → OzlukEvrakTanim → PersonelOzlukEvrak.Tamamlandi = false yapar.
    /// Silme idempotent: kayıt yoksa hata vermez.
    /// </summary>
    private async Task HizliEvrakSilAsync(string canonicalTip)
    {
        if (seciliDurum == null) return;
        var soforId = seciliDurum.SoforId;
        var kayitTemizlendi = false;
        var fizikselSilmeBasarisiz = false;

        var tanim = await FindOzlukEvrakTanimForCanonicalTipAsync(canonicalTip);
        if (tanim == null)
        {
            Logger.LogInformation("HizliEvrakSil: '{Tip}' için eşleşen OzlukEvrakTanim bulunamadı, sadece EvrakDosya temizlendi.", canonicalTip);
            ToastService.ShowInfo($"'{canonicalTip}' için evrak tanımı bulunamadı.");
            // _mevcutTipler ve ana listeyi yine de yenile
            await DetayAc(soforId);
            await LoadData();
            return;
        }

        try
        {
            // PersonelOzlukEvrak kaydını bul ve işaretini kaldır
            var personelEvrak = await OzlukService.EvrakIsaretle(soforId, tanim.Id, false);
            if (personelEvrak != null)
            {
                var silinecekDosyaYolu = personelEvrak.DosyaYolu;

                // Dosya alanlarını da temizle
                personelEvrak.DosyaYolu = null;
                personelEvrak.DosyaAdi = null;
                personelEvrak.DosyaTipi = null;
                personelEvrak.DosyaBoyutu = null;
                await OzlukService.UpdatePersonelEvrakAsync(personelEvrak);
                kayitTemizlendi = true;

                if (!string.IsNullOrWhiteSpace(silinecekDosyaYolu))
                {
                    try
                    {
                        await SecureFileService.DeleteAsync(silinecekDosyaYolu);
                    }
                    catch (Exception ex)
                    {
                        fizikselSilmeBasarisiz = true;
                        Logger.LogWarning(ex, "HizliEvrakSil: fiziksel dosya silme hatası. SoforId={SoforId}, Tip={Tip}, Yol={Yol}",
                            soforId, canonicalTip, silinecekDosyaYolu);
                    }
                }

                Logger.LogInformation("HizliEvrakSil: PersonelOzlukEvrak temizlendi. SoforId={SoforId}, EvrakTanimId={Id}, Tip={Tip}",
                    soforId, tanim.Id, canonicalTip);
            }
            else
            {
                ToastService.ShowInfo($"{canonicalTip} için temizlenecek kayıt bulunamadı.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "HizliEvrakSil: PersonelOzlukEvrak temizleme hatası. Tip={Tip}", canonicalTip);
            ToastService.ShowError($"{canonicalTip} kaydı temizlenemedi: {ex.GetBaseException().Message}");
        }

        // UI'ı yenile
        seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
        await EvrakGecerlilikTarihleriniYukleAsync(soforId);
        await DetayAc(soforId);
        await LoadData();

        if (kayitTemizlendi && fizikselSilmeBasarisiz)
            ToastService.ShowWarning($"{canonicalTip} kaydı temizlendi, ancak fiziksel dosya silinemedi.");
        else if (kayitTemizlendi)
            ToastService.ShowSuccess($"{canonicalTip} kaydı temizlendi.");
    }

