    /// <summary>
    /// Başarılı upload sonrası, aynı canonical kategorideki eski EvrakDosya kayıtlarını soft-delete yapar.
    /// Eski bozuk hızlı upload sisteminden kalma, yanlış path'li kayıtların yeni doğru kaydı gölgelemesini engeller.
    /// </summary>
    private async Task TemizleStaleEvrakDosyaKayitlariAsync(int soforId, string evrakAdi)
    {
        var canonical = EvrakTipiCanonicalMapper.GetCanonicalName(evrakAdi);
        if (canonical == null) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var tumEvrakDosyalar = await db.EvrakDosyalari
                .Where(x => x.PersonelId == soforId && !x.IsDeleted)
                .ToListAsync();

            var silinecekler = tumEvrakDosyalar
                .Where(x => EvrakTipiCanonicalMapper.BelongsToCategory(x.EvrakTipi, canonical))
                .ToList();

            if (silinecekler.Count > 0)
            {
                foreach (var eski in silinecekler)
                {
                    eski.IsDeleted = true;
                }
                await db.SaveChangesAsync();
                Logger.LogInformation("Stale EvrakDosya temizlendi: {Count} kayıt soft-delete. SoforId={SoforId}, Canonical={Canonical}",
                    silinecekler.Count, soforId, canonical);

                // _yeniEvraklar listesini de güncelle (DetayAc tekrar çağrılmadan önce)
                foreach (var eski in silinecekler)
                {
                    _yeniEvraklar.RemoveAll(x => x.Id == eski.Id);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Stale EvrakDosya temizleme hatası. SoforId={SoforId}, EvrakAdi={EvrakAdi}", soforId, evrakAdi);
        }
    }

    private async Task EvrakDosyasiIndir(OzlukEvrakDetay evrak)
    {
        if (string.IsNullOrWhiteSpace(evrak.DosyaYolu))
            return;

        try
        {
            var bytes = await SecureFileService.ReadDecryptedAsync(evrak.DosyaYolu);
            if (bytes == null)
            {
                ToastService.ShowWarning("Dosya bulunamadı.");
                return;
            }

            var dosyaAdi = BuildEvrakDosyaAdi(evrak.EvrakAdi, evrak.DosyaYolu);
            await JS.InvokeVoidAsync("downloadFile", dosyaAdi, Convert.ToBase64String(bytes), GetMimeType(dosyaAdi));
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Dosya indirilemedi: {ex.GetBaseException().Message}");
        }
    }

