    private static string BuildEvrakDosyaAdi(string evrakAdi, string dosyaYolu)
    {
        var extension = Path.GetExtension(Path.GetFileNameWithoutExtension(dosyaYolu));
        if (string.IsNullOrWhiteSpace(extension))
        {
            extension = ".bin";
        }

        var safeName = string.Concat(evrakAdi.Select(ch => Path.GetInvalidFileNameChars().Contains(ch) ? '_' : ch));
        return $"{safeName}{extension}";
    }

    private async Task EvrakGecerlilikTarihleriniYukleAsync(int soforId)
    {
        evrakGecerlilikTarihleri.Clear();

        var personel = await SoforService.GetByIdAsync(soforId);
        if (personel == null || seciliDurum == null)
            return;

        foreach (var evrak in seciliDurum.Evraklar.Where(GecerlilikTarihiDestekleniyor))
        {
            // Önce özlük evrak kaydındaki GecerlilikBitisTarihi'ne bak
            if (evrak.GecerlilikBitisTarihi.HasValue)
                evrakGecerlilikTarihleri[evrak.EvrakTanimId] = evrak.GecerlilikBitisTarihi;
            else
                evrakGecerlilikTarihleri[evrak.EvrakTanimId] = GetPersonelBelgeTarihi(personel, evrak);
        }
    }

    private async Task PersonelBelgeTarihiniGuncelleAsync(int soforId, OzlukEvrakDetay evrak)
    {
        if (!evrakGecerlilikTarihleri.TryGetValue(evrak.EvrakTanimId, out var secilenTarih) || !secilenTarih.HasValue)
            return;

        var personel = await SoforService.GetByIdAsync(soforId);
        if (personel == null)
            return;

        var guncellendi = EvrakTarihAlaniniUygula(personel, evrak, secilenTarih.Value.Date);
        if (guncellendi)
            await SoforService.UpdateAsync(personel);

        // Özlük evrak kaydındaki GecerlilikBitisTarihi'ni de güncelle
        try
        {
            var personelEvrak = await OzlukService.EvrakIsaretle(soforId, evrak.EvrakTanimId, true);
            personelEvrak.GecerlilikBitisTarihi = secilenTarih.Value.Date;
            await OzlukService.UpdatePersonelEvrakAsync(personelEvrak);
        }
        catch
        {
            // GecerlilikBitisTarihi güncellemesi başarısız olsa da devam et
        }
    }

    private async Task EvrakGecerlilikTarihiDegistiAsync(int soforId, OzlukEvrakDetay evrak, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        DateTime? tarih = DateTime.TryParse(raw, out var parsed)
            ? (DateTime?)parsed.Date
            : null;

        evrakGecerlilikTarihleri[evrak.EvrakTanimId] = tarih;

        if (!tarih.HasValue)
            return;

        try
        {
            await PersonelBelgeTarihiniGuncelleAsync(soforId, evrak);
            seciliDurum = await OzlukService.GetPersonelEvrakDurumuAsync(soforId);
            await EvrakGecerlilikTarihleriniYukleAsync(soforId);
            await LoadData();
            ToastService.ShowSuccess($"{evrak.EvrakAdi} geçerlilik tarihi güncellendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Geçerlilik tarihi güncellenemedi: {ex.GetBaseException().Message}");
        }
    }

    private DateTime? GetEvrakGecerlilikTarihi(int evrakTanimId)
        => evrakGecerlilikTarihleri.TryGetValue(evrakTanimId, out var value) ? value : null;

    private static string FormatDateInput(DateTime? value)
        => value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static bool GecerlilikTarihiDestekleniyor(OzlukEvrakDetay evrak)
        => EvrakTuruBelirle(evrak) != null;

    private static DateTime? GetPersonelBelgeTarihi(Sofor personel, OzlukEvrakDetay evrak)
        => EvrakTuruBelirle(evrak) switch
        {
            "Ehliyet" => personel.EhliyetGecerlilikTarihi,
            "MykBelgesi" => personel.MykBelgesiGecerlilikTarihi,
            "Psikoteknik" => personel.PsikoteknikGecerlilikTarihi,
            "Saglik" => personel.SaglikRaporuGecerlilikTarihi,
            "Sozlesme" => personel.IseBaslamaTarihi,
            _ => null
        };

    private static bool EvrakTarihAlaniniUygula(Sofor personel, OzlukEvrakDetay evrak, DateTime tarih)
    {
        switch (EvrakTuruBelirle(evrak))
        {
            case "Ehliyet":
                personel.EhliyetGecerlilikTarihi = tarih;
                return true;
            case "MykBelgesi":
                personel.MykBelgesiGecerlilikTarihi = tarih;
                return true;
            case "Psikoteknik":
                personel.PsikoteknikGecerlilikTarihi = tarih;
                return true;
            case "Saglik":
                personel.SaglikRaporuGecerlilikTarihi = tarih;
                return true;
            case "Sozlesme":
                personel.IseBaslamaTarihi = tarih;
                return true;
            default:
                return false;
        }
    }

    private static string? EvrakTuruBelirle(OzlukEvrakDetay evrak)
    {
        var ad = evrak.EvrakAdi;
        var canonical = EvrakTipiCanonicalMapper.GetCanonicalName(ad);

        // Ehliyet → Sofor.EhliyetGecerlilikTarihi
        if (canonical == "Ehliyet")
            return "Ehliyet";

        // MYK / Mesleki Yeterlilik → Sofor.MykBelgesiGecerlilikTarihi
        if (ad.Contains("MYK", StringComparison.OrdinalIgnoreCase)
            || ad.Contains("Mesleki Yeterlilik", StringComparison.OrdinalIgnoreCase))
            return "MykBelgesi";

        // Psikoteknik → Sofor.PsikoteknikGecerlilikTarihi
        if (canonical == "Sertifika" && ad.Contains("Psikoteknik", StringComparison.OrdinalIgnoreCase))
            return "Psikoteknik";

        // Sağlık Raporu → Sofor.SaglikRaporuGecerlilikTarihi
        if (canonical == "Saglik Raporu")
            return "Saglik";

        // İş Sözleşmesi → Sofor.IseBaslamaTarihi
        if (canonical == "Is Sozlesmesi")
            return "Sozlesme";

        return null;
    }

    private static bool DetayBelgeFiltreUyuyor(OzlukEvrakDetay evrak, string detayBelgeFiltre)
    {
        return detayBelgeFiltre switch
        {
            "ehliyet" => EvrakTipiCanonicalMapper.BelongsToCategory(evrak.EvrakAdi, "Ehliyet"),
            "diploma" => EvrakTipiCanonicalMapper.BelongsToCategory(evrak.EvrakAdi, "Diploma"),
            "sertifika" => EvrakTipiCanonicalMapper.BelongsToCategory(evrak.EvrakAdi, "Sertifika"),
            "saglik" => EvrakTipiCanonicalMapper.BelongsToCategory(evrak.EvrakAdi, "Saglik Raporu"),
            "sozlesme" => EvrakTipiCanonicalMapper.BelongsToCategory(evrak.EvrakAdi, "Is Sozlesmesi"),
            _ => true
        };
    }

