@page "/personel/finans/avanslar"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@inject IPersonelFinansService FinansService
@inject ISoforService SoforService
@inject IFirmaService FirmaService
@inject IBankaHesapService BankaHesapService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Personel Avans Yönetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-cash-coin me-2"></i>Personel Avans Yönetimi</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel/finans">Personel Finans</a></li>
                    <li class="breadcrumb-item active">Avanslar</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 200px;" @bind="secilenFirmaId" @bind:after="YenileData">
                <option value="0">Tüm Firmalar</option>
                @if (firmalar != null)
                {
                    @foreach (var firma in firmalar)
                    {
                        <option value="@firma.Id">@firma.FirmaAdi</option>
                    }
                }
            </select>
            <select class="form-select form-select-sm" style="width: 200px;" @bind="secilenPersonelId" @bind:after="YenileData">
                <option value="0">Tüm Personeller</option>
                @if (personeller != null)
                {
                    @foreach (var p in personeller)
                    {
                        <option value="@p.Id">@p.TamAd</option>
                    }
                }
            </select>
            <button class="btn btn-success btn-sm" @onclick="YeniAvansAc">
                <i class="bi bi-plus-circle me-1"></i>Yeni Avans
            </button>
            <button class="btn btn-outline-success btn-sm" @onclick="ExcelAktar" disabled="@(avanslar == null || !avanslar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Özet Kartlar -->
        <div class="row mb-3 g-2">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2">
                        <small>Toplam Avans</small>
                        <h4 class="mb-0">@FormatPara(toplamAvans)</h4>
                        <small>@toplamAdet kayıt</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body py-2">
                        <small>Mahsup Edilen</small>
                        <h4 class="mb-0">@FormatPara(mahsupEdilen)</h4>
                        <small>Kapatılan</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2">
                        <small>Kalan Avans</small>
                        <h4 class="mb-0">@FormatPara(kalanAvans)</h4>
                        <small>@acikAdet avans açık</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body py-2">
                        <small>Tamamı Mahsup</small>
                        <h4 class="mb-0">@mahsupTamAdet</h4>
                        <small>kayıt</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Avans Listesi -->
        <div class="card">
            <div class="card-header py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Avans Listesi</h5>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" @bind="sadecAciklar" @bind:after="YenileData" />
                        <label class="form-check-label">Sadece Açık Avanslar</label>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Tarih</th>
                                <th>Personel</th>
                                <th>Firma</th>
                                <th class="text-end">Tutar</th>
                                <th>Ödeme Şekli</th>
                                <th class="text-end">Mahsup</th>
                                <th class="text-end">Kalan</th>
                                <th>Durum</th>
                                <th>Açıklama</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (avanslar != null && avanslar.Any())
                            {
                                @foreach (var avans in avanslar)
                                {
                                    <tr>
                                        <td>@avans.AvansTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <strong>@avans.Personel.TamAd</strong>
                                            <br /><small class="text-muted">@avans.Personel.SoforKodu</small>
                                        </td>
                                        <td>@(avans.Firma?.FirmaAdi ?? "-")</td>
                                        <td class="text-end"><strong>@FormatPara(avans.Tutar)</strong></td>
                                        <td>
                                            <span class="badge bg-secondary">@GetOdemeSekliAdi(avans.OdemeSekli)</span>
                                        </td>
                                        <td class="text-end">
                                            @if (avans.MahsupEdilen > 0)
                                            {
                                                <span class="text-success">@FormatPara(avans.MahsupEdilen)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (avans.Kalan > 0)
                                            {
                                                <strong class="text-warning">@FormatPara(avans.Kalan)</strong>
                                            }
                                            else
                                            {
                                                <span class="text-success">0,00 ₺</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @GetDurumClass(avans.Durum)">
                                                @GetDurumAdi(avans.Durum)
                                            </span>
                                        </td>
                                        <td>
                                            <small>@(avans.Aciklama ?? "-")</small>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                @if (avans.Kalan > 0 && avans.Durum != AvansDurum.IptalEdildi)
                                                {
                                                    <button class="btn btn-outline-success" @onclick="() => MahsupModalAc(avans)" title="Mahsup Et">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                }
                                                <button class="btn btn-outline-primary" @onclick="() => DetayGor(avans)" title="Detay">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                <button class="btn btn-outline-warning" @onclick="() => DuzenleModalAc(avans)" title="Düzenle">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                @if (avans.Durum != AvansDurum.IptalEdildi && avans.MahsupEdilen == 0)
                                                {
                                                    <button class="btn btn-outline-danger" @onclick="() => IptalEt(avans)" title="İptal Et">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                        <p class="mt-2 mb-0">Avans kaydı bulunamadı</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Yeni/Düzenle Avans Modal -->
@if (showAvansModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-cash-coin me-2"></i>
                        @(editAvans.Id > 0 ? "Avans Düzenle" : "Yeni Avans")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Personel *</label>
                        <select class="form-select" @bind="editAvans.PersonelId" disabled="@(editAvans.Id > 0)">
                            <option value="0">Seçin...</option>
                            @if (personeller != null)
                            {
                                @foreach (var p in personeller)
                                {
                                    <option value="@p.Id">@p.TamAd (@p.SoforKodu)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Firma</label>
                        <select class="form-select" @bind="editAvans.FirmaId">
                            <option value="">Seçin...</option>
                            @if (firmalar != null)
                            {
                                @foreach (var f in firmalar)
                                {
                                    <option value="@f.Id">@f.FirmaAdi</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Tarih *</label>
                                <input type="date" class="form-control" @bind="editAvans.AvansTarihi" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Tutar *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editAvans.Tutar" step="0.01" min="0" />
                                    <span class="input-group-text">₺</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ödeme Şekli *</label>
                        <select class="form-select" @bind="editAvans.OdemeSekli">
                            <option value="@AvansOdemeSekli.Nakit">Nakit</option>
                            <option value="@AvansOdemeSekli.BankaTransfer">Banka Transfer</option>
                            <option value="@AvansOdemeSekli.Cek">Çek</option>
                            <option value="@AvansOdemeSekli.Senet">Senet</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Banka/Kasa Hesabı</label>
                        <select class="form-select" @bind="editAvans.BankaHesapId">
                            <option value="">Seçin...</option>
                            @if (bankaHesaplari != null)
                            {
                                @foreach (var h in bankaHesaplari)
                                {
                                    <option value="@h.Id">@h.HesapAdi</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" rows="2" @bind="editAvans.Aciklama"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="AvansKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Mahsup Modal -->
@if (showMahsupModal && secilenAvans != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>Avans Mahsup</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 mb-3">
                        <strong>@secilenAvans.Personel.TamAd</strong><br />
                        <small>Avans Tutarı: @FormatPara(secilenAvans.Tutar)</small><br />
                        <small>Mahsup Edilen: @FormatPara(secilenAvans.MahsupEdilen)</small><br />
                        <strong class="text-danger">Kalan: @FormatPara(secilenAvans.Kalan)</strong>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Mahsup Tarihi *</label>
                                <input type="date" class="form-control" @bind="yeniMahsup.MahsupTarihi" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Mahsup Tutarı *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="yeniMahsup.MahsupTutari" 
                                           step="0.01" min="0" max="@secilenAvans.Kalan" />
                                    <span class="input-group-text">₺</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mahsup Şekli *</label>
                        <select class="form-select" @bind="yeniMahsup.MahsupSekli">
                            <option value="@MahsupSekli.MaastanKesinti">Maaştan Kesinti</option>
                            <option value="@MahsupSekli.NakitIade">Nakit İade</option>
                            <option value="@MahsupSekli.BankaIade">Banka İade</option>
                            <option value="@MahsupSekli.Diger">Diğer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" rows="2" @bind="yeniMahsup.Aciklama"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-success" @onclick="MahsupKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Mahsup Et
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public int PersonelId { get; set; }

    private List<Firma>? firmalar;
    private List<Sofor>? personeller;
    private List<BankaHesap>? bankaHesaplari;
    private List<PersonelAvans>? avanslar;

    private int secilenFirmaId = 0;
    private int secilenPersonelId = 0;
    private bool sadecAciklar = false;
    private bool isLoading = true;
    private bool isSaving = false;

    // Özet değerler
    private decimal toplamAvans = 0;
    private decimal mahsupEdilen = 0;
    private decimal kalanAvans = 0;
    private int toplamAdet = 0;
    private int acikAdet = 0;
    private int mahsupTamAdet = 0;

    // Modaller
    private bool showAvansModal = false;
    private bool showMahsupModal = false;
    private PersonelAvans editAvans = new();
    private PersonelAvans? secilenAvans;
    private PersonelAvansMahsup yeniMahsup = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        personeller = await SoforService.GetActiveAsync();
        bankaHesaplari = await BankaHesapService.GetAllAsync();

        var aktifFirma = FirmaService.GetAktifFirma();
        if (!aktifFirma.TumFirmalar && aktifFirma.FirmaId > 0)
            secilenFirmaId = aktifFirma.FirmaId;

        if (PersonelId > 0)
            secilenPersonelId = PersonelId;

        await YenileData();
    }

    private async Task YenileData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            avanslar = await FinansService.GetAvanslarAsync(
                secilenFirmaId > 0 ? secilenFirmaId : null,
                secilenPersonelId > 0 ? secilenPersonelId : null
            );

            if (sadecAciklar)
                avanslar = avanslar.Where(a => a.Kalan > 0 && a.Durum != AvansDurum.IptalEdildi).ToList();

            HesaplaOzetler();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HesaplaOzetler()
    {
        if (avanslar == null || !avanslar.Any())
        {
            toplamAvans = mahsupEdilen = kalanAvans = 0;
            toplamAdet = acikAdet = mahsupTamAdet = 0;
            return;
        }

        toplamAvans = avanslar.Sum(a => a.Tutar);
        mahsupEdilen = avanslar.Sum(a => a.MahsupEdilen);
        kalanAvans = avanslar.Sum(a => a.Kalan);
        toplamAdet = avanslar.Count;
        acikAdet = avanslar.Count(a => a.Kalan > 0);
        mahsupTamAdet = avanslar.Count(a => a.Durum == AvansDurum.TamamenMahsup);
    }

    private void YeniAvansAc()
    {
        var aktifFirma = FirmaService.GetAktifFirma();
        editAvans = new PersonelAvans
        {
            AvansTarihi = DateTime.Today,
            OdemeSekli = AvansOdemeSekli.Nakit,
            FirmaId = (aktifFirma.TumFirmalar || aktifFirma.FirmaId <= 0) ? null : aktifFirma.FirmaId,
            PersonelId = secilenPersonelId > 0 ? secilenPersonelId : 0
        };
        showAvansModal = true;
    }

    private void DuzenleModalAc(PersonelAvans avans)
    {
        editAvans = new PersonelAvans
        {
            Id = avans.Id,
            PersonelId = avans.PersonelId,
            FirmaId = avans.FirmaId,
            AvansTarihi = avans.AvansTarihi,
            Tutar = avans.Tutar,
            OdemeSekli = avans.OdemeSekli,
            BankaHesapId = avans.BankaHesapId,
            Aciklama = avans.Aciklama
        };
        showAvansModal = true;
    }

    private async Task AvansKaydet()
    {
        if (editAvans.PersonelId == 0 || editAvans.Tutar <= 0)
        {
            ToastService.ShowWarning("Personel ve tutar zorunlu!");
            return;
        }

        isSaving = true;
        try
        {
            if (editAvans.Id > 0)
                await FinansService.UpdateAvansAsync(editAvans);
            else
                await FinansService.CreateAvansAsync(editAvans);

            ToastService.ShowSuccess("Avans kaydedildi!");
            ModalKapat();
            await YenileData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void MahsupModalAc(PersonelAvans avans)
    {
        secilenAvans = avans;
        yeniMahsup = new PersonelAvansMahsup
        {
            MahsupTarihi = DateTime.Today,
            MahsupTutari = avans.Kalan,
            MahsupSekli = MahsupSekli.MaastanKesinti
        };
        showMahsupModal = true;
    }

    private async Task MahsupKaydet()
    {
        if (secilenAvans == null || yeniMahsup.MahsupTutari <= 0)
        {
            ToastService.ShowWarning("Mahsup tutarı geçersiz!");
            return;
        }

        isSaving = true;
        try
        {
            await FinansService.MahsupEtAvansAsync(secilenAvans.Id, yeniMahsup);
            ToastService.ShowSuccess("Avans mahsup edildi!");
            ModalKapat();
            await YenileData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task IptalEt(PersonelAvans avans)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", 
            $"{avans.Personel.TamAd} - {FormatPara(avans.Tutar)} tutarındaki avansı iptal etmek istediğinize emin misiniz?");
        
        if (confirmed)
        {
            try
            {
                var iptalNedeni = await JS.InvokeAsync<string>("prompt", "İptal nedeni:");
                if (!string.IsNullOrWhiteSpace(iptalNedeni))
                {
                    await FinansService.IptalEtAvansAsync(avans.Id, iptalNedeni);
                    ToastService.ShowSuccess("Avans iptal edildi!");
                    await YenileData();
                }
            }
            catch (Exception ex)
            {
                ToastService.ShowError($"Hata: {ex.Message}");
            }
        }
    }

    private void DetayGor(PersonelAvans avans)
    {
        // Detay sayfası veya modal açılabilir
        ToastService.ShowInfo("Detay sayfası yakında eklenecek!");
    }

    private async Task ExcelAktar()
    {
        if (avanslar == null || !avanslar.Any())
            return;

        try
        {
            var bytes = await FinansService.ExportAvansRaporAsync(avanslar);
            var fileName = $"PersonelAvanslar_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Excel dosyası indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void ModalKapat()
    {
        showAvansModal = false;
        showMahsupModal = false;
        secilenAvans = null;
    }

    private string FormatPara(decimal tutar) => tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " ₺";
    
    private string GetOdemeSekliAdi(AvansOdemeSekli sekil) => sekil switch
    {
        AvansOdemeSekli.Nakit => "Nakit",
        AvansOdemeSekli.BankaTransfer => "Banka",
        AvansOdemeSekli.Cek => "Çek",
        AvansOdemeSekli.Senet => "Senet",
        _ => sekil.ToString()
    };

    private string GetDurumAdi(AvansDurum durum) => durum switch
    {
        AvansDurum.Verildi => "Verildi",
        AvansDurum.KismenMahsup => "Kısmen Mahsup",
        AvansDurum.TamamenMahsup => "Tamamen Mahsup",
        AvansDurum.IptalEdildi => "İptal",
        _ => durum.ToString()
    };

    private string GetDurumClass(AvansDurum durum) => durum switch
    {
        AvansDurum.Verildi => "bg-primary",
        AvansDurum.KismenMahsup => "bg-warning text-dark",
        AvansDurum.TamamenMahsup => "bg-success",
        AvansDurum.IptalEdildi => "bg-danger",
        _ => "bg-secondary"
    };
}
