@page "/personel-tasima/tedarikciler/{TedarikciId:int}/evraklar"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject ITasimaTedarikciService TedarikciService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Tedarikçi Evrakları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary" @onclick="GeriDon">
                <i class="bi bi-arrow-left"></i>
            </button>
            <h3 class="mb-0">
                <i class="bi bi-folder2-open me-2"></i>
                @if (tedarikci != null)
                {
                    <span>@tedarikci.Unvan — Evrak Yönetimi</span>
                }
            </h3>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary btn-sm" href="@($"/personel-tasima/tedarikciler/{TedarikciId}")">
                <i class="bi bi-pencil me-1"></i>Tedarikçi Düzenle
            </a>
            <button class="btn btn-outline-dark btn-sm" @onclick="TopluYazdir">
                <i class="bi bi-printer me-1"></i>Toplu Yazdır
            </button>
            @if (EvrakFiltreAktifMi)
            {
                <button class="btn btn-outline-primary btn-sm" @onclick="() => TopluZipIndir(true)" disabled="@(FiltreliEvraklar.Count == 0)">
                    <i class="bi bi-file-earmark-zip me-1"></i>Filtreli ZIP İndir
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => TopluZipIndir(false)" disabled="@(evraklar.Count == 0)">
                    <i class="bi bi-archive me-1"></i>ZIP İndir (Tümü)
                </button>
            }
            else
            {
                <button class="btn btn-outline-primary btn-sm" @onclick="() => TopluZipIndir(false)" disabled="@(evraklar.Count == 0)">
                    <i class="bi bi-file-earmark-zip me-1"></i>ZIP İndir
                </button>
            }
            <button class="btn btn-primary" @onclick="@(() => YeniEvrakAc(null))">
                <i class="bi bi-plus-lg me-1"></i>Yeni Evrak
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Ara (Evrak, Poliçe, Şirket, Açıklama)</label>
                        <input class="form-control form-control-sm" @bind="evrakArama" placeholder="Örn: sigorta, poliçe no" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Durum</label>
                        <select class="form-select form-select-sm" @bind="evrakDurumFiltre">
                            <option value="">Tümü</option>
                            @foreach (var d in Enum.GetValues<EvrakDurum>())
                            {
                                <option value="@d.ToString()">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Grup</label>
                        <select class="form-select form-select-sm" @bind="evrakGrupFiltre">
                            <option value="tum">Tümü</option>
                            <option value="surekli">Sürekli Gerekli</option>
                            <option value="diger">Diğer</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-grid">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="TemizleEvrakFiltre">Temizle</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-light h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted">Listelenen / Toplam</div>
                        <div class="h4 mb-0">@FiltreliEvraklar.Count / @ToplamEvrakSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-success-subtle h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted">Aktif</div>
                        <div class="h4 mb-0">@AktifEvrakSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-danger-subtle h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted">Süresi Dolmuş</div>
                        <div class="h4 mb-0">@SuresiDolmusEvrakSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-warning-subtle h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted">Eksik Sürekli Evrak Kategorisi</div>
                        <div class="h4 mb-0">@EksikSurekliKategoriSayisi</div>
                    </div>
                </div>
            </div>
        </div>

        @if (!FiltreliEvraklar.Any())
        {
            <div class="alert alert-warning py-2 mb-3">Filtre kriterine uygun evrak bulunamadı.</div>
        }

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-shield-check me-1"></i>Sürekli Gerekli Evraklar</h6>
                <span class="badge bg-secondary">@GorunenSurekliKategoriler.Count() kategori</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var kategori in GorunenSurekliKategoriler)
                    {
                        var kategoriEvraklari = GetKategoriEvraklari(kategori);
                        var oncelikliEvrak = GetKategoriOncelikliEvrak(kategoriEvraklari);
                        var suresiDolacak = oncelikliEvrak?.BitisTarihi.HasValue == true && oncelikliEvrak.BitisTarihi!.Value <= DateTime.Today.AddDays(30);
                        var suresiDolmus = oncelikliEvrak?.BitisTarihi.HasValue == true && oncelikliEvrak.BitisTarihi!.Value < DateTime.Today;

                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 @(suresiDolmus ? "border-danger" : suresiDolacak ? "border-warning" : oncelikliEvrak != null ? "border-success" : "border-secondary")">
                                <div class="card-header d-flex justify-content-between align-items-center py-2 @(suresiDolmus ? "bg-danger text-white" : suresiDolacak ? "bg-warning" : oncelikliEvrak != null ? "bg-success text-white" : "bg-light")">
                                    <span>
                                        <i class="bi @GetKategoriIcon(kategori) me-1"></i>
                                        @kategori
                                    </span>
                                    @if (oncelikliEvrak != null)
                                    {
                                        <span class="badge @(suresiDolmus ? "bg-light text-danger" : suresiDolacak ? "bg-dark" : "bg-light text-success")">
                                            @(suresiDolmus ? "Süresi Dolmuş" : suresiDolacak ? "Yaklaşıyor" : "Aktif")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Eksik</span>
                                    }
                                </div>
                                <div class="card-body py-2">
                                    @if (oncelikliEvrak != null)
                                    {
                                        <table class="table table-borderless table-sm mb-0">
                                            @if (oncelikliEvrak.BitisTarihi.HasValue)
                                            {
                                                <tr>
                                                    <th width="95"><small>Bitiş:</small></th>
                                                    <td>
                                                        <strong class="@(suresiDolmus ? "text-danger" : suresiDolacak ? "text-warning" : "")">
                                                            @oncelikliEvrak.BitisTarihi!.Value.ToString("dd.MM.yyyy")
                                                        </strong>
                                                    </td>
                                                </tr>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(oncelikliEvrak.PoliceNo))
                                            {
                                                <tr>
                                                    <th><small>Poliçe:</small></th>
                                                    <td>@oncelikliEvrak.PoliceNo</td>
                                                </tr>
                                            }
                                            @if (oncelikliEvrak.Tutar.HasValue)
                                            {
                                                <tr>
                                                    <th><small>Tutar:</small></th>
                                                    <td>@oncelikliEvrak.Tutar!.Value.ToString("N2") TL</td>
                                                </tr>
                                            }
                                        </table>
                                        <div class="d-flex gap-1 mt-2">
                                            <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => EvrakDetayAc(oncelikliEvrak)">
                                                <i class="bi bi-eye me-1"></i>Detay
                                            </button>
                                            <button class="btn btn-sm btn-outline-info" @onclick="() => DosyaEkleAc(oncelikliEvrak)">
                                                <i class="bi bi-paperclip"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EvrakDuzenle(oncelikliEvrak)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-2">
                                            <small class="text-muted">Bu kategoride evrak bulunamadı</small>
                                            <br />
                                            <button class="btn btn-sm btn-primary mt-2" @onclick="() => YeniEvrakAc(kategori)">
                                                <i class="bi bi-plus-lg me-1"></i>Ekle
                                            </button>
                                        </div>
                                    }
                                </div>
                                @if (kategoriEvraklari.Count > 1)
                                {
                                    <div class="card-footer py-1 bg-light">
                                        <small class="text-muted">@kategoriEvraklari.Count evrak | </small>
                                        <a href="#" class="small" @onclick="() => KategoriEvraklariniGoster(kategori)" @onclick:preventDefault>Tümü</a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-archive me-1"></i>Diğer Evraklar</h6>
                <span class="badge bg-secondary">@GorunenDigerKategoriler.Count() kategori</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var kategori in GorunenDigerKategoriler)
                    {
                        var kategoriEvraklari = GetKategoriEvraklari(kategori);
                        var oncelikliEvrak = GetKategoriOncelikliEvrak(kategoriEvraklari);
                        var suresiDolacak = oncelikliEvrak?.BitisTarihi.HasValue == true && oncelikliEvrak.BitisTarihi!.Value <= DateTime.Today.AddDays(30);
                        var suresiDolmus = oncelikliEvrak?.BitisTarihi.HasValue == true && oncelikliEvrak.BitisTarihi!.Value < DateTime.Today;

                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 @(suresiDolmus ? "border-danger" : suresiDolacak ? "border-warning" : oncelikliEvrak != null ? "border-success" : "")">
                                <div class="card-header d-flex justify-content-between align-items-center py-2 @(suresiDolmus ? "bg-danger text-white" : suresiDolacak ? "bg-warning" : oncelikliEvrak != null ? "bg-success text-white" : "")">
                                    <span>
                                        <i class="bi @GetKategoriIcon(kategori) me-1"></i>
                                        @kategori
                                    </span>
                                    @if (oncelikliEvrak != null)
                                    {
                                        <span class="badge @(suresiDolmus ? "bg-light text-danger" : suresiDolacak ? "bg-dark" : "bg-light text-success")">
                                            @(suresiDolmus ? "Süresi Dolmuş" : suresiDolacak ? "Yaklaşıyor" : "Aktif")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Evrak Yok</span>
                                    }
                                </div>
                                <div class="card-body py-2">
                                    @if (oncelikliEvrak != null)
                                    {
                                        <table class="table table-borderless table-sm mb-0">
                                            @if (oncelikliEvrak.BitisTarihi.HasValue)
                                            {
                                                <tr>
                                                    <th width="95"><small>Bitiş:</small></th>
                                                    <td><strong class="@(suresiDolmus ? "text-danger" : suresiDolacak ? "text-warning" : "")">@oncelikliEvrak.BitisTarihi!.Value.ToString("dd.MM.yyyy")</strong></td>
                                                </tr>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(oncelikliEvrak.PoliceNo))
                                            {
                                                <tr>
                                                    <th><small>Poliçe:</small></th>
                                                    <td>@oncelikliEvrak.PoliceNo</td>
                                                </tr>
                                            }
                                            @if (oncelikliEvrak.Tutar.HasValue)
                                            {
                                                <tr>
                                                    <th><small>Tutar:</small></th>
                                                    <td>@oncelikliEvrak.Tutar!.Value.ToString("N2") TL</td>
                                                </tr>
                                            }
                                        </table>
                                        <div class="d-flex gap-1 mt-2">
                                            <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => EvrakDetayAc(oncelikliEvrak)">
                                                <i class="bi bi-eye me-1"></i>Detay
                                            </button>
                                            <button class="btn btn-sm btn-outline-info" @onclick="() => DosyaEkleAc(oncelikliEvrak)">
                                                <i class="bi bi-paperclip"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EvrakDuzenle(oncelikliEvrak)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-2">
                                            <small class="text-muted">Bu kategoride evrak yok</small>
                                            <br />
                                            <button class="btn btn-sm btn-primary mt-2" @onclick="() => YeniEvrakAc(kategori)">
                                                <i class="bi bi-plus-lg me-1"></i>Ekle
                                            </button>
                                        </div>
                                    }
                                </div>
                                @if (kategoriEvraklari.Count > 1)
                                {
                                    <div class="card-footer py-1 bg-light">
                                        <small class="text-muted">@kategoriEvraklari.Count evrak | </small>
                                        <a href="#" class="small" @onclick="() => KategoriEvraklariniGoster(kategori)" @onclick:preventDefault>Tümü</a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Evrak Ekle/Düzenle Modal -->
@if (showEvrakModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editEvrak.Id > 0 ? "Evrak Düzenle" : "Yeni Evrak")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kategori *</label>
                            <select class="form-select" @bind="editEvrak.EvrakKategorisi">
                                @foreach (var kat in TedarikciEvrakKategorileri.TumKategoriler)
                                {
                                    <option value="@kat">@kat</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Evrak Adı</label>
                            <input type="text" class="form-control" @bind="editEvrak.EvrakAdi" placeholder="Örn: 2025 Ticaret Sicil" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Başlangıç Tarihi</label>
                            <input type="date" class="form-control" @bind="editEvrak.BaslangicTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bitiş Tarihi</label>
                            <input type="date" class="form-control" @bind="editEvrak.BitisTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hatırlatma</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editEvrak.HatirlatmaGunOnce" min="1" max="90" />
                                <span class="input-group-text">gün önce</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tutar</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editEvrak.Tutar" step="0.01" />
                                <span class="input-group-text">TL</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sigorta Şirketi</label>
                            <input type="text" class="form-control" @bind="editEvrak.SigortaSirketi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Poliçe No</label>
                            <input type="text" class="form-control" @bind="editEvrak.PoliceNo" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" @bind="editEvrak.Aciklama" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Durum</label>
                            <select class="form-select" @bind="editEvrak.Durum">
                                <option value="@EvrakDurum.Aktif">Aktif</option>
                                <option value="@EvrakDurum.Pasif">Pasif</option>
                                <option value="@EvrakDurum.SuresiDolmus">Süresi Dolmuş</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">&nbsp;</label>
                            <div class="form-check mt-2">
                                <input type="checkbox" class="form-check-input" @bind="editEvrak.HatirlatmaAktif" id="chkHatirlatma" />
                                <label class="form-check-label" for="chkHatirlatma">Hatırlatma Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="EvrakKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Dosya Ekle Modal -->
@if (showDosyaModal && dosyaEvrak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-paperclip me-2"></i>Dosya Ekle — @dosyaEvrak.EvrakKategorisi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (dosyaEvrak.Dosyalar.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">Mevcut Dosyalar</label>
                            <div class="list-group">
                                @foreach (var dosya in dosyaEvrak.Dosyalar)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                        <div>
                                            <i class="bi @GetDosyaIcon(dosya.DosyaTipi) me-2"></i>
                                            @dosya.DosyaAdi
                                            <small class="text-muted ms-2">(@FormatDosyaBoyutu(dosya.DosyaBoyutu))</small>
                                        </div>
                                        <div>
                                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => OnIzlemeAc(dosya, dosyaEvrak.EvrakKategorisi)">
                                                <i class="bi bi-search"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => DosyaIndir(dosya)">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DosyaSil(dosya)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Yeni Dosya Ekle</label>
                        <InputFile class="form-control" OnChange="DosyaSecildi" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <small class="text-muted">PDF, JPG, PNG, DOC dosyaları yükleyebilirsiniz (Maks 10 MB)</small>
                    </div>
                    @if (secilenDosyalar.Any())
                    {
                        <div class="alert alert-info py-2">
                            <strong>@secilenDosyalar.Count dosya seçildi</strong>
                            <ul class="mb-0 ps-3">
                                @foreach (var d in secilenDosyalar)
                                {
                                    <li><small>@d.Name (@FormatDosyaBoyutu(d.Size))</small></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                    <button type="button" class="btn btn-primary" @onclick="DosyalariYukle" disabled="@(!secilenDosyalar.Any() || isUploading)">
                        @if (isUploading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-upload me-1"></i>Yükle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Evrak Detay Modal -->
@if (showDetayModal && detayEvrak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-text me-2"></i>@detayEvrak.EvrakKategorisi — Detay</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm">
                                <tr><th width="120">Kategori:</th><td>@detayEvrak.EvrakKategorisi</td></tr>
                                <tr><th>Evrak Adı:</th><td>@detayEvrak.EvrakAdi</td></tr>
                                <tr><th>Başlangıç:</th><td>@detayEvrak.BaslangicTarihi?.ToString("dd.MM.yyyy")</td></tr>
                                <tr><th>Bitiş:</th><td><strong>@detayEvrak.BitisTarihi?.ToString("dd.MM.yyyy")</strong></td></tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm">
                                <tr><th width="120">Tutar:</th><td>@(detayEvrak.Tutar?.ToString("N2") ?? "-") TL</td></tr>
                                <tr><th>Şirket:</th><td>@detayEvrak.SigortaSirketi</td></tr>
                                <tr><th>Poliçe No:</th><td>@detayEvrak.PoliceNo</td></tr>
                                <tr><th>Durum:</th><td><span class="badge @GetDurumClass(detayEvrak.Durum)">@detayEvrak.Durum</span></td></tr>
                            </table>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(detayEvrak.Aciklama))
                    {
                        <div class="alert alert-light py-2">
                            <strong>Açıklama:</strong> @detayEvrak.Aciklama
                        </div>
                    }
                    @if (detayEvrak.Dosyalar.Any())
                    {
                        <h6 class="mt-3"><i class="bi bi-paperclip me-1"></i>Dosyalar (@detayEvrak.Dosyalar.Count)</h6>
                        <div class="list-group">
                            @foreach (var dosya in detayEvrak.Dosyalar)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <div>
                                        <i class="bi @GetDosyaIcon(dosya.DosyaTipi) me-2"></i>
                                        @dosya.DosyaAdi
                                        <small class="text-muted ms-2">(@FormatDosyaBoyutu(dosya.DosyaBoyutu))</small>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-info" @onclick="() => OnIzlemeAc(dosya, detayEvrak.EvrakKategorisi)">
                                            <i class="bi bi-search"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => DosyaIndir(dosya)">
                                            <i class="bi bi-download"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-info" @onclick="() => DosyaEkleAc(detayEvrak)">
                        <i class="bi bi-paperclip me-1"></i>Dosya Ekle
                    </button>
                    <button type="button" class="btn btn-outline-primary" @onclick="() => EvrakDuzenle(detayEvrak)">
                        <i class="bi bi-pencil me-1"></i>Düzenle
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Önizleme Modal -->
@if (showPreviewModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content" style="height:90vh;">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-eye me-2"></i>@previewTitle
                    </h5>
                    <button type="button" class="btn-close" @onclick="OnIzlemeKapat"></button>
                </div>
                <div class="modal-body p-0" style="overflow:hidden;">
                    @if (isPreviewLoading)
                    {
                        <div class="h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(previewError))
                    {
                        <div class="h-100 d-flex align-items-center justify-content-center p-4">
                            <div class="alert alert-warning mb-0">@previewError</div>
                        </div>
                    }
                    else if (previewType == "pdf" && !string.IsNullOrWhiteSpace(previewDataUrl))
                    {
                        <iframe src="@previewDataUrl" style="width:100%;height:100%;border:none;"></iframe>
                    }
                    else if (previewType == "image" && !string.IsNullOrWhiteSpace(previewDataUrl))
                    {
                        <div class="h-100 d-flex align-items-center justify-content-center bg-light">
                            <img src="@previewDataUrl" style="max-width:100%;max-height:100%;object-fit:contain;" alt="Önizleme" />
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="OnIzlemeKapat">Kapat</button>
                    @if (previewDownloadable != null)
                    {
                        <button type="button" class="btn btn-primary" @onclick="() => DosyaIndir(previewDownloadable)">
                            <i class="bi bi-download me-1"></i>İndir
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Kategori Evrak Listesi Modal -->
@if (showKategoriModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-collection me-2"></i>@(seciliKategori ?? "Kategori") Evrakları</h5>
                    <button type="button" class="btn-close" @onclick="KategoriModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (!seciliKategoriEvraklari.Any())
                    {
                        <div class="text-muted">Bu kategoride listelenecek evrak bulunamadı.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Evrak</th>
                                        <th>Başlangıç</th>
                                        <th>Bitiş</th>
                                        <th>Durum</th>
                                        <th>Dosya</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evrak in seciliKategoriEvraklari)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(evrak.EvrakAdi) ? evrak.EvrakKategorisi : evrak.EvrakAdi)</div>
                                                @if (!string.IsNullOrWhiteSpace(evrak.PoliceNo))
                                                {
                                                    <div class="small text-muted">Poliçe: @evrak.PoliceNo</div>
                                                }
                                            </td>
                                            <td>@evrak.BaslangicTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@evrak.BitisTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td><span class="badge @GetDurumClass(evrak.Durum)">@evrak.Durum</span></td>
                                            <td>@(evrak.Dosyalar?.Count ?? 0)</td>
                                            <td class="text-end" style="white-space:nowrap">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EvrakDetayAc(evrak)">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-info ms-1" @onclick="() => DosyaEkleAc(evrak)">
                                                    <i class="bi bi-paperclip"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="KategoriModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int TedarikciId { get; set; }

    private TasimaTedarikci? tedarikci;
    private List<TedarikciEvrak> evraklar = new();
    private bool isLoading = true;

    private bool showEvrakModal = false;
    private bool showDosyaModal = false;
    private bool showDetayModal = false;
    private bool showKategoriModal = false;
    private bool showPreviewModal = false;
    private TedarikciEvrak editEvrak = new();
    private TedarikciEvrak? dosyaEvrak;
    private TedarikciEvrak? detayEvrak;
    private string? seciliKategori;
    private List<TedarikciEvrak> seciliKategoriEvraklari = new();
    private bool isPreviewLoading = false;
    private string? previewDataUrl;
    private string previewType = string.Empty;
    private string previewTitle = string.Empty;
    private string? previewError;
    private TedarikciEvrakDosya? previewDownloadable;

    private List<IBrowserFile> secilenDosyalar = new();
    private bool isUploading = false;
    private string evrakArama = string.Empty;
    private string? evrakDurumFiltre;
    private string evrakGrupFiltre = "tum";

    private static readonly HashSet<string> SurekliGerekliKategoriler = new(StringComparer.OrdinalIgnoreCase)
    {
        TedarikciEvrakKategorileri.TicaretSicil,
        TedarikciEvrakKategorileri.VergiLevhasi,
        TedarikciEvrakKategorileri.ImzaSirkuleri,
        TedarikciEvrakKategorileri.YetkiBelgesi,
        TedarikciEvrakKategorileri.FaaliyetBelgesi,
        TedarikciEvrakKategorileri.SgkBelgesi,
        TedarikciEvrakKategorileri.IsGuvenligi,
        TedarikciEvrakKategorileri.SorumlulukSig
    };

    private List<string> DigerKategoriler => TedarikciEvrakKategorileri.TumKategoriler
        .Where(k => !SurekliGerekliKategoriler.Contains(k))
        .ToList();

    private bool EvrakFiltreAktifMi =>
        !string.IsNullOrWhiteSpace(evrakArama)
        || !string.IsNullOrWhiteSpace(evrakDurumFiltre)
        || !string.Equals(evrakGrupFiltre, "tum", StringComparison.OrdinalIgnoreCase);

    private List<TedarikciEvrak> FiltreliEvraklar => evraklar
        .Where(e => string.IsNullOrWhiteSpace(evrakArama)
            || (e.EvrakKategorisi?.Contains(evrakArama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (e.EvrakAdi?.Contains(evrakArama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (e.PoliceNo?.Contains(evrakArama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (e.SigortaSirketi?.Contains(evrakArama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (e.Aciklama?.Contains(evrakArama, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(e => string.IsNullOrWhiteSpace(evrakDurumFiltre)
            || string.Equals(e.Durum.ToString(), evrakDurumFiltre, StringComparison.OrdinalIgnoreCase))
        .Where(e => evrakGrupFiltre switch
        {
            "surekli" => SurekliGerekliKategoriler.Contains(e.EvrakKategorisi ?? string.Empty),
            "diger" => !SurekliGerekliKategoriler.Contains(e.EvrakKategorisi ?? string.Empty),
            _ => true
        })
        .ToList();

    private IEnumerable<string> GorunenSurekliKategoriler => SurekliGerekliKategoriler
        .Where(k => !EvrakFiltreAktifMi || GetKategoriEvraklari(k).Any());

    private IEnumerable<string> GorunenDigerKategoriler => DigerKategoriler
        .Where(k => !EvrakFiltreAktifMi || GetKategoriEvraklari(k).Any());

    private int ToplamEvrakSayisi => evraklar.Count;
    private int AktifEvrakSayisi => FiltreliEvraklar.Count(e => e.Durum == EvrakDurum.Aktif);
    private int SuresiDolmusEvrakSayisi => FiltreliEvraklar.Count(e => e.Durum == EvrakDurum.SuresiDolmus || (e.BitisTarihi.HasValue && e.BitisTarihi.Value.Date < DateTime.Today));
    private int EksikSurekliKategoriSayisi => SurekliGerekliKategoriler.Count(k => !FiltreliEvraklar.Any(e => string.Equals(e.EvrakKategorisi, k, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        tedarikci = await TedarikciService.GetAsync(TedarikciId);
        if (tedarikci == null)
        {
            Nav.NavigateTo("/personel-tasima/tedarikciler");
            return;
        }
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            evraklar = await TedarikciService.GetTedarikciEvraklariAsync(TedarikciId);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GeriDon() => Nav.NavigateTo($"/personel-tasima/tedarikciler/{TedarikciId}");

    private void YeniEvrakAc(string? kategori = null)
    {
        editEvrak = new TedarikciEvrak
        {
            TasimaTedarikciId = TedarikciId,
            EvrakKategorisi = kategori ?? TedarikciEvrakKategorileri.TicaretSicil,
            Durum = EvrakDurum.Aktif,
            HatirlatmaAktif = true,
            HatirlatmaGunOnce = 15
        };
        showEvrakModal = true;
    }

    private void EvrakDuzenle(TedarikciEvrak evrak)
    {
        editEvrak = new TedarikciEvrak
        {
            Id = evrak.Id,
            TasimaTedarikciId = evrak.TasimaTedarikciId,
            EvrakKategorisi = evrak.EvrakKategorisi,
            EvrakAdi = evrak.EvrakAdi,
            Aciklama = evrak.Aciklama,
            BaslangicTarihi = evrak.BaslangicTarihi,
            BitisTarihi = evrak.BitisTarihi,
            Tutar = evrak.Tutar,
            SigortaSirketi = evrak.SigortaSirketi,
            PoliceNo = evrak.PoliceNo,
            Durum = evrak.Durum,
            HatirlatmaAktif = evrak.HatirlatmaAktif,
            HatirlatmaGunOnce = evrak.HatirlatmaGunOnce
        };
        showDetayModal = false;
        showEvrakModal = true;
    }

    private void EvrakDetayAc(TedarikciEvrak evrak)
    {
        detayEvrak = evrak;
        showDetayModal = true;
    }

    private async Task EvrakKaydet()
    {
        if (string.IsNullOrWhiteSpace(editEvrak.EvrakKategorisi))
        {
            ToastService.ShowWarning("Kategori seçin!");
            return;
        }
        try
        {
            if (editEvrak.Id > 0)
                await TedarikciService.UpdateTedarikciEvrakAsync(editEvrak);
            else
                await TedarikciService.CreateTedarikciEvrakAsync(editEvrak);

            ToastService.ShowSuccess("Evrak kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void DosyaEkleAc(TedarikciEvrak evrak)
    {
        dosyaEvrak = evrak;
        secilenDosyalar.Clear();
        showDetayModal = false;
        showDosyaModal = true;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        secilenDosyalar = e.GetMultipleFiles(10).ToList();
    }

    private async Task DosyalariYukle()
    {
        if (dosyaEvrak == null || !secilenDosyalar.Any()) return;
        isUploading = true;
        StateHasChanged();
        try
        {
            foreach (var file in secilenDosyalar)
                await TedarikciService.UploadTedarikciEvrakDosyaAsync(dosyaEvrak.Id, file);

            ToastService.ShowSuccess($"{secilenDosyalar.Count} dosya yüklendi.");
            secilenDosyalar.Clear();
            await YenileAsync();
            dosyaEvrak = evraklar.FirstOrDefault(e => e.Id == dosyaEvrak.Id);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Yükleme hatası: " + ex.Message);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task DosyaIndir(TedarikciEvrakDosya dosya)
    {
        try
        {
            var bytes = await TedarikciService.GetTedarikciEvrakDosyaAsync(dosya.Id);
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosya.DosyaAdi, Convert.ToBase64String(bytes));
        }
        catch (Exception ex)
        {
            ToastService.ShowError("İndirme hatası: " + ex.Message);
        }
    }

    private async Task DosyaSil(TedarikciEvrakDosya dosya)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{dosya.DosyaAdi}' dosyasını silmek istediğinizden emin misiniz?");
        if (confirmed)
        {
            try
            {
                await TedarikciService.DeleteTedarikciEvrakDosyaAsync(dosya.Id);
                ToastService.ShowSuccess("Dosya silindi.");
                await YenileAsync();
                if (dosyaEvrak != null)
                    dosyaEvrak = evraklar.FirstOrDefault(e => e.Id == dosyaEvrak.Id);
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Silme hatası: " + ex.Message);
            }
        }
    }

    private async Task OnIzlemeAc(TedarikciEvrakDosya dosya, string belgeAdi)
    {
        showPreviewModal = true;
        isPreviewLoading = true;
        previewDataUrl = null;
        previewType = string.Empty;
        previewError = null;
        previewTitle = belgeAdi;
        previewDownloadable = dosya;
        StateHasChanged();

        try
        {
            var bytes = await TedarikciService.GetTedarikciEvrakDosyaAsync(dosya.Id);
            if (bytes == null || bytes.Length == 0)
            {
                previewError = "Dosya okunamadı veya boş.";
                return;
            }

            var uzanti = GetRealExtension(dosya);
            var mime = GetMimeType(uzanti.TrimStart('.'));

            if (uzanti == ".pdf")
            {
                previewType = "pdf";
                previewDataUrl = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
            }
            else if (uzanti is ".jpg" or ".jpeg" or ".png" or ".gif" or ".bmp" or ".webp")
            {
                previewType = "image";
                previewDataUrl = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
            }
            else
            {
                previewError = $"Bu dosya türü ({uzanti}) için ön izleme desteklenmiyor. Dosyayı indirip görüntüleyebilirsiniz.";
            }
        }
        catch (Exception ex)
        {
            previewError = $"Ön izleme yüklenemedi: {ex.Message}";
        }
        finally
        {
            isPreviewLoading = false;
            StateHasChanged();
        }
    }

    private void OnIzlemeKapat()
    {
        showPreviewModal = false;
        previewDataUrl = null;
        previewType = string.Empty;
        previewTitle = string.Empty;
        previewError = null;
        previewDownloadable = null;
    }

    private async Task TopluYazdir()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task TopluZipIndir(bool filtreli)
    {
        try
        {
            var seciliEvrakIdleri = filtreli
                ? FiltreliEvraklar.Select(e => e.Id).Distinct().ToList()
                : null;

            if (filtreli && (seciliEvrakIdleri == null || seciliEvrakIdleri.Count == 0))
            {
                ToastService.ShowWarning("Filtre kriterine uygun evrak bulunamadı.");
                return;
            }

            var zipBytes = await TedarikciService.GetTedarikciEvraklariZipAsync(TedarikciId, seciliEvrakIdleri);
            if (zipBytes.Length == 0)
            {
                ToastService.ShowWarning("ZIP oluşturulamadı. İndirilecek dosya bulunamadı.");
                return;
            }

            var adEki = filtreli ? "filtreli_" : string.Empty;
            var dosyaAdi = $"tedarikci_evraklari_{adEki}{TedarikciId}_{DateTime.Now:yyyyMMdd_HHmm}.zip";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(zipBytes));
            ToastService.ShowSuccess(filtreli
                ? "Filtrelenmiş tedarikçi evrakları ZIP olarak indirildi."
                : "Tedarikçi evrakları ZIP olarak indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Toplu ZIP indirme hatası: " + ex.Message);
        }
    }

    private void KategoriEvraklariniGoster(string kategori)
    {
        seciliKategori = kategori;
        seciliKategoriEvraklari = GetKategoriEvraklari(kategori);
        showKategoriModal = true;
    }

    private List<TedarikciEvrak> GetKategoriEvraklari(string kategori)
    {
        return FiltreliEvraklar
            .Where(e => string.Equals(e.EvrakKategorisi, kategori, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(e => e.Durum == EvrakDurum.Aktif)
            .ThenBy(e => e.BitisTarihi ?? DateTime.MaxValue)
            .ThenByDescending(e => e.Id)
            .ToList();
    }

    private void TemizleEvrakFiltre()
    {
        evrakArama = string.Empty;
        evrakDurumFiltre = null;
        evrakGrupFiltre = "tum";
    }

    private TedarikciEvrak? GetKategoriOncelikliEvrak(List<TedarikciEvrak> kategoriEvraklari)
    {
        return kategoriEvraklari.FirstOrDefault(e => e.Durum == EvrakDurum.Aktif)
            ?? kategoriEvraklari.FirstOrDefault();
    }

    private void KategoriModalKapat()
    {
        showKategoriModal = false;
        seciliKategori = null;
        seciliKategoriEvraklari = new();
    }

    private void ModalKapat()
    {
        showEvrakModal = false;
        showDosyaModal = false;
        showDetayModal = false;
        showKategoriModal = false;
        showPreviewModal = false;
    }

    private static string GetRealExtension(TedarikciEvrakDosya dosya)
    {
        var ad = dosya.DosyaAdi ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(ad))
        {
            while (ad.EndsWith(".enc", StringComparison.OrdinalIgnoreCase))
                ad = ad[..^4];
            var extFromName = Path.GetExtension(ad).ToLowerInvariant();
            if (!string.IsNullOrWhiteSpace(extFromName))
                return extFromName;
        }

        var tip = dosya.DosyaTipi?.Trim().TrimStart('.').ToLowerInvariant();
        return string.IsNullOrWhiteSpace(tip) ? string.Empty : "." + tip;
    }

    private static string GetMimeType(string? extension)
    {
        return extension?.ToLowerInvariant() switch
        {
            "pdf" => "application/pdf",
            "jpg" or "jpeg" => "image/jpeg",
            "png" => "image/png",
            "gif" => "image/gif",
            "bmp" => "image/bmp",
            "webp" => "image/webp",
            "doc" => "application/msword",
            "docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "xls" => "application/vnd.ms-excel",
            "xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "ppt" => "application/vnd.ms-powerpoint",
            "pptx" => "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            "txt" => "text/plain",
            "csv" => "text/csv",
            "zip" => "application/zip",
            _ => "application/octet-stream"
        };
    }

    private string GetKategoriIcon(string kategori) => kategori switch
    {
        TedarikciEvrakKategorileri.TicaretSicil    => "bi-newspaper",
        TedarikciEvrakKategorileri.VergiLevhasi    => "bi-receipt",
        TedarikciEvrakKategorileri.ImzaSirkuleri   => "bi-pen",
        TedarikciEvrakKategorileri.YetkiBelgesi    => "bi-file-earmark-check",
        TedarikciEvrakKategorileri.FaaliyetBelgesi => "bi-building",
        TedarikciEvrakKategorileri.SgkBelgesi      => "bi-shield-check",
        TedarikciEvrakKategorileri.IsGuvenligi     => "bi-shield-shaded",
        TedarikciEvrakKategorileri.SorumlulukSig   => "bi-umbrella",
        TedarikciEvrakKategorileri.KapasteRaporu   => "bi-clipboard-data",
        _                                           => "bi-file-earmark"
    };

    private string GetDosyaIcon(string? dosyaTipi) => dosyaTipi?.ToLower() switch
    {
        "pdf"                      => "bi-file-earmark-pdf text-danger",
        "jpg" or "jpeg" or "png"   => "bi-file-earmark-image text-primary",
        "doc" or "docx"            => "bi-file-earmark-word text-primary",
        _                          => "bi-file-earmark"
    };

    private string GetDurumClass(EvrakDurum durum) => durum switch
    {
        EvrakDurum.Aktif        => "bg-success",
        EvrakDurum.Pasif        => "bg-secondary",
        EvrakDurum.SuresiDolmus => "bg-danger",
        _                       => "bg-secondary"
    };

    private string FormatDosyaBoyutu(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / 1024 / 1024} MB";
    }
}
