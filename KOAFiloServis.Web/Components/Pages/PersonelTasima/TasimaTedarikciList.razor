@page "/personel-tasima/tedarikciler"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject ITasimaTedarikciService TedarikciService
@inject ICariService CariService
@inject ISoforService SoforService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Personel Taşıma - Tedarikçiler</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-truck me-2"></i>Personel Taşıma Tedarikçileri</h3>
            <small class="text-muted">Alt yüklenici (taşıma) firmalarını, personel ve araçlarını tek noktadan yönetin.</small>
        </div>
        <button class="btn btn-primary" @onclick="YeniTedarikci">
            <i class="bi bi-plus-circle me-1"></i> Yeni Tedarikçi
        </button>
    </div>

    <div class="card mb-3 border-info">
        <div class="card-header py-2 bg-info bg-opacity-10">
            <strong><i class="bi bi-person-plus me-1"></i>Hızlı Tedarikçi Oluştur</strong>
            <span class="text-muted small ms-2">Mevcut cari veya personel kaydından anında tedarikçi oluşturun</span>
        </div>
        <div class="card-body py-2">
            <ul class="nav nav-tabs nav-sm mb-2">
                <li class="nav-item">
                    <button class="nav-link @(hizliOlusturTab == "cari" ? "active" : "")" @onclick='() => hizliOlusturTab = "cari"'>
                        <i class="bi bi-building me-1"></i>Cariden
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(hizliOlusturTab == "personel" ? "active" : "")" @onclick='() => hizliOlusturTab = "personel"'>
                        <i class="bi bi-person me-1"></i>Personelden
                    </button>
                </li>
            </ul>

            @if (hizliOlusturTab == "cari")
            {
                <div class="row g-2">
                    <div class="col-md-7">
                        <label class="form-label small mb-1">Aktif Cari Ara</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Cari kodu, ünvan veya vergi no yazın..."
                               @bind="cariArama" @bind:event="oninput" />
                        @if (FiltreliCariler.Any() && seciliCariId == null)
                        {
                            <div class="border rounded mt-1 bg-white shadow-sm" style="max-height:200px;overflow-y:auto;z-index:100;position:relative">
                                @foreach (var c in FiltreliCariler)
                                {
                                    <div class="px-2 py-1 border-bottom @(cariHoverId == c.Id ? "bg-primary bg-opacity-10" : "")"
                                         @onclick="() => CariSec(c)"
                                         @onmouseenter="(e) => cariHoverId = c.Id"
                                         @onmouseleave="(e) => cariHoverId = null"
                                         style="cursor:pointer;font-size:.85rem">
                                        <span class="badge bg-secondary me-1" style="font-size:.7rem">@c.CariKodu</span>
                                        <strong>@c.Unvan</strong>
                                        @if (!string.IsNullOrEmpty(c.VergiNo))
                                        { <span class="text-muted ms-1" style="font-size:.75rem">(@c.VergiNo)</span> }
                                    </div>
                                }
                            </div>
                        }
                        @if (seciliCariId.HasValue)
                        {
                            var sc = cariler.FirstOrDefault(c => c.Id == seciliCariId.Value);
                            <div class="mt-1 px-2 py-1 bg-success bg-opacity-10 border border-success rounded d-flex justify-content-between align-items-center" style="font-size:.85rem">
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><strong>@sc?.CariKodu</strong> — @sc?.Unvan</span>
                                <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" @onclick="CariSecimTemizle" title="Seçimi temizle">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(cariArama) && !FiltreliCariler.Any() && seciliCariId == null)
                        {
                            <div class="text-muted small mt-1"><i class="bi bi-info-circle me-1"></i>Sonuç bulunamadı.</div>
                        }
                    </div>
                    <div class="col-md-auto align-self-start pt-4">
                        <button class="btn btn-sm btn-success" @onclick="CaridenHemenOlustur" disabled="@(!seciliCariId.HasValue || hizliOlusturYukleniyor)">
                            @if (hizliOlusturYukleniyor && hizliOlusturTab == "cari")
                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-check-circle me-1"></i>Hemen Oluştur
                        </button>
                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CariKopyaFormunaGit" disabled="@(!seciliCariId.HasValue)">
                            <i class="bi bi-pencil-square me-1"></i>Forma Git
                        </button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(hizliOlusturMesaj))
                    {
                        <div class="col-12"><div class="alert alert-success py-1 mb-0 small">@hizliOlusturMesaj</div></div>
                    }
                </div>
            }
            else
            {
                <div class="row g-2">
                    <div class="col-md-7">
                        <label class="form-label small mb-1">Aktif Personel Ara</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Ad, soyad veya personel kodu yazın..."
                               @bind="personelArama" @bind:event="oninput" />
                        @if (FiltreliPersoneller.Any() && seciliPersonelId == null)
                        {
                            <div class="border rounded mt-1 bg-white shadow-sm" style="max-height:200px;overflow-y:auto;z-index:100;position:relative">
                                @foreach (var p in FiltreliPersoneller)
                                {
                                    <div class="px-2 py-1 border-bottom"
                                         @onclick="() => PersonelSec(p)"
                                         style="cursor:pointer;font-size:.85rem">
                                        <span class="badge bg-secondary me-1" style="font-size:.7rem">@p.SoforKodu</span>
                                        <strong>@p.Ad @p.Soyad</strong>
                                        <span class="text-muted ms-1" style="font-size:.75rem">(@p.Gorev)</span>
                                    </div>
                                }
                            </div>
                        }
                        @if (seciliPersonelId.HasValue)
                        {
                            var sp = aktifPersoneller.FirstOrDefault(p => p.Id == seciliPersonelId.Value);
                            <div class="mt-1 px-2 py-1 bg-success bg-opacity-10 border border-success rounded d-flex justify-content-between align-items-center" style="font-size:.85rem">
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><strong>@sp?.SoforKodu</strong> — @sp?.Ad @sp?.Soyad</span>
                                <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" @onclick="PersonelSecimTemizle" title="Seçimi temizle">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(personelArama) && !FiltreliPersoneller.Any() && seciliPersonelId == null)
                        {
                            <div class="text-muted small mt-1"><i class="bi bi-info-circle me-1"></i>Sonuç bulunamadı.</div>
                        }
                    </div>
                    <div class="col-md-auto align-self-start pt-4">
                        <button class="btn btn-sm btn-success" @onclick="PersoneldenHemenOlustur" disabled="@(!seciliPersonelId.HasValue || hizliOlusturYukleniyor)">
                            @if (hizliOlusturYukleniyor && hizliOlusturTab == "personel")
                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-check-circle me-1"></i>Hemen Oluştur
                        </button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(hizliOlusturMesaj))
                    {
                        <div class="col-12"><div class="alert alert-success py-1 mb-0 small">@hizliOlusturMesaj</div></div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <input type="text" class="form-control form-control-sm" placeholder="Ara: ünvan, kod, vergi no..." @bind="aramaMetni" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="durumFiltre">
                        <option value="">Tümü (Aktif + Pasif)</option>
                        <option value="aktif">Yalnızca Aktif</option>
                        <option value="pasif">Yalnızca Pasif</option>
                    </select>
                </div>
                <div class="col-md-3 text-muted small">
                    Toplam: <strong>@FiltrelenmisTedarikciler.Count</strong> tedarikçi
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!FiltrelenmisTedarikciler.Any())
    {
        <div class="alert alert-info">Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Kod</th>
                        <th>Ünvan</th>
                        <th>Yetkili</th>
                        <th>Telefon</th>
                        <th>Vergi No</th>
                        <th>Cari</th>
                        <th class="text-center">Personel</th>
                        <th class="text-center">Araç</th>
                        <th class="text-center">Aktif İş</th>
                        <th>Sözleşme</th>
                        <th class="text-center">Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var t in FiltrelenmisTedarikciler)
                {
                    <tr>
                        <td><code>@t.TedarikciKodu</code></td>
                        <td><strong>@t.Unvan</strong></td>
                        <td>@t.YetkiliKisi</td>
                        <td>@t.Telefon</td>
                        <td>@t.VergiNo</td>
                        <td>
                            @if (t.CariId.HasValue && t.Cari != null)
                            {
                                <span class="badge bg-success-subtle text-success border border-success" title="@t.Cari.Unvan">
                                    <i class="bi bi-link-45deg"></i> @t.Cari.CariKodu
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning" title="Cari bağlantısı yok - mutabakat çalışmaz">
                                    <i class="bi bi-exclamation-triangle"></i> Eksik
                                </span>
                                var oneri = OneriCariBul(t);
                                if (oneri != null)
                                {
                                    <button class="btn btn-sm btn-outline-success ms-1 py-0"
                                            title="@($"Öneri: {oneri.CariKodu} - {oneri.Unvan}")"
                                            disabled="@(atamaYukleniyorId == t.Id)"
                                            @onclick="() => OneriyiAta(t, oneri)">
                                        @if (atamaYukleniyorId == t.Id)
                                        { <span class="spinner-border spinner-border-sm"></span> }
                                        else
                                        { <i class="bi bi-magic"></i> }
                                        <span class="small">Ata: @oneri.CariKodu</span>
                                    </button>
                                }
                            }
                        </td>
                        <td class="text-center">@(personelSayilari.GetValueOrDefault(t.Id))</td>
                        <td class="text-center">@(aracSayilari.GetValueOrDefault(t.Id))</td>
                        <td class="text-center">@(isSayilari.GetValueOrDefault(t.Id))</td>
                        <td>
                            @if (t.SozlesmeBitisTarihi.HasValue)
                            {
                                <span>@t.SozlesmeBitisTarihi.Value.ToString("dd.MM.yyyy")</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (t.Aktif)
                            { <span class="badge bg-success">Aktif</span> }
                            else
                            { <span class="badge bg-secondary">Pasif</span> }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-warning me-1" href="@($"/personel-tasima/tedarikciler/{t.Id}/evraklar")">
                                <i class="bi bi-folder2-open"></i> Evraklar
                            </a>
                            <a class="btn btn-sm btn-outline-primary" href="@($"/personel-tasima/tedarikciler/{t.Id}")">
                                <i class="bi bi-pencil"></i> Düzenle
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<TasimaTedarikci> tedarikciler = new();
    private List<Cari> cariler = new();
    private List<Sofor> aktifPersoneller = new();
    private int? seciliCariId;
    private int? seciliPersonelId;
    private string cariArama = "";
    private string personelArama = "";
    private int? cariHoverId;
    private string hizliOlusturTab = "cari";
    private bool hizliOlusturYukleniyor = false;
    private string? hizliOlusturMesaj;
    private Dictionary<int, int> personelSayilari = new();
    private Dictionary<int, int> aracSayilari = new();
    private Dictionary<int, int> isSayilari = new();
    private bool yukleniyor = true;
    private string aramaMetni = string.Empty;
    private string durumFiltre = string.Empty;
    private int? atamaYukleniyorId;

    private Cari? OneriCariBul(TasimaTedarikci t)
    {
        if (cariler.Count == 0) return null;
        if (!string.IsNullOrWhiteSpace(t.VergiNo))
        {
            var v = cariler.FirstOrDefault(c => !string.IsNullOrWhiteSpace(c.VergiNo)
                && string.Equals(c.VergiNo!.Trim(), t.VergiNo!.Trim(), StringComparison.OrdinalIgnoreCase));
            if (v != null) return v;
        }
        if (!string.IsNullOrWhiteSpace(t.Unvan))
        {
            var u = cariler.FirstOrDefault(c => !string.IsNullOrWhiteSpace(c.Unvan)
                && string.Equals(c.Unvan!.Trim(), t.Unvan!.Trim(), StringComparison.OrdinalIgnoreCase));
            if (u != null) return u;
        }
        return null;
    }

    private async Task OneriyiAta(TasimaTedarikci t, Cari c)
    {
        try
        {
            atamaYukleniyorId = t.Id;
            t.CariId = c.Id;
            t.Cari = c;
            await TedarikciService.UpdateAsync(t);
        }
        finally
        {
            atamaYukleniyorId = null;
        }
    }

    private List<Cari> FiltreliCariler => string.IsNullOrWhiteSpace(cariArama)
        ? new()
        : cariler
            .Where(c =>
                (c.CariKodu?.Contains(cariArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.Unvan?.Contains(cariArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.VergiNo?.Contains(cariArama, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(20)
            .ToList();

    private List<Sofor> FiltreliPersoneller => string.IsNullOrWhiteSpace(personelArama)
        ? new()
        : aktifPersoneller
            .Where(p =>
                (p.SoforKodu?.Contains(personelArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Ad?.Contains(personelArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Soyad?.Contains(personelArama, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Telefon?.Contains(personelArama, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(20)
            .ToList();

    private List<TasimaTedarikci> FiltrelenmisTedarikciler => tedarikciler
        .Where(t => string.IsNullOrWhiteSpace(aramaMetni)
            || (t.Unvan?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false)
            || (t.TedarikciKodu?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false)
            || (t.VergiNo?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(t => durumFiltre switch
        {
            "aktif" => t.Aktif,
            "pasif" => !t.Aktif,
            _ => true
        })
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await Yukle();
    }

    private async Task Yukle()
    {
        yukleniyor = true;
        tedarikciler = await TedarikciService.GetAllAsync();
        var tumCariler = await CariService.GetAllAsync();
        cariler = tumCariler.Where(c => c.Aktif).ToList();
        var tumPersonel = await SoforService.GetAllAsync();
        aktifPersoneller = tumPersonel.Where(p => p.Aktif).ToList();
        personelSayilari.Clear();
        aracSayilari.Clear();
        isSayilari.Clear();
        foreach (var t in tedarikciler)
        {
            personelSayilari[t.Id] = (await TedarikciService.GetTedarikciPersonelleriAsync(t.Id)).Count;
            aracSayilari[t.Id] = (await TedarikciService.GetTedarikciAraclariAsync(t.Id)).Count;
            isSayilari[t.Id] = (await TedarikciService.GetIslerAsync(t.Id))
                .Count(i => i.Durum == TasimaTedarikciIsDurum.Aktif);
        }
        yukleniyor = false;
    }

    private void YeniTedarikci() => Nav.NavigateTo("/personel-tasima/tedarikciler/yeni");

    private void CariSec(Cari c)
    {
        seciliCariId = c.Id;
        cariArama = "";
    }

    private void CariSecimTemizle()
    {
        seciliCariId = null;
        cariArama = "";
    }

    private void PersonelSec(Sofor p)
    {
        seciliPersonelId = p.Id;
        personelArama = "";
    }

    private void PersonelSecimTemizle()
    {
        seciliPersonelId = null;
        personelArama = "";
    }

    private async Task CaridenHemenOlustur()
    {
        if (!seciliCariId.HasValue) return;
        hizliOlusturYukleniyor = true;
        hizliOlusturMesaj = null;
        var olusan = await TedarikciService.CreateFromCariAsync(seciliCariId.Value, updateIfExists: true);
        hizliOlusturYukleniyor = false;
        Nav.NavigateTo($"/personel-tasima/tedarikciler/{olusan.Id}");
    }

    private async Task PersoneldenHemenOlustur()
    {
        if (!seciliPersonelId.HasValue) return;
        hizliOlusturYukleniyor = true;
        hizliOlusturMesaj = null;
        var olusan = await TedarikciService.CreateFromPersonelAsync(seciliPersonelId.Value, updateIfExists: true);
        hizliOlusturYukleniyor = false;
        Nav.NavigateTo($"/personel-tasima/tedarikciler/{olusan.Id}");
    }

    private void CariKopyaFormunaGit()
    {
        if (!seciliCariId.HasValue)
            return;
        Nav.NavigateTo($"/personel-tasima/tedarikciler/yeni?copyCariId={seciliCariId.Value}");
    }
}
