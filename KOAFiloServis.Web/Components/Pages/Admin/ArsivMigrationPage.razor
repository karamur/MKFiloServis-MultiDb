@page "/admin/arsiv-migration"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Web.Services
@inject ArchiveMigrationService MigrationService
@inject IToastService ToastService
@inject IJSRuntime JS
@inject ILogger<ArsivMigrationPage> Logger
@rendermode InteractiveServer

<PageTitle>Arşiv Taşıma</PageTitle>

<div class="container-fluid">
    <h3><i class="bi bi-archive me-2"></i>Arşiv Evrak Taşıma</h3>
    <p class="text-muted">Eski personel ve araç evraklarını yeni organize dizin yapısına taşır.</p>

    @if (isRunning)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            @statusMessage
        </div>
    }
    else if (report != null)
    {
        <div class="alert @(report.IsDryRun ? "alert-warning" : "alert-success")">
            <strong>@(report.IsDryRun ? "DRY-RUN" : "GERÇEK TAŞIMA")</strong> tamamlandı.
            Rapor: <code>@reportPath</code>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <i class="bi bi-person-badge me-1"></i>Personel Evrakları
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr><td>Toplam</td><td><strong>@report.Personel.Total</strong></td></tr>
                            <tr><td>Zaten Yeni Dizinde</td><td><span class="text-success">@report.Personel.AlreadyInNewPath</span></td></tr>
                            <tr><td>@(report.IsDryRun ? "Taşınacak" : "Taşındı")</td><td><span class="text-primary">@report.Personel.Migrated</span></td></tr>
                            <tr><td>Dosyası Eksik</td><td><span class="text-danger">@report.Personel.MissingSource</span></td></tr>
                            <tr><td>Başarısız</td><td><span class="text-danger">@report.Personel.Failed</span></td></tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-truck me-1"></i>Araç Evrakları
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr><td>Toplam</td><td><strong>@report.Arac.Total</strong></td></tr>
                            <tr><td>Zaten Yeni Dizinde</td><td><span class="text-success">@report.Arac.AlreadyInNewPath</span></td></tr>
                            <tr><td>@(report.IsDryRun ? "Taşınacak" : "Taşındı")</td><td><span class="text-primary">@report.Arac.Migrated</span></td></tr>
                            <tr><td>Dosyası Eksik</td><td><span class="text-danger">@report.Arac.MissingSource</span></td></tr>
                            <tr><td>Başarısız</td><td><span class="text-danger">@report.Arac.Failed</span></td></tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @if (report.Entries.Any(e => e.Status == "Failed" || e.Status == "Missing"))
        {
            <div class="card mb-3 border-danger">
                <div class="card-header bg-danger text-white">Sorunlu Kayıtlar (@report.Entries.Count(e => e.Status is "Failed" or "Missing"))</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-striped mb-0" style="font-size:0.8rem;">
                        <thead><tr><th>Tip</th><th>Id</th><th>Durum</th><th>Açıklama</th><th>Hata</th></tr></thead>
                        <tbody>
                            @foreach (var e in report.Entries.Where(e => e.Status is "Failed" or "Missing").Take(50))
                            {
                                <tr>
                                    <td>@e.Type</td>
                                    <td>@e.RecordId</td>
                                    <td><span class="badge @(e.Status == "Failed" ? "bg-danger" : "bg-warning text-dark")">@e.Status</span></td>
                                    <td>@e.DisplayName</td>
                                    <td><small class="text-danger">@e.Error</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (report.Entries.Any(e => e.Status is "Pending" or "Copied"))
        {
            <details class="mb-3">
                <summary>Başarılı Kayıtlar (@report.Entries.Count(e => e.Status is "Pending" or "Copied" or "Skipped"))</summary>
                <div class="table-responsive" style="max-height:400px;">
                    <table class="table table-sm table-striped" style="font-size:0.75rem;">
                        <thead><tr><th>Tip</th><th>Id</th><th>Durum</th><th>Açıklama</th><th>Kaynak</th><th>Hedef</th></tr></thead>
                        <tbody>
                            @foreach (var e in report.Entries.Where(e => e.Status is "Pending" or "Copied" or "Skipped").Take(200))
                            {
                                <tr>
                                    <td>@e.Type</td>
                                    <td>@e.RecordId</td>
                                    <td><span class="badge @(e.Status == "Copied" ? "bg-success" : e.Status == "Skipped" ? "bg-secondary" : "bg-info")">@e.Status</span></td>
                                    <td>@e.DisplayName</td>
                                    <td><small>@e.SourcePath</small></td>
                                    <td><small>@e.TargetPath</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </details>
        }
    }

    <div class="card">
        <div class="card-body">
            <h5>İşlem</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-warning" @onclick="RunDryRun" disabled="@isRunning">
                    <i class="bi bi-search me-1"></i>Analiz (Dry-Run)
                </button>
                <button class="btn btn-danger" @onclick="ConfirmExecute" disabled="@isRunning">
                    <i class="bi bi-play-circle me-1"></i>Gerçek Taşıma
                </button>
            </div>
            <small class="text-muted mt-2 d-block">
                Dry-Run: dosya kopyalanmaz, DB değişmez. Sadece rapor üretilir.<br/>
                Gerçek Taşıma: şifreli dosyalar ESKİ KONUMDA KALIR, yeni konuma KOPYALANIR, DB path güncellenir.
            </small>
        </div>
    </div>
</div>

@code {
    private bool isRunning;
    private string statusMessage = "";
    private ArchiveMigrationService.MigrationReport? report;
    private string? reportPath;

    private async Task RunDryRun()
    {
        await RunAsync(dryRun: true);
    }

    private async Task ConfirmExecute()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Emin misiniz? Bu işlem tüm eski evrakları yeni dizinlere KOPYALAYACAK ve DB kayıtlarını GÜNCELLEYECEK. Eski dosyalar silinmez.");
        if (confirmed)
            await RunAsync(dryRun: false);
    }

    private async Task RunAsync(bool dryRun)
    {
        isRunning = true;
        statusMessage = dryRun ? "Dry-run analiz yapılıyor..." : "Gerçek taşıma yapılıyor...";
        report = null;
        StateHasChanged();

        try
        {
            report = await MigrationService.ExecuteAsync(dryRun: dryRun);
            reportPath = await MigrationService.SaveReportAsync(report);
            statusMessage = "";
            var label = dryRun ? "Dry-run" : "Taşıma";
            var total = report.Personel.Migrated + report.Arac.Migrated;
            ToastService.ShowSuccess($"{label} tamamlandı. {(dryRun ? "Taşınacak" : "Taşındı")}: {total} evrak. Rapor: {reportPath}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Arşiv migration hatası");
            ToastService.ShowError($"Hata: {ex.Message}");
            statusMessage = "";
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }
}
