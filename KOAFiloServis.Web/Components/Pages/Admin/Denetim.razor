@page "/denetim"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Data
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject DenetimService DenetimService
@attribute [Authorize(Roles = "Admin,HoldingYoneticisi,Muhasebeci")]
@rendermode InteractiveServer

<PageTitle>Finans Denetim</PageTitle>

<div class="container-fluid px-3">
    <h4 class="mb-3"><i class="bi bi-shield-check me-2 text-primary"></i>Finans Denetim</h4>

    @* Filtreler *@
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="_firmaId" @bind:after="Denetle">
                        @foreach (var f in _firmalar) { <option value="@f.Id">@f.FirmaAdi</option> }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Yıl</label>
                    <select class="form-select form-select-sm" @bind="_yil" @bind:after="Denetle">
                        @for (int y = DateTime.Today.Year - 1; y <= DateTime.Today.Year + 1; y++) { <option value="@y">@y</option> }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Ay</label>
                    <select class="form-select form-select-sm" @bind="_ay" @bind:after="Denetle">
                        @for (int m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000,m,1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")))</option> }
                    </select>
                </div>
                <div class="col-auto ms-auto">
                    <button class="btn btn-outline-primary btn-sm" @onclick="IncidentLogla" disabled="@(_rapor == null || _rapor.Temiz)">
                        <i class="bi bi-journal-plus me-1"></i>Tutarsızlıkları Logla
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_yukleniyor)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
    }
    else if (_rapor != null)
    {
        @* Özet *@
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="card @(_rapor.Temiz ? "border-success" : _rapor.Skor >= 70 ? "border-warning" : "border-danger") h-100">
                    <div class="card-body py-3 text-center">
                        <div class="fs-1 mb-2">@(_rapor.Temiz ? "✅" : _rapor.Skor >= 70 ? "⚠️" : "❌")</div>
                        <h5>@_rapor.SkorDurum</h5>
                        <div class="fs-2 fw-bold @(_rapor.Skor >= 100 ? "text-success" : _rapor.Skor >= 70 ? "text-warning" : "text-danger")">@_rapor.Skor</div>
                        <small class="text-muted">@_rapor.GecenKontrol / @(_rapor.GecenKontrol + _rapor.KalanKontrol) kontrol başarılı</small>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light"><tr><th>Kontrol</th><th>Beklenen</th><th>Gerçekleşen</th><th>Fark</th><th>Sonuç</th></tr></thead>
                    <tbody>
                        @foreach (var k in _rapor.Kontroller)
                        {
                            <tr class="@(k.Gecti ? "" : "table-danger")">
                                <td class="small">@k.Ad</td>
                                <td class="text-end small">@k.Beklenen.ToString("N2")</td>
                                <td class="text-end small">@k.Gerceklesen.ToString("N2")</td>
                                <td class="text-end small @(k.Fark != 0 ? "text-danger fw-bold" : "text-success")">@k.Fark.ToString("N2")</td>
                                <td>@(k.Gecti ? "✅" : "❌")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
