@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.Extensions.Logging
@inject ILogger<EbysAIPanel> Logger

<div class="ebys-ai-panel @(Expanded ? "expanded" : "collapsed")">
    <div class="panel-header" @onclick="TogglePanel">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-robot text-primary"></i>
            <span class="fw-semibold">AI Belge Analizi</span>
            @if (_aiDurum != null)
            {
                <span class="badge @(_aiDurum.OllamaAktif ? "bg-success" : "bg-danger") badge-sm">
                    @(_aiDurum.OllamaAktif ? "Aktif" : "Pasif")
                </span>
            }
        </div>
        <i class="bi @(Expanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
    </div>

    @if (Expanded)
    {
        <div class="panel-body">
            @if (_yukleniyor)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <p class="text-muted mt-2 mb-0">@_yukleniyorMesaj</p>
                </div>
            }
            else if (_aiDurum != null && !_aiDurum.OllamaAktif)
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    AI servisi şu an aktif değil. Ollama'nın çalıştığından emin olun.
                </div>
            }
            else
            {
                <!-- Dosya Yükleme -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-file-earmark-arrow-up me-1"></i>
                        Belge Yükle (OCR + Sınıflandırma)
                    </label>
                    <InputFile OnChange="DosyaSecildi" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.bmp,.tiff" />
                    <small class="text-muted">PDF, JPG, PNG, BMP, TIFF desteklenir</small>
                </div>

                <!-- Belge Tipi Seçimi -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-tag me-1"></i>
                        Belge Grubu
                    </label>
                    <select class="form-select" @bind="_seciliBelgeTipi">
                        <option value="@BelgeTipi.EbysEvrak">EBYS Gelen/Giden Evrak</option>
                        <option value="@BelgeTipi.PersonelOzluk">Personel Özlük Belgesi</option>
                        <option value="@BelgeTipi.AracEvrak">Araç Evrakı</option>
                        <option value="@BelgeTipi.Genel">Genel Belge</option>
                    </select>
                </div>

                <!-- Manuel Metin Girişi -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-textarea-t me-1"></i>
                        veya Metin Girin
                    </label>
                    <textarea class="form-control" rows="4" @bind="_manuelMetin" 
                        placeholder="Analiz edilecek belge metnini buraya yapıştırın..."></textarea>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button class="btn btn-primary flex-fill" @onclick="SiniflandirmaYap" 
                        disabled="@(string.IsNullOrWhiteSpace(_analizMetin))">
                        <i class="bi bi-cpu me-1"></i>
                        Sınıflandır
                    </button>
                    <button class="btn btn-outline-secondary flex-fill" @onclick="OzetOlustur"
                        disabled="@(string.IsNullOrWhiteSpace(_analizMetin))">
                        <i class="bi bi-card-text me-1"></i>
                        Özet Oluştur
                    </button>
                </div>

                <!-- OCR Sonucu -->
                @if (_ocrSonuc != null)
                {
                    <div class="card mb-3 border-@(_ocrSonuc.Basarili ? "success" : "danger")">
                        <div class="card-header bg-@(_ocrSonuc.Basarili ? "success" : "danger") bg-opacity-10 py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">
                                    <i class="bi bi-file-text me-1"></i>
                                    OCR Sonucu
                                </span>
                                @if (_ocrSonuc.Basarili)
                                {
                                    <span class="badge bg-success">Güven: %@Math.Round(_ocrSonuc.GuvenSkor)</span>
                                }
                            </div>
                        </div>
                        <div class="card-body py-2">
                            @if (_ocrSonuc.Basarili)
                            {
                                <div class="small mb-2">
                                    <span class="text-muted">
                                        @_ocrSonuc.Detay?.KelimeSayisi kelime, 
                                        @_ocrSonuc.Detay?.SatirSayisi satır
                                        (@_ocrSonuc.IslemSuresi.TotalSeconds.ToString("F1")s)
                                    </span>
                                </div>
                                <div class="ocr-metin border rounded p-2 bg-light" style="max-height: 150px; overflow-y: auto;">
                                    <pre class="mb-0 small">@_ocrSonuc.Metin.Substring(0, Math.Min(_ocrSonuc.Metin.Length, 500))@(_ocrSonuc.Metin.Length > 500 ? "..." : "")</pre>
                                </div>
                            }
                            else
                            {
                                <div class="text-danger small">
                                    <i class="bi bi-x-circle me-1"></i>
                                    @_ocrSonuc.HataMesaji
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Sınıflandırma Sonucu -->
                @if (_siniflandirmaSonuc != null)
                {
                    <div class="card mb-3 border-primary">
                        <div class="card-header bg-primary bg-opacity-10 py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">
                                    <i class="bi bi-diagram-3 me-1"></i>
                                    Sınıflandırma Sonucu
                                </span>
                                <span class="badge bg-primary">Güven: %@Math.Round(_siniflandirmaSonuc.GuvenSkor)</span>
                            </div>
                        </div>
                        <div class="card-body py-2">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="fw-semibold">Tahmin Edilen Kategori:</span>
                                <span class="badge bg-success fs-6">@_siniflandirmaSonuc.TahminEdilenKategori</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_siniflandirmaSonuc.AIAciklama))
                            {
                                <div class="small text-muted">
                                    <i class="bi bi-info-circle me-1"></i>
                                    @_siniflandirmaSonuc.AIAciklama
                                </div>
                            }
                            @if (_siniflandirmaSonuc.AlternatifKategoriler?.Any() == true)
                            {
                                <div class="mt-2">
                                    <small class="text-muted">Alternatifler:</small>
                                    @foreach (var alt in _siniflandirmaSonuc.AlternatifKategoriler.Take(3))
                                    {
                                        <span class="badge bg-secondary me-1">@alt.KategoriAdi (%@Math.Round(alt.GuvenSkor))</span>
                                    }
                                </div>
                            }

                            @if (OnKategoriSecildi.HasDelegate)
                            {
                                <div class="mt-2">
                                    <button class="btn btn-sm btn-outline-success" 
                                        @onclick="() => KategoriUygula(_siniflandirmaSonuc.TahminEdilenKategori)">
                                        <i class="bi bi-check-lg me-1"></i>
                                        Kategoriyi Uygula
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Özet Sonucu -->
                @if (!string.IsNullOrWhiteSpace(_ozetSonuc))
                {
                    <div class="card mb-3 border-info">
                        <div class="card-header bg-info bg-opacity-10 py-2">
                            <span class="fw-semibold">
                                <i class="bi bi-card-text me-1"></i>
                                Belge Özeti
                            </span>
                        </div>
                        <div class="card-body py-2">
                            <p class="mb-0 small">@_ozetSonuc</p>
                        </div>
                    </div>
                }

                <!-- Anahtar Kelimeler -->
                @if (_anahtarKelimeler?.Any() == true)
                {
                    <div class="card border-secondary">
                        <div class="card-header bg-secondary bg-opacity-10 py-2">
                            <span class="fw-semibold">
                                <i class="bi bi-tags me-1"></i>
                                Anahtar Kelimeler
                            </span>
                        </div>
                        <div class="card-body py-2">
                            @foreach (var kelime in _anahtarKelimeler)
                            {
                                <span class="badge bg-outline-secondary text-dark border me-1 mb-1">@kelime</span>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

<style>
    .ebys-ai-panel {
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        cursor: pointer;
        user-select: none;
    }

    .panel-header:hover {
        background: linear-gradient(135deg, #e9ecef 0%, #dee2e6 100%);
    }

    .panel-body {
        padding: 16px;
        border-top: 1px solid #e0e0e0;
    }

    .ocr-metin pre {
        white-space: pre-wrap;
        word-wrap: break-word;
        font-family: inherit;
    }

    .badge-sm {
        font-size: 0.7rem;
        padding: 2px 6px;
    }
</style>

@code {
    [Parameter] public bool Expanded { get; set; } = true;
    [Parameter] public EventCallback<string> OnKategoriSecildi { get; set; }
    [Parameter] public EventCallback<string> OnOzetOlusturuldu { get; set; }
    [Parameter] public EventCallback<List<string>> OnAnahtarKelimelerCikarildi { get; set; }
    [Parameter] public EventCallback<string> OnMetinCikarildi { get; set; }

    [Inject] private IEbysAIService AIService { get; set; } = default!;

    private AIDurumBilgi? _aiDurum;
    private OcrSonuc? _ocrSonuc;
    private BelgeSiniflandirmaSonuc? _siniflandirmaSonuc;
    private string? _ozetSonuc;
    private List<string>? _anahtarKelimeler;

    private BelgeTipi _seciliBelgeTipi = BelgeTipi.EbysEvrak;
    private string _manuelMetin = string.Empty;
    private string _analizMetin = string.Empty;

    private bool _yukleniyor;
    private string _yukleniyorMesaj = "Yükleniyor...";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _aiDurum = await AIService.DurumKontrolAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "EbysAIPanel AI durum kontrolu basarisiz oldu");
            _aiDurum = new AIDurumBilgi { OllamaAktif = false };
        }
    }

    private void TogglePanel()
    {
        Expanded = !Expanded;
    }

    private async Task DosyaSecildi(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        _yukleniyor = true;
        _yukleniyorMesaj = "OCR işlemi yapılıyor...";
        _ocrSonuc = null;
        _siniflandirmaSonuc = null;
        StateHasChanged();

        try
        {
            // Max 10MB
            var maxSize = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxSize);
            
            _ocrSonuc = await AIService.MetinCikarAsync(stream, file.Name);
            
            if (_ocrSonuc.Basarili)
            {
                _analizMetin = _ocrSonuc.Metin;
                _manuelMetin = string.Empty;

                // Metin çıkarıldı event'i
                if (OnMetinCikarildi.HasDelegate)
                    await OnMetinCikarildi.InvokeAsync(_analizMetin);

                // Otomatik sınıflandırma
                _yukleniyorMesaj = "Belge sınıflandırılıyor...";
                StateHasChanged();
                
                _siniflandirmaSonuc = await AIService.BelgeSiniflandirAsync(_analizMetin, _seciliBelgeTipi);

                // Anahtar kelimeler
                _yukleniyorMesaj = "Anahtar kelimeler çıkarılıyor...";
                StateHasChanged();
                
                _anahtarKelimeler = await AIService.AnahtarKelimelerCikarAsync(_analizMetin, 8);
                
                if (OnAnahtarKelimelerCikarildi.HasDelegate && _anahtarKelimeler?.Any() == true)
                    await OnAnahtarKelimelerCikarildi.InvokeAsync(_anahtarKelimeler);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "EbysAIPanel dosya islemede hata (DosyaAdi={DosyaAdi})", file?.Name);
            _ocrSonuc = new OcrSonuc
            {
                Basarili = false,
                HataMesaji = $"Dosya işleme hatası: {ex.Message}"
            };
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task SiniflandirmaYap()
    {
        // Manuel metin varsa onu kullan
        if (!string.IsNullOrWhiteSpace(_manuelMetin))
            _analizMetin = _manuelMetin;

        if (string.IsNullOrWhiteSpace(_analizMetin))
            return;

        _yukleniyor = true;
        _yukleniyorMesaj = "Belge sınıflandırılıyor...";
        _siniflandirmaSonuc = null;
        StateHasChanged();

        try
        {
            _siniflandirmaSonuc = await AIService.BelgeSiniflandirAsync(_analizMetin, _seciliBelgeTipi);
            
            // Anahtar kelimeler de çıkar
            _anahtarKelimeler = await AIService.AnahtarKelimelerCikarAsync(_analizMetin, 8);
            
            if (OnAnahtarKelimelerCikarildi.HasDelegate && _anahtarKelimeler?.Any() == true)
                await OnAnahtarKelimelerCikarildi.InvokeAsync(_anahtarKelimeler);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "EbysAIPanel siniflandirma hatasi (BelgeTipi={BelgeTipi})", _seciliBelgeTipi);
            _siniflandirmaSonuc = new BelgeSiniflandirmaSonuc
            {
                Basarili = false,
                HataMesaji = ex.Message
            };
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task OzetOlustur()
    {
        if (!string.IsNullOrWhiteSpace(_manuelMetin))
            _analizMetin = _manuelMetin;

        if (string.IsNullOrWhiteSpace(_analizMetin))
            return;

        _yukleniyor = true;
        _yukleniyorMesaj = "Özet oluşturuluyor...";
        _ozetSonuc = null;
        StateHasChanged();

        try
        {
            _ozetSonuc = await AIService.BelgeOzetiOlusturAsync(_analizMetin);
            
            if (OnOzetOlusturuldu.HasDelegate && !string.IsNullOrWhiteSpace(_ozetSonuc))
                await OnOzetOlusturuldu.InvokeAsync(_ozetSonuc);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "EbysAIPanel ozet olusturma hatasi");
            _ozetSonuc = $"Özet oluşturulamadı: {ex.Message}";
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task KategoriUygula(string kategori)
    {
        if (OnKategoriSecildi.HasDelegate)
            await OnKategoriSecildi.InvokeAsync(kategori);
    }
}
