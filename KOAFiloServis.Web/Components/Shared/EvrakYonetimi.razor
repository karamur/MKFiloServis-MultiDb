@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Data
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject FileService FileService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS
@inject ILogger<EvrakYonetimi> Logger

<div class="evrak-yonetimi">
    <h6 class="mb-3"><i class="bi bi-paperclip me-2"></i>Evrak Yönetimi</h6>

    @* Opsiyonel geçerlilik tarihi *@
    <div class="mb-3 d-flex align-items-center gap-2">
        <label class="form-label mb-0 small text-muted text-nowrap"><i class="bi bi-calendar-check me-1"></i>Yüklenecek evrak için geçerlilik tarihi:</label>
        <InputDate class="form-control form-control-sm" style="width:180px" @bind-Value="_seciliTarih" />
        @if (_seciliTarih.HasValue)
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _seciliTarih = null" title="Tarihi kaldır">
                <i class="bi bi-x"></i>
            </button>
        }
    </div>

    @* Evrak Tipleri Checklist — SADECE DB'den okunur *@
    <div class="row mb-3">
        @foreach (var tip in EvrakTipleri)
        {
            var varMi = _evraklar.Any(x => x.EvrakTipi == tip && !x.IsDeleted);
            EvrakDosya? evrak = varMi ? _evraklar.First(x => x.EvrakTipi == tip && !x.IsDeleted) : null;
            var status = GetStatus(evrak);
            var bgClass = varMi switch
            {
                true when status == "EXPIRED" => "bg-danger bg-opacity-10",
                true when status == "WARNING" => "bg-warning bg-opacity-10",
                true => "bg-success bg-opacity-10",
                false => "bg-warning bg-opacity-10"
            };

            <div class="col-md-6 mb-2">
                <div class="d-flex align-items-center justify-content-between p-2 border rounded @bgClass">
                    <div>
                        <i class="bi @(varMi && status == "OK" ? "bi-check-circle-fill text-success" : status == "EXPIRED" ? "bi-x-circle-fill text-danger" : status == "WARNING" ? "bi-exclamation-triangle-fill text-warning" : "bi-exclamation-circle-fill text-warning") me-2"></i>
                        <span class="fw-semibold">@tip</span>
                        @if (!varMi)
                        {
                            <span class="badge bg-warning text-dark ms-2">Eksik</span>
                        }
                        else
                        {
                            <small class="text-muted ms-2">@evrak!.DosyaAdi</small>
                            @if (status == "EXPIRED")
                            {
                                <span class="badge bg-danger ms-1">Süresi Doldu!</span>
                            }
                            else if (status == "WARNING")
                            {
                                var kalan = (evrak!.GecerlilikTarihi!.Value - DateTime.UtcNow).Days;
                                <span class="badge bg-warning text-dark ms-1">@kalan gün kaldı</span>
                            }
                        }
                    </div>
                    <div class="btn-group btn-group-sm">
                        @if (!varMi)
                        {
                            <label class="btn btn-outline-primary btn-sm" title="Dosya Yukle">
                                <i class="bi bi-upload me-1"></i>Yükle
                                <InputFile class="d-none" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"
                                           OnChange="e => UploadEvrak(e, tip)" />
                            </label>
                        }
                        else
                        {
                            <button class="btn btn-outline-info btn-sm" @onclick="() => EvrakGor(evrak!)" title="Goruntule">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-outline-success btn-sm" @onclick="() => EvrakIndir(evrak!)" title="Indir">
                                <i class="bi bi-download"></i>
                            </button>
                            <label class="btn btn-outline-warning btn-sm" title="Guncelle (tekrar yukle)">
                                <i class="bi bi-arrow-repeat"></i>
                                <InputFile class="d-none" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"
                                           OnChange="e => UploadEvrak(e, tip)" />
                            </label>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => EvrakSil(evrak!)" title="Sil">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @* Hata mesaji *@
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger py-1 small mb-3">@_errorMessage</div>
    }

    @* Dosya Listesi *@
    @if (_evraklar.Any())
    {
        <div class="card mt-3">
            <div class="card-header py-2">
                <strong><i class="bi bi-files me-2"></i>Yüklenen Dosyalar (@_evraklar.Count)</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Evrak Tipi</th>
                            <th>Dosya Adı</th>
                            <th>Geçerlilik</th>
                            <th>Durum</th>
                            <th class="text-center">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evrak in _evraklar.OrderByDescending(x => x.YuklenmeTarihi))
                        {
                            var st = GetStatus(evrak);
                            <tr>
                                <td><span class="badge bg-primary">@evrak.EvrakTipi</span></td>
                                <td>
                                    @evrak.DosyaAdi
                                    @if (evrak.GuncellenmeTarihi.HasValue)
                                    {
                                        <small class="text-muted d-block">Güncellendi: @evrak.GuncellenmeTarihi.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                    }
                                </td>
                                <td>
                                    @if (evrak.GecerlilikTarihi.HasValue)
                                    {
                                        <span>@evrak.GecerlilikTarihi.Value.ToString("dd.MM.yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Süresiz</span>
                                    }
                                </td>
                                <td>
                                    @switch (st)
                                    {
                                        case "EXPIRED":
                                            <span class="badge bg-danger">Süresi Doldu</span>
                                            break;
                                        case "WARNING":
                                            var k = (evrak.GecerlilikTarihi!.Value - DateTime.UtcNow).Days;
                                            <span class="badge bg-warning text-dark">@k gün kaldı</span>
                                            break;
                                        default:
                                            <span class="badge bg-success">Geçerli</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-info" @onclick="() => EvrakGor(evrak)" title="Görüntüle">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-outline-success" @onclick="() => EvrakIndir(evrak)" title="İndir">
                                            <i class="bi bi-download"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick="() => EvrakSil(evrak)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? PersonelId { get; set; }
    [Parameter] public int? AracId { get; set; }
    [Parameter] public List<string> EvrakTipleri { get; set; } = new() { "Kimlik", "Ehliyet", "Saglik Raporu", "Sozlesme" };
    [Parameter] public EventCallback OnChanged { get; set; }

    private List<EvrakDosya> _evraklar = new();
    private string? _errorMessage;
    private DateTime? _seciliTarih;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvraklar();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PersonelId.HasValue && AracId.HasValue)
        {
            _errorMessage = "HATA: Aynı anda hem PersonelId hem AracId set edilemez.";
            Logger.LogError("EvrakYonetimi: PersonelId={P} ve AracId={A} aynı anda set edildi!", PersonelId, AracId);
            return;
        }
        _errorMessage = null;
        await LoadEvraklar();
    }

    private async Task LoadEvraklar()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (PersonelId.HasValue)
                _evraklar = await db.EvrakDosyalari.Where(x => x.PersonelId == PersonelId.Value && !x.IsDeleted).ToListAsync();
            else if (AracId.HasValue)
                _evraklar = await db.EvrakDosyalari.Where(x => x.AracId == AracId.Value && !x.IsDeleted).ToListAsync();
            else
                _evraklar = new();
        }
        catch (Exception ex)
        {
            _evraklar = new();
            Logger.LogError(ex, "EvrakYonetimi Load hatasi PersonelId={P} AracId={A}", PersonelId, AracId);
        }
    }

    // PART 3: Status hesaplama
    private static string GetStatus(EvrakDosya? e)
    {
        if (e == null || e.GecerlilikTarihi == null)
            return "OK";

        var days = (e.GecerlilikTarihi.Value.Date - DateTime.UtcNow.Date).Days;

        if (days < 0) return "EXPIRED";
        if (days <= 7) return "WARNING";
        return "OK";
    }

    private async Task UploadEvrak(InputFileChangeEventArgs e, string evrakTipi)
    {
        var file = e.File;
        if (file == null) return;

        _errorMessage = null;

        try
        {
            var diskAdi = await FileService.SaveAsync(file);

            await using var db = await DbFactory.CreateDbContextAsync();

            var existing = await db.EvrakDosyalari.FirstOrDefaultAsync(x =>
                x.PersonelId == PersonelId &&
                x.AracId == AracId &&
                x.EvrakTipi == evrakTipi &&
                !x.IsDeleted);

            if (existing != null)
            {
                FileService.Delete(existing.DosyaYolu);
                existing.DosyaAdi = file.Name;
                existing.DosyaYolu = diskAdi;
                existing.GuncellenmeTarihi = DateTime.UtcNow;
                existing.GecerlilikTarihi = _seciliTarih; // PART 2: tarih güncelle

                Logger.LogInformation("Evrak güncellendi: {Tip} PersonelId={P} AracId={A} Gecerlilik={G}",
                    evrakTipi, PersonelId, AracId, _seciliTarih);
            }
            else
            {
                db.EvrakDosyalari.Add(new EvrakDosya
                {
                    PersonelId = PersonelId,
                    AracId = AracId,
                    EvrakTipi = evrakTipi,
                    DosyaAdi = file.Name,
                    DosyaYolu = diskAdi,
                    GecerlilikTarihi = _seciliTarih // PART 2: tarih ekle
                });

                Logger.LogInformation("Evrak kaydedildi: {Tip} PersonelId={P} AracId={A} Gecerlilik={G}",
                    evrakTipi, PersonelId, AracId, _seciliTarih);
            }

            await db.SaveChangesAsync();
            await LoadEvraklar();
            StateHasChanged();

            if (OnChanged.HasDelegate)
                await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Yükleme hatası: {ex.Message}";
            Logger.LogError(ex, "EvrakYonetimi Upload hatasi PersonelId={P} AracId={A} Tip={T}", PersonelId, AracId, evrakTipi);
        }
    }

    private async Task EvrakGor(EvrakDosya evrak)
    {
        try
        {
            var bytes = await FileService.ReadAsync(evrak.DosyaYolu);
            var base64 = Convert.ToBase64String(bytes);
            var ext = Path.GetExtension(evrak.DosyaAdi).ToLowerInvariant();
            var mime = ext switch
            {
                ".pdf" => "application/pdf",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".png" => "image/png",
                _ => "application/octet-stream"
            };
            await JS.InvokeVoidAsync("window.open", $"data:{mime};base64,{base64}", "_blank");
        }
        catch (FileNotFoundException)
        {
            _errorMessage = $"Dosya diskte bulunamadı: {evrak.DosyaAdi}. Dosya silinmiş veya taşınmış olabilir. Yeniden yükleyin.";
            Logger.LogWarning("EvrakYonetimi View: dosya diskte yok Id={Id} Yol={Yol}", evrak.Id, evrak.DosyaYolu);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Görüntüleme hatası: {ex.Message}";
            Logger.LogError(ex, "EvrakYonetimi View hatasi Id={Id}", evrak.Id);
        }
    }

    private async Task EvrakIndir(EvrakDosya evrak)
    {
        try
        {
            var bytes = await FileService.ReadAsync(evrak.DosyaYolu);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", evrak.DosyaAdi, base64, "application/octet-stream");
            Logger.LogInformation("Evrak indirildi: Id={Id} Dosya={D}", evrak.Id, evrak.DosyaAdi);
        }
        catch (FileNotFoundException)
        {
            _errorMessage = $"Dosya diskte bulunamadı: {evrak.DosyaAdi}. Dosya silinmiş veya taşınmış olabilir. Yeniden yükleyin.";
            Logger.LogWarning("EvrakYonetimi Download: dosya diskte yok Id={Id} Yol={Yol}", evrak.Id, evrak.DosyaYolu);
        }
        catch (Exception ex)
        {
            _errorMessage = $"İndirme hatası: {ex.Message}";
            Logger.LogError(ex, "EvrakYonetimi Download hatasi Id={Id}", evrak.Id);
        }
    }

    private async Task EvrakSil(EvrakDosya evrak)
    {
        _errorMessage = null;

        // Onay al
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"\"{evrak.DosyaAdi}\" dosyasını silmek istediğinize emin misiniz?");
        if (!confirmed) return;

        try
        {
            // Diskteki dosyayı sil
            FileService.Delete(evrak.DosyaYolu);

            // DB'den soft delete — FirstOrDefaultAsync FindAsync'ten daha güvenilir
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.EvrakDosyalari
                .FirstOrDefaultAsync(x => x.Id == evrak.Id && !x.IsDeleted);

            if (entity != null)
            {
                entity.IsDeleted = true;
                await db.SaveChangesAsync();
                Logger.LogInformation("Evrak silindi: Id={Id} Tip={Tip} Dosya={D}", evrak.Id, evrak.EvrakTipi, evrak.DosyaAdi);
            }
            else
            {
                Logger.LogWarning("Evrak silme: kayit bulunamadi Id={Id}", evrak.Id);
            }

            await LoadEvraklar();
            StateHasChanged();

            if (OnChanged.HasDelegate)
                await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Silme hatası: {ex.Message}";
            Logger.LogError(ex, "EvrakYonetimi Delete hatasi Id={Id}", evrak.Id);
        }
    }
}
