{
  "DatabaseProvider": "PostgreSQL",
  "ConnectionStrings": {
    "DefaultConnection": "Host=DB_HOST;Port=5432;Database=KOAFiloServis_PreProd;Username=DB_USER;Password=DB_PASSWORD;Pooling=true;MinPoolSize=2;MaxPoolSize=30;",
    "MasterConnection_COMMENT": "Nihai mimari (2026): Tek KOAFiloServis DB.",
    "HoldingConnection_COMMENT": "Nihai mimari (2026): Holding verisi tek DB'de."
  },
  "TenantDatabase_COMMENT": "Tenant DB kaldırıldı.",
  "Jwt": {
    "Secret": "PreProd-Test-Secret-Change-Before-Production-Min-32-Chars!!",
    "Issuer": "KOAFiloServis-PreProd",
    "Audience": "KOAFiloServis-API-PreProd",
    "ExpirationHours": 12
  },
  "Email": {
    "Enabled": false,
    "SmtpHost": "smtp.yourdomain.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply-preprod@yourdomain.com",
    "FromName": "USTUN Grup Filo Servis (PreProd)"
  },
  "Backup": {
    "Enabled": false,
    "Path": "/var/koa/preprod-backups",
    "RetentionDays": 7,
    "ScheduleHour": 3
  },
  "Cache": {
    "Provider": "Memory",
    "Redis": {
      "ConnectionString": "localhost:6379",
      "InstanceName": "KoaFilo:PreProd:",
      "ConnectTimeout": 5000,
      "SyncTimeout": 1000
    },
    "DefaultExpirationMinutes": 2
  },
  "Storage": {
    "Provider": "Local",
    "S3": {
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "koa-filo-servis-preprod",
      "Region": "eu-central-1",
      "ServiceUrl": ""
    }
  },
  "IpGuvenlik": {
    "Enabled": false,
    "BeyazListe": [],
    "KaraListe": []
  },
  "PuantajEngine": {
    "AutoProcess": {
      "Enabled": false,
      "CronExpression": "0 30 0 1 * ?",
      "RetryCount": 3,
      "RetryBaseDelayMs": 2000,
      "EngineTimeoutSeconds": 600,
      "StaleTimeoutMinutes": 15
    }
  },
  "HealthChecksUI": {
    "HealthChecks": [
      { "Name": "Puantaj Job", "Uri": "/health/puantaj-job" }
    ],
    "EvaluationTimeInSeconds": 60
  },
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "KOAFiloServis.Web.Services.PuantajJobService": "Debug",
      "KOAFiloServis.Web.Services.PuantajMutexService": "Debug",
      "KOAFiloServis.Web.Services.SecureFileService": "Debug",
      "KOAFiloServis.Web.Services.BudgetService": "Debug",
      "KOAFiloServis.Web.Services.LegacyDataTransferService": "Debug"
    }
  }
}
